spec: uuid_extra1051
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module UUID class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks uuid.UUID property descriptors via __class__.__name__ == 'property'"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra1051.uuid_property_class_names:
  description: "uuid.UUID property descriptors __class__.__name__ identity"
  kind: python_call_eq
  category: property_class_names
  id_prefix: uu1051p
  columns: [id, function, args, expected]
  rows:
    - [uu1051p001, uuid.UUID.version.__class__.__name__.__eq__,       ["property"], true]
    - [uu1051p002, uuid.UUID.variant.__class__.__name__.__eq__,       ["property"], true]
    - [uu1051p003, uuid.UUID.hex.__class__.__name__.__eq__,           ["property"], true]
    - [uu1051p004, uuid.UUID.urn.__class__.__name__.__eq__,           ["property"], true]
    - [uu1051p005, uuid.UUID.node.__class__.__name__.__eq__,          ["property"], true]
    - [uu1051p006, uuid.UUID.clock_seq.__class__.__name__.__eq__,     ["property"], true]
    - [uu1051p007, uuid.UUID.clock_seq_low.__class__.__name__.__eq__, ["property"], true]
    - [uu1051p008, uuid.UUID.time.__class__.__name__.__eq__,          ["property"], true]

table uuid_extra1051.uuid_property_fget_qualnames:
  description: "uuid.UUID property fget __qualname__ identity checks"
  kind: python_call_eq
  category: property_fget_qualnames
  id_prefix: uu1051q
  columns: [id, function, args, expected]
  rows:
    - [uu1051q001, uuid.UUID.hex.__class__.__name__.__eq__,              ["property"],    true]
    - [uu1051q002, uuid.UUID.version.fget.__qualname__.__eq__,           ["UUID.version"],    true]
    - [uu1051q003, uuid.UUID.variant.fget.__qualname__.__eq__,           ["UUID.variant"],    true]
    - [uu1051q004, uuid.UUID.hex.fget.__qualname__.__eq__,               ["UUID.hex"],        true]
    - [uu1051q005, uuid.UUID.urn.fget.__qualname__.__eq__,               ["UUID.urn"],        true]
    - [uu1051q006, uuid.UUID.node.fget.__qualname__.__eq__,              ["UUID.node"],       true]
    - [uu1051q007, uuid.UUID.clock_seq.fget.__qualname__.__eq__,         ["UUID.clock_seq"],  true]
    - [uu1051q008, uuid.UUID.clock_seq_low.fget.__qualname__.__eq__,     ["UUID.clock_seq_low"], true]
    - [uu1051q009, uuid.UUID.time.fget.__qualname__.__eq__,              ["UUID.time"],       true]

table uuid_extra1051.uuid_class_identity:
  description: "uuid.UUID and uuid module class/type identity checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: uu1051c
  columns: [id, function, args, expected]
  rows:
    - [uu1051c001, uuid.UUID.__class__.__name__.__eq__,          ["type"],      true]
    - [uu1051c002, uuid.UUID.__module__.__eq__,                  ["uuid"],      true]
    - [uu1051c003, uuid.UUID.__qualname__.__eq__,                ["UUID"],      true]
    - [uu1051c004, uuid.UUID.hex.__class__.__name__.__eq__,      ["property"],  true]
    - [uu1051c005, uuid.UUID.version.fget.__class__.__name__.__eq__, ["function"], true]
    - [uu1051c006, uuid.UUID.variant.fget.__class__.__name__.__eq__, ["function"], true]
    - [uu1051c007, uuid.UUID.hex.fget.__class__.__name__.__eq__,     ["function"], true]
