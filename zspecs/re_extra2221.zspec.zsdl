    - ["re2221030", "re.Match.__dict__.__contains__", ["__repr__"], true]
    - ["re2221031", "re.RegexFlag.__dict__.__contains__", ["__repr__"], true]
    - ["re2221032", "re.error.__dict__.__contains__", ["__repr__"], false]

