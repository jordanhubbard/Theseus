spec: asyncio_extra143
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-protocol.html — Python asyncio protocol documentation"
    - "https://docs.python.org/3/library/asyncio-transport.html — Python asyncio transport documentation"
    - "https://docs.python.org/3/library/asyncio-queue.html — Python asyncio queue documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — Python asyncio synchronization documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/protocols.py, Lib/asyncio/transports.py, Lib/asyncio/queues.py, Lib/asyncio/locks.py"
  notes:
    - "This spec covers: asyncio.BaseProtocol — __doc__.__len__()==247; __name__=='BaseProtocol' (len=12); __module__=='asyncio.protocols' (len=17). asyncio.Protocol — __doc__.__len__()==810; __name__=='Protocol' (len=8); __module__=='asyncio.protocols' (len=17). asyncio.DatagramProtocol — __doc__.__eq__('Interface for datagram protocol.')==True (len=32); __name__=='DatagramProtocol' (len=16); __module__=='asyncio.protocols' (len=17). asyncio.BaseTransport — __doc__.__eq__('Base class for transports.')==True (len=26); __name__=='BaseTransport' (len=13); __module__=='asyncio.transports' (len=18). asyncio.WriteTransport — __doc__.__eq__('Interface for write-only transports.')==True (len=36); __name__=='WriteTransport' (len=14); __module__=='asyncio.transports' (len=18). asyncio.DatagramTransport — __doc__.__eq__('Interface for datagram (UDP) transports.')==True (len=40); __name__=='DatagramTransport' (len=17); __module__=='asyncio.transports' (len=18). asyncio.Queue — __doc__.__len__()==490; __name__=='Queue' (len=5); __module__=='asyncio.queues' (len=14). asyncio.Lock — __doc__.__len__()==1437; __name__=='Lock' (len=4); __module__=='asyncio.locks' (len=13). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All three protocol classes (BaseProtocol, Protocol, DatagramProtocol) share __module__=='asyncio.protocols' (len=17). All transport classes (BaseTransport, WriteTransport, DatagramTransport) share __module__=='asyncio.transports' (len=18). asyncio.Queue.__module__=='asyncio.queues' (len=14); asyncio.Lock.__module__=='asyncio.locks' (len=13). asyncio.Lock has the longest __doc__ at 1437 chars (vs Queue at 490); asyncio.Protocol has the longest protocol doc at 810 chars; asyncio.DatagramProtocol has the shortest at 32. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio protocol classes __doc__ and identity — extra143
#
# asyncio.BaseProtocol.__doc__.__len__()      == 247
# asyncio.BaseProtocol.__name__               == 'BaseProtocol' (len=12)
# asyncio.BaseProtocol.__module__             == 'asyncio.protocols' (len=17)
# asyncio.Protocol.__doc__.__len__()          == 810
# asyncio.DatagramProtocol.__doc__.__len__()  == 32
# asyncio.DatagramProtocol.__name__           == 'DatagramProtocol' (len=16)
# ---------------------------------------------------------------------------

table asyncio_extra143.protocol_classes:
  description: "asyncio protocol class __doc__ and identity checks — BaseProtocol.__doc__.__len__()==247 (multi-sentence doc describing BaseProtocol as the common base for Protocol and ProcessProtocol and the case when BaseProtocol is used directly for write-only transports); BaseProtocol.__name__.__eq__('BaseProtocol')==True (len=12: 'Base'=4+'Protocol'=8=12); BaseProtocol.__module__.__eq__('asyncio.protocols')==True (len=17: 'asyncio'=7+'.'=1+'protocols'=9=17, shared by all three protocol classes); Protocol.__doc__.__len__()==810 (the longest of the three protocol docs, multi-paragraph with subprotocol relationship description); DatagramProtocol.__doc__.__eq__('Interface for datagram protocol.')==True (len=32: shortest of the three, a single sentence); DatagramProtocol.__name__.__eq__('DatagramProtocol')==True (len=16: 'Datagram'=8+'Protocol'=8=16, the longest of the three protocol class names); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioproto143

  columns: [id, function, args, expected, description]
  rows:
    - [bp_doc_len,   asyncio.BaseProtocol.__doc__.__len__,           [],                                 247,   "asyncio.BaseProtocol.__doc__.__len__() == 247; verified with Python 3.14.3"]
    - [bp_name_eq,   asyncio.BaseProtocol.__name__.__eq__,          ["BaseProtocol"],                    true,  "asyncio.BaseProtocol.__name__ == 'BaseProtocol' (len=12); verified with Python 3.14.3"]
    - [bp_name_len,  asyncio.BaseProtocol.__name__.__len__,          [],                                 12,    "asyncio.BaseProtocol.__name__.__len__() == 12; verified with Python 3.14.3"]
    - [bp_mod_eq,    asyncio.BaseProtocol.__module__.__eq__,        ["asyncio.protocols"],               true,  "asyncio.BaseProtocol.__module__ == 'asyncio.protocols' (len=17); verified with Python 3.14.3"]
    - [bp_mod_len,   asyncio.BaseProtocol.__module__.__len__,        [],                                 17,    "asyncio.BaseProtocol.__module__.__len__() == 17; verified with Python 3.14.3"]
    - [p_doc_len,    asyncio.Protocol.__doc__.__len__,               [],                                 810,   "asyncio.Protocol.__doc__.__len__() == 810; verified with Python 3.14.3"]
    - [p_name_len,   asyncio.Protocol.__name__.__len__,              [],                                 8,     "asyncio.Protocol.__name__.__len__() == 8 ('Protocol'); verified with Python 3.14.3"]
    - [dp_doc_eq,    asyncio.DatagramProtocol.__doc__.__eq__,       ["Interface for datagram protocol."], true,  "asyncio.DatagramProtocol.__doc__ == 'Interface for datagram protocol.' (len=32); verified with Python 3.14.3"]
    - [dp_doc_len,   asyncio.DatagramProtocol.__doc__.__len__,       [],                                 32,    "asyncio.DatagramProtocol.__doc__.__len__() == 32; verified with Python 3.14.3"]
    - [dp_name_eq,   asyncio.DatagramProtocol.__name__.__eq__,      ["DatagramProtocol"],                true,  "asyncio.DatagramProtocol.__name__ == 'DatagramProtocol' (len=16); verified with Python 3.14.3"]
    - [dp_name_len,  asyncio.DatagramProtocol.__name__.__len__,      [],                                 16,    "asyncio.DatagramProtocol.__name__.__len__() == 16; verified with Python 3.14.3"]
    - [dp_mod_len,   asyncio.DatagramProtocol.__module__.__len__,    [],                                 17,    "asyncio.DatagramProtocol.__module__.__len__() == 17 ('asyncio.protocols'); verified with Python 3.14.3"]

