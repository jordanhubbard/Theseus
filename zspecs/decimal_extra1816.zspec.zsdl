spec: decimal_extra1816
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "decimal module CPython source"
    - "Python data model documentation"
  not_derived_from:
    - "any third-party decimal library"
  notes:
    - "Tests __format__, __repr__, __str__, __reduce__, __copy__, __deepcopy__ presence in class __dict__"
    - "Tests extended numeric protocol attrs for Decimal"
  created_at: "2026-04-12"

table decimal_extra1816.format_protocol:
