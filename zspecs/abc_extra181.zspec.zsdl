spec: abc_extra181
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "abc.__name__ == 'abc' (len=3); abc.__package__ == '' (empty string, not 'abc' — verified Python 3.14.3)."
    - "abc.__doc__.__class__.__name__ == 'str' — the module docstring is a str instance."
    - "abc.ABCMeta.__name__ == 'ABCMeta' (len=7); abc.ABC.__name__ == 'ABC' (len=3)."
    - "abc.abstractmethod.__name__ == 'abstractmethod' (len=14); abc.get_cache_token.__name__ == 'get_cache_token' (len=15)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc module-level attribute name equality
#
# abc.__name__.__eq__('abc') == True (len=3)
# abc.__package__.__eq__('') == True (empty string — abc has no package)
# abc.__doc__.__class__.__name__.__eq__('str') == True
# ---------------------------------------------------------------------------

table abc_extra181.module_attrs:
  description: "abc module-level attribute identity: __name__=='abc', __package__=='' (empty), __doc__ is a str; new to abc_extra181"
  kind: python_call_eq
  category: identity
  id_prefix: abcmodule181

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_eq,
       __name__.__eq__,
       ["abc"],
       true,
       "abc.__name__.__eq__('abc') == True — module name string identity; str.__eq__ returns True; new to abc_extra181"]
    - [module_name_len_3,
       __name__.__len__,
       [],
       3,
       "abc.__name__.__len__() == 3 — 'abc' has 3 characters: a-b-c; str.__len__() returns 3; new to abc_extra181"]
    - [module_package_empty,
       __package__.__eq__,
       [""],
       true,
       "abc.__package__.__eq__('') == True — abc is a top-level module: __package__ is empty string; str.__eq__ returns True; new to abc_extra181"]
    - [module_package_len_0,
       __package__.__len__,
       [],
       0,
       "abc.__package__.__len__() == 0 — empty string __package__ has length 0; str.__len__() returns 0; new to abc_extra181"]
    - [doc_class_name_eq,
       __doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "abc.__doc__.__class__.__name__.__eq__('str') == True — module docstring is a str instance; str.__eq__ returns True; new to abc_extra181"]

