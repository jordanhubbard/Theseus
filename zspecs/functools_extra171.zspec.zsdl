spec: functools_extra171
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.reduce.__doc__.__class__.__name__ 'str'; functools.reduce.__doc__.__contains__('function') True; functools.lru_cache.__module__ 'functools'; functools.cache.__module__ 'functools'; functools.total_ordering.__module__ 'functools'; functools.singledispatch.__module__ 'functools' (Wave 295)."
    - "functools.reduce.__doc__.__class__.__name__ == 'str' — functools.reduce is a C builtin function (implemented in Modules/_functoolsmodule.c); its __doc__ attribute is a plain Python str object describing the reduce operation; __class__.__name__ is 'str'. Verified with Python 3.14.3."
    - "functools.reduce.__doc__.__contains__('function') == True — the reduce docstring begins 'Apply a function of two arguments cumulatively to the items of an iterable, from...'; the word 'function' appears in that docstring; str.__contains__('function') returns True. Verified with Python 3.14.3."
    - "functools.lru_cache.__module__ == 'functools' — lru_cache is a Python function defined in Lib/functools.py; its __module__ attribute is 'functools'. Verified with Python 3.14.3."
    - "functools.cache.__module__ == 'functools' — cache is a Python function defined in Lib/functools.py (a simple unbounded memoization decorator); its __module__ attribute is 'functools'. Verified with Python 3.14.3."
    - "functools.total_ordering.__module__ == 'functools' — total_ordering is a Python function (class decorator) defined in Lib/functools.py; its __module__ attribute is 'functools'. Verified with Python 3.14.3."
    - "functools.singledispatch.__module__ == 'functools' — singledispatch is a Python function (decorator) defined in Lib/functools.py that transforms a function into a single-dispatch generic function; its __module__ attribute is 'functools'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.reduce.__doc__ string properties
#
# Wave 295 theme: functools.reduce docstring — its class name and content
# membership checks.
#
# functools.reduce.__doc__.__class__.__name__ == 'str'
# functools.reduce.__doc__.__contains__('function') == True
# functools.reduce.__doc__.__contains__('iterable') == True
# functools.reduce.__doc__.__contains__('reduce') == False (the word 'reduce'
#   does not appear in the docstring body itself)
#
# functools.reduce(function, iterable[, initializer]) is a C builtin in
# Modules/_functoolsmodule.c that applies a two-argument function cumulatively
# to the items of an iterable, reducing it to a single value. Its __doc__
# is a plain Python str. The docstring begins "Apply a function of two
# arguments cumulatively to the items of an iterable, from..." and contains
# the words 'function' and 'iterable'. New to extra171.
# ---------------------------------------------------------------------------

table functools_extra171.reduce_doc_string_properties:
  description: "functools.reduce.__doc__: __class__.__name__ 'str', contains 'function' True, contains 'iterable' True; wave 295; new to extra171"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsrdsp171

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_doc_cls_str,
       "reduce.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.reduce.__doc__.__class__.__name__.__eq__('str') == True — functools.reduce is a C builtin (Modules/_functoolsmodule.c); its __doc__ attribute is a plain Python str object; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra171"]
    - [reduce_doc_has_function,
       "reduce.__doc__.__contains__",
       ["function"],
       true,
       "functools.reduce.__doc__.__contains__('function') == True — the reduce docstring begins 'Apply a function of two arguments cumulatively to the items of an iterable, from...'; the substring 'function' appears in the docstring; str.__contains__('function') returns True; new to extra171"]
    - [reduce_doc_has_iterable,
       "reduce.__doc__.__contains__",
       ["iterable"],
       true,
       "functools.reduce.__doc__.__contains__('iterable') == True — the reduce docstring describes applying a function cumulatively 'to the items of an iterable'; the substring 'iterable' appears in the docstring; str.__contains__('iterable') returns True; new to extra171"]
    - [reduce_doc_has_apply,
       "reduce.__doc__.__contains__",
       ["Apply"],
       true,
       "functools.reduce.__doc__.__contains__('Apply') == True — the reduce docstring begins with 'Apply a function of two arguments...'; the substring 'Apply' is the first word; str.__contains__('Apply') returns True; new to extra171"]

# ---------------------------------------------------------------------------
# Table 2: functools decorator function __module__ attributes
#
# Wave 295 theme: functools decorator functions — lru_cache, cache,
# total_ordering, and singledispatch all have __module__ == 'functools'.
#
# functools.lru_cache.__module__ == 'functools'
# functools.cache.__module__ == 'functools'
# functools.total_ordering.__module__ == 'functools'
# functools.singledispatch.__module__ == 'functools'
#
# lru_cache(maxsize=128, typed=False) is a decorator that wraps a function
# with a memoizing callable that saves up to maxsize most recent calls using
# an LRU (least recently used) eviction policy. cache is an alias for
# lru_cache(maxsize=None). total_ordering fills in missing comparison methods
# given __eq__ and one of __lt__/__le__/__gt__/__ge__. singledispatch
# transforms a function into a single-dispatch generic function. All four
# are Python functions defined in Lib/functools.py with __module__ 'functools'.
# New to extra171.
# ---------------------------------------------------------------------------

table functools_extra171.decorator_function_modules:
  description: "functools: lru_cache.__module__ 'functools', cache.__module__ 'functools', total_ordering.__module__ 'functools', singledispatch.__module__ 'functools'; wave 295; new to extra171"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsdfm171

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_module_functools,
       "lru_cache.__module__.__eq__",
       ["functools"],
       true,
       "functools.lru_cache.__module__.__eq__('functools') == True — lru_cache is a Python function defined in Lib/functools.py that memoizes calls keeping up to maxsize most recent results using an LRU eviction policy; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra171"]
    - [cache_module_functools,
       "cache.__module__.__eq__",
       ["functools"],
       true,
       "functools.cache.__module__.__eq__('functools') == True — cache is a Python function defined in Lib/functools.py as an unbounded memoization decorator (equivalent to lru_cache(maxsize=None)); its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra171"]
    - [total_ordering_module_functools,
       "total_ordering.__module__.__eq__",
       ["functools"],
       true,
       "functools.total_ordering.__module__.__eq__('functools') == True — total_ordering is a Python class decorator defined in Lib/functools.py that supplies missing comparison methods given __eq__ and one ordering method; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra171"]
    - [singledispatch_module_functools,
       "singledispatch.__module__.__eq__",
       ["functools"],
       true,
       "functools.singledispatch.__module__.__eq__('functools') == True — singledispatch is a Python decorator defined in Lib/functools.py that transforms a function into a single-dispatch generic function dispatching on the type of the first argument; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra171"]

# ---------------------------------------------------------------------------
# Table 3: functools decorator function __name__ and __class__.__name__
#
# Wave 295 theme: functools decorator functions — their __name__ attributes
# and __class__.__name__ (all are Python functions, so 'function').
#
# functools.lru_cache.__name__ == 'lru_cache'
# functools.cache.__name__ == 'cache'
# functools.total_ordering.__name__ == 'total_ordering'
# functools.singledispatch.__name__ == 'singledispatch'
#
# Each of these is a regular Python function (not a class or C extension),
# so __class__.__name__ is 'function'. Their __name__ attributes match the
# attribute name used to access them from the functools module. New to extra171.
# ---------------------------------------------------------------------------

table functools_extra171.decorator_function_names:
  description: "functools: lru_cache.__name__ 'lru_cache', cache.__name__ 'cache', total_ordering.__name__ 'total_ordering', singledispatch.__name__ 'singledispatch'; wave 295; new to extra171"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsdfn171

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_name_lru_cache,
       "lru_cache.__name__.__eq__",
       ["lru_cache"],
       true,
       "functools.lru_cache.__name__.__eq__('lru_cache') == True — lru_cache is a Python function in Lib/functools.py; its __name__ attribute is 'lru_cache'; str.__eq__('lru_cache') returns True; new to extra171"]
    - [cache_name_cache,
       "cache.__name__.__eq__",
       ["cache"],
       true,
       "functools.cache.__name__.__eq__('cache') == True — cache is a Python function in Lib/functools.py; its __name__ attribute is 'cache'; str.__eq__('cache') returns True; new to extra171"]
    - [total_ordering_name,
       "total_ordering.__name__.__eq__",
       ["total_ordering"],
       true,
       "functools.total_ordering.__name__.__eq__('total_ordering') == True — total_ordering is a Python function in Lib/functools.py; its __name__ attribute is 'total_ordering'; str.__eq__('total_ordering') returns True; new to extra171"]
    - [singledispatch_name,
       "singledispatch.__name__.__eq__",
       ["singledispatch"],
       true,
       "functools.singledispatch.__name__.__eq__('singledispatch') == True — singledispatch is a Python function in Lib/functools.py; its __name__ attribute is 'singledispatch'; str.__eq__('singledispatch') returns True; new to extra171"]

# ---------------------------------------------------------------------------
# Table 4: functools.reduce.__doc__ cross-checks and class identity
#
# Wave 295 theme: functools.reduce docstring — additional membership and
# class identity cross-checks.
#
# functools.reduce.__doc__.__class__.__name__ != 'NoneType'
# functools.reduce.__doc__.__contains__('cumul') == True  (from 'cumulatively')
# functools.lru_cache.__class__.__name__ == 'function'
# functools.singledispatch.__class__.__name__ == 'function'
#
# The reduce docstring is non-None (so __class__.__name__ != 'NoneType').
# It contains the word root 'cumul' (from 'cumulatively'). The lru_cache and
# singledispatch decorators are plain Python functions; their __class__.__name__
# is 'function', not 'builtin_function_or_method' or 'type'. New to extra171.
# ---------------------------------------------------------------------------

table functools_extra171.reduce_doc_and_decorator_class_cross_checks:
  description: "functools: reduce.__doc__ class not NoneType, contains 'cumul'; lru_cache and singledispatch __class__.__name__ 'function'; wave 295; new to extra171"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsrdcc171

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_doc_not_nonetype,
       "reduce.__doc__.__class__.__name__.__eq__",
       ["NoneType"],
       false,
       "functools.reduce.__doc__.__class__.__name__.__eq__('NoneType') == False — reduce.__doc__ is a non-None str object; its __class__.__name__ is 'str' not 'NoneType'; str.__eq__('NoneType') returns False; new to extra171"]
    - [reduce_doc_has_cumul,
       "reduce.__doc__.__contains__",
       ["cumul"],
       true,
       "functools.reduce.__doc__.__contains__('cumul') == True — the reduce docstring uses 'cumulatively' to describe how the function is applied; the substring 'cumul' appears in 'cumulatively'; str.__contains__('cumul') returns True; new to extra171"]
    - [lru_cache_cls_name_function,
       "lru_cache.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.lru_cache.__class__.__name__.__eq__('function') == True — lru_cache is a regular Python function defined in Lib/functools.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra171"]
    - [singledispatch_cls_name_function,
       "singledispatch.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.singledispatch.__class__.__name__.__eq__('function') == True — singledispatch is a regular Python function defined in Lib/functools.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra171"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra171
# ---------------------------------------------------------------------------

invariant functools_extra171.reduce_doc_class_str:
  description: "functools.reduce.__doc__.__class__.__name__ == 'str' — reduce is a C builtin; its docstring is a plain Python str; wave 295; new to extra171"
  kind: python_call_eq
  function: reduce.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra171.reduce_doc_contains_function:
  description: "functools.reduce.__doc__.__contains__('function') == True — the reduce docstring describes applying 'a function of two arguments'; wave 295; new to extra171"
  kind: python_call_eq
  function: reduce.__doc__.__contains__
  args: ["function"]
  expected: true

invariant functools_extra171.reduce_doc_contains_iterable:
  description: "functools.reduce.__doc__.__contains__('iterable') == True — the reduce docstring mentions 'items of an iterable'; wave 295; new to extra171"
  kind: python_call_eq
  function: reduce.__doc__.__contains__
  args: ["iterable"]
  expected: true

invariant functools_extra171.lru_cache_module_functools:
  description: "functools.lru_cache.__module__ == 'functools' — lru_cache is defined in Lib/functools.py; wave 295; new to extra171"
  kind: python_call_eq
  function: lru_cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra171.cache_module_functools:
  description: "functools.cache.__module__ == 'functools' — cache (unbounded memoization decorator) is defined in Lib/functools.py; wave 295; new to extra171"
  kind: python_call_eq
  function: cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra171.total_ordering_module_functools:
  description: "functools.total_ordering.__module__ == 'functools' — total_ordering class decorator is defined in Lib/functools.py; wave 295; new to extra171"
  kind: python_call_eq
  function: total_ordering.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra171.singledispatch_module_functools:
  description: "functools.singledispatch.__module__ == 'functools' — singledispatch generic-function decorator is defined in Lib/functools.py; wave 295; new to extra171"
  kind: python_call_eq
  function: singledispatch.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra171.lru_cache_class_function:
  description: "functools.lru_cache.__class__.__name__ == 'function' — lru_cache is a regular Python function, not a C builtin or class; wave 295; new to extra171"
  kind: python_call_eq
  function: lru_cache.__class__.__name__.__eq__
  args: ["function"]
  expected: true
