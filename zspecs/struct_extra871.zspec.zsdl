spec: struct_extra871
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - struct
  not_derived_from:
    - ctypes
    - array
  notes:
    - Covers struct module spec, class hierarchy attributes, and method doc types
  created_at: "2026-04-12"

table struct_extra871.module_spec:
  description: Verify struct module spec class name
  kind: python_call_eq
  category: module_identity
  id_prefix: st871ms
  columns: [id, function, args, expected]
  rows:
    - [st871ms001, struct.__spec__.__class__.__name__.__eq__, ["ModuleSpec"], true]

table struct_extra871.class_hierarchy:
  description: Verify struct.Struct and struct.error class hierarchy attributes
  kind: python_call_eq
  category: class_identity
  id_prefix: st871ch
  columns: [id, function, args, expected]
  rows:
    - [st871ch001, struct.Struct.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [st871ch002, struct.error.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [st871ch003, struct.Struct.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [st871ch004, struct.error.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]

table struct_extra871.error_qualnames:
  description: Verify qualnames of struct.error dunder methods
  kind: python_call_eq
  category: qualname
  id_prefix: st871eq
  columns: [id, function, args, expected]
  rows:
    - [st871eq001, struct.error.__str__.__qualname__.__eq__, ["error.__str__"], true]
    - [st871eq002, struct.error.__repr__.__qualname__.__eq__, ["error.__repr__"], true]

table struct_extra871.doc_types:
  description: Verify doc attribute types for struct methods and functions
  kind: python_call_eq
  category: doc_identity
  id_prefix: st871dt
  columns: [id, function, args, expected]
  rows:
    - [st871dt001, struct.Struct.pack.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st871dt002, struct.Struct.unpack.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st871dt003, struct.Struct.iter_unpack.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st871dt004, struct.pack.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st871dt005, struct.unpack.__doc__.__class__.__name__.__eq__, ["str"], true]
