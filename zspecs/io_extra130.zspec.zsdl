spec: io_extra130
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/textio.c"
  notes:
    - "This spec covers: io.TextIOWrapper method __qualname__ values and lengths."
    - "TextIOWrapper is a C extension type from _io; its methods are slot wrappers with __qualname__ attributes."
    - "io.TextIOWrapper.read.__qualname__ = 'TextIOWrapper.read' (length 18)."
    - "io.TextIOWrapper.write.__qualname__ = 'TextIOWrapper.write' (length 19)."
    - "io.TextIOWrapper.readline.__qualname__ = 'TextIOWrapper.readline' (length 22)."
    - "io.TextIOWrapper.flush.__qualname__ = 'TextIOWrapper.flush' (length 19)."
    - "io.TextIOWrapper.close.__qualname__ = 'TextIOWrapper.close' (length 19)."
    - "io.TextIOWrapper.seek.__qualname__ = 'TextIOWrapper.seek' (length 18)."
    - "io.TextIOWrapper.tell.__qualname__ = 'TextIOWrapper.tell' (length 18)."
    - "io.TextIOWrapper.truncate.__qualname__ = 'TextIOWrapper.truncate' (length 22)."
    - "io.TextIOWrapper.readlines.__qualname__ = '_IOBase.readlines' (length 17) — inherited from _IOBase."
    - "io.TextIOWrapper.writelines.__qualname__ = '_IOBase.writelines' (length 18) — inherited from _IOBase."
    - "io.TextIOWrapper.__name__ = 'TextIOWrapper' and __module__ = '_io'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.TextIOWrapper read/write/readline/seek/tell method __qualname__
# All are C slot wrappers defined on TextIOWrapper itself (not inherited).
# Qualname format: 'TextIOWrapper.<method>'.
# ---------------------------------------------------------------------------

table io_extra130.TextIOWrapper_rw_qualnames:
  description: "io.TextIOWrapper read/write/readline/seek/tell method __qualname__ values and lengths"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: iotiow130

  columns: [id, function, args, expected, description]
  rows:
    - [read_qname_eq,     TextIOWrapper.read.__qualname__.__eq__,     ["TextIOWrapper.read"],     true,  "TextIOWrapper.read.__qualname__ == 'TextIOWrapper.read'"]
    - [read_qname_len,    TextIOWrapper.read.__qualname__.__len__,    [],                         18,    "TextIOWrapper.read.__qualname__ has 18 characters"]
    - [write_qname_eq,    TextIOWrapper.write.__qualname__.__eq__,    ["TextIOWrapper.write"],    true,  "TextIOWrapper.write.__qualname__ == 'TextIOWrapper.write'"]
    - [write_qname_len,   TextIOWrapper.write.__qualname__.__len__,   [],                         19,    "TextIOWrapper.write.__qualname__ has 19 characters"]
    - [readline_qname_eq, TextIOWrapper.readline.__qualname__.__eq__, ["TextIOWrapper.readline"], true,  "TextIOWrapper.readline.__qualname__ == 'TextIOWrapper.readline'"]
    - [readline_qname_len,TextIOWrapper.readline.__qualname__.__len__,[],                         22,    "TextIOWrapper.readline.__qualname__ has 22 characters"]
    - [seek_qname_eq,     TextIOWrapper.seek.__qualname__.__eq__,     ["TextIOWrapper.seek"],     true,  "TextIOWrapper.seek.__qualname__ == 'TextIOWrapper.seek'"]
    - [seek_qname_len,    TextIOWrapper.seek.__qualname__.__len__,    [],                         18,    "TextIOWrapper.seek.__qualname__ has 18 characters"]
    - [tell_qname_eq,     TextIOWrapper.tell.__qualname__.__eq__,     ["TextIOWrapper.tell"],     true,  "TextIOWrapper.tell.__qualname__ == 'TextIOWrapper.tell'"]
    - [tell_qname_len,    TextIOWrapper.tell.__qualname__.__len__,    [],                         18,    "TextIOWrapper.tell.__qualname__ has 18 characters"]

# ---------------------------------------------------------------------------
# io.TextIOWrapper flush/close/truncate method __qualname__
# flush, close, truncate are defined directly on TextIOWrapper.
# ---------------------------------------------------------------------------

table io_extra130.TextIOWrapper_flush_close_truncate_qualnames:
  description: "io.TextIOWrapper flush/close/truncate method __qualname__ values and lengths"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: iotiow130

  columns: [id, function, args, expected, description]
  rows:
    - [flush_qname_eq,    TextIOWrapper.flush.__qualname__.__eq__,    ["TextIOWrapper.flush"],    true,  "TextIOWrapper.flush.__qualname__ == 'TextIOWrapper.flush'"]
    - [flush_qname_len,   TextIOWrapper.flush.__qualname__.__len__,   [],                         19,    "TextIOWrapper.flush.__qualname__ has 19 characters"]
    - [close_qname_eq,    TextIOWrapper.close.__qualname__.__eq__,    ["TextIOWrapper.close"],    true,  "TextIOWrapper.close.__qualname__ == 'TextIOWrapper.close'"]
    - [close_qname_len,   TextIOWrapper.close.__qualname__.__len__,   [],                         19,    "TextIOWrapper.close.__qualname__ has 19 characters"]
    - [truncate_qname_eq, TextIOWrapper.truncate.__qualname__.__eq__, ["TextIOWrapper.truncate"], true,  "TextIOWrapper.truncate.__qualname__ == 'TextIOWrapper.truncate'"]
    - [truncate_qname_len,TextIOWrapper.truncate.__qualname__.__len__,[],                         22,    "TextIOWrapper.truncate.__qualname__ has 22 characters"]
    - [flush_not_read,    TextIOWrapper.flush.__qualname__.__eq__,    ["TextIOWrapper.read"],     false, "TextIOWrapper.flush.__qualname__ != 'TextIOWrapper.read'"]

# ---------------------------------------------------------------------------
# io.TextIOWrapper inherited method __qualname__ and class attrs
# readlines/writelines are inherited from _IOBase, so their __qualname__ has
# the '_IOBase' prefix rather than 'TextIOWrapper'.
# __name__ == 'TextIOWrapper', __module__ == '_io' (C extension).
# ---------------------------------------------------------------------------

table io_extra130.TextIOWrapper_inherited_and_classattrs:
  description: "io.TextIOWrapper inherited method qualnames and class __name__/__module__"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: iotiow130

  columns: [id, function, args, expected, description]
  rows:
    - [readlines_qname_eq,  TextIOWrapper.readlines.__qualname__.__eq__,  ["_IOBase.readlines"],  true,  "TextIOWrapper.readlines.__qualname__ == '_IOBase.readlines' (inherited from _IOBase)"]
    - [readlines_qname_len, TextIOWrapper.readlines.__qualname__.__len__, [],                      17,    "TextIOWrapper.readlines.__qualname__ has 17 characters"]
    - [writelines_qname_eq, TextIOWrapper.writelines.__qualname__.__eq__, ["_IOBase.writelines"], true,  "TextIOWrapper.writelines.__qualname__ == '_IOBase.writelines' (inherited from _IOBase)"]
    - [writelines_qname_len,TextIOWrapper.writelines.__qualname__.__len__,[],                      18,    "TextIOWrapper.writelines.__qualname__ has 18 characters"]
    - [name_eq,             TextIOWrapper.__name__.__eq__,                ["TextIOWrapper"],       true,  "io.TextIOWrapper.__name__ == 'TextIOWrapper'"]
    - [module_eq,           TextIOWrapper.__module__.__eq__,              ["_io"],                 true,  "io.TextIOWrapper.__module__ == '_io' (C extension, not pure Python io)"]
    - [module_not_io,       TextIOWrapper.__module__.__eq__,              ["io"],                  false, "io.TextIOWrapper.__module__ != 'io'"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra130.TextIOWrapper.read_qualname:
  description: "io.TextIOWrapper.read.__qualname__ == 'TextIOWrapper.read' (method qualname includes class prefix for C slot wrappers)"
  category: method_qualnames
  kind: python_call_eq
  function: TextIOWrapper.read.__qualname__.__eq__
  args: ["TextIOWrapper.read"]
  expected: true

invariant io_extra130.TextIOWrapper.write_qualname_len:
  description: "io.TextIOWrapper.write.__qualname__.__len__() == 19 ('TextIOWrapper.write' is 19 characters)"
  category: method_qualnames
  kind: python_call_eq
  function: TextIOWrapper.write.__qualname__.__len__
  args: []
  expected: 19

invariant io_extra130.TextIOWrapper.readline_qualname_len:
  description: "io.TextIOWrapper.readline.__qualname__.__len__() == 22 ('TextIOWrapper.readline' is 22 characters)"
  category: method_qualnames
  kind: python_call_eq
  function: TextIOWrapper.readline.__qualname__.__len__
  args: []
  expected: 22

invariant io_extra130.TextIOWrapper.readlines_qualname_is_IOBase:
  description: "io.TextIOWrapper.readlines.__qualname__ == '_IOBase.readlines' (readlines is inherited from _IOBase, so its qualname reflects the defining class)"
  category: method_qualnames
  kind: python_call_eq
  function: TextIOWrapper.readlines.__qualname__.__eq__
  args: ["_IOBase.readlines"]
  expected: true

invariant io_extra130.TextIOWrapper.module_is_underscore_io:
  description: "io.TextIOWrapper.__module__ == '_io' (TextIOWrapper is a C extension type defined in _io, not the pure-Python io wrapper)"
  category: method_qualnames
  kind: python_call_eq
  function: TextIOWrapper.__module__.__eq__
  args: ["_io"]
  expected: true

