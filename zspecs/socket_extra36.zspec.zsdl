spec: socket_extra36
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra35.zspec.zsdl — covers socket.socket __init__/__repr__/__enter__/__exit__ __qualname__.__len__(); AddressFamily/SocketKind __mro__.__len__()==6; AF_INET/SOCK_STREAM __class__.__qualname__.__len__()."
    - "socket_extra34.zspec.zsdl — covers socket.socket close/setblocking/getsockname/fileno/detach/shutdown/sendall __name__.__len__()."
    - "socket_extra33.zspec.zsdl — covers htonl/htons/ntohl/ntohs __name__.__len__()==5; create_server/gethostbyname __name__.__len__()==13; socket.__dict__['family'/'type'] descriptor class name len (8)."
    - "socket_extra32.zspec.zsdl — covers recvfrom/sendto/makefile/recvfrom_into/recv_into/connect_ex __qualname__.__len__(); getaddrinfo/getnameinfo/setdefaulttimeout/getdefaulttimeout/create_connection __name__.__len__()."
    - "socket_extra31.zspec.zsdl — covers close/setblocking/getsockname/fileno/detach/shutdown/sendall __qualname__.__len__()."
    - "socket_extra29.zspec.zsdl — covers socket.socket/__mro__.__len__()==3; setsockopt/getsockopt/settimeout/getpeername __qualname__/__name__.__len__()."
    - "socket_extra28.zspec.zsdl — covers socket.socket bind/connect/listen/accept/send/recv __qualname__.__len__() and __name__.__len__()."
  notes:
    - "This spec extends socket through socket_extra35; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: htonl/htons/ntohl/ntohs __name__.__len__()==5 (extra33); socket.socket.bind/connect/listen/accept/send/recv __qualname__/__name__.__len__() (extra28); socket.socket.close/setblocking/getsockname/fileno/detach/shutdown/sendall __qualname__/__name__.__len__() (extra31/34); socket.socket.setsockopt/getsockopt/settimeout/getpeername __qualname__/__name__.__len__() (extra29)."
    - "This spec covers: htonl/__qualname__.__len__() (NOVEL — extra33 covers htonl.__name__.__len__()==5; no prior spec checks htonl.__qualname__.__len__(); for C builtins __qualname__==__name__, so len==5; distinct __qualname__ axis); htons/__qualname__.__len__() (NOVEL — same reasoning); ntohl/__qualname__.__len__() (NOVEL — same); ntohs/__qualname__.__len__() (NOVEL — same); socket.socket.dup.__qualname__.__len__() (NOVEL — 'socket.dup' has 10 chars; dup not covered in any prior socket method qualname spec); socket.socket.get_inheritable.__qualname__.__len__() (NOVEL — 'socket.get_inheritable' has 22 chars; no prior spec covers get_inheritable); socket.socket.set_inheritable.__qualname__.__len__() (NOVEL — 'socket.set_inheritable' has 22 chars; no prior spec covers set_inheritable)."
    - "socket.htonl.__qualname__ == 'htonl' (len 5). extra33 checks htonl.__name__.__len__()==5. For C-level builtin_function_or_method objects __qualname__==__name__=='htonl', so __qualname__.__len__()==5. The __qualname__.__len__() axis is distinct from __name__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.htons.__qualname__ == 'htons' (len 5). Same as htonl. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.ntohl.__qualname__ == 'ntohl' (len 5). Same pattern. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.ntohs.__qualname__ == 'ntohs' (len 5). Same pattern. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.dup.__qualname__ == 'socket.dup' (len 10). dup() duplicates the file descriptor underlying the socket. No prior socket spec checks dup's qualname or name length. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.get_inheritable.__qualname__ == 'socket.get_inheritable' (len 22). get_inheritable() returns whether the socket fd is inheritable by child processes (added in Python 3.4). No prior socket spec checks get_inheritable in any capacity. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.set_inheritable.__qualname__ == 'socket.set_inheritable' (len 22). set_inheritable() sets whether the socket fd is inheritable (added in Python 3.4). No prior socket spec checks set_inheritable in any capacity. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# htonl/htons/ntohl/ntohs __qualname__.__len__()
#
# These four functions convert integers between host and network byte order.
# For C-level builtin_function_or_method objects, __qualname__ == __name__.
# Thus htonl.__qualname__ == 'htonl' (len 5), etc.
#
# extra33 checks htonl/htons/ntohl/ntohs __name__.__len__()==5.
# No prior spec checks __qualname__.__len__() for any of these four functions.
# The __qualname__ axis is a distinct regression invariant from __name__.
# ---------------------------------------------------------------------------

table socket_extra36.hton_ntoh_qualname_lens:
  description: "socket.htonl/htons/ntohl/ntohs __qualname__.__len__()==5 — novel __qualname__ axis; extra33 covers __name__.__len__ only; for C builtins __qualname__==__name__"
  kind: python_call_eq
  category: function_names
  id_prefix: hnql36

  columns: [id, function, args, expected]
  rows:
    - [htonl_qualname_len, htonl.__qualname__.__len__, [], 5]
    - [htons_qualname_len, htons.__qualname__.__len__, [], 5]
    - [ntohl_qualname_len, ntohl.__qualname__.__len__, [], 5]
    - [ntohs_qualname_len, ntohs.__qualname__.__len__, [], 5]

# ---------------------------------------------------------------------------
# socket.socket.dup, get_inheritable, set_inheritable __qualname__.__len__()
#
# socket.socket.dup() duplicates the file descriptor underlying the socket.
# socket.socket.get_inheritable() returns whether the socket fd is inheritable.
# socket.socket.set_inheritable() sets whether the socket fd is inheritable.
# All three were added to support Python 3.4+ process/fd management.
#
# No prior socket spec checks dup, get_inheritable, or set_inheritable in any
# capacity (not via __qualname__, __name__, or any value). These are the
# remaining uncovered socket.socket method qualname lengths.
#
#   socket.socket.dup.__qualname__             == 'socket.dup'             -> 10
#   socket.socket.get_inheritable.__qualname__ == 'socket.get_inheritable' -> 22
#   socket.socket.set_inheritable.__qualname__ == 'socket.set_inheritable' -> 22
# ---------------------------------------------------------------------------

table socket_extra36.socket_fd_management_qualname_lens:
  description: "socket.socket.dup/get_inheritable/set_inheritable __qualname__.__len__() — all novel; no prior socket spec covers these three methods in any capacity"
  kind: python_call_eq
  category: function_names
  id_prefix: sfdmql36

  columns: [id, function, args, expected]
  rows:
    - [dup_qualname_len,             "socket.dup.__qualname__.__len__",             [], 10]
    - [get_inheritable_qualname_len, "socket.get_inheritable.__qualname__.__len__", [], 22]
    - [set_inheritable_qualname_len, "socket.set_inheritable.__qualname__.__len__", [], 22]
