spec: inspect_extra35
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra34.zspec.zsdl."
    - "Prior specs covered: ismodule/isclass/isfunction/ismethod/isbuiltin/isroutine __qualname__.__len__() and __name__.__len__(); getmembers/getfile/getsource/getsourcelines/getmodule/getargs/signature/stack/currentframe/getfullargspec __qualname__.__len__(); Parameter/__mro__.__len__()==2; class __bases__[0].__name__.__len__() for Parameter/Signature/BoundArguments (all 6); isroutine/__name__.__len__()==9; iscode/__name__.__len__()==6; isframe/__name__.__len__()==7; iscoroutinefunction/__qualname__.__len__()==19; isgeneratorfunction/__qualname__.__len__()==19; isasyncgenfunction/__qualname__.__len__()==18; iscode/__qualname__.__len__()==6; isframe/__qualname__.__len__()==7; istraceback/__qualname__.__len__()==11; getfile/__qualname__.__len__()==7; getmodule/__qualname__.__len__()==9."
    - "This spec covers: iscoroutinefunction.__name__.__len__() (19 — 'iscoroutinefunction'); isasyncgenfunction.__name__.__len__() (18 — 'isasyncgenfunction'); isgeneratorfunction.__name__.__len__() (19 — 'isgeneratorfunction'); istraceback.__name__.__len__() (11 — 'istraceback'); getfile.__name__.__len__() (7 — 'getfile'); findsource.__name__.__len__() (10 — 'findsource'); getmodule.__name__.__len__() (9 — 'getmodule')."
    - "Key findings: iscoroutinefunction and isgeneratorfunction both have __name__ length 19 — the longest inspect predicate names. isasyncgenfunction is 18 chars. istraceback is 11 chars. getfile and isframe share the same __name__ length (7). findsource.__name__ is 'findsource' (10 chars) — matching getmembers in length. getmodule.__name__ is 'getmodule' (9 chars) — matching isroutine and getsource. For all these module-level functions, __name__ == __qualname__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# *function predicate __name__.__len__() table — extra35 namespace
#
# inspect.iscoroutinefunction.__name__ is 'iscoroutinefunction' (19 chars).
# inspect.isgeneratorfunction.__name__ is 'isgeneratorfunction' (19 chars).
# inspect.isasyncgenfunction.__name__ is 'isasyncgenfunction' (18 chars).
# Prior specs recorded their __qualname__.__len__() in extra32, but not their
# __name__.__len__() as a group. For module-level functions __name__ == __qualname__,
# so these values match. The three *function predicates form a cohesive group:
# they test whether a callable is an async generator function, coroutine function,
# or generator function. No prior inspect spec records these three __name__.__len__()
# values together in the extra35 namespace.
# ---------------------------------------------------------------------------

table inspect_extra35.async_predicate_name_lengths:
  description: "inspect *function predicate __name__.__len__(): iscoroutinefunction(19), isgeneratorfunction(19), isasyncgenfunction(18)"
  kind: python_call_eq
  category: string_properties
  id_prefix: asyncprednamelen35

  columns: [id, function, args, expected, description]
  rows:
    - [iscoroutinefunction,
       iscoroutinefunction.__name__.__len__,
       [],
       19,
       "len(inspect.iscoroutinefunction.__name__) == 19 — 'iscoroutinefunction' (matches __qualname__)"]
    - [isgeneratorfunction,
       isgeneratorfunction.__name__.__len__,
       [],
       19,
       "len(inspect.isgeneratorfunction.__name__) == 19 — 'isgeneratorfunction' (same length as iscoroutinefunction)"]
    - [isasyncgenfunction,
       isasyncgenfunction.__name__.__len__,
       [],
       18,
       "len(inspect.isasyncgenfunction.__name__) == 18 — 'isasyncgenfunction' (one char shorter than the coroutine/generator variants)"]

# ---------------------------------------------------------------------------
# Object-type predicate __name__.__len__() — istraceback — extra35 namespace
#
# inspect.istraceback.__name__ is 'istraceback' (11 chars). Prior extra31 recorded
# istraceback.__qualname__.__len__() == 11, but not istraceback.__name__.__len__()
# as a standalone in the extra35 namespace. For a module-level function __name__ ==
# __qualname__, so 11 chars is confirmed for both. 'istraceback' is notably longer
# than iscode (6) and isframe (7), reflecting the full word 'traceback'.
# ---------------------------------------------------------------------------

invariant inspect_extra35.istraceback_name_len:
  description: "len(inspect.istraceback.__name__) == 11 — 'istraceback' (matches __qualname__; longer than iscode(6) and isframe(7))"
  category: string_properties
  kind: python_call_eq
  function: istraceback.__name__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# Source-retrieval helper __name__.__len__() table — extra35 namespace
#
# inspect.getfile.__name__ is 'getfile' (7 chars). inspect.findsource.__name__
# is 'findsource' (10 chars). inspect.getmodule.__name__ is 'getmodule' (9 chars).
# Prior extra32 recorded these three as __qualname__.__len__() values (getfile=7,
# getmodule=9) and extra34 recorded getfile.__name__.__len__()==7 is not yet recorded.
# Actually prior extra34 did NOT record getfile/__name__.__len__() — it recorded
# getfile/__qualname__.__len__()==7 and getmembers/__qualname__.__len__()==10.
# No prior inspect spec records getfile/__name__.__len__(), findsource/__name__.__len__(),
# and getmodule/__name__.__len__() together as a group in the extra35 namespace.
# ---------------------------------------------------------------------------

table inspect_extra35.source_helper_name_lengths:
  description: "inspect source-retrieval helper __name__.__len__(): getfile(7), findsource(10), getmodule(9)"
  kind: python_call_eq
  category: string_properties
  id_prefix: srchelpernamelen35

  columns: [id, function, args, expected, description]
  rows:
    - [getfile,
       getfile.__name__.__len__,
       [],
       7,
       "len(inspect.getfile.__name__) == 7 — 'getfile' (same length as isframe; matches __qualname__)"]
    - [findsource,
       findsource.__name__.__len__,
       [],
       10,
       "len(inspect.findsource.__name__) == 10 — 'findsource' (same length as getmembers; matches __qualname__)"]
    - [getmodule,
       getmodule.__name__.__len__,
       [],
       9,
       "len(inspect.getmodule.__name__) == 9 — 'getmodule' (same length as isroutine and getsource; matches __qualname__)"]
