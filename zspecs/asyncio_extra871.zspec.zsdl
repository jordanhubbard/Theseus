spec: asyncio_extra871
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - asyncio
  not_derived_from:
    - typing
    - contextlib
  notes:
    - asyncio class type identity checks via __class__.__name__
  created_at: "2026-04-12"

table asyncio_extra871.class_type_identity:
  description: Verify that asyncio class objects have __class__.__name__ equal to 'type'
  kind: python_call_eq
  category: type_identity
  id_prefix: as871xx
  columns: [id, function, args, expected]
  rows:
    - [as871xx001, asyncio.Task.__class__.__name__.__eq__, ["type"], true]
    - [as871xx002, asyncio.Future.__class__.__name__.__eq__, ["type"], true]
    - [as871xx003, asyncio.Lock.__class__.__name__.__eq__, ["type"], true]
    - [as871xx004, asyncio.Semaphore.__class__.__name__.__eq__, ["type"], true]
    - [as871xx005, asyncio.Event.__class__.__name__.__eq__, ["type"], true]
    - [as871xx006, asyncio.Condition.__class__.__name__.__eq__, ["type"], true]
    - [as871xx007, asyncio.Queue.__class__.__name__.__eq__, ["type"], true]
    - [as871xx008, asyncio.LifoQueue.__class__.__name__.__eq__, ["type"], true]
    - [as871xx009, asyncio.PriorityQueue.__class__.__name__.__eq__, ["type"], true]
    - [as871xx010, asyncio.QueueEmpty.__class__.__name__.__eq__, ["type"], true]
    - [as871xx011, asyncio.QueueFull.__class__.__name__.__eq__, ["type"], true]
    - [as871xx012, asyncio.StreamReader.__class__.__name__.__eq__, ["type"], true]
