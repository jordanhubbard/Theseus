spec: tinyglobby
version: ">=0.2.0"
backend: node(tinyglobby)

docs: https://github.com/SuperchupuDev/tinyglobby#readme

provenance:
  derived_from:
    - "tinyglobby README — https://github.com/SuperchupuDev/tinyglobby#readme"
    - "Test vectors verified with tinyglobby via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "tinyglobby source"
  notes:
    - "Smaller, faster alternative to fast-glob — used by Vite/Vitest internals."
    - "Install: npm install tinyglobby"
    - "Named exports glob (async) / globSync / isDynamicPattern / escapePath / convertPathToPattern. CJS-importable."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws TypeError on invalid pattern types; globSync returns [] on no match."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant tinyglobby.isDynamicPattern_glob:
  description: "isDynamicPattern('*.js') is true"
  category: helpers
  kind: node_chain_eq
  entry: named
  function: isDynamicPattern
  entry_args: ["*.js"]
  chain: []
  expected: true

invariant tinyglobby.isDynamicPattern_literal:
  description: "isDynamicPattern('foo.txt') is false"
  category: helpers
  kind: node_chain_eq
  entry: named
  function: isDynamicPattern
  entry_args: ["foo.txt"]
  chain: []
  expected: false

invariant tinyglobby.isDynamicPattern_globstar:
  description: "isDynamicPattern('**/*.ts') is true"
  category: helpers
  kind: node_chain_eq
  entry: named
  function: isDynamicPattern
  entry_args: ["**/*.ts"]
  chain: []
  expected: true

invariant tinyglobby.escapePath_star:
  description: "escapePath('foo*bar') escapes asterisk"
  category: helpers
  kind: node_chain_eq
  entry: named
  function: escapePath
  entry_args: ["foo*bar"]
  chain: []
  expected: "foo\\*bar"

invariant tinyglobby.globSync_no_match:
  description: "globSync on non-matching pattern returns []"
  category: glob
  kind: node_chain_eq
  entry: named
  function: globSync
  entry_args: [["/tmp/no-such-tinyglobby-pattern-zxc/*.txt"]]
  chain:
    - {get: length}
  expected: 0

invariant tinyglobby.convertPathToPattern_passthrough:
  description: "convertPathToPattern leaves a plain path unchanged"
  category: helpers
  kind: node_chain_eq
  entry: named
  function: convertPathToPattern
  entry_args: ["/foo/bar"]
  chain: []
  expected: "/foo/bar"

invariant tinyglobby.has_glob_function:
  description: "module exposes a glob() async function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "glob.constructor.name"}
  expected: "AsyncFunction"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:41:43Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
