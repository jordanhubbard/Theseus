spec: lodash_pick
version: ">=4.0.0"
backend: node(lodash.pick)

docs: https://lodash.com/docs/#pick

provenance:
  derived_from:
    - "lodash.pick README — https://www.npmjs.com/package/lodash.pick"
    - "Test vectors verified with lodash.pick@4.4.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.pick exports the _.pick function directly as module.exports."
    - "pick(object, paths) creates an object with only the specified properties."
    - "Missing paths are omitted from the result."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns new object with only specified paths."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_pick.pick:
  kind: node_module_call_eq
  function: ~
  category: pick
  id_prefix: lpick

  columns: [id, args, expected]
  rows:
    - [basic,   [{"a": 1, "b": 2, "c": 3}, ["a", "c"]],   {"a": 1, "c": 3}]
    - [one,     [{"x": 10, "y": 20}, ["x"]],               {"x": 10}]
    - [missing, [{"a": 1, "b": 2}, ["a", "z"]],            {"a": 1}]
