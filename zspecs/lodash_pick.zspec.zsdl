spec: lodash_pick
version: ">=4.0.0"
backend: node(lodash.pick)

docs: https://lodash.com/docs/#pick

provenance:
  derived_from:
    - "lodash.pick README — https://www.npmjs.com/package/lodash.pick"
    - "Test vectors verified with lodash.pick@4.4.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.pick exports the _.pick function directly as module.exports."
    - "pick(object, keys) creates a new object with only the specified keys."
    - "Missing keys are silently omitted from the result."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a new object containing only the picked keys. No errors for valid inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_pick.pick:
  kind: node_module_call_eq
  function: ~
  category: pick
  id_prefix: lpk

  columns: [id, args, expected]
  rows:
    - [two_keys,  [{"a": 1, "b": 2, "c": 3}, ["a", "c"]],  {"a": 1, "c": 3}]
    - [one_key,   [{"x": 10, "y": 20}, ["x"]],              {"x": 10}]
    - [missing,   [{"a": 1}, ["a", "b"]],                   {"a": 1}]
