spec: hl3031
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib: Secure hashes and message digests"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 649 (hl3031): __missing__, __init_subclass__, __class_getitem__ dict-presence checks for hashlib types."
    - "On CPython, type(hashlib.md5()), type(hashlib.sha1()), type(hashlib.sha256()), type(hashlib.sha512()), type(hashlib.sha224()), type(hashlib.sha384()) all resolve to the same C-level HASH type from _hashlib."
    - "hashlib.blake2b and hashlib.blake2s are distinct C extension types from _blake2."
    - "None of the hashlib types define __missing__, __init_subclass__, or __class_getitem__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl3031.missing:
  description: "hashlib types __missing__ dict-presence checks; wave 649"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl3031
  columns: [id, function, args, expected]
  rows:
    - ["hl3031001", operator.contains, [type(hashlib.md5()).__dict__,    "__missing__"], false]
    - ["hl3031002", operator.contains, [type(hashlib.sha1()).__dict__,   "__missing__"], false]
    - ["hl3031003", operator.contains, [type(hashlib.sha256()).__dict__, "__missing__"], false]
    - ["hl3031004", operator.contains, [type(hashlib.sha512()).__dict__, "__missing__"], false]
    - ["hl3031005", operator.contains, [type(hashlib.sha224()).__dict__, "__missing__"], false]
    - ["hl3031006", operator.contains, [type(hashlib.sha384()).__dict__, "__missing__"], false]
    - ["hl3031007", operator.contains, [hashlib.blake2b.__dict__,        "__missing__"], false]
    - ["hl3031008", operator.contains, [hashlib.blake2s.__dict__,        "__missing__"], false]

