spec: lower_case_first
version: ">=2.0.2"
backend: node(lower-case-first)

docs: https://www.npmjs.com/package/lower-case-first

provenance:
  derived_from:
    - "lower-case-first README — https://www.npmjs.com/package/lower-case-first"
    - "Test vectors verified with lower-case-first via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lower-case-first source"
  notes:
    - "lower-case-first is an npm package. Install: npm install lower-case-first"
    - "Lowercases the first character of a string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string with the first character lowercased."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lower_case_first.lowerCaseFirst:
  kind: node_module_call_eq
  function: lowerCaseFirst
  category: string
  id_prefix: lcf

  columns: [id, args, expected]
  rows:
    - [basic,   ["Hello"],        "hello"]
    - [upper,   ["WORLD"],        "wORLD"]
    - [already, ["alreadyLower"], "alreadyLower"]

