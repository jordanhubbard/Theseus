spec: tinyspy
version: ">=4.0.0"
backend: node(tinyspy)

docs: https://github.com/tinylibs/tinyspy#readme

provenance:
  derived_from:
    - "tinyspy README — https://github.com/tinylibs/tinyspy#readme"
    - "Test vectors verified with tinyspy via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "tinyspy source"
  notes:
    - "Tiny spy library used by Vitest internals — alternative to sinon."
    - "Install: npm install tinyspy"
    - "v4 ESM only; named exports spy / spyOn / restoreAll / getInternalState."
    - "Calling a spy needs to be done via {call: [...], tap: true} to leave the spy reference in v for state inspection — but tap currently only applies to method/get; track via initial state instead."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure factory; never throws."
  stderr: "null"
  stickiness: "Spies created with spyOn must be restored via .restore() to undo the patch."
  codes: {}

invariant tinyspy.spy_factory_arity:
  description: "spy() factory takes one optional arg (function-to-wrap)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "spy.length"}
  expected: 1

invariant tinyspy.spyOn_factory_arity:
  description: "spyOn(object, name, accessor?) takes 3 args"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "spyOn.length"}
  expected: 3

invariant tinyspy.spy_returns_function:
  description: "spy() returns a function"
  category: shape
  kind: node_chain_eq
  entry: factory
  factory: spy
  entry_args: []
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant tinyspy.spy_call_count_zero_initially:
  description: "Fresh spy has callCount 0"
  category: state
  kind: node_chain_eq
  entry: factory
  factory: spy
  entry_args: []
  chain:
    - {get: callCount}
  expected: 0

invariant tinyspy.spy_called_false_initially:
  description: "Fresh spy has called === false"
  category: state
  kind: node_chain_eq
  entry: factory
  factory: spy
  entry_args: []
  chain:
    - {get: called}
  expected: false

invariant tinyspy.spy_calls_array_empty:
  description: "Fresh spy has calls.length 0"
  category: state
  kind: node_chain_eq
  entry: factory
  factory: spy
  entry_args: []
  chain:
    - {get: calls}
    - {get: length}
  expected: 0

invariant tinyspy.spy_returns_array_empty:
  description: "Fresh spy has returns.length 0"
  category: state
  kind: node_chain_eq
  entry: factory
  factory: spy
  entry_args: []
  chain:
    - {get: returns}
    - {get: length}
  expected: 0

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:42:46Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
