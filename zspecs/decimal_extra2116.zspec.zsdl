spec: decimal_extra2116
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/decimal.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave _extra2116: __or__/__ror__/__ior__, __and__/__rand__/__iand__, __xor__/__rxor__/__ixor__ dict-presence checks."
    - "decimal.Decimal is a full numeric type but does NOT define set/dict merge operators in its own __dict__."
    - "decimal.Decimal does NOT define set-intersection operators (__and__, __rand__, __iand__) — these are bitwise/set, not arithmetic."
    - "decimal.Decimal does NOT define set-symmetric-difference operators (__xor__, __rxor__, __ixor__)."
    - "decimal.Context and decimal.DecimalException also define none of these operators."
    - "These operators are absent because Decimal models decimal arithmetic, not binary bitwise or set operations."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __or__ / __ror__ / __ior__ — dict-merge / set-union dict-presence
# decimal.Decimal, Context, DecimalException: all False
# Decimal is a numeric type but has no bitwise or set-merge operators
# ---------------------------------------------------------------------------

table decimal_extra2116.or_protocol:
  description: "decimal types __or__/__ror__/__ior__ dict-presence"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2116

  columns: [id, function, args, expected]
  rows:
    - ["dc2116001", "decimal.Decimal.__dict__.__contains__",          ["__or__"],  false]
    - ["dc2116002", "decimal.Decimal.__dict__.__contains__",          ["__ror__"], false]
    - ["dc2116003", "decimal.Decimal.__dict__.__contains__",          ["__ior__"], false]
    - ["dc2116004", "decimal.Context.__dict__.__contains__",          ["__or__"],  false]
    - ["dc2116005", "decimal.Context.__dict__.__contains__",          ["__ror__"], false]
    - ["dc2116006", "decimal.Context.__dict__.__contains__",          ["__ior__"], false]
    - ["dc2116007", "decimal.DecimalException.__dict__.__contains__", ["__or__"],  false]
    - ["dc2116008", "decimal.DecimalException.__dict__.__contains__", ["__ror__"], false]
    - ["dc2116009", "decimal.DecimalException.__dict__.__contains__", ["__ior__"], false]

