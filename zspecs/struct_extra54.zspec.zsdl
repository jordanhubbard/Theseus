spec: struct_extra54
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra53.zspec.zsdl — covers struct.__all__.__contains__ for pack/unpack/unpack_from (table); struct.__dict__.__contains__ for Struct/pack/error/calcsize (table); error.__doc__.__class__.__name__.__eq__('NoneType') (invariant)."
    - "struct_extra52.zspec.zsdl — covers struct.__all__.__class__.__name__.__eq__('list'); __all__.__contains__ for Struct/error/pack_into/iter_unpack (table) and calcsize (invariant); Struct/error __eq__.__class__.__name__.__eq__('wrapper_descriptor')."
    - "struct_extra29.zspec.zsdl — covers struct.__spec__.__name__.__len__()==6 and struct.__loader__.__class__.__name__.__len__()==16."
    - "struct_extra26.zspec.zsdl — covers struct.__spec__.__class__.__name__.__len__()==10 and struct.__all__.__len__()==8."
    - "struct_extra19.zspec.zsdl — covers struct.__package__.__eq__('') and struct.__package__.__class__.__name__.__eq__('str')."
    - "struct.zspec — covers struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra53; it does NOT duplicate invariants present in those files."
    - "Wave 225 theme: __loader__ identity + __spec__ attribute chains + __file__/__cached__ class name checks."
    - "NOTE: struct in Python 3 is implemented as a thin Python wrapper (Lib/struct.py) around the C extension _struct. On Python 3.14.3 macOS/Darwin 25.4.0, import struct loads the Python wrapper file; therefore struct.__loader__.__class__.__name__ == 'SourceFileLoader' (not 'ExtensionFileLoader' or 'BuiltinImporter'). struct.__file__ and struct.__cached__ are str paths to struct.py and its .pyc respectively. All verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 1: struct_extra29 checks struct.__loader__.__class__.__name__.__len__()==16 (length axis). struct_extra26 checks struct.__spec__.__class__.__name__.__len__()==10 (length axis for spec class). No prior struct spec checks __loader__.__class__.__name__.__eq__('SourceFileLoader') or __spec__.__class__.__name__.__eq__('ModuleSpec') — the equality axes. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__loader__.__class__.__name__ == 'SourceFileLoader'. struct is loaded as a Python source file (Lib/struct.py); its loader is importlib.machinery.SourceFileLoader. struct_extra29 covers __loader__.__class__.__name__.__len__()==16 but NOT __eq__('SourceFileLoader'). No prior struct spec checks __loader__.__class__.__name__.__eq__('SourceFileLoader'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__spec__.__class__.__name__ == 'ModuleSpec'. The struct module's __spec__ attribute is an importlib.machinery.ModuleSpec instance. struct_extra26 covers __spec__.__class__.__name__.__len__()==10 but NOT __eq__('ModuleSpec'). No prior struct spec checks __spec__.__class__.__name__.__eq__('ModuleSpec'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior struct spec checks struct.__file__.__class__.__name__.__eq__('str'). struct.py is loaded from a Python source file; its __file__ attribute is a str path (e.g., '.../lib/python3.14/struct.py'). str.__class__.__name__ == 'str'. This confirms __file__ is a string path (as opposed to None for pure built-in modules). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__file__.__class__.__name__ == 'str'. struct is loaded from a .py source file (Lib/struct.py); its __file__ attribute is a Python str path. No prior struct spec checks struct.__file__.__class__.__name__.__eq__('str'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 3: No prior struct spec checks struct.__cached__.__class__.__name__.__eq__('str'). struct.py is compiled to a .pyc bytecode cache; its __cached__ attribute is a str path to the .pyc file under __pycache__. Distinct from __file__: __file__ is the source path, __cached__ is the bytecode path. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__cached__.__class__.__name__ == 'str'. struct.py has a compiled bytecode cache; its __cached__ attribute is a Python str path to the .pyc file. No prior struct spec checks struct.__cached__.__class__.__name__.__eq__('str'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct loader identity + module spec/file/cached class name checks
#
# Wave 225 theme: __loader__ identity + __spec__ attribute chains +
# __file__/__cached__ class name checks.
#
# struct in Python 3 loads as a Python wrapper (Lib/struct.py) around
# the C extension _struct. Its loader is therefore SourceFileLoader and it
# has str __file__ and __cached__ paths. Prior specs cover __len__ axes;
# this spec covers __eq__ axes — all novel equality anchors for struct.
# ---------------------------------------------------------------------------

table struct_extra54.loader_spec_file_cached:
  description: "struct.__loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__.__class__.__name__.__eq__('str') / __cached__.__class__.__name__.__eq__('str') — loader/spec/file/cached class identity for the struct Python wrapper module; struct_extra29 covers __loader__.__class__.__name__.__len__()==16 and struct_extra26 covers __spec__.__class__.__name__.__len__()==10 (length axes) but no prior struct spec checks these via __eq__; all four are novel equality anchors"
  kind: python_call_eq
  category: module_structure
  id_prefix: structload54

  columns: [id, function, args, expected]
  rows:
    - [loader_class_name_eq,  __loader__.__class__.__name__.__eq__,  ["SourceFileLoader"], true]
    - [spec_class_name_eq,    __spec__.__class__.__name__.__eq__,    ["ModuleSpec"],       true]
    - [file_class_name_eq,    __file__.__class__.__name__.__eq__,    ["str"],              true]
    - [cached_class_name_eq,  __cached__.__class__.__name__.__eq__,  ["str"],              true]

# ---------------------------------------------------------------------------
# struct.__loader__.__class__.__name__.__eq__('SourceFileLoader') — standalone
#
# struct_extra29 covers __loader__.__class__.__name__.__len__()==16 (length
# axis). No prior struct spec checks the equality axis for the loader class
# name. SourceFileLoader identity confirms that struct is loaded as the
# Python wrapper Lib/struct.py, not as the underlying C extension _struct.
# This is an important architectural fact: the top-level 'struct' module is
# a Python file, even though its core functionality is C-backed.
# ---------------------------------------------------------------------------

invariant struct_extra54.loader_class_name_sourcefileloader:
  description: "struct.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — struct is loaded as Lib/struct.py (Python wrapper) by SourceFileLoader even though its core is C-backed (_struct extension); struct_extra29 covers __loader__.__class__.__name__.__len__()==16 (length axis) but no prior struct spec checks __eq__('SourceFileLoader'); confirms the Python-wrapper loader identity for struct"
  category: module_structure
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true
