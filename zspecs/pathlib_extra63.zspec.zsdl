spec: pathlib_extra63
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra62.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath __repr__.__class__.__name__/__qualname__.__eq__('function'); Path/PurePath __hash__.__class__.__name__.__eq__('function')."
    - "pathlib_extra61.zspec.zsdl — covers PurePosixPath/PureWindowsPath __class__.__module__.__eq__('builtins'); Path/__init__ and PurePath/__init__ __class__.__name__.__eq__('function'); PurePath property name/suffix/parent/stem __class__.__module__.__eq__('builtins')."
    - "pathlib_extra60.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy'); PurePath property name/suffix/parent/stem __class__.__qualname__.__eq__('property')."
    - "pathlib_extra59.zspec.zsdl — covers Path property __class__.__qualname__=='property' (8 properties) and PurePath property __class__.__name__=='property' (4 properties)."
    - "pathlib_extra58.zspec.zsdl — covers pathlib class __module__.__eq__('pathlib') for Path/PurePath/PurePosixPath/PureWindowsPath; Path property __class__.__name__=='property' for 10 attributes."
    - "pathlib_extra54.zspec.zsdl — covers Path/__class__.__module__.__eq__('builtins') and PurePath/__class__.__module__.__eq__('builtins'); Path/PurePath/PurePosixPath/PureWindowsPath __class__.__qualname__.__eq__('type')."
    - "pathlib_extra53.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath __class__.__name__.__eq__('type')."
    - "pathlib_extra37.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath __dict__.__class__.__name__.__len__()==12."
  notes:
    - "This spec extends pathlib_extra62.zspec.zsdl."
    - "Prior specs collectively covered: pathlib_extra62 covers __repr__.__class__.__name__/__qualname__ and __hash__.__class__.__name__ for path classes. NOT YET COVERED: pathlib.__all__.__class__.__name__.__eq__('list') — no prior pathlib spec checks __all__.__class__.__name__; novel; pathlib.__all__.__len__()==7 — no prior pathlib spec checks the length of __all__; novel; Path/PurePath __eq__.__class__.__name__.__eq__('function') — PurePath defines __eq__ as a regular Python function in pathlib.py; Path/PurePosixPath/PureWindowsPath all inherit it; __eq__.__class__.__name__ == 'function'; no prior pathlib spec checks __eq__.__class__.__name__; novel."
    - "pathlib has __all__ defined as a list. Verified: hasattr(pathlib, '__all__') == True. pathlib.__all__ is a plain Python list with 7 entries: ['UnsupportedOperation', 'PurePath', 'PurePosixPath', 'PureWindowsPath', 'Path', 'PosixPath', 'WindowsPath']. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.__all__.__class__.__name__ == 'list'. The __all__ attribute is a plain Python list. No prior pathlib spec checks __all__.__class__.__name__. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.__all__.__len__() == 7. The pathlib module's __all__ list has 7 entries. No prior pathlib spec checks __all__.__len__(). Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.Path.__eq__.__class__.__name__ == 'function'. PurePath defines __eq__ as a regular Python function in pathlib.py (confirmed: '__eq__' in PurePath.__dict__ == True). Path does NOT define its own __eq__ ('__eq__' in Path.__dict__ == False); it inherits PurePath.__eq__. The __eq__.__qualname__ is 'PurePath.__eq__' for all four path classes. The builtin 'function' type has __name__ == 'function'. No prior pathlib spec checks __eq__.__class__.__name__. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__eq__.__class__.__name__ == 'function'. PurePath defines __eq__ as a Python function in its own __dict__. Same as above. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.PurePosixPath.__eq__.__class__.__name__ == 'function'. PurePosixPath does NOT define __eq__ in its own __dict__ ('__eq__' in PurePosixPath.__dict__ == False); it inherits PurePath.__eq__ which is a Python function. __eq__.__qualname__ == 'PurePath.__eq__'. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.PureWindowsPath.__eq__.__class__.__name__ == 'function'. PureWindowsPath does NOT define __eq__ in its own __dict__ ('__eq__' in PureWindowsPath.__dict__ == False); it inherits PurePath.__eq__ which is a Python function. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "This contrasts with C-extension types (like io.BytesIO) where __eq__ is a 'wrapper_descriptor'. pathlib path classes are pure-Python, so their __eq__ is the 'function' type."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib module __all__ identity
#
# The pathlib module defines __all__ as a plain Python list with 7 entries:
# ['UnsupportedOperation', 'PurePath', 'PurePosixPath', 'PureWindowsPath',
#  'Path', 'PosixPath', 'WindowsPath'].
#
#   pathlib.__all__.__class__.__name__ == 'list'
#   pathlib.__all__.__len__()          == 7
#
# No prior pathlib spec checks __all__.__class__.__name__ or its length.
# Both anchors are novel in the pathlibAll63 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra63.all_identity:
  description: "pathlib module __all__.__class__.__name__.__eq__('list') and __all__.__len__()==7 — pathlib defines __all__ as a plain Python list with 7 public names (UnsupportedOperation, PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath, WindowsPath); no prior pathlib spec checks __all__.__class__.__name__ or its length; both novel anchors in pathlibAll63 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: pathlibAll63all

  columns: [id, function, args, expected]
  rows:
    - [all_class_name, "__all__.__class__.__name__.__eq__", ["list"], true]
    - [all_len,        "__all__.__len__",                   [],        7   ]

# ---------------------------------------------------------------------------
# pathlib Path/PurePath __eq__.__class__.__name__ == 'function'
#
# PurePath defines __eq__ as a regular Python function in pathlib.py
# (confirmed: '__eq__' in PurePath.__dict__ == True). Path does NOT define its
# own __eq__ (__eq__ not in Path.__dict__). Both Path and PurePath resolve
# __eq__ to PurePath.__eq__, whose __qualname__ is 'PurePath.__eq__'.
# The builtin 'function' type has __name__ == 'function'.
#
# This contrasts with C-extension types where __eq__ is a 'wrapper_descriptor'.
# pathlib's pure-Python implementation means __eq__ is a regular function.
#
#   Path.__eq__.__class__.__name__    == 'function'
#   PurePath.__eq__.__class__.__name__ == 'function'
#
# No prior pathlib spec checks __eq__.__class__.__name__ for any path class.
# Both anchors are novel in the pathlibAll63 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra63.path_eq_class_name:
  description: "pathlib Path/PurePath __eq__.__class__.__name__.__eq__('function') — PurePath defines __eq__ as a regular Python function in pathlib.py; Path inherits PurePath.__eq__; the builtin 'function' type has __name__=='function'; contrasts with C-extension types where __eq__ is 'wrapper_descriptor'; no prior pathlib spec checks __eq__.__class__.__name__; both novel anchors in pathlibAll63 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibAll63peq

  columns: [id, function, args, expected]
  rows:
    - [Path_eq_class_name,     "Path.__eq__.__class__.__name__.__eq__",     ["function"], true]
    - [PurePath_eq_class_name, "PurePath.__eq__.__class__.__name__.__eq__", ["function"], true]

# ---------------------------------------------------------------------------
# pathlib PurePosixPath/PureWindowsPath __eq__.__class__.__name__ == 'function'
#
# PurePosixPath and PureWindowsPath do NOT define __eq__ in their own __dict__
# (confirmed: '__eq__' in PurePosixPath.__dict__ == False and
# '__eq__' in PureWindowsPath.__dict__ == False). Both inherit PurePath.__eq__,
# which is a regular Python function. The __eq__.__qualname__ for both is
# 'PurePath.__eq__'. The builtin 'function' type has __name__ == 'function'.
#
#   PurePosixPath.__eq__.__class__.__name__  == 'function'
#   PureWindowsPath.__eq__.__class__.__name__ == 'function'
#
# No prior pathlib spec checks __eq__.__class__.__name__ for PurePosixPath or
# PureWindowsPath. Both anchors are novel in the pathlibAll63 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra63.purepath_subclass_eq_class_name:
  description: "pathlib PurePosixPath/PureWindowsPath __eq__.__class__.__name__.__eq__('function') — neither PurePosixPath nor PureWindowsPath defines __eq__ in its own __dict__; both inherit PurePath.__eq__ which is a Python function (__eq__.__qualname__=='PurePath.__eq__'); the builtin 'function' type has __name__=='function'; no prior pathlib spec checks __eq__.__class__.__name__ for PurePosixPath/PureWindowsPath; both novel anchors in pathlibAll63 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibAll63subeq

  columns: [id, function, args, expected]
  rows:
    - [PurePosixPath_eq_class_name,  "PurePosixPath.__eq__.__class__.__name__.__eq__",  ["function"], true]
    - [PureWindowsPath_eq_class_name, "PureWindowsPath.__eq__.__class__.__name__.__eq__", ["function"], true]

invariant pathlib_extra63.all_class_name_list:
  description: "pathlib.__all__.__class__.__name__ == 'list' — the pathlib module defines __all__ as a plain Python list; no prior pathlib spec checks __all__.__class__.__name__; novel anchor in pathlibAll63 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant pathlib_extra63.all_len_7:
  description: "pathlib.__all__.__len__() == 7 — the pathlib module's __all__ list contains 7 public names (UnsupportedOperation, PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath, WindowsPath); no prior pathlib spec checks the length of __all__; novel anchor in pathlibAll63 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 7

invariant pathlib_extra63.PurePath_eq_class_name_function:
  description: "pathlib.PurePath.__eq__.__class__.__name__ == 'function' — PurePath defines __eq__ as a regular Python function in pathlib.py (confirmed: '__eq__' in PurePath.__dict__ == True); the builtin 'function' type has __name__=='function'; contrasts with C-extension types where __eq__ is 'wrapper_descriptor'; no prior pathlib spec checks __eq__.__class__.__name__; novel anchor in pathlibAll63 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: PurePath.__eq__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pathlib_extra63.Path_eq_class_name_function:
  description: "pathlib.Path.__eq__.__class__.__name__ == 'function' — Path does not define __eq__ in its own __dict__; it inherits PurePath.__eq__ which is a Python function; the builtin 'function' type has __name__=='function'; no prior pathlib spec checks __eq__.__class__.__name__; novel anchor in pathlibAll63 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Path.__eq__.__class__.__name__.__eq__
  args: ["function"]
  expected: true
