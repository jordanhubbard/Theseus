spec: uuid_extra115
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra114.zspec.zsdl — covers UUID.time_low/time_mid/time_hi_version/clock_seq_low/urn fget.__qualname__ equality and lengths (table + invariants)."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality for hex/bytes/bytes_le/fields/node/time/clock_seq/version/variant/clock_seq_hi_variant (table + invariants)."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__.__code__.co_name/__eq__('__init__') / UUID.__init__.__code__.co_argcount.__eq__(7) / UUID.__str__/__repr__/__eq__/__hash__/__lt__ method qualname equality and lengths (table + invariants)."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality and co_argcount (table + invariants)."
  notes:
    - "This spec extends uuid through uuid_extra114; it does NOT duplicate invariants present in those files."
    - "Wave 290 theme: UUID property fget code attributes (co_name, co_argcount) for basic properties — hex/bytes/version/variant/fields/node/time/clock_seq/bytes_le fget.__code__.co_name equality and co_argcount — all UUID properties have fget.__code__.co_argcount==1 (takes self) and fget.__code__.co_name equal to the property name."
    - "uuid.UUID.hex.fget.__code__.co_name == 'hex'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.hex.fget.__code__.co_argcount == 1. All UUID property fget functions take only self. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes.fget.__code__.co_name == 'bytes'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.version.fget.__code__.co_name == 'version'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.variant.fget.__code__.co_name == 'variant'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.fields.fget.__code__.co_name == 'fields'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.node.fget.__code__.co_name == 'node'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time.fget.__code__.co_name == 'time'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.clock_seq.fget.__code__.co_name == 'clock_seq'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes_le.fget.__code__.co_name == 'bytes_le'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: All UUID properties are implemented as Python functions in Lib/uuid.py. Their fget.__code__.co_name always equals the property name (the def statement name matches the property attribute name). All have co_argcount==1 (taking only self). The uuid.UUID.int attribute is NOT a property (it is a member_descriptor slot), so it has no fget. uuid_extra99 anchors UUID.__init__.__code__.co_name and co_argcount for the __init__ method; uuid_extra96 anchors uuid1/uuid4/uuid3/uuid5 co_name and co_argcount (module-level functions). This spec is the first to anchor property fget __code__ attributes. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget.__code__.co_name.__eq__('hex')
# uuid.UUID.hex.fget.__code__.co_argcount.__eq__(1)
# uuid.UUID.bytes.fget.__code__.co_name.__eq__('bytes')
# uuid.UUID.bytes.fget.__code__.co_argcount.__eq__(1)
# uuid.UUID.version.fget.__code__.co_name.__eq__('version')
#
# Wave 290 theme: hex, bytes, version property fget __code__ attributes.
#
# UUID.hex.fget.__code__.co_name is 'hex' — the Python def statement name.
# co_argcount is 1 (only self). UUID.bytes.fget.__code__.co_name is 'bytes',
# co_argcount is 1. UUID.version.fget.__code__.co_name is 'version', co_argcount
# is 1. All UUID properties have fget as a Python-level function with co_argcount==1.
# No prior uuid spec anchors fget.__code__ attributes for any property under
# uuidprop115. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra115.UUID_hex_bytes_version_fget_code:
  description: "UUID.hex.fget.__code__.co_name.__eq__('hex')==True / UUID.hex.fget.__code__.co_argcount.__eq__(1)==True / UUID.bytes.fget.__code__.co_name.__eq__('bytes')==True / UUID.bytes.fget.__code__.co_argcount.__eq__(1)==True / UUID.version.fget.__code__.co_name.__eq__('version')==True — all UUID property fget functions are Python-level functions (Lib/uuid.py); co_name equals the property name; co_argcount==1 for all (only self); extra97 anchors fget qualname equality but NOT fget __code__ attributes; no prior spec anchors fget co_name or co_argcount; first uuidprop115 anchor"
  kind: python_call_eq
  category: code_attributes
  id_prefix: uuidprop115

  columns: [id, function, args, expected, description]
  rows:
    - [hex_co_name,      "UUID.hex.fget.__code__.co_name.__eq__",       ["hex"],     true, "UUID.hex.fget.__code__.co_name is 'hex' (def statement name in Lib/uuid.py; no prior spec anchors fget co_name)"]
    - [hex_co_argc,      "UUID.hex.fget.__code__.co_argcount.__eq__",   [1],         true, "UUID.hex.fget.__code__.co_argcount is 1 (only self; all UUID property fget functions take only self; no prior spec anchors fget co_argcount)"]
    - [bytes_co_name,    "UUID.bytes.fget.__code__.co_name.__eq__",     ["bytes"],   true, "UUID.bytes.fget.__code__.co_name is 'bytes' (property returns the UUID as 16-byte big-endian bytes; co_name matches property name)"]
    - [bytes_co_argc,    "UUID.bytes.fget.__code__.co_argcount.__eq__", [1],         true, "UUID.bytes.fget.__code__.co_argcount is 1 (only self; same co_argcount as all other UUID property fget functions)"]
    - [version_co_name,  "UUID.version.fget.__code__.co_name.__eq__",   ["version"], true, "UUID.version.fget.__code__.co_name is 'version' (property returns the UUID version number 1-5; co_name matches property name)"]

# ---------------------------------------------------------------------------
# uuid.UUID.variant.fget.__code__.co_name.__eq__('variant')
# uuid.UUID.variant.fget.__code__.co_argcount.__eq__(1)
# uuid.UUID.fields.fget.__code__.co_name.__eq__('fields')
# uuid.UUID.node.fget.__code__.co_name.__eq__('node')
# uuid.UUID.time.fget.__code__.co_name.__eq__('time')
#
# Wave 290 theme: variant, fields, node, time property fget __code__ attributes.
#
# UUID.variant.fget.__code__.co_name is 'variant', co_argcount is 1.
# UUID.fields.fget.__code__.co_name is 'fields'. UUID.node.fget.__code__.co_name
# is 'node'. UUID.time.fget.__code__.co_name is 'time'. All co_argcount==1.
# No prior uuid spec anchors fget.__code__ attributes for any of these properties.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra115.UUID_variant_fields_node_time_fget_code:
  description: "UUID.variant.fget.__code__.co_name.__eq__('variant')==True / UUID.variant.fget.__code__.co_argcount.__eq__(1)==True / UUID.fields.fget.__code__.co_name.__eq__('fields')==True / UUID.node.fget.__code__.co_name.__eq__('node')==True / UUID.time.fget.__code__.co_name.__eq__('time')==True — all four have co_argcount==1 (only self); co_name matches property name for each; no prior spec anchors fget co_name for variant/fields/node/time; first uuidprop115 anchor for these properties"
  kind: python_call_eq
  category: code_attributes
  id_prefix: uuidprop115

  columns: [id, function, args, expected, description]
  rows:
    - [variant_co_name,  "UUID.variant.fget.__code__.co_name.__eq__",  ["variant"], true, "UUID.variant.fget.__code__.co_name is 'variant' (property returns the UUID variant RFC specification; co_name matches property name)"]
    - [variant_co_argc,  "UUID.variant.fget.__code__.co_argcount.__eq__", [1],      true, "UUID.variant.fget.__code__.co_argcount is 1 (only self; consistent with all other UUID property fget functions)"]
    - [fields_co_name,   "UUID.fields.fget.__code__.co_name.__eq__",   ["fields"],  true, "UUID.fields.fget.__code__.co_name is 'fields' (property returns 6-tuple of RFC 4122 field values; co_name matches property name)"]
    - [node_co_name,     "UUID.node.fget.__code__.co_name.__eq__",     ["node"],    true, "UUID.node.fget.__code__.co_name is 'node' (property returns the 48-bit hardware address / node field; co_name matches property name)"]
    - [time_co_name,     "UUID.time.fget.__code__.co_name.__eq__",     ["time"],    true, "UUID.time.fget.__code__.co_name is 'time' (property returns the 60-bit UUID timestamp; co_name matches property name)"]

# ---------------------------------------------------------------------------
# uuid.UUID.clock_seq.fget.__code__.co_name.__eq__('clock_seq')
# uuid.UUID.clock_seq.fget.__code__.co_argcount.__eq__(1)
# uuid.UUID.bytes_le.fget.__code__.co_name.__eq__('bytes_le')
# uuid.UUID.version.fget.__code__.co_argcount.__eq__(1)
# uuid.UUID.fields.fget.__code__.co_argcount.__eq__(1)
#
# Wave 290 theme: clock_seq, bytes_le property fget __code__ and co_argcount
# cross-checks for version and fields.
#
# UUID.clock_seq.fget.__code__.co_name is 'clock_seq', co_argcount is 1.
# UUID.bytes_le.fget.__code__.co_name is 'bytes_le'. version and fields co_argcount
# cross-checks confirm that all UUID property fget functions uniformly have
# co_argcount==1 (only self). No prior uuid spec anchors fget.__code__ attributes
# for clock_seq or bytes_le under uuidprop115.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra115.UUID_clock_seq_bytes_le_fget_code:
  description: "UUID.clock_seq.fget.__code__.co_name.__eq__('clock_seq')==True / UUID.clock_seq.fget.__code__.co_argcount.__eq__(1)==True / UUID.bytes_le.fget.__code__.co_name.__eq__('bytes_le')==True / UUID.version.fget.__code__.co_argcount.__eq__(1)==True / UUID.fields.fget.__code__.co_argcount.__eq__(1)==True — clock_seq co_name is 'clock_seq' (9 chars; property returns 14-bit clock sequence); bytes_le co_name is 'bytes_le' (property returns 16-byte little-endian bytes); co_argcount==1 uniformly across all UUID properties; no prior spec anchors fget co_name for clock_seq or bytes_le; first uuidprop115 unified anchor"
  kind: python_call_eq
  category: code_attributes
  id_prefix: uuidprop115

  columns: [id, function, args, expected, description]
  rows:
    - [clock_seq_co_name,   "UUID.clock_seq.fget.__code__.co_name.__eq__",     ["clock_seq"], true, "UUID.clock_seq.fget.__code__.co_name is 'clock_seq' (9 chars; property returns 14-bit RFC 4122 clock sequence; co_name matches property name)"]
    - [clock_seq_co_argc,   "UUID.clock_seq.fget.__code__.co_argcount.__eq__", [1],           true, "UUID.clock_seq.fget.__code__.co_argcount is 1 (only self; uniform with all other UUID property fget functions)"]
    - [bytes_le_co_name,    "UUID.bytes_le.fget.__code__.co_name.__eq__",      ["bytes_le"],  true, "UUID.bytes_le.fget.__code__.co_name is 'bytes_le' (8 chars; property returns 16-byte little-endian UUID bytes with mixed-endian MS format; co_name matches property name)"]
    - [version_co_argc2,    "UUID.version.fget.__code__.co_argcount.__eq__",   [1],           true, "UUID.version.fget.__code__.co_argcount is 1 (cross-check confirming co_argcount==1 for version fget; uniform across all UUID properties)"]
    - [fields_co_argc2,     "UUID.fields.fget.__code__.co_argcount.__eq__",    [1],           true, "UUID.fields.fget.__code__.co_argcount is 1 (cross-check confirming co_argcount==1 for fields fget; uniform across all UUID properties)"]

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget.__code__.co_name.__eq__('hex') — standalone
#
# uuid.UUID.hex.fget.__code__.co_name is 'hex'. The hex property returns the UUID
# as a 32-character hexadecimal string (without hyphens). Its fget is a Python-level
# function defined in Lib/uuid.py with def hex(self). The code object's co_name
# attribute reflects the name of the function as written in the def statement:
# 'hex'. For UUID properties, co_name always equals the property name because the
# def name matches the @property decorator target. No prior uuid spec anchors any
# UUID property fget co_name in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra115.UUID_hex_fget_co_name_eq:
  description: "uuid.UUID.hex.fget.__code__.co_name.__eq__('hex') == True — hex property returns 32-char hex UUID string without hyphens; fget co_name is 'hex' (the def statement name in Lib/uuid.py); co_name always equals the property name for UUID properties; no prior uuid spec anchors any UUID property fget co_name in any form; first standalone under uuidprop115"
  category: code_attributes
  kind: python_call_eq
  function: "UUID.hex.fget.__code__.co_name.__eq__"
  args: ["hex"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget.__code__.co_argcount.__eq__(1) — standalone
#
# uuid.UUID.hex.fget.__code__.co_argcount is 1. All UUID property fget functions
# take only self — co_argcount is 1 for all of them. This uniform pattern reflects
# that UUID properties are read-only computed values derived from the internal
# UUID integer (uuid.UUID.__int__). There are no settable properties (UUID is
# immutable). The co_argcount==1 applies to every UUID property fget without
# exception. No prior uuid spec anchors any UUID property fget co_argcount.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra115.UUID_hex_fget_co_argcount_1:
  description: "uuid.UUID.hex.fget.__code__.co_argcount.__eq__(1) == True — all UUID property fget functions take only self (co_argcount==1); UUID is immutable so all properties are read-only computed values derived from the internal integer; uniform co_argcount==1 applies to every UUID property fget without exception; no prior uuid spec anchors any UUID property fget co_argcount; first standalone under uuidprop115"
  category: code_attributes
  kind: python_call_eq
  function: "UUID.hex.fget.__code__.co_argcount.__eq__"
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.bytes.fget.__code__.co_name.__eq__('bytes') — standalone
#
# uuid.UUID.bytes.fget.__code__.co_name is 'bytes'. The bytes property returns
# the UUID as a 16-byte big-endian bytes object. Its fget co_name is 'bytes' —
# the property name used in the def statement. Note that 'bytes' is also the name
# of the Python built-in type, but here it refers to the UUID property name.
# UUID.bytes and uuid.UUID.bytes_le are distinct properties: bytes uses big-endian
# byte order while bytes_le uses little-endian with Microsoft GUID format.
# No prior uuid spec anchors UUID.bytes fget co_name.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra115.UUID_bytes_fget_co_name_eq:
  description: "uuid.UUID.bytes.fget.__code__.co_name.__eq__('bytes') == True — bytes property returns 16-byte big-endian UUID bytes; fget co_name is 'bytes' (the property name; distinct from the bytes built-in type); UUID.bytes uses big-endian order while UUID.bytes_le uses little-endian; no prior uuid spec anchors UUID.bytes fget co_name; first bytes fget co_name standalone under uuidprop115"
  category: code_attributes
  kind: python_call_eq
  function: "UUID.bytes.fget.__code__.co_name.__eq__"
  args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.clock_seq.fget.__code__.co_name.__eq__('clock_seq') — standalone
#
# uuid.UUID.clock_seq.fget.__code__.co_name is 'clock_seq'. The clock_seq property
# returns the 14-bit clock sequence from the UUID (RFC 4122 §4.1.5). Its fget
# co_name is 'clock_seq' (9 chars) — the property name. The clock_seq is used
# to ensure uniqueness when the clock is set backwards or a new node ID is assigned.
# co_name 'clock_seq' has the same number of chars (9) as uuid.UUID.clock_seq
# qualname suffix — both are the property name. No prior uuid spec anchors
# UUID.clock_seq fget co_name. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra115.UUID_clock_seq_fget_co_name_eq:
  description: "uuid.UUID.clock_seq.fget.__code__.co_name.__eq__('clock_seq') == True — clock_seq property returns the 14-bit RFC 4122 clock sequence (used to ensure uniqueness when clock is set backwards); fget co_name is 'clock_seq' (9 chars; matches the property name); no prior uuid spec anchors UUID.clock_seq fget co_name; first clock_seq fget co_name standalone under uuidprop115"
  category: code_attributes
  kind: python_call_eq
  function: "UUID.clock_seq.fget.__code__.co_name.__eq__"
  args: ["clock_seq"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.variant.fget.__code__.co_name.__eq__('variant') — standalone
#
# uuid.UUID.variant.fget.__code__.co_name is 'variant'. The variant property
# returns the UUID variant, which specifies the layout of the UUID (e.g.,
# RESERVED_NCS, RFC_4122, RESERVED_MICROSOFT, or RESERVED_FUTURE). Its fget
# co_name is 'variant' (7 chars), matching the property name. The variant is
# encoded in bits 62-63 of the UUID. No prior uuid spec anchors UUID.variant
# fget co_name. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra115.UUID_variant_fget_co_name_eq:
  description: "uuid.UUID.variant.fget.__code__.co_name.__eq__('variant') == True — variant property returns the UUID variant (RFC_4122, RESERVED_NCS, etc.) encoded in bits 62-63; fget co_name is 'variant' (7 chars; matches property name); no prior uuid spec anchors UUID.variant fget co_name; first variant fget co_name standalone under uuidprop115"
  category: code_attributes
  kind: python_call_eq
  function: "UUID.variant.fget.__code__.co_name.__eq__"
  args: ["variant"]
  expected: true

