spec: struct_extra191
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "struct.Struct.pack.__name__ == 'pack' (len=4); struct.Struct.unpack.__name__ == 'unpack' (len=6) — method names on the Struct class."
    - "struct.Struct.pack_into.__name__ == 'pack_into' (len=9); struct.Struct.unpack_from.__name__ == 'unpack_from' (len=11) — longer method names on Struct."
    - "struct.Struct.iter_unpack.__name__ == 'iter_unpack' (len=11) — iter_unpack and unpack_from share the same name length."
    - "struct.Struct.__init__.__name__ == '__init__' (len=8) — the dunder initializer."
    - "struct.Struct.size.__class__.__name__ == 'getset_descriptor' (len=17) — size is a C-level getset descriptor."
    - "struct.Struct.format.__class__.__name__ == 'getset_descriptor' (len=17) — format is also a C-level getset descriptor, same type as size."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct method name lengths — pack, unpack, pack_into
# ---------------------------------------------------------------------------

table structnamelens191.short_method_names:
  kind: python_call_eq
  category: name_lengths
  id_prefix: structnamelens191

  columns: [id, function, args, expected, description]
  rows:
    - [pack_name_len,      Struct.pack.__name__.__len__,      [], 4, "len(struct.Struct.pack.__name__) == 4 ('pack' has 4 characters)"]
    - [unpack_name_len,    Struct.unpack.__name__.__len__,    [], 6, "len(struct.Struct.unpack.__name__) == 6 ('unpack' has 6 characters)"]
    - [pack_into_name_len, Struct.pack_into.__name__.__len__, [], 9, "len(struct.Struct.pack_into.__name__) == 9 ('pack_into' has 9 characters)"]

# ---------------------------------------------------------------------------
# struct.Struct method name lengths — unpack_from, iter_unpack, __init__
# ---------------------------------------------------------------------------

table structnamelens191.longer_method_names:
  kind: python_call_eq
  category: name_lengths
  id_prefix: structnamelens191

  columns: [id, function, args, expected, description]
  rows:
    - [unpack_from_name_len,  Struct.unpack_from.__name__.__len__,  [], 11, "len(struct.Struct.unpack_from.__name__) == 11 ('unpack_from' has 11 characters)"]
    - [iter_unpack_name_len,  Struct.iter_unpack.__name__.__len__,  [], 11, "len(struct.Struct.iter_unpack.__name__) == 11 ('iter_unpack' has 11 characters)"]
    - [init_name_len,         Struct.__init__.__name__.__len__,     [],  8, "len(struct.Struct.__init__.__name__) == 8 ('__init__' has 8 characters)"]

# ---------------------------------------------------------------------------
# struct.Struct descriptor class name lengths — size and format
# Both are getset_descriptor (len=17) at the C level.
# ---------------------------------------------------------------------------

table structnamelens191.descriptor_class_names:
  kind: python_call_eq
  category: name_lengths
  id_prefix: structnamelens191

  columns: [id, function, args, expected, description]
  rows:
    - [size_class_name_len,   Struct.size.__class__.__name__.__len__,   [], 17, "len(struct.Struct.size.__class__.__name__) == 17 ('getset_descriptor' has 17 characters)"]
    - [format_class_name_len, Struct.format.__class__.__name__.__len__, [], 17, "len(struct.Struct.format.__class__.__name__) == 17 ('getset_descriptor' has 17 characters)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant structnamelens191.Struct.pack.name_len:
  description: "len(struct.Struct.pack.__name__) == 4 ('pack' has 4 characters)"
  category: name_lengths
  kind: python_call_eq
  function: Struct.pack.__name__.__len__
  args: []
  expected: 4

invariant structnamelens191.Struct.unpack.name_len:
  description: "len(struct.Struct.unpack.__name__) == 6 ('unpack' has 6 characters)"
  category: name_lengths
  kind: python_call_eq
  function: Struct.unpack.__name__.__len__
  args: []
  expected: 6

invariant structnamelens191.Struct.pack_into.name_len:
  description: "len(struct.Struct.pack_into.__name__) == 9 ('pack_into' has 9 characters)"
  category: name_lengths
  kind: python_call_eq
  function: Struct.pack_into.__name__.__len__
  args: []
  expected: 9

invariant structnamelens191.Struct.unpack_from.name_len:
  description: "len(struct.Struct.unpack_from.__name__) == 11 ('unpack_from' has 11 characters)"
  category: name_lengths
  kind: python_call_eq
  function: Struct.unpack_from.__name__.__len__
  args: []
  expected: 11

invariant structnamelens191.Struct.iter_unpack.name_len:
  description: "len(struct.Struct.iter_unpack.__name__) == 11 ('iter_unpack' has 11 characters)"
  category: name_lengths
  kind: python_call_eq
  function: Struct.iter_unpack.__name__.__len__
  args: []
  expected: 11

invariant structnamelens191.Struct.__init__.name_len:
  description: "len(struct.Struct.__init__.__name__) == 8 ('__init__' has 8 characters)"
  category: name_lengths
  kind: python_call_eq
  function: Struct.__init__.__name__.__len__
  args: []
  expected: 8

invariant structnamelens191.Struct.size.class_name_len:
  description: "len(struct.Struct.size.__class__.__name__) == 17 ('getset_descriptor' has 17 characters)"
  category: name_lengths
  kind: python_call_eq
  function: Struct.size.__class__.__name__.__len__
  args: []
  expected: 17

invariant structnamelens191.Struct.format.class_name_len:
  description: "len(struct.Struct.format.__class__.__name__) == 17 ('getset_descriptor' has 17 characters)"
  category: name_lengths
  kind: python_call_eq
  function: Struct.format.__class__.__name__.__len__
  args: []
  expected: 17
