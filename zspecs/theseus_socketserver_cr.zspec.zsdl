spec: theseus_socketserver_cr
version: ">=3.8"
backend: python_cleanroom(theseus_socketserver_cr)
blocks: socketserver

docs: https://docs.python.org/3/library/socketserver.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/socketserver.html"
  not_derived_from:
    - "CPython source: Lib/socketserver.py (internal implementation)"
  notes:
    - "Clean-room socketserver module. Do NOT import socketserver."
    - "TCPServer, UDPServer: base server classes."
    - "BaseRequestHandler: base class for request handlers."
    - "StreamRequestHandler, DatagramRequestHandler: specializations."

error_model: python_exceptions

invariant theseus_socketserver_cr.socketserver2_tcp_handler:
  description: "TCPServer and BaseRequestHandler can be defined and instantiated"
  category: TCPServer
  kind: python_call_eq
  function: socketserver2_tcp_handler
  args: []
  expected: true

invariant theseus_socketserver_cr.socketserver2_address_family:
  description: "TCPServer.address_family is socket.AF_INET"
  category: TCPServer
  kind: python_call_eq
  function: socketserver2_address_family
  args: []
  expected: true

invariant theseus_socketserver_cr.socketserver2_handler_class:
  description: "BaseRequestHandler has handle() method"
  category: BaseRequestHandler
  kind: python_call_eq
  function: socketserver2_handler_class
  args: []
  expected: true
