spec: base64_extra14
version: ">=3.9"
backend: python_module(base64)

docs: https://docs.python.org/3/library/base64.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/base64.html — Python base64 module documentation"
    - "RFC 4648 — The Base16, Base32, and Base64 Data Encodings"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/base64.py"
    - "base64_extra13.zspec.zsdl — covers b64encode(b'hello')/b64decode(b'aGVsbG8='); b16encode(b'hi')/b16decode(b'6869'); urlsafe_b64encode(b'hello') class name."
    - "base64_extra12.zspec.zsdl — covers b64encode/decode/urlsafe_b64encode/decode/b16encode/b32encode __name__/__module__; b64encode(b'') value/class/decode."
    - "base64_extra11.zspec.zsdl — covers urlsafe_b64encode/decode __name__/__module__; b32decode __name__/__module__; urlsafe/b16/b32 encode/decode vectors."
    - "base64_extra10.zspec.zsdl — covers b64decode.__name__/__module__; b64encode/decode abc/Man; urlsafe fbff; b32encode/decode foo/foobar; b16encode/decode DEADBEEF."
    - "base64_extra7.zspec.zsdl — covers b16/b32/b85 __name__ and __module__; b16encode null/ff; b64encode Man; urlsafe return class."
  notes:
    - "This spec extends base64 through base64_extra13; it does NOT duplicate invariants present in those files."
    - "Focus: b64encode single-pad (b'f'), double-pad (b'fo'), no-pad (b'foo') vectors; b64decode round-trip for each; urlsafe_b64encode(b'foo+bar') value; b16encode(b'hello') value (uppercase hex)."
    - "base64.b64encode(b'f') == b'Zg==': 1-byte input requires two padding chars. RFC 4648 §4. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "base64.b64encode(b'fo') == b'Zm8=': 2-byte input requires one padding char. RFC 4648 §4. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "base64.b64encode(b'foo') == b'Zm9v': 3-byte input requires no padding. RFC 4648 §4. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "base64.b64decode(b'Zg==') == b'f': round-trip decode of single-pad encoding. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "base64.b64decode(b'Zm8=') == b'fo': round-trip decode of double-pad encoding. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "base64.b64decode(b'Zm9v') == b'foo': round-trip decode of no-pad encoding. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "base64.urlsafe_b64encode(b'foo+bar') == b'Zm9vK2Jhcg==': '+' encodes to 'K2' in standard base64, preserved in URL-safe alphabet. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "base64.b16encode(b'hello') == b'68656C6C6F': b16encode uses uppercase hex digits per RFC 4648 §8. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# b64encode — single-pad, double-pad, and no-pad vectors (extra14 namespace)
#
# RFC 4648 §4 specifies three canonical padding cases:
#   1 input byte → 2 base64 chars + '=='
#   2 input bytes → 3 base64 chars + '='
#   3 input bytes → 4 base64 chars (no padding)
# base64_extra5 covers length-1/2/3/6 variants; base64_extra13 covers b'hello'.
# No prior spec covers b'f', b'fo', b'foo' as standalone value invariants
# from the extra14 namespace.
# ---------------------------------------------------------------------------

invariant base64_extra14.b64encode.f.value:
  description: "base64.b64encode(b'f') == b'Zg==' — single-byte input: two padding chars"
  category: b64
  kind: python_call_eq
  function: b64encode
  args: [!ascii "f"]
  expected: !b64 "Zg=="

invariant base64_extra14.b64encode.fo.value:
  description: "base64.b64encode(b'fo') == b'Zm8=' — two-byte input: one padding char"
  category: b64
  kind: python_call_eq
  function: b64encode
  args: [!ascii "fo"]
  expected: !b64 "Zm8="

invariant base64_extra14.b64encode.foo.value:
  description: "base64.b64encode(b'foo') == b'Zm9v' — three-byte input: no padding"
  category: b64
  kind: python_call_eq
  function: b64encode
  args: [!ascii "foo"]
  expected: !b64 "Zm9v"

# ---------------------------------------------------------------------------
# b64decode — round-trip for each padding case (extra14 namespace)
#
# Inverse of the three b64encode vectors above.
# Verifies that b64decode correctly recovers each original byte sequence.
# ---------------------------------------------------------------------------

invariant base64_extra14.b64decode.Zgeq.value:
  description: "base64.b64decode(b'Zg==') == b'f' — decode of single-byte encoding"
  category: b64
  kind: python_call_eq
  function: b64decode
  args: [!b64 "Zg=="]
  expected: !ascii "f"

invariant base64_extra14.b64decode.Zm8eq.value:
  description: "base64.b64decode(b'Zm8=') == b'fo' — decode of two-byte encoding"
  category: b64
  kind: python_call_eq
  function: b64decode
  args: [!b64 "Zm8="]
  expected: !ascii "fo"

invariant base64_extra14.b64decode.Zm9v.value:
  description: "base64.b64decode(b'Zm9v') == b'foo' — decode of three-byte no-pad encoding"
  category: b64
  kind: python_call_eq
  function: b64decode
  args: [!b64 "Zm9v"]
  expected: !ascii "foo"

# ---------------------------------------------------------------------------
# urlsafe_b64encode(b'foo+bar') — value (extra14 namespace)
#
# 'foo+bar' encodes to 'Zm9vK2Jhcg==' in standard Base64. The URL-safe
# variant uses '-' and '_' instead of '+' and '/'; since 'foo+bar' does not
# contain bytes that map to those characters, the encoding is identical to
# standard Base64 for this input.
# base64_extra7 covers urlsafe_b64encode return class; base64_extra11 covers
# urlsafe_b64encode/decode for b'f'. No prior spec covers this specific input.
# ---------------------------------------------------------------------------

invariant base64_extra14.urlsafe_b64encode.foobar.value:
  description: "base64.urlsafe_b64encode(b'foo+bar') == b'Zm9vK2Jhcg==' — URL-safe encoding of b'foo+bar'"
  category: urlsafe_b64
  kind: python_call_eq
  function: urlsafe_b64encode
  args: [!ascii "foo+bar"]
  expected: !b64 "Zm9vK2Jhcg=="

# ---------------------------------------------------------------------------
# b16encode(b'hello') — value (extra14 namespace)
#
# RFC 4648 §8 specifies uppercase hex digits for Base16 encoding.
# 'h'=0x68, 'e'=0x65, 'l'=0x6c, 'l'=0x6c, 'o'=0x6f → b'68656C6C6F'.
# base64_extra13 covers b16encode(b'hi') == b'6869' (two chars, lowercase).
# Note: b16encode output is uppercase: 0x6c → '6C', 0x6f → '6F'.
# No prior spec covers b16encode(b'hello') as a value invariant from extra14.
# ---------------------------------------------------------------------------

invariant base64_extra14.b16encode.hello.value:
  description: "base64.b16encode(b'hello') == b'68656C6C6F' — RFC 4648 uppercase hex encoding of b'hello'"
  category: b16
  kind: python_call_eq
  function: b16encode
  args: [!ascii "hello"]
  expected: !ascii "68656C6C6F"
