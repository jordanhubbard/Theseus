# ---------------------------------------------------------------------------
# re.Pattern.__module__.__len__()
#
# Pattern.__module__ == 're', which has length 2.
# re.Pattern is the compiled regular expression type; its __module__ is 're'.
# ---------------------------------------------------------------------------

invariant re_extra30.Pattern.module.len:
  description: "re.Pattern.__module__.__len__() == 2 — 're' has 2 characters"
  category: string_length
  kind: python_call_eq
  function: Pattern.__module__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# re.Match.__module__.__len__()
#
# Match.__module__ == 're', which has length 2.
# re.Match is the match object type; its __module__ is 're'.
# ---------------------------------------------------------------------------

invariant re_extra30.Match.module.len:
  description: "re.Match.__module__.__len__() == 2 — 're' has 2 characters"
  category: string_length
  kind: python_call_eq
  function: Match.__module__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# Consolidated table — all twelve __len__ invariants
#
# Covers __module__.__len__() for compile/match/search/fullmatch/sub (5),
# __name__.__len__() for compile/match/search/fullmatch/sub (5), and
# __module__.__len__() for Pattern/Match (2).
# ---------------------------------------------------------------------------

table re_extra30.string_lengths:
  description: "String lengths of __module__ and __name__ attributes for re module functions and types"
  kind: python_call_eq
  category: string_length

  columns: [id, function, args, expected]
  rows:
    - [compile_module_len,   compile.__module__.__len__,   [], 2]
    - [match_module_len,     match.__module__.__len__,     [], 2]
    - [search_module_len,    search.__module__.__len__,    [], 2]
    - [fullmatch_module_len, fullmatch.__module__.__len__, [], 2]
    - [sub_module_len,       sub.__module__.__len__,       [], 2]
    - [compile_name_len,     compile.__name__.__len__,     [], 7]
    - [match_name_len,       match.__name__.__len__,       [], 5]
    - [search_name_len,      search.__name__.__len__,      [], 6]
    - [fullmatch_name_len,   fullmatch.__name__.__len__,   [], 9]
    - [sub_name_len,         sub.__name__.__len__,         [], 3]
    - [Pattern_module_len,   Pattern.__module__.__len__,   [], 2]
    - [Match_module_len,     Match.__module__.__len__,     [], 2]
