spec: re_extra30
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re_extra29.zspec.zsdl."
    - "Prior specs covered: re.compile/match/search/fullmatch/findall/finditer/sub/subn/split/escape/purge __name__/__module__/__qualname__, Pattern/Match/__name__/__module__/__qualname__/__bases__[0].__name__, re.error/__name__/__module__/__bases__[0].__name__, re.IGNORECASE/MULTILINE/DOTALL/VERBOSE values, various __qualname__ checks."
    - "This spec covers: compile.__module__.__len__() == 2, match.__module__.__len__() == 2, search.__module__.__len__() == 2, fullmatch.__module__.__len__() == 2, sub.__module__.__len__() == 2, compile.__name__.__len__() == 7, match.__name__.__len__() == 5, search.__name__.__len__() == 6, fullmatch.__name__.__len__() == 9, sub.__name__.__len__() == 3, Pattern.__module__.__len__() == 2, Match.__module__.__len__() == 2."
    - "re.compile.__module__ == 're' (len 2). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.match.__module__ == 're' (len 2). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.search.__module__ == 're' (len 2). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.fullmatch.__module__ == 're' (len 2). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.sub.__module__ == 're' (len 2). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.compile.__name__ == 'compile' (len 7). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.match.__name__ == 'match' (len 5). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.search.__name__ == 'search' (len 6). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.fullmatch.__name__ == 'fullmatch' (len 9). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.sub.__name__ == 'sub' (len 3). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.Pattern.__module__ == 're' (len 2). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.Match.__module__ == 're' (len 2). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.compile.__module__.__len__()
#
# compile.__module__ == 're', which has length 2. Prior specs record the
# __module__ string value; this spec records its length via __len__ as a
# fresh extra30-namespace invariant. The re module name is 2 characters long.
# ---------------------------------------------------------------------------

invariant re_extra30.compile.module.len:
  description: "re.compile.__module__.__len__() == 2 — 're' has 2 characters"
  category: string_length
  kind: python_call_eq
  function: compile.__module__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# re.match.__module__.__len__()
#
# match.__module__ == 're', which has length 2.
# ---------------------------------------------------------------------------

invariant re_extra30.match.module.len:
  description: "re.match.__module__.__len__() == 2 — 're' has 2 characters"
  category: string_length
  kind: python_call_eq
  function: match.__module__.__len__
