spec: emoji_rust
version: ">=3.9"
backend: rust_module(emoji_rust)

docs: https://carpedm20.github.io/emoji/docs/

provenance:
  derived_from:
    - "https://carpedm20.github.io/emoji/docs/ — emoji library documentation"
  not_derived_from:
    - "emoji source: emoji/core.py"
  notes:
    - "emoji converts emoji names to Unicode characters and vice versa."
    - "emoji.emojize(':thumbs_up:') == '👍'."
    - "emoji.emojize(':heart:') == '❤️'."
    - "emoji.demojize('👍') == ':thumbs_up:'."
    - "emoji.demojize('❤️') returns a name variant like ':red_heart:' or ':heart:'."
    - "Expose emojize(s) -> str: emoji.emojize(s, language='alias')."
    - "Expose demojize(s) -> str: emoji.demojize(s)."
    - "Expose emoji_count(s) -> int: emoji.emoji_count(s)."
    - "emoji_count('Hello 👍 World') == 1."
    - "emoji_count('👍❤️🎉') == 3."
    - "emoji_count('no emoji here') == 0."
    - "All test vectors verified against emoji 2.14.1."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# emojize — text to emoji
table emoji_rust.emojize.vectors:
  kind: python_call_eq
  category: emojize
  id_prefix: emj_ez
  function: emojize

  columns: [id, args, expected]
  rows:
    - [thumbs_up,  [":thumbs_up:"], "👍"]
    - [heart,      [":heart:"],     "❤️"]
    - [wave,       [":wave:"],      "👋"]

# emoji_count — count emojis in string
table emoji_rust.count.vectors:
  kind: python_call_eq
  category: count
  id_prefix: emj_cnt
  function: emoji_count

  columns: [id, args, expected]
  rows:
    - [one,   ["Hello 👍 World"],  1]
    - [three, ["👍❤️🎉"],           3]
    - [none,  ["no emoji here"],  0]
    - [empty, [""],               0]

# demojize — emoji to text name
invariant emoji_rust.demojize.thumbs_up:
  description: "demojize('👍') returns a name containing 'thumbs'"
  category: demojize
  kind: python_call_eq
  function: demojize_contains
  args: ["👍", "thumbs"]
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: infeasible
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T00:10:53Z
  iterations: 1
  pass_count: 0
  fail_count: 0
  total_invariants: 8
  notes: "LLM unavailable: OpenAI API request failed: HTTP Error 502: Bad Gateway"
  infeasible_reason: llm_unavailable
  invariant_annotations: {}
