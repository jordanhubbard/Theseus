# concurrent.futures.Executor core methods — extra172
#
# concurrent.futures.Executor.submit.__name__.__eq__('submit')       == True (len=6)
# concurrent.futures.Executor.map.__name__.__eq__('map')             == True (len=3)
# concurrent.futures.Executor.shutdown.__name__.__eq__('shutdown')   == True (len=8)
# ---------------------------------------------------------------------------

table concurrent_futures_extra172.executor_core_methods:
  description: "concurrent.futures.Executor core method name identity checks in cfexecutor172core namespace — concurrent.futures.Executor.submit.__name__.__eq__('submit')==True ('submit'=6: 's'+'u'+'b'+'m'+'i'+'t'=6; Executor.submit(fn, *args, **kwargs) submits a callable to be executed asynchronously and returns a Future); concurrent.futures.Executor.submit.__name__.__len__()==6; concurrent.futures.Executor.map.__name__.__eq__('map')==True ('map'=3: 'm'+'a'+'p'=3; the shortest method name in this spec; Executor.map(fn, *iterables, timeout=None, chunksize=1) is equivalent to map(fn, *iterables) but runs asynchronously); concurrent.futures.Executor.map.__name__.__len__()==3; concurrent.futures.Executor.shutdown.__name__.__eq__('shutdown')==True ('shutdown'=8: 's'+'h'+'u'+'t'+'d'+'o'+'w'+'n'=8; Executor.shutdown(wait=True, cancel_futures=False) signals the executor to free resources; same length as '__exit__'=8 by coincidence — but 'shutdown' is undecorated and '__exit__' has dunder wrapping); concurrent.futures.Executor.shutdown.__name__.__len__()==8; NAME LENGTHS: 'map'=3 < 'submit'=6 < '__exit__'=8 == 'shutdown'=8 < '__enter__'=9; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexecutor172core

  columns: [id, function, args, expected, description]
  rows:
    - [submit_name_eq,    "concurrent.futures.Executor.submit.__name__.__eq__",    ["submit"],    true,  "Executor.submit.__name__ == 'submit' (len=6); verified with Python 3.14.3"]
    - [submit_name_len,   "concurrent.futures.Executor.submit.__name__.__len__",   [],            6,     "Executor.submit.__name__.__len__() == 6 ('submit'=6); verified with Python 3.14.3"]
    - [map_name_eq,       "concurrent.futures.Executor.map.__name__.__eq__",       ["map"],       true,  "Executor.map.__name__ == 'map' (len=3; shortest method name in this spec); verified with Python 3.14.3"]
    - [map_name_len,      "concurrent.futures.Executor.map.__name__.__len__",      [],            3,     "Executor.map.__name__.__len__() == 3 ('map'=3; shortest in spec); verified with Python 3.14.3"]
    - [shutdown_name_eq,  "concurrent.futures.Executor.shutdown.__name__.__eq__",  ["shutdown"],  true,  "Executor.shutdown.__name__ == 'shutdown' (len=8: same len as '__exit__'=8); verified with Python 3.14.3"]
    - [shutdown_name_len, "concurrent.futures.Executor.shutdown.__name__.__len__", [],            8,     "Executor.shutdown.__name__.__len__() == 8 ('shutdown'=8; same as '__exit__'=8); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.Future callback and result methods — extra172
#
# concurrent.futures.Future.add_done_callback.__name__.__eq__('add_done_callback')  == True (len=17)
# concurrent.futures.Future.set_result.__name__.__eq__('set_result')                == True (len=10)
# ---------------------------------------------------------------------------

table concurrent_futures_extra172.future_methods:
  description: "concurrent.futures.Future method name identity checks in cfexecutor172fut namespace — concurrent.futures.Future.add_done_callback.__name__.__eq__('add_done_callback')==True ('add_done_callback'=17: 'add'=3+'_'=1+'done'=4+'_'=1+'callback'=8=17; Future.add_done_callback(fn) registers fn to be called when the future completes; fn receives the future as its only argument; callbacks are called in FIFO order; if the future is already done, the callback is scheduled immediately); concurrent.futures.Future.add_done_callback.__name__.__len__()==17; concurrent.futures.Future.set_result.__name__.__eq__('set_result')==True ('set_result'=10: 'set'=3+'_'=1+'result'=6=10; Future.set_result(result) sets the result of the future; raises InvalidStateError if already done; typically called by executor internals, not user code); concurrent.futures.Future.set_result.__name__.__len__()==10; NAME LENGTHS in this spec: 'map'=3 < 'submit'=6 < '__exit__'=8 == 'shutdown'=8 < '__enter__'=9 < 'set_result'=10 < 'add_done_callback'=17; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexecutor172fut

  columns: [id, function, args, expected, description]
  rows:
    - [adc_name_eq,   "concurrent.futures.Future.add_done_callback.__name__.__eq__",  ["add_done_callback"],  true,  "Future.add_done_callback.__name__ == 'add_done_callback' (len=17: 'add'=3+'_done_callback'=14=17); verified with Python 3.14.3"]
    - [adc_name_len,  "concurrent.futures.Future.add_done_callback.__name__.__len__", [],                     17,    "Future.add_done_callback.__name__.__len__() == 17 (longest method name in this spec); verified with Python 3.14.3"]
    - [sr_name_eq,    "concurrent.futures.Future.set_result.__name__.__eq__",         ["set_result"],         true,  "Future.set_result.__name__ == 'set_result' (len=10: 'set'=3+'_result'=7=10); verified with Python 3.14.3"]
    - [sr_name_len,   "concurrent.futures.Future.set_result.__name__.__len__",        [],                     10,    "Future.set_result.__name__.__len__() == 10 ('set_result'=10); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra172
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra172.executor_enter_name_eq:
  description: "concurrent.futures.Executor.__enter__.__name__.__eq__('__enter__') returns True — concurrent.futures.Executor.__enter__.__name__=='__enter__' (len=9: '__'=2+'enter'=5+'__'=2=9); Executor.__enter__ is the context manager entry method; it simply returns self, enabling the pattern 'with ThreadPoolExecutor() as executor:'; the with-statement protocol calls __enter__ on entry and __exit__ on exit (even if an exception occurs); Executor.__enter__ returns self so the 'as' clause binds to the executor object itself; '__enter__'=9 is 1 char longer than '__exit__'=8 because 'enter'=5 > 'exit'=4; both share the '__....__' dunder wrapping (2+2=4 overhead chars); NEW in extra172: first standalone Executor.__enter__.__name__ invariant in cfexecutor172cm namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Executor.__enter__.__name__.__eq__"
  args: ["__enter__"]
  expected: true

invariant concurrent_futures_extra172.executor_exit_name_eq:
  description: "concurrent.futures.Executor.__exit__.__name__.__eq__('__exit__') returns True — concurrent.futures.Executor.__exit__.__name__=='__exit__' (len=8: '__'=2+'exit'=4+'__'=2=8); Executor.__exit__ is the context manager exit method; it receives three arguments (exc_type, exc_val, exc_tb) from the with-statement and calls self.shutdown(wait=True); this ensures all submitted futures are completed and all worker threads/processes are cleaned up before leaving the with block; '__exit__'=8 is 1 shorter than '__enter__'=9; the same length as Executor.shutdown.__name__='shutdown'=8 (coincidence — both 8 chars but one is a dunder and one is not); NEW in extra172: first standalone Executor.__exit__.__name__ invariant in cfexecutor172cm namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Executor.__exit__.__name__.__eq__"
  args: ["__exit__"]
  expected: true

invariant concurrent_futures_extra172.executor_map_name_len:
  description: "concurrent.futures.Executor.map.__name__.__len__() == 3 — concurrent.futures.Executor.map.__name__ is 'map' (3 characters: 'm'+'a'+'p'=3); 'map' is the shortest method name in this spec: 'map'=3 < 'submit'=6 < 'shutdown'=8; Executor.map(fn, *iterables, timeout=None, chunksize=1) provides a convenient interface equivalent to Python's built-in map() but executed asynchronously in the thread/process pool; it returns an iterator of results in the same order as the input iterables; the chunksize parameter applies only to ProcessPoolExecutor and controls how many items are sent to each worker at once (batching reduces IPC overhead for large iterables); NEW in extra172: first standalone Executor.map.__name__.__len__ invariant in cfexecutor172core namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Executor.map.__name__.__len__"
  args: []
  expected: 3

invariant concurrent_futures_extra172.future_add_done_callback_name_len:
  description: "concurrent.futures.Future.add_done_callback.__name__.__len__() == 17 — concurrent.futures.Future.add_done_callback.__name__ is 'add_done_callback' (17 characters: 'add'=3+'_'=1+'done'=4+'_'=1+'callback'=8=17); 'add_done_callback'=17 is the longest method name in this spec — it is 8 chars longer than 'set_result'=10, 11 chars longer than '__enter__'=9, and 14 chars longer than 'map'=3; Future.add_done_callback supports composing futures: each callback receives the completed future and can chain subsequent work; callbacks are called in the thread that completed the future OR the calling thread if the future was already complete when add_done_callback was called; NEW in extra172: first standalone Future.add_done_callback.__name__.__len__ invariant in cfexecutor172fut namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Future.add_done_callback.__name__.__len__"
  args: []
  expected: 17

invariant concurrent_futures_extra172.executor_submit_name_eq:
  description: "concurrent.futures.Executor.submit.__name__.__eq__('submit') returns True — concurrent.futures.Executor.submit.__name__=='submit' (len=6: 's'+'u'+'b'+'m'+'i'+'t'=6); Executor.submit(fn, *args, **kwargs) is the primary method for submitting work to the executor; it returns a concurrent.futures.Future immediately; the Future represents the pending result of the call; Executor.submit is declared as an abstract method in the base Executor class — subclasses ThreadPoolExecutor and ProcessPoolExecutor provide concrete implementations; 'submit'=6 is the second-shortest non-dunder method name in this spec after 'map'=3; NAME: 'submit' comes from the job submission metaphor (submit a task for execution); NEW in extra172: first standalone Executor.submit.__name__ invariant in cfexecutor172core namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Executor.submit.__name__.__eq__"
  args: ["submit"]
  expected: true

invariant concurrent_futures_extra172.future_set_result_name_eq:
  description: "concurrent.futures.Future.set_result.__name__.__eq__('set_result') returns True — concurrent.futures.Future.set_result.__name__=='set_result' (len=10: 'set'=3+'_'=1+'result'=6=10); concurrent.futures.Future.set_result(result) sets the result of the work associated with the Future to result; raises concurrent.futures.InvalidStateError if the Future is already done (completed, cancelled, or raised an exception); set_result is primarily intended for internal use by executor implementations and test code — user code typically only reads from futures via .result(), .exception(), and .add_done_callback(); 'set_result'=10 > '__enter__'=9 by 1; 'set_result'=10 < 'add_done_callback'=17 by 7; NEW in extra172: first standalone Future.set_result.__name__ invariant in cfexecutor172fut namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Future.set_result.__name__.__eq__"
  args: ["set_result"]
  expected: true
