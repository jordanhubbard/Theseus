spec: concurrent_futures_extra172
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: concurrent.futures executor context manager protocol — concurrent.futures.Executor.__enter__.__name__=='__enter__' (len=9: '__'=2+'enter'=5+'__'=2=9); concurrent.futures.Executor.__exit__.__name__=='__exit__' (len=8: '__'=2+'exit'=4+'__'=2=8); concurrent.futures.Executor.submit.__name__=='submit' (len=6); concurrent.futures.Executor.map.__name__=='map' (len=3); concurrent.futures.Executor.shutdown.__name__=='shutdown' (len=8); concurrent.futures.Future.add_done_callback.__name__=='add_done_callback' (len=17: 'add'=3+'_done_callback'=14=17); concurrent.futures.Future.set_result.__name__=='set_result' (len=10: 'set'=3+'_result'=7=10). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Executor.__enter__.__name__.__len__() == 9. '__enter__' is 9 characters: '__'=2 + 'enter'=5 + '__'=2 = 9. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Executor.__exit__.__name__.__len__() == 8. '__exit__' is 8 characters: '__'=2 + 'exit'=4 + '__'=2 = 8. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Future.add_done_callback.__name__.__len__() == 17. 'add_done_callback' is 17 characters: 'add'=3 + '_'=1 + 'done'=4 + '_'=1 + 'callback'=8 = 17. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Executor context manager methods — extra172
#
# concurrent.futures.Executor.__enter__.__name__.__eq__('__enter__')  == True (len=9)
# concurrent.futures.Executor.__exit__.__name__.__eq__('__exit__')    == True (len=8)
# ---------------------------------------------------------------------------

table concurrent_futures_extra172.executor_context_manager_methods:
  description: "concurrent.futures.Executor context manager method name identity checks in cfexecutor172cm namespace — concurrent.futures.Executor.__enter__.__name__.__eq__('__enter__')==True ('__enter__'=9: '__'=2+'enter'=5+'__'=2=9; Executor.__enter__ simply returns self, enabling use as 'with Executor() as ex:'); concurrent.futures.Executor.__enter__.__name__.__len__()==9; concurrent.futures.Executor.__exit__.__name__.__eq__('__exit__')==True ('__exit__'=8: '__'=2+'exit'=4+'__'=2=8; Executor.__exit__ calls self.shutdown(wait=True) to clean up the thread/process pool on context exit); concurrent.futures.Executor.__exit__.__name__.__len__()==8; NOTE: '__enter__'=9 is 1 char longer than '__exit__'=8 ('enter'=5 vs 'exit'=4); both are defined in concurrent.futures._base.Executor (Lib/concurrent/futures/_base.py); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexecutor172cm

  columns: [id, function, args, expected, description]
  rows:
    - [enter_name_eq,   "concurrent.futures.Executor.__enter__.__name__.__eq__",  ["__enter__"],  true,  "Executor.__enter__.__name__ == '__enter__' (len=9: '__'=2+'enter'=5+'__'=2=9); verified with Python 3.14.3"]
    - [enter_name_len,  "concurrent.futures.Executor.__enter__.__name__.__len__", [],             9,     "Executor.__enter__.__name__.__len__() == 9 ('__enter__'=9); verified with Python 3.14.3"]
    - [exit_name_eq,    "concurrent.futures.Executor.__exit__.__name__.__eq__",   ["__exit__"],   true,  "Executor.__exit__.__name__ == '__exit__' (len=8: '__'=2+'exit'=4+'__'=2=8); verified with Python 3.14.3"]
    - [exit_name_len,   "concurrent.futures.Executor.__exit__.__name__.__len__",  [],             8,     "Executor.__exit__.__name__.__len__() == 8 ('__exit__'=8; 1 shorter than '__enter__'=9); verified with Python 3.14.3"]

