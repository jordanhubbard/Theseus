spec: collections_abc
version: ">=3.3"
backend: python_module(collections.abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/collections.abc.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "collections.abc source: _collections_abc.py (PSF; source inspection permitted)"
  not_derived_from:
    - "collections.abc source: internal ABC registration mechanisms"
  notes:
    - "All ABCs in collections.abc are defined in the module 'collections.abc'."
    - "ABCs provide __subclasshook__ for implicit registration of built-in types."
    - "ByteString is deprecated since Python 3.12 but still present."
    - "Buffer was added in Python 3.12."
    - "All classes verified present in Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Attribute access raises AttributeError for missing names; ABC instantiation raises TypeError."
  stderr: "null"
  stickiness: "N/A — each access is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Class name checks — __name__ attribute of each ABC class
# ---------------------------------------------------------------------------

table collections_abc.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cls

  columns: [id, function, args, expected]
  rows:
    - [hashable,         Hashable.__name__.__eq__,          ["Hashable"],          true]
    - [iterable,         Iterable.__name__.__eq__,          ["Iterable"],          true]
    - [iterator,         Iterator.__name__.__eq__,          ["Iterator"],          true]
    - [callable_abc,     Callable.__name__.__eq__,          ["Callable"],          true]
    - [container,        Container.__name__.__eq__,         ["Container"],         true]
    - [collection,       Collection.__name__.__eq__,        ["Collection"],        true]
    - [sized,            Sized.__name__.__eq__,             ["Sized"],             true]
    - [reversible,       Reversible.__name__.__eq__,        ["Reversible"],        true]
    - [sequence,         Sequence.__name__.__eq__,          ["Sequence"],          true]
    - [mutable_sequence, MutableSequence.__name__.__eq__,   ["MutableSequence"],   true]
    - [set_abc,          Set.__name__.__eq__,               ["Set"],               true]
    - [mutable_set,      MutableSet.__name__.__eq__,        ["MutableSet"],        true]
    - [mapping,          Mapping.__name__.__eq__,           ["Mapping"],           true]
    - [mutable_mapping,  MutableMapping.__name__.__eq__,    ["MutableMapping"],    true]
    - [mapping_view,     MappingView.__name__.__eq__,       ["MappingView"],       true]
    - [keys_view,        KeysView.__name__.__eq__,          ["KeysView"],          true]
    - [items_view,       ItemsView.__name__.__eq__,         ["ItemsView"],         true]
    - [values_view,      ValuesView.__name__.__eq__,        ["ValuesView"],        true]
    - [generator,        Generator.__name__.__eq__,         ["Generator"],         true]
    - [awaitable,        Awaitable.__name__.__eq__,         ["Awaitable"],         true]
    - [coroutine_abc,    Coroutine.__name__.__eq__,         ["Coroutine"],         true]
    - [async_iterable,   AsyncIterable.__name__.__eq__,     ["AsyncIterable"],     true]
    - [async_iterator,   AsyncIterator.__name__.__eq__,     ["AsyncIterator"],     true]
    - [async_generator,  AsyncGenerator.__name__.__eq__,    ["AsyncGenerator"],    true]

# ---------------------------------------------------------------------------
# Module checks — all ABCs live in collections.abc
# ---------------------------------------------------------------------------

table collections_abc.module_checks:
  kind: python_call_eq
  category: module
  id_prefix: mod

  columns: [id, function, args, expected]
  rows:
    - [sequence_module,  Sequence.__module__.__eq__,      ["collections.abc"],  true]
    - [mapping_module,   Mapping.__module__.__eq__,       ["collections.abc"],  true]
    - [hashable_module,  Hashable.__module__.__eq__,      ["collections.abc"],  true]
    - [iterable_module,  Iterable.__module__.__eq__,      ["collections.abc"],  true]
    - [callable_module,  Callable.__module__.__eq__,      ["collections.abc"],  true]
    - [set_module,       Set.__module__.__eq__,           ["collections.abc"],  true]

