spec: decimal_extra12
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html
rfcs:
  - "IBM General Decimal Arithmetic specification"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec extends decimal.zspec.zsdl and prior extras (decimal_extra through decimal_extra11)."
    - "decimal_extra8 covers: is_zero(0)==True, is_zero(1)==False, is_signed(-1)==True, is_signed(1)==False."
    - "decimal_extra through decimal_extra11 cover: is_nan, is_infinite, is_finite, is_normal, is_qnan, is_snan, scaleb, shift."
    - "No prior spec covers Decimal.fma() (fused multiply-add)."
    - "No prior spec covers Decimal.compare() as a value-returning call."
    - "No prior spec covers Decimal.logb() (adjusted exponent as Decimal)."
    - "No prior spec covers Decimal.radix() (always returns Decimal('10'))."
    - "No prior spec covers Decimal.remainder_near() (IEEE 754-style remainder)."
    - "Decimal('1').fma(2, 3).__str__() == '5' — fused multiply-add: 1*2+3."
    - "Decimal('2').fma(3, 4).__str__() == '10' — fused multiply-add: 2*3+4."
    - "Decimal('2').compare(1).__str__() == '1' — compare returns 1 when self > other."
    - "Decimal('1').compare(2).__str__() == '-1' — compare returns -1 when self < other."
    - "Decimal('100').logb().__str__() == '2' — adjusted exponent of 100 is 2 (10^2)."
    - "Decimal('1').logb().__str__() == '0' — adjusted exponent of 1 is 0 (10^0)."
    - "Decimal('1').radix().__str__() == '10' — Decimal always uses base 10."
    - "Decimal('5').remainder_near(3).__str__() == '-1' — IEEE 754 remainder: 5 - 2*3 == -1."
    - "Decimal('10').remainder_near(3).__str__() == '1' — IEEE 754 remainder: 10 - 3*3 == 1."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal.fma() — fused multiply-add
#
# fma(b, c) computes self * b + c in a single operation (no intermediate
# rounding). No prior spec covers fma().
# Integer method_args are accepted by fma() and auto-converted to Decimal.
# Results are compared as strings via method_chain: __str__.
# Decimal('1').fma(2, 3) == Decimal('5'): 1*2+3=5.
# Decimal('2').fma(3, 4) == Decimal('10'): 2*3+4=10.
# ---------------------------------------------------------------------------

invariant decimal_extra12.Decimal.fma_one_two_three:
  description: "Decimal('1').fma(2, 3).__str__() == '5' — fused multiply-add: 1*2+3 == 5"
  category: arithmetic
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: fma
  method_args: [2, 3]
  method_chain: __str__
  expected: "5"

invariant decimal_extra12.Decimal.fma_two_three_four:
  description: "Decimal('2').fma(3, 4).__str__() == '10' — fused multiply-add: 2*3+4 == 10"
  category: arithmetic
  kind: python_call_eq
  function: Decimal
  args: ["2"]
  method: fma
  method_args: [3, 4]
  method_chain: __str__
  expected: "10"

# ---------------------------------------------------------------------------
# Decimal.compare() — three-way comparison returning Decimal
#
# compare() returns Decimal('-1'), Decimal('0'), or Decimal('1') depending
# on whether self is less than, equal to, or greater than other.
# No prior spec covers compare() as a value-returning call.
# Integer method_args are accepted and auto-converted to Decimal.
# ---------------------------------------------------------------------------

invariant decimal_extra12.Decimal.compare_greater:
  description: "Decimal('2').compare(1).__str__() == '1' — compare returns 1 when self > other"
  category: comparison
  kind: python_call_eq
  function: Decimal
  args: ["2"]
  method: compare
  method_args: [1]
  method_chain: __str__
  expected: "1"

invariant decimal_extra12.Decimal.compare_less:
  description: "Decimal('1').compare(2).__str__() == '-1' — compare returns -1 when self < other"
  category: comparison
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: compare
  method_args: [2]
  method_chain: __str__
  expected: "-1"

# ---------------------------------------------------------------------------
# Decimal.logb() — adjusted exponent
#
# logb() returns the adjusted exponent of self as a Decimal (IEEE 754 logB).
# For Decimal('100'): 100 == 1.00e+2, adjusted exponent == 2.
# For Decimal('1'): 1 == 1e+0, adjusted exponent == 0.
# No prior spec covers logb().
# ---------------------------------------------------------------------------

invariant decimal_extra12.Decimal.logb_hundred:
  description: "Decimal('100').logb().__str__() == '2' — adjusted exponent of 100 is 2"
  category: arithmetic
  kind: python_call_eq
  function: Decimal
  args: ["100"]
  method: logb
  method_chain: __str__
  expected: "2"

invariant decimal_extra12.Decimal.logb_one:
  description: "Decimal('1').logb().__str__() == '0' — adjusted exponent of 1 is 0"
  category: arithmetic
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: logb
  method_chain: __str__
  expected: "0"

# ---------------------------------------------------------------------------
# Decimal.radix() — always returns Decimal('10')
#
# radix() returns Decimal('10') regardless of the Decimal's value — the
# decimal module always uses base 10 per IEEE 754. No prior spec covers radix().
# ---------------------------------------------------------------------------

invariant decimal_extra12.Decimal.radix:
  description: "Decimal('1').radix().__str__() == '10' — Decimal always uses base 10"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: radix
  method_chain: __str__
  expected: "10"

# ---------------------------------------------------------------------------
# Decimal.remainder_near() — IEEE 754-style remainder
#
# remainder_near(other) computes self - n*other where n is the integer
# nearest to self/other (round half to even). This differs from the %
# operator which always returns a non-negative result.
# No prior spec covers remainder_near().
# Integer method_args are accepted: remainder_near(3) is equivalent to
# remainder_near(Decimal('3')).
# Decimal('5').remainder_near(3): 5/3 ≈ 1.67, rounds to 2, so 5 - 2*3 = -1.
# Decimal('10').remainder_near(3): 10/3 ≈ 3.33, rounds to 3, so 10 - 3*3 = 1.
# ---------------------------------------------------------------------------

invariant decimal_extra12.Decimal.remainder_near_five_three:
  description: "Decimal('5').remainder_near(3).__str__() == '-1' — IEEE 754 remainder: 5 - 2*3 == -1"
  category: arithmetic
  kind: python_call_eq
  function: Decimal
  args: ["5"]
  method: remainder_near
  method_args: [3]
  method_chain: __str__
  expected: "-1"

invariant decimal_extra12.Decimal.remainder_near_ten_three:
  description: "Decimal('10').remainder_near(3).__str__() == '1' — IEEE 754 remainder: 10 - 3*3 == 1"
  category: arithmetic
  kind: python_call_eq
  function: Decimal
  args: ["10"]
  method: remainder_near
  method_args: [3]
  method_chain: __str__
  expected: "1"
