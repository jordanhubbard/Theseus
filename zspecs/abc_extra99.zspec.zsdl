spec: abc_extra99
version: ">=3.9"
backend: python_module(abc)
extends: abc_extra98

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra98.zspec.zsdl."
    - "This spec covers: wave 254 theme — abc ABCMeta __init__ and __new__ method identity. NEW in extra99: abc.ABCMeta.__init__.__class__.__name__=='wrapper_descriptor' (ABCMeta.__init__ is inherited from type, not Python-defined); abc.ABCMeta.__init__.__qualname__=='type.__init__' (len=13, reflects the defining class type); abc.ABCMeta.__new__.__class__.__name__=='function' (ABCMeta.__new__ is Python-defined in abc.py); abc.ABCMeta.__new__.__qualname__=='ABCMeta.__new__' (len=15); abc.ABCMeta.__new__.__code__.co_argcount==4 (mcls, name, bases, namespace); abc.ABC.__init_subclass__.__class__.__name__=='builtin_function_or_method'; abc.ABC.__init_subclass__.__qualname__=='ABC.__init_subclass__' (len=21); abc.ABCMeta.register.__class__.__name__=='function'; abc.ABCMeta.register.__code__.co_argcount==2 (cls, subclass); abc.ABCMeta._dump_registry.__qualname__=='ABCMeta._dump_registry' (len=22, longest); abc.ABCMeta._dump_registry.__code__.co_argcount==2 (cls, file); abc.abstractmethod.__qualname__=='abstractmethod' (len=14); abc.ABCMeta.__subclasshook__.__qualname__=='ABCMeta.__subclasshook__' (len=24, longest method qualname). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__init__.__class__.__name__ == 'wrapper_descriptor'. ABCMeta does not define its own __init__; it inherits from type, so ABCMeta.__init__ is type.__init__ (a C-level wrapper_descriptor). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__new__.__class__.__name__ == 'function'. ABCMeta defines __new__ in Python (Lib/abc.py), so it is a Python function (class='function'). co_argcount==4: (mcls, name, bases, namespace). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__init_subclass__.__qualname__.__len__() == 21. 'ABC.__init_subclass__' is 21 chars: 'ABC.'=4 + '__init_subclass__'=17. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__subclasshook__.__qualname__.__len__() == 24. 'ABCMeta.__subclasshook__' is 24 chars: 'ABCMeta.'=8 + '__subclasshook__'=16. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta.__init__ and __new__ method identity — extra99
#
# Wave 254 theme: abc ABCMeta __init__ and __new__ method identity.
#
# abc.ABCMeta.__init__.__class__.__name__  == 'wrapper_descriptor'  (inherited from type)
# abc.ABCMeta.__init__.__qualname__        == 'type.__init__'       (len=13)
# abc.ABCMeta.__new__.__class__.__name__   == 'function'            (Python-defined)
# abc.ABCMeta.__new__.__qualname__         == 'ABCMeta.__new__'     (len=15)
# abc.ABCMeta.__new__.__code__.co_argcount == 4
# ---------------------------------------------------------------------------

table abc_extra99.abc_abcmeta_init_new_identity:
  description: "abc.ABCMeta.__init__ and __new__ method identity checks in abcmeta99 namespace — wave 254 theme: ABCMeta.__init__ is inherited from type (not Python-defined in abc.py), so its class is 'wrapper_descriptor' (a C-level descriptor wrapping type.__init__); abc.ABCMeta.__init__.__class__.__name__.__eq__('wrapper_descriptor')==True; abc.ABCMeta.__init__.__qualname__.__eq__('type.__init__')==True (len=13: 'type.'=5 + '__init__'=8; qualname uses defining class 'type', not 'ABCMeta'); abc.ABCMeta.__init__.__qualname__.__len__()==13; in contrast ABCMeta.__new__ IS Python-defined in Lib/abc.py, so its class is 'function'; abc.ABCMeta.__new__.__class__.__name__.__eq__('function')==True; abc.ABCMeta.__new__.__qualname__.__eq__('ABCMeta.__new__')==True (len=15: 'ABCMeta.'=8 + '__new__'=7); abc.ABCMeta.__new__.__qualname__.__len__()==15; abc.ABCMeta.__new__.__code__.co_argcount==4 (mcls, name, bases, namespace); abc.ABCMeta.__new__.__module__.__eq__('abc')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmeta99

  columns: [id, function, args, expected, description]
  rows:
    - [init_cls,    abc.ABCMeta.__init__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true, "abc.ABCMeta.__init__.__class__.__name__ == 'wrapper_descriptor' (inherited from type); verified with Python 3.14.3"]
    - [init_qn_eq,  abc.ABCMeta.__init__.__qualname__.__eq__,          ["type.__init__"],      true, "abc.ABCMeta.__init__.__qualname__ == 'type.__init__' (len=13, qualname uses defining class 'type'); verified with Python 3.14.3"]
    - [init_qn_len, abc.ABCMeta.__init__.__qualname__.__len__,         [],                     13,   "abc.ABCMeta.__init__.__qualname__.__len__() == 13 ('type.'=5+'__init__'=8); verified with Python 3.14.3"]
    - [new_cls,     abc.ABCMeta.__new__.__class__.__name__.__eq__,     ["function"],           true, "abc.ABCMeta.__new__.__class__.__name__ == 'function' (Python-defined in abc.py); verified with Python 3.14.3"]
    - [new_qn_eq,   abc.ABCMeta.__new__.__qualname__.__eq__,           ["ABCMeta.__new__"],    true, "abc.ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__' (len=15); verified with Python 3.14.3"]
    - [new_qn_len,  abc.ABCMeta.__new__.__qualname__.__len__,          [],                     15,   "abc.ABCMeta.__new__.__qualname__.__len__() == 15 ('ABCMeta.'=8+'__new__'=7); verified with Python 3.14.3"]
    - [new_args,    abc.ABCMeta.__new__.__code__.co_argcount.__eq__,   [4],                    true, "abc.ABCMeta.__new__.__code__.co_argcount == 4 (mcls, name, bases, namespace); verified with Python 3.14.3"]
    - [new_module,  abc.ABCMeta.__new__.__module__.__eq__,             ["abc"],                true, "abc.ABCMeta.__new__.__module__ == 'abc' (Python-defined in Lib/abc.py); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta.register, _dump_registry, __subclasshook__ and
# abc.ABC.__init_subclass__ method identity — extra99
#
# abc.ABC.__init_subclass__.__class__.__name__        == 'builtin_function_or_method'
# abc.ABC.__init_subclass__.__qualname__              == 'ABC.__init_subclass__'   (len=21)
# abc.ABCMeta.register.__class__.__name__             == 'function'
# abc.ABCMeta.register.__code__.co_argcount           == 2
# abc.ABCMeta.register.__qualname__                   == 'ABCMeta.register'        (len=16)
# abc.ABCMeta._dump_registry.__qualname__             == 'ABCMeta._dump_registry'  (len=22)
# abc.ABCMeta._dump_registry.__code__.co_argcount     == 2
# abc.ABCMeta.__subclasshook__.__qualname__            == 'ABCMeta.__subclasshook__'(len=24, longest)
# abc.abstractmethod.__qualname__                     == 'abstractmethod'           (len=14)
# ---------------------------------------------------------------------------

table abc_extra99.abc_abcmeta_method_identity:
  description: "abc.ABCMeta method identity and __qualname__ checks in abcmeta99 namespace — wave 254 theme: abc.ABC.__init_subclass__.__class__.__name__.__eq__('builtin_function_or_method')==True (ABC inherits __init_subclass__ from object — it is a built-in classmethod); abc.ABC.__init_subclass__.__qualname__.__eq__('ABC.__init_subclass__')==True (len=21: 'ABC.'=4 + '__init_subclass__'=17); abc.ABC.__init_subclass__.__qualname__.__len__()==21; abc.ABCMeta.register.__class__.__name__.__eq__('function')==True (Python-defined classmethod in abc.py); abc.ABCMeta.register.__qualname__.__eq__('ABCMeta.register')==True (len=16: 'ABCMeta.'=8 + 'register'=8); abc.ABCMeta.register.__qualname__.__len__()==16; abc.ABCMeta.register.__code__.co_argcount==2 (cls, subclass); abc.ABCMeta._dump_registry.__qualname__.__eq__('ABCMeta._dump_registry')==True (len=22: 'ABCMeta.'=8 + '_dump_registry'=14); abc.ABCMeta._dump_registry.__qualname__.__len__()==22; abc.ABCMeta._dump_registry.__code__.co_argcount==2 (cls, file); abc.ABCMeta.__subclasshook__.__qualname__.__len__()==24 (longest method qualname in spec: 'ABCMeta.'=8+'__subclasshook__'=16); abc.abstractmethod.__qualname__.__eq__('abstractmethod')==True (len=14); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmeta99a

  columns: [id, function, args, expected, description]
  rows:
    - [initsub_cls,   abc.ABC.__init_subclass__.__class__.__name__.__eq__,     ["builtin_function_or_method"], true, "abc.ABC.__init_subclass__.__class__.__name__ == 'builtin_function_or_method' (inherited from object); verified with Python 3.14.3"]
    - [initsub_qn_eq, abc.ABC.__init_subclass__.__qualname__.__eq__,            ["ABC.__init_subclass__"],      true, "abc.ABC.__init_subclass__.__qualname__ == 'ABC.__init_subclass__' (len=21); verified with Python 3.14.3"]
    - [initsub_qn_ln, abc.ABC.__init_subclass__.__qualname__.__len__,           [],                             21,   "abc.ABC.__init_subclass__.__qualname__.__len__() == 21 ('ABC.'=4+'__init_subclass__'=17); verified with Python 3.14.3"]
    - [reg_cls,       abc.ABCMeta.register.__class__.__name__.__eq__,           ["function"],                   true, "abc.ABCMeta.register.__class__.__name__ == 'function' (Python-defined classmethod); verified with Python 3.14.3"]
    - [reg_qn_eq,     abc.ABCMeta.register.__qualname__.__eq__,                 ["ABCMeta.register"],           true, "abc.ABCMeta.register.__qualname__ == 'ABCMeta.register' (len=16); verified with Python 3.14.3"]
    - [reg_qn_len,    abc.ABCMeta.register.__qualname__.__len__,                [],                             16,   "abc.ABCMeta.register.__qualname__.__len__() == 16 ('ABCMeta.'=8+'register'=8); verified with Python 3.14.3"]
    - [reg_args,      abc.ABCMeta.register.__code__.co_argcount.__eq__,         [2],                            true, "abc.ABCMeta.register.__code__.co_argcount == 2 (cls, subclass); verified with Python 3.14.3"]
    - [dump_qn_eq,    abc.ABCMeta._dump_registry.__qualname__.__eq__,           ["ABCMeta._dump_registry"],     true, "abc.ABCMeta._dump_registry.__qualname__ == 'ABCMeta._dump_registry' (len=22); verified with Python 3.14.3"]
    - [dump_qn_len,   abc.ABCMeta._dump_registry.__qualname__.__len__,          [],                             22,   "abc.ABCMeta._dump_registry.__qualname__.__len__() == 22 ('ABCMeta.'=8+'_dump_registry'=14); verified with Python 3.14.3"]
    - [dump_args,     abc.ABCMeta._dump_registry.__code__.co_argcount.__eq__,   [2],                            true, "abc.ABCMeta._dump_registry.__code__.co_argcount == 2 (cls, file); verified with Python 3.14.3"]
    - [hook_qn_len,   abc.ABCMeta.__subclasshook__.__qualname__.__len__,        [],                             24,   "abc.ABCMeta.__subclasshook__.__qualname__.__len__() == 24 (longest in spec: 'ABCMeta.'=8+'__subclasshook__'=16); verified with Python 3.14.3"]
    - [absm_qn_eq,    abc.abstractmethod.__qualname__.__eq__,                   ["abstractmethod"],             true, "abc.abstractmethod.__qualname__ == 'abstractmethod' (len=14); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra99
# ---------------------------------------------------------------------------

invariant abc_extra99.ABCMeta_init_is_wrapper_descriptor:
  description: "abc.ABCMeta.__init__.__class__.__name__.__eq__('wrapper_descriptor') returns True — ABCMeta.__init__ is inherited from type (not defined in Lib/abc.py), so it is type.__init__, a C-level wrapper_descriptor; ABCMeta.__init__.__qualname__ is 'type.__init__' (len=13: 'type.'=5 + '__init__'=8); the qualname uses 'type.' as the prefix — the defining class — rather than 'ABCMeta.'; this contrasts with ABCMeta.__new__ which IS Python-defined in abc.py (class='function', qualname='ABCMeta.__new__', len=15); the 'wrapper_descriptor' class indicates C-level slot wrapper around type's C implementation; NEW in extra99: first standalone ABCMeta.__init__ class name invariant in abcmeta99 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__init__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant abc_extra99.ABCMeta_new_argcount_4:
  description: "abc.ABCMeta.__new__.__code__.co_argcount == 4 — ABCMeta.__new__ is Python-defined in Lib/abc.py; its signature is __new__(mcls, name, bases, namespace, **kwargs): mcls=the metaclass, name=class name string, bases=tuple of base classes, namespace=class dict; co_argcount counts positional parameters excluding *args and **kwargs, giving 4; ABCMeta.__new__.__class__.__name__ is 'function'; ABCMeta.__new__.__qualname__ is 'ABCMeta.__new__' (len=15); ABCMeta.__new__.__module__ is 'abc'; compare: ABCMeta.register.__code__.co_argcount==2 (cls, subclass), ABCMeta._dump_registry.__code__.co_argcount==2 (cls, file); NEW in extra99: first standalone ABCMeta.__new__ co_argcount invariant in abcmeta99 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__new__.__code__.co_argcount.__eq__
  args: [4]
  expected: true

invariant abc_extra99.ABC_init_subclass_qualname_len_21:
  description: "abc.ABC.__init_subclass__.__qualname__.__len__() == 21 — ABC.__init_subclass__.__qualname__ is 'ABC.__init_subclass__' (21 chars: 'ABC.'=4 + '__init_subclass__'=17); abc.ABC.__init_subclass__.__class__.__name__ is 'builtin_function_or_method' (ABC inherits __init_subclass__ from object; it is a built-in classmethod, not a Python-level function); compare qualname lengths in this spec: type.__init__=13, ABCMeta.__new__=15, ABCMeta.register=16, ABC.__init_subclass__=21, ABCMeta._dump_registry=22, ABCMeta.__subclasshook__=24 (longest); the double-underscore prefix '__init_subclass__' contributes 17 chars to the qualname; NEW in extra99: first standalone ABC.__init_subclass__ qualname length invariant in abcmeta99 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__init_subclass__.__qualname__.__len__
  args: []
  expected: 21

invariant abc_extra99.ABCMeta_subclasshook_qualname_longest:
  description: "abc.ABCMeta.__subclasshook__.__qualname__.__len__() == 24 — ABCMeta.__subclasshook__.__qualname__ is 'ABCMeta.__subclasshook__' (24 chars: 'ABCMeta.'=8 + '__subclasshook__'=16); this is the longest method qualname in this spec; compare method qualname lengths: type.__init__=13, ABCMeta.__new__=15, ABCMeta.register=16, ABC.__init_subclass__=21, ABCMeta._dump_registry=22, ABCMeta.__subclasshook__=24 (longest); ABCMeta.__subclasshook__ is a classmethod that can be overridden by abstract base classes to customize issubclass() checks; abc.ABCMeta.__subclasshook__.__class__.__name__ is 'builtin_function_or_method'; NEW in extra99: first standalone ABCMeta.__subclasshook__ qualname length invariant in abcmeta99 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__subclasshook__.__qualname__.__len__
  args: []
  expected: 24

invariant abc_extra99.ABCMeta_dump_registry_qualname_len_22:
  description: "abc.ABCMeta._dump_registry.__qualname__.__len__() == 22 — _dump_registry.__qualname__ is 'ABCMeta._dump_registry' (22 chars: 'ABCMeta.'=8 + '_dump_registry'=14); abc.ABCMeta._dump_registry.__class__.__name__ is 'function' (Python-defined classmethod in abc.py); _dump_registry.__code__.co_argcount is 2 (cls, file); compare qualname lengths: ABCMeta.register=16, ABC.__init_subclass__=21, ABCMeta._dump_registry=22, ABCMeta.__subclasshook__=24; _dump_registry prints a registry of registered implementations of the abstract class to the given file; NEW in extra99: first standalone ABCMeta._dump_registry qualname length invariant in abcmeta99 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta._dump_registry.__qualname__.__len__
  args: []
  expected: 22
