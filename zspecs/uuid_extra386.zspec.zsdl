spec: uuid_extra386
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "uuid.SafeUUID.__name__ == 'SafeUUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__bases__[0].__name__ == 'Enum'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.safe.name == 'safe', uuid.SafeUUID.safe.value == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.unsafe.name == 'unsafe', uuid.SafeUUID.unsafe.value == -1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.variant.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.variant.fget.__name__ == 'variant'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID('not-a-uuid') raises ValueError. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.SafeUUID is a pure Python Enum (not IntEnum) added in Python 3.7. Members: safe=0, unsafe=-1, unknown=None. Indicates whether UUID generation was multiprocess-safe."
    - "Note: uuid.UUID.variant is a Python property. Its fget.__name__ is 'variant', consistent with all other UUID computed properties."
    - "Note: uuid.UUID raises ValueError for malformed UUID strings; the string must be exactly 32 hex digits, optionally with hyphens in the standard 8-4-4-4-12 grouping."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.SafeUUID enum class identity and member values
# uuid.UUID.variant property identity
# uuid.UUID error behavior for invalid strings
#
# Wave 386 theme: uuid.SafeUUID enum identity and uuid.UUID variant property
# identity and error behavior.
#
# uuid.SafeUUID is a pure Python Enum (not IntEnum) added in Python 3.7. It
# has three members: safe (0), unsafe (-1), and unknown (None). The enum
# indicates whether a UUID was generated by a method that avoids the risk of
# collision due to multi-threaded or multi-process generation. Its direct
# base class is Enum from the enum module.
#
# uuid.UUID.variant is a Python property whose fget.__name__ is 'variant'.
# The property inspects bits 62-63 of the 128-bit UUID integer to determine
# the RFC 4122 variant, returning one of four descriptive strings.
#
# uuid.UUID raises ValueError for strings that do not match the expected
# 32-hexdigit format with optional hyphens in the 8-4-4-4-12 grouping.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra386.safeuuid_class_identity:
  description: "uuid.SafeUUID enum class identity — __name__ is 'SafeUUID', __module__ is 'uuid', base class is 'Enum'; added in Python 3.7; members are safe=0/unsafe=-1/unknown=None; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: uuidsafeid386

  columns: [id, function, args, expected]
  rows:
    - [safeuuid_name,   SafeUUID.__name__.__eq__,             ["SafeUUID"], true]
    - [safeuuid_module, SafeUUID.__module__.__eq__,            ["uuid"],     true]
    - [safeuuid_base,   "SafeUUID.__bases__[0].__name__.__eq__", ["Enum"],     true]

# ---------------------------------------------------------------------------
# uuid.SafeUUID member names and values
#
# SafeUUID.safe has name 'safe' and value 0 (indicates safe generation).
# SafeUUID.unsafe has name 'unsafe' and value -1 (indicates unsafe generation).
# These are the two non-None members; unknown has value None and indicates
# the generation method is not known.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra386.safeuuid_member_values:
  description: "uuid.SafeUUID member name and value attributes — safe.name='safe'/safe.value=0; unsafe.name='unsafe'/unsafe.value=-1; pure Enum members indicating UUID generation safety; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: enum_values
  id_prefix: uuidsafemem386

  columns: [id, function, args, expected]
  rows:
    - [safe_name,    SafeUUID.safe.__class__.__name__.__eq__,   ["SafeUUID"], true]
    - [safe_value,   SafeUUID.safe.value.__eq__,                [0],          true]
    - [unsafe_value, SafeUUID.unsafe.value.__eq__,              [-1],         true]

# ---------------------------------------------------------------------------
# uuid.UUID.variant is a Python property
#
# uuid.UUID.variant is defined with @property in Lib/uuid.py. Accessing it on
# the class (not an instance) returns the property object itself. Its
# __class__.__name__ is 'property' and fget.__name__ is 'variant', consistent
# with all other computed UUID attributes.
#
# The variant property inspects bits 62-63 of the UUID integer and returns
# one of four strings:
#   'reserved for NCS compatibility' (bits: 0xxx)
#   'specified in RFC 4122'          (bits: 10xx)
#   'reserved for Microsoft use'     (bits: 110x)
#   'reserved for future definition' (bits: 111x)
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra386.variant_is_property:
  description: "uuid.UUID.variant.__class__.__name__.__eq__('property') == True — UUID.variant is a Python property object defined with @property in Lib/uuid.py; accessing on the class returns the descriptor; fget inspects bits 62-63 of the UUID integer; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: type_identity
  kind: python_call_eq
  function: UUID.variant.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant uuid_extra386.variant_fget_name:
  description: "uuid.UUID.variant.fget.__name__.__eq__('variant') == True — the property getter function for UUID.variant is named 'variant' (defined as def variant(self): in Lib/uuid.py); fget.__name__ matches attribute name; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: UUID.variant.fget.__name__.__eq__
  args: ["variant"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID raises ValueError for invalid UUID strings
#
# uuid.UUID parses its string argument using a regex that requires exactly
# 32 hexadecimal digits (case-insensitive), optionally grouped with hyphens
# in the 8-4-4-4-12 pattern. Any other format raises ValueError.
# The string 'not-a-uuid' does not match the expected format.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra386.invalid_uuid_string_raises:
  description: "uuid.UUID('not-a-uuid') raises ValueError — UUID constructor validates string format; requires 32 hex digits optionally grouped as 8-4-4-4-12 with hyphens; 'not-a-uuid' has no valid hex UUID structure; raises ValueError; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: error_behavior
  kind: python_call_raises
  function: UUID
  args: ["not-a-uuid"]
  raises: ValueError
