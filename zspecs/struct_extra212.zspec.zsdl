spec: struct_extra212
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "IEEE 754-2019 — Standard for Floating-Point Arithmetic (for float/double format strings)"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "verified with Python 3.14.3."
    - "struct.Struct('!I').pack.__class__.__name__ == 'builtin_function_or_method' — Struct method pack is a C builtin."
    - "struct.Struct('!I').unpack.__class__.__name__ == 'builtin_function_or_method'."
    - "struct.Struct('!I').pack_into.__class__.__name__ == 'builtin_function_or_method'."
    - "struct.Struct('!I').unpack_from.__class__.__name__ == 'builtin_function_or_method'."
    - "struct.Struct('!I').iter_unpack.__class__.__name__ == 'builtin_function_or_method'."
    - "struct.Struct('!I').size == 4; struct.Struct('!I').format == '!I'."
    - "struct.Struct('!I').format.__class__.__name__ == 'str' — format is a str on Python 3.9+."
    - "struct.calcsize('!c') == 1; struct.calcsize('!?') == 1; struct.calcsize('!h') == 2."
    - "struct.calcsize('!i') == 4; struct.calcsize('!l') == 4; struct.calcsize('!q') == 8; struct.calcsize('!e') == 2."
    - "struct.pack.__qualname__ == 'pack'; struct.Struct.__qualname__ == 'Struct'."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct instance method class names
#
# struct.Struct('!I').pack.__class__.__name__        == 'builtin_function_or_method'
# struct.Struct('!I').unpack.__class__.__name__      == 'builtin_function_or_method'
# struct.Struct('!I').pack_into.__class__.__name__   == 'builtin_function_or_method'
# struct.Struct('!I').unpack_from.__class__.__name__ == 'builtin_function_or_method'
# struct.Struct('!I').iter_unpack.__class__.__name__ == 'builtin_function_or_method'
# ---------------------------------------------------------------------------

table struct_extra212.struct_instance_method_classes:
  description: "struct.Struct instance method class names in structeq212 namespace — wave 212 theme: Struct methods pack/unpack/pack_into/unpack_from/iter_unpack are all builtin_function_or_method; Struct is implemented in C (_struct module) so its methods are C builtin methods rather than Python bound methods; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: structeq212

  columns: [id, function, args, expected, description]
  rows:
    - [pack_class,        "struct.Struct('!I').pack.__class__.__name__.__eq__",        ["builtin_function_or_method"],  true,  "struct.Struct('!I').pack.__class__.__name__ == 'builtin_function_or_method' — pack is a C builtin method"]
    - [unpack_class,      "struct.Struct('!I').unpack.__class__.__name__.__eq__",      ["builtin_function_or_method"],  true,  "struct.Struct('!I').unpack.__class__.__name__ == 'builtin_function_or_method' — unpack is a C builtin method"]
    - [pack_into_class,   "struct.Struct('!I').pack_into.__class__.__name__.__eq__",   ["builtin_function_or_method"],  true,  "struct.Struct('!I').pack_into.__class__.__name__ == 'builtin_function_or_method' — pack_into is a C builtin method"]
    - [unpack_from_class, "struct.Struct('!I').unpack_from.__class__.__name__.__eq__", ["builtin_function_or_method"],  true,  "struct.Struct('!I').unpack_from.__class__.__name__ == 'builtin_function_or_method' — unpack_from is a C builtin method"]
    - [iter_unpack_class, "struct.Struct('!I').iter_unpack.__class__.__name__.__eq__", ["builtin_function_or_method"],  true,  "struct.Struct('!I').iter_unpack.__class__.__name__ == 'builtin_function_or_method' — iter_unpack is a C builtin method"]

# ---------------------------------------------------------------------------
# struct.calcsize — format character sizes for network byte order
#
# struct.calcsize('!c') == 1  (char)
# struct.calcsize('!?') == 1  (bool)
# struct.calcsize('!h') == 2  (signed short)
# struct.calcsize('!i') == 4  (signed int)
# struct.calcsize('!l') == 4  (signed long)
# struct.calcsize('!q') == 8  (signed long long)
# struct.calcsize('!e') == 2  (IEEE 754 half-float)
# ---------------------------------------------------------------------------

table struct_extra212.calcsize_format_chars:
  description: "struct.calcsize network-byte-order format character size checks in structeq212a namespace — wave 212 theme: c=1 (char), ?=1 (bool), h=2 (short), i=4 (int), l=4 (long), q=8 (long long), e=2 (half-float IEEE 754); sizes are specified by the struct format character reference; verified with Python 3.14.3"
  kind: python_call_eq
  category: calcsize
  id_prefix: structeq212a

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_c,  struct.calcsize,  ["!c"],  1,  "struct.calcsize('!c') == 1 — 'c' format is a single char, 1 byte"]
    - [calcsize_q,  struct.calcsize,  ["!?"],  1,  "struct.calcsize('!?') == 1 — '?' format is a bool, 1 byte"]
    - [calcsize_h,  struct.calcsize,  ["!h"],  2,  "struct.calcsize('!h') == 2 — 'h' format is signed short, 2 bytes"]
    - [calcsize_i,  struct.calcsize,  ["!i"],  4,  "struct.calcsize('!i') == 4 — 'i' format is signed int, 4 bytes"]
    - [calcsize_l,  struct.calcsize,  ["!l"],  4,  "struct.calcsize('!l') == 4 — 'l' format is signed long, 4 bytes in network order"]
    - [calcsize_qq, struct.calcsize,  ["!q"],  8,  "struct.calcsize('!q') == 8 — 'q' format is signed long long, 8 bytes"]
    - [calcsize_e,  struct.calcsize,  ["!e"],  2,  "struct.calcsize('!e') == 2 — 'e' format is IEEE 754 half-precision float, 2 bytes"]

# ---------------------------------------------------------------------------
# struct.Struct attributes — format and size
#
# struct.Struct('!I').size              == 4
# struct.Struct('!I').format            == '!I'
# struct.Struct('!I').format.__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

table struct_extra212.struct_attributes:
  description: "struct.Struct instance attribute checks in structeq212b namespace — wave 212 theme: Struct('!I').size == 4; Struct('!I').format == '!I'; format.__class__.__name__ == 'str'; on Python 3.9+ Struct.format is a str rather than bytes; verified with Python 3.14.3"
  kind: python_call_eq
  category: attributes
  id_prefix: structeq212b

  columns: [id, function, args, expected, description]
  rows:
    - [struct_size,          "struct.Struct('!I').size.__eq__",                     [4],     true,  "struct.Struct('!I').size == 4 — network-order unsigned int is 4 bytes"]
    - [struct_format_eq,     "struct.Struct('!I').format.__eq__",                   ["!I"],  true,  "struct.Struct('!I').format == '!I' — format attribute echoes back the format string as given"]
    - [struct_format_class,  "struct.Struct('!I').format.__class__.__name__.__eq__", ["str"], true,  "struct.Struct('!I').format.__class__.__name__ == 'str' — on Python 3.9+ Struct.format is a str (not bytes)"]
    - [struct_qualname,      "struct.Struct.__qualname__.__eq__",                   ["Struct"], true, "struct.Struct.__qualname__ == 'Struct' — the Struct class qualname is its simple name"]

# ---------------------------------------------------------------------------
# struct.pack — raises struct.error for invalid format string
# struct.calcsize — raises struct.error for bad format character
# ---------------------------------------------------------------------------

invariant struct_extra212.pack_bad_format_raises:
  description: "struct.pack('!Z', 0) raises struct.error — 'Z' is not a recognised struct format character; struct.pack validates the format string before packing any values; an unrecognised character causes struct.error; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: struct.pack
  args: ["!Z", 0]
  expected_exception: struct.error

invariant struct_extra212.unpack_empty_buf_raises:
  description: "struct.unpack('!I', b'') raises struct.error — format '!I' requires exactly 4 bytes but the buffer is empty (0 bytes); unpack is strict about buffer length; struct.error is raised with 'unpack requires a buffer of N bytes'; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: struct.unpack
  args: ["!I", !hex ""]
  expected_exception: struct.error

invariant struct_extra212.pack_qualname:
  description: "struct.pack.__qualname__ == 'pack' — the module-level pack function qualname matches its simple name; struct is a C extension module (_struct) so its functions have unqualified qualnames; verified with Python 3.14.3"
  category: function_identity
  kind: python_call_eq
  function: "struct.pack.__qualname__.__eq__"
  args: ["pack"]
  expected: true

