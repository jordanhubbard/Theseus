spec: io_extra901
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __module__ attributes of io base and concrete classes"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra901.base_class_modules:
  description: "io abstract base class __module__ identity"
  kind: python_call_eq
  category: base_class_modules
  id_prefix: io901x
  columns: [id, function, args, expected]
  rows:
    - [io901x001, io.IOBase.__module__.__eq__,         ["io"], true]
    - [io901x002, io.RawIOBase.__module__.__eq__,      ["io"], true]
    - [io901x003, io.BufferedIOBase.__module__.__eq__, ["io"], true]
    - [io901x004, io.TextIOBase.__module__.__eq__,     ["io"], true]
    - [io901x005, io.IOBase.__class__.__name__.__eq__,         ["type"], true]
    - [io901x006, io.RawIOBase.__class__.__name__.__eq__,      ["type"], true]
    - [io901x007, io.BufferedIOBase.__class__.__name__.__eq__, ["type"], true]

table io_extra901.concrete_file_class_modules:
  description: "io concrete file class __module__ identity"
  kind: python_call_eq
  category: concrete_file_class_modules
  id_prefix: io901y
  columns: [id, function, args, expected]
  rows:
    - [io901y001, io.FileIO.__module__.__eq__,         ["io"], true]
    - [io901y002, io.BytesIO.__module__.__eq__,        ["io"], true]
    - [io901y003, io.StringIO.__module__.__eq__,       ["io"], true]
    - [io901y004, io.BufferedReader.__module__.__eq__,  ["io"], true]
    - [io901y005, io.FileIO.__class__.__name__.__eq__,         ["type"], true]
    - [io901y006, io.BytesIO.__class__.__name__.__eq__,        ["type"], true]
    - [io901y007, io.StringIO.__class__.__name__.__eq__,       ["type"], true]
    - [io901y008, io.BufferedReader.__class__.__name__.__eq__,  ["type"], true]

table io_extra901.class_name_checks:
  description: "io class __name__ identity"
  kind: python_call_eq
  category: class_name_checks
  id_prefix: io901z
  columns: [id, function, args, expected]
  rows:
    - [io901z001, io.IOBase.__name__.__eq__,          ["IOBase"],         true]
    - [io901z002, io.RawIOBase.__name__.__eq__,       ["RawIOBase"],      true]
    - [io901z003, io.BufferedIOBase.__name__.__eq__,  ["BufferedIOBase"], true]
    - [io901z004, io.TextIOBase.__name__.__eq__,      ["TextIOBase"],     true]
    - [io901z005, io.FileIO.__name__.__eq__,          ["FileIO"],         true]
    - [io901z006, io.BytesIO.__name__.__eq__,         ["BytesIO"],        true]
    - [io901z007, io.StringIO.__name__.__eq__,        ["StringIO"],       true]
