spec: re_extra204
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "re_extra203.zspec.zsdl — covers re class attribute identity"
  notes:
    - "This spec covers re module-level dunder attributes: __name__, __package__, __spec__.name, __loader__.__class__.__name__, __doc__.__class__.__name__."
    - "re.__name__ == 're'; the module name is the bare string 're'; confirmed Python 3.14.3 macOS."
    - "re.__package__ == 're'; re is a package (directory with __init__.py); __package__ equals the package name; confirmed Python 3.14.3 macOS."
    - "re.__spec__.name == 're'; the ModuleSpec name matches the module __name__; confirmed Python 3.14.3 macOS."
    - "re.__loader__.__class__.__name__ == 'SourceFileLoader'; re is a pure-Python source module loaded by SourceFileLoader; confirmed Python 3.14.3 macOS."
    - "re.__doc__.__class__.__name__ == 'str'; the module docstring is a str object; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re module __name__ identity
# __name__ == 're', length == 2
# ---------------------------------------------------------------------------

table re_extra204.module_name:
  description: "re module __name__ attribute identity: value, equality, and length"
  kind: python_call_eq
  category: module_identity
  id_prefix: remod204

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,         re.__name__.__eq__,   ["re"],  true,  "re.__name__ == 're'; the module name is the bare string 're'; confirmed Python 3.14.3 macOS"]
    - [name_len,        re.__name__.__len__,  [],      2,     "re.__name__.__len__() == 2; 're' has r(1)e(2); confirmed Python 3.14.3 macOS"]
    - [name_not_regex,  re.__name__.__eq__,   ["regex"], false, "re.__name__ != 'regex'; the standard library module name is 're' not 'regex'; confirmed Python 3.14.3 macOS"]
    - [name_not_empty,  re.__name__.__eq__,   [""],    false,  "re.__name__ is not empty string; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re module __package__ and __spec__.name identity
# __package__ == 're', __spec__.name == 're'
# ---------------------------------------------------------------------------

table re_extra204.module_package_and_spec:
  description: "re module __package__ and __spec__.name attribute identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: remod204

  columns: [id, function, args, expected, description]
  rows:
    - [package_eq,      re.__package__.__eq__,      ["re"], true,  "re.__package__ == 're'; re is a package and __package__ equals the package name; confirmed Python 3.14.3 macOS"]
    - [package_len,     re.__package__.__len__,     [],     2,     "re.__package__.__len__() == 2; 're' has r(1)e(2); confirmed Python 3.14.3 macOS"]
    - [spec_name_eq,    re.__spec__.name.__eq__,    ["re"], true,  "re.__spec__.name == 're'; the ModuleSpec name matches the module __name__; confirmed Python 3.14.3 macOS"]
    - [spec_name_len,   re.__spec__.name.__len__,   [],     2,     "re.__spec__.name.__len__() == 2; 're' has r(1)e(2); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re module __loader__ and __doc__ class names
# __loader__.__class__.__name__ == 'SourceFileLoader', __doc__.__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

table re_extra204.module_loader_and_doc:
  description: "re module __loader__.__class__.__name__ and __doc__.__class__.__name__ identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: remod204

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_eq,   re.__loader__.__class__.__name__.__eq__,    ["SourceFileLoader"], true,  "re.__loader__.__class__.__name__ == 'SourceFileLoader'; re is a pure-Python source module loaded by SourceFileLoader; confirmed Python 3.14.3 macOS"]
    - [loader_class_len,  re.__loader__.__class__.__name__.__len__,   [],                  16,    "re.__loader__.__class__.__name__.__len__() == 16; 'SourceFileLoader' has 16 characters; confirmed Python 3.14.3 macOS"]
    - [doc_class_eq,      re.__doc__.__class__.__name__.__eq__,       ["str"],             true,  "re.__doc__.__class__.__name__ == 'str'; the module docstring is a str object; confirmed Python 3.14.3 macOS"]
    - [doc_class_len,     re.__doc__.__class__.__name__.__len__,      [],                  3,     "re.__doc__.__class__.__name__.__len__() == 3; 'str' has s(1)t(2)r(3); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra204.name_eq:
  description: "re.__name__ == 're' — the module name is the bare string 're'; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: re.__name__.__eq__
  args: ["re"]
  expected: true

invariant re_extra204.name_len:
  description: "re.__name__.__len__() == 2 — 're' has two characters r and e; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: re.__name__.__len__
  args: []
  expected: 2

invariant re_extra204.package_eq:
  description: "re.__package__ == 're' — re is a package and __package__ equals the package name; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: re.__package__.__eq__
  args: ["re"]
  expected: true

invariant re_extra204.package_len:
  description: "re.__package__.__len__() == 2 — 're' has two characters; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: re.__package__.__len__
  args: []
  expected: 2

invariant re_extra204.spec_name_eq:
  description: "re.__spec__.name == 're' — the ModuleSpec name matches the module __name__; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: re.__spec__.name.__eq__
  args: ["re"]
  expected: true

invariant re_extra204.spec_name_len:
  description: "re.__spec__.name.__len__() == 2 — 're' has r(1)e(2); confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: re.__spec__.name.__len__
  args: []
  expected: 2

invariant re_extra204.loader_class_name_eq:
  description: "re.__loader__.__class__.__name__ == 'SourceFileLoader' — re is a pure-Python source module loaded by SourceFileLoader; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: re.__loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant re_extra204.doc_class_name_eq:
  description: "re.__doc__.__class__.__name__ == 'str' — the module docstring is a str object; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: re.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

