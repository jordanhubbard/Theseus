spec: multiprocessing_extra190
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "multiprocessing.Pool.__name__ == 'Pool' (len=4); but multiprocessing.Pool is a bound method of BaseContext, not the Pool class itself."
    - "multiprocessing.Pool.__class__.__name__ == 'method' (len=6); multiprocessing.Pool is a context factory method, not a class."
    - "multiprocessing.pool.Pool.__name__ == 'Pool' (len=4); the actual Pool class is in multiprocessing.pool submodule."
    - "multiprocessing.pool.Pool.__module__ == 'multiprocessing.pool' (len=20: 'multiprocessing'=15+'.'=1+'pool'=4=20)."
    - "multiprocessing.pool.Pool.__bases__[0].__name__ == 'object' (len=6); Pool inherits directly from object."
    - "multiprocessing.pool.Pool.__init__.__qualname__ == 'Pool.__init__' (len=13: 'Pool'=4+'.'=1+'__init__'=8=13)."
    - "multiprocessing.pool.Pool.map.__qualname__ == 'Pool.map' (len=8: 'Pool'=4+'.'=1+'map'=3=8)."
    - "multiprocessing.pool.Pool.apply.__qualname__ == 'Pool.apply' (len=10: 'Pool'=4+'.'=1+'apply'=5=10)."
    - "Length ordering: Pool.map (8) < Pool.apply (10) < Pool.__init__ (13)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.Pool bound method identity
#
# multiprocessing.Pool.__name__ == 'Pool' (len=4)
# multiprocessing.Pool.__class__.__name__ == 'method' (len=6)
# ---------------------------------------------------------------------------

table multiprocessing_extra190.mp_pool_method_identity:
  description: "multiprocessing.Pool bound method identity checks in mppool190 namespace — multiprocessing.Pool.__name__=='Pool' (len=4: P(1)o(2)o(3)l(4)); but multiprocessing.Pool is a bound method of the DefaultContext (BaseContext.Pool), not the Pool class directly; multiprocessing.Pool.__class__.__name__=='method' (len=6: m(1)e(2)t(3)h(4)o(5)d(6)); this is a key distinction: 'import multiprocessing; multiprocessing.Pool' gives you the factory method, not the class; to access the actual Pool class you must use 'multiprocessing.pool.Pool'; multiprocessing.Pool.__name__=='Pool' and multiprocessing.pool.Pool.__name__=='Pool' are both 'Pool' (len=4) but refer to different objects; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mppool190

  columns: [id, function, args, expected, description]
  rows:
    - [mp_pool_name_eq,         multiprocessing.Pool.__name__.__eq__,         ["Pool"],    true, "multiprocessing.Pool.__name__ == 'Pool' (len=4; Pool is a bound factory method on DefaultContext); verified Python 3.14.3"]
    - [mp_pool_name_len,        multiprocessing.Pool.__name__.__len__,        [],          4,    "multiprocessing.Pool.__name__.__len__() == 4 ('Pool'=4: P+o+o+l); verified Python 3.14.3"]
    - [mp_pool_class_name_eq,   multiprocessing.Pool.__class__.__name__.__eq__, ["method"], true, "multiprocessing.Pool.__class__.__name__ == 'method' (len=6; Pool attribute is a bound method, not a class); verified Python 3.14.3"]
    - [mp_pool_class_name_len,  multiprocessing.Pool.__class__.__name__.__len__, [],        6,    "multiprocessing.Pool.__class__.__name__.__len__() == 6 ('method'=6: m+e+t+h+o+d); verified Python 3.14.3"]
    - [mp_pool_name_is_pool,    multiprocessing.Pool.__name__.__eq__,         ["Pool"],    true, "multiprocessing.Pool.__name__=='Pool' (same as pool.Pool.__name__=='Pool'); both share the name 'Pool' despite being different objects; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: multiprocessing.pool.Pool class identity
#
# multiprocessing.pool.Pool.__name__ == 'Pool' (len=4)
# multiprocessing.pool.Pool.__module__ == 'multiprocessing.pool' (len=20)
# multiprocessing.pool.Pool.__bases__[0].__name__ == 'object' (len=6)
# ---------------------------------------------------------------------------

table multiprocessing_extra190.pool_class_identity:
  description: "multiprocessing.pool.Pool class identity checks in mppool190 namespace — Pool.__name__=='Pool' (len=4; the actual Pool class accessed via the submodule); Pool.__module__=='multiprocessing.pool' (len=20: 'multiprocessing'=15+'.'=1+'pool'=4=20; this is the canonical module path for the Pool class); Pool.__bases__[0].__name__=='object' (len=6; Pool inherits directly from object, not from any abstract base); Pool.__module__ (20) is much shorter than concurrent.futures.ThreadPoolExecutor.__module__ (25); Pool.__bases__[0].__name__=='object' confirms there is no Executor-like abstract base in multiprocessing; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mppool190

  columns: [id, function, args, expected, description]
  rows:
    - [pool_name_eq,    multiprocessing.pool.Pool.__name__.__eq__,    ["Pool"],                   true, "multiprocessing.pool.Pool.__name__ == 'Pool' (len=4; the actual Pool class in the pool submodule); verified Python 3.14.3"]
    - [pool_name_len,   multiprocessing.pool.Pool.__name__.__len__,   [],                         4,    "multiprocessing.pool.Pool.__name__.__len__() == 4 ('Pool'=4; P+o+o+l); verified Python 3.14.3"]
    - [pool_module_eq,  multiprocessing.pool.Pool.__module__.__eq__,  ["multiprocessing.pool"],   true, "multiprocessing.pool.Pool.__module__ == 'multiprocessing.pool' (len=20: multiprocessing=15+.=1+pool=4=20); verified Python 3.14.3"]
    - [pool_module_len, multiprocessing.pool.Pool.__module__.__len__, [],                         20,   "multiprocessing.pool.Pool.__module__.__len__() == 20 ('multiprocessing.pool'=20: multiprocessing=15+.=1+pool=4=20); verified Python 3.14.3"]
    - ["pool_base_eq",  "multiprocessing.pool.Pool.__bases__[0].__name__.__eq__", ["object"],     true, "multiprocessing.pool.Pool.__bases__[0].__name__ == 'object' (len=6; Pool inherits directly from object, no abstract base); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: multiprocessing.pool.Pool method qualnames
#
# Pool.__init__.__qualname__ == 'Pool.__init__' (len=13)
# Pool.map.__qualname__ == 'Pool.map' (len=8)
# Pool.apply.__qualname__ == 'Pool.apply' (len=10)
# ---------------------------------------------------------------------------

table multiprocessing_extra190.pool_method_qualnames:
  description: "multiprocessing.pool.Pool method qualname identity in mppool190 namespace — Pool.__init__.__qualname__=='Pool.__init__' (len=13: 'Pool'=4+'.'=1+'__init__'=8=13; starts worker processes, sets up task queues and result handler); Pool.map.__qualname__=='Pool.map' (len=8: 'Pool'=4+'.'=1+'map'=3=8; parallel map — applies function to iterable items using worker processes, blocks until all results ready); Pool.apply.__qualname__=='Pool.apply' (len=10: 'Pool'=4+'.'=1+'apply'=5=10; applies function to args in a worker, blocks until result ready — synchronous variant); length ordering: Pool.map (8) < Pool.apply (10) < Pool.__init__ (13); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mppool190

  columns: [id, function, args, expected, description]
  rows:
    - [pool_init_qualname_eq,   multiprocessing.pool.Pool.__init__.__qualname__.__eq__,  ["Pool.__init__"], true, "multiprocessing.pool.Pool.__init__.__qualname__ == 'Pool.__init__' (len=13; starts workers, sets up queues); verified Python 3.14.3"]
    - [pool_init_qualname_len,  multiprocessing.pool.Pool.__init__.__qualname__.__len__, [],               13,   "multiprocessing.pool.Pool.__init__.__qualname__.__len__() == 13 ('Pool.__init__'=13: Pool=4+.=1+__init__=8=13); verified Python 3.14.3"]
    - [pool_map_qualname_eq,    multiprocessing.pool.Pool.map.__qualname__.__eq__,       ["Pool.map"],     true, "multiprocessing.pool.Pool.map.__qualname__ == 'Pool.map' (len=8; parallel map over iterable); verified Python 3.14.3"]
    - [pool_map_qualname_len,   multiprocessing.pool.Pool.map.__qualname__.__len__,      [],               8,    "multiprocessing.pool.Pool.map.__qualname__.__len__() == 8 ('Pool.map'=8: Pool=4+.=1+map=3=8; shortest in spec); verified Python 3.14.3"]
    - [pool_apply_qualname_eq,  multiprocessing.pool.Pool.apply.__qualname__.__eq__,     ["Pool.apply"],   true, "multiprocessing.pool.Pool.apply.__qualname__ == 'Pool.apply' (len=10; synchronous single-call in worker); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra190
# ---------------------------------------------------------------------------

invariant multiprocessing_extra190.mp_Pool_name_eq:
  description: "multiprocessing.Pool.__name__.__eq__('Pool') returns True — multiprocessing.Pool.__name__=='Pool' (len=4: P(1)o(2)o(3)l(4)); note that multiprocessing.Pool is a bound method of the DefaultContext object (not the Pool class itself); calling multiprocessing.Pool(...) invokes the factory method which creates a multiprocessing.pool.Pool instance using the current start method; this is a key design: the top-level multiprocessing namespace exposes Pool as a convenience factory, hiding the context machinery; compare multiprocessing.pool.Pool which is the actual class; both share the name 'Pool' (len=4); NEW in mppool190: first standalone multiprocessing.Pool.__name__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Pool.__name__.__eq__
  args: ["Pool"]
  expected: true

invariant multiprocessing_extra190.mp_Pool_class_name_is_method:
  description: "multiprocessing.Pool.__class__.__name__.__eq__('method') returns True — multiprocessing.Pool.__class__.__name__=='method' (len=6: m(1)e(2)t(3)h(4)o(5)d(6)); this confirms that multiprocessing.Pool is a bound method (specifically BaseContext.Pool bound to the DefaultContext instance), not a class; type(multiprocessing.Pool) is <class 'method'>; this design allows the multiprocessing module to return Pool instances appropriate for the platform start method ('fork', 'spawn', or 'forkserver') without exposing the context machinery directly; compare multiprocessing.pool.Pool.__class__.__name__=='type' (it is an actual class); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Pool.__class__.__name__.__eq__
  args: ["method"]
  expected: true

invariant multiprocessing_extra190.pool_Pool_name_eq:
  description: "multiprocessing.pool.Pool.__name__.__eq__('Pool') returns True — multiprocessing.pool.Pool.__name__=='Pool' (len=4); this is the actual Pool class defined in Lib/multiprocessing/pool.py; unlike multiprocessing.Pool (which is a bound method), multiprocessing.pool.Pool is a proper class (type(multiprocessing.pool.Pool) is <class 'type'>); Pool manages a pool of worker processes with a task queue; workers are spawned lazily (on first submit) or eagerly (all at __init__ time depending on start method); Pool.__name__ (4) is one of the shorter class names in the stdlib; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.__name__.__eq__
  args: ["Pool"]
  expected: true

invariant multiprocessing_extra190.pool_Pool_module_eq:
  description: "multiprocessing.pool.Pool.__module__.__eq__('multiprocessing.pool') returns True — multiprocessing.pool.Pool.__module__=='multiprocessing.pool' (len=20: 'multiprocessing'=15+'.'=1+'pool'=4=20); Pool is defined in Lib/multiprocessing/pool.py; the module name 'multiprocessing.pool' directly maps to this file path; __module__ (20) reflects the two-level package: multiprocessing (15) → pool (4); compare concurrent.futures.ThreadPoolExecutor.__module__=='concurrent.futures.thread' (25) — three levels vs two; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.__module__.__eq__
  args: ["multiprocessing.pool"]
  expected: true

invariant multiprocessing_extra190.pool_Pool_base_is_object:
  description: "multiprocessing.pool.Pool.__bases__[0].__name__.__eq__('object') returns True — multiprocessing.pool.Pool.__bases__[0].__name__=='object' (len=6: o(1)b(2)j(3)e(4)c(5)t(6)); Pool inherits directly from object with no abstract base class; this contrasts with concurrent.futures.ThreadPoolExecutor and ProcessPoolExecutor which both inherit from the Executor abstract base; Pool's interface (map, apply, apply_async, map_async, starmap, etc.) is not enforced by an ABC; Pool.__bases__[0].__name__=='object' (6) == multiprocessing.Pool.__class__.__name__=='method' (6) — a coincidental length tie; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.pool.Pool.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant multiprocessing_extra190.pool_Pool_init_qualname_eq:
  description: "multiprocessing.pool.Pool.__init__.__qualname__.__eq__('Pool.__init__') returns True — Pool.__init__.__qualname__=='Pool.__init__' (len=13: 'Pool'=4+'.'=1+'__init__'=8=13); Pool.__init__ accepts processes (number of workers), initializer, initargs, maxtasksperchild, and context parameters; __init__ spawns or forks the worker processes and sets up the task queue, result handler thread, and worker handler thread; __init__.__qualname__ (13) > map.__qualname__ (8) > apply.__qualname__ (10)? No — ordering is map (8) < apply (10) < __init__ (13); NEW in mppool190: standalone Pool.__init__.__qualname__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.__init__.__qualname__.__eq__
  args: ["Pool.__init__"]
  expected: true

invariant multiprocessing_extra190.pool_Pool_map_qualname_eq:
  description: "multiprocessing.pool.Pool.map.__qualname__.__eq__('Pool.map') returns True — Pool.map.__qualname__=='Pool.map' (len=8: 'Pool'=4+'.'=1+'map'=3=8); Pool.map is the synchronous parallel map: it applies func to every item in iterable, distributing chunks of work to worker processes; Pool.map blocks until all results are ready and returns them in order; Pool.map.__qualname__ (8) is the shortest qualname in this spec; length ordering: Pool.map (8) < Pool.apply (10) < Pool.__init__ (13); 'map' (3 chars) is the shortest method name; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.map.__qualname__.__eq__
  args: ["Pool.map"]
  expected: true

invariant multiprocessing_extra190.pool_Pool_apply_qualname_eq:
  description: "multiprocessing.pool.Pool.apply.__qualname__.__eq__('Pool.apply') returns True — Pool.apply.__qualname__=='Pool.apply' (len=10: 'Pool'=4+'.'=1+'apply'=5=10); Pool.apply calls func with args and kwds in a worker process, blocking until the result is available; apply is the synchronous single-call variant (compare apply_async for the non-blocking form); Pool.apply.__qualname__ (10) sits between Pool.map (8) and Pool.__init__ (13) — length ordering: map (8) < apply (10) < __init__ (13); 'apply' (5 chars) is the mid-length method name in this spec; NEW in mppool190: standalone Pool.apply.__qualname__ invariant completing 8-invariant coverage; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.apply.__qualname__.__eq__
  args: ["Pool.apply"]
  expected: true
