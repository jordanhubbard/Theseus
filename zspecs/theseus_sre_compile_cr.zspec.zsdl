spec: theseus_sre_compile_cr
version: ">=3.0"
backend: python_cleanroom(theseus_sre_compile_cr)
blocks: sre_compile

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/re.html"
  not_derived_from:
    - "CPython source: Lib/sre_compile.py"
  notes:
    - "Clean-room sre_compile module. Do NOT import sre_compile."

error_model: python_exceptions

invariant theseus_sre_compile_cr.sreco2_compile:
  description: "compile() function produces a regex pattern object"
  category: behavior
  kind: python_call_eq
  function: sreco2_compile
  args: []
  expected: true

invariant theseus_sre_compile_cr.sreco2_isstring:
  description: "isstring() utility function works correctly"
  category: behavior
  kind: python_call_eq
  function: sreco2_isstring
  args: []
  expected: true

invariant theseus_sre_compile_cr.sreco2_error:
  description: "error exception class exists"
  category: behavior
  kind: python_call_eq
  function: sreco2_error
  args: []
  expected: true
