spec: socket_extra32
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra31.zspec.zsdl — covers socket.timeout/herror/gaierror __dict__.__class__.__name__=='mappingproxy'/__len__()==12; socket.socket.close/__qualname__=='socket.close'/__len__()==12; setblocking/__qualname__.__len__()==18; getsockname/__qualname__.__len__()==18; fileno/detach/shutdown/sendall __qualname__.__len__()."
    - "socket_extra30.zspec.zsdl — covers socket.__all__.__len__()==238; AF_INET/AF_INET6 __class__.__name__=='AddressFamily'; SOCK_STREAM/SOCK_DGRAM __class__.__name__=='SocketKind'; SOL_SOCKET/IPPROTO_TCP values."
    - "socket_extra29.zspec.zsdl — covers socket.socket/__mro__.__len__()==3; error/timeout/herror/gaierror MRO lengths; setsockopt/getsockopt/settimeout/getpeername qualnames."
    - "socket_extra28.zspec.zsdl — covers socket.socket.bind/connect/listen/accept/send/recv qualnames; getaddrinfo/__qualname__.__len__(); setdefaulttimeout/__qualname__.__len__()/__module__.__len__()."
    - "socket_extra27.zspec.zsdl — covers __module__.__len__() for socket/error/timeout/herror/gaierror; __name__.__len__() for socket/error; __qualname__ for gethostname/getfqdn/inet_aton/inet_ntoa."
  notes:
    - "This spec extends socket_extra31.zspec.zsdl."
    - "Prior specs covered: all __module__/__name__/__mro__/__bases__[0].__name__ for socket/error/timeout/herror/gaierror; method __qualname__ and __len__() for bind/connect/listen/accept/send/recv/setsockopt/getsockopt/settimeout/getpeername/close/setblocking/getsockname/fileno/detach/shutdown/sendall; socket.__all__.__len__()==238; AF/SOCK/SOL constant class names; getaddrinfo/setdefaulttimeout/gethostname/getfqdn/inet_aton/inet_ntoa qualnames."
    - "This spec covers NEW angles: socket.socket.recvfrom/__qualname__.__len__()==15; sendto/__qualname__.__len__()==13; makefile/__qualname__.__len__()==15; recvfrom_into/__qualname__.__len__()==20; recv_into/__qualname__.__len__()==16; connect_ex/__qualname__.__len__()==17; socket.getaddrinfo/__name__.__len__()==11; socket.getnameinfo/__name__.__len__()==11; socket.setdefaulttimeout/__name__.__len__()==17; socket.getdefaulttimeout/__name__.__len__()==17; socket.create_connection/__name__.__len__()==17; socket.IPPROTO_TCP/__class__.__name__.__len__()==3; socket.IPPROTO_UDP/__class__.__name__.__len__()==3; socket.AF_UNIX/__class__.__name__.__len__()==13."
    - "socket.socket.recvfrom.__qualname__ == 'socket.recvfrom' — len 15. sendto == 'socket.sendto' — len 13. makefile == 'socket.makefile' — len 15. recvfrom_into == 'socket.recvfrom_into' — len 20. recv_into == 'socket.recv_into' — len 16. connect_ex == 'socket.connect_ex' — len 17. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__name__ == 'getaddrinfo' — len 11. getnameinfo.__name__ == 'getnameinfo' — len 11. setdefaulttimeout.__name__ == 'setdefaulttimeout' — len 17. getdefaulttimeout.__name__ == 'getdefaulttimeout' — len 17. create_connection.__name__ == 'create_connection' — len 17. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_TCP.__class__.__name__ == 'int' — len 3. IPPROTO_UDP.__class__.__name__ == 'int' — len 3. IPPROTO constants are plain Python ints, unlike AF/SOCK which use enum subclasses. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.AF_UNIX.__class__.__name__ == 'AddressFamily' — len 13. Same enum type as AF_INET/AF_INET6. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket method __qualname__.__len__() — recvfrom, sendto, makefile,
# recvfrom_into, recv_into, connect_ex
#
# No prior socket spec checks __qualname__ length for any of these six methods.
# recvfrom      -> 'socket.recvfrom'      (15)
# sendto        -> 'socket.sendto'        (13)
# makefile      -> 'socket.makefile'      (15)
# recvfrom_into -> 'socket.recvfrom_into' (20)
# recv_into     -> 'socket.recv_into'     (16)
# connect_ex    -> 'socket.connect_ex'    (17)
# ---------------------------------------------------------------------------

table socket_extra32.socket_method_qualname_lens:
  description: "socket.socket recvfrom/sendto/makefile/recvfrom_into/recv_into/connect_ex __qualname__.__len__()"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: smql32

  columns: [id, function, args, expected]
  rows:
    - [recvfrom,      "socket.recvfrom.__qualname__.__len__",      [], 15]
    - [sendto,        "socket.sendto.__qualname__.__len__",        [], 13]
    - [makefile,      "socket.makefile.__qualname__.__len__",      [], 15]
    - [recvfrom_into, "socket.recvfrom_into.__qualname__.__len__", [], 20]
    - [recv_into,     "socket.recv_into.__qualname__.__len__",     [], 16]
    - [connect_ex,    "socket.connect_ex.__qualname__.__len__",    [], 17]

# ---------------------------------------------------------------------------
# Module-level socket function __name__.__len__() — getaddrinfo, getnameinfo,
# setdefaulttimeout, getdefaulttimeout, create_connection
#
# socket_extra27 covered gethostname/__name__.__len__()==11 and getfqdn/__name__.__len__()==7.
# socket_extra28 covered getaddrinfo/__qualname__.__len__() but NOT __name__.__len__().
# No prior spec checks __name__.__len__() for getaddrinfo, getnameinfo,
# setdefaulttimeout, getdefaulttimeout, or create_connection.
# getaddrinfo.__name__    == 'getaddrinfo'    (11)
# getnameinfo.__name__    == 'getnameinfo'    (11)
# setdefaulttimeout.__name__ == 'setdefaulttimeout' (17)
# getdefaulttimeout.__name__ == 'getdefaulttimeout' (17)
# create_connection.__name__ == 'create_connection' (17)
# ---------------------------------------------------------------------------

table socket_extra32.module_func_name_lens:
  description: "socket module-level function __name__.__len__() — getaddrinfo(11)/getnameinfo(11)/setdefaulttimeout(17)/getdefaulttimeout(17)/create_connection(17)"
  kind: python_call_eq
  category: string_lengths
  id_prefix: smfn32

  columns: [id, function, args, expected]
  rows:
    - [getaddrinfo,       getaddrinfo.__name__.__len__,       [], 11]
    - [getnameinfo,       getnameinfo.__name__.__len__,       [], 11]
    - [setdefaulttimeout, setdefaulttimeout.__name__.__len__, [], 17]
    - [getdefaulttimeout, getdefaulttimeout.__name__.__len__, [], 17]
    - [create_connection, create_connection.__name__.__len__, [], 17]

# ---------------------------------------------------------------------------
# socket.IPPROTO_TCP and IPPROTO_UDP __class__.__name__.__len__()
#
# socket_extra30 confirmed AF_INET/AF_INET6 are AddressFamily (len 13) and
# SOCK_STREAM/SOCK_DGRAM are SocketKind (len 10). IPPROTO constants differ:
# they are plain Python ints, not enum members. __class__.__name__ == 'int', len 3.
# No prior spec checks IPPROTO constant class names or lengths.
# ---------------------------------------------------------------------------

invariant socket_extra32.IPPROTO_TCP_class_name_len:
  description: "socket.IPPROTO_TCP.__class__.__name__.__len__() == 3 — IPPROTO_TCP is a plain int; len('int') == 3"
  category: constants
  kind: python_call_eq
  function: IPPROTO_TCP.__class__.__name__.__len__
  args: []
  expected: 3

invariant socket_extra32.IPPROTO_UDP_class_name_len:
  description: "socket.IPPROTO_UDP.__class__.__name__.__len__() == 3 — IPPROTO_UDP is a plain int; len('int') == 3"
  category: constants
  kind: python_call_eq
  function: IPPROTO_UDP.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# socket.AF_UNIX __class__.__name__.__len__()
#
# socket_extra30 checked AF_INET and AF_INET6 (both AddressFamily, len 13).
# AF_UNIX is also an AddressFamily enum member (len 13).
# No prior spec checks __class__.__name__.__len__() for AF_UNIX specifically.
# AF_UNIX is available on macOS/Darwin and most Unix-like platforms.
# ---------------------------------------------------------------------------

invariant socket_extra32.AF_UNIX_class_name_len:
  description: "socket.AF_UNIX.__class__.__name__.__len__() == 13 — AF_UNIX is AddressFamily enum; len('AddressFamily') == 13"
  category: constants
  kind: python_call_eq
  function: AF_UNIX.__class__.__name__.__len__
  args: []
  expected: 13
