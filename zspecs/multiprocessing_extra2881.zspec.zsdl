spec: mp2881
version: ">=3.9"
error_model: python_exceptions
provenance:
  derived_from: [multiprocessing source, Python docs, https://docs.python.org/3/library/multiprocessing.html]
  not_derived_from: [any external dataset, multiprocessing_extra2866.zspec.zsdl — covers __rand__/__ror__/__rxor__ dict-presence, multiprocessing_extra2851.zspec.zsdl — covers __rlshift__/__rrshift__/__rpow__ dict-presence, multiprocessing_extra2836.zspec.zsdl — covers __rtruediv__/__rfloordiv__/__rmod__ dict-presence]
  notes: [Wave 639 theme — __iadd__/__isub__/__imul__ dict-presence checks for multiprocessing types. In-place augmented assignment operators. Process/Pool/AsyncResult/MapResult/SyncManager are process-management primitives lacking these dunders. managers.ListProxy defines both __iadd__ and __imul__ (list concatenation/repetition). managers.BaseListProxy defines __imul__ only. managers.SetProxy defines __isub__ only (set difference update). All other proxy types lack these dunders. type(multiprocessing.Array('i', 3)) used to avoid nested brackets in flow sequences. All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0 2026-04-13.]
  created_at: "2026-04-13"

table mp2881.iadd:
  kind: python_call_eq
  columns: [id, function, args, expected]
  rows:
    - ["mp2881001", operator.contains, [multiprocessing.Process.__dict__, "__iadd__"], false]
    - ["mp2881002", operator.contains, [multiprocessing.pool.Pool.__dict__, "__iadd__"], false]
    - ["mp2881003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__, "__iadd__"], false]
    - ["mp2881004", operator.contains, [multiprocessing.pool.MapResult.__dict__, "__iadd__"], false]
    - ["mp2881005", operator.contains, [multiprocessing.managers.SyncManager.__dict__, "__iadd__"], false]
    - ["mp2881006", operator.contains, [multiprocessing.managers.BaseProxy.__dict__, "__iadd__"], false]

