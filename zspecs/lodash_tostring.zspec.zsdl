spec: lodash_tostring
version: ">=4.0.0"
backend: node(lodash.tostring)

docs: https://lodash.com/docs/#toString

provenance:
  derived_from:
    - "lodash.tostring README — https://www.npmjs.com/package/lodash.tostring"
    - "Test vectors verified with lodash.tostring@4.1.4 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.tostring exports the _.toString function directly as module.exports."
    - "toString converts value to a string. null/undefined returns ''."
    - "Arrays are joined with commas."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_tostring.tostring:
  kind: node_module_call_eq
  function: ~
  category: tostring
  id_prefix: ltos

  columns: [id, args, expected]
  rows:
    - [number,    [3],           "3"]
    - [float,     [3.14],        "3.14"]
    - [array,     [[1, 2, 3]],   "1,2,3"]
    - [null_val,  [null],        ""]
    - [already,   ["hello"],     "hello"]

