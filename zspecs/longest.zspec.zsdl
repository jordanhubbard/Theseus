spec: longest
version: ">=2.0.1"
backend: node(longest)

docs: https://www.npmjs.com/package/longest

provenance:
  derived_from:
    - "longest README — https://www.npmjs.com/package/longest"
    - "Test vectors verified with longest via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "longest source"
  notes:
    - "longest is an npm package. Install: npm install longest"
    - "Returns the longest string from an array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table longest.find:
  kind: node_module_call_eq
  function: ~
  category: array
  id_prefix: lngst

  columns: [id, args, expected]
  rows:
    - [mixed,   [["short", "medium", "looooong"]],  "looooong"]
    - [ranked,  [["a", "bb", "ccc"]],               "ccc"]
