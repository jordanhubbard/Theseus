spec: enum_extra36
version: ">=3.11"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum_extra35.zspec.zsdl."
    - "Prior specs covered: Enum/IntEnum/Flag/IntFlag/StrEnum/EnumType __name__/__module__/__qualname__/__mro__/__bases__[0].__name__/__dict__.__class__.__name__.__len__(); all __mro__.__len__() values; Enum dunder method __qualname__.__len__() for __new__/__str__/__repr__/__hash__/__format__; EnumType method __qualname__.__len__() for __call__/__prepare__/__repr__/__setattr__/__delattr__/__iter__/__new__/__getitem__; Enum._missing_/__generate_next_value_ qualname lengths; helper symbol qualname lens (auto/unique/member/nonmember); enum.__all__.__len__()==30; EnumType.__bases__[0].__name__.__len__()==4; IntEnum.__bases__[0].__name__.__len__()==3; Flag.__bases__[0].__name__.__len__()==4; Enum instance methods __qualname__.__len__() for __reduce_ex__/__copy__/__deepcopy__/__dir__/_add_alias_/_add_value_alias_/__init_subclass__; EnumType utility methods __qualname__.__len__() for _check_for_existing_members_/__init_subclass__/__subclasshook__/_find_data_repr_/_find_data_type_/_get_mixins_/_add_member_/_find_new_/_convert_/_create_/__bool__/__len__/__dir__; IntEnum/StrEnum/IntFlag __mro__.__len__()==5/5/6."
    - "This spec covers: __name__.__len__() for Enum (4), IntEnum (7), Flag (4), IntFlag (7), StrEnum (7), EnumType (8), auto (4), unique (6); __qualname__.__len__() for Enum (4) and EnumType (8)."
    - "Enum.__name__ == 'Enum' (4 chars). Flag.__name__ == 'Flag' (4 chars). auto.__name__ == 'auto' (4 chars) — three public symbols share the 4-char name length."
    - "IntEnum.__name__ == 'IntEnum' (7 chars). IntFlag.__name__ == 'IntFlag' (7 chars). StrEnum.__name__ == 'StrEnum' (7 chars) — three symbols share the 7-char name length."
    - "EnumType.__name__ == 'EnumType' (8 chars). Note: enum.EnumMeta is an alias for enum.EnumType; EnumMeta.__name__ is also 'EnumType' (8 chars), because the class object's __name__ reflects the primary definition name."
    - "unique.__name__ == 'unique' (6 chars) — the class decorator for enforcing unique member values."
    - "Enum.__qualname__ == 'Enum' (4 chars) == Enum.__name__.__len__() — top-level class, name equals qualname."
    - "EnumType.__qualname__ == 'EnumType' (8 chars) == EnumType.__name__.__len__() — top-level metaclass, name equals qualname."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__len__() for the four-character enum public symbols (extra36 namespace)
#
# Three public symbols in the enum module share a 4-character name:
#   Enum.__name__  == 'Enum'  (4 chars) — the base class for all enum types
#   Flag.__name__  == 'Flag'  (4 chars) — the base class for flag enumerations
#   auto.__name__  == 'auto'  (4 chars) — the automatic value assignment class
# This 4-char cluster is the smallest name length among enum's public classes.
# No prior enum spec records these three __name__ lengths together in the
# extra36 namespace.
# ---------------------------------------------------------------------------

table enum_extra36.four_char_name_lens:
  description: "__name__.__len__() for Enum, Flag, and auto — all 4 chars"
  kind: python_call_eq
  category: class_name_attrs
  id_prefix: name_len

  columns: [id, function, args, expected]
  rows:
    - [Enum, Enum.__name__.__len__, [], 4]
    - [Flag, Flag.__name__.__len__, [], 4]
    - [auto, auto.__name__.__len__, [], 4]

# ---------------------------------------------------------------------------
# __name__.__len__() for the seven-character enum public classes (extra36 namespace)
#
# Three public classes in the enum module share a 7-character name:
#   IntEnum.__name__  == 'IntEnum'  (7 chars) — integer-valued enum base
#   IntFlag.__name__  == 'IntFlag'  (7 chars) — integer-valued flag base
#   StrEnum.__name__  == 'StrEnum'  (7 chars) — string-valued enum base
# All three are "mixed-in" enum types that combine enum behavior with a built-in
# type. No prior enum spec records these three __name__ lengths together in the
# extra36 namespace.
# ---------------------------------------------------------------------------

table enum_extra36.seven_char_name_lens:
  description: "__name__.__len__() for IntEnum, IntFlag, and StrEnum — all 7 chars"
  kind: python_call_eq
  category: class_name_attrs
  id_prefix: name_len

  columns: [id, function, args, expected]
  rows:
    - [IntEnum, IntEnum.__name__.__len__, [], 7]
    - [IntFlag, IntFlag.__name__.__len__, [], 7]
    - [StrEnum, StrEnum.__name__.__len__, [], 7]

# ---------------------------------------------------------------------------
# EnumType.__name__.__len__() == 8 — standalone (extra36 namespace)
#
# EnumType is the metaclass for all enum types. Its __name__ is 'EnumType'
# (8 characters). Note that enum.EnumMeta is an alias pointing to the same
# object, but the class object's __name__ attribute reflects the primary
# definition: EnumMeta.__name__ == 'EnumType' (also 8). The 8-character length
# is unique among enum's top-level public symbols. No prior enum spec records
# EnumType.__name__.__len__() as a standalone in the extra36 namespace.
# ---------------------------------------------------------------------------

invariant enum_extra36.EnumType.name_len:
  description: "len(enum.EnumType.__name__) == 8 — 'EnumType' is 8 chars; note EnumMeta is an alias and EnumMeta.__name__ is also 'EnumType'"
  category: class_name_attrs
  kind: python_call_eq
  function: EnumType.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# unique.__name__.__len__() == 6 — standalone (extra36 namespace)
#
# enum.unique is a class decorator (a function) that enforces all member values
# are unique within an enum. Its __name__ is 'unique' (6 characters). The
# 6-char length is distinct from Enum/Flag/auto (4), IntEnum/IntFlag/StrEnum (7),
# and EnumType (8). No prior enum spec records unique.__name__.__len__() as a
# standalone in the extra36 namespace.
# ---------------------------------------------------------------------------

invariant enum_extra36.unique.name_len:
  description: "len(enum.unique.__name__) == 6 — 'unique' is 6 chars; the class decorator enforcing unique member values"
  category: class_name_attrs
  kind: python_call_eq
  function: unique.__name__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# Enum.__qualname__.__len__() == 4 — standalone (extra36 namespace)
#
# Enum is defined at the top level of the enum module, so its __qualname__
# equals its __name__: 'Enum' (4 characters). This is the base class from which
# all enumeration types derive when using the functional or class syntax.
# No prior enum spec records Enum.__qualname__.__len__() as a standalone in
# the extra36 namespace.
# ---------------------------------------------------------------------------

invariant enum_extra36.Enum.qualname_len:
  description: "len(enum.Enum.__qualname__) == 4 — 'Enum' is 4 chars; __qualname__ == __name__ for this top-level base class"
  category: qualname_attrs
  kind: python_call_eq
  function: Enum.__qualname__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# EnumType.__qualname__.__len__() == 8 — standalone (extra36 namespace)
#
# EnumType is defined at the top level of the enum module, so its __qualname__
# equals its __name__: 'EnumType' (8 characters). As the metaclass governing
# all enum type creation, EnumType's qualname length (8) is the largest among
# the simple (non-compound) qualnames in the enum module's top-level public API.
# No prior enum spec records EnumType.__qualname__.__len__() as a standalone in
# the extra36 namespace.
# ---------------------------------------------------------------------------

invariant enum_extra36.EnumType.qualname_len:
  description: "len(enum.EnumType.__qualname__) == 8 — 'EnumType' is 8 chars; __qualname__ == __name__ for this top-level metaclass"
  category: qualname_attrs
  kind: python_call_eq
  function: EnumType.__qualname__.__len__
  args: []
  expected: 8
