spec: struct_extra190
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "struct.__name__ == 'struct' and struct.__package__ == '' — struct is a top-level stdlib module with no package prefix."
    - "struct.__spec__.name == 'struct' — the ModuleSpec name attribute matches the module's __name__."
    - "struct.Struct.__name__.__len__() == 6 ('Struct' has 6 characters); struct.pack.__name__.__len__() == 4 ('pack' has 4 characters)."
    - "struct.unpack.__name__.__len__() == 6 ('unpack' has 6 characters); struct.calcsize.__name__.__len__() == 8 ('calcsize' has 8 characters)."
    - "struct.error.__name__.__len__() == 5 ('error' has 5 characters) — struct.error is a subclass of Exception."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct module identity — __name__, __package__, __spec__.name
# ---------------------------------------------------------------------------

table structmodule190.module_identity:
  kind: python_call_eq
  category: module_identity
  id_prefix: structmodule190

  columns: [id, function, args, expected, description]
  rows:
    - [module_name,    __name__.__eq__,     ["struct"], true, "struct.__name__ == 'struct' (top-level stdlib module name)"]
    - [module_package, __package__.__eq__,  [""],       true, "struct.__package__ == '' (empty string — struct is a top-level module, no package prefix)"]
    - [spec_name,      __spec__.name.__eq__, ["struct"], true, "struct.__spec__.name == 'struct' (ModuleSpec.name matches the module's __name__)"]

# ---------------------------------------------------------------------------
# struct function and class name length checks
# ---------------------------------------------------------------------------

table structmodule190.name_lengths:
  kind: python_call_eq
  category: name_lengths
  id_prefix: structmodule190

  columns: [id, function, args, expected, description]
  rows:
    - [struct_class_name_len, Struct.__name__.__len__,    [], 6, "len(struct.Struct.__name__) == 6 ('Struct' has 6 characters)"]
    - [pack_name_len,         pack.__name__.__len__,      [], 4, "len(struct.pack.__name__) == 4 ('pack' has 4 characters)"]
    - [unpack_name_len,       unpack.__name__.__len__,    [], 6, "len(struct.unpack.__name__) == 6 ('unpack' has 6 characters)"]
    - [calcsize_name_len,     calcsize.__name__.__len__,  [], 8, "len(struct.calcsize.__name__) == 8 ('calcsize' has 8 characters)"]
    - [error_name_len,        error.__name__.__len__,     [], 5, "len(struct.error.__name__) == 5 ('error' has 5 characters)"]

# ---------------------------------------------------------------------------
# struct function and class name equality checks
# ---------------------------------------------------------------------------

table structmodule190.name_equality:
  kind: python_call_eq
  category: name_equality
  id_prefix: structmodule190

  columns: [id, function, args, expected, description]
  rows:
    - [struct_class_name_eq, Struct.__name__.__eq__,   ["Struct"],   true, "struct.Struct.__name__ == 'Struct'"]
    - [pack_name_eq,         pack.__name__.__eq__,     ["pack"],     true, "struct.pack.__name__ == 'pack'"]
    - [unpack_name_eq,       unpack.__name__.__eq__,   ["unpack"],   true, "struct.unpack.__name__ == 'unpack'"]
    - [calcsize_name_eq,     calcsize.__name__.__eq__, ["calcsize"], true, "struct.calcsize.__name__ == 'calcsize'"]
    - [error_name_eq,        error.__name__.__eq__,    ["error"],    true, "struct.error.__name__ == 'error'"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant structmodule190.module.name:
  description: "struct.__name__ == 'struct' (top-level stdlib module name)"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["struct"]
  expected: true

invariant structmodule190.module.package:
  description: "struct.__package__ == '' (top-level stdlib module, no package prefix)"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant structmodule190.module.spec_name:
  description: "struct.__spec__.name == 'struct' (ModuleSpec.name matches struct.__name__)"
  category: module_identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["struct"]
  expected: true

invariant structmodule190.Struct.name_len:
  description: "len(struct.Struct.__name__) == 6 ('Struct' has 6 characters)"
  category: name_lengths
  kind: python_call_eq
  function: Struct.__name__.__len__
  args: []
  expected: 6

invariant structmodule190.pack.name_len:
  description: "len(struct.pack.__name__) == 4 ('pack' has 4 characters)"
  category: name_lengths
  kind: python_call_eq
  function: pack.__name__.__len__
  args: []
  expected: 4

invariant structmodule190.unpack.name_len:
  description: "len(struct.unpack.__name__) == 6 ('unpack' has 6 characters)"
  category: name_lengths
  kind: python_call_eq
  function: unpack.__name__.__len__
  args: []
  expected: 6

invariant structmodule190.calcsize.name_len:
  description: "len(struct.calcsize.__name__) == 8 ('calcsize' has 8 characters)"
  category: name_lengths
  kind: python_call_eq
  function: calcsize.__name__.__len__
  args: []
  expected: 8

invariant structmodule190.error.name_len:
  description: "len(struct.error.__name__) == 5 ('error' has 5 characters)"
  category: name_lengths
  kind: python_call_eq
  function: error.__name__.__len__
  args: []
  expected: 5
