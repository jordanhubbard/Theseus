spec: io_extra184
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec covers: io.TextIOWrapper class identity — __name__, __module__, __mro__ length, __bases__[0].__name__; and io.IncrementalNewlineDecoder class identity — __name__, __module__, __mro__ length."
    - "io.TextIOWrapper.__name__ == 'TextIOWrapper' (len=13); io.TextIOWrapper.__module__ == 'io'."
    - "io.TextIOWrapper.__mro__.__len__() == 4: the MRO is (TextIOWrapper, TextIOBase, IOBase, object) — 4 classes."
    - "io.TextIOWrapper.__bases__[0].__name__ == 'TextIOBase' — TextIOWrapper inherits directly from TextIOBase."
    - "io.IncrementalNewlineDecoder.__name__ == 'IncrementalNewlineDecoder' (len=22) — the longest io class name covered."
    - "io.IncrementalNewlineDecoder.__module__ == 'io'."
    - "io.IncrementalNewlineDecoder.__mro__.__len__() == 2: MRO is (IncrementalNewlineDecoder, object) — only 2 classes."
    - "Length comparison: 'TextIOWrapper' (13) < 'IncrementalNewlineDecoder' (22): IncrementalNewlineDecoder is 9 characters longer."
    - "MRO comparison: TextIOWrapper (4) > IncrementalNewlineDecoder (2): TextIOWrapper has a deeper inheritance chain."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io.TextIOWrapper class name identity
# __name__=='TextIOWrapper' (len=13); __module__=='io'
# ---------------------------------------------------------------------------

table io_extra184.textiowrapper_class_identity:
  description: "io.TextIOWrapper class identity: __name__=='TextIOWrapper' (len=13); __module__=='io'; confirmed Python 3.14.3 macOS"
  kind: python_call_eq
  category: identity
  id_prefix: iotextwrapper184

  columns: [id, function, args, expected, description]
  rows:
    - [tiw_name,       TextIOWrapper.__name__.__eq__,          ["TextIOWrapper"], true, "io.TextIOWrapper.__name__ == 'TextIOWrapper' — TextIOWrapper is the main text-mode I/O wrapper class; 'TextIOWrapper' has 13 characters: T(1)e(2)x(3)t(4)I(5)O(6)W(7)r(8)a(9)p(10)p(11)e(12)r(13); confirmed Python 3.14.3 macOS"]
    - [tiw_name_len,   TextIOWrapper.__name__.__len__,         [],                13,   "io.TextIOWrapper.__name__.__len__() == 13 — 'TextIOWrapper' has 13 characters; TextIOWrapper (13) < IncrementalNewlineDecoder (22): TextIOWrapper has the shorter class name of the two covered; confirmed Python 3.14.3 macOS"]
    - [tiw_module,     TextIOWrapper.__module__.__eq__,        ["io"],            true, "io.TextIOWrapper.__module__ == 'io' — TextIOWrapper is defined in the io module (backed by the _io C extension); __module__ reports 'io' as the public module name; confirmed Python 3.14.3 macOS"]
    - [tiw_mro_len,    TextIOWrapper.__mro__.__len__,          [],                4,    "io.TextIOWrapper.__mro__.__len__() == 4 — the MRO is (TextIOWrapper, TextIOBase, IOBase, object): 4 classes; TextIOWrapper (4) > IncrementalNewlineDecoder (2): TextIOWrapper has a deeper inheritance chain; confirmed Python 3.14.3 macOS"]
    - [tiw_base0_name, "TextIOWrapper.__bases__[0].__name__.__eq__", ["TextIOBase"], true, "io.TextIOWrapper.__bases__[0].__name__ == 'TextIOBase' — TextIOWrapper directly inherits from TextIOBase; __bases__[0] is TextIOBase which is the first (and only) direct base in the MRO after TextIOWrapper itself; confirmed Python 3.14.3 macOS"]
    - [tiw_base0_len,  "TextIOWrapper.__bases__[0].__name__.__len__", [],          10,   "io.TextIOWrapper.__bases__[0].__name__.__len__() == 10 — 'TextIOBase' has 10 characters: T(1)e(2)x(3)t(4)I(5)O(6)B(7)a(8)s(9)e(10); TextIOBase (10) < TextIOWrapper (13): the base class name is 3 characters shorter than the subclass; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: io.TextIOWrapper MRO class names at positions 1 and 3
# __mro__[1].__name__=='TextIOBase'; __mro__[3].__name__=='object'
# ---------------------------------------------------------------------------

table io_extra184.textiowrapper_mro_entries:
  description: "io.TextIOWrapper MRO entry names: __mro__[1].__name__=='TextIOBase'; __mro__[2].__name__=='IOBase'; __mro__[3].__name__=='object'; MRO has 4 entries total"
  kind: python_call_eq
  category: identity
  id_prefix: iotextwrapper184

  columns: [id, function, args, expected, description]
  rows:
    - [mro1_name,     "TextIOWrapper.__mro__[1].__name__.__eq__", ["TextIOBase"], true, "io.TextIOWrapper.__mro__[1].__name__ == 'TextIOBase' — the second entry in the MRO (index 1) is TextIOBase, the direct abstract base for text streams; MRO: (TextIOWrapper[0], TextIOBase[1], IOBase[2], object[3]); confirmed Python 3.14.3 macOS"]
    - [mro1_name_len, "TextIOWrapper.__mro__[1].__name__.__len__", [],            10,   "io.TextIOWrapper.__mro__[1].__name__.__len__() == 10 — 'TextIOBase' has 10 characters; TextIOBase (10) < TextIOWrapper (13): the base class name is shorter by 3 characters; confirmed Python 3.14.3 macOS"]
    - [mro2_name,     "TextIOWrapper.__mro__[2].__name__.__eq__", ["IOBase"],     true, "io.TextIOWrapper.__mro__[2].__name__ == 'IOBase' — the third MRO entry (index 2) is IOBase, the ultimate base for all I/O classes; 'IOBase' has 6 characters; confirmed Python 3.14.3 macOS"]
    - [mro2_name_len, "TextIOWrapper.__mro__[2].__name__.__len__", [],            6,    "io.TextIOWrapper.__mro__[2].__name__.__len__() == 6 — 'IOBase' has 6 characters: I(1)O(2)B(3)a(4)s(5)e(6); IOBase (6) < TextIOBase (10) < TextIOWrapper (13): the MRO name lengths increase as we go from root toward the leaf class; confirmed Python 3.14.3 macOS"]
    - [mro3_name,     "TextIOWrapper.__mro__[3].__name__.__eq__", ["object"],     true, "io.TextIOWrapper.__mro__[3].__name__ == 'object' — the fourth and final MRO entry (index 3) is object, the Python root class; all Python classes ultimately inherit from object; confirmed Python 3.14.3 macOS"]
    - [mro0_name,     "TextIOWrapper.__mro__[0].__name__.__eq__", ["TextIOWrapper"], true, "io.TextIOWrapper.__mro__[0].__name__ == 'TextIOWrapper' — the first MRO entry (index 0) is the class itself; __mro__[0] is always the class on which __mro__ is looked up; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: io.IncrementalNewlineDecoder class identity
# __name__ (len=22) is the longest io class name; __mro__.__len__()==2
# ---------------------------------------------------------------------------

table io_extra184.incrementalnewlinedecoder_identity:
  description: "io.IncrementalNewlineDecoder class identity: __name__=='IncrementalNewlineDecoder' (len=22); __module__=='io'; __mro__.__len__()==2 — only inherits from object"
  kind: python_call_eq
  category: identity
  id_prefix: iotextwrapper184

  columns: [id, function, args, expected, description]
  rows:
    - [ind_name,     IncrementalNewlineDecoder.__name__.__eq__,     ["IncrementalNewlineDecoder"], true, "io.IncrementalNewlineDecoder.__name__ == 'IncrementalNewlineDecoder' — IncrementalNewlineDecoder is the class that translates universal newlines incrementally; 'IncrementalNewlineDecoder' has 22 characters; it is the longest io class name covered; confirmed Python 3.14.3 macOS"]
    - [ind_name_len, IncrementalNewlineDecoder.__name__.__len__,    [],                           22,   "io.IncrementalNewlineDecoder.__name__.__len__() == 22 — 'IncrementalNewlineDecoder' has 22 characters; IncrementalNewlineDecoder (22) > TextIOWrapper (13) by 9 characters: it is the longest io class name covered; confirmed Python 3.14.3 macOS"]
    - [ind_module,   IncrementalNewlineDecoder.__module__.__eq__,   ["io"],                       true, "io.IncrementalNewlineDecoder.__module__ == 'io' — IncrementalNewlineDecoder is defined in the io module (backed by _io C extension); __module__ reports 'io'; confirmed Python 3.14.3 macOS"]
    - [ind_mro_len,  IncrementalNewlineDecoder.__mro__.__len__,     [],                           2,    "io.IncrementalNewlineDecoder.__mro__.__len__() == 2 — the MRO is (IncrementalNewlineDecoder, object): only 2 classes; IncrementalNewlineDecoder (2) < TextIOWrapper (4): IncrementalNewlineDecoder has a shallower inheritance chain despite the longer name; confirmed Python 3.14.3 macOS"]
    - [ind_base0,    "IncrementalNewlineDecoder.__bases__[0].__name__.__eq__", ["object"], true, "io.IncrementalNewlineDecoder.__bases__[0].__name__ == 'object' — IncrementalNewlineDecoder inherits directly from object; its MRO is (IncrementalNewlineDecoder, object) with only 2 entries; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra184.textiowrapper_name_is_textiowrapper:
  description: "io.TextIOWrapper.__name__ == 'TextIOWrapper' — TextIOWrapper wraps a buffered binary stream and provides text-mode I/O; len=13; TextIOWrapper (13) < IncrementalNewlineDecoder (22): TextIOWrapper has the shorter of the two class names covered; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: TextIOWrapper.__name__.__eq__
  args: ["TextIOWrapper"]
  expected: true

invariant io_extra184.textiowrapper_name_len_is_13:
  description: "io.TextIOWrapper.__name__.__len__() == 13 — 'TextIOWrapper' has 13 characters; TextIOWrapper (13) < IncrementalNewlineDecoder (22): difference of 9 characters; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: TextIOWrapper.__name__.__len__
  args: []
  expected: 13

invariant io_extra184.textiowrapper_module_is_io:
  description: "io.TextIOWrapper.__module__ == 'io' — TextIOWrapper's __module__ is 'io', the public module name; the underlying implementation is in the _io C extension; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: TextIOWrapper.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra184.textiowrapper_mro_len_is_4:
  description: "io.TextIOWrapper.__mro__.__len__() == 4 — MRO: (TextIOWrapper, TextIOBase, IOBase, object); 4 classes in the chain; TextIOWrapper MRO (4) > IncrementalNewlineDecoder MRO (2); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: TextIOWrapper.__mro__.__len__
  args: []
  expected: 4

invariant io_extra184.textiowrapper_bases0_is_textiobase:
  description: "io.TextIOWrapper.__bases__[0].__name__ == 'TextIOBase' — TextIOWrapper's only direct base is TextIOBase; TextIOBase (10) < TextIOWrapper (13): the base class name is 3 characters shorter; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "TextIOWrapper.__bases__[0].__name__.__eq__"
  args: ["TextIOBase"]
  expected: true

invariant io_extra184.ind_name_len_is_22:
  description: "io.IncrementalNewlineDecoder.__name__.__len__() == 22 — 'IncrementalNewlineDecoder' has 22 characters; this is the longest io class name covered; IncrementalNewlineDecoder (22) > TextIOWrapper (13) by 9; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: IncrementalNewlineDecoder.__name__.__len__
  args: []
  expected: 22

invariant io_extra184.ind_module_is_io:
  description: "io.IncrementalNewlineDecoder.__module__ == 'io' — IncrementalNewlineDecoder's __module__ is 'io'; both TextIOWrapper and IncrementalNewlineDecoder share the same module name 'io'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: IncrementalNewlineDecoder.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra184.ind_mro_len_is_2:
  description: "io.IncrementalNewlineDecoder.__mro__.__len__() == 2 — MRO: (IncrementalNewlineDecoder, object); only 2 classes; IncrementalNewlineDecoder (MRO len=2) < TextIOWrapper (MRO len=4): despite its longer name, IncrementalNewlineDecoder has the shallower inheritance chain; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: IncrementalNewlineDecoder.__mro__.__len__
  args: []
  expected: 2

