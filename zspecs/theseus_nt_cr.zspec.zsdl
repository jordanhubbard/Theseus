spec: theseus_nt_cr
version: ">=3.0"
backend: python_cleanroom(theseus_nt_cr)
blocks: nt

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/os.html"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
  notes:
    - "Clean-room nt module (Windows POSIX equivalent). Do NOT import nt."
    - "On non-Windows, delegates to posix with stubs for Windows-only functions."

error_model: python_exceptions

invariant theseus_nt_cr.nt2_getcwd:
  description: "getcwd() returns a non-empty string"
  category: behavior
  kind: python_call_eq
  function: nt2_getcwd
  args: []
  expected: true

invariant theseus_nt_cr.nt2_stat:
  description: "stat() returns a stat_result object"
  category: behavior
  kind: python_call_eq
  function: nt2_stat
  args: []
  expected: true

invariant theseus_nt_cr.nt2_constants:
  description: "nt constants are integers"
  category: behavior
  kind: python_call_eq
  function: nt2_constants
  args: []
  expected: true
