spec: socket_extra1381
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "Wave 539 (_extra1381): focuses on __abstractmethods__ frozenset checks."
    - "socket.socket is a concrete Python class wrapping a C-level socket; it defines no abstract methods, so socket.socket.__dict__.__contains__('__abstractmethods__') returns False."
    - "socket.error is an alias for OSError (a C builtin exception); it defines no abstract methods, so socket.error.__dict__.__contains__('__abstractmethods__') returns False."
    - "socket.timeout is an alias for TimeoutError (itself an OSError subclass); it defines no abstract methods, so socket.timeout.__dict__.__contains__('__abstractmethods__') returns False."
    - "frozenset is the type that __abstractmethods__ would be assigned to on abstract classes; frozenset.__class__.__name__ == 'type' (frozenset's metaclass is type)."
    - "frozenset.__bases__.__class__.__name__ == 'tuple' — the bases attribute of any class is always a tuple."
    - "socket.socket.__dict__.__class__.__name__ == 'mappingproxy' — all Python class __dict__ attributes are mappingproxy instances."
    - "socket.error.__dict__.__class__.__name__ == 'mappingproxy' and socket.timeout.__dict__.__class__.__name__ == 'mappingproxy' — same holds for exception aliases."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table socket_extra1381.socket_class_abstractmethods_absent:
  description: "socket.socket class dict does not contain __abstractmethods__ — socket.socket is a concrete class with no abstract methods; __dict__.__contains__ returns False"
  kind: python_call_eq
  category: abstractmethods_checks
  id_prefix: sk1381sc
  columns: [id, function, args, expected]
  rows:
    - [sk1381sc001, socket.socket.__dict__.__contains__,              ["__abstractmethods__"], false]
    - [sk1381sc002, socket.error.__dict__.__contains__,               ["__abstractmethods__"], false]
    - [sk1381sc003, socket.timeout.__dict__.__contains__,             ["__abstractmethods__"], false]
    - [sk1381sc004, socket.socket.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [sk1381sc005, socket.error.__dict__.__class__.__name__.__eq__,  ["mappingproxy"], true]
    - [sk1381sc006, socket.timeout.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]

table socket_extra1381.frozenset_abstractmethods_type_checks:
  description: "frozenset (the type __abstractmethods__ would be set to on abstract classes) class-level checks; frozenset.__class__.__name__ == 'type' and frozenset.__bases__.__class__.__name__ == 'tuple'"
  kind: python_call_eq
  category: abstractmethods_checks
  id_prefix: sk1381fa
  columns: [id, function, args, expected]
  rows:
    - [sk1381fa001, frozenset.__class__.__name__.__eq__,            ["type"],         true]
    - [sk1381fa002, frozenset.__bases__.__class__.__name__.__eq__,  ["tuple"],        true]
    - [sk1381fa003, frozenset.__name__.__class__.__name__.__eq__,   ["str"],          true]
    - [sk1381fa004, frozenset.__dict__.__contains__,                 ["__abstractmethods__"], false]
    - [sk1381fa005, frozenset.__dict__.__class__.__name__.__eq__,   ["mappingproxy"], true]
    - [sk1381fa006, frozenset.__mro__.__class__.__name__.__eq__,    ["tuple"],        true]

table socket_extra1381.socket_error_timeout_bases_and_class_name_checks:
  description: "socket.socket, socket.error, and socket.timeout __bases__ and __class__.__name__ cross-checks; verifies the inheritance structure attributes are consistent with the abstractmethods theme"
  kind: python_call_eq
  category: abstractmethods_checks
  id_prefix: sk1381bc
  columns: [id, function, args, expected]
  rows:
    - [sk1381bc001, socket.socket.__bases__.__class__.__name__.__eq__,   ["tuple"],  true]
    - [sk1381bc002, socket.error.__bases__.__class__.__name__.__eq__,    ["tuple"],  true]
    - [sk1381bc003, socket.timeout.__bases__.__class__.__name__.__eq__,  ["tuple"],  true]
    - [sk1381bc004, socket.socket.__mro__.__class__.__name__.__eq__,     ["tuple"],  true]
    - [sk1381bc005, socket.error.__name__.__class__.__name__.__eq__,     ["str"],    true]
    - [sk1381bc006, socket.timeout.__name__.__class__.__name__.__eq__,   ["str"],    true]
