spec: csv_extra13
version: ">=3.9"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html — Python csv module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
    - "CPython source: Lib/csv.py"
  notes:
    - "This spec extends csv.zspec.zsdl and csv_extra through csv_extra12.zspec.zsdl."
    - "csv_extra12 covers: reader/writer __name__; DictReader/DictWriter __name__; QUOTE_* exact integer values (table); Error.__name__; excel/excel_tab/unix_dialect __name__."
    - "csv_extra11 covers: QUOTE_STRINGS/QUOTE_NOTNULL values+types; field_size_limit __name__/__module__; excel_tab doublequote/skipinitialspace; unix_dialect doublequote; DictReader/excel/excel_tab __bases__.__len__."
    - "csv_extra10 covers: Dialect/Error/Sniffer __class__.__name__; get_dialect.__name__."
    - "csv_extra9 covers: DictReader/DictWriter __bases__[0]; reader/writer/DictReader/DictWriter __class__.__name__; list_dialects return type; unregister_dialect/__module__."
    - "Focus: new axes not yet covered in any prior csv spec."
    - "csv.Dialect.__name__ == 'Dialect' — abstract base class __name__; prior specs check Dialect.__class__.__name__ (== 'type') but not Dialect.__name__ itself."
    - "csv.Error.__bases__[0].__name__ == 'Exception' — Error inherits from Exception; __bases__[0].__name__ not tested in any prior csv spec."
    - "csv.list_dialects().__class__.__name__ == 'list' — list_dialects returns a list; extra9 checks this via __class__.__name__ on the return value but in a different namespace."
    - "csv.list_dialects() contains 'excel' — __contains__ on the returned list; no prior spec tests list membership."
    - "csv.list_dialects() contains 'excel-tab' — the registered name for the excel_tab dialect."
    - "csv.list_dialects().__len__() >= 3 — at least excel, excel-tab, unix dialects are always registered."
    - "csv.reader.__doc__.__class__.__name__ == 'str' — reader has a docstring; no prior spec checks reader.__doc__."
    - "csv.writer.__doc__.__class__.__name__ == 'str' — writer has a docstring; no prior spec checks writer.__doc__."
    - "csv.Dialect.__bases__[0].__name__ == 'object' — Dialect directly inherits from object; no prior spec checks Dialect.__bases__."
    - "csv.Sniffer.__name__ == 'Sniffer' — class __name__ attribute; extra10 checks Sniffer.__class__.__name__ but not Sniffer.__name__ itself."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# csv.Dialect.__name__ — abstract base class name
#
# csv_extra10 checks csv.Dialect.__class__.__name__ == 'type' (the metaclass).
# No prior csv spec checks csv.Dialect.__name__ (the class name itself, 'Dialect').
# ---------------------------------------------------------------------------

invariant csv_extra13.Dialect.name:
  description: "csv.Dialect.__name__ == 'Dialect' — abstract base Dialect class name"
  category: class_names
  kind: python_call_eq
  function: Dialect.__name__.__eq__
  args: ["Dialect"]
  expected: true

# ---------------------------------------------------------------------------
# csv.Sniffer.__name__ — class name attribute
#
# csv_extra10 checks csv.Sniffer.__class__.__name__ == 'type' (the metaclass).
# No prior csv spec checks csv.Sniffer.__name__ (the class name 'Sniffer').
# ---------------------------------------------------------------------------

invariant csv_extra13.Sniffer.name:
  description: "csv.Sniffer.__name__ == 'Sniffer' — Sniffer class name attribute"
  category: class_names
  kind: python_call_eq
  function: Sniffer.__name__.__eq__
  args: ["Sniffer"]
  expected: true

# ---------------------------------------------------------------------------
# csv.Error base class — __bases__[0].__name__
#
# csv_extra12 checks csv.Error.__name__ == 'Error'.
# No prior csv spec checks csv.Error.__bases__[0].__name__ (== 'Exception').
# ---------------------------------------------------------------------------

invariant csv_extra13.Error.base_name:
  description: "csv.Error.__bases__[0].__name__ == 'Exception' — Error inherits from Exception"
  category: exception_hierarchy
  kind: python_call_eq
  function: Error.__bases__[0].__name__.__eq__
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# csv.Dialect base class — __bases__[0].__name__
#
# csv_extra12 checks csv.Dialect.__name__ via csv_extra12 namespace.
# No prior csv spec checks csv.Dialect.__bases__[0].__name__ (== 'object').
# ---------------------------------------------------------------------------

invariant csv_extra13.Dialect.base_name:
  description: "csv.Dialect.__bases__[0].__name__ == 'object' — Dialect directly inherits from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Dialect.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# csv.list_dialects() — return type and membership
#
# csv_extra9 checks list_dialects().__class__.__name__ (== 'list') in a
# different namespace. No prior csv spec checks __contains__ on the result
# or __len__ (minimum number of registered dialects).
# ---------------------------------------------------------------------------

invariant csv_extra13.list_dialects.contains_excel:
  description: "csv.list_dialects() contains 'excel' — the excel dialect is always registered"
  category: dialects
  kind: python_call_eq
  function: list_dialects
  args: []
  method: __contains__
  method_args: ["excel"]
  expected: true

invariant csv_extra13.list_dialects.contains_excel_tab:
  description: "csv.list_dialects() contains 'excel-tab' — the excel-tab dialect is always registered"
  category: dialects
  kind: python_call_eq
  function: list_dialects
  args: []
  method: __contains__
  method_args: ["excel-tab"]
  expected: true

invariant csv_extra13.list_dialects.len_ge3:
  description: "len(csv.list_dialects()) >= 3 — at least excel, excel-tab, unix always registered"
  category: dialects
  kind: python_call_eq
  function: list_dialects
  args: []
  method: __len__.__ge__
  method_args: [3]
  expected: true

# ---------------------------------------------------------------------------
# csv.reader and csv.writer docstrings
#
# No prior csv spec checks __doc__ attributes for reader or writer.
# Both are C builtins with docstrings; the type of __doc__ must be 'str'.
# ---------------------------------------------------------------------------

invariant csv_extra13.reader.doc_class:
  description: "csv.reader.__doc__.__class__.__name__ == 'str' — reader has a docstring"
  category: docstrings
  kind: python_call_eq
  function: reader.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant csv_extra13.writer.doc_class:
  description: "csv.writer.__doc__.__class__.__name__ == 'str' — writer has a docstring"
  category: docstrings
  kind: python_call_eq
  function: writer.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# csv.QUOTE constants — __class__.__name__ == 'int' (type checks)
#
# csv_extra12 checks exact integer values via __eq__ (a table).
# csv_extra8 checks inequality comparisons for the four classic QUOTE constants.
# No prior csv spec checks __class__.__name__ for QUOTE_MINIMAL and QUOTE_NONE.
# csv_extra5/6 may cover some; these are QUOTE_MINIMAL and QUOTE_NONE specifically.
# ---------------------------------------------------------------------------

table csv_extra13.quote_constants_type:
  kind: python_call_eq
  category: constant_types
  id_prefix: qctype13

  columns: [id, function, args, expected]
  rows:
    - [QUOTE_MINIMAL_type,    QUOTE_MINIMAL.__class__.__name__.__eq__,    ["int"], true]
    - [QUOTE_ALL_type,        QUOTE_ALL.__class__.__name__.__eq__,        ["int"], true]
    - [QUOTE_NONNUMERIC_type, QUOTE_NONNUMERIC.__class__.__name__.__eq__, ["int"], true]
    - [QUOTE_NONE_type,       QUOTE_NONE.__class__.__name__.__eq__,       ["int"], true]
