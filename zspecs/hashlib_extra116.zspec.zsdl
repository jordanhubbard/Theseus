spec: hashlib_extra116
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra115.zspec.zsdl — covers hash object .name attribute equality and lengths / hashlib.new function identity / pbkdf2_hmac module and type (table + invariants)."
    - "hashlib_extra114.zspec.zsdl — covers hashlib.__name__/__package__/__spec__/__all__/__loader__ module-level dunder attributes (table + invariants)."
    - "hashlib_extra113.zspec.zsdl — covers HASH class-level descriptor types / HASH descriptor qualnames and __objclass__ (table + invariants)."
    - "hashlib_extra112.zspec.zsdl — covers md5/sha1/sha256/sha512 function __qualname__ string equality / sha224/sha384/sha3_512/blake2s qualname equality / qualname length groupings (table + invariants)."
    - "hashlib_extra111.zspec.zsdl — covers sha3_256/__qualname__ and blake2b qualname / blake2b is a type not a function (table + invariants)."
    - "hashlib_extra108.zspec.zsdl — covers sha224/sha384/sha3_256/sha3_512 digest_size and block_size / blake2b/blake2s digest_size and block_size (table + invariants)."
    - "hashlib_extra107.zspec.zsdl — covers HASH type identity (__name__=='HASH', __module__=='_hashlib', __mro__.__len__()==2) (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 __class__.__name__=='builtin_function_or_method' / algorithms_guaranteed.__len__()==14 (table + invariants)."
  notes:
    - "This spec extends hashlib through hashlib_extra115; it does NOT duplicate invariants present in those files."
    - "Wave 273 theme: HASH object method type identity (update/digest/hexdigest/copy are builtin_function_or_method at instance level) / HASH object method __qualname__ equality / HASH class __module__ equality for sha256() and md5() instances."
    - "hashlib.sha256().update.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256().digest.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256().hexdigest.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256().copy.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256().update.__qualname__ == 'HASH.update'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256().digest.__qualname__ == 'HASH.digest'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256().hexdigest.__qualname__ == 'HASH.hexdigest'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256().copy.__qualname__ == 'HASH.copy'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256().__class__.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().__class__.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512().update.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1().digest.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: HASH instance methods (update, digest, hexdigest, copy) are 'builtin_function_or_method' at the instance level because they are bound C methods. This is analogous to struct.Struct instance methods. hashlib_extra107 anchors HASH class identity (__name__=='HASH', __module__=='_hashlib'); this spec anchors the instance method types for the first time."
    - "Note: The __qualname__ of HASH instance methods uses the 'HASH.' prefix (the C class name), not 'sha256.' or 'HASH256.'. update='HASH.update', digest='HASH.digest', hexdigest='HASH.hexdigest', copy='HASH.copy'. These qualnames are the same regardless of which algorithm was used to create the hash object."
    - "Note: sha256().__class__.__module__ == '_hashlib' (8 chars with leading underscore) confirms the HASH class is implemented in the _hashlib C extension module. Both md5() and sha256() produce HASH instances from the same C class (_hashlib.HASH)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha256().update.__class__.__name__ == 'builtin_function_or_method'
# hashlib.sha256().digest.__class__.__name__ == 'builtin_function_or_method'
# hashlib.sha256().hexdigest.__class__.__name__ == 'builtin_function_or_method'
# hashlib.sha256().copy.__class__.__name__ == 'builtin_function_or_method'
# hashlib.sha512().update.__class__.__name__ == 'builtin_function_or_method'
#
# Wave 273 theme: HASH instance method type identity.
#
# HASH instance methods (update, digest, hexdigest, copy) are bound C methods,
# appearing as 'builtin_function_or_method' at the instance level. This parallels
# how struct.Struct instance methods work. hashlib_extra107 anchors HASH class
# identity (__name__=='HASH', __module__=='_hashlib'); hashlib_extra113 anchors
# HASH class-level descriptor types (getset_descriptors for name/block_size/
# digest_size). This spec anchors the instance method types for the first time.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra116.hash_instance_method_type_identity:
  description: "sha256().update.__class__.__name__=='builtin_function_or_method' / sha256().digest.__class__.__name__=='builtin_function_or_method' / sha256().hexdigest.__class__.__name__=='builtin_function_or_method' / sha256().copy.__class__.__name__=='builtin_function_or_method' / sha512().update.__class__.__name__=='builtin_function_or_method' — bound C methods at instance level; same pattern as struct.Struct instance methods; extra107 anchors HASH class identity; extra113 anchors descriptor types; first hashmeth116 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashmeth116

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_update_type, "sha256().update.__class__.__name__.__eq__",    ["builtin_function_or_method"], true, "hashlib.sha256().update is a bound C method (builtin_function_or_method); feeds data into the hash state"]
    - [sha256_digest_type, "sha256().digest.__class__.__name__.__eq__",    ["builtin_function_or_method"], true, "hashlib.sha256().digest is a bound C method (builtin_function_or_method); returns raw bytes digest"]
    - [sha256_hexdigest_type, "sha256().hexdigest.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "hashlib.sha256().hexdigest is a bound C method (builtin_function_or_method); returns hex string digest"]
    - [sha256_copy_type,   "sha256().copy.__class__.__name__.__eq__",      ["builtin_function_or_method"], true, "hashlib.sha256().copy is a bound C method (builtin_function_or_method); returns copy of hash object"]
    - [sha512_update_type, "sha512().update.__class__.__name__.__eq__",    ["builtin_function_or_method"], true, "hashlib.sha512().update is a bound C method (builtin_function_or_method); same type regardless of algorithm"]

# ---------------------------------------------------------------------------
# hashlib.sha256().update.__qualname__ == 'HASH.update'
# hashlib.sha256().digest.__qualname__ == 'HASH.digest'
# hashlib.sha256().hexdigest.__qualname__ == 'HASH.hexdigest'
# hashlib.sha256().copy.__qualname__ == 'HASH.copy'
# hashlib.sha1().digest.__qualname__ == 'HASH.digest'
#
# Wave 273 theme: HASH instance method qualname equality.
#
# HASH instance method qualnames use the 'HASH.' prefix regardless of the
# algorithm (sha256(), sha512(), md5(), sha1() all produce HASH instances with
# identically-named bound methods). The qualname 'HASH.update' (11 chars:
# 'HASH.'=5 + 'update'=6), 'HASH.digest' (11 chars: 'HASH.'=5 + 'digest'=6),
# 'HASH.hexdigest' (14 chars: 'HASH.'=5 + 'hexdigest'=9), 'HASH.copy' (9 chars:
# 'HASH.'=5 + 'copy'=4). No prior hashlib spec anchors these qualname equalities.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra116.hash_instance_method_qualname_equality:
  description: "sha256().update.__qualname__.__eq__('HASH.update')==True / sha256().digest.__qualname__.__eq__('HASH.digest')==True / sha256().hexdigest.__qualname__.__eq__('HASH.hexdigest')==True / sha256().copy.__qualname__.__eq__('HASH.copy')==True / sha1().digest.__qualname__.__eq__('HASH.digest')==True — qualnames use 'HASH.' prefix (C class name) regardless of algorithm; update=11 chars; digest=11 chars; hexdigest=14 chars; copy=9 chars; no prior hashlib spec anchors these qualnames; first hashmeth116 anchor"
  kind: python_call_eq
  category: method_identity
  id_prefix: hashmeth116

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_update_qualname,    "sha256().update.__qualname__.__eq__",    ["HASH.update"],    true, "hashlib.sha256().update.__qualname__ is 'HASH.update' (11 chars; 'HASH.'=5 + 'update'=6; C class prefix)"]
    - [sha256_digest_qualname,    "sha256().digest.__qualname__.__eq__",    ["HASH.digest"],    true, "hashlib.sha256().digest.__qualname__ is 'HASH.digest' (11 chars; 'HASH.'=5 + 'digest'=6; same length as update)"]
    - [sha256_hexdigest_qualname, "sha256().hexdigest.__qualname__.__eq__", ["HASH.hexdigest"], true, "hashlib.sha256().hexdigest.__qualname__ is 'HASH.hexdigest' (14 chars; 'HASH.'=5 + 'hexdigest'=9; longest of the four)"]
    - [sha256_copy_qualname,      "sha256().copy.__qualname__.__eq__",      ["HASH.copy"],      true, "hashlib.sha256().copy.__qualname__ is 'HASH.copy' (9 chars; 'HASH.'=5 + 'copy'=4; shortest of the four)"]
    - [sha1_digest_qualname,      "sha1().digest.__qualname__.__eq__",      ["HASH.digest"],    true, "hashlib.sha1().digest.__qualname__ is 'HASH.digest' (same qualname as sha256().digest; algorithm-independent)"]

# ---------------------------------------------------------------------------
# hashlib.sha256().__class__.__module__.__eq__('_hashlib')
# hashlib.md5().__class__.__module__.__eq__('_hashlib')
# hashlib.sha256().__class__.__module__.__len__() == 8
# hashlib.sha256().update.__name__.__eq__('update')
# hashlib.sha256().hexdigest.__name__.__eq__('hexdigest')
#
# Wave 273 theme: HASH class module equality and method __name__ equality.
#
# sha256().__class__.__module__ is '_hashlib' (8 chars with leading underscore).
# Both md5() and sha256() instances share the same HASH class (__class__.__module__
# == '_hashlib'). hashlib_extra107 anchors HASH class __name__=='HASH' and
# __module__=='_hashlib' via the class object itself; this spec anchors the same
# module via the instance's __class__.__module__ for the first time. Method __name__
# attributes: update='update' (6 chars), hexdigest='hexdigest' (9 chars).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra116.hash_class_module_and_method_names:
  description: "sha256().__class__.__module__.__eq__('_hashlib')==True / md5().__class__.__module__.__eq__('_hashlib')==True / sha256().__class__.__module__.__len__()==8 / sha256().update.__name__.__eq__('update')==True / sha256().hexdigest.__name__.__eq__('hexdigest')==True — both md5 and sha256 instances share the HASH C class from _hashlib (8 chars; leading underscore is CPython C extension convention); method __name__ attrs: update=6 chars, hexdigest=9 chars; extra107 anchors HASH class __module__; first hashmeth116 anchor for instance __class__.__module__"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashmeth116

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_class_module_eq, "sha256().__class__.__module__.__eq__",      ["_hashlib"], true, "hashlib.sha256().__class__.__module__ is '_hashlib' (8 chars; the C extension module implementing HASH)"]
    - [md5_class_module_eq,    "md5().__class__.__module__.__eq__",         ["_hashlib"], true, "hashlib.md5().__class__.__module__ is '_hashlib' (same C class as sha256; HASH is shared across algorithms)"]
    - [sha256_class_module_len, "sha256().__class__.__module__.__len__",    [],           8,    "hashlib.sha256().__class__.__module__.__len__() is 8 ('_hashlib': underscore + 'hashlib')"]
    - [update_name_eq,          "sha256().update.__name__.__eq__",          ["update"],   true, "hashlib.sha256().update.__name__ is 'update' (6 chars; u-p-d-a-t-e; feeds bytes into hash state)"]
    - [hexdigest_name_eq,       "sha256().hexdigest.__name__.__eq__",       ["hexdigest"], true, "hashlib.sha256().hexdigest.__name__ is 'hexdigest' (9 chars; returns lowercase hex string of the digest)"]

# ---------------------------------------------------------------------------
# hashlib.sha256().update.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# hashlib.sha256().update is a 'builtin_function_or_method'. HASH instance
# methods are bound C methods — when accessed on a HASH instance (e.g., sha256()),
# the method_descriptor at the class level becomes a builtin_function_or_method.
# This is the standard Python descriptor protocol for C extension types. The
# equivalent for a struct.Struct instance is also 'builtin_function_or_method'
# (e.g., struct.Struct('I').pack). hashlib_extra107 anchors HASH class identity;
# no prior hashlib spec anchors the instance method type as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra116.sha256_update_type_eq:
  description: "hashlib.sha256().update.__class__.__name__.__eq__('builtin_function_or_method') == True — HASH instance method is a bound C method (builtin_function_or_method); descriptor protocol converts method_descriptor to bound builtin_function_or_method on instance access; parallels struct.Struct('I').pack type; extra107 anchors HASH class identity; first standalone under hashmeth116"
  category: type_identity
  kind: python_call_eq
  function: "sha256().update.__class__.__name__.__eq__"
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha256().update.__qualname__.__eq__('HASH.update') — standalone
#
# hashlib.sha256().update.__qualname__ is 'HASH.update' (11 chars: 'HASH.'=5 +
# 'update'=6). The 'HASH.' prefix reflects the C class name 'HASH' (capital
# letters; defined in _hashlib). The qualname 'HASH.update' is the same
# regardless of which algorithm was used to create the hash instance (sha256(),
# sha512(), md5() all produce instances with the same HASH class and identical
# bound method qualnames). No prior hashlib spec anchors HASH.update qualname
# equality as a standalone under hashmeth116.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra116.sha256_update_qualname_eq:
  description: "hashlib.sha256().update.__qualname__.__eq__('HASH.update') == True — qualname is 'HASH.update' (11 chars; 'HASH.'=5 + 'update'=6); 'HASH.' prefix reflects C class name; qualname is algorithm-independent (sha256/sha512/md5 all produce same qualname); no prior hashlib spec anchors this qualname; first standalone under hashmeth116"
  category: method_identity
  kind: python_call_eq
  function: "sha256().update.__qualname__.__eq__"
  args: ["HASH.update"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha256().hexdigest.__qualname__.__eq__('HASH.hexdigest') — standalone
#
# hashlib.sha256().hexdigest.__qualname__ is 'HASH.hexdigest' (14 chars: 'HASH.'=5
# + 'hexdigest'=9). hexdigest is the longest qualname among the four core HASH
# instance methods (update=11, digest=11, hexdigest=14, copy=9). hexdigest returns
# a lowercase hexadecimal string representation of the digest (e.g., for sha256
# this is a 64-char hex string: 32 bytes * 2 hex chars per byte). No prior
# hashlib spec anchors HASH.hexdigest qualname equality as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra116.sha256_hexdigest_qualname_eq:
  description: "hashlib.sha256().hexdigest.__qualname__.__eq__('HASH.hexdigest') == True — qualname is 'HASH.hexdigest' (14 chars; 'HASH.'=5 + 'hexdigest'=9); longest among four core HASH method qualnames (update=11, digest=11, hexdigest=14, copy=9); hexdigest returns 64-char hex string for sha256; first standalone under hashmeth116"
  category: method_identity
  kind: python_call_eq
  function: "sha256().hexdigest.__qualname__.__eq__"
  args: ["HASH.hexdigest"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha256().__class__.__module__.__eq__('_hashlib') — standalone
#
# hashlib.sha256().__class__.__module__ is '_hashlib'. The HASH class is
# implemented in the _hashlib C extension (Modules/_hashlib.c). Accessing
# __class__ on a HASH instance returns the HASH type object itself, whose
# __module__ is '_hashlib' (8 chars). hashlib_extra107 anchors HASH class
# __module__ via the class object directly (hashlib.sha256().__class__.__name__
# == 'HASH' and __module__ == '_hashlib' at the type level). This standalone
# anchors the same value via the instance __class__ chain.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra116.sha256_class_module_eq:
  description: "hashlib.sha256().__class__.__module__.__eq__('_hashlib') == True — HASH class __module__ is '_hashlib' (8 chars; _hashlib C extension implements HASH in Modules/_hashlib.c); accessed via instance __class__ chain; extra107 anchors HASH class __module__ via class object directly; first standalone for instance __class__.__module__ under hashmeth116"
  category: type_identity
  kind: python_call_eq
  function: "sha256().__class__.__module__.__eq__"
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha256().copy.__qualname__.__eq__('HASH.copy') — standalone
#
# hashlib.sha256().copy.__qualname__ is 'HASH.copy' (9 chars: 'HASH.'=5 +
# 'copy'=4). copy is the shortest qualname among the four core HASH instance
# methods. HASH.copy creates a new HASH instance with the same algorithm and
# current hash state, allowing the same intermediate state to be used multiple
# times without re-hashing the prefix data. This is efficient for computing
# digests of many messages that share a common prefix.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra116.sha256_copy_qualname_eq:
  description: "hashlib.sha256().copy.__qualname__.__eq__('HASH.copy') == True — qualname is 'HASH.copy' (9 chars; 'HASH.'=5 + 'copy'=4); shortest qualname among four core HASH methods (update=11, digest=11, hexdigest=14, copy=9); copy returns new HASH with same state for reuse without re-hashing prefix; first standalone under hashmeth116"
  category: method_identity
  kind: python_call_eq
  function: "sha256().copy.__qualname__.__eq__"
  args: ["HASH.copy"]
  expected: true

