spec: pathlib_extra268
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
  notes:
    - "pathlib.PurePath('/usr/local/bin/python3.py').name == 'python3.py' — filename with extension."
    - "pathlib.PurePath('/usr/local/bin/python3.py').suffix == '.py' — last extension component."
    - "pathlib.PurePath('/usr/local/bin/python3.py').stem == 'python3' — name without final suffix."
    - "PurePath.parent on POSIX returns a PurePosixPath instance."
    - "PurePath.parts returns a plain tuple; parts[0] == '/' for absolute paths on POSIX."
    - "pathlib.Path.cwd and pathlib.Path.home are classmethods; type(Path.cwd).__name__ == 'method'."
    - "pathlib.Path.cwd.__func__.__qualname__ == 'Path.cwd', Path.home.__func__.__qualname__ == 'Path.home'."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PurePath attribute values — /usr/local/bin/python3.py
# ---------------------------------------------------------------------------

invariant pathlib_extra268.PurePath.name_attr:
  description: "PurePath('/usr/local/bin/python3.py').name == 'python3.py'"
  category: identity
  kind: python_call_eq
  function: PurePath
  args: ["/usr/local/bin/python3.py"]
  method: name
  expected: "python3.py"

invariant pathlib_extra268.PurePath.suffix_attr:
  description: "PurePath('/usr/local/bin/python3.py').suffix == '.py'"
  category: identity
  kind: python_call_eq
  function: PurePath
  args: ["/usr/local/bin/python3.py"]
  method: suffix
  expected: ".py"

invariant pathlib_extra268.PurePath.stem_attr:
  description: "PurePath('/usr/local/bin/python3.py').stem == 'python3'"
  category: identity
  kind: python_call_eq
  function: PurePath
  args: ["/usr/local/bin/python3.py"]
  method: stem
  expected: "python3"

# ---------------------------------------------------------------------------
# PurePath.parent — class identity of returned object
# ---------------------------------------------------------------------------

invariant pathlib_extra268.PurePath.parent_class:
  description: "PurePath('/usr/local/bin/python3.py').parent.__class__.__name__ == 'PurePosixPath' on POSIX"
  category: identity
  kind: python_call_eq
  function: PurePath
  args: ["/usr/local/bin/python3.py"]
  method: parent
  method_chain: __class__
  method_chain2: __name__
  expected: "PurePosixPath"

# ---------------------------------------------------------------------------
# PurePath.parts — tuple identity and first element
# ---------------------------------------------------------------------------

invariant pathlib_extra268.PurePath.parts_class:
  description: "PurePath('/usr/local/bin/python3.py').parts.__class__.__name__ == 'tuple'"
  category: identity
  kind: python_call_eq
  function: PurePath
  args: ["/usr/local/bin/python3.py"]
  method: parts
  method_chain: __class__
  method_chain2: __name__
  expected: "tuple"

invariant pathlib_extra268.PurePath.parts_root:
  description: "PurePath('/usr/local/bin/python3.py').parts[0] == '/' — root element of absolute path"
  category: identity
  kind: python_call_eq
  function: PurePath
  args: ["/usr/local/bin/python3.py"]
  method: parts
  method_chain: __getitem__
  method_chain_args: [0]
  expected: "/"

# ---------------------------------------------------------------------------
# pathlib.Path.cwd — classmethod identity
# ---------------------------------------------------------------------------

invariant pathlib_extra268.Path.cwd.type_name:
  description: "type(pathlib.Path.cwd).__name__ == 'method' — cwd is a classmethod"
  category: identity
  kind: python_call_eq
  function: Path.cwd.__class__.__name__.__eq__
  args: ["method"]
  expected: true

invariant pathlib_extra268.Path.cwd.func_qualname:
  description: "pathlib.Path.cwd.__func__.__qualname__ == 'Path.cwd'"
  category: identity
  kind: python_call_eq
  function: Path.cwd.__func__.__qualname__.__eq__
  args: ["Path.cwd"]
  expected: true

# ---------------------------------------------------------------------------
# pathlib.Path.home — classmethod identity
# ---------------------------------------------------------------------------

invariant pathlib_extra268.Path.home.type_name:
  description: "type(pathlib.Path.home).__name__ == 'method' — home is a classmethod"
  category: identity
  kind: python_call_eq
  function: Path.home.__class__.__name__.__eq__
  args: ["method"]
  expected: true

invariant pathlib_extra268.Path.home.func_qualname:
  description: "pathlib.Path.home.__func__.__qualname__ == 'Path.home'"
  category: identity
  kind: python_call_eq
  function: Path.home.__func__.__qualname__.__eq__
  args: ["Path.home"]
  expected: true
