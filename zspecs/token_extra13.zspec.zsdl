spec: token_extra13
version: ">=3.9"
backend: python_module(token)

docs: https://docs.python.org/3/library/token.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/token.html — Python token module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/token.py"
    - "token_extra12.zspec.zsdl — covers ENCODING/NL/ERRORTOKEN/INDENT/DEDENT/LPAR/RPAR __class__.__name__=='int' standalone; COMMENT/INDENT/DEDENT/LPAR/RPAR exact values"
    - "token_extra11.zspec.zsdl — covers tok_name.__len__()==71; EXACT_TOKEN_TYPES.__len__()==48; exact values for ENDMARKER/NAME/NUMBER/STRING/NEWLINE/OP (table)"
    - "token_extra10.zspec.zsdl — covers NAME/NUMBER/STRING/OP/NEWLINE/ENDMARKER/INDENT/DEDENT/COMMENT/ENCODING/NL/ERRORTOKEN __class__.__name__=='int' (table)"
    - "token_extra9.zspec.zsdl — covers tok_name/EXACT_TOKEN_TYPES __class__.__name__=='dict'; ISEOF/ISTERMINAL/ISNONTERMINAL __qualname__; tok_name indices 11-16; EXACT_TOKEN_TYPES exact values"
    - "token_extra4.zspec.zsdl — covers INDENT==5/DEDENT==6 exact values"
    - "token_extra2.zspec.zsdl — covers ERRORTOKEN/__class__.__name__=='int' standalone; ENCODING/__class__.__name__=='int' standalone"
    - "token_extra.zspec.zsdl — covers int type checks for major constants; tok_name/EXACT_TOKEN_TYPES is_dict; NAME/NUMBER/STRING/NEWLINE/ENDMARKER exact values"
  notes:
    - "This spec extends token_extra12.zspec.zsdl."
    - "Focus: standalone __class__.__name__=='int' invariants for NAME, NUMBER, STRING, ENDMARKER, NEWLINE, OP in the token_extra13 namespace; tok_name/__class__.__name__=='dict' and EXACT_TOKEN_TYPES/__class__.__name__=='dict' standalone in token_extra13 namespace."
    - "token.NAME.__class__.__name__ == 'int' — token_extra10 covers NAME in a class-name table; distinct standalone invariant in token_extra13 namespace."
    - "token.NUMBER.__class__.__name__ == 'int' — token_extra10 covers NUMBER in a class-name table; distinct standalone invariant in token_extra13 namespace."
    - "token.STRING.__class__.__name__ == 'int' — token_extra10 covers STRING in a class-name table; distinct standalone invariant in token_extra13 namespace."
    - "token.ENDMARKER.__class__.__name__ == 'int' — token_extra10 covers ENDMARKER in a class-name table; distinct standalone invariant in token_extra13 namespace."
    - "token.NEWLINE.__class__.__name__ == 'int' — token_extra10 covers NEWLINE in a class-name table; distinct standalone invariant in token_extra13 namespace."
    - "token.OP.__class__.__name__ == 'int' — token_extra10 covers OP in a class-name table; distinct standalone invariant in token_extra13 namespace."
    - "token.tok_name.__class__.__name__ == 'dict' — token_extra9 covers this in its namespace; distinct standalone invariant in token_extra13 namespace."
    - "token.EXACT_TOKEN_TYPES.__class__.__name__ == 'dict' — token_extra9 covers this in its namespace; distinct standalone invariant in token_extra13 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Core token constant __class__.__name__ == 'int' — standalone invariants
# (token_extra13 namespace)
#
# token_extra10 covers all six of these in a single table.
# These are distinct standalone invariants in the token_extra13 namespace.
# NAME=1, NUMBER=2, STRING=3, ENDMARKER=0, NEWLINE=4, OP=55.
# ---------------------------------------------------------------------------

invariant token_extra13.NAME.class_is_int:
  description: "token.NAME.__class__.__name__ == 'int' — NAME constant is a plain integer"
  category: class_names
  kind: python_call_eq
  function: NAME.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant token_extra13.NUMBER.class_is_int:
  description: "token.NUMBER.__class__.__name__ == 'int' — NUMBER constant is a plain integer"
  category: class_names
  kind: python_call_eq
  function: NUMBER.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant token_extra13.STRING.class_is_int:
  description: "token.STRING.__class__.__name__ == 'int' — STRING constant is a plain integer"
  category: class_names
  kind: python_call_eq
  function: STRING.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant token_extra13.ENDMARKER.class_is_int:
  description: "token.ENDMARKER.__class__.__name__ == 'int' — ENDMARKER constant is a plain integer"
  category: class_names
  kind: python_call_eq
  function: ENDMARKER.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant token_extra13.NEWLINE.class_is_int:
  description: "token.NEWLINE.__class__.__name__ == 'int' — NEWLINE constant is a plain integer"
  category: class_names
  kind: python_call_eq
  function: NEWLINE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant token_extra13.OP.class_is_int:
  description: "token.OP.__class__.__name__ == 'int' — OP constant is a plain integer"
  category: class_names
  kind: python_call_eq
  function: OP.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# tok_name and EXACT_TOKEN_TYPES __class__.__name__ == 'dict'
# (token_extra13 namespace)
#
# token_extra9 covers tok_name/__class__.__name__=='dict' and
# EXACT_TOKEN_TYPES/__class__.__name__=='dict' in that namespace.
# These are distinct standalone invariants in the token_extra13 namespace.
# tok_name maps token codes (int) to string names; EXACT_TOKEN_TYPES maps
# exact operator strings to token codes.
# ---------------------------------------------------------------------------

invariant token_extra13.tok_name.class_is_dict:
  description: "token.tok_name.__class__.__name__ == 'dict' — tok_name is a plain dict mapping token codes to names"
  category: class_names
  kind: python_call_eq
  function: tok_name.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant token_extra13.EXACT_TOKEN_TYPES.class_is_dict:
  description: "token.EXACT_TOKEN_TYPES.__class__.__name__ == 'dict' — EXACT_TOKEN_TYPES maps operator strings to token codes"
  category: class_names
  kind: python_call_eq
  function: EXACT_TOKEN_TYPES.__class__.__name__.__eq__
  args: ["dict"]
  expected: true
