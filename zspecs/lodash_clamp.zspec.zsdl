spec: lodash_clamp
version: ">=4.0.0"
backend: node(lodash.clamp)

docs: https://lodash.com/docs/#clamp

provenance:
  derived_from:
    - "lodash.clamp README — https://www.npmjs.com/package/lodash.clamp"
    - "Test vectors verified with lodash.clamp@4.0.3 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.clamp exports the _.clamp function directly as module.exports."
    - "clamp(number, lower, upper) clamps number within the inclusive range [lower, upper]."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number clamped to [lower, upper]."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_clamp.clamp:
  kind: node_module_call_eq
  function: ~
  category: clamp
  id_prefix: lclamp

  columns: [id, args, expected]
  rows:
    - [in_range,    [5, 1, 10],   5]
    - [below_min,   [0, 1, 10],   1]
    - [above_max,   [15, 1, 10],  10]
    - [at_min,      [1, 1, 10],   1]
    - [at_max,      [10, 1, 10],  10]

