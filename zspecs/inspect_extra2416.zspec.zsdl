    - ["in2416008", "inspect.Traceback.__dict__.__contains__", ["__iter__"], false]
    - ["in2416009", "inspect.ArgInfo.__dict__.__contains__", ["__iter__"], false]
    - ["in2416010", "inspect.FullArgSpec.__dict__.__contains__", ["__iter__"], false]

# ===
# Table 4: __next__ not in class __dict__ for named-tuple-derived inspect types
# ===

table inspect_extra2416.namedtuple_next_not_in_dict:
  description: "inspect named-tuple types do not define __next__ in their own __dict__"
