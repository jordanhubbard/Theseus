spec: inspect_extra2416
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/inspect.html"
    - "CPython source — Lib/inspect.py"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 608 (_extra2416): __iter__ and __next__ dict-presence and type classification."
    - "inspect.Parameter, inspect.Signature, and inspect.BoundArguments are NOT iterable."
    - "None of these classes define __iter__ or __next__ in their own __dict__."
    - "inspect.Signature does NOT implement __iter__ despite holding an ordered mapping of parameters."
    - "inspect.BoundArguments does NOT implement __iter__ despite wrapping positional and keyword args."
    - "inspect.FrameInfo, inspect.Traceback, inspect.ArgInfo, and inspect.FullArgSpec also have no iter."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ===
# Table 1: __iter__ not in class __dict__ for core inspect introspection types
# ===

table inspect_extra2416.iter_not_in_dict:
  description: "__iter__ is absent from __dict__ for inspect.Parameter, Signature, and BoundArguments"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2416
  columns: [id, function, args, expected]
  rows:
    - ["in2416001", "inspect.Parameter.__dict__.__contains__", ["__iter__"], false]
    - ["in2416002", "inspect.Signature.__dict__.__contains__", ["__iter__"], false]
    - ["in2416003", "inspect.BoundArguments.__dict__.__contains__", ["__iter__"], false]

# ===
# Table 2: __next__ not in class __dict__ for core inspect introspection types
# ===

table inspect_extra2416.next_not_in_dict:
  description: "__next__ is absent from __dict__ for inspect.Parameter, Signature, and BoundArguments"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2416
  columns: [id, function, args, expected]
  rows:
    - ["in2416004", "inspect.Parameter.__dict__.__contains__", ["__next__"], false]
    - ["in2416005", "inspect.Signature.__dict__.__contains__", ["__next__"], false]
    - ["in2416006", "inspect.BoundArguments.__dict__.__contains__", ["__next__"], false]

# ===
