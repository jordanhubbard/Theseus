spec: jmespath
version: ">=0.15.0"
backend: node(jmespath)

docs: https://www.npmjs.com/package/jmespath

provenance:
  derived_from:
    - "jmespath README — https://www.npmjs.com/package/jmespath"
    - "Test vectors verified with jmespath via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "jmespath source"
  notes:
    - "jmespath is an npm package. Install: npm install jmespath"
    - "jmespath.search(data, expression) queries a JSON data structure with a JMESPath expression."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns queried value."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table jmespath.search:
  kind: node_module_call_eq
  function: search
  category: query
  id_prefix: jmepath

  columns: [id, args, expected]
  rows:
    - [wildcard, [{"locations": [{"name": "Seattle", "state": "WA"},
                                  {"name": "Portland", "state": "OR"}]},
                  "locations[*].name"],
       ["Seattle", "Portland"]]
    - [index,    [{"locations": [{"name": "Seattle"},{"name": "Portland"}]},
                  "locations[0].name"],
       "Seattle"]
    - [nested,   [{"foo": {"bar": "baz"}}, "foo.bar"],  "baz"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T19:42:56Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
