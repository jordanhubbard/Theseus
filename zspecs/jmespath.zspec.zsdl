spec: jmespath
version: ">=0.15.0"
backend: node(jmespath)

docs: https://jmespath.org/

provenance:
  derived_from:
    - "JMESPath specification — https://jmespath.org/specification.html"
    - "jmespath README — https://www.npmjs.com/package/jmespath"
    - "Test vectors verified with jmespath@0.16.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "jmespath source"
  notes:
    - "jmespath exports {search} named function."
    - "search(data, expression) queries JSON data using JMESPath expression."
    - "Field access, array indexing, wildcard projections, and filters are supported."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns queried value or null if not found."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table jmespath.search:
  kind: node_module_call_eq
  function: search
  category: search
  id_prefix: jmes

  columns: [id, args, expected]
  rows:
    - [field,      [{"a": {"b": 1}}, "a.b"],             1]
    - [index,      [{"a": [10, 20, 30]}, "a[1]"],        20]
    - [wildcard,   [{"a": [{"n": 1}, {"n": 2}]}, "a[*].n"], [1, 2]]
    - [filter,     [{"a": [{"n": 1}, {"n": 2}, {"n": 3}]}, "a[?n > `1`].n"], [2, 3]]
    - [literal,    [{"a": 1}, "b"],                      null]
