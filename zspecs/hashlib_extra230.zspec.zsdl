spec: hashlib_extra230
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha2module.c"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.md5().digest_size == 16 — MD5 produces a 128-bit/16-byte digest."
    - "hashlib.sha1().digest_size == 20 — SHA-1 produces a 160-bit/20-byte digest."
    - "hashlib.sha256().digest_size == 32 — SHA-256 produces a 256-bit/32-byte digest."
    - "hashlib.sha512().digest_size == 64 — SHA-512 produces a 512-bit/64-byte digest."
    - "hashlib.sha224().digest_size == 28 — SHA-224 produces a 224-bit/28-byte digest."
    - "hashlib.sha384().digest_size == 48 — SHA-384 produces a 384-bit/48-byte digest."
    - "'md5' in hashlib.algorithms_guaranteed == True — md5 is guaranteed on all Python platforms."
    - "'sha256' in hashlib.algorithms_guaranteed == True — sha256 is guaranteed on all Python platforms."
    - "hashlib.md5().block_size == 64 — MD5 internal block size is 512 bits/64 bytes."
    - "hashlib.sha256().block_size == 64 — SHA-256 internal block size is 512 bits/64 bytes."
    - "hashlib.sha512().block_size == 128 — SHA-512 internal block size is 1024 bits/128 bytes."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib algorithm digest_size contracts
#
# hashlib.md5().digest_size    == 16
# hashlib.sha1().digest_size   == 20
# hashlib.sha256().digest_size == 32
# hashlib.sha512().digest_size == 64
# hashlib.sha224().digest_size == 28
# hashlib.sha384().digest_size == 48
#
# The digest_size attribute is the number of bytes in the hash output.
# These values are fixed by the respective algorithm specifications.
# ---------------------------------------------------------------------------

table hashlib_extra230.digest_sizes:
  description: "md5/sha1/sha256/sha512/sha224/sha384 digest_size values; fixed by algorithm spec; new to extra230"
  kind: python_call_eq
  category: identity
  id_prefix: hashlib230

  columns: [id, function, args, expected, description]
  rows:
    - [md5_digest_size_16,
       "md5().digest_size.__eq__",
       [16],
       true,
       "hashlib.md5().digest_size.__eq__(16) == True — MD5 produces a 128-bit digest (16 bytes); digest_size is fixed by RFC 1321; new anchor in extra230 namespace; verified Python 3.14.3"]
    - [sha1_digest_size_20,
       "sha1().digest_size.__eq__",
       [20],
       true,
       "hashlib.sha1().digest_size.__eq__(20) == True — SHA-1 produces a 160-bit digest (20 bytes); digest_size fixed by FIPS PUB 180-4; new anchor in extra230 namespace; verified Python 3.14.3"]
    - [sha256_digest_size_32,
       "sha256().digest_size.__eq__",
       [32],
       true,
       "hashlib.sha256().digest_size.__eq__(32) == True — SHA-256 produces a 256-bit digest (32 bytes); digest_size fixed by FIPS PUB 180-4; new anchor in extra230 namespace; verified Python 3.14.3"]
    - [sha512_digest_size_64,
       "sha512().digest_size.__eq__",
       [64],
       true,
       "hashlib.sha512().digest_size.__eq__(64) == True — SHA-512 produces a 512-bit digest (64 bytes); digest_size fixed by FIPS PUB 180-4; new anchor in extra230 namespace; verified Python 3.14.3"]
    - [sha224_digest_size_28,
       "sha224().digest_size.__eq__",
       [28],
       true,
       "hashlib.sha224().digest_size.__eq__(28) == True — SHA-224 produces a 224-bit digest (28 bytes); digest_size fixed by FIPS PUB 180-4; new anchor in extra230 namespace; verified Python 3.14.3"]
    - [sha384_digest_size_48,
       "sha384().digest_size.__eq__",
       [48],
       true,
       "hashlib.sha384().digest_size.__eq__(48) == True — SHA-384 produces a 384-bit digest (48 bytes); digest_size fixed by FIPS PUB 180-4; new anchor in extra230 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# hashlib algorithms_guaranteed membership
#
# 'md5' in hashlib.algorithms_guaranteed == True
# 'sha256' in hashlib.algorithms_guaranteed == True
#
# algorithms_guaranteed is a frozenset of algorithm names available on all
# Python platforms. md5 and sha256 are guaranteed by the Python spec.
# ---------------------------------------------------------------------------

table hashlib_extra230.algorithms_guaranteed_membership:
  description: "'md5' and 'sha256' in algorithms_guaranteed; guaranteed on all Python platforms; new to extra230"
  kind: python_call_eq
  category: identity
  id_prefix: hashlib230a

  columns: [id, function, args, expected, description]
  rows:
    - [md5_in_guaranteed,
       "algorithms_guaranteed.__contains__",
       ["md5"],
       true,
       "hashlib.algorithms_guaranteed.__contains__('md5') == True — md5 is in algorithms_guaranteed; available on all Python platforms; frozenset membership; new anchor in extra230 namespace; verified Python 3.14.3"]
    - [sha256_in_guaranteed,
       "algorithms_guaranteed.__contains__",
       ["sha256"],
       true,
       "hashlib.algorithms_guaranteed.__contains__('sha256') == True — sha256 is in algorithms_guaranteed; available on all Python platforms; frozenset membership; new anchor in extra230 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# hashlib algorithm block_size contracts
#
# hashlib.md5().block_size    == 64
# hashlib.sha256().block_size == 64
# hashlib.sha512().block_size == 128
#
# The block_size attribute is the internal compression block size in bytes.
# MD5 and SHA-256 use 512-bit (64-byte) blocks; SHA-512 uses 1024-bit (128-byte).
# ---------------------------------------------------------------------------

table hashlib_extra230.block_sizes:
  description: "md5/sha256 block_size==64; sha512 block_size==128; internal compression block sizes; new to extra230"
  kind: python_call_eq
  category: identity
  id_prefix: hashlib230b

  columns: [id, function, args, expected, description]
  rows:
    - [md5_block_size_64,
       "md5().block_size.__eq__",
       [64],
       true,
       "hashlib.md5().block_size.__eq__(64) == True — MD5 uses a 512-bit/64-byte internal compression block size; block_size is fixed by RFC 1321; new anchor in extra230 namespace; verified Python 3.14.3"]
    - [sha256_block_size_64,
       "sha256().block_size.__eq__",
       [64],
       true,
       "hashlib.sha256().block_size.__eq__(64) == True — SHA-256 uses a 512-bit/64-byte internal compression block size; same as MD5 but different algorithm; new anchor in extra230 namespace; verified Python 3.14.3"]
    - [sha512_block_size_128,
       "sha512().block_size.__eq__",
       [128],
       true,
       "hashlib.sha512().block_size.__eq__(128) == True — SHA-512 uses a 1024-bit/128-byte internal compression block size; double the block size of SHA-256; new anchor in extra230 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashlib_extra230.md5_digest_size_16:
  description: "hashlib.md5().digest_size.__eq__(16) == True — MD5 produces a 128-bit digest encoded as 16 bytes; digest_size is fixed by the MD5 algorithm specification (RFC 1321); every call to hashlib.md5() creates a fresh HASH object with digest_size==16; no prior hashlib spec anchors md5().digest_size as a standalone in the extra230 namespace; first extra230 anchor; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "md5().digest_size.__eq__"
  args: [16]
  expected: true

invariant hashlib_extra230.sha256_digest_size_32:
  description: "hashlib.sha256().digest_size.__eq__(32) == True — SHA-256 produces a 256-bit digest encoded as 32 bytes; digest_size is fixed by FIPS PUB 180-4; every call to hashlib.sha256() creates a fresh HASH object with digest_size==32; no prior hashlib spec anchors sha256().digest_size as standalone in extra230 namespace; first extra230 anchor; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "sha256().digest_size.__eq__"
  args: [32]
  expected: true

invariant hashlib_extra230.sha512_block_size_128:
  description: "hashlib.sha512().block_size.__eq__(128) == True — SHA-512 uses a 1024-bit/128-byte internal compression block size; this is double the block size used by MD5 and SHA-256 (64 bytes); block_size is fixed by FIPS PUB 180-4 for SHA-512; no prior hashlib spec anchors sha512().block_size as standalone in extra230 namespace; first extra230 anchor; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "sha512().block_size.__eq__"
  args: [128]
  expected: true
