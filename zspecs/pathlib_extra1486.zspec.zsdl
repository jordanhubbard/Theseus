spec: pathlib_extra1486
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module PurePath, PurePosixPath, PureWindowsPath, Path documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "os.path source code"
  notes:
    - "Wave 546 (_extra1486): context manager protocol checks for pathlib module classes."
    - "pathlib path classes (PurePath, PurePosixPath, PureWindowsPath, Path) are NOT context managers. None define __enter__ or __exit__ in their __dict__, and hasattr checks also return False."
    - "PurePath and its subclasses are pure path manipulation classes with no file system side effects; they are not resources that need to be acquired and released."
    - "Path (concrete path) also lacks the context manager protocol even though it can open files via Path.open(); the returned file object is a context manager, but Path itself is not."
    - "pathlib.Path.__dict__.__contains__('__enter__') == False — verified with Python 3.12."
    - "pathlib.Path.__dict__.__contains__('open') == True — Path defines open() in its own __dict__; Path.open() returns a context manager, but Path itself is not one."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra1486.purepath_context_manager_protocol:
  description: "pathlib.PurePath has no context manager protocol — __enter__ and __exit__ are absent from PurePath.__dict__ and PurePath has no __enter__ attribute at all; wave 546; new to extra1486"
  kind: python_call_eq
  category: context_manager_protocol
  id_prefix: pl1486pp
  columns: [id, function, args, expected, description]
  rows:
    - [pl1486pp001,
       pathlib.PurePath.__dict__.__contains__,
       ["__enter__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__enter__') == False — PurePath is a pure path manipulation class; it does not implement the context manager protocol; __enter__ is not defined in PurePath.__dict__ and not inherited from any base class; verified with Python 3.12"]
    - [pl1486pp002,
       pathlib.PurePath.__dict__.__contains__,
       ["__exit__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__exit__') == False — PurePath does not implement __exit__ either; it cannot be used as a context manager; verified with Python 3.12"]
    - [pl1486pp003,
       pathlib.PurePath.__dict__.__contains__,
       ["name"],
       true,
       "pathlib.PurePath.__dict__.__contains__('name') == True — PurePath defines 'name' (the final path component) as a property in its own __dict__; this contrasts with __enter__/__exit__ which are absent entirely; verified with Python 3.12"]
    - [pl1486pp004,
       pathlib.PurePath.__dict__.__contains__,
       ["parent"],
       true,
       "pathlib.PurePath.__dict__.__contains__('parent') == True — PurePath defines 'parent' as a property in its own __dict__; path manipulation properties are present while context manager methods are absent; verified with Python 3.12"]
    - [pl1486pp005,
       pathlib.PurePath.__dict__.__contains__,
       ["suffix"],
       true,
       "pathlib.PurePath.__dict__.__contains__('suffix') == True — PurePath defines 'suffix' (the file extension) as a property in its own __dict__; verified with Python 3.12"]
    - [pl1486pp006,
       pathlib.PurePath.__dict__.__contains__,
       ["stem"],
       true,
       "pathlib.PurePath.__dict__.__contains__('stem') == True — PurePath defines 'stem' (the final path component without suffix) as a property in its own __dict__; path component properties are defined here while context manager protocol is not; verified with Python 3.12"]
    - [pl1486pp007,
       pathlib.PurePath.__dict__.__contains__,
       ["parts"],
       true,
       "pathlib.PurePath.__dict__.__contains__('parts') == True — PurePath defines 'parts' (a tuple of path components) as a property in its own __dict__; verified with Python 3.12"]

table pathlib_extra1486.pureposixpath_purewindowspath_context_manager_protocol:
  description: "pathlib.PurePosixPath and pathlib.PureWindowsPath have no context manager protocol — both are pure path subclasses that inherit no __enter__ or __exit__; wave 546; new to extra1486"
  kind: python_call_eq
  category: context_manager_protocol
  id_prefix: pl1486pw
  columns: [id, function, args, expected, description]
  rows:
    - [pl1486pw001,
       pathlib.PurePosixPath.__dict__.__contains__,
       ["__enter__"],
       false,
       "pathlib.PurePosixPath.__dict__.__contains__('__enter__') == False — PurePosixPath is a POSIX-specific pure path class; it does not define __enter__ in its own __dict__ and inherits no context manager support from PurePath; verified with Python 3.12"]
    - [pl1486pw002,
       pathlib.PurePosixPath.__dict__.__contains__,
       ["__exit__"],
       false,
       "pathlib.PurePosixPath.__dict__.__contains__('__exit__') == False — PurePosixPath does not define __exit__; it is not a context manager; verified with Python 3.12"]
    - [pl1486pw003,
       pathlib.PureWindowsPath.__dict__.__contains__,
       ["__enter__"],
       false,
       "pathlib.PureWindowsPath.__dict__.__contains__('__enter__') == False — PureWindowsPath is a Windows-specific pure path class; it does not define __enter__ in its own __dict__ and inherits no context manager support; verified with Python 3.12"]
    - [pl1486pw004,
       pathlib.PureWindowsPath.__dict__.__contains__,
       ["__exit__"],
       false,
       "pathlib.PureWindowsPath.__dict__.__contains__('__exit__') == False — PureWindowsPath does not implement __exit__; it is not usable as a context manager; verified with Python 3.12"]
    - [pl1486pw005,
       pathlib.PurePosixPath.__class__.__name__.__eq__,
       ["type"],
       true,
       "pathlib.PurePosixPath.__class__.__name__ == 'type' — PurePosixPath is a class object whose metaclass is the built-in type; this confirms it is a proper class despite lacking context manager support; verified with Python 3.12"]
    - [pl1486pw006,
       pathlib.PureWindowsPath.__class__.__name__.__eq__,
       ["type"],
       true,
       "pathlib.PureWindowsPath.__class__.__name__ == 'type' — PureWindowsPath is a class object whose metaclass is the built-in type; verified with Python 3.12"]

table pathlib_extra1486.path_context_manager_protocol:
  description: "pathlib.Path has no context manager protocol — Path defines no __enter__ or __exit__ in its own __dict__ and inherits none; Path.open() returns a context manager but Path itself is not one; wave 546; new to extra1486"
  kind: python_call_eq
  category: context_manager_protocol
  id_prefix: pl1486pt
  columns: [id, function, args, expected, description]
  rows:
    - [pl1486pt001,
       pathlib.Path.__dict__.__contains__,
       ["__enter__"],
       false,
       "pathlib.Path.__dict__.__contains__('__enter__') == False — Path is the concrete path class for file system operations; despite being able to open files, Path itself does not implement __enter__ and cannot be used as a context manager; verified with Python 3.12"]
    - [pl1486pt002,
       pathlib.Path.__dict__.__contains__,
       ["__exit__"],
       false,
       "pathlib.Path.__dict__.__contains__('__exit__') == False — Path does not implement __exit__; using 'with pathlib.Path(...)' directly would raise AttributeError; you must call Path.open() to get a context-manager-capable file object; verified with Python 3.12"]
    - [pl1486pt003,
       pathlib.Path.__dict__.__contains__,
       ["open"],
       true,
       "pathlib.Path.__dict__.__contains__('open') == True — Path defines 'open' in its own __dict__; Path.open() returns a file object that IS a context manager, but Path itself is not — this illustrates the distinction between having an open method and implementing the context manager protocol directly; verified with Python 3.12"]
    - [pl1486pt004,
       pathlib.Path.__dict__.__contains__,
       ["exists"],
       true,
       "pathlib.Path.__dict__.__contains__('exists') == True — Path defines 'exists' in its own __dict__; Path owns its file-system-querying methods while delegating to os.stat() under the hood; verified with Python 3.12"]
    - [pl1486pt005,
       pathlib.Path.__dict__.__contains__,
       ["stat"],
       true,
       "pathlib.Path.__dict__.__contains__('stat') == True — Path defines 'stat' in its own __dict__; like 'exists', 'stat' is a concrete file-system method, further illustrating that Path defines file-system methods but not context manager protocol methods; verified with Python 3.12"]
    - [pl1486pt006,
       pathlib.Path.__class__.__name__.__eq__,
       ["type"],
       true,
       "pathlib.Path.__class__.__name__ == 'type' — Path is a class object whose metaclass is the built-in type; verified with Python 3.12"]
