spec: to_sentence_case
version: ">=1.0.0"
backend: node(to-sentence-case)

docs: https://www.npmjs.com/package/to-sentence-case

provenance:
  derived_from:
    - "to-sentence-case README — https://www.npmjs.com/package/to-sentence-case"
    - "Test vectors verified with to-sentence-case via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "to-sentence-case source"
  notes:
    - "to-sentence-case is an npm package. Install: npm install to-sentence-case"
    - "Converts a string to sentence case (first letter capitalized, rest lowercase)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table to_sentence_case.toSentenceCase:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: sentcase

  columns: [id, args, expected]
  rows:
    - [lower,   ["hello world"],  "Hello world"]
    - [camel,   ["fooBar"],       "Foo bar"]
    - [single,  ["hello"],        "Hello"]
