spec: dot_object
version: ">=2.1.5"
backend: node(dot-object)

docs: https://www.npmjs.com/package/dot-object

provenance:
  derived_from:
    - "dot-object README — https://www.npmjs.com/package/dot-object"
    - "Test vectors verified with dot-object via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "dot-object source"
  notes:
    - "dot-object is an npm package. Install: npm install dot-object"
    - "pick(path, obj) retrieves a value from a nested object using dot-notation path."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the value at the given dot-notation path."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table dot_object.pick:
  kind: node_module_call_eq
  function: pick
  category: objects
  id_prefix: dotopick

  columns: [id, args, expected]
  rows:
    - [one_level, ["x", {"x": 99}],                   99]
    - [two_level, ["a.b", {"a": {"b": 42}}],           42]
    - [three_level, ["a.b.c", {"a": {"b": {"c": 7}}}], 7]
