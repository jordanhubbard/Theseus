spec: logging_extra
version: ">=3.2"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "Python 3 logging documentation — https://docs.python.org/3/library/logging.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
    - "logging.zspec.zsdl — covers level ordering and reverse getLevelName lookups"
    - "logging_config.zspec.zsdl — covers logging.config classes and dictConfig/fileConfig"
    - "logging_handlers.zspec.zsdl — covers logging.handlers submodule classes and port constants"
    - "logging_nullhandler.zspec.zsdl — covers NullHandler, inheritance chains, and __module__ checks"
  notes:
    - "logging.DEBUG=10, INFO=20, WARNING=30, ERROR=40, CRITICAL=50, NOTSET=0."
    - "logging.WARN=30 is a deprecated alias for WARNING; logging.FATAL=50 is a deprecated alias for CRITICAL."
    - "logging.getLevelName(int) returns the level name string; getLevelName(10) == 'DEBUG'."
    - "Manager.__name__ == 'Manager' — Manager tracks the Logger hierarchy."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Level constants — exact integer values
# ---------------------------------------------------------------------------

table logging_extra.level_values:
  kind: python_call_eq
  category: level_int
  id_prefix: level

  columns: [id, function, args, expected]
  rows:
    - [debug,    DEBUG.__eq__,    [10], true]
    - [info,     INFO.__eq__,     [20], true]
    - [warning,  WARNING.__eq__,  [30], true]
    - [error,    ERROR.__eq__,    [40], true]
    - [critical, CRITICAL.__eq__,  [50], true]
    - [notset,   NOTSET.__eq__,   [0],  true]

# Deprecated aliases
invariant logging_extra.level_values.warn_alias:
  description: "logging.WARN == 30 — deprecated alias for WARNING"
  category: level_int
  kind: python_call_eq
  function: WARN.__eq__
  args: [30]
  expected: true

invariant logging_extra.level_values.fatal_alias:
  description: "logging.FATAL == 50 — deprecated alias for CRITICAL"
  category: level_int
  kind: python_call_eq
  function: FATAL.__eq__
  args: [50]
  expected: true

# ---------------------------------------------------------------------------
# Class __name__ checks
# ---------------------------------------------------------------------------

table logging_extra.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [logger,    Logger.__name__.__eq__,    ["Logger"],    true]
    - [handler,   Handler.__name__.__eq__,   ["Handler"],   true]
    - [formatter, Formatter.__name__.__eq__,  ["Formatter"], true]
    - [filter,    Filter.__name__.__eq__,    ["Filter"],    true]
    - [logrecord, LogRecord.__name__.__eq__,  ["LogRecord"], true]
    - [manager,   Manager.__name__.__eq__,   ["Manager"],   true]

# ---------------------------------------------------------------------------
# Class __module__ checks
# ---------------------------------------------------------------------------

invariant logging_extra.class_modules.logger:
  description: "logging.Logger.__module__ == 'logging'"
  category: class_modules
  kind: python_call_eq
  function: Logger.__module__.__eq__
  args: ["logging"]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ checks
# ---------------------------------------------------------------------------

table logging_extra.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [getlogger,    getLogger.__name__.__eq__,    ["getLogger"],    true]
    - [getlevelname, getLevelName.__name__.__eq__,  ["getLevelName"], true]

# ---------------------------------------------------------------------------
# getLevelName — integer → name string (forward lookup)
# ---------------------------------------------------------------------------

table logging_extra.getLevelName.int_to_str:
  kind: python_call_eq
  category: level_name_lookup
  function: getLevelName
  id_prefix: lname

  columns: [id, args, expected]
  rows:
    - [debug_name,   [10], "DEBUG"]
    - [info_name,    [20], "INFO"]
    - [warning_name, [30], "WARNING"]
