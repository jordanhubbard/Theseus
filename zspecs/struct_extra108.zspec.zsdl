spec: struct_extra108
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra107.zspec.zsdl — covers Struct.size/format qualname equality and __objclass__ / module-level function qualnames vs descriptor qualnames (table + invariants)."
    - "struct_extra106.zspec.zsdl — covers Struct class-level method qualnames (pack, unpack, pack_into, unpack_from, iter_unpack) / Struct.__init__ is wrapper_descriptor / all five methods are method_descriptor (table + invariants)."
    - "struct_extra105.zspec.zsdl — covers struct.__spec__ attributes / struct.__name__ and __package__ equality and lengths / struct.error __init__/__str__ qualnames and types (table + invariants)."
    - "struct_extra104.zspec.zsdl — covers Struct.size/format getset_descriptor qualnames and __objclass__ / module-level function qualname equality for all six functions / iter_unpack qualname (table + invariants)."
    - "struct_extra103.zspec.zsdl — covers calcsize for compound format strings / repeat-count formats / fixed-size string formats / struct module attribute checks (table + invariants)."
    - "struct_extra102.zspec.zsdl — covers calcsize for single-char format codes and two-element composites (table + invariants)."
    - "struct_extra101.zspec.zsdl — covers struct.error class identity / Struct class attribute equality / Struct method types and instance size (table + invariants)."
    - "struct_extra100.zspec.zsdl — covers Struct instance method qualname lengths / module-level function qualname lengths (table + invariants)."
    - "struct_extra99.zspec.zsdl — covers module-level function __doc__ lengths / Struct.size/__format__ __doc__ equality (table + invariants)."
    - "struct_extra98.zspec.zsdl — covers Struct.size/__format__ getset_descriptor class names and qualnames (table + invariants)."
    - "struct_extra95.zspec.zsdl — covers pack_into/unpack_from/iter_unpack __qualname__.__len__() / Struct.__qualname__.__len__()==6 / error.__qualname__.__len__()==5 / module-level function __module__.__eq__('_struct') (table + invariants)."
  notes:
    - "This spec extends struct through struct_extra107; it does NOT duplicate invariants present in those files."
    - "Wave 272 theme: struct module-level function __name__ lengths / struct.error __name__/__module__/__qualname__ lengths and equality / struct.Struct class __name__/__module__ equality and lengths / struct.error MRO structure."
    - "struct.pack.__name__.__len__() == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__name__.__len__() == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__name__.__len__() == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__name__.__len__() == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__name__ == 'error' (5 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__module__ == 'struct' (6 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__qualname__ == 'error' (5 chars; same as __name__ because error is a top-level class). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__mro__.__len__() == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__mro__[0].__name__ == 'error'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__mro__[1].__name__ == 'Exception'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__mro__[2].__name__ == 'BaseException'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__name__ == 'Struct' (6 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__module__ == '_struct' (7 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.error.__mro__ has 4 elements: error -> Exception -> BaseException -> object. This means struct.error is a direct subclass of Exception (not ValueError or OSError). struct_extra101 anchors error class identity (__name__/__module__/__bases__[0].__name__=='Exception'); this spec anchors the MRO length and element names as a grouped table for the first time."
    - "Note: Module-level function __name__ lengths vary: pack=4, unpack=6, calcsize=8, iter_unpack=11, pack_into=9, unpack_from=11. struct_extra100 anchors qualname lengths; this spec anchors __name__ lengths (which equal the qualname values for module-level functions since qualname==name for top-level C functions)."
    - "Note: struct.Struct.__module__ is '_struct' (7 chars, with leading underscore) because Struct is implemented in the _struct C extension. This contrasts with struct.error.__module__ which is 'struct' (6 chars, no underscore) because error is defined in the Python-level struct module."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack.__name__.__len__() == 4
# struct.unpack.__name__.__len__() == 6
# struct.calcsize.__name__.__len__() == 8
# struct.iter_unpack.__name__.__len__() == 11
# struct.pack_into.__name__.__len__() == 9
#
# Wave 272 theme: struct module-level function __name__ lengths.
#
# The six module-level functions have varying name lengths:
# pack=4, unpack=6, calcsize=8, pack_into=9, unpack_from=11, iter_unpack=11.
# unpack_from and iter_unpack share the same length (11). pack_into=9 is between
# calcsize=8 and unpack_from/iter_unpack=11. struct_extra100 anchors qualname lengths
# (which equal __name__ lengths for module-level C functions). This spec anchors
# __name__ lengths explicitly using __len__() calls.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra108.module_function_name_lengths:
  description: "pack.__name__.__len__()==4 / unpack.__name__.__len__()==6 / calcsize.__name__.__len__()==8 / iter_unpack.__name__.__len__()==11 / pack_into.__name__.__len__()==9 — pack=4; unpack=6; calcsize=8; pack_into=9; iter_unpack=11; unpack_from also=11 (same as iter_unpack); extra100 anchors qualname lengths; first structfunc108 anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: structfunc108

  columns: [id, function, args, expected, description]
  rows:
    - [pack_name_len,        "pack.__name__.__len__",        [], 4,  "struct.pack.__name__.__len__() is 4 ('pack': p-a-c-k; shortest module-level function name)"]
    - [unpack_name_len,      "unpack.__name__.__len__",      [], 6,  "struct.unpack.__name__.__len__() is 6 ('unpack': u-n-p-a-c-k)"]
    - [calcsize_name_len,    "calcsize.__name__.__len__",    [], 8,  "struct.calcsize.__name__.__len__() is 8 ('calcsize': c-a-l-c-s-i-z-e)"]
    - [iter_unpack_name_len, "iter_unpack.__name__.__len__", [], 11, "struct.iter_unpack.__name__.__len__() is 11 ('iter_unpack': 11 chars; same length as unpack_from)"]
    - [pack_into_name_len,   "pack_into.__name__.__len__",   [], 9,  "struct.pack_into.__name__.__len__() is 9 ('pack_into': p-a-c-k-_-i-n-t-o; between calcsize=8 and iter_unpack=11)"]

# ---------------------------------------------------------------------------
# struct.error.__name__.__eq__('error')
# struct.error.__module__.__eq__('struct')
# struct.error.__qualname__.__eq__('error')
# struct.error.__name__.__len__() == 5
# struct.error.__module__.__len__() == 6
#
# Wave 272 theme: struct.error class __name__/__module__/__qualname__ equality and lengths.
#
# struct.error.__name__ is 'error' (5 chars: e-r-r-o-r). struct.error.__module__
# is 'struct' (6 chars: s-t-r-u-c-t). struct.error.__qualname__ is 'error' (same
# as __name__ because error is a top-level class in the struct module). The module
# 'struct' has one more char than the class name 'error' (6 vs 5). Note that
# struct.error.__module__ is 'struct' (not '_struct') because struct.error is
# the Python-level exception class defined in the struct module wrapper, not the C extension.
# struct_extra101 anchors error class identity; this spec anchors string equality and lengths.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra108.error_class_name_module_qualname_equality_and_lengths:
  description: "error.__name__.__eq__('error')==True / error.__module__.__eq__('struct')==True / error.__qualname__.__eq__('error')==True / error.__name__.__len__()==5 / error.__module__.__len__()==6 — error.__name__ is 'error' (5 chars); __module__ is 'struct' (6 chars; one more than class name); __qualname__=='error' (same as __name__; top-level class); __module__ is 'struct' not '_struct' (Python-level exception); extra101 anchors error identity; first structfunc108 anchor"
  kind: python_call_eq
  category: class_identity
  id_prefix: structfunc108

  columns: [id, function, args, expected, description]
  rows:
    - [error_name_eq,     "error.__name__.__eq__",      ["error"],  true, "struct.error.__name__ is 'error' (5 chars; e-r-r-o-r; lowercase exception class name)"]
    - [error_module_eq,   "error.__module__.__eq__",    ["struct"], true, "struct.error.__module__ is 'struct' (6 chars; Python-level struct module, not '_struct' C extension)"]
    - [error_qualname_eq, "error.__qualname__.__eq__",  ["error"],  true, "struct.error.__qualname__ is 'error' (same as __name__; top-level class not nested in another class)"]
    - [error_name_len,    "error.__name__.__len__",     [],         5,    "struct.error.__name__.__len__() is 5 ('error': e-r-r-o-r; one less than __module__ 'struct'=6)"]
    - [error_module_len,  "error.__module__.__len__",   [],         6,    "struct.error.__module__.__len__() is 6 ('struct': s-t-r-u-c-t; one more than __name__ 'error'=5)"]

# ---------------------------------------------------------------------------
# struct.error.__mro__.__len__() == 4
# struct.error.__mro__[0].__name__.__eq__('error')
# struct.error.__mro__[1].__name__.__eq__('Exception')
# struct.error.__mro__[2].__name__.__eq__('BaseException')
# struct.Struct.__name__.__eq__('Struct')
#
# Wave 272 theme: struct.error MRO structure and struct.Struct class name.
#
# struct.error.__mro__ has 4 elements: error -> Exception -> BaseException -> object.
# struct.error is a direct subclass of Exception (not ValueError or OSError).
# The MRO confirms the inheritance chain: error[0]=error, [1]=Exception,
# [2]=BaseException, [3]=object. struct.Struct.__name__ is 'Struct' (6 chars,
# capital S) — distinct from the struct module name 'struct' (lowercase s).
# struct_extra101 anchors struct.error __bases__[0].__name__=='Exception';
# this spec anchors the full MRO length and element names as a grouped table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra108.error_mro_structure_and_struct_class_name:
  description: "error.__mro__.__len__()==4 / error.__mro__[0].__name__.__eq__('error')==True / error.__mro__[1].__name__.__eq__('Exception')==True / error.__mro__[2].__name__.__eq__('BaseException')==True / Struct.__name__.__eq__('Struct')==True — error MRO: error->Exception->BaseException->object (4 elements); error is direct subclass of Exception (not ValueError or OSError); Struct.__name__ is 'Struct' (6 chars capital S); extra101 anchors error bases; first structfunc108 anchor"
  kind: python_call_eq
  category: class_identity
  id_prefix: structfunc108

  columns: [id, function, args, expected, description]
  rows:
    - [error_mro_len,      "error.__mro__.__len__",                  [],               4,    "struct.error.__mro__.__len__() is 4 (error -> Exception -> BaseException -> object)"]
    - [error_mro_0_eq,     "error.__mro__[0].__name__.__eq__",       ["error"],        true, "struct.error.__mro__[0].__name__ is 'error' (the class itself is first in its own MRO)"]
    - [error_mro_1_eq,     "error.__mro__[1].__name__.__eq__",       ["Exception"],    true, "struct.error.__mro__[1].__name__ is 'Exception' (direct base class; error is a subclass of Exception)"]
    - [error_mro_2_eq,     "error.__mro__[2].__name__.__eq__",       ["BaseException"], true, "struct.error.__mro__[2].__name__ is 'BaseException' (grandparent; Exception subclasses BaseException)"]
    - [struct_name_eq,     "Struct.__name__.__eq__",                 ["Struct"],       true, "struct.Struct.__name__ is 'Struct' (6 chars capital S; distinct from module name 'struct' lowercase s)"]

# ---------------------------------------------------------------------------
# struct.pack.__name__.__len__() == 4 — standalone
#
# struct.pack.__name__.__len__() is 4. struct.pack is a C-level function with
# __name__=='pack' (4 chars: p-a-c-k). For module-level C functions, __name__
# equals __qualname__ (no class prefix). 'pack' is the shortest function name
# among the six struct module-level functions (pack=4, unpack=6, calcsize=8,
# pack_into=9, unpack_from=11, iter_unpack=11). struct_extra100 anchors the
# qualname length (same value as name length for module-level functions);
# this spec anchors the __name__.__len__() call as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra108.pack_name_len:
  description: "struct.pack.__name__.__len__() == 4 — __name__ is 'pack' (4 chars; p-a-c-k; shortest struct module-level function name); for module-level C functions __name__==__qualname__; extra100 anchors qualname length (same value); first standalone under structfunc108"
  category: function_identity
  kind: python_call_eq
  function: "pack.__name__.__len__"
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# struct.error.__name__.__eq__('error') — standalone
#
# struct.error.__name__ is 'error'. struct.error is the exception class raised
# by struct.pack() and struct.unpack() when arguments are invalid (wrong format
# string, wrong number of arguments, wrong buffer size). The class name 'error'
# (5 chars, all lowercase) follows a Python convention of lowercase exception
# names used in some older C extension modules (os.error, socket.error, etc.).
# More modern Python exceptions use PascalCase (ValueError, TypeError, etc.).
# struct_extra101 anchors error class identity via __bases__[0].__name__;
# this spec anchors error.__name__ equality as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra108.error_name_eq:
  description: "struct.error.__name__.__eq__('error') == True — __name__ is 'error' (5 chars; e-r-r-o-r; all lowercase); raised by pack()/unpack() for invalid args; lowercase name follows older C extension module convention (cf. os.error, socket.error); modern exceptions use PascalCase; extra101 anchors error __bases__[0]; first standalone under structfunc108"
  category: class_identity
  kind: python_call_eq
  function: "error.__name__.__eq__"
  args: ["error"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__module__.__eq__('struct') — standalone
#
# struct.error.__module__ is 'struct'. The struct.error exception class is
# defined in the Python-level struct module (not in the _struct C extension).
# This means __module__=='struct' (6 chars, no leading underscore). Compare
# with struct.Struct.__module__ which is '_struct' (7 chars, with leading
# underscore) because Struct is defined in the C extension. The distinction
# struct.error/__module__=='struct' vs struct.Struct/__module__=='_struct'
# illustrates how the Python wrapper (struct.py) can define its own classes
# alongside classes imported from the C extension.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra108.error_module_eq:
  description: "struct.error.__module__.__eq__('struct') == True — __module__ is 'struct' (6 chars no underscore); error is defined in Python-level struct module (not _struct C extension); contrast with Struct.__module__=='_struct' (7 chars, with underscore); 'struct' vs '_struct' distinction shows Python wrapper vs C extension origin; first standalone under structfunc108"
  category: class_identity
  kind: python_call_eq
  function: "error.__module__.__eq__"
  args: ["struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__mro__.__len__() == 4 — standalone
#
# struct.error.__mro__.__len__() is 4. The MRO of struct.error is:
# [error, Exception, BaseException, object]. The length 4 confirms that
# struct.error has 3 ancestors (Exception, BaseException, object). This is
# the standard MRO depth for direct subclasses of Exception. In contrast,
# subclasses of more specific exceptions (like ValueError) would have MRO
# depth 5 (adding ValueError between error and Exception). struct_extra101
# anchors that struct.error.__bases__[0].__name__=='Exception'; this spec
# anchors the MRO length as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra108.error_mro_len:
  description: "struct.error.__mro__.__len__() == 4 — MRO is [error, Exception, BaseException, object] (4 elements); standard depth for direct Exception subclasses; depth 5 would indicate subclass of a more specific exception like ValueError; extra101 anchors __bases__[0].__name__=='Exception'; first standalone under structfunc108"
  category: class_identity
  kind: python_call_eq
  function: "error.__mro__.__len__"
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# struct.pack.__doc__.__class__.__name__.__eq__('str') — standalone
#
# struct.pack.__doc__.__class__.__name__ is 'str'. struct.pack is a C-level
# function that has a docstring (accessible via __doc__). The docstring is a
# Python str object. This confirms that C extension functions can have Python
# str docstrings (set via the function's PyDoc_STRVAR or the method definition's
# doc field in the C source). struct_extra99 anchors struct.pack.__doc__ length;
# this spec anchors the docstring type as 'str' via __class__.__name__ equality.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra108.pack_doc_type_str:
  description: "struct.pack.__doc__.__class__.__name__.__eq__('str') == True — C-level function has a Python str docstring; set via PyDoc_STRVAR or method definition doc field in _struct.c; C extension functions can have Python str docs; extra99 anchors __doc__ length; first standalone for __doc__ type under structfunc108"
  category: function_identity
  kind: python_call_eq
  function: "pack.__doc__.__class__.__name__.__eq__"
  args: ["str"]
  expected: true
