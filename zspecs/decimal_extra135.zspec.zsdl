# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra135.Decimal.compare_is_method_descriptor:
  description: "decimal.Decimal.compare.__class__.__name__ == 'method_descriptor' (unlike the arithmetic operators __add__/__mul__ which are wrapper_descriptor; compare is a named method exposed via the method_descriptor protocol in the C extension)"
  category: method_descriptor
  kind: python_call_eq
  function: Decimal.compare.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant decimal_extra135.Decimal.compare_qualname_len_15:
  description: "decimal.Decimal.compare.__qualname__.__len__() == 15 ('Decimal.compare' has 15 characters; compare is the IEEE 754 total-order comparison method, distinct from __lt__/__gt__ which use partial ordering)"
  category: method_descriptor
  kind: python_call_eq
  function: Decimal.compare.__qualname__.__len__
  args: []
  expected: 15

invariant decimal_extra135.Decimal.__ceil__is_method_descriptor:
  description: "decimal.Decimal.__ceil__.__class__.__name__ == 'method_descriptor' (not wrapper_descriptor; __ceil__ rounds toward positive infinity and is implemented as a named C method, distinct from slot wrappers)"
  category: method_descriptor
  kind: python_call_eq
  function: "Decimal.__ceil__.__class__.__name__.__eq__"
  args: ["method_descriptor"]
  expected: true

invariant decimal_extra135.Decimal.__ceil__qualname_len_16:
  description: "decimal.Decimal.__ceil__.__qualname__.__len__() == 16 ('Decimal.__ceil__' has 16 characters; one more than compare (15), one fewer than __floor__ (17))"
  category: method_descriptor
  kind: python_call_eq
  function: "Decimal.__ceil__.__qualname__.__len__"
  args: []
  expected: 16

invariant decimal_extra135.Decimal.__floor__qualname_len_17:
  description: "decimal.Decimal.__floor__.__qualname__.__len__() == 17 ('Decimal.__floor__' has 17 characters; the longest qualname among compare/max/min/__ceil__/__floor__ in this spec)"
  category: method_descriptor
  kind: python_call_eq
  function: "Decimal.__floor__.__qualname__.__len__"
  args: []
  expected: 17

