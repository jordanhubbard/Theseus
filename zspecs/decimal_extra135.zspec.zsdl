  notes:
    - "This spec covers: decimal.Decimal method_descriptor identity for compare, max, min, __ceil__, __floor__ — their __qualname__, __name__, __class__.__name__, and __objclass__.__name__."
    - "compare, max, min, __ceil__, __floor__ are method_descriptor instances (unlike the arithmetic operators __add__, __mul__, etc. which are wrapper_descriptor)."
    - "Decimal.compare.__qualname__ == 'Decimal.compare' (length 15); __name__ == 'compare' (7)."
    - "Decimal.max.__qualname__ == 'Decimal.max' (length 11); __name__ == 'max' (3)."
    - "Decimal.min.__qualname__ == 'Decimal.min' (length 11); __name__ == 'min' (3)."
    - "Decimal.__ceil__.__qualname__ == 'Decimal.__ceil__' (length 16); __name__ == '__ceil__' (8)."
    - "Decimal.__floor__.__qualname__ == 'Decimal.__floor__' (length 17); __name__ == '__floor__' (9)."
    - "All five methods have __objclass__.__name__ == 'Decimal' and __objclass__.__module__ == 'decimal'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal compare/max/min method_descriptor type identity
# compare, max, min are method_descriptor (not wrapper_descriptor like __add__).
# All three have __objclass__.__name__ == 'Decimal', __objclass__.__module__ == 'decimal'.
# ---------------------------------------------------------------------------

table decimal_extra135.Decimal_compare_max_min_identity:
  description: "decimal.Decimal compare/max/min method_descriptor identity: type='method_descriptor', __objclass__.__name__='Decimal', __objclass__.__module__='decimal'"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: decdec135

  columns: [id, function, args, expected]
  rows:
    - [cmp_cls_eq,      Decimal.compare.__class__.__name__.__eq__,        ["method_descriptor"], true]
    - [max_cls_eq,      Decimal.max.__class__.__name__.__eq__,            ["method_descriptor"], true]
    - [min_cls_eq,      Decimal.min.__class__.__name__.__eq__,            ["method_descriptor"], true]
    - [cmp_obj_eq,      Decimal.compare.__objclass__.__name__.__eq__,     ["Decimal"],           true]
    - [max_obj_eq,      Decimal.max.__objclass__.__name__.__eq__,         ["Decimal"],           true]
    - [min_obj_eq,      Decimal.min.__objclass__.__name__.__eq__,         ["Decimal"],           true]
    - [cmp_objmod_eq,   Decimal.compare.__objclass__.__module__.__eq__,   ["decimal"],           true]
    - [max_objmod_eq,   Decimal.max.__objclass__.__module__.__eq__,       ["decimal"],           true]
    - [min_objmod_eq,   Decimal.min.__objclass__.__module__.__eq__,       ["decimal"],           true]

