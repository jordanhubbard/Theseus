spec: multiprocessing_extra631
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers Pool, Manager, RawValue, RawArray as functions; Queue types as classes; Process doc identity"
  created_at: "2026-04-12T00:00:00Z"

table multiprocessing_extra631.pool_manager_identity:
  description: "multiprocessing Pool and Manager function class identity checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: mp631pi
  columns: [id, function, args, expected]
  rows:
    - [mp631pi001, multiprocessing.Pool.__class__.__name__.__eq__, ["function"], true]
    - [mp631pi002, multiprocessing.Pool.__name__.__eq__, ["Pool"], true]
    - [mp631pi003, multiprocessing.Manager.__class__.__name__.__eq__, ["function"], true]
    - [mp631pi004, multiprocessing.Manager.__name__.__eq__, ["Manager"], true]
    - [mp631pi005, multiprocessing.RawValue.__class__.__name__.__eq__, ["function"], true]
    - [mp631pi006, multiprocessing.RawArray.__class__.__name__.__eq__, ["function"], true]

table multiprocessing_extra631.queue_and_process_identity:
  description: "multiprocessing Queue types and Process doc identity checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: mp631mg
  columns: [id, function, args, expected]
  rows:
    - [mp631mg001, multiprocessing.Queue.__qualname__.__eq__, ["Queue"], true]
    - [mp631mg002, multiprocessing.JoinableQueue.__class__.__name__.__eq__, ["type"], true]
    - [mp631mg003, multiprocessing.JoinableQueue.__qualname__.__eq__, ["JoinableQueue"], true]
    - [mp631mg004, multiprocessing.SimpleQueue.__class__.__name__.__eq__, ["type"], true]
    - [mp631mg005, multiprocessing.SimpleQueue.__qualname__.__eq__, ["SimpleQueue"], true]
    - [mp631mg006, multiprocessing.Process.__doc__.__class__.__name__.__eq__, ["str"], true]
