spec: hashlib_extra2656
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib classes documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from: ["CPython source code"]
  notes: ["Wave 624: checks hashlib HASH (accessed via hashlib.new('sha256').__class__), blake2b, blake2s __dict__ for __contains__, __add__, __mul__ presence. All three classes return False for all three dunders — none defines __contains__, __add__, or __mul__ in its own __dict__."]
  created_at: "2026-04-13"
error_model: python_exceptions

table hashlib_extra2656.HASH_dict_presence:
  description: "hashlib HASH class (hashlib.new('sha256').__class__) __dict__ does not contain __contains__, __add__, or __mul__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl2656hd
  columns: [id, function, args, expected]
  rows:
    - ["hl2656hd001", hashlib.new("sha256").__class__.__dict__.__contains__, ["__contains__"], false]
    - ["hl2656hd002", hashlib.new("sha256").__class__.__dict__.__contains__, ["__add__"],      false]
    - ["hl2656hd003", hashlib.new("sha256").__class__.__dict__.__contains__, ["__mul__"],      false]

