spec: functools_extra2791
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "any proprietary source"
  notes:
    - "Wave 633 (_extra2791): __iand__, __ior__, and __ixor__ dict-presence checks (in-place bitwise AND &=, OR |=, XOR ^=)."
    - "functools.partial is a C-level type — no in-place bitwise operators defined."
    - "functools.partialmethod is a pure-Python class — no in-place bitwise operators defined."
    - "functools.cached_property is a pure-Python descriptor class — no in-place bitwise operators defined."
    - "functools.singledispatchmethod is a pure-Python class — no in-place bitwise operators defined."
    - "None of the functools utility types implement set/dict merge protocols; __iand__, __ior__, __ixor__ are all absent."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __iand__ dict-presence (in-place bitwise AND &=)
#
# functools.partial, partialmethod, cached_property, singledispatchmethod
# are utility wrappers — none define __iand__ in their own __dict__.
# ---------------------------------------------------------------------------

table functools_extra2791.iand_protocol:
  description: "functools types __iand__ dict-presence checks — all False (no in-place bitwise AND protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2791
  columns: [id, function, args, expected]
  rows:
    - ["ft2791001", "functools.partial.__dict__.__contains__",             ["__iand__"], false]
    - ["ft2791002", "functools.partialmethod.__dict__.__contains__",       ["__iand__"], false]
    - ["ft2791003", "functools.cached_property.__dict__.__contains__",     ["__iand__"], false]
    - ["ft2791004", "functools.singledispatchmethod.__dict__.__contains__", ["__iand__"], false]

# ---------------------------------------------------------------------------
# Table 2: __ior__ dict-presence (in-place bitwise OR |=)
#
# None of the functools types define __ior__ — these classes wrap callables
# and do not participate in set-union or dict-merge protocols.
# ---------------------------------------------------------------------------

table functools_extra2791.ior_protocol:
  description: "functools types __ior__ dict-presence checks — all False (no in-place bitwise OR / dict-merge protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2791
  columns: [id, function, args, expected]
  rows:
    - ["ft2791005", "functools.partial.__dict__.__contains__",             ["__ior__"], false]
    - ["ft2791006", "functools.partialmethod.__dict__.__contains__",       ["__ior__"], false]
    - ["ft2791007", "functools.cached_property.__dict__.__contains__",     ["__ior__"], false]
    - ["ft2791008", "functools.singledispatchmethod.__dict__.__contains__", ["__ior__"], false]

# ---------------------------------------------------------------------------
# Table 3: __ixor__ dict-presence (in-place bitwise XOR ^=)
#
# None of the functools types define __ixor__ — symmetric-difference has
# no meaning for partial application or descriptor machinery.
# ---------------------------------------------------------------------------

table functools_extra2791.ixor_protocol:
  description: "functools types __ixor__ dict-presence checks — all False (no in-place bitwise XOR / set-symmetric-difference protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2791
  columns: [id, function, args, expected]
  rows:
    - ["ft2791009", "functools.partial.__dict__.__contains__",             ["__ixor__"], false]
    - ["ft2791010", "functools.partialmethod.__dict__.__contains__",       ["__ixor__"], false]
    - ["ft2791011", "functools.cached_property.__dict__.__contains__",     ["__ixor__"], false]
    - ["ft2791012", "functools.singledispatchmethod.__dict__.__contains__", ["__ixor__"], false]

# ---------------------------------------------------------------------------
# Table 4: combined in-place bitwise operator absence — all three operators
#
# Cross-check: each type lacks all three in-place bitwise operators.
# Confirms that the functools API surface is strictly about higher-order
# function utilities, not numeric or set-theoretic in-place mutation.
# ---------------------------------------------------------------------------

table functools_extra2791.inplace_bitwise_absent:
  description: "functools types full __iand__/__ior__/__ixor__ absence cross-check — all False"
