spec: abc_extra706
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Covers ABC, ABCMeta, abstractmethod, and get_cache_token class and function identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra706.abc_class_identity:
  description: "Identity checks for abc.ABC and abc.ABCMeta class qualnames and modules"
  kind: python_call_eq
  category: class_identity
  id_prefix: ab706ci
  columns: [id, function, args, expected]
  rows:
    - [ab706ci001, abc.ABC.__qualname__.__eq__, ["ABC"], true]
    - [ab706ci002, abc.ABC.__module__.__eq__, ["abc"], true]
    - [ab706ci003, abc.ABCMeta.__qualname__.__eq__, ["ABCMeta"], true]
    - [ab706ci004, abc.ABCMeta.__module__.__eq__, ["abc"], true]
    - [ab706ci005, abc.ABCMeta.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ab706ci006, abc.ABCMeta.register.__qualname__.__eq__, ["ABCMeta.register"], true]
    - [ab706ci007, abc.ABCMeta.register.__module__.__eq__, ["abc"], true]

table abc_extra706.abstractmethod_identity:
  description: "Identity checks for abc.abstractmethod decorator qualname, module, and doc"
  kind: python_call_eq
  category: class_identity
  id_prefix: ab706am
  columns: [id, function, args, expected]
  rows:
    - [ab706am001, abc.abstractmethod.__qualname__.__eq__, ["abstractmethod"], true]
    - [ab706am002, abc.abstractmethod.__module__.__eq__, ["abc"], true]
    - [ab706am003, abc.abstractmethod.__doc__.__class__.__name__.__eq__, ["str"], true]

table abc_extra706.cache_token_identity:
  description: "Identity checks for abc.get_cache_token function qualname and module"
  kind: python_call_eq
  category: function_identity
  id_prefix: ab706ct
  columns: [id, function, args, expected]
  rows:
    - [ab706ct001, abc.get_cache_token.__qualname__.__eq__, ["get_cache_token"], true]
    - [ab706ct002, abc.get_cache_token.__module__.__eq__, ["abc"], true]
