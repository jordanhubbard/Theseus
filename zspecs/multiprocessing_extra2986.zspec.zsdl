spec: mp2986
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/multiprocessing.html"
    - "CPython docs — https://docs.python.org/3/library/multiprocessing.managers.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Wave 646 — theme: __len__, __length_hint__, __contains__ dict-presence (container/sequence protocol)."
    - "Tests operator.contains(SomeClass.__dict__, '__len__') etc. for multiprocessing classes."
    - "Classes covered: Process, pool.Pool, pool.AsyncResult, pool.MapResult, managers.SyncManager, managers.ListProxy, managers.SetProxy, managers.DictProxy, managers.BaseListProxy, managers._BaseDictProxy, managers._BaseSetProxy."
    - "Key finding: the user-facing proxy classes (ListProxy, SetProxy, DictProxy) do NOT define __len__ or __contains__ in their own __dict__ — those methods live in the private base classes (BaseListProxy, _BaseDictProxy, _BaseSetProxy)."
    - "BaseListProxy.__dict__ defines both __len__ (true) and __contains__ (true); no __length_hint__."
    - "_BaseDictProxy.__dict__ defines both __len__ (true) and __contains__ (true); no __length_hint__."
    - "_BaseSetProxy.__dict__ defines both __len__ (true) and __contains__ (true); no __length_hint__."
    - "No multiprocessing class defines __length_hint__ in its own __dict__."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __len__ dict-presence — operator.contains(Cls.__dict__, '__len__')
#
# User-facing proxy classes (ListProxy, SetProxy, DictProxy) do not define
# __len__ directly; it lives in their private base classes.
# BaseListProxy, _BaseDictProxy, _BaseSetProxy DO define __len__ (true).
# ---------------------------------------------------------------------------

table mp2986.len:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: container_len
  id_prefix: len

  columns: [id, function, args, expected]
  rows:
    - ["len_Process",        operator.contains, [Process.__dict__,                                  "__len__"], false]
    - ["len_Pool",           operator.contains, [multiprocessing.pool.Pool.__dict__,                "__len__"], false]
    - ["len_AsyncResult",    operator.contains, [multiprocessing.pool.AsyncResult.__dict__,         "__len__"], false]
    - ["len_MapResult",      operator.contains, [multiprocessing.pool.MapResult.__dict__,           "__len__"], false]
    - ["len_SyncManager",    operator.contains, [multiprocessing.managers.SyncManager.__dict__,     "__len__"], false]
    - ["len_ListProxy",      operator.contains, [multiprocessing.managers.ListProxy.__dict__,       "__len__"], false]
    - ["len_SetProxy",       operator.contains, [multiprocessing.managers.SetProxy.__dict__,        "__len__"], false]
    - ["len_DictProxy",      operator.contains, [multiprocessing.managers.DictProxy.__dict__,       "__len__"], false]
    - ["len_BaseListProxy",  operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,   "__len__"], true]
    - ["len_BaseDictProxy",  operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__,  "__len__"], true]
    - ["len_BaseSetProxy",   operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,   "__len__"], true]

# ---------------------------------------------------------------------------
# __length_hint__ dict-presence — operator.contains(Cls.__dict__, '__length_hint__')
#
# No multiprocessing class defines __length_hint__; all results are false.
# ---------------------------------------------------------------------------

table mp2986.length_hint:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: container_length_hint
  id_prefix: lh

  columns: [id, function, args, expected]
  rows:
    - ["lh_Process",        operator.contains, [Process.__dict__,                                  "__length_hint__"], false]
    - ["lh_Pool",           operator.contains, [multiprocessing.pool.Pool.__dict__,                "__length_hint__"], false]
    - ["lh_AsyncResult",    operator.contains, [multiprocessing.pool.AsyncResult.__dict__,         "__length_hint__"], false]
    - ["lh_MapResult",      operator.contains, [multiprocessing.pool.MapResult.__dict__,           "__length_hint__"], false]
    - ["lh_SyncManager",    operator.contains, [multiprocessing.managers.SyncManager.__dict__,     "__length_hint__"], false]
    - ["lh_ListProxy",      operator.contains, [multiprocessing.managers.ListProxy.__dict__,       "__length_hint__"], false]
    - ["lh_SetProxy",       operator.contains, [multiprocessing.managers.SetProxy.__dict__,        "__length_hint__"], false]
    - ["lh_DictProxy",      operator.contains, [multiprocessing.managers.DictProxy.__dict__,       "__length_hint__"], false]
    - ["lh_BaseListProxy",  operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,   "__length_hint__"], false]
    - ["lh_BaseDictProxy",  operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__,  "__length_hint__"], false]
    - ["lh_BaseSetProxy",   operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,   "__length_hint__"], false]

# ---------------------------------------------------------------------------
# __contains__ dict-presence — operator.contains(Cls.__dict__, '__contains__')
#
# User-facing proxy classes do not define __contains__ directly.
# BaseListProxy, _BaseDictProxy, _BaseSetProxy DO define __contains__ (true).
# ---------------------------------------------------------------------------

table mp2986.contains:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: container_contains
  id_prefix: con

  columns: [id, function, args, expected]
  rows:
    - ["con_Process",        operator.contains, [Process.__dict__,                                  "__contains__"], false]
    - ["con_Pool",           operator.contains, [multiprocessing.pool.Pool.__dict__,                "__contains__"], false]
    - ["con_AsyncResult",    operator.contains, [multiprocessing.pool.AsyncResult.__dict__,         "__contains__"], false]
    - ["con_MapResult",      operator.contains, [multiprocessing.pool.MapResult.__dict__,           "__contains__"], false]
    - ["con_SyncManager",    operator.contains, [multiprocessing.managers.SyncManager.__dict__,     "__contains__"], false]
    - ["con_ListProxy",      operator.contains, [multiprocessing.managers.ListProxy.__dict__,       "__contains__"], false]
    - ["con_SetProxy",       operator.contains, [multiprocessing.managers.SetProxy.__dict__,        "__contains__"], false]
    - ["con_DictProxy",      operator.contains, [multiprocessing.managers.DictProxy.__dict__,       "__contains__"], false]
    - ["con_BaseListProxy",  operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,   "__contains__"], true]
    - ["con_BaseDictProxy",  operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__,  "__contains__"], true]
    - ["con_BaseSetProxy",   operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,   "__contains__"], true]

# ---------------------------------------------------------------------------
# combined — all three operators across a cross-class sample
#
# 8 subjects x 3 operators = 24 rows.
# Focuses on the contrast between user-facing proxies (false) and their
# private base classes (true for __len__ and __contains__, false for
# __length_hint__).
# ---------------------------------------------------------------------------

