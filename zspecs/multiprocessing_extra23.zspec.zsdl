spec: multiprocessing_extra23
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "This spec extends multiprocessing.zspec.zsdl and prior extras through multiprocessing_extra22.zspec.zsdl."
    - "multiprocessing_extra21 covers: Process method qualnames (start/join/is_alive/terminate/kill) eq and length tables."
    - "multiprocessing_extra22 covers: all context-bound callable __qualname__ LENGTH tables (Queue/Pool/Lock/Event/Semaphore/etc)."
    - "NOT yet covered in any prior spec: cpu_count/__qualname__ and __module__ in extra23 namespace."
    - "NOT yet covered: active_children/__qualname__ and __module__ in extra23 namespace."
    - "NOT yet covered: current_process/__qualname__ and __module__ in extra23 namespace."
    - "NOT yet covered: Process property fget __qualname__ table (name/pid/exitcode/daemon/authkey) in extra23 namespace."
    - "NOT yet covered: Process property fget __qualname__ length table in extra23 namespace."
    - "cpu_count.__qualname__ == 'BaseContext.cpu_count' — length 21 (context-bound method)."
    - "cpu_count.__module__ == 'multiprocessing.context' — length 23."
    - "active_children.__qualname__ == 'active_children' — length 15 (module-level function)."
    - "active_children.__module__ == 'multiprocessing.process' — length 23."
    - "current_process.__qualname__ == 'current_process' — length 15 (module-level function)."
    - "current_process.__module__ == 'multiprocessing.process' — length 23."
    - "Process.name.fget.__qualname__ == 'BaseProcess.name' — inherited from BaseProcess (length 16)."
    - "Process.pid.fget.__qualname__ == 'BaseProcess.ident' — pid property delegates to ident getter (length 17)."
    - "Process.exitcode.fget.__qualname__ == 'BaseProcess.exitcode' — inherited (length 20)."
    - "Process.daemon.fget.__qualname__ == 'BaseProcess.daemon' — inherited (length 18)."
    - "Process.authkey.fget.__qualname__ == 'BaseProcess.authkey' — inherited (length 19)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level function __qualname__ table — extra23 namespace
#
# cpu_count is a context-bound method (qualname 'BaseContext.cpu_count').
# active_children and current_process are plain module-level functions
# (qualnames 'active_children' and 'current_process').
# No prior spec checks these __qualname__ values.
# ---------------------------------------------------------------------------

table multiprocessing_extra23.module_function_qualnames:
  description: "multiprocessing module-level function __qualname__ values in extra23 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: mfqn23

  columns: [id, function, args, expected]
  rows:
    - [cpu_count,       cpu_count.__qualname__.__eq__,       ["BaseContext.cpu_count"], true]
    - [active_children, active_children.__qualname__.__eq__, ["active_children"],       true]
    - [current_process, current_process.__qualname__.__eq__, ["current_process"],       true]

# ---------------------------------------------------------------------------
# Module-level function __qualname__ length table — extra23 namespace
#
# Lengths: BaseContext.cpu_count(21), active_children(15), current_process(15).
# ---------------------------------------------------------------------------

table multiprocessing_extra23.module_function_qualname_lengths:
  description: "multiprocessing module-level function __qualname__ lengths in extra23 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: mfqnlen23

  columns: [id, function, args, expected]
  rows:
    - [cpu_count,       cpu_count.__qualname__.__len__,       [], 21]
    - [active_children, active_children.__qualname__.__len__, [], 15]
    - [current_process, current_process.__qualname__.__len__, [], 15]

# ---------------------------------------------------------------------------
# Module-level function __module__ table — extra23 namespace
#
# cpu_count is defined in multiprocessing.context (length 23).
# active_children and current_process are defined in multiprocessing.process
# (length 23). No prior spec checks these __module__ values.
# ---------------------------------------------------------------------------

table multiprocessing_extra23.module_function_modules:
  description: "multiprocessing module-level function __module__ values in extra23 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: mfmod23

  columns: [id, function, args, expected]
  rows:
    - [cpu_count,       cpu_count.__module__.__eq__,       ["multiprocessing.context"], true]
    - [active_children, active_children.__module__.__eq__, ["multiprocessing.process"], true]
    - [current_process, current_process.__module__.__eq__, ["multiprocessing.process"], true]

# ---------------------------------------------------------------------------
# Process property fget __qualname__ table — extra23 namespace
#
# multiprocessing.Process inherits from BaseProcess. All property getter
# functions have __qualname__ with 'BaseProcess.' prefix — they are defined
# on BaseProcess, not on the subclass Process.
# Note: pid.fget has qualname 'BaseProcess.ident' (not 'BaseProcess.pid')
# because the underlying getter function is named ident.
# No prior spec checks these property fget qualname values.
# ---------------------------------------------------------------------------

table multiprocessing_extra23.process_property_fget_qualnames:
  description: "multiprocessing.Process property fget __qualname__ values in extra23 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: proppfqn23

  columns: [id, function, args, expected]
  rows:
    - [name,     Process.name.fget.__qualname__.__eq__,     ["BaseProcess.name"],     true]
    - [pid,      Process.pid.fget.__qualname__.__eq__,      ["BaseProcess.ident"],    true]
    - [exitcode, Process.exitcode.fget.__qualname__.__eq__, ["BaseProcess.exitcode"], true]
    - [daemon,   Process.daemon.fget.__qualname__.__eq__,   ["BaseProcess.daemon"],   true]
    - [authkey,  Process.authkey.fget.__qualname__.__eq__,  ["BaseProcess.authkey"],  true]

# ---------------------------------------------------------------------------
# Process property fget __qualname__ length table — extra23 namespace
#
# Lengths: BaseProcess.name(16), BaseProcess.ident(17), BaseProcess.exitcode(20),
#          BaseProcess.daemon(18), BaseProcess.authkey(19).
# ---------------------------------------------------------------------------

table multiprocessing_extra23.process_property_fget_qualname_lengths:
  description: "multiprocessing.Process property fget __qualname__ lengths in extra23 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: proppfqnlen23

  columns: [id, function, args, expected]
  rows:
    - [name,     Process.name.fget.__qualname__.__len__,     [], 16]
    - [pid,      Process.pid.fget.__qualname__.__len__,      [], 17]
    - [exitcode, Process.exitcode.fget.__qualname__.__len__, [], 20]
    - [daemon,   Process.daemon.fget.__qualname__.__len__,   [], 18]
    - [authkey,  Process.authkey.fget.__qualname__.__len__,  [], 19]

# ---------------------------------------------------------------------------
# cpu_count.__module__ length — standalone extra23 invariant
#
# Both cpu_count and active_children/current_process have __module__ strings
# of length 23. This standalone invariant confirms that cpu_count's module
# path ('multiprocessing.context') has 23 characters.
# No prior spec checks any __module__ length for multiprocessing functions.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra23.cpu_count.module_len:
  description: "multiprocessing.cpu_count.__module__ length == 23 — 'multiprocessing.context' has 23 characters"
  category: method_names
  kind: python_call_eq
  function: cpu_count.__module__.__len__
  args: []
  expected: 23
