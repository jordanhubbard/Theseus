spec: io_extra2536
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/io.py"
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "Theme: __format__, __bytes__, and __fspath__ dict-presence checks across io module classes."
    - "None of the io classes (BytesIO, StringIO, IOBase, RawIOBase, BufferedIOBase, BufferedReader, BufferedWriter, TextIOWrapper, FileIO) define __format__, __bytes__, or __fspath__ in their own __dict__."
    - "io classes do not implement the filesystem path protocol (__fspath__); they represent streams, not paths."
    - "io classes do not define __bytes__ for bytes conversion; BytesIO.getvalue() is used to retrieve bytes content."
    - "io classes rely on the default object.__format__ inherited from object, not a custom override."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BytesIO — __format__, __bytes__, __fspath__ dict-presence
# ---------------------------------------------------------------------------

table io_extra2536.bytesio_proto_dict:
  description: "io.BytesIO.__dict__ contains no __format__, __bytes__, or __fspath__; all __dict__.__contains__ calls return False; verified with Python 3.14.4"
  kind: python_call_eq
  category: dict_presence
  id_prefix: io2536

  columns: [id, function, args, expected]
  rows:
    - ["io2536001", io.BytesIO.__dict__.__contains__, ["__format__"], false]
    - ["io2536002", io.BytesIO.__dict__.__contains__, ["__bytes__"], false]
    - ["io2536003", io.BytesIO.__dict__.__contains__, ["__fspath__"], false]

