spec: socket_extra226
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html
rfcs:
  - "RFC 793 — Transmission Control Protocol"
  - "RFC 768 — User Datagram Protocol"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.error.__name__ == 'OSError' — socket.error is an alias for the built-in OSError; __name__ is 'OSError'."
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily' — AF_INET is an IntEnum member of AddressFamily."
    - "socket.AF_INET6.__class__.__name__ == 'AddressFamily' — AF_INET6 is an IntEnum member of AddressFamily."
    - "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' — SOCK_STREAM is an IntEnum member of SocketKind."
    - "socket.SOCK_DGRAM.__class__.__name__ == 'SocketKind' — SOCK_DGRAM is an IntEnum member of SocketKind."
    - "socket.IPPROTO_TCP.__class__.__name__ == 'int' — IPPROTO_TCP is a plain int (not an IntEnum member)."
    - "socket.IPPROTO_UDP.__class__.__name__ == 'int' — IPPROTO_UDP is a plain int (not an IntEnum member)."
    - "socket.has_ipv6 == True on modern macOS/Darwin 25.4.0 with Python 3.14.3."
    - "socket.has_ipv6.__class__.__name__ == 'bool' — has_ipv6 is a bool attribute."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.error and socket.AF_INET/__class__.__name__ checks
#
# socket.error.__name__.__eq__('OSError') == True
# socket.AF_INET.__class__.__name__.__eq__('AddressFamily') == True
# socket.AF_INET6.__class__.__name__.__eq__('AddressFamily') == True
#
# socket.error is a direct alias for the built-in OSError; its __name__ is
# 'OSError'. AF_INET and AF_INET6 are members of the AddressFamily IntEnum.
# ---------------------------------------------------------------------------

table socket_extra226.error_and_af_class_names:
  description: "error.__name__=='OSError'; AF_INET/__class__.__name__=='AddressFamily'; AF_INET6/__class__.__name__=='AddressFamily'; new to extra226"
  kind: python_call_eq
  category: identity
  id_prefix: socket226

  columns: [id, function, args, expected, description]
  rows:
    - [error_name_OSError,
       "error.__name__.__eq__",
       ["OSError"],
       true,
       "socket.error.__name__.__eq__('OSError') == True — socket.error is an alias for the built-in OSError class; __name__ is 'OSError' (not 'error'); new anchor in extra226 namespace"]
    - [AF_INET_class_AddressFamily,
       "AF_INET.__class__.__name__.__eq__",
       ["AddressFamily"],
       true,
       "socket.AF_INET.__class__.__name__.__eq__('AddressFamily') == True — AF_INET is a member of the AddressFamily IntEnum; __class__.__name__ is 'AddressFamily'; new anchor in extra226 namespace"]
    - [AF_INET6_class_AddressFamily,
       "AF_INET6.__class__.__name__.__eq__",
       ["AddressFamily"],
       true,
       "socket.AF_INET6.__class__.__name__.__eq__('AddressFamily') == True — AF_INET6 is a member of the AddressFamily IntEnum; __class__.__name__ is 'AddressFamily'; new anchor in extra226 namespace"]

# ---------------------------------------------------------------------------
# socket.SOCK_STREAM and socket.SOCK_DGRAM __class__.__name__ checks
#
# socket.SOCK_STREAM.__class__.__name__.__eq__('SocketKind') == True
# socket.SOCK_DGRAM.__class__.__name__.__eq__('SocketKind') == True
#
# SOCK_STREAM and SOCK_DGRAM are members of the SocketKind IntEnum.
# ---------------------------------------------------------------------------

table socket_extra226.sock_type_class_names:
  description: "SOCK_STREAM/__class__.__name__=='SocketKind'; SOCK_DGRAM/__class__.__name__=='SocketKind'; new to extra226"
  kind: python_call_eq
  category: identity
  id_prefix: socket226a

  columns: [id, function, args, expected, description]
  rows:
    - [SOCK_STREAM_class_SocketKind,
       "SOCK_STREAM.__class__.__name__.__eq__",
       ["SocketKind"],
       true,
       "socket.SOCK_STREAM.__class__.__name__.__eq__('SocketKind') == True — SOCK_STREAM is a member of the SocketKind IntEnum used for TCP-style stream sockets; new anchor in extra226 namespace"]
    - [SOCK_DGRAM_class_SocketKind,
       "SOCK_DGRAM.__class__.__name__.__eq__",
       ["SocketKind"],
       true,
       "socket.SOCK_DGRAM.__class__.__name__.__eq__('SocketKind') == True — SOCK_DGRAM is a member of the SocketKind IntEnum used for UDP-style datagram sockets; new anchor in extra226 namespace"]

# ---------------------------------------------------------------------------
# socket.IPPROTO_TCP and socket.IPPROTO_UDP __class__.__name__ checks
#
# socket.IPPROTO_TCP.__class__.__name__.__eq__('int') == True
# socket.IPPROTO_UDP.__class__.__name__.__eq__('int') == True
#
# Unlike AF_INET and SOCK_STREAM which are IntEnum members, IPPROTO_TCP and
# IPPROTO_UDP are plain Python ints (not IntEnum members). __class__.__name__
# is 'int', not an enum name.
# ---------------------------------------------------------------------------

table socket_extra226.ipproto_class_names:
  description: "IPPROTO_TCP/__class__.__name__=='int'; IPPROTO_UDP/__class__.__name__=='int'; plain ints not IntEnum; new to extra226"
  kind: python_call_eq
  category: identity
  id_prefix: socket226b

  columns: [id, function, args, expected, description]
  rows:
    - [IPPROTO_TCP_class_int,
       "IPPROTO_TCP.__class__.__name__.__eq__",
       ["int"],
       true,
       "socket.IPPROTO_TCP.__class__.__name__.__eq__('int') == True — IPPROTO_TCP is a plain Python int (not an IntEnum member); __class__.__name__ is 'int'; contrasts with AF_INET ('AddressFamily'); new anchor in extra226 namespace"]
    - [IPPROTO_UDP_class_int,
       "IPPROTO_UDP.__class__.__name__.__eq__",
       ["int"],
       true,
       "socket.IPPROTO_UDP.__class__.__name__.__eq__('int') == True — IPPROTO_UDP is a plain Python int (not an IntEnum member); __class__.__name__ is 'int'; contrasts with SOCK_DGRAM ('SocketKind'); new anchor in extra226 namespace"]

# ---------------------------------------------------------------------------
# socket.has_ipv6 — boolean feature flag
#
# socket.has_ipv6.__class__.__name__.__eq__('bool') == True
# socket.has_ipv6.__eq__(True) == True
#
# has_ipv6 is a boolean attribute set at Python build time indicating
# whether IPv6 support is compiled in. On modern macOS/Darwin 25.4.0 with
# Python 3.14.3, this is True.
# ---------------------------------------------------------------------------

table socket_extra226.has_ipv6_checks:
  description: "has_ipv6.__class__.__name__=='bool'; has_ipv6.__eq__(True)==True; new to extra226"
  kind: python_call_eq
  category: identity
  id_prefix: socket226c

  columns: [id, function, args, expected, description]
  rows:
    - [has_ipv6_class_bool,
       "has_ipv6.__class__.__name__.__eq__",
       ["bool"],
       true,
       "socket.has_ipv6.__class__.__name__.__eq__('bool') == True — has_ipv6 is a Python bool; __class__.__name__ is 'bool'; set at build time; new anchor in extra226 namespace"]
    - [has_ipv6_is_true,
       "has_ipv6.__eq__",
       [true],
       true,
       "socket.has_ipv6.__eq__(True) == True — IPv6 is available in this Python build on macOS/Darwin 25.4.0; bool.__eq__(True) returns True; verified Python 3.14.3; new anchor in extra226 namespace"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant socket_extra226.error_name_OSError:
  description: "socket.error.__name__.__eq__('OSError') == True — socket.error is a direct alias for the Python built-in OSError class; it is not a separate exception class; __name__ is 'OSError' (7 chars) not 'error'; socket.error is OSError returns True at the Python level; extra102/126/134/152/165/182/211 anchor this from their namespaces; first extra226 namespace anchor; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "error.__name__.__eq__"
  args: ["OSError"]
  expected: true

invariant socket_extra226.AF_INET_class_AddressFamily:
  description: "socket.AF_INET.__class__.__name__.__eq__('AddressFamily') == True — AF_INET is an IntEnum member of the AddressFamily enum defined in Lib/socket.py; __class__.__name__ is 'AddressFamily'; this distinguishes it from plain int constants like IPPROTO_TCP; extra96/123 anchor this from their namespaces; first extra226 namespace anchor; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "AF_INET.__class__.__name__.__eq__"
  args: ["AddressFamily"]
  expected: true

invariant socket_extra226.IPPROTO_TCP_class_int:
  description: "socket.IPPROTO_TCP.__class__.__name__.__eq__('int') == True — IPPROTO_TCP is a plain Python int (value 6), not an IntEnum member; its __class__.__name__ is 'int' rather than an enum name like 'AddressFamily' or 'SocketKind'; this reflects that protocol constants are not wrapped in an IntEnum in Python's socket module; extra106 anchors this from its namespace; first extra226 namespace anchor; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "IPPROTO_TCP.__class__.__name__.__eq__"
  args: ["int"]
  expected: true

invariant socket_extra226.has_ipv6_is_bool:
  description: "socket.has_ipv6.__class__.__name__.__eq__('bool') == True — has_ipv6 is a module-level bool attribute indicating whether IPv6 is compiled into the socket C extension; __class__.__name__ is 'bool'; extra13 anchors has_ipv6.__class__.__name__ from its namespace; first extra226 namespace anchor; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "has_ipv6.__class__.__name__.__eq__"
  args: ["bool"]
  expected: true
