# UUID.__eq__.__qualname__.__len__() == 11 (ties __lt__/__le__/__gt__/__ge__).
# UUID.__lt__.__qualname__.__len__() == 11 (confirmed).
# UUID.__ge__.__qualname__.__len__() == 11 (confirmed).
# No prior uuid spec anchors UUID.__eq__.__qualname__ string as a table under uuidcmp154.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra154.UUID_eq_qualname_and_comparison_lengths:
  description: "uuid.UUID.__eq__.__qualname__.__eq__('UUID.__eq__')==True / __eq__.__qualname__.__len__()==11 / __lt__.__qualname__.__len__()==11 / __ge__.__qualname__.__len__()==11 — __eq__.__qualname__ is 'UUID.__eq__' (11 chars = 'UUID.'=5 + '__eq__'=6; Python 'function'; NOT anchored by extra151 which covers only __lt__/__le__/__gt__/__ge__; first anchor for __eq__ qualname string here); __eq__.__qualname__.__len__() is 11 (all five comparison dunders tie at 11: each dunder suffix has 6 chars; 'UUID.'=5 prefix; 5+6=11); __lt__.__qualname__.__len__() is 11 (confirmed; extra151 anchors as table row; confirmed here in full 5-method group); __ge__.__qualname__.__len__() is 11 (confirmed; ties all others; length ordering: all five ==11; no variation); first uuidcmp154 anchor for __eq__ qualname and full 5-method length tie"
  kind: python_call_eq
  category: identity
  id_prefix: uuidcmp154

  columns: [id, function, args, expected, description]
  rows:
    - [eq_qualname_uuid_eq,  "__eq__.__qualname__.__eq__",  ["UUID.__eq__"], true, "uuid.UUID.__eq__.__qualname__ == 'UUID.__eq__' (11 chars = 'UUID.'=5 + '__eq__'=6; Python function; first anchor for __eq__ qualname; novel vs extra151)"]
    - [eq_qualname_len_11,   "__eq__.__qualname__.__len__", [],              11,   "uuid.UUID.__eq__.__qualname__.__len__() == 11 (ties all four: __lt__/__le__/__gt__/__ge__; all comparison dunders have 6-char names + 5-char 'UUID.' prefix)"]
    - [lt_qualname_len_11,   "__lt__.__qualname__.__len__", [],              11,   "uuid.UUID.__lt__.__qualname__.__len__() == 11 (confirmed; extra151 anchors; 'UUID.__lt__' = 'UUID.'=5 + '__lt__'=6 = 11)"]
    - [ge_qualname_len_11,   "__ge__.__qualname__.__len__", [],              11,   "uuid.UUID.__ge__.__qualname__.__len__() == 11 (confirmed; ties all five comparison dunders; '__ge__'=6 + 'UUID.'=5 = 11)"]

# ---------------------------------------------------------------------------
# uuid.UUID comparison method types (all five are 'function')
#
# Wave 344 theme: all five comparison dunders are Python 'function' type.
#
# UUID.__lt__.__class__.__name__ == 'function' (8 chars).
# UUID.__le__.__class__.__name__ == 'function' (8 chars; ties __lt__).
# UUID.__eq__.__class__.__name__ == 'function' (8 chars; ties all comparison methods).
# UUID.__ge__.__class__.__name__ == 'function' (8 chars; ties all four).
# All are 'function' because UUID is a pure Python class (not a C extension type).
# No prior uuid spec anchors UUID comparison method types as a table under uuidcmp154.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra154.UUID_comparison_method_types:
  description: "uuid.UUID.__lt__.__class__.__name__.__eq__('function')==True / __le__.__class__.__name__.__eq__('function')==True / __eq__.__class__.__name__.__eq__('function')==True / __ge__.__class__.__name__.__eq__('function')==True — all four (and __gt__) are 'function' (8 chars; pure Python function objects defined with def in Lib/uuid.py); UUID is a pure Python class so its comparison methods are 'function' not 'wrapper_descriptor' (which would be the case for C extension types); __lt__.__class__.__name__ is 'function' (8 chars; Python function); __le__.__class__.__name__ is 'function' (8 chars; ties __lt__); __eq__.__class__.__name__ is 'function' (8 chars; first __eq__ type anchor here; same type as __lt__/__le__/__gt__/__ge__); __ge__.__class__.__name__ is 'function' (8 chars; all five comparison dunders tie as 'function'); 'function' (8 chars) vs 'wrapper_descriptor' (18 chars; C extension type equivalent); first uuidcmp154 anchor for comparison method types"
  kind: python_call_eq
  category: identity
  id_prefix: uuidcmp154

  columns: [id, function, args, expected, description]
  rows:
    - [lt_class_function, "__lt__.__class__.__name__.__eq__", ["function"], true, "uuid.UUID.__lt__.__class__.__name__ == 'function' (8 chars; pure Python function; UUID is a Python class not a C type; defined with def in Lib/uuid.py)"]
    - [le_class_function, "__le__.__class__.__name__.__eq__", ["function"], true, "uuid.UUID.__le__.__class__.__name__ == 'function' (8 chars; ties __lt__; pure Python function; UUID defined in Lib/uuid.py)"]
    - [eq_class_function, "__eq__.__class__.__name__.__eq__", ["function"], true, "uuid.UUID.__eq__.__class__.__name__ == 'function' (8 chars; first __eq__ type anchor here; same type as __lt__/__le__/__gt__/__ge__; Python function)"]
    - [ge_class_function, "__ge__.__class__.__name__.__eq__", ["function"], true, "uuid.UUID.__ge__.__class__.__name__ == 'function' (8 chars; ties all others; all five comparison dunders are Python 'function' type)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__eq__.__qualname__.__eq__('UUID.__eq__') — standalone
#
# uuid.UUID.__eq__.__qualname__ is 'UUID.__eq__' (11 chars = 'UUID.'=5 + '__eq__'=6).
# uuid.UUID.__eq__ is a Python function (not a C slot wrapper). UUID is defined in
# Lib/uuid.py as a pure Python class with explicit comparison methods. __eq__ is defined
# to compare UUID instances based on their underlying integer value (UUID.int). '__eq__'
# (6 chars) has the same length as '__lt__', '__le__', '__gt__', and '__ge__' (all 6 chars),
# so 'UUID.__eq__' (11 chars) ties all four other comparison method qualnames. This is the
# first spec to anchor uuid.UUID.__eq__.__qualname__ explicitly (extra151 anchors the other
# four but not __eq__; extra147 anchors __eq__ qualname length but may not anchor the string).
# No prior uuid spec anchors UUID.__eq__.__qualname__ string as a standalone under uuidcmp154.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra154.UUID_eq_qualname_str:
  description: "uuid.UUID.__eq__.__qualname__.__eq__('UUID.__eq__') == True — 11 chars = 'UUID.'=5 + '__eq__'=6; Python 'function' (not wrapper_descriptor; UUID is pure Python class); __eq__ compares UUID instances by UUID.int value; '__eq__'=6 chars (ties '__lt__'/'__le__'/'__gt__'/'__ge__' at 6 chars each); 'UUID.__eq__' (11 chars) ties all four other comparison qualnames; extra151 anchors __lt__/__le__/__gt__/__ge__ but NOT __eq__; first uuid spec standalone for __eq__ qualname string under uuidcmp154"
  category: identity
  kind: python_call_eq
  function: __eq__.__qualname__.__eq__
  args: ["UUID.__eq__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__eq__.__qualname__.__len__()==11 — standalone
#
# uuid.UUID.__eq__.__qualname__.__len__() is 11. 'UUID.__eq__' = 'UUID.'=5 + '__eq__'=6 = 11.
# All five comparison dunders (__lt__, __le__, __gt__, __ge__, __eq__) have 11-char qualnames
# because all comparison dunder names have exactly 6 chars ('__XY__' where XY is 2 chars: lt,
# le, gt, ge, eq). The 'UUID.' prefix (5 chars) plus any 6-char dunder = 11. This creates
# a perfect tie: all five comparison method qualnames have identical length. extra147 may
# anchor __eq__ qualname length as a table row in a length comparison table. This standalone
# confirms __eq__.__qualname__.__len__() == 11 as a dedicated invariant for the full five-method
# comparison group. No prior uuid spec anchors __eq__.__qualname__.__len__() as a standalone
# under uuidcmp154. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra154.UUID_eq_qualname_len_11:
  description: "uuid.UUID.__eq__.__qualname__.__len__() == 11 — 'UUID.__eq__' = 'UUID.'=5 + '__eq__'=6 = 11; all five comparison dunders tie at 11 chars: __lt__(11), __le__(11), __gt__(11), __ge__(11), __eq__(11); '__eq__'=6 chars (same as '__lt__'/'__le__'/'__gt__'/'__ge__'); 'UUID.'=5 chars; all comparison dunder names are 2-letter abbreviations with __ prefix and __ suffix = 6 chars; length ordering: all five comparison qualnames == 11; no variation; first standalone for __eq__ qualname length under uuidcmp154"
  category: identity
  kind: python_call_eq
  function: __eq__.__qualname__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# uuid.UUID.__lt__.__class__.__name__.__eq__('function') — standalone
#
# uuid.UUID.__lt__.__class__.__name__ is 'function' (8 chars). UUID.__lt__ is a Python
# function defined in Lib/uuid.py. UUID uses functools.total_ordering or explicit comparison
# methods. In CPython, Python-defined comparison methods are 'function' type (as returned by
# type(lambda: None).__name__). This contrasts with C extension types where comparison
# methods appear as 'wrapper_descriptor' (e.g., int.__lt__.__class__.__name__ ==
# 'wrapper_descriptor'). UUID is a pure Python class so all its methods, including comparison
# dunders, are 'function' type. '__lt__.__class__.__name__ == 'function' means UUID defines
# __lt__ explicitly in Python (def __lt__(self, other): ...). No prior uuid spec anchors
# UUID.__lt__.__class__.__name__ as a standalone under uuidcmp154.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra154.UUID_lt_class_function:
  description: "uuid.UUID.__lt__.__class__.__name__.__eq__('function') == True — 'function' (8 chars); UUID is a pure Python class (Lib/uuid.py); comparison methods are Python 'function' objects (not 'wrapper_descriptor' which would indicate C slot); '__lt__' is defined with def in Lib/uuid.py; contrasts with int.__lt__.__class__.__name__=='wrapper_descriptor' (C type); all five UUID comparison dunders are 'function' (pure Python); 'function'=8 chars; no prior uuid spec anchors __lt__.__class__.__name__ as a standalone; first standalone under uuidcmp154"
  category: identity
  kind: python_call_eq
  function: __lt__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__gt__.__qualname__.__eq__('UUID.__gt__') — standalone
#
# uuid.UUID.__gt__.__qualname__ is 'UUID.__gt__' (11 chars = 'UUID.'=5 + '__gt__'=6).
# uuid.UUID.__gt__ is a Python function (same type as __lt__, __le__, __ge__, __eq__).
# '__gt__' means 'greater than': uuid_a > uuid_b calls uuid_a.__gt__(uuid_b). UUID comparison
# is based on the UUID integer value (UUID.int). '__gt__' (6 chars) = '__'=2 + 'gt'=2 + '__'=2.
# 'UUID.__gt__' (11 chars) ties all other four comparison dunder qualnames. extra151 anchors
# UUID.__gt__.__qualname__ as a table row; this standalone confirms it as a dedicated invariant
# under uuidcmp154. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra154.UUID_gt_qualname_str:
  description: "uuid.UUID.__gt__.__qualname__.__eq__('UUID.__gt__') == True — 11 chars = 'UUID.'=5 + '__gt__'=6; Python 'function'; uuid_a > uuid_b calls __gt__; comparison based on UUID.int value; '__gt__'=6 chars = '__'=2 + 'gt'=2 + '__'=2; ties all four other comparison qualnames at 11 chars; extra151 anchors __gt__ qualname as table row; this standalone provides dedicated invariant under uuidcmp154; all five comparison methods (__lt__/__le__/__gt__/__ge__/__eq__) have 11-char qualnames and 'function' type; first standalone for __gt__ qualname under uuidcmp154"
  category: identity
  kind: python_call_eq
  function: __gt__.__qualname__.__eq__
  args: ["UUID.__gt__"]
  expected: true

