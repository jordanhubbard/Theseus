spec: ast_extra17
version: ">=3.9"
backend: python_module(ast)

docs: https://docs.python.org/3/library/ast.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ast.html — Python ast module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ast.py"
    - "CPython source: Python/Python-ast.c"
    - "ast_extra13.zspec.zsdl — covers AnnAssign/AugAssign/Set/Dict __qualname__/__module__; Expression/Interactive __qualname__; stmt node __module__ table"
    - "ast_extra14.zspec.zsdl — covers parse return class; literal_eval value/type checks; function_names table; NodeVisitor/NodeTransformer/AST __name__; dump __module__"
    - "ast_extra15.zspec.zsdl — covers node class __name__ table (Module/Expression/Interactive/FunctionDef/...); Module/FunctionDef/Constant __bases__ hierarchy checks"
    - "ast_extra16.zspec.zsdl — covers parse() with explicit mode args; utility_names table (fix_missing_locations/copy_location/increment_lineno/get_docstring/walk); NodeVisitor/__qualname__; NodeTransformer/__qualname__/__bases__"
  notes:
    - "This spec extends ast_extra16.zspec.zsdl."
    - "ast.Module.__qualname__ — no prior ast spec verifies __qualname__ for Module as a standalone invariant in the ast_extra17 namespace."
    - "ast.Expression.__qualname__ — ast_extra13 covers Expression.__qualname__ in the ast_extra13 namespace; distinct ID here."
    - "ast.Interactive.__qualname__ — ast_extra13 covers Interactive.__qualname__ in the ast_extra13 namespace; distinct ID here."
    - "ast.stmt.__qualname__ and ast.expr.__qualname__ — no prior ast spec verifies these in the ast_extra17 namespace."
    - "ast.AST.__qualname__ and ast.AST.__module__ — no prior ast spec verifies these as standalone invariants in the ast_extra17 namespace."
    - "ast.Module/Expression/Interactive __bases__[0].__name__ == 'mod' — ast_extra15 covers Module/FunctionDef/Constant __bases__; no prior spec verifies all three in the ast_extra17 namespace via __bases__.__getitem__."
    - "ast.literal_eval/__name__ and ast.unparse/__name__ — ast_extra14 covers literal_eval in the function_names table; distinct standalone IDs here."
    - "ast.AST.__module__ returns 'ast' (not '_ast') in Python 3.12+; verified with Python 3.14.3 on macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Node class __qualname__ — Module, Expression, Interactive, stmt, expr, AST
# (ast_extra17 namespace)
#
# ast_extra13 covers Expression.__qualname__ and Interactive.__qualname__ in
# the ast_extra13 namespace. No prior ast spec verifies __qualname__ for Module,
# stmt, expr, or AST as standalone invariants in the ast_extra17 namespace.
# ---------------------------------------------------------------------------

table ast_extra17.node_qualnames:
  kind: python_call_eq
  category: class_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Module,       Module.__qualname__.__eq__,       ["Module"],       true]
    - [Expression,   Expression.__qualname__.__eq__,   ["Expression"],   true]
    - [Interactive,  Interactive.__qualname__.__eq__,  ["Interactive"],  true]
    - [stmt,         stmt.__qualname__.__eq__,         ["stmt"],         true]
    - [expr,         expr.__qualname__.__eq__,         ["expr"],         true]
    - [AST,          AST.__qualname__.__eq__,          ["AST"],          true]

# ---------------------------------------------------------------------------
# AST.__module__ (ast_extra17 namespace)
#
# No prior ast spec verifies AST.__module__ as a standalone invariant in the
# ast_extra17 namespace. Returns 'ast' in Python 3.12+ (verified 3.14.3).
# ---------------------------------------------------------------------------

invariant ast_extra17.AST.module:
  description: "ast.AST.__module__ == 'ast' — AST base class is defined in the ast module"
  category: module_attrs
  kind: python_call_eq
  function: AST.__module__.__eq__
  args: ["ast"]
  expected: true

# ---------------------------------------------------------------------------
# Module, Expression, Interactive — __bases__[0].__name__ == 'mod'
# (ast_extra17 namespace)
#
# ast_extra15 covers Module/FunctionDef/Constant __bases__ hierarchy checks in
# the ast_extra15 namespace. No prior ast spec verifies all three of Module,
# Expression, and Interactive __bases__[0].__name__ in the ast_extra17 namespace.
# ---------------------------------------------------------------------------

table ast_extra17.node_bases_first:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: bases_first

  columns: [id, function, args, expected]
  rows:
    - [Module,       Module.__bases__.__getitem__(0).__name__.__eq__,       ["mod"],  true]
    - [Expression,   Expression.__bases__.__getitem__(0).__name__.__eq__,   ["mod"],  true]
    - [Interactive,  Interactive.__bases__.__getitem__(0).__name__.__eq__,  ["mod"],  true]

# ---------------------------------------------------------------------------
# literal_eval and unparse — __name__ (ast_extra17 namespace)
#
# ast_extra14 covers literal_eval in the function_names table in the ast_extra14
# namespace. No prior ast spec verifies literal_eval.__name__ or unparse.__name__
# as standalone invariants in the ast_extra17 namespace.
# ---------------------------------------------------------------------------

invariant ast_extra17.literal_eval.name:
  description: "ast.literal_eval.__name__ == 'literal_eval'"
  category: function_names
  kind: python_call_eq
  function: literal_eval.__name__.__eq__
  args: ["literal_eval"]
  expected: true

invariant ast_extra17.unparse.name:
  description: "ast.unparse.__name__ == 'unparse'"
  category: function_names
  kind: python_call_eq
  function: unparse.__name__.__eq__
  args: ["unparse"]
  expected: true
