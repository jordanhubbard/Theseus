spec: pathlib_extra2596
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 pathlib documentation — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
    - "pathlib_extra.zspec.zsdl — covers existing pathlib invariants"
  notes:
    - "Wave 2596 theme: __get__/__set__/__delete__ descriptor protocol dict-presence."
    - "None of the pathlib classes define __get__, __set__, or __delete__ in their own __dict__."
    - "pathlib.Path and pathlib.PurePath are filesystem path objects, not descriptors."
    - "pathlib.PurePosixPath and pathlib.PureWindowsPath are pure-syntax path classes; none define descriptor methods."
    - "The descriptor protocol (__get__, __set__, __delete__) is for attribute-access customization — pathlib classes have no such role."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __get__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2596.no_get_in_pathlib_classes:
  description: "__get__ is absent from all pathlib class __dict__s — path objects are not descriptors"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2596

  columns: [id, function, args, expected]
  rows:
    - ["pp2596001", "pathlib.PurePath.__dict__.__contains__",        ["__get__"], false]
    - ["pp2596002", "pathlib.Path.__dict__.__contains__",            ["__get__"], false]
    - ["pp2596003", "pathlib.PurePosixPath.__dict__.__contains__",   ["__get__"], false]
    - ["pp2596004", "pathlib.PureWindowsPath.__dict__.__contains__", ["__get__"], false]

# ---------------------------------------------------------------------------
# __set__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2596.no_set_in_pathlib_classes:
  description: "__set__ is absent from all pathlib class __dict__s — path objects do not implement the data descriptor protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2596

  columns: [id, function, args, expected]
  rows:
    - ["pp2596005", "pathlib.PurePath.__dict__.__contains__",        ["__set__"], false]
    - ["pp2596006", "pathlib.Path.__dict__.__contains__",            ["__set__"], false]
    - ["pp2596007", "pathlib.PurePosixPath.__dict__.__contains__",   ["__set__"], false]
    - ["pp2596008", "pathlib.PureWindowsPath.__dict__.__contains__", ["__set__"], false]

# ---------------------------------------------------------------------------
# __delete__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2596.no_delete_in_pathlib_classes:
  description: "__delete__ is absent from all pathlib class __dict__s — path objects do not implement the deletion descriptor protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2596

  columns: [id, function, args, expected]
  rows:
    - ["pp2596009",  "pathlib.PurePath.__dict__.__contains__",        ["__delete__"], false]
    - ["pp2596010", "pathlib.Path.__dict__.__contains__",            ["__delete__"], false]
    - ["pp2596011", "pathlib.PurePosixPath.__dict__.__contains__",   ["__delete__"], false]
    - ["pp2596012", "pathlib.PureWindowsPath.__dict__.__contains__", ["__delete__"], false]

# ---------------------------------------------------------------------------
# Complementary: pathlib classes HAVE path-manipulation methods but NOT descriptor methods
# Confirms that path objects are domain-specific types, never descriptors
# ---------------------------------------------------------------------------

table pathlib_extra2596.pathlib_has_path_methods_not_descriptor:
  description: "pathlib classes define path methods (parts, name, stat, exists) but NOT __get__/__set__/__delete__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2596

  columns: [id, function, args, expected]
  rows:
    - ["pp2596013", "pathlib.PurePath.__dict__.__contains__", ["__str__"],    true]
    - ["pp2596014", "pathlib.PurePath.__dict__.__contains__", ["parts"],      true]
    - ["pp2596015", "pathlib.PurePath.__dict__.__contains__", ["name"],       true]
    - ["pp2596016", "pathlib.PurePath.__dict__.__contains__", ["parent"],     true]
    - ["pp2596017", "pathlib.PurePath.__dict__.__contains__", ["__get__"],    false]
    - ["pp2596018", "pathlib.Path.__dict__.__contains__",     ["stat"],       true]
    - ["pp2596019", "pathlib.Path.__dict__.__contains__",     ["exists"],     true]
    - ["pp2596020", "pathlib.Path.__dict__.__contains__",     ["open"],       true]
    - ["pp2596021", "pathlib.Path.__dict__.__contains__",     ["__set__"],    false]
    - ["pp2596022", "pathlib.Path.__dict__.__contains__",     ["__delete__"], false]
