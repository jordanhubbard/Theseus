spec: pathlib_extra56
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra55.zspec.zsdl — covers 12 Path method qualname lengths (open=9, read_text=14, write_text=15, read_bytes=15, write_bytes=16, mkdir=10, unlink=11, exists=11, is_file=12, is_dir=11, stat=9, rename=11)."
    - "pathlib_extra54.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath __class__.__qualname__.__eq__('type'); Path.cwd/__class__.__qualname__.__eq__('method'); Path.home/__class__.__qualname__.__eq__('method'); Path/__class__.__module__.__eq__('builtins'); PurePath/__class__.__module__.__eq__('builtins')."
    - "pathlib_extra53.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __class__.__name__.__eq__('type') and __class__.__name__.__len__()==4; Path.cwd/__class__.__name__.__eq__('method'); Path.home/__class__.__name__.__eq__('method')."
    - "pathlib_extra50.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __qualname__.__len__(); Path.cwd/__qualname__.__len__()==8; Path.home/__qualname__.__len__()==9."
    - "pathlib_extra49.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __qualname__.__eq__(); Path.cwd/__qualname__.__eq__('Path.cwd'); Path.home/__qualname__.__eq__('Path.home')."
  notes:
    - "This spec extends pathlib_extra55.zspec.zsdl."
    - "Prior specs collectively covered: all pathlib class __qualname__ equality and lengths (pathlib_extra49/pathlib_extra50); class __class__.__name__/__qualname__ equality (pathlib_extra53/pathlib_extra54); Path.cwd and Path.home __qualname__ equality and length (pathlib_extra49/pathlib_extra50) and __class__.__name__/__qualname__ equality (pathlib_extra53/pathlib_extra54); Path file-operation method __qualname__ lengths (pathlib_extra55). NO prior pathlib spec checks the __doc__ attribute of any pathlib class or the pathlib module itself, nor the type (__class__.__name__/__qualname__/__module__) of those __doc__ strings. NO prior pathlib spec checks __qualname__.__eq__() string equality for file-operation methods (pathlib_extra49 covers class-level __qualname__.__eq__ only)."
    - "This spec covers: pathlib.Path.__doc__.__class__.__name__.__eq__('str') (NOVEL — no prior pathlib spec checks Path.__doc__ or its type; novel); pathlib.PurePath.__doc__.__class__.__name__.__eq__('str') (NOVEL); pathlib.PurePosixPath.__doc__.__class__.__name__.__eq__('str') (NOVEL); pathlib.PureWindowsPath.__doc__.__class__.__name__.__eq__('str') (NOVEL); pathlib.__doc__.__class__.__name__.__eq__('str') (NOVEL — module docstring type; novel); pathlib.Path.__doc__.__class__.__qualname__.__eq__('str') (NOVEL — no prior pathlib spec checks __doc__.__class__.__qualname__; novel); pathlib.PurePath.__doc__.__class__.__qualname__.__eq__('str') (NOVEL); pathlib.__doc__.__class__.__qualname__.__eq__('str') (NOVEL); pathlib.Path.__doc__.__class__.__module__.__eq__('builtins') (NOVEL — no prior pathlib spec checks __doc__.__class__.__module__; novel); pathlib.PurePath.__doc__.__class__.__module__.__eq__('builtins') (NOVEL); pathlib.Path.open.__qualname__.__eq__('Path.open') (NOVEL — pathlib_extra49 covers class-level __qualname__.__eq__; pathlib_extra55 covers __qualname__.__len__() for open; no prior pathlib spec checks __qualname__.__eq__() for Path.open; novel); pathlib.Path.read_text.__qualname__.__eq__('Path.read_text') (NOVEL); pathlib.Path.exists.__qualname__.__eq__('Path.exists') (NOVEL)."
    - "pathlib.Path.__doc__ is a str instance. Path is a Python class in pathlib; its class docstring is a plain Python str. Therefore __doc__.__class__.__name__=='str'. No prior pathlib spec checks Path.__doc__ or its type. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__doc__.__class__.__name__ == 'str'. PurePath is a Python class; its docstring is a str. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PurePosixPath.__doc__.__class__.__name__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PureWindowsPath.__doc__.__class__.__name__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.__doc__.__class__.__name__ == 'str'. The pathlib module has a docstring; its type is str. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.__doc__.__class__.__qualname__ == 'str'. For the builtin str type, __qualname__==__name__=='str'. Novel __qualname__ path anchor for Path.__doc__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__doc__.__class__.__qualname__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.__doc__.__class__.__qualname__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.__doc__.__class__.__module__ == 'builtins'. The str type is a C-level builtin type whose __module__ is 'builtins'. Novel __module__ anchor for Path.__doc__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__doc__.__class__.__module__ == 'builtins'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.open.__qualname__.__eq__('Path.open'). pathlib_extra49 covers class-level __qualname__.__eq__; pathlib_extra55 covers Path.open.__qualname__.__len__()==9. No prior pathlib spec checks Path.open.__qualname__.__eq__(). Novel string equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.read_text.__qualname__.__eq__('Path.read_text'). Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.exists.__qualname__.__eq__('Path.exists'). Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib class __doc__.__class__.__name__ equality
#
# Every pathlib class has a docstring attribute (__doc__) that is a plain
# Python str instance. Therefore for any pathlib class C:
#
#   C.__doc__.__class__.__name__ == 'str'
#
# This covers the major pathlib classes plus the module docstring:
#
#   pathlib.Path.__doc__.__class__.__name__             == 'str'
#   pathlib.PurePath.__doc__.__class__.__name__         == 'str'
#   pathlib.PurePosixPath.__doc__.__class__.__name__    == 'str'
#   pathlib.PureWindowsPath.__doc__.__class__.__name__  == 'str'
#   pathlib.__doc__.__class__.__name__                  == 'str'
#
# No prior pathlib spec checks __doc__ or its type for any pathlib class.
# All five equality anchors are novel in the pathlib_extra56 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra56.class_doc_names:
  description: "pathlib class __doc__.__class__.__name__.__eq__('str') for Path/PurePath/PurePosixPath/PureWindowsPath/pathlib-module — every pathlib class docstring is a plain str instance; no prior pathlib spec checks __doc__ or its type for any pathlib class; all five novel equality anchors in pathlib_extra56 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibdoc56cn

  columns: [id, function, args, expected]
  rows:
    - [Path_doc_class_name,            "Path.__doc__.__class__.__name__.__eq__",            ["str"], true]
    - [PurePath_doc_class_name,        "PurePath.__doc__.__class__.__name__.__eq__",        ["str"], true]
    - [PurePosixPath_doc_class_name,   "PurePosixPath.__doc__.__class__.__name__.__eq__",   ["str"], true]
    - [PureWindowsPath_doc_class_name, "PureWindowsPath.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [module_doc_class_name,          "__doc__.__class__.__name__.__eq__",                 ["str"], true]

# ---------------------------------------------------------------------------
# pathlib class __doc__.__class__.__qualname__ equality (selected)
#
# For the builtin str type, __qualname__==__name__=='str'. Therefore:
#
#   pathlib.Path.__doc__.__class__.__qualname__    == 'str'
#   pathlib.PurePath.__doc__.__class__.__qualname__ == 'str'
#   pathlib.__doc__.__class__.__qualname__         == 'str'
#
# No prior pathlib spec checks __doc__.__class__.__qualname__ for any class.
# All three equality anchors are novel in the pathlib_extra56 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra56.class_doc_qualnames:
  description: "pathlib class __doc__.__class__.__qualname__.__eq__('str') for Path/PurePath/pathlib-module — for the builtin str type __qualname__==__name__=='str'; no prior pathlib spec checks __doc__.__class__.__qualname__ for any class; all three novel __qualname__ path anchors in pathlib_extra56 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibdoc56cq

  columns: [id, function, args, expected]
  rows:
    - [Path_doc_class_qualname,    "Path.__doc__.__class__.__qualname__.__eq__",    ["str"], true]
    - [PurePath_doc_class_qualname, "PurePath.__doc__.__class__.__qualname__.__eq__", ["str"], true]
    - [module_doc_class_qualname,  "__doc__.__class__.__qualname__.__eq__",         ["str"], true]

# ---------------------------------------------------------------------------
# pathlib class __doc__.__class__.__module__ equality (selected)
#
# The str type is a C-level builtin type whose __module__ is 'builtins'.
# Therefore for any pathlib class whose docstring is a str:
#
#   pathlib.Path.__doc__.__class__.__module__    == 'builtins'
#   pathlib.PurePath.__doc__.__class__.__module__ == 'builtins'
#
# No prior pathlib spec checks __doc__.__class__.__module__ for any class.
# Both equality anchors are novel in the pathlib_extra56 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra56.class_doc_modules:
  description: "pathlib class __doc__.__class__.__module__.__eq__('builtins') for Path/PurePath — str is a C-level builtin type whose __module__=='builtins'; no prior pathlib spec checks __doc__.__class__.__module__ for any class; both novel __module__ anchors in pathlib_extra56 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibdoc56cm

  columns: [id, function, args, expected]
  rows:
    - [Path_doc_class_module,    "Path.__doc__.__class__.__module__.__eq__",    ["builtins"], true]
    - [PurePath_doc_class_module, "PurePath.__doc__.__class__.__module__.__eq__", ["builtins"], true]

# ---------------------------------------------------------------------------
# pathlib.Path method __qualname__ string equality (selected)
#
# Path is a Python class in pathlib. Its concrete file-operation methods carry
# __qualname__ strings of the form 'Path.<methodname>'. The exact strings are:
#
#   Path.open.__qualname__      == 'Path.open'
#   Path.read_text.__qualname__ == 'Path.read_text'
#   Path.exists.__qualname__    == 'Path.exists'
#
# pathlib_extra49 covers class-level __qualname__.__eq__() (e.g. Path.__qualname__).
# pathlib_extra55 covers Path.open.__qualname__.__len__()==9 etc.
# No prior pathlib spec checks __qualname__.__eq__() for any concrete Path method.
# All three equality anchors are novel in the pathlib_extra56 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra56.path_method_qualname_eq:
  description: "pathlib.Path method __qualname__.__eq__() for open/read_text/exists — qualname strings are 'Path.<method>'; pathlib_extra49 covers class-level __qualname__.__eq__; pathlib_extra55 covers __qualname__.__len__(); no prior pathlib spec checks __qualname__.__eq__() for any concrete Path file-operation method; all three novel equality anchors in pathlib_extra56 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathlibdoc56meq

  columns: [id, function, args, expected]
  rows:
    - [Path_open_qualname_eq,      "Path.open.__qualname__.__eq__",      ["Path.open"],      true]
    - [Path_read_text_qualname_eq, "Path.read_text.__qualname__.__eq__", ["Path.read_text"], true]
    - [Path_exists_qualname_eq,    "Path.exists.__qualname__.__eq__",    ["Path.exists"],    true]
