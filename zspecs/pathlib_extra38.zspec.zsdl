spec: pathlib_extra38
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra37.zspec.zsdl — covers pathlib.__all__.__len__()==7; __all__.__class__.__name__.__len__()==4; Path/PurePath/PurePosixPath/PureWindowsPath __dict__.__class__.__name__.__len__()==12; PurePath.__reduce__.__qualname__.__len__()==19; WindowsPath.__mro__.__len__()==5; Path.iterdir/glob/rglob/resolve/absolute __qualname__.__len__()."
    - "pathlib_extra36.zspec.zsdl — covers __mro__.__len__() for PurePath/Path/PurePosixPath/PosixPath; __bases__[0].__name__.__len__() for Path/PurePosixPath; Path.rename/unlink/rmdir/chmod/symlink_to __qualname__.__len__()."
    - "pathlib_extra35.zspec.zsdl — covers __qualname__.__len__() for PosixPath/PurePosixPath/PureWindowsPath/WindowsPath; Path.open/read_text/write_text/mkdir/exists/stat __qualname__.__len__(); PosixPath/WindowsPath __module__.__len__()."
    - "pathlib_extra34.zspec.zsdl — covers __module__.__len__() for Path/PurePath/PurePosixPath/PureWindowsPath; __name__.__len__() for all six classes; __qualname__.__len__() for Path/PurePath."
    - "pathlib_extra33.zspec.zsdl — covers PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __qualname__; PosixPath/WindowsPath __bases__[0].__name__; Path/__init__/__qualname__; PurePath/__init__/__name__/__qualname__; Path/__truediv__/__name__/__qualname__."
  notes:
    - "This spec extends pathlib_extra37.zspec.zsdl."
    - "Prior specs covered: Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __name__/__module__/__qualname__ and lengths; MRO depths for PurePath/Path/PurePosixPath/PosixPath/WindowsPath; __bases__[0].__name__ for Path/PurePosixPath/PosixPath/WindowsPath; Path methods open/read_text/write_text/mkdir/exists/stat/rename/unlink/rmdir/chmod/symlink_to/iterdir/glob/rglob/resolve/absolute __qualname__.__len__(); PurePath.__reduce__.__qualname__; mappingproxy check for all four pure/concrete classes."
    - "This spec covers: PureWindowsPath.__mro__.__len__()==3; pathlib.UnsupportedOperation.__mro__.__len__()==6; PurePosixPath/__bases__[0].__name__=='PurePath'/__len__()==8; PureWindowsPath/__bases__[0].__name__=='PurePath'/__len__()==8; PosixPath/__bases__[0].__name__.__len__()==4 ('Path'); WindowsPath/__bases__[0].__name__.__len__()==4 ('Path'); Path.read_bytes/__qualname__.__len__()==15; Path.write_bytes/__qualname__.__len__()==16; Path.is_file/__qualname__.__len__()==12; Path.is_dir/__qualname__.__len__()==11; PurePath.as_posix/__qualname__.__len__()==17; PurePath.joinpath/__qualname__.__len__()==17; PurePath.with_name/__qualname__.__len__()==18; PurePath.with_suffix/__qualname__.__len__()==20."
    - "PureWindowsPath.__mro__ == [PureWindowsPath, PurePath, object] — len 3. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "pathlib.UnsupportedOperation.__mro__ has 6 entries: UnsupportedOperation -> NotImplementedError -> RuntimeError -> Exception -> BaseException -> object. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "PurePosixPath.__bases__[0].__name__ == 'PurePath' — len 8. PureWindowsPath.__bases__[0].__name__ == 'PurePath' — len 8. Both pure path variants inherit directly from PurePath. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "PosixPath.__bases__[0].__name__ == 'Path' — len 4. WindowsPath.__bases__[0].__name__ == 'Path' — len 4. Both concrete platform paths inherit directly from Path. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Path.read_bytes.__qualname__ == 'Path.read_bytes' — len 15. write_bytes == 'Path.write_bytes' — len 16. is_file == 'Path.is_file' — len 12. is_dir == 'Path.is_dir' — len 11. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "PurePath.as_posix.__qualname__ == 'PurePath.as_posix' — len 17. joinpath == 'PurePath.joinpath' — len 17. with_name == 'PurePath.with_name' — len 18. with_suffix == 'PurePath.with_suffix' — len 20. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PureWindowsPath.__mro__.__len__() and UnsupportedOperation.__mro__.__len__()
#
# pathlib_extra36 covered PurePath(3)/Path(5)/PurePosixPath(3)/PosixPath(5).
# pathlib_extra37 covered WindowsPath (also 5).
# PureWindowsPath.__mro__ == [PureWindowsPath, PurePath, object] — len 3 (NEW).
# UnsupportedOperation.__mro__ has 6 entries (NEW — no prior spec touches it).
# ---------------------------------------------------------------------------

invariant pathlib_extra38.PureWindowsPath_mro_len:
  description: "pathlib.PureWindowsPath.__mro__.__len__() == 3 — PureWindowsPath -> PurePath -> object"
  category: class_hierarchy
  kind: python_call_eq
  function: PureWindowsPath.__mro__.__len__
  args: []
  expected: 3

invariant pathlib_extra38.UnsupportedOperation_mro_len:
  description: "pathlib.UnsupportedOperation.__mro__.__len__() == 6 — UnsupportedOperation -> NotImplementedError -> RuntimeError -> Exception -> BaseException -> object"
  category: class_hierarchy
  kind: python_call_eq
  function: UnsupportedOperation.__mro__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# PurePosixPath and PureWindowsPath __bases__[0].__name__ and __len__()
#
# pathlib_extra36 covered PurePosixPath.__bases__[0].__name__.__len__() == 8.
# No prior spec checks __bases__[0].__name__ for PureWindowsPath or the
# __eq__ of PurePosixPath.__bases__[0].__name__.
# Both PurePosixPath and PureWindowsPath inherit directly from PurePath (len 8).
# ---------------------------------------------------------------------------

invariant pathlib_extra38.PurePosixPath_base_name:
  description: "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' — PurePosixPath inherits from PurePath"
  category: class_hierarchy
  kind: python_call_eq
  function: "PurePosixPath.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra38.PureWindowsPath_base_name:
  description: "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' — PureWindowsPath inherits from PurePath"
  category: class_hierarchy
  kind: python_call_eq
  function: "PureWindowsPath.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

table pathlib_extra38.pure_variant_base_name_lengths:
  description: "pathlib.PurePosixPath/PureWindowsPath __bases__[0].__name__.__len__()==8; PosixPath/WindowsPath __bases__[0].__name__.__len__()==4"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: ple38a

  columns: [id, function, args, expected, description]
  rows:
    - [PurePosixPath_base_len,
       "PurePosixPath.__bases__[0].__name__.__len__",
       [],
       8,
       "len('PurePath') == 8"]
    - [PureWindowsPath_base_len,
       "PureWindowsPath.__bases__[0].__name__.__len__",
       [],
       8,
       "len('PurePath') == 8"]
    - [PosixPath_base_len,
       "PosixPath.__bases__[0].__name__.__len__",
       [],
       4,
       "len('Path') == 4 — PosixPath inherits from Path"]
    - [WindowsPath_base_len,
       "WindowsPath.__bases__[0].__name__.__len__",
       [],
       4,
       "len('Path') == 4 — WindowsPath inherits from Path"]

# ---------------------------------------------------------------------------
# Path.read_bytes, write_bytes, is_file, is_dir __qualname__.__len__()
#
# No prior spec checks __qualname__ length for read_bytes, write_bytes, is_file, or is_dir.
# pathlib_extra35 covered read_text/write_text.
# read_bytes.__qualname__ == 'Path.read_bytes' (len 15)
# write_bytes.__qualname__ == 'Path.write_bytes' (len 16)
# is_file.__qualname__ == 'Path.is_file' (len 12)
# is_dir.__qualname__ == 'Path.is_dir' (len 11)
# ---------------------------------------------------------------------------

table pathlib_extra38.Path_io_method_qualname_lengths:
  description: "pathlib.Path read_bytes/write_bytes/is_file/is_dir __qualname__.__len__()"
  kind: python_call_eq
  category: string_lengths
  id_prefix: ple38b

  columns: [id, function, args, expected, description]
  rows:
    - [read_bytes_qualname_len,
       "Path.read_bytes.__qualname__.__len__",
       [],
       15,
       "len('Path.read_bytes') == 15"]
    - [write_bytes_qualname_len,
       "Path.write_bytes.__qualname__.__len__",
       [],
       16,
       "len('Path.write_bytes') == 16"]
    - [is_file_qualname_len,
       "Path.is_file.__qualname__.__len__",
       [],
       12,
       "len('Path.is_file') == 12"]
    - [is_dir_qualname_len,
       "Path.is_dir.__qualname__.__len__",
       [],
       11,
       "len('Path.is_dir') == 11"]

# ---------------------------------------------------------------------------
# PurePath.as_posix, joinpath, with_name, with_suffix __qualname__.__len__()
#
# No prior spec checks __qualname__ length for any PurePath method.
# Prior specs covered only Path and its subclasses' methods.
# as_posix.__qualname__ == 'PurePath.as_posix' (len 17)
# joinpath.__qualname__ == 'PurePath.joinpath' (len 17)
# with_name.__qualname__ == 'PurePath.with_name' (len 18)
# with_suffix.__qualname__ == 'PurePath.with_suffix' (len 20)
# ---------------------------------------------------------------------------

invariant pathlib_extra38.PurePath_as_posix_qualname_len:
  description: "len(pathlib.PurePath.as_posix.__qualname__) == 17 — len('PurePath.as_posix') == 17"
  category: function_qualnames
  kind: python_call_eq
  function: "PurePath.as_posix.__qualname__.__len__"
  args: []
  expected: 17

invariant pathlib_extra38.PurePath_joinpath_qualname_len:
  description: "len(pathlib.PurePath.joinpath.__qualname__) == 17 — len('PurePath.joinpath') == 17"
  category: function_qualnames
  kind: python_call_eq
  function: "PurePath.joinpath.__qualname__.__len__"
  args: []
  expected: 17

table pathlib_extra38.PurePath_method_qualname_lengths:
  description: "pathlib.PurePath.with_name/__qualname__.__len__()==18; with_suffix/__qualname__.__len__()==20"
  kind: python_call_eq
  category: string_lengths
  id_prefix: ple38c

  columns: [id, function, args, expected, description]
  rows:
    - [with_name_qualname_len,
       "PurePath.with_name.__qualname__.__len__",
       [],
       18,
       "len('PurePath.with_name') == 18"]
    - [with_suffix_qualname_len,
       "PurePath.with_suffix.__qualname__.__len__",
       [],
       20,
       "len('PurePath.with_suffix') == 20"]
