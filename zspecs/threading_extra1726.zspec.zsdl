spec: threading_extra1726
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/threading.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 562 (_extra1726): comparison/ordering protocol dict-presence checks."
    - "All threading types define no comparison operators in their own __dict__."
    - "threading.Thread.__dict__.__contains__('__lt__') is False — Thread has no ordering protocol."
    - "threading.Event.__dict__.__contains__('__lt__') is False — Event has no ordering protocol."
    - "threading.Lock.__dict__.__contains__('__lt__') is False — Lock is a C extension type with no ordering."
    - "threading.RLock.__dict__.__contains__('__lt__') is False — RLock is a C extension type with no ordering."
    - "threading.Condition.__dict__.__contains__('__lt__') is False — Condition has no ordering protocol."
    - "threading.Thread.__dict__.__contains__('__eq__') is False — Thread defines no __eq__ in its own dict."
    - "threading.Event.__dict__.__contains__('__hash__') is False — Event defines no __hash__ in its own dict."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table threading_extra1726.comparison_protocol_thread_event:
  description: "threading.Thread and threading.Event comparison protocol dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1726

  columns: [id, function, args, expected]
  rows:
    - ["th1726001", "threading.Thread.__dict__.__contains__", ["__lt__"], false]
    - ["th1726002", "threading.Thread.__dict__.__contains__", ["__le__"], false]
    - ["th1726003", "threading.Thread.__dict__.__contains__", ["__gt__"], false]
    - ["th1726004", "threading.Thread.__dict__.__contains__", ["__ge__"], false]
    - ["th1726005", "threading.Thread.__dict__.__contains__", ["__ne__"], false]
    - ["th1726006", "threading.Event.__dict__.__contains__", ["__lt__"], false]
    - ["th1726007", "threading.Event.__dict__.__contains__", ["__le__"], false]
    - ["th1726008", "threading.Event.__dict__.__contains__", ["__gt__"], false]
    - ["th1726009", "threading.Event.__dict__.__contains__", ["__ge__"], false]
    - ["th1726010", "threading.Event.__dict__.__contains__", ["__ne__"], false]

table threading_extra1726.comparison_protocol_lock_rlock_condition:
  description: "threading.Lock, threading.RLock, and threading.Condition comparison protocol dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1726

  columns: [id, function, args, expected]
  rows:
    - ["th1726011", "threading.Lock.__dict__.__contains__", ["__lt__"], false]
    - ["th1726012", "threading.Lock.__dict__.__contains__", ["__le__"], false]
    - ["th1726013", "threading.Lock.__dict__.__contains__", ["__gt__"], false]
    - ["th1726014", "threading.Lock.__dict__.__contains__", ["__ge__"], false]
    - ["th1726015", "threading.Lock.__dict__.__contains__", ["__ne__"], false]
    - ["th1726016", "threading.RLock.__dict__.__contains__", ["__lt__"], false]
    - ["th1726017", "threading.RLock.__dict__.__contains__", ["__le__"], false]
    - ["th1726018", "threading.RLock.__dict__.__contains__", ["__gt__"], false]
    - ["th1726019", "threading.RLock.__dict__.__contains__", ["__ge__"], false]
    - ["th1726020", "threading.RLock.__dict__.__contains__", ["__ne__"], false]
    - ["th1726021", "threading.Condition.__dict__.__contains__", ["__lt__"], false]
    - ["th1726022", "threading.Condition.__dict__.__contains__", ["__le__"], false]
    - ["th1726023", "threading.Condition.__dict__.__contains__", ["__gt__"], false]
