spec: multiprocessing_extra38
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Process — Process class"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/managers.py"
  notes:
    - "This spec extends multiprocessing_extra37.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', Process.__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() tables, Process method __qualname__.__len__() for start/run/join/terminate/is_alive/kill, Pool method __qualname__/__name__.__len__() tables, AuthenticationError/ProcessError/BufferTooShort __bases__[0].__name__, Process/Pool/__mro__.__len__() tables, __all__ metadata, class __dict__.__class__.__name__.__len__() tables, DefaultContext method qualname lengths, BaseProcess class metadata, cpu_count/__name__.__len__()==9, current_process/__name__.__len__()==15, active_children/__name__.__len__()==15, parent_process/__name__.__len__()==14, get_start_method/__name__.__len__()==16, pool.ApplyResult/MapResult/IMapIterator/IMapUnorderedIterator tables, Process/__name__=='Process' (extra37), Process/__module__=='multiprocessing.context' (extra37), Queue/__name__=='Queue' (extra37), Pipe/__name__=='Pipe' (extra37), Process method __qualname__.__len__() for start/join/run (extra37)."
    - "This spec covers: Process.__bases__[0].__name__=='BaseProcess'; Process.__mro__.__len__()==3; Manager.__name__=='Manager' (Manager is a bound method on DefaultContext, not a class); cpu_count.__name__=='cpu_count'; cpu_count.__module__=='multiprocessing.context' (23 chars); current_process.__name__=='current_process'; current_process.__module__=='multiprocessing.process' (23 chars); active_children.__name__=='active_children'."
    - "multiprocessing.Process.__mro__ has length 3: [Process, BaseProcess, object]. The MRO is short because Process (context-bound) extends only BaseProcess, which extends object. No intermediate mixin classes appear in the MRO."
    - "multiprocessing.Manager is a bound method (type 'method'), not a class. Manager.__name__ == 'Manager' and Manager.__module__ == 'multiprocessing.context'. It is a factory method on the default context that creates a SyncManager instance. This contrasts with Pool, Queue, etc., which are classes (not methods) exposed at the multiprocessing top level."
    - "multiprocessing.cpu_count.__module__ == 'multiprocessing.context' (23 chars). multiprocessing.current_process.__module__ == 'multiprocessing.process' (23 chars). multiprocessing.active_children.__module__ is also 'multiprocessing.process' (23 chars). The two modules share the same length (23), but differ in the final component: 'context' vs 'process'. cpu_count is provided by the context layer; current_process and active_children are implemented in the process module."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Process.__bases__[0] and __mro__ — extra38 namespace
#
# Process class hierarchy:
#   Process.__bases__[0].__name__ == 'BaseProcess' (11 chars)
#   Process.__mro__.__len__()     == 3
# The MRO is [Process, BaseProcess, object] — depth 3.
# Process inherits from BaseProcess which inherits from object; no mixins.
# Prior specs confirmed Process.__bases__[0].__name__ as a string equality in
# earlier namespaces; extra38 re-establishes it here and adds the MRO length.
# ---------------------------------------------------------------------------

table multiprocessing_extra38.process_hierarchy:
  description: "multiprocessing.Process class hierarchy in extra38 namespace — base class name and MRO depth"
  kind: python_call_eq
  category: class_names
  id_prefix: mpprochier38

  columns: [id, function, args, expected, description]
  rows:
    - [bases0_name, "Process.__bases__[0].__name__.__eq__", ["BaseProcess"], true, "Process.__bases__[0].__name__ == 'BaseProcess' — direct base class"]
    - [mro_len,     Process.__mro__.__len__,               [],              3,    "Process.__mro__.__len__() == 3 — MRO is [Process, BaseProcess, object]"]

# ---------------------------------------------------------------------------
# multiprocessing.Manager identity — extra38 namespace
#
# multiprocessing.Manager is a bound method on DefaultContext, not a class:
#   Manager.__name__   == 'Manager'                    ( 7 chars)
#   Manager.__module__ == 'multiprocessing.context'    (23 chars)
# Manager is a factory method that creates SyncManager instances. It differs from
# Pool, Queue, and Process (which are context-bound classes). Prior specs did not
# capture Manager.__name__ or Manager.__module__ string equality in extra38.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra38.Manager_name_eq:
  description: "multiprocessing.Manager.__name__ == 'Manager' — Manager is a bound method on DefaultContext (factory for SyncManager), not a class; its __name__ is 'Manager' (7 chars)"
  category: function_names
  kind: python_call_eq
  function: Manager.__name__.__eq__
  args: ["Manager"]
  expected: true

# ---------------------------------------------------------------------------
# multiprocessing top-level function __name__ equality — extra38 namespace
#
# Three core functions at the top-level multiprocessing namespace:
#   cpu_count.__name__       == 'cpu_count'       ( 9 chars)
#   current_process.__name__ == 'current_process' (15 chars)
#   active_children.__name__ == 'active_children' (15 chars)
# current_process and active_children share the same __name__ length (15).
# Prior specs measured these as integer __len__() values; extra38 captures
# the string equality checks in this namespace.
# ---------------------------------------------------------------------------

table multiprocessing_extra38.function_name_equality:
  description: "multiprocessing top-level function __name__ string equality in extra38 namespace"
  kind: python_call_eq
  category: function_names
  id_prefix: mpfuncnameq38

  columns: [id, function, args, expected, description]
  rows:
    - [cpu_count,       cpu_count.__name__.__eq__,       ["cpu_count"],       true, "cpu_count.__name__ == 'cpu_count' (9 chars)"]
    - [current_process, current_process.__name__.__eq__, ["current_process"], true, "current_process.__name__ == 'current_process' (15 chars)"]
    - [active_children, active_children.__name__.__eq__, ["active_children"], true, "active_children.__name__ == 'active_children' (15 chars)"]

# ---------------------------------------------------------------------------
# multiprocessing top-level function __module__ — extra38 namespace
#
# cpu_count, current_process, and active_children have different __module__ values:
#   cpu_count.__module__       == 'multiprocessing.context' (23 chars) — context layer
#   current_process.__module__ == 'multiprocessing.process' (23 chars) — process module
#   active_children.__module__ == 'multiprocessing.process' (23 chars) — process module
# All three module strings are 23 chars, but 'context' vs 'process' differ in meaning:
# cpu_count is provided by the context (DefaultContext.cpu_count), while
# current_process and active_children are implemented in multiprocessing.process.
# ---------------------------------------------------------------------------

table multiprocessing_extra38.function_module_equality:
  description: "multiprocessing top-level function __module__ string equality in extra38 namespace — context vs process submodule"
  kind: python_call_eq
  category: module_names
  id_prefix: mpfuncmodeq38

  columns: [id, function, args, expected, description]
  rows:
    - [cpu_count,       cpu_count.__module__.__eq__,       ["multiprocessing.context"], true, "cpu_count.__module__ == 'multiprocessing.context' (23 chars) — provided by context layer"]
    - [current_process, current_process.__module__.__eq__, ["multiprocessing.process"], true, "current_process.__module__ == 'multiprocessing.process' (23 chars)"]
    - [active_children, active_children.__module__.__eq__, ["multiprocessing.process"], true, "active_children.__module__ == 'multiprocessing.process' (23 chars)"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra38
# ---------------------------------------------------------------------------

invariant multiprocessing_extra38.Process_bases0_name_eq:
  description: "multiprocessing.Process.__bases__[0].__name__ == 'BaseProcess' — Process directly extends BaseProcess; no intermediate mixin in the inheritance chain"
  category: class_names
  kind: python_call_eq
  function: "Process.__bases__[0].__name__.__eq__"
  args: ["BaseProcess"]
  expected: true

invariant multiprocessing_extra38.Process_mro_len:
  description: "multiprocessing.Process.__mro__.__len__() == 3 — MRO is [Process, BaseProcess, object]; shallow hierarchy with no mixins"
  category: class_names
  kind: python_call_eq
  function: Process.__mro__.__len__
  args: []
  expected: 3

invariant multiprocessing_extra38.cpu_count_name_eq:
  description: "multiprocessing.cpu_count.__name__ == 'cpu_count' — the function for reporting the number of CPUs (9 chars)"
  category: function_names
  kind: python_call_eq
  function: cpu_count.__name__.__eq__
  args: ["cpu_count"]
  expected: true

invariant multiprocessing_extra38.cpu_count_module_eq:
  description: "multiprocessing.cpu_count.__module__ == 'multiprocessing.context' — cpu_count is provided by the context layer (DefaultContext), not the process module (23 chars)"
  category: module_names
  kind: python_call_eq
  function: cpu_count.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true
