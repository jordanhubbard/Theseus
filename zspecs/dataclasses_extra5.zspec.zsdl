spec: dataclasses_extra5
version: ">=3.9"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses module documentation"
    - "PEP 557 — Data Classes"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "Extends dataclasses.zspec.zsdl through dataclasses_extra4.zspec.zsdl."
    - "Previous specs cover: function names (dataclass, field, fields, asdict, astuple, replace, make_dataclass, is_dataclass), class names (FrozenInstanceError, InitVar, KW_ONLY, MISSING, Field), Field attributes (default, default_factory, repr, compare), is_dataclass negative cases."
    - "dataclasses.dataclass.__module__ == 'dataclasses' — the decorator is defined in this module."
    - "dataclasses.field.__module__ == 'dataclasses' — the field helper is defined in this module."
    - "dataclasses.fields.__module__ == 'dataclasses' — the fields() introspection function is defined here."
    - "dataclasses.asdict.__module__ == 'dataclasses' — asdict() is defined in this module."
    - "dataclasses.astuple.__module__ == 'dataclasses' — astuple() is defined in this module."
    - "dataclasses.replace.__module__ == 'dataclasses' — replace() is defined in this module."
    - "dataclasses.make_dataclass.__module__ == 'dataclasses' — make_dataclass() is defined here."
    - "dataclasses.is_dataclass.__module__ == 'dataclasses' — is_dataclass() is defined here."
    - "dataclasses.FrozenInstanceError.__module__ == 'dataclasses'."
    - "dataclasses.FrozenInstanceError.__bases__[0].__name__ == 'AttributeError'."
    - "dataclasses.Field.__module__ == 'dataclasses'."
    - "dataclasses.InitVar.__module__ == 'dataclasses'."
    - "dataclasses.KW_ONLY.__class__.__name__ == '_KW_ONLY_TYPE' (Python 3.10+)."
    - "dataclasses.MISSING.__class__.__name__ == '_MISSING_TYPE' — already confirmed in extra4, repeated here for module path."
    - "dataclasses.field(default=1).default == 1 — explicit default value round-trips correctly."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module affiliation — public functions
#
# All public functions in the dataclasses module must have __module__ equal
# to 'dataclasses'. We verify each one explicitly.
# ---------------------------------------------------------------------------

invariant dataclasses_extra5.dataclass.module:
  description: "dataclasses.dataclass.__module__ == 'dataclasses'"
  category: module
  kind: python_call_eq
  function: dataclass.__module__.__eq__
  args: ["dataclasses"]
  expected: true

invariant dataclasses_extra5.field.module:
  description: "dataclasses.field.__module__ == 'dataclasses'"
  category: module
  kind: python_call_eq
  function: field.__module__.__eq__
  args: ["dataclasses"]
  expected: true

invariant dataclasses_extra5.fields.module:
  description: "dataclasses.fields.__module__ == 'dataclasses'"
  category: module
  kind: python_call_eq
  function: fields.__module__.__eq__
  args: ["dataclasses"]
  expected: true

invariant dataclasses_extra5.asdict.module:
  description: "dataclasses.asdict.__module__ == 'dataclasses'"
  category: module
  kind: python_call_eq
  function: asdict.__module__.__eq__
  args: ["dataclasses"]
  expected: true

invariant dataclasses_extra5.astuple.module:
  description: "dataclasses.astuple.__module__ == 'dataclasses'"
  category: module
  kind: python_call_eq
  function: astuple.__module__.__eq__
  args: ["dataclasses"]
  expected: true

invariant dataclasses_extra5.replace.module:
  description: "dataclasses.replace.__module__ == 'dataclasses'"
  category: module
  kind: python_call_eq
  function: replace.__module__.__eq__
  args: ["dataclasses"]
  expected: true

invariant dataclasses_extra5.make_dataclass.module:
  description: "dataclasses.make_dataclass.__module__ == 'dataclasses'"
  category: module
  kind: python_call_eq
  function: make_dataclass.__module__.__eq__
  args: ["dataclasses"]
  expected: true

invariant dataclasses_extra5.is_dataclass.module:
  description: "dataclasses.is_dataclass.__module__ == 'dataclasses'"
  category: module
  kind: python_call_eq
  function: is_dataclass.__module__.__eq__
  args: ["dataclasses"]
  expected: true

# ---------------------------------------------------------------------------
# Module affiliation — public classes and sentinels
# ---------------------------------------------------------------------------

invariant dataclasses_extra5.FrozenInstanceError.module:
  description: "dataclasses.FrozenInstanceError.__module__ == 'dataclasses'"
  category: module
  kind: python_call_eq
  function: FrozenInstanceError.__module__.__eq__
  args: ["dataclasses"]
  expected: true

invariant dataclasses_extra5.Field.module:
  description: "dataclasses.Field.__module__ == 'dataclasses'"
  category: module
  kind: python_call_eq
  function: Field.__module__.__eq__
  args: ["dataclasses"]
  expected: true

invariant dataclasses_extra5.InitVar.module:
  description: "dataclasses.InitVar.__module__ == 'dataclasses'"
  category: module
  kind: python_call_eq
  function: InitVar.__module__.__eq__
  args: ["dataclasses"]
  expected: true

# ---------------------------------------------------------------------------
# FrozenInstanceError — base class is AttributeError
#
# dataclasses.FrozenInstanceError is raised when a frozen dataclass field
# is assigned to after construction. Its first base class is AttributeError.
# ---------------------------------------------------------------------------

invariant dataclasses_extra5.FrozenInstanceError.base_is_AttributeError:
  description: "dataclasses.FrozenInstanceError.__bases__[0].__name__ == 'AttributeError'"
  category: class_hierarchy
  kind: python_call_eq
  function: FrozenInstanceError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["AttributeError"]
  expected: true

# ---------------------------------------------------------------------------
# KW_ONLY — sentinel class name (Python 3.10+)
#
# dataclasses.KW_ONLY is a sentinel that marks all following fields in a
# dataclass as keyword-only. Its class name is '_KW_ONLY_TYPE'.
# ---------------------------------------------------------------------------

invariant dataclasses_extra5.KW_ONLY.class_name:
  description: "dataclasses.KW_ONLY.__class__.__name__ == '_KW_ONLY_TYPE' (Python 3.10+)"
  category: sentinels
  version: ">=3.10"
  kind: python_call_eq
  function: KW_ONLY.__class__.__name__.__eq__
  args: ["_KW_ONLY_TYPE"]
  expected: true

# ---------------------------------------------------------------------------
# MISSING — sentinel class name (cross-check from module path)
#
# dataclasses.MISSING is the sentinel used when no default is provided.
# Its class name is '_MISSING_TYPE'. This extends coverage from extra4's
# confirmation using a __module__ access path.
# ---------------------------------------------------------------------------

invariant dataclasses_extra5.MISSING.class_name_crosscheck:
  description: "dataclasses.MISSING.__class__.__name__ == '_MISSING_TYPE' — cross-check from extra5 module path"
  category: sentinels
  kind: python_call_eq
  function: MISSING.__class__.__name__.__eq__
  args: ["_MISSING_TYPE"]
  expected: true

# ---------------------------------------------------------------------------
# field(default=1) — explicit default round-trips
#
# When a default value is given to field(), it must be stored in the
# .default attribute unchanged. We verify with the integer 1.
# ---------------------------------------------------------------------------

invariant dataclasses_extra5.field.explicit_default_stored:
  description: "dataclasses.field(default=1).default == 1 — explicit default is stored correctly"
  category: field
  kind: python_call_eq
  function: field
  args: []
  method: default
  expected: 1
