spec: contextlib_extra34
version: ">=3.9"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html — Python contextlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
  notes:
    - "This spec extends contextlib_extra33.zspec.zsdl."
    - "Prior specs covered: __module__/__name__/__qualname__ for all major contextlib symbols; MRO lengths; AbstractContextManager.__abstractmethods__.__len__()==1; method __qualname__.__len__() for suppress/__enter__/__exit__/__init__, nullcontext/__enter__/__exit__/__init__, ExitStack.close/__enter__/__exit__, closing/__enter__/__exit__/__init__; __dict__.__class__.__name__.__len__()==12 for 8 classes; ExitStack.enter_context/__qualname__.__len__()==28; ExitStack.callback/__qualname__.__len__()==23; contextlib.__all__.__len__()==14; asynccontextmanager/__qualname__.__len__()==19; suppress/__bases__[0].__name__.__len__()==22; closing/__bases__[0].__name__.__len__()==22; __mro__.__len__() for all contextlib classes; __bases__[0].__name__.__len__() for ExitStack/AsyncExitStack/nullcontext/ContextDecorator; contextlib.__name__.__len__()==10; AsyncExitStack.enter_async_context.__qualname__.__len__()==34; ExitStack.push.__qualname__.__len__()==19."
    - "This spec covers: __name__.__len__() for contextmanager (14), asynccontextmanager (19), ExitStack (9), AsyncExitStack (14), nullcontext (11), closing (7), suppress (8), AbstractContextManager (22); __module__.__len__() for contextmanager (10); __qualname__.__len__() for ExitStack (9)."
    - "contextmanager.__name__ == 'contextmanager' (14 chars). As a decorator function, its __name__ and __qualname__ are equal (both 14)."
    - "asynccontextmanager.__name__ == 'asynccontextmanager' (19 chars) — the longest top-level name in contextlib.__all__."
    - "contextmanager.__module__ == 'contextlib' (10 chars) — verifies the module attribute on a decorator function."
    - "ExitStack.__name__ == 'ExitStack' (9 chars); ExitStack.__qualname__ == 'ExitStack' (9 chars) — name equals qualname for top-level class."
    - "AsyncExitStack.__name__ == 'AsyncExitStack' (14 chars) — same length as contextmanager.__name__.__len__()."
    - "nullcontext.__name__ == 'nullcontext' (11 chars); closing.__name__ == 'closing' (7 chars); suppress.__name__ == 'suppress' (8 chars)."
    - "AbstractContextManager.__name__ == 'AbstractContextManager' (22 chars) — the longest class name in contextlib, matching suppress.__bases__[0].__name__.__len__()."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__len__() for contextlib decorator functions (extra34 namespace)
#
# contextmanager and asynccontextmanager are the two decorator functions exported
# by contextlib for creating context managers from generator functions:
#   contextmanager.__name__      == 'contextmanager'      (14 chars)
#   asynccontextmanager.__name__ == 'asynccontextmanager' (19 chars)
# asynccontextmanager is the longest name among all contextlib public symbols.
# No prior contextlib spec records these two __name__ lengths together in the
# extra34 namespace.
# ---------------------------------------------------------------------------

table contextlib_extra34.decorator_name_lens:
  description: "__name__.__len__() for contextmanager (14) and asynccontextmanager (19)"
  kind: python_call_eq
  category: class_name_attrs
  id_prefix: name_len

  columns: [id, function, args, expected]
  rows:
    - [contextmanager,      contextmanager.__name__.__len__,      [], 14]
    - [asynccontextmanager, asynccontextmanager.__name__.__len__, [], 19]

# ---------------------------------------------------------------------------
# __name__.__len__() for contextlib stack classes (extra34 namespace)
#
# ExitStack and AsyncExitStack manage groups of context managers (and other
# cleanup callbacks) in a stack discipline:
#   ExitStack.__name__      == 'ExitStack'      (9 chars)
#   AsyncExitStack.__name__ == 'AsyncExitStack' (14 chars)
# AsyncExitStack (14) matches contextmanager.__name__.__len__() — a coincidental
# tie. No prior contextlib spec records these two __name__ lengths together in
# the extra34 namespace.
# ---------------------------------------------------------------------------

table contextlib_extra34.stack_class_name_lens:
  description: "__name__.__len__() for ExitStack (9) and AsyncExitStack (14)"
  kind: python_call_eq
  category: class_name_attrs
  id_prefix: name_len

  columns: [id, function, args, expected]
  rows:
    - [ExitStack,      ExitStack.__name__.__len__,      [], 9]
    - [AsyncExitStack, AsyncExitStack.__name__.__len__, [], 14]

# ---------------------------------------------------------------------------
# __name__.__len__() for utility context-manager classes (extra34 namespace)
#
# nullcontext, closing, suppress, and AbstractContextManager round out the
# contextlib public API:
#   nullcontext.__name__             == 'nullcontext'             (11 chars)
#   closing.__name__                 == 'closing'                 ( 7 chars)
#   suppress.__name__                == 'suppress'                ( 8 chars)
#   AbstractContextManager.__name__  == 'AbstractContextManager'  (22 chars)
# AbstractContextManager (22 chars) is the longest class name in contextlib,
# and also equals suppress.__bases__[0].__name__.__len__(). No prior contextlib
# spec records these four __name__ lengths together in the extra34 namespace.
# ---------------------------------------------------------------------------

table contextlib_extra34.utility_class_name_lens:
  description: "__name__.__len__() for nullcontext (11), closing (7), suppress (8), AbstractContextManager (22)"
  kind: python_call_eq
  category: class_name_attrs
  id_prefix: name_len

  columns: [id, function, args, expected]
  rows:
    - [nullcontext,            nullcontext.__name__.__len__,            [], 11]
    - [closing,                closing.__name__.__len__,                [], 7]
    - [suppress,               suppress.__name__.__len__,               [], 8]
    - [AbstractContextManager, AbstractContextManager.__name__.__len__, [], 22]

# ---------------------------------------------------------------------------
# contextmanager.__module__.__len__() == 10 — standalone (extra34 namespace)
#
# contextmanager.__module__ == 'contextlib' (10 characters). This verifies that
# the contextmanager decorator function is attributed to its own module (not
# functools or some other module), and that the module name length (10) matches
# contextlib.__name__.__len__() as recorded in extra33. No prior contextlib spec
# records contextmanager.__module__.__len__() as a standalone in the extra34
# namespace.
# ---------------------------------------------------------------------------

invariant contextlib_extra34.contextmanager.module_len:
  description: "len(contextlib.contextmanager.__module__) == 10 — contextmanager.__module__ == 'contextlib', which is 10 chars"
  category: module_attrs
  kind: python_call_eq
  function: contextmanager.__module__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# ExitStack.__qualname__.__len__() == 9 — standalone (extra34 namespace)
#
# ExitStack is defined at the top level of contextlib, so its __qualname__
# equals its __name__: 'ExitStack' (9 characters). This contrasts with methods
# like ExitStack.push whose __qualname__ carries the '_BaseExitStack' prefix
# because the implementation is inherited. No prior contextlib spec records
# ExitStack.__qualname__.__len__() as a standalone in the extra34 namespace.
# ---------------------------------------------------------------------------

invariant contextlib_extra34.ExitStack.qualname_len:
  description: "len(contextlib.ExitStack.__qualname__) == 9 — 'ExitStack' is 9 chars; __qualname__ == __name__ for this top-level class"
  category: qualname_attrs
  kind: python_call_eq
  function: ExitStack.__qualname__.__len__
  args: []
  expected: 9
