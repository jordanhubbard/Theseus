spec: concurrent_futures_extra2536
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "Theme: __format__, __bytes__, and __fspath__ dict-presence — checking whether concurrent.futures classes define custom formatting, bytes conversion, and filesystem path protocol in their class __dict__."
    - "concurrent.futures.Future is a placeholder for an asynchronous computation result; it defines no string-format override, bytes conversion, or path protocol in its class __dict__. Verified with Python 3.14."
    - "concurrent.futures.Executor is the abstract base class for thread and process pool executors; it defines no formatting, bytes, or path protocol. Verified with Python 3.14."
    - "concurrent.futures.ThreadPoolExecutor manages a pool of worker threads; it is not a formatted, byte-serializable, or path-like object. Verified with Python 3.14."
    - "concurrent.futures.ProcessPoolExecutor manages a pool of worker processes; it carries no custom formatting, bytes, or OS path protocol in its class __dict__. Verified with Python 3.14."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: concurrent.futures.Future — __format__/__bytes__/__fspath__ absence
#
# Theme: custom formatting, bytes conversion, and path protocol absent from
# concurrent.futures.Future __dict__.
# Future is a plain result-holder for thread/process pool work items;
# it is not a string-formattable, byte-serializable, or path-like object.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2536.future_format_bytes_fspath:
