spec: concurrent_futures_extra252
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "concurrent.futures.Future.__init__.__name__ == '__init__' (len=8); __qualname__ == 'Future.__init__' (len=15)."
    - "concurrent.futures.Future.__repr__.__name__ == '__repr__' (len=8); __qualname__ == 'Future.__repr__' (len=15) — both __init__ and __repr__ share qualname length of 15."
    - "concurrent.futures.Future.__class__.__name__ == 'type' (len=4) — Future is a class object, so its __class__ is the metaclass 'type'."
    - "concurrent.futures.Future.__dict__.__contains__('result') == True and __contains__('cancel') == True — both methods are defined directly on Future."
    - "concurrent.futures.Future.__dict__.__contains__('add_done_callback') == True and __contains__('set_result') == True."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Future dunder method identity
#
# Future.__init__.__name__ == '__init__' (len=8)
# Future.__init__.__qualname__ == 'Future.__init__' (len=15)
# Future.__repr__.__name__ == '__repr__' (len=8)
# Future.__repr__.__qualname__ == 'Future.__repr__' (len=15)
# Future.__class__.__name__ == 'type' (len=4)
# ---------------------------------------------------------------------------

table concurrent_futures_extra252.future_dunder_identity:
  description: "concurrent.futures.Future dunder method identity — __init__ and __repr__ both have __name__ len=8 and __qualname__ len=15; Future.__class__.__name__ == 'type' since Future is itself a class object; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cf252dn

  columns: [id, function, args, expected, description]
  rows:
    - [init_name_eq,    Future.__init__.__name__.__eq__,       ["__init__"],           true, "concurrent.futures.Future.__init__.__name__ == '__init__'; verified with Python 3.14.3"]
    - [init_name_len,   Future.__init__.__name__.__len__,      [],                     8,    "concurrent.futures.Future.__init__.__name__.__len__() == 8; verified with Python 3.14.3"]
    - [init_qname_eq,   Future.__init__.__qualname__.__eq__,   ["Future.__init__"],    true, "concurrent.futures.Future.__init__.__qualname__ == 'Future.__init__'; verified with Python 3.14.3"]
    - [init_qname_len,  Future.__init__.__qualname__.__len__,  [],                     15,   "concurrent.futures.Future.__init__.__qualname__.__len__() == 15; verified with Python 3.14.3"]
    - [repr_name_eq,    Future.__repr__.__name__.__eq__,       ["__repr__"],           true, "concurrent.futures.Future.__repr__.__name__ == '__repr__'; verified with Python 3.14.3"]
    - [repr_name_len,   Future.__repr__.__name__.__len__,      [],                     8,    "concurrent.futures.Future.__repr__.__name__.__len__() == 8; verified with Python 3.14.3"]
    - [repr_qname_eq,   Future.__repr__.__qualname__.__eq__,   ["Future.__repr__"],    true, "concurrent.futures.Future.__repr__.__qualname__ == 'Future.__repr__'; verified with Python 3.14.3"]
    - [repr_qname_len,  Future.__repr__.__qualname__.__len__,  [],                     15,   "concurrent.futures.Future.__repr__.__qualname__.__len__() == 15; verified with Python 3.14.3"]
    - [cls_name_eq,     Future.__class__.__name__.__eq__,      ["type"],               true, "concurrent.futures.Future.__class__.__name__ == 'type' — Future is a class object whose metaclass is 'type'; verified with Python 3.14.3"]
    - [cls_name_len,    Future.__class__.__name__.__len__,     [],                     4,    "concurrent.futures.Future.__class__.__name__.__len__() == 4; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.Future.__dict__ membership
#
# Future.__dict__.__contains__('result') == True
# Future.__dict__.__contains__('cancel') == True
# Future.__dict__.__contains__('add_done_callback') == True
# Future.__dict__.__contains__('set_result') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra252.future_dict_membership:
  description: "concurrent.futures.Future.__dict__ membership — result, cancel, add_done_callback, and set_result are all defined directly on the Future class (not inherited); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cf252dm

  columns: [id, function, args, expected, description]
  rows:
    - [dict_result,    Future.__dict__.__contains__,   ["result"],            true, "concurrent.futures.Future.__dict__.__contains__('result') == True — result() is defined on Future directly; verified with Python 3.14.3"]
    - [dict_cancel,    Future.__dict__.__contains__,   ["cancel"],            true, "concurrent.futures.Future.__dict__.__contains__('cancel') == True — cancel() is defined on Future directly; verified with Python 3.14.3"]
    - [dict_adc,       Future.__dict__.__contains__,   ["add_done_callback"], true, "concurrent.futures.Future.__dict__.__contains__('add_done_callback') == True — add_done_callback() is defined on Future directly; verified with Python 3.14.3"]
    - [dict_setresult, Future.__dict__.__contains__,   ["set_result"],        true, "concurrent.futures.Future.__dict__.__contains__('set_result') == True — set_result() is defined on Future directly; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra252
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra252.future_init_qualname:
  description: "concurrent.futures.Future.__init__.__qualname__.__eq__('Future.__init__') returns True — the qualified name includes the class prefix 'Future.' (len=15), distinguishing it from a bare '__init__' (len=8); __init__ and __repr__ share identical qualname length; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Future.__init__.__qualname__.__eq__
  args: ["Future.__init__"]
  expected: true

invariant concurrent_futures_extra252.future_class_is_type:
  description: "concurrent.futures.Future.__class__.__name__.__eq__('type') returns True — Future is a plain class whose metaclass is the built-in 'type' (len=4); this confirms Future uses no custom metaclass; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Future.__class__.__name__.__eq__
  args: ["type"]
  expected: true
