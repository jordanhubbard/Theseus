spec: pdb_extra
version: ">=3.0"
backend: python_module(pdb)

docs: https://docs.python.org/3/library/pdb.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/pdb.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pdb.py"
    - "CPython source: Lib/bdb.py"
  notes:
    - "This spec covers pdb behaviors not already captured in pdb.zspec.zsdl."
    - "Pdb.__name__ == 'Pdb' — covered in pdb.zspec.zsdl table; restated here as standalone invariant."
    - "Pdb.__module__ == 'pdb' — covered in pdb.zspec.zsdl; restated here as standalone invariant."
    - "Pdb.__bases__[0].__name__ == 'Bdb' — Pdb's first base class is bdb.Bdb (Python source confirmed)."
    - "run, runeval, runcall, set_trace, post_mortem, pm are all top-level public functions in pdb."
    - "help.__name__ == 'help' — pdb exports a help() convenience function distinct from the builtin help."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Pdb class — name, module, and base class
# ---------------------------------------------------------------------------

invariant pdb_extra.Pdb.name:
  description: "pdb.Pdb.__name__ == 'Pdb'"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__name__.__eq__
  args: ["Pdb"]
  expected: true

invariant pdb_extra.Pdb.module:
  description: "pdb.Pdb.__module__ == 'pdb'"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__module__.__eq__
  args: ["pdb"]
  expected: true

invariant pdb_extra.Pdb.base_is_Bdb:
  description: "pdb.Pdb.__bases__[0].__name__ == 'Bdb' — Pdb inherits from bdb.Bdb"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Bdb"]
  expected: true

# ---------------------------------------------------------------------------
# Public API functions — name checks
# ---------------------------------------------------------------------------

invariant pdb_extra.functions.run:
  description: "pdb.run.__name__ == 'run'"
  category: functions
  kind: python_call_eq
  function: run.__name__.__eq__
  args: ["run"]
  expected: true

invariant pdb_extra.functions.runeval:
  description: "pdb.runeval.__name__ == 'runeval'"
  category: functions
  kind: python_call_eq
  function: runeval.__name__.__eq__
  args: ["runeval"]
  expected: true

invariant pdb_extra.functions.runcall:
  description: "pdb.runcall.__name__ == 'runcall'"
  category: functions
  kind: python_call_eq
  function: runcall.__name__.__eq__
  args: ["runcall"]
  expected: true

invariant pdb_extra.functions.set_trace:
  description: "pdb.set_trace.__name__ == 'set_trace'"
  category: functions
  kind: python_call_eq
  function: set_trace.__name__.__eq__
  args: ["set_trace"]
  expected: true

invariant pdb_extra.functions.post_mortem:
  description: "pdb.post_mortem.__name__ == 'post_mortem'"
  category: functions
  kind: python_call_eq
  function: post_mortem.__name__.__eq__
  args: ["post_mortem"]
  expected: true

invariant pdb_extra.functions.pm:
  description: "pdb.pm.__name__ == 'pm'"
  category: functions
  kind: python_call_eq
  function: pm.__name__.__eq__
  args: ["pm"]
  expected: true

invariant pdb_extra.functions.help:
  description: "pdb.help.__name__ == 'help'"
  category: functions
  kind: python_call_eq
  function: help.__name__.__eq__
  args: ["help"]
  expected: true
