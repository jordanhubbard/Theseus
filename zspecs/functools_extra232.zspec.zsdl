spec: functools_extra232
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers functools behavioral output contracts: reduce and partial docstring length contracts, reduce docstring content containing 'single' and 'initial', partial docstring content containing 'keywords', WRAPPER_ASSIGNMENTS element [4] '__annotate__' and [5] '__type_params__' equality, and reduce/partial module name length."
    - "functools.reduce.__doc__.__len__() == 389 — reduce docstring is 'Apply a function of two arguments cumulatively to the items of an iterable, from left to right...' with total length 389 characters. Verified with Python 3.14.3."
    - "functools.partial.__doc__.__len__() == 83 — partial docstring is 'Create a new function with partial application of the given arguments\\nand keywords.' with total length 83 characters. Verified with Python 3.14.3."
    - "functools.lru_cache.__doc__.__len__() == 743 — lru_cache docstring is a long description of the least-recently-used cache decorator with total length 743. Verified with Python 3.14.3."
    - "functools.reduce.__doc__.__contains__('single') == True — reduce docstring contains 'This effectively reduces the iterable to a single value'. Verified with Python 3.14.3."
    - "functools.reduce.__doc__.__contains__('initial') == True — reduce docstring contains 'If initial is present'. Verified with Python 3.14.3."
    - "functools.partial.__doc__.__contains__('keywords') == True — partial docstring contains 'and keywords'. Verified with Python 3.14.3."
    - "functools.reduce.__module__.__len__() == 10 — reduce.__module__ is '_functools' with length 10. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__getitem__(4).__eq__('__annotate__') == True — 5th element (index 4) of WRAPPER_ASSIGNMENTS tuple is '__annotate__' (added Python 3.14). Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__getitem__(5).__eq__('__type_params__') == True — 6th element (index 5) of WRAPPER_ASSIGNMENTS tuple is '__type_params__' (added Python 3.14). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools reduce and partial __doc__ length contracts
#
# functools.reduce.__doc__.__len__() == 389
# functools.partial.__doc__.__len__() == 83
# functools.lru_cache.__doc__.__len__() == 743
# functools.reduce.__module__.__len__() == 10
# functools.reduce.__qualname__.__len__() == 6
#
# These are numeric behavioral output contracts verifying specific docstring
# and attribute lengths for functools core functions. New to extra232.
# ---------------------------------------------------------------------------

table functools_extra232.behavioral_doc_lens:
  description: "functools reduce/partial/lru_cache __doc__ length contracts; reduce.__module__.__len__; new to extra232"
  kind: python_call_eq
  category: behavioral
  id_prefix: functoolsextra232doclen

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_doc_len_389,
       reduce.__doc__.__len__,
       [],
       389,
       "functools.reduce.__doc__.__len__() == 389 — reduce docstring is 'Apply a function of two arguments cumulatively to the items of an iterable, from left to right...This effectively reduces the iterable to a single value...'; total length is 389 characters; __len__() returns 389; new to extra232"]
    - [partial_doc_len_83,
       partial.__doc__.__len__,
       [],
       83,
       "functools.partial.__doc__.__len__() == 83 — partial docstring is 'Create a new function with partial application of the given arguments\\nand keywords.'; total length is 83 characters; __len__() returns 83; new to extra232"]
    - [lru_cache_doc_len_743,
       lru_cache.__doc__.__len__,
       [],
       743,
       "functools.lru_cache.__doc__.__len__() == 743 — lru_cache docstring is a 743-character description of the least-recently-used cache decorator explaining maxsize and typed parameters; __len__() returns 743; new to extra232"]
    - [reduce_module_len_10,
       reduce.__module__.__len__,
       [],
       10,
       "functools.reduce.__module__.__len__() == 10 — reduce.__module__ is '_functools' (the C extension module); the string '_functools' has exactly 10 characters; __len__() returns 10; new to extra232"]
    - [reduce_qualname_len_6,
       reduce.__qualname__.__len__,
       [],
       6,
       "functools.reduce.__qualname__.__len__() == 6 — reduce.__qualname__ is 'reduce' which has exactly 6 characters; __len__() returns 6; new to extra232"]

# ---------------------------------------------------------------------------
# Table 2: functools reduce and partial __doc__ content contracts
#
# functools.reduce.__doc__.__contains__('single') == True
# functools.reduce.__doc__.__contains__('initial') == True
# functools.partial.__doc__.__contains__('keywords') == True
# functools.reduce.__doc__.__contains__('cumulatively') == True
# functools.partial.__doc__.__contains__('partial') == True
#
# These verify the behavioral semantics described in the docstrings.
# New to extra232.
# ---------------------------------------------------------------------------

table functools_extra232.behavioral_doc_contents:
  description: "functools reduce/partial __doc__ content contracts; 'single', 'initial', 'keywords', 'cumulatively'; new to extra232"
  kind: python_call_eq
  category: behavioral
  id_prefix: functoolsextra232doccont

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_doc_contains_single,
       reduce.__doc__.__contains__,
       ["single"],
       true,
       "functools.reduce.__doc__.__contains__('single') == True — reduce docstring states 'This effectively reduces the iterable to a single value'; 'single' appears in the docstring; __contains__('single') returns True; new to extra232"]
    - [reduce_doc_contains_initial,
       reduce.__doc__.__contains__,
       ["initial"],
       true,
       "functools.reduce.__doc__.__contains__('initial') == True — reduce docstring states 'If initial is present, it is placed before the items of the iterable in the calculation'; 'initial' appears in the docstring; __contains__('initial') returns True; new to extra232"]
    - [partial_doc_contains_keywords,
       partial.__doc__.__contains__,
       ["keywords"],
       true,
       "functools.partial.__doc__.__contains__('keywords') == True — partial docstring is 'Create a new function with partial application of the given arguments\\nand keywords.'; 'keywords' appears in the docstring; __contains__('keywords') returns True; new to extra232"]
    - [reduce_doc_contains_cumulatively,
       reduce.__doc__.__contains__,
       ["cumulatively"],
       true,
       "functools.reduce.__doc__.__contains__('cumulatively') == True — reduce docstring states 'Apply a function of two arguments cumulatively'; 'cumulatively' appears as a key semantic word; __contains__('cumulatively') returns True; new to extra232"]
    - [reduce_doc_contains_left,
       reduce.__doc__.__contains__,
       ["left"],
       true,
       "functools.reduce.__doc__.__contains__('left') == True — reduce docstring states 'from left to right'; 'left' appears in the docstring; __contains__('left') returns True; new to extra232"]

# ---------------------------------------------------------------------------
# Table 3: functools WRAPPER_ASSIGNMENTS indices 4 and 5 (Python 3.14 additions)
#
# functools.WRAPPER_ASSIGNMENTS[4] == '__annotate__'
# functools.WRAPPER_ASSIGNMENTS[5] == '__type_params__'
#
# Python 3.14 added '__annotate__' and '__type_params__' to WRAPPER_ASSIGNMENTS.
# Their values at specific indices were never verified by prior functools extra specs
# (extra10 covered indices 1-3 and -1, but not 4 and 5 by direct eq check).
# New to extra232.
# ---------------------------------------------------------------------------

table functools_extra232.wrapper_assignments_py314:
  description: "functools.WRAPPER_ASSIGNMENTS[4]=='__annotate__' and [5]=='__type_params__' (Python 3.14 additions); new to extra232"
  kind: python_call_eq
  category: behavioral
  id_prefix: functoolsextra232wrappyok

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_assignments_idx4_annotate,
       WRAPPER_ASSIGNMENTS.__getitem__,
       [4],
       "__annotate__",
       "functools.WRAPPER_ASSIGNMENTS[4] == '__annotate__' — 5th element (index 4) of WRAPPER_ASSIGNMENTS is '__annotate__', added in Python 3.14 to copy annotation laziness markers; __getitem__(4) returns '__annotate__'; new to extra232"]
    - [wrapper_assignments_idx5_type_params,
       WRAPPER_ASSIGNMENTS.__getitem__,
       [5],
       "__type_params__",
       "functools.WRAPPER_ASSIGNMENTS[5] == '__type_params__' — 6th element (index 5) of WRAPPER_ASSIGNMENTS is '__type_params__', added in Python 3.14 for PEP 695 type parameter support; __getitem__(5) returns '__type_params__'; new to extra232"]
    - [wrapper_assignments_len_6,
       WRAPPER_ASSIGNMENTS.__len__,
       [],
       6,
       "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — WRAPPER_ASSIGNMENTS tuple has exactly 6 elements: __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__; __len__() returns 6; new to extra232"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra232
# ---------------------------------------------------------------------------

invariant functools_extra232.reduce_doc_len_389:
  description: "functools.reduce.__doc__.__len__() == 389 — reduce docstring has exactly 389 characters; new to extra232"
  kind: python_call_eq
  function: reduce.__doc__.__len__
  args: []
  expected: 389

invariant functools_extra232.partial_doc_len_83:
  description: "functools.partial.__doc__.__len__() == 83 — partial docstring has exactly 83 characters; new to extra232"
  kind: python_call_eq
  function: partial.__doc__.__len__
  args: []
  expected: 83

invariant functools_extra232.lru_cache_doc_len_743:
  description: "functools.lru_cache.__doc__.__len__() == 743 — lru_cache docstring has exactly 743 characters; new to extra232"
  kind: python_call_eq
  function: lru_cache.__doc__.__len__
  args: []
  expected: 743

invariant functools_extra232.reduce_module_len_10:
  description: "functools.reduce.__module__.__len__() == 10 — reduce.__module__ is '_functools' (10 chars); new to extra232"
  kind: python_call_eq
  function: reduce.__module__.__len__
  args: []
  expected: 10

invariant functools_extra232.reduce_qualname_len_6:
  description: "functools.reduce.__qualname__.__len__() == 6 — reduce.__qualname__ is 'reduce' (6 chars); new to extra232"
  kind: python_call_eq
  function: reduce.__qualname__.__len__
  args: []
  expected: 6

invariant functools_extra232.reduce_doc_contains_single:
  description: "functools.reduce.__doc__.__contains__('single') == True — docstring contains 'reduces the iterable to a single value'; new to extra232"
  kind: python_call_eq
  function: reduce.__doc__.__contains__
  args: ["single"]
  expected: true

invariant functools_extra232.reduce_doc_contains_initial:
  description: "functools.reduce.__doc__.__contains__('initial') == True — docstring contains 'If initial is present'; new to extra232"
  kind: python_call_eq
  function: reduce.__doc__.__contains__
  args: ["initial"]
  expected: true

invariant functools_extra232.partial_doc_contains_keywords:
  description: "functools.partial.__doc__.__contains__('keywords') == True — docstring ends with 'and keywords.'; new to extra232"
  kind: python_call_eq
  function: partial.__doc__.__contains__
  args: ["keywords"]
  expected: true

invariant functools_extra232.reduce_doc_contains_cumulatively:
  description: "functools.reduce.__doc__.__contains__('cumulatively') == True — docstring says 'Apply a function of two arguments cumulatively'; new to extra232"
  kind: python_call_eq
  function: reduce.__doc__.__contains__
  args: ["cumulatively"]
  expected: true

invariant functools_extra232.wrapper_assignments_idx4_annotate:
  description: "functools.WRAPPER_ASSIGNMENTS[4] == '__annotate__' — 5th element added Python 3.14; new to extra232"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__getitem__
  args: [4]
  expected: "__annotate__"

invariant functools_extra232.wrapper_assignments_idx5_type_params:
  description: "functools.WRAPPER_ASSIGNMENTS[5] == '__type_params__' — 6th element added Python 3.14; new to extra232"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__getitem__
  args: [5]
  expected: "__type_params__"

invariant functools_extra232.wrapper_assignments_len_6:
  description: "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — tuple has exactly 6 elements in Python 3.14; new to extra232"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6
