spec: threading_extra2671
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/threading.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 625 theme: __sub__, __floordiv__, and __mod__ dict-presence checks (subtraction and integer division arithmetic)."
    - "threading.Thread is a runnable object; it does not define subtraction or integer division arithmetic protocols."
    - "threading.Lock (accessed as threading.Lock, actual type is _thread.lock) is a synchronization primitive; it defines acquire/release but not __sub__, __floordiv__, or __mod__."
    - "threading.Event, threading.Condition, threading.Semaphore, threading.BoundedSemaphore are synchronization primitives; none define __sub__, __floordiv__, or __mod__."
    - "threading.Timer is a Thread subclass for deferred execution; it defines none of these arithmetic protocols."
    - "threading.Barrier is a synchronization barrier; it does not define __sub__, __floordiv__, or __mod__."
    - "threading.local is a thread-local storage object; it does not define subtraction or integer division arithmetic protocols."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __sub__ dict-presence — absent from all threading synchronization types
# ---------------------------------------------------------------------------

table threading_extra2671.sub_protocol:
  description: "__sub__ is absent from all threading type __dict__s — synchronization primitives do not implement subtraction"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2671

  columns: [id, function, args, expected]
  rows:
    - ["th2671001", "threading.Thread.__dict__.__contains__",           ["__sub__"], false]
    - ["th2671002", "threading.Lock.__dict__.__contains__",             ["__sub__"], false]
    - ["th2671003", "threading.Event.__dict__.__contains__",            ["__sub__"], false]
    - ["th2671004", "threading.Condition.__dict__.__contains__",        ["__sub__"], false]
    - ["th2671005", "threading.Semaphore.__dict__.__contains__",        ["__sub__"], false]
    - ["th2671006", "threading.BoundedSemaphore.__dict__.__contains__", ["__sub__"], false]
    - ["th2671007", "threading.Timer.__dict__.__contains__",            ["__sub__"], false]
    - ["th2671008", "threading.Barrier.__dict__.__contains__",          ["__sub__"], false]
    - ["th2671009", "threading.local.__dict__.__contains__",            ["__sub__"], false]

