# ---------------------------------------------------------------------------
# Combined per-type view — Thread, Barrier, and Timer vs. all three protocols
# ---------------------------------------------------------------------------

table threading_extra2671.thread_barrier_combined:
  description: "threading.Thread, threading.Barrier, and threading.Timer define none of __sub__, __floordiv__, __mod__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2671

  columns: [id, function, args, expected]
  rows:
    - ["th2671028", "threading.Thread.__dict__.__contains__",  ["__sub__"],      false]
    - ["th2671029", "threading.Thread.__dict__.__contains__",  ["__floordiv__"], false]
    - ["th2671030", "threading.Thread.__dict__.__contains__",  ["__mod__"],      false]
    - ["th2671031", "threading.Barrier.__dict__.__contains__", ["__sub__"],      false]
    - ["th2671032", "threading.Barrier.__dict__.__contains__", ["__floordiv__"], false]
    - ["th2671033", "threading.Barrier.__dict__.__contains__", ["__mod__"],      false]
    - ["th2671034", "threading.Timer.__dict__.__contains__",   ["__sub__"],      false]
    - ["th2671035", "threading.Timer.__dict__.__contains__",   ["__floordiv__"], false]
    - ["th2671036", "threading.Timer.__dict__.__contains__",   ["__mod__"],      false]
