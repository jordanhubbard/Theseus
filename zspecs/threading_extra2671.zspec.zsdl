    - ["th2671013", "threading.Condition.__dict__.__contains__",        ["__floordiv__"], false]
    - ["th2671014", "threading.Semaphore.__dict__.__contains__",        ["__floordiv__"], false]
    - ["th2671015", "threading.BoundedSemaphore.__dict__.__contains__", ["__floordiv__"], false]
    - ["th2671016", "threading.Timer.__dict__.__contains__",            ["__floordiv__"], false]
    - ["th2671017", "threading.Barrier.__dict__.__contains__",          ["__floordiv__"], false]
