spec: to_constant_case
version: ">=1.0.0"
backend: node(to-constant-case)

docs: https://www.npmjs.com/package/to-constant-case

provenance:
  derived_from:
    - "to-constant-case README — https://www.npmjs.com/package/to-constant-case"
    - "Test vectors verified with to-constant-case via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "to-constant-case source"
  notes:
    - "to-constant-case is an npm package. Install: npm install to-constant-case"
    - "Converts a string to CONSTANT_CASE (all uppercase with underscores)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table to_constant_case.toConstantCase:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: constcase

  columns: [id, args, expected]
  rows:
    - [spaces,  ["hello world"],  "HELLO_WORLD"]
    - [camel,   ["fooBar"],       "FOO_BAR"]
    - [hyphen,  ["foo-bar"],      "FOO_BAR"]
