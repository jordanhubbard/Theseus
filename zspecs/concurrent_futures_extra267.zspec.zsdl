spec: concurrent_futures_extra267
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "concurrent.futures.BrokenExecutor is defined in concurrent.futures._base; __bases__[0].__name__ == 'RuntimeError'."
    - "concurrent.futures.thread.BrokenThreadPool inherits from BrokenExecutor; defined in concurrent.futures.thread."
    - "concurrent.futures.process.BrokenProcessPool inherits from BrokenExecutor; defined in concurrent.futures.process."
    - "Python 3.14.3 does NOT expose a top-level concurrent.futures.Error class."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BrokenExecutor class identity — table
#
# BrokenExecutor, BrokenThreadPool, BrokenProcessPool __name__ and __module__.
# BrokenExecutor inherits from RuntimeError.
# ---------------------------------------------------------------------------

table concurrent_futures_extra267.broken_executor_identity:
  description: "concurrent.futures broken executor exception classes report expected __name__ and __module__"
  kind: python_call_eq
  category: identity
  id_prefix: bexcid

  columns: [id, function, args, expected, description]
  rows:
    - [exec_name,    BrokenExecutor.__name__.__eq__,                   ["BrokenExecutor"],           true, "concurrent.futures.BrokenExecutor.__name__ == 'BrokenExecutor'"]
    - [exec_module,  BrokenExecutor.__module__.__eq__,                 ["concurrent.futures._base"], true, "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base'"]
    - [thread_name,  thread.BrokenThreadPool.__name__.__eq__,          ["BrokenThreadPool"],         true, "concurrent.futures.thread.BrokenThreadPool.__name__ == 'BrokenThreadPool'"]
    - [thread_mod,   thread.BrokenThreadPool.__module__.__eq__,        ["concurrent.futures.thread"], true, "concurrent.futures.thread.BrokenThreadPool.__module__ == 'concurrent.futures.thread'"]
    - [process_name, process.BrokenProcessPool.__name__.__eq__,        ["BrokenProcessPool"],        true, "concurrent.futures.process.BrokenProcessPool.__name__ == 'BrokenProcessPool'"]

# ---------------------------------------------------------------------------
# Inheritance chain — BrokenExecutor, BrokenThreadPool, BrokenProcessPool
# ---------------------------------------------------------------------------

table concurrent_futures_extra267.broken_executor_bases:
  description: "concurrent.futures broken executor exception classes report expected base class names"
  kind: python_call_eq
  category: identity
  id_prefix: bexcbase

  columns: [id, function, args, expected, description]
  rows:
    - [exec_base,    "BrokenExecutor.__bases__[0].__name__.__eq__",          ["RuntimeError"],    true, "BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'"]
    - [thread_base,  "thread.BrokenThreadPool.__bases__[0].__name__.__eq__", ["BrokenExecutor"],  true, "BrokenThreadPool.__bases__[0].__name__ == 'BrokenExecutor'"]
    - [process_base, "process.BrokenProcessPool.__bases__[0].__name__.__eq__", ["BrokenExecutor"], true, "BrokenProcessPool.__bases__[0].__name__ == 'BrokenExecutor'"]
    - [process_mod,  process.BrokenProcessPool.__module__.__eq__,            ["concurrent.futures.process"], true, "BrokenProcessPool.__module__ == 'concurrent.futures.process'"]
    - [thread_qn,    thread.BrokenThreadPool.__qualname__.__eq__,            ["BrokenThreadPool"], true, "BrokenThreadPool.__qualname__ == 'BrokenThreadPool'"]

# ---------------------------------------------------------------------------
# BrokenExecutor __qualname__ and __bases__ chain — standalone invariants
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra267.BrokenExecutor.qualname:
  description: "concurrent.futures.BrokenExecutor.__qualname__ == 'BrokenExecutor'"
  category: identity
  kind: python_call_eq
  function: BrokenExecutor.__qualname__.__eq__
  args: ["BrokenExecutor"]
  expected: true

invariant concurrent_futures_extra267.BrokenProcessPool.qualname:
  description: "concurrent.futures.process.BrokenProcessPool.__qualname__ == 'BrokenProcessPool'"
  category: identity
  kind: python_call_eq
  function: process.BrokenProcessPool.__qualname__.__eq__
  args: ["BrokenProcessPool"]
  expected: true

invariant concurrent_futures_extra267.BrokenExecutor.mro_length:
  description: "concurrent.futures.BrokenExecutor MRO length is at least 3 (BrokenExecutor, RuntimeError, ...)"
  category: identity
  kind: python_call_eq
  function: BrokenExecutor.__mro__[2].__name__.__eq__
  args: ["Exception"]
  expected: true

invariant concurrent_futures_extra267.BrokenThreadPool.mro_base1:
  description: "concurrent.futures.thread.BrokenThreadPool.__mro__[1].__name__ == 'BrokenExecutor'"
  category: identity
  kind: python_call_eq
  function: "thread.BrokenThreadPool.__mro__[1].__name__.__eq__"
  args: ["BrokenExecutor"]
  expected: true
