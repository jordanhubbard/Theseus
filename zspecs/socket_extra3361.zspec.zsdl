provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 671 (sk3361): __invert__, __floor__, __ceil__ dict-presence checks for socket types."
    - "Theme: __invert__/__floor__/__ceil__ dict-presence (~x, math.floor(x), math.ceil(x))."
    - "All values False — UUID, Struct, and socket types have no bitwise-invert or rounding protocol."
    - "socket.socket is a Python class; it does not define __invert__, __floor__, or __ceil__ in its __dict__."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses (EnumType metaclass)."
    - "AddressFamily and SocketKind are IntEnum but do NOT define __invert__, __floor__, or __ceil__ in their own __dict__; these methods are not overridden at the subclass level."
    - "operator.contains(socket.AddressFamily.__dict__, '__invert__') is False — not present in AddressFamily's own __dict__."
    - "operator.contains(socket.SocketKind.__dict__, '__invert__') is False — same reasoning as AddressFamily."
    - "All values are False for all 3 socket types across all 3 operators."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

