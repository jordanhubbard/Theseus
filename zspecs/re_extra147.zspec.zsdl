spec: re_extra147
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.Pattern and re.Match C extension type identity — __name__, __qualname__, __module__, __doc__ lengths, __class__.__name__, __bases__, and MRO — plus re.Pattern and re.Match method __qualname__ values and lengths."
    - "re.Pattern.__name__ == 'Pattern' (len=7); re.Pattern.__qualname__ == 'Pattern' (len=7); re.Pattern.__module__ == 're' (len=2)."
    - "re.Match.__name__ == 'Match' (len=5); re.Match.__qualname__ == 'Match' (len=5); re.Match.__module__ == 're' (len=2)."
    - "re.Pattern.__doc__ == 'Compiled regular expression object.' (len=35); re.Match.__doc__ len == 92."
    - "re.Pattern.__bases__[0].__name__ == 'object'; re.Match.__bases__[0].__name__ == 'object'. Both are direct subclasses of object with MRO length 2."
    - "re.Pattern.__class__.__name__ == 'type'; re.Match.__class__.__name__ == 'type' (both are C extension types with the 'type' metaclass)."
    - "re.Pattern method qualname lengths: sub=11, subn=12, match/split=13, search=14, findall=15, finditer=16, fullmatch=17."
    - "re.Match method qualname lengths: end=9, span=10, group/start=11, groups/expand=12, groupdict=15."
    - "All re.Pattern and re.Match method qualnames follow 'Pattern.<method>' and 'Match.<method>' patterns respectively."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern and re.Match type identity
# Pattern.__name__ == 'Pattern' (len=7); Match.__name__ == 'Match' (len=5).
# Both have __module__ == 're', __class__.__name__ == 'type'.
# Both have __bases__ == (object,) and MRO length == 2.
# Pattern.__doc__ len == 35; Match.__doc__ len == 92.
# ---------------------------------------------------------------------------

table re_extra147.Pattern_Match_type_identity:
  description: "re.Pattern and re.Match type identity: Pattern.__name__=7, Match.__name__=5, both __module__='re', both __class__.__name__='type', both MRO length=2, Pattern.__doc__ len=35, Match.__doc__ len=92"
  kind: python_call_eq
  category: class_identity
  id_prefix: repm147

  columns: [id, function, args, expected, description]
  rows:
    - [pat_name_eq,     Pattern.__name__.__eq__,                     ["Pattern"], true, "re.Pattern.__name__ == 'Pattern' (the compiled regex type; previously only accessible as type(re.compile(r''))).__name__ in older Python)"]
    - [pat_name_len,    Pattern.__name__.__len__,                    [],           7,    "re.Pattern.__name__.__len__() == 7 ('Pattern' has 7 characters)"]
    - [pat_qname_eq,    Pattern.__qualname__.__eq__,                 ["Pattern"], true, "re.Pattern.__qualname__ == 'Pattern' (top-level C extension type; qualname == name for top-level types)"]
    - [pat_module_eq,   Pattern.__module__.__eq__,                   ["re"],      true, "re.Pattern.__module__ == 're' (len=2; exposed in the 're' module namespace, not '_sre' where it is implemented)"]
    - [pat_cls_eq,      Pattern.__class__.__name__.__eq__,           ["type"],    true, "re.Pattern.__class__.__name__ == 'type' (a C extension type with standard metaclass 'type')"]
    - [pat_doc_eq,      Pattern.__doc__.__eq__,                      ["Compiled regular expression object."], true, "re.Pattern.__doc__ == 'Compiled regular expression object.' (the complete, exact docstring)"]
    - [pat_doc_len,     Pattern.__doc__.__len__,                     [],           35,   "re.Pattern.__doc__.__len__() == 35 ('Compiled regular expression object.' has 35 characters)"]
    - [pat_mro_len,     "Pattern.__mro__.__len__",                   [],           2,    "re.Pattern.__mro__.__len__() == 2 ([Pattern, object]; Pattern is a direct subclass of object with no intermediate types)"]
    - [pat_base0_eq,    "Pattern.__bases__[0].__name__.__eq__",      ["object"],  true, "re.Pattern.__bases__[0].__name__ == 'object' (Pattern directly subclasses object)"]
    - [mat_name_eq,     Match.__name__.__eq__,                       ["Match"],   true, "re.Match.__name__ == 'Match' (the match result type returned by re.match(), re.search(), etc.)"]
    - [mat_name_len,    Match.__name__.__len__,                      [],           5,    "re.Match.__name__.__len__() == 5 ('Match' has 5 characters; 2 shorter than 'Pattern')"]
    - [mat_module_eq,   Match.__module__.__eq__,                     ["re"],      true, "re.Match.__module__ == 're'"]
    - [mat_doc_len,     Match.__doc__.__len__,                       [],           92,   "re.Match.__doc__.__len__() == 92 (longer than Pattern.__doc__ (35); the Match doc states 'The result of re.match() and re.search()' and adds that match objects always have boolean value True)"]
    - [mat_mro_len,     "Match.__mro__.__len__",                     [],           2,    "re.Match.__mro__.__len__() == 2 ([Match, object]; like Pattern, Match directly subclasses object)"]
    - [mat_base0_eq,    "Match.__bases__[0].__name__.__eq__",        ["object"],  true, "re.Match.__bases__[0].__name__ == 'object' (Match directly subclasses object)"]

# ---------------------------------------------------------------------------
# re.Pattern method __qualname__ values and lengths
# All follow 'Pattern.<method>' pattern.
# sub=11, subn=12, match/split=13, search=14, findall=15, finditer=16, fullmatch=17.
# ---------------------------------------------------------------------------

table re_extra147.Pattern_method_qualnames:
  description: "re.Pattern method __qualname__ lengths: sub=11, subn=12, match/split=13, search=14, findall=15, finditer=16, fullmatch=17; all follow 'Pattern.<method>' pattern"
  kind: python_call_eq
  category: qualname
  id_prefix: repm147

  columns: [id, function, args, expected, description]
  rows:
    - [pat_sub_qeq,      Pattern.sub.__qualname__.__eq__,       ["Pattern.sub"],       true, "re.Pattern.sub.__qualname__ == 'Pattern.sub' (pattern-based substitution method; len=11)"]
    - [pat_sub_qlen,     Pattern.sub.__qualname__.__len__,      [],                    11,   "re.Pattern.sub.__qualname__.__len__() == 11 ('Pattern.sub' has 11 characters; shortest Pattern method qualname)"]
    - [pat_subn_qeq,     Pattern.subn.__qualname__.__eq__,      ["Pattern.subn"],      true, "re.Pattern.subn.__qualname__ == 'Pattern.subn' (like sub but returns (result, count); len=12)"]
    - [pat_subn_qlen,    Pattern.subn.__qualname__.__len__,     [],                    12,   "re.Pattern.subn.__qualname__.__len__() == 12 ('Pattern.subn' has 12 characters)"]
    - [pat_match_qeq,    Pattern.match.__qualname__.__eq__,     ["Pattern.match"],     true, "re.Pattern.match.__qualname__ == 'Pattern.match' (match at beginning of string; len=13)"]
    - [pat_match_qlen,   Pattern.match.__qualname__.__len__,    [],                    13,   "re.Pattern.match.__qualname__.__len__() == 13 ('Pattern.match' has 13 characters; tied with Pattern.split)"]
    - [pat_split_qeq,    Pattern.split.__qualname__.__eq__,     ["Pattern.split"],     true, "re.Pattern.split.__qualname__ == 'Pattern.split' (split string by pattern; len=13; tied with match)"]
    - [pat_split_qlen,   Pattern.split.__qualname__.__len__,    [],                    13,   "re.Pattern.split.__qualname__.__len__() == 13 (tied with Pattern.match at 13)"]
    - [pat_search_qeq,   Pattern.search.__qualname__.__eq__,    ["Pattern.search"],    true, "re.Pattern.search.__qualname__ == 'Pattern.search' (scan string for match; len=14)"]
    - [pat_search_qlen,  Pattern.search.__qualname__.__len__,   [],                    14,   "re.Pattern.search.__qualname__.__len__() == 14 ('Pattern.search' has 14 characters)"]
    - [pat_findall_qeq,  Pattern.findall.__qualname__.__eq__,   ["Pattern.findall"],   true, "re.Pattern.findall.__qualname__ == 'Pattern.findall' (return list of all matches; len=15)"]
    - [pat_findall_qlen, Pattern.findall.__qualname__.__len__,  [],                    15,   "re.Pattern.findall.__qualname__.__len__() == 15 ('Pattern.findall' has 15 characters)"]
    - [pat_finditer_qeq, Pattern.finditer.__qualname__.__eq__,  ["Pattern.finditer"],  true, "re.Pattern.finditer.__qualname__ == 'Pattern.finditer' (return iterator of matches; len=16)"]
    - [pat_finditer_qlen,Pattern.finditer.__qualname__.__len__, [],                    16,   "re.Pattern.finditer.__qualname__.__len__() == 16 ('Pattern.finditer' has 16 characters)"]
    - [pat_fmatch_qeq,   Pattern.fullmatch.__qualname__.__eq__, ["Pattern.fullmatch"], true, "re.Pattern.fullmatch.__qualname__ == 'Pattern.fullmatch' (match entire string; len=17; longest Pattern method qualname)"]
    - [pat_fmatch_qlen,  Pattern.fullmatch.__qualname__.__len__,[],                    17,   "re.Pattern.fullmatch.__qualname__.__len__() == 17 ('Pattern.fullmatch' has 17 characters; longest Pattern method qualname, matching the function fullmatch's name length of 9 + 'Pattern.' prefix 8 = 17)"]

# ---------------------------------------------------------------------------
# re.Match method __qualname__ values and lengths
# All follow 'Match.<method>' pattern.
# end=9, span=10, group/start=11, groups/expand=12, groupdict=15.
# ---------------------------------------------------------------------------

table re_extra147.Match_method_qualnames:
  description: "re.Match method __qualname__ lengths: end=9, span=10, group/start=11, groups/expand=12, groupdict=15; all follow 'Match.<method>' pattern"
  kind: python_call_eq
  category: qualname
  id_prefix: repm147

  columns: [id, function, args, expected, description]
  rows:
    - [mat_end_qeq,       Match.end.__qualname__.__eq__,       ["Match.end"],       true, "re.Match.end.__qualname__ == 'Match.end' (return end of match; len=9; shortest Match method qualname)"]
    - [mat_end_qlen,      Match.end.__qualname__.__len__,      [],                   9,    "re.Match.end.__qualname__.__len__() == 9 ('Match.end' has 9 characters; shortest Match method qualname)"]
    - [mat_span_qeq,      Match.span.__qualname__.__eq__,      ["Match.span"],      true, "re.Match.span.__qualname__ == 'Match.span' (return (start, end) tuple; len=10)"]
    - [mat_span_qlen,     Match.span.__qualname__.__len__,     [],                   10,   "re.Match.span.__qualname__.__len__() == 10 ('Match.span' has 10 characters)"]
    - [mat_group_qeq,     Match.group.__qualname__.__eq__,     ["Match.group"],     true, "re.Match.group.__qualname__ == 'Match.group' (return the string matched by the group; len=11)"]
    - [mat_group_qlen,    Match.group.__qualname__.__len__,    [],                   11,   "re.Match.group.__qualname__.__len__() == 11 ('Match.group' has 11 characters; tied with Match.start)"]
    - [mat_start_qeq,     Match.start.__qualname__.__eq__,     ["Match.start"],     true, "re.Match.start.__qualname__ == 'Match.start' (return start of match; len=11; tied with group)"]
    - [mat_start_qlen,    Match.start.__qualname__.__len__,    [],                   11,   "re.Match.start.__qualname__.__len__() == 11 (tied with Match.group at 11)"]
    - [mat_groups_qeq,    Match.groups.__qualname__.__eq__,    ["Match.groups"],    true, "re.Match.groups.__qualname__ == 'Match.groups' (return tuple of all groups; len=12)"]
    - [mat_groups_qlen,   Match.groups.__qualname__.__len__,   [],                   12,   "re.Match.groups.__qualname__.__len__() == 12 ('Match.groups' has 12 characters; tied with Match.expand)"]
    - [mat_expand_qeq,    Match.expand.__qualname__.__eq__,    ["Match.expand"],    true, "re.Match.expand.__qualname__ == 'Match.expand' (return string by expanding template; len=12; tied with groups)"]
    - [mat_expand_qlen,   Match.expand.__qualname__.__len__,   [],                   12,   "re.Match.expand.__qualname__.__len__() == 12 (tied with Match.groups at 12)"]
    - [mat_gdict_qeq,     Match.groupdict.__qualname__.__eq__, ["Match.groupdict"], true, "re.Match.groupdict.__qualname__ == 'Match.groupdict' (return dict of named groups; len=15; longest Match method qualname)"]
    - [mat_gdict_qlen,    Match.groupdict.__qualname__.__len__,[],                   15,   "re.Match.groupdict.__qualname__.__len__() == 15 ('Match.groupdict' has 15 characters; longest Match method qualname)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra147.Pattern.name_eq_Pattern:
  description: "re.Pattern.__name__ == 'Pattern' (len=7) — re.Pattern is the compiled regex type returned by re.compile(); it was exposed directly in the re module namespace in Python 3.7+. Its __name__ is 'Pattern', not 're.Pattern', as the class name does not include the module prefix."
  category: class_identity
  kind: python_call_eq
  function: Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra147.Pattern.doc_len_35:
  description: "re.Pattern.__doc__.__len__() == 35 ('Compiled regular expression object.' — the complete exact docstring, including the trailing period; at 35 characters it is notably shorter than re.Match.__doc__ (92 characters) despite Pattern being the more central type)"
  category: doc_identity
  kind: python_call_eq
  function: Pattern.__doc__.__len__
  args: []
  expected: 35

invariant re_extra147.Pattern.mro_len_2:
  description: "re.Pattern.__mro__.__len__() == 2 (MRO is [Pattern, object]; Pattern is a C extension type that directly subclasses object with no intermediate abstract base classes; this contrasts with re.RegexFlag whose MRO has 7 entries due to the enum inheritance chain)"
  category: class_identity
  kind: python_call_eq
  function: "Pattern.__mro__.__len__"
  args: []
  expected: 2

invariant re_extra147.Match.doc_len_92:
  description: "re.Match.__doc__.__len__() == 92 (the Match docstring reads: 'The result of re.match() and re.search().\\nMatch objects always have a boolean value of True.' — at 92 characters it is significantly longer than re.Pattern.__doc__ (35))"
  category: doc_identity
  kind: python_call_eq
  function: Match.__doc__.__len__
  args: []
  expected: 92

invariant re_extra147.Match.name_eq_Match:
  description: "re.Match.__name__ == 'Match' (len=5) — re.Match is the type of objects returned by successful match operations; its __name__ 'Match' is 2 characters shorter than re.Pattern.__name__ 'Pattern' (7)"
  category: class_identity
  kind: python_call_eq
  function: Match.__name__.__eq__
  args: ["Match"]
  expected: true

invariant re_extra147.Pattern.fullmatch_qualname_len_17:
  description: "re.Pattern.fullmatch.__qualname__.__len__() == 17 ('Pattern.fullmatch' has 17 characters; the longest Pattern method qualname; 'Pattern.' prefix (8) + 'fullmatch' (9) = 17; fullmatch was added in Python 3.4 to match the entire string)"
  category: qualname
  kind: python_call_eq
  function: Pattern.fullmatch.__qualname__.__len__
  args: []
  expected: 17

invariant re_extra147.Pattern.sub_qualname_len_11:
  description: "re.Pattern.sub.__qualname__.__len__() == 11 ('Pattern.sub' has 11 characters; the shortest Pattern method qualname; 'Pattern.' prefix (8) + 'sub' (3) = 11)"
  category: qualname
  kind: python_call_eq
  function: Pattern.sub.__qualname__.__len__
  args: []
  expected: 11

invariant re_extra147.Match.groupdict_qualname_len_15:
  description: "re.Match.groupdict.__qualname__.__len__() == 15 ('Match.groupdict' has 15 characters; the longest Match method qualname; 'Match.' prefix (6) + 'groupdict' (9) = 15; groupdict() returns a dictionary mapping group names to matched strings)"
  category: qualname
  kind: python_call_eq
  function: Match.groupdict.__qualname__.__len__
  args: []
  expected: 15

