spec: concurrent_futures_extra256
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "concurrent.futures.Executor.__name__ == 'Executor' (len=8); __module__ == 'concurrent.futures._base' (len=24); __bases__[0].__name__ == 'object' (len=6)."
    - "Executor.submit.__qualname__ == 'Executor.submit' (len=15); Executor.map.__qualname__ == 'Executor.map' (len=12, shortest); Executor.shutdown.__qualname__ == 'Executor.shutdown' (len=17, longest)."
    - "concurrent.futures.wait.__name__ == 'wait' (len=4); __qualname__ == 'wait' (len=4); __module__ == 'concurrent.futures._base' (len=24); __class__.__name__ == 'function'."
    - "concurrent.futures.as_completed.__name__ == 'as_completed' (len=12); __qualname__ == 'as_completed' (len=12); __class__.__name__ == 'function'."
    - "as_completed.__name__ length (12) equals Executor.map.__qualname__ length (12) — numeric coincidence."
    - "Executor.__module__ length (24) equals concurrent.futures.wait.__module__ length (24) — both 'concurrent.futures._base'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Executor class identity
#
# concurrent.futures.Executor.__name__ == 'Executor' (len=8)
# concurrent.futures.Executor.__module__ == 'concurrent.futures._base' (len=24)
# concurrent.futures.Executor.__bases__[0].__name__ == 'object' (len=6)
# concurrent.futures.Executor.submit.__qualname__ == 'Executor.submit' (len=15)
# concurrent.futures.Executor.map.__qualname__ == 'Executor.map' (len=12)
# concurrent.futures.Executor.shutdown.__qualname__ == 'Executor.shutdown' (len=17)
# ---------------------------------------------------------------------------

table concurrent_futures_extra256.executor_class_identity:
  description: "concurrent.futures.Executor(len=8) class identity — inherits from object(len=6); defined in concurrent.futures._base(len=24); map.__qualname__ len=12 (shortest), submit len=15, shutdown len=17 (longest); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cf256ex

  columns: [id, function, args, expected, description]
  rows:
    - [ex_name_eq,          Executor.__name__.__eq__,                              ["Executor"],                   true, "concurrent.futures.Executor.__name__ == 'Executor'; verified with Python 3.14.3"]
    - [ex_name_len,         Executor.__name__.__len__,                             [],                             8,    "concurrent.futures.Executor.__name__.__len__() == 8; verified with Python 3.14.3"]
    - [ex_mod_eq,           Executor.__module__.__eq__,                            ["concurrent.futures._base"],   true, "concurrent.futures.Executor.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [ex_mod_len,          Executor.__module__.__len__,                           [],                             24,   "concurrent.futures.Executor.__module__.__len__() == 24; verified with Python 3.14.3"]
    - [ex_base_eq,          "Executor.__bases__[0].__name__.__eq__",               ["object"],                     true, "concurrent.futures.Executor.__bases__[0].__name__ == 'object' — Executor inherits directly from object; verified with Python 3.14.3"]
    - [ex_base_len,         "Executor.__bases__[0].__name__.__len__",              [],                             6,    "concurrent.futures.Executor.__bases__[0].__name__.__len__() == 6; verified with Python 3.14.3"]
    - [ex_submit_name_eq,   Executor.submit.__name__.__eq__,                       ["submit"],                     true, "concurrent.futures.Executor.submit.__name__ == 'submit'; verified with Python 3.14.3"]
    - [ex_submit_name_len,  Executor.submit.__name__.__len__,                      [],                             6,    "concurrent.futures.Executor.submit.__name__.__len__() == 6; verified with Python 3.14.3"]
    - [ex_submit_qn_eq,     Executor.submit.__qualname__.__eq__,                   ["Executor.submit"],            true, "concurrent.futures.Executor.submit.__qualname__ == 'Executor.submit'; verified with Python 3.14.3"]
    - [ex_submit_qn_len,    Executor.submit.__qualname__.__len__,                  [],                             15,   "concurrent.futures.Executor.submit.__qualname__.__len__() == 15; verified with Python 3.14.3"]
    - [ex_map_name_eq,      Executor.map.__name__.__eq__,                          ["map"],                        true, "concurrent.futures.Executor.map.__name__ == 'map'; verified with Python 3.14.3"]
    - [ex_map_name_len,     Executor.map.__name__.__len__,                         [],                             3,    "concurrent.futures.Executor.map.__name__.__len__() == 3 — shortest method name; verified with Python 3.14.3"]
    - [ex_map_qn_eq,        Executor.map.__qualname__.__eq__,                      ["Executor.map"],               true, "concurrent.futures.Executor.map.__qualname__ == 'Executor.map'; verified with Python 3.14.3"]
    - [ex_map_qn_len,       Executor.map.__qualname__.__len__,                     [],                             12,   "concurrent.futures.Executor.map.__qualname__.__len__() == 12 — shortest Executor qualname; equals as_completed.__name__ length; verified with Python 3.14.3"]
    - [ex_shutdown_name_eq, Executor.shutdown.__name__.__eq__,                     ["shutdown"],                   true, "concurrent.futures.Executor.shutdown.__name__ == 'shutdown'; verified with Python 3.14.3"]
    - [ex_shutdown_name_len,Executor.shutdown.__name__.__len__,                    [],                             8,    "concurrent.futures.Executor.shutdown.__name__.__len__() == 8 — same as Executor.__name__ length; verified with Python 3.14.3"]
    - [ex_shutdown_qn_eq,   Executor.shutdown.__qualname__.__eq__,                 ["Executor.shutdown"],          true, "concurrent.futures.Executor.shutdown.__qualname__ == 'Executor.shutdown'; verified with Python 3.14.3"]
    - [ex_shutdown_qn_len,  Executor.shutdown.__qualname__.__len__,                [],                             17,   "concurrent.futures.Executor.shutdown.__qualname__.__len__() == 17 — longest Executor qualname; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.wait and concurrent.futures.as_completed function identity
#
# concurrent.futures.wait.__name__ == 'wait' (len=4)
# concurrent.futures.wait.__qualname__ == 'wait' (len=4)
# concurrent.futures.wait.__module__ == 'concurrent.futures._base' (len=24)
# concurrent.futures.wait.__class__.__name__ == 'function'
# concurrent.futures.as_completed.__name__ == 'as_completed' (len=12)
# concurrent.futures.as_completed.__qualname__ == 'as_completed' (len=12)
# concurrent.futures.as_completed.__class__.__name__ == 'function'
# ---------------------------------------------------------------------------

table concurrent_futures_extra256.module_functions_identity:
  description: "concurrent.futures.wait(len=4) and as_completed(len=12) function identity — both are plain functions (class='function') in concurrent.futures._base(len=24); wait.__name__ == wait.__qualname__ (both 'wait', len=4); as_completed.__name__ == as_completed.__qualname__ (both 'as_completed', len=12); as_completed name length (12) equals Executor.map qualname length (12); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cf256fn

  columns: [id, function, args, expected, description]
  rows:
    - [w_name_eq,           wait.__name__.__eq__,                                  ["wait"],                       true, "concurrent.futures.wait.__name__ == 'wait'; verified with Python 3.14.3"]
    - [w_name_len,          wait.__name__.__len__,                                 [],                             4,    "concurrent.futures.wait.__name__.__len__() == 4 — shortest name in spec; verified with Python 3.14.3"]
    - [w_qn_eq,             wait.__qualname__.__eq__,                              ["wait"],                       true, "concurrent.futures.wait.__qualname__ == 'wait' — module-level function, qualname equals name; verified with Python 3.14.3"]
    - [w_qn_len,            wait.__qualname__.__len__,                             [],                             4,    "concurrent.futures.wait.__qualname__.__len__() == 4 — qualname equals name for module-level function; verified with Python 3.14.3"]
    - [w_mod_eq,            wait.__module__.__eq__,                                ["concurrent.futures._base"],   true, "concurrent.futures.wait.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [w_mod_len,           wait.__module__.__len__,                               [],                             24,   "concurrent.futures.wait.__module__.__len__() == 24 — same as Executor.__module__ length; verified with Python 3.14.3"]
    - [w_cls_eq,            wait.__class__.__name__.__eq__,                        ["function"],                   true, "concurrent.futures.wait.__class__.__name__ == 'function' — plain Python function; verified with Python 3.14.3"]
    - [ac_name_eq,          as_completed.__name__.__eq__,                          ["as_completed"],               true, "concurrent.futures.as_completed.__name__ == 'as_completed'; verified with Python 3.14.3"]
    - [ac_name_len,         as_completed.__name__.__len__,                         [],                             12,   "concurrent.futures.as_completed.__name__.__len__() == 12 — equals Executor.map qualname length; verified with Python 3.14.3"]
    - [ac_qn_eq,            as_completed.__qualname__.__eq__,                      ["as_completed"],               true, "concurrent.futures.as_completed.__qualname__ == 'as_completed' — module-level function; verified with Python 3.14.3"]
    - [ac_qn_len,           as_completed.__qualname__.__len__,                     [],                             12,   "concurrent.futures.as_completed.__qualname__.__len__() == 12 — qualname equals name for module-level function; verified with Python 3.14.3"]
    - [ac_cls_eq,           as_completed.__class__.__name__.__eq__,                ["function"],                   true, "concurrent.futures.as_completed.__class__.__name__ == 'function' — plain Python function; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra256
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra256.executor_base_is_object:
  description: "concurrent.futures.Executor.__bases__[0].__name__.__eq__('object') returns True — Executor is a plain abstract base class inheriting directly from object(len=6); it is not a subclass of concurrent.futures.Future or any other framework class; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Executor.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant concurrent_futures_extra256.wait_qualname_equals_name:
  description: "concurrent.futures.wait.__qualname__.__eq__('wait') returns True — wait is a module-level function so its __qualname__ equals its __name__ (both 'wait', len=4); this distinguishes it from class methods where qualname has a 'ClassName.' prefix; same holds for as_completed; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: wait.__qualname__.__eq__
  args: ["wait"]
  expected: true

invariant concurrent_futures_extra256.executor_shutdown_longest_qualname:
  description: "concurrent.futures.Executor.shutdown.__qualname__.__len__() == 17 — 'Executor.shutdown' (len=17) is the longest Executor method qualname; Executor.map is shortest (len=12); Executor.submit is middle (len=15); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Executor.shutdown.__qualname__.__len__
  args: []
  expected: 17
