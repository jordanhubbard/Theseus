spec: direction
version: ">=2.0.1"
backend: node(direction)

docs: https://www.npmjs.com/package/direction

provenance:
  derived_from:
    - "direction README — https://www.npmjs.com/package/direction"
    - "Test vectors verified with direction via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "direction source"
  notes:
    - "direction is an npm package. Install: npm install direction"
    - "Returns 'ltr', 'rtl', or 'neutral' based on the text direction of the input string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table direction.direction:
  kind: node_module_call_eq
  function: direction
  category: text
  id_prefix: dir

  columns: [id, args, expected]
  rows:
    - [ltr,      ["hello"],   "ltr"]
    - [rtl,      ["مرحبا"],   "rtl"]
    - [neutral,  ["1234"],    "neutral"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:24:50Z
  iterations: 2
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 2 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
