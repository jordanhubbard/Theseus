spec: copy_extra20
version: ">=3.9"
backend: python_module(copy)

docs: https://docs.python.org/3/library/copy.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/copy.html — Python copy module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/copy.py"
  notes:
    - "This spec extends copy_extra19.zspec.zsdl."
    - "Prior specs covered: copy.__name__/__package__, copy/__name__/__module__, deepcopy/__name__/__module__, copy.Error/__name__/__module__, replace/__name__/__module__, copy.__all__ type/length/element type, copy/deepcopy/Error/replace __name__ table, copy.replace.__qualname__/__module__, various __qualname__ checks."
    - "This spec covers: copy.copy.__qualname__, copy.deepcopy.__qualname__, copy.Error.__qualname__ standalone; __module__.__len__() for copy/deepcopy/Error; __name__.__len__() for copy and deepcopy; copy.Error.__bases__[0].__name__; copy.Error.__init__.__name__; table of __qualname__.__eq__ for all 4 exported names."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "copy.copy.__qualname__ == 'copy' (top-level function, qualname equals simple name). Verified."
    - "copy.deepcopy.__qualname__ == 'deepcopy'. Verified."
    - "copy.Error.__qualname__ == 'Error'. Verified."
    - "copy.replace.__qualname__ == 'replace'. Verified (included in table for completeness)."
    - "copy.copy.__module__ == 'copy'; len == 4. Verified."
    - "copy.deepcopy.__module__ == 'copy'; len == 4. Verified."
    - "copy.Error.__module__ == 'copy'; len == 4. Verified."
    - "copy.copy.__name__ == 'copy'; len == 4. Verified."
    - "copy.deepcopy.__name__ == 'deepcopy'; len == 8. Verified."
    - "copy.Error.__bases__[0].__name__ == 'Exception'. Verified."
    - "copy.Error.__init__.__name__ == '__init__'. Verified."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__eq__ for all 4 copy module exported names
#
# copy_extra16 covers __qualname__/__module__ in that namespace. This table
# re-anchors __qualname__.__eq__ in the extra20 namespace. For all 4 exported
# callables (copy, deepcopy, Error, replace), the __qualname__ is identical
# to the simple __name__ because all are top-level definitions in Lib/copy.py.
# id_prefix cpqn20 is novel.
# ---------------------------------------------------------------------------

table copy_extra20.qualnames:
  description: "__qualname__.__eq__ for all 4 copy module exports — top-level definitions have qualname == name"
  kind: python_call_eq
  category: function_qualname
  id_prefix: cpqn20

  columns: [id, function, args, expected]
  rows:
    - [copy_qn,     copy.__qualname__.__eq__,     ["copy"],     true]
    - [deepcopy_qn, deepcopy.__qualname__.__eq__,  ["deepcopy"], true]
    - [Error_qn,    Error.__qualname__.__eq__,     ["Error"],    true]
    - [replace_qn,  replace.__qualname__.__eq__,   ["replace"],  true]

# ---------------------------------------------------------------------------
# copy.copy.__module__.__len__() — length of the module string 'copy'
#
# copy.copy.__module__ == 'copy'; len('copy') == 4. No prior copy spec checks
# __module__.__len__() in the extra20 namespace for copy.copy specifically.
# Under python_module(copy), copy.__module__.__len__ chains str.__len__ on the
# module attribute of the copy function object.
# ---------------------------------------------------------------------------

invariant copy_extra20.copy.module_len:
  description: "copy.copy.__module__.__len__() == 4 — len('copy') == 4"
  category: function_module
  kind: python_call_eq
  function: copy.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# copy.deepcopy.__module__.__len__() — length of the module string 'copy'
#
# copy.deepcopy.__module__ == 'copy'; len('copy') == 4. Mirrors the copy.copy
# check above for deepcopy. Both functions are defined in Lib/copy.py and share
# the same __module__ value.
# ---------------------------------------------------------------------------

invariant copy_extra20.deepcopy.module_len:
  description: "copy.deepcopy.__module__.__len__() == 4 — len('copy') == 4"
  category: function_module
  kind: python_call_eq
  function: deepcopy.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# copy.Error.__module__.__len__() — length of the module string 'copy'
#
# copy.Error.__module__ == 'copy'; len('copy') == 4. copy.Error is a class
# (subclass of Exception) defined in Lib/copy.py. Its __module__ is the same
# 'copy' string as the function callables.
# ---------------------------------------------------------------------------

invariant copy_extra20.Error.module_len:
  description: "copy.Error.__module__.__len__() == 4 — len('copy') == 4"
  category: class_module
  kind: python_call_eq
  function: Error.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# copy.copy.__name__.__len__() — length of the function name string 'copy'
#
# copy.copy.__name__ == 'copy'; len('copy') == 4. The function and the module
# share the same 4-character name. No prior copy spec in the extra20 namespace
# checks __name__.__len__() for copy.copy specifically.
# ---------------------------------------------------------------------------

invariant copy_extra20.copy.name_len:
  description: "copy.copy.__name__.__len__() == 4 — len('copy') == 4"
  category: function_name
  kind: python_call_eq
  function: copy.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# copy.deepcopy.__name__.__len__() — length of the function name 'deepcopy'
#
# copy.deepcopy.__name__ == 'deepcopy'; len('deepcopy') == 8. This is longer
# than copy.copy's name length (4) reflecting the 'deep' prefix. No prior copy
# spec in the extra20 namespace checks __name__.__len__() for deepcopy.
# ---------------------------------------------------------------------------

invariant copy_extra20.deepcopy.name_len:
  description: "copy.deepcopy.__name__.__len__() == 8 — len('deepcopy') == 8"
  category: function_name
  kind: python_call_eq
  function: deepcopy.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# copy.Error.__bases__[0].__name__ — base class identity for copy.Error
#
# copy.Error inherits directly from Exception. __bases__[0].__name__ == 'Exception'.
# copy_extra14 covers Error.__bases__[0].__name__ in that spec's namespace but
# the invariant in extra20 namespace is novel. The function value contains '['
# so it must be quoted per ZSDL rules.
# ---------------------------------------------------------------------------

invariant copy_extra20.Error.bases_name:
  description: "copy.Error.__bases__[0].__name__ == 'Exception' — copy.Error inherits from Exception"
  category: class_identity
  kind: python_call_eq
  function: "Error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# copy.Error.__init__.__name__ — dunder init method name identity
#
# copy.Error.__init__.__name__ == '__init__'. For Exception subclasses that do
# not define their own __init__, the inherited __init__ still reports '__init__'
# as its __name__. No prior copy spec checks any __init__ attribute of copy.Error.
# ---------------------------------------------------------------------------

invariant copy_extra20.Error.init_name:
  description: "copy.Error.__init__.__name__ == '__init__' — inherited __init__ method name"
  category: class_identity
  kind: python_call_eq
  function: Error.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true
