spec: inspect_extra3
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/inspect.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect.zspec.zsdl — covers function names (ismodule, isclass, ismethod, isfunction, isgeneratorfunction, isgenerator, iscoroutinefunction, iscoroutine, isframe, iscode, isbuiltin, signature, getmembers, getmodule, getsourcefile, getfile, getdoc, getcomments, stack, currentframe, getfullargspec, Parameter, Signature, FrameInfo)"
    - "inspect_extra.zspec.zsdl — covers ismodule(os)==True, isclass(int)==True, isfunction(lambda: None)==True, isbuiltin(len)==True, ismethod on bound method==True, signature(len).__class__.__name__=='Signature', Parameter/__name__, Signature/__name__, getmembers/__name__"
    - "inspect_extra2.zspec.zsdl — covers inspect.isclass(str)==True, inspect.isclass(42)==False, inspect.isfunction(print)==False, inspect.isbuiltin(print)==True, inspect.getdoc(len).__class__.__name__=='str', inspect.Parameter/__module__, inspect.Signature/__module__, inspect.CO_OPTIMIZED value, inspect.CO_NEWLOCALS value"
  notes:
    - "This spec extends inspect.zspec.zsdl, inspect_extra.zspec.zsdl, and inspect_extra2.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "inspect.ismodule.__name__ == 'ismodule' — module-level Python function."
    - "inspect.isclass.__name__ == 'isclass'."
    - "inspect.isfunction.__name__ == 'isfunction'."
    - "inspect.isbuiltin.__name__ == 'isbuiltin'."
    - "inspect.signature.__name__ == 'signature'."
    - "inspect.getmembers.__name__ == 'getmembers'."
    - "inspect.getdoc.__name__ == 'getdoc'."
    - "inspect.currentframe.__name__ == 'currentframe'."
    - "inspect.stack.__name__ == 'stack'."
    - "inspect.ismodule.__module__ == 'inspect' — all inspect predicates are defined in inspect."
    - "inspect.isclass.__module__ == 'inspect'."
    - "inspect.signature.__module__ == 'inspect'."
    - "inspect.Parameter.__name__ == 'Parameter' — class defined in inspect."
    - "inspect.Signature.__name__ == 'Signature' — class defined in inspect."
    - "inspect.FrameInfo.__name__ == 'FrameInfo' — namedtuple-like class defined in inspect."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ checks — new coverage not in prior inspect specs
#
# inspect_extra covers: getmembers (via invariant), Parameter, Signature.
# New here: ismodule, isclass, isfunction, isbuiltin, signature, getdoc,
# currentframe, stack.
# ---------------------------------------------------------------------------

table inspect_extra3.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [ismodule,      ismodule.__name__.__eq__,      ["ismodule"],      true]
    - [isclass,       isclass.__name__.__eq__,       ["isclass"],       true]
    - [isfunction,    isfunction.__name__.__eq__,    ["isfunction"],    true]
    - [isbuiltin,     isbuiltin.__name__.__eq__,     ["isbuiltin"],     true]
    - [signature,     signature.__name__.__eq__,     ["signature"],     true]
    - [getmembers,    getmembers.__name__.__eq__,    ["getmembers"],    true]
    - [getdoc,        getdoc.__name__.__eq__,        ["getdoc"],        true]
    - [currentframe,  currentframe.__name__.__eq__,  ["currentframe"],  true]
    - [stack,         stack.__name__.__eq__,         ["stack"],         true]

# ---------------------------------------------------------------------------
# Function __module__ checks
# ---------------------------------------------------------------------------

table inspect_extra3.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [ismodule,   ismodule.__module__.__eq__,   ["inspect"], true]
    - [isclass,    isclass.__module__.__eq__,    ["inspect"], true]
    - [signature,  signature.__module__.__eq__,  ["inspect"], true]

# ---------------------------------------------------------------------------
# Class __name__ checks — Parameter, Signature, FrameInfo
# ---------------------------------------------------------------------------

invariant inspect_extra3.Parameter.name:
  description: "inspect.Parameter.__name__ == 'Parameter'"
  category: class_names
  kind: python_call_eq
  function: Parameter.__name__.__eq__
  args: ["Parameter"]
  expected: true

invariant inspect_extra3.Signature.name:
  description: "inspect.Signature.__name__ == 'Signature'"
  category: class_names
  kind: python_call_eq
  function: Signature.__name__.__eq__
  args: ["Signature"]
  expected: true

invariant inspect_extra3.FrameInfo.name:
  description: "inspect.FrameInfo.__name__ == 'FrameInfo'"
  category: class_names
  kind: python_call_eq
  function: FrameInfo.__name__.__eq__
  args: ["FrameInfo"]
  expected: true
