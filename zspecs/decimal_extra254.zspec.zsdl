spec: decimal_extra254
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra.zspec.zsdl — covers Decimal predicates, to_eng_string, Context/BasicContext/ExtendedContext class names"
    - "decimal_extra253.zspec.zsdl — covers Context class identity, getcontext defaults, ROUND_* constants"
  notes:
    - "decimal.Decimal arithmetic dunder methods are wrapper_descriptor objects (C implementation)."
    - "All six operators __add__/__sub__/__mul__/__truediv__/__mod__/__pow__ have __class__.__name__ == 'wrapper_descriptor'."
    - "Each method __name__ equals the bare dunder name (e.g. '__add__')."
    - "Each method __qualname__ is 'Decimal.<dunder>' (e.g. 'Decimal.__add__')."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal arithmetic methods — __name__
# ---------------------------------------------------------------------------

table decimal_extra254.Decimal.arith_names:
  description: "__add__/__sub__/__mul__/__truediv__/__mod__/__pow__ __name__ equals bare dunder"
  kind: python_call_eq
  category: identity
  id_prefix: arith_name

  columns: [id, function, args, expected, description]
  rows:
    - [add_name,      Decimal.__add__.__name__.__eq__,      ["__add__"],      true, "__add__ __name__"]
    - [sub_name,      Decimal.__sub__.__name__.__eq__,      ["__sub__"],      true, "__sub__ __name__"]
    - [mul_name,      Decimal.__mul__.__name__.__eq__,      ["__mul__"],      true, "__mul__ __name__"]
    - [truediv_name,  Decimal.__truediv__.__name__.__eq__,  ["__truediv__"],  true, "__truediv__ __name__"]
    - [mod_name,      Decimal.__mod__.__name__.__eq__,      ["__mod__"],      true, "__mod__ __name__"]
    - [pow_name,      Decimal.__pow__.__name__.__eq__,      ["__pow__"],      true, "__pow__ __name__"]

# ---------------------------------------------------------------------------
# Decimal arithmetic methods — __qualname__
# ---------------------------------------------------------------------------

table decimal_extra254.Decimal.arith_qualnames:
  description: "__add__/__sub__/__mul__/__truediv__/__mod__/__pow__ qualnames are 'Decimal.<dunder>'"
  kind: python_call_eq
  category: identity
  id_prefix: arith_qualname

  columns: [id, function, args, expected, description]
  rows:
    - [add_qualname,      Decimal.__add__.__qualname__.__eq__,      ["Decimal.__add__"],      true, "__add__ qualname"]
    - [sub_qualname,      Decimal.__sub__.__qualname__.__eq__,      ["Decimal.__sub__"],      true, "__sub__ qualname"]
    - [mul_qualname,      Decimal.__mul__.__qualname__.__eq__,      ["Decimal.__mul__"],      true, "__mul__ qualname"]
    - [truediv_qualname,  Decimal.__truediv__.__qualname__.__eq__,  ["Decimal.__truediv__"],  true, "__truediv__ qualname"]
    - [mod_qualname,      Decimal.__mod__.__qualname__.__eq__,      ["Decimal.__mod__"],      true, "__mod__ qualname"]
    - [pow_qualname,      Decimal.__pow__.__qualname__.__eq__,      ["Decimal.__pow__"],      true, "__pow__ qualname"]

# ---------------------------------------------------------------------------
# Decimal arithmetic methods — __class__.__name__ (wrapper_descriptor)
# ---------------------------------------------------------------------------

table decimal_extra254.Decimal.arith_class_names:
  description: "arithmetic dunder methods are wrapper_descriptor objects (C implementation)"
  kind: python_call_eq
  category: identity
  id_prefix: arith_class

  columns: [id, function, args, expected, description]
  rows:
    - [add_class,      Decimal.__add__.__class__.__name__.__eq__,      ["wrapper_descriptor"], true, "__add__ is wrapper_descriptor"]
    - [sub_class,      Decimal.__sub__.__class__.__name__.__eq__,      ["wrapper_descriptor"], true, "__sub__ is wrapper_descriptor"]
    - [mul_class,      Decimal.__mul__.__class__.__name__.__eq__,      ["wrapper_descriptor"], true, "__mul__ is wrapper_descriptor"]
    - [truediv_class,  Decimal.__truediv__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true, "__truediv__ is wrapper_descriptor"]
    - [mod_class,      Decimal.__mod__.__class__.__name__.__eq__,      ["wrapper_descriptor"], true, "__mod__ is wrapper_descriptor"]
    - [pow_class,      Decimal.__pow__.__class__.__name__.__eq__,      ["wrapper_descriptor"], true, "__pow__ is wrapper_descriptor"]
