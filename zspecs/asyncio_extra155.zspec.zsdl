table asyncio_extra155.asyncio_abstract_event_loop_policy_identity:
  description: "asyncio.AbstractEventLoopPolicy class identity checks in asyncioaelp155 namespace — asyncio.AbstractEventLoopPolicy.__name__=='_AbstractEventLoopPolicy' (len=24; note leading underscore — the public name AbstractEventLoopPolicy is an alias for the private class '_AbstractEventLoopPolicy'; longest name in this spec: _AbstractEventLoopPolicy(24) > AbstractEventLoop(17) > BaseEventLoop(13)); asyncio.AbstractEventLoopPolicy.__module__=='asyncio.events' (len=14; same module as AbstractEventLoop — both are defined in Lib/asyncio/events.py); asyncio.AbstractEventLoopPolicy.__bases__[0].__name__=='object' (AbstractEventLoopPolicy inherits directly from object; it defines the interface for policy objects that control how event loops are created and retrieved per-thread); note: AbstractEventLoopPolicy is deprecated as of Python 3.12 (slated for removal in Python 3.16); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioaelp155

  columns: [id, function, args, expected, description]
  rows:
    - [aelp_name_eq,   asyncio.AbstractEventLoopPolicy.__name__.__eq__,                ["_AbstractEventLoopPolicy"],  true,  "asyncio.AbstractEventLoopPolicy.__name__ == '_AbstractEventLoopPolicy' (len=24; leading underscore — private impl class); verified with Python 3.14.3"]
    - [aelp_mod_eq,    asyncio.AbstractEventLoopPolicy.__module__.__eq__,               ["asyncio.events"],             true,  "asyncio.AbstractEventLoopPolicy.__module__ == 'asyncio.events' (len=14; same module as AbstractEventLoop); verified with Python 3.14.3"]
    - [aelp_base_eq,   "asyncio.AbstractEventLoopPolicy.__bases__[0].__name__.__eq__",  ["object"],                     true,  "asyncio.AbstractEventLoopPolicy.__bases__[0].__name__ == 'object' (inherits from object); verified with Python 3.14.3"]
    - [aelp_name_len,  asyncio.AbstractEventLoopPolicy.__name__.__len__,                [],                             24,    "asyncio.AbstractEventLoopPolicy.__name__.__len__() == 24 ('_AbstractEventLoopPolicy'; with leading underscore); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra155
# ---------------------------------------------------------------------------

invariant asyncio_extra155.asyncio_AbstractEventLoop_module_is_events:
  description: "asyncio.AbstractEventLoop.__module__.__eq__('asyncio.events') returns True — asyncio.AbstractEventLoop is defined in Lib/asyncio/events.py and its __module__ is 'asyncio.events' (len=14: 'asyncio'=7+'.'=1+'events'=6=14); AbstractEventLoop defines the abstract event loop API (run_forever, call_soon, call_later, create_task, etc.) without providing an implementation; it is the root of the event loop class hierarchy: AbstractEventLoop > object; asyncio.BaseEventLoop.__bases__[0].__name__=='AbstractEventLoop' (BaseEventLoop is the first concrete implementor); compare: asyncio.BaseEventLoop.__module__=='asyncio.base_events' (len=20, 6 chars longer) because the implementation lives in a different submodule; asyncio.AbstractEventLoopPolicy.__module__=='asyncio.events' (same module as AbstractEventLoop — both policy and loop ABCs are in events.py); NEW in extra155: first standalone asyncio.AbstractEventLoop.__module__ identity invariant in asyncioael155 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.AbstractEventLoop.__module__.__eq__
  args: ["asyncio.events"]
  expected: true

invariant asyncio_extra155.asyncio_AbstractEventLoop_bases0_is_object:
  description: "asyncio.AbstractEventLoop.__bases__[0].__name__.__eq__('object') returns True — asyncio.AbstractEventLoop inherits directly from object (single inheritance); AbstractEventLoop is the abstract interface class that defines the full event loop API without implementing it; its abstract methods must be implemented by concrete loop classes; AbstractEventLoop.__bases__[0].__name__=='object' (len=6); compare: asyncio.BaseEventLoop.__bases__[0].__name__=='AbstractEventLoop' (BaseEventLoop is the first concrete child); the full event loop MRO ends with AbstractEventLoop > object; asyncio.AbstractEventLoopPolicy.__bases__[0].__name__=='object' (same — both abstract classes root at object); NEW in extra155: first standalone asyncio.AbstractEventLoop.__bases__[0] name identity invariant in asyncioael155 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.AbstractEventLoop.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant asyncio_extra155.asyncio_BaseEventLoop_module_is_base_events:
  description: "asyncio.BaseEventLoop.__module__.__eq__('asyncio.base_events') returns True — asyncio.BaseEventLoop is defined in Lib/asyncio/base_events.py and its __module__ is 'asyncio.base_events' (len=19: 'asyncio'=7+'.'=1+'base_events'=11=19); BaseEventLoop provides the concrete event loop infrastructure: the _run_once loop, scheduled callbacks, I/O polling delegation, subprocess support, executor integration, and asyncio.Task scheduling; it is NOT a platform-specific loop — the platform-specific loops (like SelectorEventLoop) inherit from BaseSelectorEventLoop which inherits from BaseEventLoop; compare: AbstractEventLoop.__module__=='asyncio.events' (len=14, 5 chars shorter than 'asyncio.base_events'=19); NEW in extra155: first standalone asyncio.BaseEventLoop.__module__ identity invariant in asynciobel155 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.BaseEventLoop.__module__.__eq__
  args: ["asyncio.base_events"]
  expected: true

invariant asyncio_extra155.asyncio_BaseEventLoop_bases0_is_AbstractEventLoop:
  description: "asyncio.BaseEventLoop.__bases__[0].__name__.__eq__('AbstractEventLoop') returns True — asyncio.BaseEventLoop inherits directly from asyncio.AbstractEventLoop; BaseEventLoop.__bases__[0].__name__=='AbstractEventLoop' (len=17); this establishes the primary event loop inheritance chain: BaseEventLoop > AbstractEventLoop > object; BaseEventLoop implements the abstract methods defined by AbstractEventLoop (call_soon, call_later, run_forever, run_until_complete, create_connection, etc.) while leaving platform-specific I/O polling to subclasses; compare: asyncio.AbstractEventLoop.__bases__[0].__name__=='object' (AbstractEventLoop roots at object); asyncio.AbstractEventLoopPolicy.__bases__[0].__name__=='object' (policy ABC also roots at object); NEW in extra155: first standalone asyncio.BaseEventLoop.__bases__[0] name identity invariant in asynciobel155 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.BaseEventLoop.__bases__[0].__name__.__eq__"
  args: ["AbstractEventLoop"]
  expected: true

invariant asyncio_extra155.asyncio_AbstractEventLoopPolicy_module_is_events:
  description: "asyncio.AbstractEventLoopPolicy.__module__.__eq__('asyncio.events') returns True — asyncio.AbstractEventLoopPolicy is defined in Lib/asyncio/events.py; its __module__ is 'asyncio.events' (len=14; same module as asyncio.AbstractEventLoop — both abstract base classes for event loops and policies co-reside in events.py); AbstractEventLoopPolicy defines the interface for controlling how event loops are created and retrieved on a per-thread basis (get_event_loop(), set_event_loop(), new_event_loop()); asyncio.AbstractEventLoopPolicy.__name__=='_AbstractEventLoopPolicy' (len=24; with leading underscore — the public alias points to the private implementation class); note: AbstractEventLoopPolicy is deprecated as of Python 3.12 and slated for removal in Python 3.16; NEW in extra155: first standalone asyncio.AbstractEventLoopPolicy.__module__ identity invariant in asyncioaelp155 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.AbstractEventLoopPolicy.__module__.__eq__
  args: ["asyncio.events"]
  expected: true

