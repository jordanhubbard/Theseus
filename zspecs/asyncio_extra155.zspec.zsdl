spec: asyncio_extra155
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-eventloop.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-eventloop.html — Python asyncio event loop documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/events.py"
    - "CPython source: Lib/asyncio/base_events.py"
  notes:
    - "This spec covers: asyncio.AbstractEventLoop and asyncio.BaseEventLoop class identity, and asyncio.AbstractEventLoopPolicy identity. asyncio.AbstractEventLoop.__name__=='AbstractEventLoop' (len=17); asyncio.AbstractEventLoop.__module__=='asyncio.events' (len=14; defined in Lib/asyncio/events.py — NOT 'asyncio' top-level); asyncio.AbstractEventLoop.__bases__[0].__name__=='object' (AbstractEventLoop inherits directly from object — it is the abstract interface for event loops); asyncio.BaseEventLoop.__name__=='BaseEventLoop' (len=13); asyncio.BaseEventLoop.__module__=='asyncio.base_events' (len=19; defined in Lib/asyncio/base_events.py); asyncio.BaseEventLoop.__bases__[0].__name__=='AbstractEventLoop' (BaseEventLoop inherits from AbstractEventLoop — providing a concrete partial implementation); asyncio.AbstractEventLoopPolicy.__name__=='_AbstractEventLoopPolicy' (len=24; note leading underscore — the class is the private implementation behind the public asyncio.AbstractEventLoopPolicy name); asyncio.AbstractEventLoopPolicy.__module__=='asyncio.events' (len=14; same module as AbstractEventLoop). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.AbstractEventLoop.__module__=='asyncio.events' — AbstractEventLoop is defined in Lib/asyncio/events.py and its __module__ is 'asyncio.events' (len=14: 'asyncio'=7+'.'=1+'events'=6=14); it is the abstract base that defines the event loop API without implementing it; asyncio.BaseEventLoop.__module__=='asyncio.base_events' (len=20) where the partial implementation lives; the platform-specific loop (e.g. asyncio.SelectorEventLoop) then inherits from BaseEventLoop. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.BaseEventLoop.__bases__[0].__name__=='AbstractEventLoop' — BaseEventLoop inherits directly from AbstractEventLoop; the inheritance chain is: SelectorEventLoop > BaseSelectorEventLoop > BaseEventLoop > AbstractEventLoop > object; BaseEventLoop provides the scheduler, callbacks, timers, and task infrastructure while AbstractEventLoop defines the interface; BaseEventLoop.__module__=='asyncio.base_events' (len=19; 5 chars longer than AbstractEventLoop's 'asyncio.events'=14). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.AbstractEventLoopPolicy.__module__=='asyncio.events' — AbstractEventLoopPolicy is defined in Lib/asyncio/events.py, the same module as AbstractEventLoop; its __module__ is 'asyncio.events' (len=14); asyncio.AbstractEventLoopPolicy.__name__=='_AbstractEventLoopPolicy' (len=24; note the leading underscore — the public name 'AbstractEventLoopPolicy' is an alias for the private implementation class '_AbstractEventLoopPolicy'; len('_AbstractEventLoopPolicy')==24, the longest name in this spec: _AbstractEventLoopPolicy(24) > AbstractEventLoop(17) > BaseEventLoop(13)). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.AbstractEventLoop class identity — extra155
#
# asyncio.AbstractEventLoop.__name__.__eq__('AbstractEventLoop')      == True
# asyncio.AbstractEventLoop.__module__.__eq__('asyncio.events')       == True
# asyncio.AbstractEventLoop.__bases__[0].__name__.__eq__('object')    == True
# ---------------------------------------------------------------------------

table asyncio_extra155.asyncio_abstract_event_loop_identity:
  description: "asyncio.AbstractEventLoop class identity checks in asyncioael155 namespace — asyncio.AbstractEventLoop.__name__=='AbstractEventLoop' (len=17; the abstract interface class defining the full event loop API — run_forever, run_until_complete, call_soon, call_later, create_task, etc.); asyncio.AbstractEventLoop.__module__=='asyncio.events' (len=14: 'asyncio'=7+'.'=1+'events'=6=14; defined in Lib/asyncio/events.py, NOT 'asyncio' top-level); asyncio.AbstractEventLoop.__bases__[0].__name__=='object' (len=6; AbstractEventLoop inherits directly from object — it is the root of the event loop class hierarchy, defining abstract methods without implementing them); AbstractEventLoop.__name__.__len__()==17; AbstractEventLoop.__module__.__len__()==14; compare: asyncio.BaseEventLoop.__module__=='asyncio.base_events' (len=20, 6 chars longer); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioael155

  columns: [id, function, args, expected, description]
  rows:
    - [ael_name_eq,   asyncio.AbstractEventLoop.__name__.__eq__,                ["AbstractEventLoop"],  true,  "asyncio.AbstractEventLoop.__name__ == 'AbstractEventLoop' (len=17); verified with Python 3.14.3"]
    - [ael_mod_eq,    asyncio.AbstractEventLoop.__module__.__eq__,               ["asyncio.events"],     true,  "asyncio.AbstractEventLoop.__module__ == 'asyncio.events' (len=14; NOT top-level 'asyncio'); verified with Python 3.14.3"]
    - [ael_base_eq,   "asyncio.AbstractEventLoop.__bases__[0].__name__.__eq__",  ["object"],             true,  "asyncio.AbstractEventLoop.__bases__[0].__name__ == 'object' (inherits from object — abstract interface root); verified with Python 3.14.3"]
    - [ael_name_len,  asyncio.AbstractEventLoop.__name__.__len__,                [],                     17,    "asyncio.AbstractEventLoop.__name__.__len__() == 17 ('AbstractEventLoop'); verified with Python 3.14.3"]
    - [ael_mod_len,   asyncio.AbstractEventLoop.__module__.__len__,              [],                     14,    "asyncio.AbstractEventLoop.__module__.__len__() == 14 ('asyncio.events'); verified with Python 3.14.3"]

