table asyncio_extra155.asyncio_base_event_loop_identity:
  description: "asyncio.BaseEventLoop class identity checks in asynciobel155 namespace — asyncio.BaseEventLoop.__name__=='BaseEventLoop' (len=13; the concrete partial implementation class that provides the scheduler, callbacks, timers, subprocesses, and task infrastructure — platform-specific loops like SelectorEventLoop inherit from it); asyncio.BaseEventLoop.__module__=='asyncio.base_events' (len=19: 'asyncio'=7+'.'=1+'base_events'=11=19; defined in Lib/asyncio/base_events.py); asyncio.BaseEventLoop.__bases__[0].__name__=='AbstractEventLoop' (len=17; BaseEventLoop inherits directly from AbstractEventLoop, implementing most of the abstract interface); BaseEventLoop.__name__.__len__()==13 (4 chars shorter than AbstractEventLoop(17)); module 'asyncio.base_events' (len=19) is longer than 'asyncio.events' (len=14) because 'base_events'=11 > 'events'=6; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciobel155

  columns: [id, function, args, expected, description]
  rows:
    - [bel_name_eq,   asyncio.BaseEventLoop.__name__.__eq__,                ["BaseEventLoop"],       true,  "asyncio.BaseEventLoop.__name__ == 'BaseEventLoop' (len=13); verified with Python 3.14.3"]
    - [bel_mod_eq,    asyncio.BaseEventLoop.__module__.__eq__,               ["asyncio.base_events"], true,  "asyncio.BaseEventLoop.__module__ == 'asyncio.base_events' (defined in Lib/asyncio/base_events.py); verified with Python 3.14.3"]
    - [bel_base_eq,   "asyncio.BaseEventLoop.__bases__[0].__name__.__eq__",  ["AbstractEventLoop"],   true,  "asyncio.BaseEventLoop.__bases__[0].__name__ == 'AbstractEventLoop' (inherits from AbstractEventLoop); verified with Python 3.14.3"]
    - [bel_name_len,  asyncio.BaseEventLoop.__name__.__len__,                [],                      13,    "asyncio.BaseEventLoop.__name__.__len__() == 13 ('BaseEventLoop'; 4 chars shorter than AbstractEventLoop=17); verified with Python 3.14.3"]

