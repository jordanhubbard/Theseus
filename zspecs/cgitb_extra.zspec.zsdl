spec: cgitb_extra
version: ">=3.9,<3.13"
backend: python_module(cgitb)

docs: https://docs.python.org/3/library/cgitb.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/cgitb.html — Python cgitb module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/cgitb.py"
  notes:
    - "The cgitb module was deprecated in Python 3.11 and removed in Python 3.13."
    - "This spec extends cgitb.zspec.zsdl."
    - "cgitb.zspec.zsdl covers: Hook.__name__, Hook.__module__, enable.__name__, reset.__name__, handler.__name__, text.__name__, html.__name__, lookup.__name__; Hook instance format/file attributes."
    - "This spec adds: __qualname__ checks for all module-level functions and the Hook class."
    - "cgitb does not define a public 'disable' function — no vector for disable.__qualname__."
    - "enable.__module__ == 'cgitb' — enable is defined directly in the cgitb module."
    - "Hook.__module__ == 'cgitb' is already in cgitb.zspec.zsdl; not duplicated here."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for module-level functions
# ---------------------------------------------------------------------------

table cgitb_extra.function_qualnames:
  kind: python_call_eq
  category: functions
  id_prefix: fqname

  columns: [id, function, args, expected]
  rows:
    - [enable,  enable.__qualname__.__eq__,  ["enable"],  true]
    - [reset,   reset.__qualname__.__eq__,   ["reset"],   true]
    - [handler, handler.__qualname__.__eq__, ["handler"], true]
    - [text,    text.__qualname__.__eq__,    ["text"],    true]
    - [html,    html.__qualname__.__eq__,    ["html"],    true]

# ---------------------------------------------------------------------------
# __qualname__ check for the Hook class
# ---------------------------------------------------------------------------

table cgitb_extra.class_qualnames:
  kind: python_call_eq
  category: classes
  id_prefix: cqname

  columns: [id, function, args, expected]
  rows:
    - [Hook, Hook.__qualname__.__eq__, ["Hook"], true]

# ---------------------------------------------------------------------------
# __module__ checks for module-level functions
# (cgitb.zspec.zsdl covers Hook.__module__; this spec adds function __module__.)
# ---------------------------------------------------------------------------

table cgitb_extra.function_modules:
  kind: python_call_eq
  category: functions
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [enable,  enable.__module__.__eq__,  ["cgitb"], true]
    - [reset,   reset.__module__.__eq__,   ["cgitb"], true]
    - [handler, handler.__module__.__eq__, ["cgitb"], true]
    - [text,    text.__module__.__eq__,    ["cgitb"], true]
    - [html,    html.__module__.__eq__,    ["cgitb"], true]
