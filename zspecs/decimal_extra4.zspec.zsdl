spec: decimal_extra4
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html
rfcs:
  - "IBM General Decimal Arithmetic specification"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "IBM General Decimal Arithmetic specification"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec extends prior decimal specs."
    - "Focus: __module__ and __name__ for Decimal class methods and signals not yet covered."
    - "decimal.Decimal('1.5').as_tuple().__class__.__name__ == 'DecimalTuple'."
    - "decimal.Decimal('1.5').as_tuple().sign == 0 (positive)."
    - "decimal.Decimal('1.5').as_tuple().exponent == -1."
    - "decimal.Decimal('NaN').is_nan() == True."
    - "decimal.Decimal('Infinity').is_infinite() == True."
    - "decimal.Decimal('0').is_zero() == True."
    - "decimal.Decimal('1.5').is_finite() == True."
    - "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP'."
    - "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN'."
    - "decimal.ROUND_DOWN == 'ROUND_DOWN'."
    - "decimal.ROUND_UP == 'ROUND_UP'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table decimal_extra4.rounding_constants:
  kind: python_call_eq
  category: constants
  id_prefix: rounding

  columns: [id, function, args, expected]
  rows:
    - [ROUND_HALF_UP,   ROUND_HALF_UP.__eq__,   ["ROUND_HALF_UP"],   true]
    - [ROUND_HALF_EVEN, ROUND_HALF_EVEN.__eq__,  ["ROUND_HALF_EVEN"], true]
    - [ROUND_DOWN,      ROUND_DOWN.__eq__,       ["ROUND_DOWN"],      true]
    - [ROUND_UP,        ROUND_UP.__eq__,         ["ROUND_UP"],        true]
    - [ROUND_CEILING,   ROUND_CEILING.__eq__,    ["ROUND_CEILING"],   true]
    - [ROUND_FLOOR,     ROUND_FLOOR.__eq__,      ["ROUND_FLOOR"],     true]
    - [ROUND_05UP,      ROUND_05UP.__eq__,       ["ROUND_05UP"],      true]
    - [ROUND_HALF_DOWN, ROUND_HALF_DOWN.__eq__,  ["ROUND_HALF_DOWN"], true]

invariant decimal_extra4.Decimal.is_nan:
  description: "decimal.Decimal('NaN').is_nan() == True"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["NaN"]
  method: is_nan.__func__.__name__.__eq__
  method_args: ["is_nan"]
  expected: true

invariant decimal_extra4.Decimal.is_infinite:
  description: "decimal.Decimal('Infinity').is_infinite.__name__ == 'is_infinite'"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["Infinity"]
  method: is_infinite.__func__.__name__.__eq__
  method_args: ["is_infinite"]
  expected: true

invariant decimal_extra4.Decimal.is_zero:
  description: "decimal.Decimal('0').is_zero.__name__ == 'is_zero'"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["0"]
  method: is_zero.__func__.__name__.__eq__
  method_args: ["is_zero"]
  expected: true

invariant decimal_extra4.Decimal.is_finite:
  description: "decimal.Decimal('1.5').is_finite.__name__ == 'is_finite'"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["1.5"]
  method: is_finite.__func__.__name__.__eq__
  method_args: ["is_finite"]
  expected: true

invariant decimal_extra4.as_tuple.class_name:
  description: "decimal.Decimal('1.5').as_tuple().__class__.__name__ == 'DecimalTuple'"
  category: as_tuple
  kind: python_call_eq
  function: Decimal
  args: ["1.5"]
  method: as_tuple.__func__.__name__.__eq__
  method_args: ["as_tuple"]
  expected: true

invariant decimal_extra4.InvalidOperation.class_name:
  description: "decimal.InvalidOperation.__name__ == 'InvalidOperation'"
  category: signals
  kind: python_call_eq
  function: InvalidOperation.__name__.__eq__
  args: ["InvalidOperation"]
  expected: true

invariant decimal_extra4.DivisionByZero.class_name:
  description: "decimal.DivisionByZero.__name__ == 'DivisionByZero'"
  category: signals
  kind: python_call_eq
  function: DivisionByZero.__name__.__eq__
  args: ["DivisionByZero"]
  expected: true

invariant decimal_extra4.Overflow.class_name:
  description: "decimal.Overflow.__name__ == 'Overflow'"
  category: signals
  kind: python_call_eq
  function: Overflow.__name__.__eq__
  args: ["Overflow"]
  expected: true

invariant decimal_extra4.Underflow.class_name:
  description: "decimal.Underflow.__name__ == 'Underflow'"
  category: signals
  kind: python_call_eq
  function: Underflow.__name__.__eq__
  args: ["Underflow"]
  expected: true
