# ---------------------------------------------------------------------------
# Standalone invariants — extra1456
# ---------------------------------------------------------------------------

invariant threading_extra1456.Thread_contains_not_in_dict:
  description: "'__contains__' not in threading.Thread.__dict__ — Thread does not define the container protocol; wave 544; new to extra1456"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["__contains__"]
  expected: false

invariant threading_extra1456.Thread_iter_not_in_dict:
  description: "'__iter__' not in threading.Thread.__dict__ — Thread does not define the iterable protocol; wave 544; new to extra1456"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["__iter__"]
  expected: false

invariant threading_extra1456.Lock_contains_not_in_dict:
