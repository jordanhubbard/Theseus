spec: threading_extra1456
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "threading_extra1441.zspec.zsdl — covers __subclasshook__, __instancecheck__, __subclasscheck__ ABC-machinery checks"
    - "threading_extra1426.zspec.zsdl — covers __format__ and __dir__ checks for threading classes"
  notes:
    - "Wave 544 (_extra1456): focuses on __contains__ and __iter__ container/iterable protocol method presence checks for threading classes."
    - "threading.Thread does not define '__contains__' in its own __dict__ — Thread manages thread lifecycle, not a container. Verified Python 3.14.4."
    - "threading.Lock does not define '__contains__' in its own __dict__ — Lock is a synchronization primitive, not a container. Verified Python 3.14.4."
    - "threading.Event does not define '__contains__' in its own __dict__ — Event is a signaling primitive, not a container. Verified Python 3.14.4."
    - "threading.Semaphore does not define '__contains__' in its own __dict__ — Semaphore is a counting synchronization primitive, not a container. Verified Python 3.14.4."
    - "threading.Barrier does not define '__contains__' in its own __dict__ — Barrier is a synchronization primitive, not a container. Verified Python 3.14.4."
    - "threading.Condition does not define '__contains__' in its own __dict__ — Condition is a synchronization primitive, not a container. Verified Python 3.14.4."
    - "None of Thread, Lock, Event, Semaphore, Barrier, Condition define '__iter__' or '__next__' in their own __dict__. Verified Python 3.14.4."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading class __contains__ dict absence
#
# Wave 544 theme: '__contains__' not in own __dict__ for threading classes.
# Thread, Lock, Event, Semaphore, Barrier, and Condition are all
# synchronization primitives or lifecycle managers — none are containers.
# ---------------------------------------------------------------------------

table threading_extra1456.contains_dict_membership:
  description: "threading classes: '__contains__' not in own __dict__ for Thread, Lock, Event, Semaphore, Barrier, Condition; wave 544; new to extra1456"
  kind: python_call_eq
  category: contains_dict_membership
  id_prefix: th1456cd

  columns: [id, function, args, expected, description]
  rows:
    - [th1456cd001,
       "Thread.__dict__.__contains__",
       ["__contains__"],
       false,
       "threading.Thread.__dict__.__contains__('__contains__') == False — Thread manages thread lifecycle; is not a container; no __contains__ in own class __dict__; new to extra1456"]
    - [th1456cd002,
       "Lock.__dict__.__contains__",
       ["__contains__"],
       false,
       "threading.Lock.__dict__.__contains__('__contains__') == False — Lock is a synchronization primitive; is not a container; no __contains__ in own class __dict__; new to extra1456"]
    - [th1456cd003,
       "Event.__dict__.__contains__",
       ["__contains__"],
       false,
       "threading.Event.__dict__.__contains__('__contains__') == False — Event is a signaling primitive; is not a container; no __contains__ in own class __dict__; new to extra1456"]
    - [th1456cd004,
       "Semaphore.__dict__.__contains__",
       ["__contains__"],
       false,
       "threading.Semaphore.__dict__.__contains__('__contains__') == False — Semaphore is a counting synchronization primitive; is not a container; no __contains__ in own class __dict__; new to extra1456"]
    - [th1456cd005,
       "Barrier.__dict__.__contains__",
       ["__contains__"],
       false,
       "threading.Barrier.__dict__.__contains__('__contains__') == False — Barrier is a synchronization primitive; is not a container; no __contains__ in own class __dict__; new to extra1456"]
    - [th1456cd006,
       "Condition.__dict__.__contains__",
       ["__contains__"],
       false,
       "threading.Condition.__dict__.__contains__('__contains__') == False — Condition is a synchronization primitive; is not a container; no __contains__ in own class __dict__; new to extra1456"]
    - [th1456cd007,
       "Thread.__dict__.__contains__",
       ["__iter__"],
       false,
       "threading.Thread.__dict__.__contains__('__iter__') == False — Thread is not iterable; no __iter__ in own class __dict__; new to extra1456"]
    - [th1456cd008,
       "Lock.__dict__.__contains__",
       ["__iter__"],
       false,
       "threading.Lock.__dict__.__contains__('__iter__') == False — Lock is not iterable; no __iter__ in own class __dict__; new to extra1456"]

