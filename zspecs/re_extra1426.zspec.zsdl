spec: re_extra1426
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers __format__ and __dir__ method type/presence for re module classes. All re classes in this batch (error, Pattern, Match) have __format__.__class__.__name__=='method_descriptor' (inherited from object or BaseException; none define __format__ in their own __dict__). re.error inherits from Exception->BaseException->object. re.Pattern and re.Match are C-level types defined in _sre.c. None define '__format__' or '__dir__' in their own __dict__. All verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
    - "re.error.__format__.__class__.__name__=='method_descriptor' — error is a pure-Python exception subclassing Exception. re.Pattern.__format__.__class__.__name__=='method_descriptor' — Pattern is a C-level type (_sre.SRE_Pattern or similar) that inherits __format__ from object. re.Match.__dict__.__contains__('__format__')==False — Match (C-level type) does not define __format__ in its own dict. All verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re class __format__ type and dict presence checks — extra1426
#
# re.error.__format__.__class__.__name__                == 'method_descriptor'
# re.error.__dict__.__contains__('__format__')         == False
# re.Pattern.__format__.__class__.__name__              == 'method_descriptor'
# re.Pattern.__dict__.__contains__('__format__')       == False
# re.Match.__format__.__class__.__name__                == 'method_descriptor'
# re.Match.__dict__.__contains__('__format__')         == False
# ---------------------------------------------------------------------------

table re_extra1426.re_format_type:
  description: "re class __format__ method type and __dict__ presence checks — wave 542 extra1426 theme. re.error.__format__.__class__.__name__=='method_descriptor' (error is a pure-Python exception class subclassing Exception; it inherits __format__ from the BaseException->object chain without overriding it). re.Pattern.__format__.__class__.__name__=='method_descriptor' (Pattern is a C-level type wrapping compiled regex patterns; it inherits object.__format__). re.Match.__format__.__class__.__name__=='method_descriptor' (Match is a C-level type wrapping match objects). None of the three re classes define '__format__' in their own __dict__. All verified with Python 3.14.4."
  kind: python_call_eq
  category: format_introspection
  id_prefix: re1426fm

  columns: [id, function, args, expected, description]
  rows:
    - [re1426fm001, re.error.__format__.__class__.__name__.__eq__,    ["method_descriptor"], true,  "re.error.__format__.__class__.__name__ == 'method_descriptor' (pure-Python exception; inherits from BaseException->object chain); verified with Python 3.14.4"]
    - [re1426fm002, re.error.__dict__.__contains__,                   ["__format__"],         false, "re.error.__dict__.__contains__('__format__') == False (not defined in own dict); verified with Python 3.14.4"]
    - [re1426fm003, re.Pattern.__format__.__class__.__name__.__eq__,  ["method_descriptor"], true,  "re.Pattern.__format__.__class__.__name__ == 'method_descriptor' (C-level type; inherits object.__format__); verified with Python 3.14.4"]
    - [re1426fm004, re.Pattern.__dict__.__contains__,                  ["__format__"],         false, "re.Pattern.__dict__.__contains__('__format__') == False; verified with Python 3.14.4"]
    - [re1426fm005, re.Match.__format__.__class__.__name__.__eq__,    ["method_descriptor"], true,  "re.Match.__format__.__class__.__name__ == 'method_descriptor' (C-level type; inherits object.__format__); verified with Python 3.14.4"]
    - [re1426fm006, re.Match.__dict__.__contains__,                   ["__format__"],         false, "re.Match.__dict__.__contains__('__format__') == False; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
