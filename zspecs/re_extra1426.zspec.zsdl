#
# re.error.__dir__.__class__.__name__               == 'method_descriptor'
# re.error.__dict__.__contains__('__dir__')        == False
# re.Pattern.__dir__.__class__.__name__             == 'method_descriptor'
# re.Pattern.__dict__.__contains__('__dir__')      == False
# re.Match.__dir__.__class__.__name__               == 'method_descriptor'
# re.Match.__dict__.__contains__('__dir__')        == False
# ---------------------------------------------------------------------------

table re_extra1426.re_dir_type:
  description: "re class __dir__ method type and __dict__ presence checks — wave 542 extra1426 theme. re.error.__dir__.__class__.__name__=='method_descriptor' (error inherits __dir__ from object via the BaseException chain). re.Pattern.__dir__.__class__.__name__=='method_descriptor' (Pattern is a C-level type; inherits object.__dir__). re.Match.__dir__.__class__.__name__=='method_descriptor' (Match likewise). None of the three re classes define '__dir__' in their own __dict__. All verified with Python 3.14.4."
  kind: python_call_eq
  category: dir_introspection
  id_prefix: re1426dr

  columns: [id, function, args, expected, description]
  rows:
    - [re1426dr001, re.error.__dir__.__class__.__name__.__eq__,    ["method_descriptor"], true,  "re.error.__dir__.__class__.__name__ == 'method_descriptor' (inherits from BaseException->object chain); verified with Python 3.14.4"]
    - [re1426dr002, re.error.__dict__.__contains__,                ["__dir__"],            false, "re.error.__dict__.__contains__('__dir__') == False (not defined in own dict); verified with Python 3.14.4"]
    - [re1426dr003, re.Pattern.__dir__.__class__.__name__.__eq__,  ["method_descriptor"], true,  "re.Pattern.__dir__.__class__.__name__ == 'method_descriptor' (C-level type; inherits object.__dir__); verified with Python 3.14.4"]
    - [re1426dr004, re.Pattern.__dict__.__contains__,              ["__dir__"],            false, "re.Pattern.__dict__.__contains__('__dir__') == False; verified with Python 3.14.4"]
    - [re1426dr005, re.Match.__dir__.__class__.__name__.__eq__,    ["method_descriptor"], true,  "re.Match.__dir__.__class__.__name__ == 'method_descriptor' (C-level type; inherits object.__dir__); verified with Python 3.14.4"]
    - [re1426dr006, re.Match.__dict__.__contains__,                ["__dir__"],            false, "re.Match.__dict__.__contains__('__dir__') == False; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# re class __format__ and __dir__ cross-checks — extra1426
#
# All three re classes uniformly inherit both __format__ and __dir__ from object.
# re.error additionally inherits via the BaseException chain (Exception is a C type).
# Neither __format__ nor __dir__ appear in any class's own __dict__.
# ---------------------------------------------------------------------------

table re_extra1426.re_format_dir_cross:
  description: "re class __format__ and __dir__ cross-checks — wave 542 extra1426. Confirms that across all three re classes (error, Pattern, Match), both __format__ and __dir__ are always 'method_descriptor' and are never present in the class's own __dict__. re.error is a pure-Python exception class but inherits __format__ and __dir__ from the C-level BaseException->object chain, yielding 'method_descriptor' for both. re.Pattern and re.Match are C-level types (_sre module) with the same uniform inheritance pattern. All verified with Python 3.14.4."
  kind: python_call_eq
  category: format_dir_cross
  id_prefix: re1426cx

  columns: [id, function, args, expected, description]
  rows:
    - [re1426cx001, re.error.__format__.__class__.__name__.__eq__,    ["method_descriptor"], true,  "re.error.__format__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [re1426cx002, re.error.__dir__.__class__.__name__.__eq__,       ["method_descriptor"], true,  "re.error.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [re1426cx003, re.Pattern.__format__.__class__.__name__.__eq__,  ["method_descriptor"], true,  "re.Pattern.__format__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [re1426cx004, re.Pattern.__dir__.__class__.__name__.__eq__,     ["method_descriptor"], true,  "re.Pattern.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [re1426cx005, re.Match.__format__.__class__.__name__.__eq__,    ["method_descriptor"], true,  "re.Match.__format__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [re1426cx006, re.Match.__dir__.__class__.__name__.__eq__,       ["method_descriptor"], true,  "re.Match.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [re1426cx007, re.error.__dict__.__contains__,                   ["__format__"],         false, "re.error.__dict__.__contains__('__format__') == False; verified with Python 3.14.4"]
    - [re1426cx008, re.error.__dict__.__contains__,                   ["__dir__"],            false, "re.error.__dict__.__contains__('__dir__') == False; verified with Python 3.14.4"]
    - [re1426cx009, re.Pattern.__dict__.__contains__,                 ["__format__"],         false, "re.Pattern.__dict__.__contains__('__format__') == False; verified with Python 3.14.4"]
    - [re1426cx010, re.Pattern.__dict__.__contains__,                 ["__dir__"],            false, "re.Pattern.__dict__.__contains__('__dir__') == False; verified with Python 3.14.4"]
    - [re1426cx011, re.Match.__dict__.__contains__,                   ["__format__"],         false, "re.Match.__dict__.__contains__('__format__') == False; verified with Python 3.14.4"]
    - [re1426cx012, re.Match.__dict__.__contains__,                   ["__dir__"],            false, "re.Match.__dict__.__contains__('__dir__') == False; verified with Python 3.14.4"]
