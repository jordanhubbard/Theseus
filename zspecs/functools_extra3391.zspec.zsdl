spec: ft3391
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 673 (ft3391): __int__, __float__, __complex__ dict-presence checks for functools types."
    - "Theme: __int__/__float__/__complex__ dict-presence (int(x), float(x), complex(x))."
    - "All values False — functools types are callable/descriptor helpers with no numeric conversion support."
    - "None of the four functools types define __int__, __float__, or __complex__ in their own __dict__."
    - "functools.partial and functools._lru_cache_wrapper are C-level types; functools.partialmethod and functools.cached_property are Python-level classes."
    - "type(functools.lru_cache(lambda: None)) accesses the internal _lru_cache_wrapper C type at runtime."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ft3391.int:
  description: "functools types __int__ dict-presence checks; wave 673"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ft3391
  columns: [id, function, args, expected]
  rows:
    - ["ft3391001", operator.contains, [functools.partial.__dict__,                          "__int__"], false]
    - ["ft3391002", operator.contains, [functools.partialmethod.__dict__,                    "__int__"], false]
    - ["ft3391003", operator.contains, [functools.cached_property.__dict__,                  "__int__"], false]
    - ["ft3391004", operator.contains, [type(functools.lru_cache(lambda: None)).__dict__,    "__int__"], false]

