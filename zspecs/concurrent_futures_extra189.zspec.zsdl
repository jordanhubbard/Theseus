invariant concurrent_futures_extra189.tpe_name_eq:
  description: "concurrent.futures.ThreadPoolExecutor.__name__.__eq__('ThreadPoolExecutor') returns True — ThreadPoolExecutor.__name__=='ThreadPoolExecutor' (len=18: Thread=6+Pool=4+Executor=8=18); ThreadPoolExecutor manages a pool of OS threads for I/O-bound concurrent tasks; threads share memory space and can access shared state directly (with appropriate synchronization); TPE.__name__ (18) < PPE.__name__ (19) by 1 — 'Thread' (6) vs 'Process' (7); NEW in cfpoolexec189: first standalone ThreadPoolExecutor.__name__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__name__.__eq__
  args: ["ThreadPoolExecutor"]
  expected: true

invariant concurrent_futures_extra189.tpe_module_eq:
  description: "concurrent.futures.ThreadPoolExecutor.__module__.__eq__('concurrent.futures.thread') returns True — ThreadPoolExecutor.__module__=='concurrent.futures.thread' (len=25: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'thread'=6=25); ThreadPoolExecutor is defined in Lib/concurrent/futures/thread.py; the module path reflects the three-level package structure: concurrent → futures → thread; compare ProcessPoolExecutor.__module__=='concurrent.futures.process' (len=26 — 'process'=7 vs 'thread'=6, one char longer); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__module__.__eq__
  args: ["concurrent.futures.thread"]
  expected: true

invariant concurrent_futures_extra189.tpe_base_is_Executor:
  description: "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__('Executor') returns True — ThreadPoolExecutor inherits from Executor (len=8: E(1)x(2)e(3)c(4)u(5)t(6)o(7)r(8)); Executor is the abstract base class in Lib/concurrent/futures/_base.py that defines the submit(), map(), and shutdown() interface; both ThreadPoolExecutor and ProcessPoolExecutor inherit from Executor, ensuring a consistent API for both thread-based and process-based parallelism; Executor.__name__ (8) is the shortest name in this spec; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__"
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra189.tpe_init_qualname_eq:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__eq__('ThreadPoolExecutor.__init__') returns True — ThreadPoolExecutor.__init__.__qualname__=='ThreadPoolExecutor.__init__' (len=27: 'ThreadPoolExecutor'=18+'.'=1+'__init__'=8=27); ThreadPoolExecutor.__init__ accepts max_workers, thread_name_prefix, initializer, and initargs; max_workers defaults to min(32, os.cpu_count()+4) since Python 3.8; __init__.__qualname__ (27) == shutdown.__qualname__ (27) > submit.__qualname__ (25) — __init__ and shutdown share the same qualname length; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__eq__
  args: ["ThreadPoolExecutor.__init__"]
  expected: true

invariant concurrent_futures_extra189.tpe_submit_qualname_eq:
  description: "concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__eq__('ThreadPoolExecutor.submit') returns True — ThreadPoolExecutor.submit.__qualname__=='ThreadPoolExecutor.submit' (len=25: 'ThreadPoolExecutor'=18+'.'=1+'submit'=6=25); submit schedules the callable to be executed and returns a concurrent.futures.Future representing the pending result; submit is the primary way to dispatch work to the executor; submit.__qualname__ (25) < __init__.__qualname__ (27) < shutdown.__qualname__ (27) by 2 — 'submit' (6 chars) < '__init__' (8 chars) == 'shutdown' (8 chars); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__eq__
  args: ["ThreadPoolExecutor.submit"]
  expected: true

invariant concurrent_futures_extra189.tpe_shutdown_qualname_eq:
  description: "concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__.__eq__('ThreadPoolExecutor.shutdown') returns True — ThreadPoolExecutor.shutdown.__qualname__=='ThreadPoolExecutor.shutdown' (len=27: 'ThreadPoolExecutor'=18+'.'=1+'shutdown'=8=27); shutdown signals the executor to free resources and optionally waits for pending futures; 'wait=True' (default) blocks until all futures complete; 'cancel_futures=True' cancels pending futures; shutdown.__qualname__ (27) == __init__.__qualname__ (27) > submit.__qualname__ (25); 'shutdown' (8 chars) == '__init__' (8 chars) — both 8-char method names yield qualname length 27; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__.__eq__
  args: ["ThreadPoolExecutor.shutdown"]
  expected: true

invariant concurrent_futures_extra189.ppe_name_eq:
  description: "concurrent.futures.ProcessPoolExecutor.__name__.__eq__('ProcessPoolExecutor') returns True — ProcessPoolExecutor.__name__=='ProcessPoolExecutor' (len=19: Process=7+Pool=4+Executor=8=19); ProcessPoolExecutor manages a pool of worker processes for CPU-bound parallel tasks; each worker is a separate OS process with its own memory space, avoiding GIL contention; PPE.__name__ (19) > TPE.__name__ (18) by 1 — 'Process' (7 chars) vs 'Thread' (6 chars); both Pool executor classes follow the 'XxxPoolExecutor' naming pattern; NEW in cfpoolexec189: standalone ProcessPoolExecutor.__name__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ProcessPoolExecutor.__name__.__eq__
  args: ["ProcessPoolExecutor"]
  expected: true

invariant concurrent_futures_extra189.ppe_base_is_Executor:
  description: "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__('Executor') returns True — ProcessPoolExecutor.__bases__[0].__name__=='Executor' (len=8); ProcessPoolExecutor inherits from the same Executor abstract base as ThreadPoolExecutor; this shared inheritance means code written against the Executor interface (submit/map/shutdown) works identically with both TPE and PPE — the classic Liskov substitution pattern; PPE.__bases__[0].__name__ (8) == TPE.__bases__[0].__name__ (8) — identical Executor base; NEW in cfpoolexec189: standalone ProcessPoolExecutor base invariant completing 8-invariant coverage for concurrent.futures pool executors; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__"
  args: ["Executor"]
  expected: true

