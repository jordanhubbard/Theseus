provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "concurrent.futures.ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor' (len=18: Thread=6+Pool=4+Executor=8=18)."
    - "concurrent.futures.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' (len=25: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'thread'=6=25)."
    - "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__ == 'Executor' (len=8); both ThreadPoolExecutor and ProcessPoolExecutor inherit from Executor."
    - "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__ == 'ThreadPoolExecutor.__init__' (len=27: 'ThreadPoolExecutor'=18+'.'=1+'__init__'=8=27)."
    - "concurrent.futures.ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit' (len=25: 'ThreadPoolExecutor'=18+'.'=1+'submit'=6=25)."
    - "concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown' (len=27: 'ThreadPoolExecutor'=18+'.'=1+'shutdown'=8=27)."
    - "concurrent.futures.ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor' (len=19: Process=7+Pool=4+Executor=8=19)."
    - "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__ == 'Executor' (len=8); same base as ThreadPoolExecutor."
    - "Length ordering: Executor (8) < submit (25) < __module__ (25) == submit (25) < __init__ (27) == shutdown (27)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

