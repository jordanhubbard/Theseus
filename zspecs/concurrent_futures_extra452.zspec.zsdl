spec: concurrent_futures_extra452
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures Executor class hierarchy"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Executor is an abstract base class; concrete subclasses are ThreadPoolExecutor and ProcessPoolExecutor"
    - "BrokenExecutor is a subclass of RuntimeError"
    - "FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED are string constants defined in concurrent.futures._base"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra452.executor_names:
  description: "concurrent.futures Executor class __name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: cfexn

  columns: [id, function, args, expected]
  rows:
    - [cfexn001, concurrent.futures.Executor.__name__.__eq__, ["Executor"], true]
    - [cfexn002, concurrent.futures.BrokenExecutor.__name__.__eq__, ["BrokenExecutor"], true]

table concurrent_futures_extra452.executor_modules:
  description: "concurrent.futures Executor class __module__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: cfexm

  columns: [id, function, args, expected]
  rows:
    - [cfexm001, concurrent.futures.Executor.__module__.__eq__, ["concurrent.futures._base"], true]
    - [cfexm002, concurrent.futures.BrokenExecutor.__module__.__eq__, ["concurrent.futures._base"], true]

table concurrent_futures_extra452.executor_bases:
  description: "concurrent.futures class __bases__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: cfexb

  columns: [id, function, args, expected]
  rows:
    - [cfexb001, "concurrent.futures.Executor.__bases__[0].__name__.__eq__", ["object"], true]
    - [cfexb002, "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"], true]
    - [cfexb003, "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"], true]
    - [cfexb004, "concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__", ["RuntimeError"], true]

table concurrent_futures_extra452.string_constants:
  description: "concurrent.futures string constant values"
  kind: python_call_eq
  category: constants
  id_prefix: cfcon

  columns: [id, function, args, expected]
  rows:
    - [cfcon001, concurrent.futures.FIRST_COMPLETED.__eq__, ["FIRST_COMPLETED"], true]
    - [cfcon002, concurrent.futures.FIRST_EXCEPTION.__eq__, ["FIRST_EXCEPTION"], true]
    - [cfcon003, concurrent.futures.ALL_COMPLETED.__eq__, ["ALL_COMPLETED"], true]
