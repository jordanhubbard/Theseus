spec: socket_extra267
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra266.zspec.zsdl — covers socket.socket bind/listen/accept/connect/send/recv/close/shutdown/setsockopt/getsockopt method identity."
    - "socket_extra265.zspec.zsdl — covers socket module-level function identity."
    - "socket_extra94.zspec.zsdl — covers socket module-level function __qualname__ and __module__ values; byte-order function class names."
    - "socket_extra93.zspec.zsdl — covers socket.socket C-level method_descriptor class names."
  notes:
    - "socket.getfqdn.__name__ == 'getfqdn' and __class__.__name__ == 'function' — getfqdn is a pure-Python function in Lib/socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.getfqdn.__module__ == 'socket' — pure-Python function defined in Lib/socket.py (not in _socket C extension). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.gethostname.__name__ == 'gethostname' and __class__.__name__ == 'builtin_function_or_method' — gethostname is a C builtin from _socket extension. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.getnameinfo.__name__ == 'getnameinfo' and __class__.__name__ == 'builtin_function_or_method' — C builtin from _socket. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.getservbyname.__name__ == 'getservbyname' and __class__.__name__ == 'builtin_function_or_method' — C builtin from _socket. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.getservbyport.__name__ == 'getservbyport' and __class__.__name__ == 'builtin_function_or_method' — C builtin from _socket. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.htons.__name__ == 'htons' and __class__.__name__ == 'builtin_function_or_method' — C builtin byte-order conversion from _socket. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.htonl.__name__ == 'htonl' and __class__.__name__ == 'builtin_function_or_method' — C builtin byte-order conversion from _socket. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.ntohs.__name__ == 'ntohs' and __class__.__name__ == 'builtin_function_or_method' — C builtin byte-order conversion from _socket. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.ntohl.__name__ == 'ntohl' and __class__.__name__ == 'builtin_function_or_method' — C builtin byte-order conversion from _socket. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket module-level function __name__ identity
# getfqdn is a pure-Python function; gethostname/getnameinfo/getservbyname/
# getservbyport/htons/htonl/ntohs/ntohl are C builtins from _socket extension.
# ---------------------------------------------------------------------------

table socket_extra267.module_function_names:
  description: "socket module-level function __name__ identity — getfqdn/gethostname/getnameinfo/getservbyname/getservbyport/htons/htonl/ntohs/ntohl __name__ matches function name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: sockfname267

  columns: [id, function, args, expected, description]
  rows:
    - [getfqdn_name,       getfqdn.__name__.__eq__,       ["getfqdn"],       true, "socket.getfqdn.__name__ == 'getfqdn' — pure-Python function in Lib/socket.py"]
    - [gethostname_name,   gethostname.__name__.__eq__,   ["gethostname"],   true, "socket.gethostname.__name__ == 'gethostname' — C builtin from _socket extension"]
    - [getnameinfo_name,   getnameinfo.__name__.__eq__,   ["getnameinfo"],   true, "socket.getnameinfo.__name__ == 'getnameinfo' — C builtin from _socket extension"]
    - [getservbyname_name, getservbyname.__name__.__eq__, ["getservbyname"], true, "socket.getservbyname.__name__ == 'getservbyname' — C builtin from _socket extension"]
    - [getservbyport_name, getservbyport.__name__.__eq__, ["getservbyport"], true, "socket.getservbyport.__name__ == 'getservbyport' — C builtin from _socket extension"]

# ---------------------------------------------------------------------------
# socket module-level function __class__.__name__ identity
# getfqdn is a pure-Python 'function'; others are 'builtin_function_or_method'.
# ---------------------------------------------------------------------------

table socket_extra267.module_function_class_names:
  description: "socket module-level function __class__.__name__ identity — getfqdn is 'function'; gethostname/getnameinfo/getservbyname/htons/htonl are 'builtin_function_or_method'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: sockfcls267

  columns: [id, function, args, expected, description]
  rows:
    - [getfqdn_class,       getfqdn.__class__.__name__.__eq__,       ["function"],                  true, "socket.getfqdn.__class__.__name__ == 'function' — pure-Python function in Lib/socket.py"]
    - [gethostname_class,   gethostname.__class__.__name__.__eq__,   ["builtin_function_or_method"], true, "socket.gethostname.__class__.__name__ == 'builtin_function_or_method' — C builtin"]
    - [getnameinfo_class,   getnameinfo.__class__.__name__.__eq__,   ["builtin_function_or_method"], true, "socket.getnameinfo.__class__.__name__ == 'builtin_function_or_method' — C builtin"]
    - [getservbyname_class, getservbyname.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "socket.getservbyname.__class__.__name__ == 'builtin_function_or_method' — C builtin"]
    - [getservbyport_class, getservbyport.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "socket.getservbyport.__class__.__name__ == 'builtin_function_or_method' — C builtin"]

# ---------------------------------------------------------------------------
# socket byte-order function identity — htons, htonl, ntohs, ntohl
# All four are C builtins from the _socket extension module.
# __name__ matches the function name; __class__.__name__ == 'builtin_function_or_method'.
# ---------------------------------------------------------------------------

invariant socket_extra267.htons_name_eq:
  description: "socket.htons.__name__ == 'htons' — C builtin byte-order conversion function from _socket; converts 16-bit int from host to network byte order; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: htons.__name__.__eq__
  args: ["htons"]
  expected: true

invariant socket_extra267.htonl_name_eq:
  description: "socket.htonl.__name__ == 'htonl' — C builtin byte-order conversion function from _socket; converts 32-bit int from host to network byte order; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: htonl.__name__.__eq__
  args: ["htonl"]
  expected: true

invariant socket_extra267.ntohs_name_eq:
  description: "socket.ntohs.__name__ == 'ntohs' — C builtin byte-order conversion function from _socket; converts 16-bit int from network to host byte order; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: ntohs.__name__.__eq__
  args: ["ntohs"]
  expected: true

invariant socket_extra267.ntohl_name_eq:
  description: "socket.ntohl.__name__ == 'ntohl' — C builtin byte-order conversion function from _socket; converts 32-bit int from network to host byte order; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: ntohl.__name__.__eq__
  args: ["ntohl"]
  expected: true

invariant socket_extra267.htons_class_eq:
  description: "socket.htons.__class__.__name__ == 'builtin_function_or_method' — htons is a C-level builtin from _socket; not a Python function; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: htons.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant socket_extra267.ntohs_class_eq:
  description: "socket.ntohs.__class__.__name__ == 'builtin_function_or_method' — ntohs is a C-level builtin from _socket; not a Python function; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: ntohs.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant socket_extra267.ntohl_class_eq:
  description: "socket.ntohl.__class__.__name__ == 'builtin_function_or_method' — ntohl is a C-level builtin from _socket; not a Python function; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: ntohl.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant socket_extra267.getfqdn_module_eq:
  description: "socket.getfqdn.__module__ == 'socket' — getfqdn is a pure-Python function defined in Lib/socket.py; __module__ is 'socket' (not '_socket' C extension); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: getfqdn.__module__.__eq__
  args: ["socket"]
  expected: true
