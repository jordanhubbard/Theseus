  id_prefix: mp1561po

  columns: [id, function, args, expected]
  rows:
    - [mp1561po001, multiprocessing.pool.Pool.__dict__.__contains__, ["__bool__"],    false]
    - [mp1561po002, multiprocessing.pool.Pool.__dict__.__contains__, ["__int__"],     false]
    - [mp1561po003, multiprocessing.pool.Pool.__dict__.__contains__, ["__float__"],   false]
    - [mp1561po004, multiprocessing.pool.Pool.__dict__.__contains__, ["__complex__"], false]
    - [mp1561po005, multiprocessing.pool.Pool.__dict__.__contains__, ["__index__"],   false]
    - [mp1561po006, multiprocessing.pool.Pool.__dict__.__contains__, ["__trunc__"],   false]
    - [mp1561po007, multiprocessing.pool.Pool.__dict__.__contains__, ["__floor__"],   false]
    - [mp1561po008, multiprocessing.pool.Pool.__dict__.__contains__, ["__ceil__"],    false]
    - [mp1561po009, multiprocessing.pool.Pool.__dict__.__contains__, ["__round__"],   false]

# ---------------------------------------------------------------------------
# Cross-class spot-check: Process vs Pool — both lack numeric protocol
# ---------------------------------------------------------------------------

table multiprocessing_extra1561.process_pool_no_numeric_spot:
  description: "Spot-check: neither multiprocessing.Process nor multiprocessing.pool.Pool defines __int__, __float__, or __complex__ in their __dict__"
  kind: python_call_eq
  category: numeric_presence
  id_prefix: mp1561sp

  columns: [id, function, args, expected]
  rows:
    - [mp1561sp001, multiprocessing.Process.__dict__.__contains__,   ["__int__"],     false]
    - [mp1561sp002, multiprocessing.pool.Pool.__dict__.__contains__,  ["__int__"],     false]
    - [mp1561sp003, multiprocessing.Process.__dict__.__contains__,   ["__float__"],   false]
    - [mp1561sp004, multiprocessing.pool.Pool.__dict__.__contains__,  ["__float__"],   false]
    - [mp1561sp005, multiprocessing.Process.__dict__.__contains__,   ["__complex__"], false]
    - [mp1561sp006, multiprocessing.pool.Pool.__dict__.__contains__,  ["__complex__"], false]
    - [mp1561sp007, multiprocessing.Process.__dict__.__contains__,   ["__index__"],   false]
    - [mp1561sp008, multiprocessing.pool.Pool.__dict__.__contains__,  ["__index__"],   false]
    - [mp1561sp009, multiprocessing.Process.__dict__.__contains__,   ["__round__"],   false]

# ---------------------------------------------------------------------------
# multiprocessing.Process — positive dict-presence checks (own class attributes)
# Note: on CPython 3.14 Process.__dict__ contains class-level dunder slots and
# private attributes; lifecycle methods (start, run, etc.) live on BaseProcess.
# ---------------------------------------------------------------------------

table multiprocessing_extra1561.process_own_attr_presence:
  description: "multiprocessing.Process.__dict__ contains its own class-level attributes including __module__ and __doc__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: mp1561pm

  columns: [id, function, args, expected]
  rows:
    - [mp1561pm001, multiprocessing.Process.__dict__.__contains__, ["__module__"],          true]
    - [mp1561pm002, multiprocessing.Process.__dict__.__contains__, ["__doc__"],             true]
    - [mp1561pm003, multiprocessing.Process.__dict__.__contains__, ["_start_method"],       true]
    - [mp1561pm004, multiprocessing.Process.__dict__.__contains__, ["_Popen"],              true]
    - [mp1561pm005, multiprocessing.Process.__dict__.__contains__, ["_after_fork"],         true]
    - [mp1561pm006, multiprocessing.Process.__dict__.__contains__, ["__static_attributes__"], true]
