spec: multiprocessing_extra1561
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Process — Process class"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.pool.Pool — Pool class"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Wave 551 (_extra1561): numeric type conversion protocol dict-presence checks for multiprocessing classes."
    - "multiprocessing.Process and multiprocessing.pool.Pool are process management classes, not numeric types."
    - "None of these classes define __bool__, __int__, __float__, __complex__, __index__, __trunc__, __floor__, __ceil__, or __round__ in their own __dict__."
    - "multiprocessing.Process.__module__=='multiprocessing.context'."
    - "multiprocessing.pool.Pool.__module__=='multiprocessing.pool'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Process — numeric type conversion protocol dict-presence (all False)
# ---------------------------------------------------------------------------

table multiprocessing_extra1561.process_numeric_protocol:
  description: "multiprocessing.Process.__dict__ does not contain any numeric type conversion protocol dunder"
  kind: python_call_eq
  category: numeric_presence
  id_prefix: mp1561pr

  columns: [id, function, args, expected]
  rows:
    - [mp1561pr001, multiprocessing.Process.__dict__.__contains__, ["__bool__"],    false]
    - [mp1561pr002, multiprocessing.Process.__dict__.__contains__, ["__int__"],     false]
    - [mp1561pr003, multiprocessing.Process.__dict__.__contains__, ["__float__"],   false]
    - [mp1561pr004, multiprocessing.Process.__dict__.__contains__, ["__complex__"], false]
    - [mp1561pr005, multiprocessing.Process.__dict__.__contains__, ["__index__"],   false]
    - [mp1561pr006, multiprocessing.Process.__dict__.__contains__, ["__trunc__"],   false]
    - [mp1561pr007, multiprocessing.Process.__dict__.__contains__, ["__floor__"],   false]
    - [mp1561pr008, multiprocessing.Process.__dict__.__contains__, ["__ceil__"],    false]
    - [mp1561pr009, multiprocessing.Process.__dict__.__contains__, ["__round__"],   false]

# ---------------------------------------------------------------------------
