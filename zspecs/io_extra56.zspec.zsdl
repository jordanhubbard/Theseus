spec: io_extra56
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra55.zspec.zsdl — covers BytesIO method qualname lengths (read=12, write=13, seek=12, tell=12, getvalue=16) and StringIO method qualname lengths (read=13, write=14, seek=13, getvalue=17)."
    - "io_extra54.zspec.zsdl — covers io concrete class __class__.__qualname__.__eq__('type') for FileIO/BytesIO/StringIO/BufferedWriter/BufferedReader/TextIOWrapper; IOBase.__class__.__qualname__.__eq__('ABCMeta'); open.__class__.__qualname__.__eq__('builtin_function_or_method'); DEFAULT_BUFFER_SIZE.__class__.__qualname__.__eq__('int')."
    - "io_extra53.zspec.zsdl — covers concrete io class __class__.__name__.__len__()==4; IOBase.__class__.__name__.__eq__('ABCMeta'); open.__name__/__qualname__.__len__()==4; open.__class__.__name__.__eq__('builtin_function_or_method')."
    - "io_extra50.zspec.zsdl — covers BytesIO/StringIO/FileIO/BufferedWriter/BufferedReader/TextIOWrapper __qualname__.__len__()."
    - "io_extra49.zspec.zsdl — covers BytesIO/StringIO/FileIO/BufferedWriter/BufferedReader/TextIOWrapper __qualname__.__eq__()."
    - "io_extra33.zspec.zsdl — covers open.__qualname__.__eq__('open')."
    - "io_extra3.zspec.zsdl — covers open.__name__.__eq__('open')."
  notes:
    - "This spec extends io_extra55.zspec.zsdl."
    - "Prior specs collectively covered: all concrete io class __qualname__ equality and lengths (io_extra49/io_extra50); concrete io class __class__.__name__/__qualname__ equality (io_extra4/io_extra53/io_extra54); IOBase.__class__.__name__/__qualname__ equality (io_extra53/io_extra54); open identity attributes (io_extra3/io_extra33/io_extra53/io_extra54); DEFAULT_BUFFER_SIZE.__class__.__qualname__ (io_extra54); BytesIO/StringIO method __qualname__ lengths (io_extra55). NO prior io spec checks the __doc__ attribute of any io class or the io module itself, nor the type (__class__.__name__/__qualname__) of those __doc__ strings."
    - "This spec covers: io.BytesIO.__doc__.__class__.__name__.__eq__('str') (NOVEL — no prior io spec checks BytesIO.__doc__ or its type; novel); io.StringIO.__doc__.__class__.__name__.__eq__('str') (NOVEL); io.FileIO.__doc__.__class__.__name__.__eq__('str') (NOVEL); io.BufferedReader.__doc__.__class__.__name__.__eq__('str') (NOVEL); io.BufferedWriter.__doc__.__class__.__name__.__eq__('str') (NOVEL); io.TextIOWrapper.__doc__.__class__.__name__.__eq__('str') (NOVEL); io.IOBase.__doc__.__class__.__name__.__eq__('str') (NOVEL); io.RawIOBase.__doc__.__class__.__name__.__eq__('str') (NOVEL); io.BufferedIOBase.__doc__.__class__.__name__.__eq__('str') (NOVEL); io.TextIOBase.__doc__.__class__.__name__.__eq__('str') (NOVEL); io.__doc__.__class__.__name__.__eq__('str') (NOVEL — module-level docstring type; novel); io.BytesIO.__doc__.__class__.__qualname__.__eq__('str') (NOVEL — no prior io spec checks any __doc__.__class__.__qualname__; novel); io.FileIO.__doc__.__class__.__qualname__.__eq__('str') (NOVEL); io.__doc__.__class__.__qualname__.__eq__('str') (NOVEL)."
    - "io.BytesIO.__doc__ is a str instance. BytesIO is a C-extension type in _io; its class docstring is a plain Python str. Therefore __doc__.__class__.__name__=='str'. No prior io spec checks BytesIO.__doc__ or its type. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.StringIO.__doc__.__class__.__name__ == 'str'. StringIO is a C-extension type in _io; its docstring is a str. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.FileIO.__doc__.__class__.__name__ == 'str'. FileIO is a C-extension type; its docstring is a str. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedReader.__doc__.__class__.__name__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedWriter.__doc__.__class__.__name__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.TextIOWrapper.__doc__.__class__.__name__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.IOBase.__doc__.__class__.__name__ == 'str'. IOBase is an abstract base class; its docstring is a str. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.RawIOBase.__doc__.__class__.__name__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedIOBase.__doc__.__class__.__name__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.TextIOBase.__doc__.__class__.__name__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.__doc__.__class__.__name__ == 'str'. The io module itself has a docstring; its type is str. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BytesIO.__doc__.__class__.__qualname__ == 'str'. For the builtin str type, __qualname__==__name__=='str'. Novel __qualname__ path anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.FileIO.__doc__.__class__.__qualname__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.__doc__.__class__.__qualname__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io class __doc__.__class__.__name__ equality
#
# Every io class has a docstring attribute (__doc__) that is a plain Python
# str instance. Therefore for any io class C:
#
#   C.__doc__.__class__.__name__ == 'str'
#
# This covers all concrete and abstract io classes, plus the module docstring:
#
#   io.BytesIO.__doc__.__class__.__name__      == 'str'
#   io.StringIO.__doc__.__class__.__name__     == 'str'
#   io.FileIO.__doc__.__class__.__name__       == 'str'
#   io.BufferedReader.__doc__.__class__.__name__ == 'str'
#   io.BufferedWriter.__doc__.__class__.__name__ == 'str'
#   io.TextIOWrapper.__doc__.__class__.__name__ == 'str'
#   io.IOBase.__doc__.__class__.__name__       == 'str'
#   io.RawIOBase.__doc__.__class__.__name__    == 'str'
#   io.BufferedIOBase.__doc__.__class__.__name__ == 'str'
#   io.TextIOBase.__doc__.__class__.__name__   == 'str'
#   io.__doc__.__class__.__name__              == 'str'
#
# No prior io spec checks __doc__ or its type for any io class.
# All eleven equality anchors are novel in the io_extra56 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra56.class_doc_names:
  description: "io class __doc__.__class__.__name__.__eq__('str') for BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper/IOBase/RawIOBase/BufferedIOBase/TextIOBase/io-module — every io class docstring is a plain str instance; no prior io spec checks __doc__ or its type for any io class; all eleven novel equality anchors in io_extra56 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: iodoc56cn

  columns: [id, function, args, expected]
  rows:
    - [BytesIO_doc_class_name,       "BytesIO.__doc__.__class__.__name__.__eq__",       ["str"], true]
    - [StringIO_doc_class_name,      "StringIO.__doc__.__class__.__name__.__eq__",      ["str"], true]
    - [FileIO_doc_class_name,        "FileIO.__doc__.__class__.__name__.__eq__",        ["str"], true]
    - [BufferedReader_doc_class_name, "BufferedReader.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [BufferedWriter_doc_class_name, "BufferedWriter.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [TextIOWrapper_doc_class_name,  "TextIOWrapper.__doc__.__class__.__name__.__eq__",  ["str"], true]
    - [IOBase_doc_class_name,        "IOBase.__doc__.__class__.__name__.__eq__",        ["str"], true]
    - [RawIOBase_doc_class_name,     "RawIOBase.__doc__.__class__.__name__.__eq__",     ["str"], true]
    - [BufferedIOBase_doc_class_name, "BufferedIOBase.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [TextIOBase_doc_class_name,    "TextIOBase.__doc__.__class__.__name__.__eq__",    ["str"], true]
    - [module_doc_class_name,        "__doc__.__class__.__name__.__eq__",               ["str"], true]

# ---------------------------------------------------------------------------
# io class __doc__.__class__.__qualname__ equality (selected)
#
# For the builtin str type, __qualname__==__name__=='str'. Therefore for any
# io class whose docstring is a str:
#
#   io.BytesIO.__doc__.__class__.__qualname__ == 'str'
#   io.FileIO.__doc__.__class__.__qualname__  == 'str'
#   io.__doc__.__class__.__qualname__         == 'str'
#
# No prior io spec checks __doc__.__class__.__qualname__ for any io class.
# All three equality anchors are novel in the io_extra56 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra56.class_doc_qualnames:
  description: "io class __doc__.__class__.__qualname__.__eq__('str') for BytesIO/FileIO/io-module — for the builtin str type __qualname__==__name__=='str'; no prior io spec checks __doc__.__class__.__qualname__ for any io class; all three novel __qualname__ path anchors in io_extra56 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: iodoc56cq

  columns: [id, function, args, expected]
  rows:
    - [BytesIO_doc_class_qualname, "BytesIO.__doc__.__class__.__qualname__.__eq__", ["str"], true]
    - [FileIO_doc_class_qualname,  "FileIO.__doc__.__class__.__qualname__.__eq__",  ["str"], true]
    - [module_doc_class_qualname,  "__doc__.__class__.__qualname__.__eq__",         ["str"], true]
