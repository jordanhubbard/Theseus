spec: zipapp_extra
version: ">=3.9"
backend: python_module(zipapp)

docs: https://docs.python.org/3/library/zipapp.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zipapp.html — Python zipapp module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/zipapp.py"
  notes:
    - "zipapp.create_archive is the main function for creating zipapp archives."
    - "zipapp.get_interpreter reads the shebang line from an existing zipapp archive."
    - "zipapp.ZipAppError is the module's exception class."
    - "ZipAppError.__name__ == 'ZipAppError' — exception class name."
    - "ZipAppError.__module__ == 'zipapp' — the exception is defined in the zipapp module."
    - "ZipAppError inherits from ValueError: ZipAppError.__bases__[0].__name__ == 'ValueError'."
    - "create_archive and get_interpreter are plain Python functions."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level function __name__ checks
# ---------------------------------------------------------------------------

table zipapp_extra.functions.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fn

  columns: [id, function, args, expected]
  rows:
    - [create_archive_name,  create_archive.__name__.__eq__,  ["create_archive"],  true]
    - [get_interpreter_name, get_interpreter.__name__.__eq__, ["get_interpreter"], true]

# ---------------------------------------------------------------------------
# Module-level function type checks — each is a plain Python function
# ---------------------------------------------------------------------------

table zipapp_extra.types.function_types:
  kind: python_call_eq
  category: types
  id_prefix: type

  columns: [id, function, args, expected]
  rows:
    - [create_archive_is_function,  create_archive.__class__.__name__.__eq__,  ["function"], true]
    - [get_interpreter_is_function, get_interpreter.__class__.__name__.__eq__, ["function"], true]

# ---------------------------------------------------------------------------
# Function qualname checks
# ---------------------------------------------------------------------------

table zipapp_extra.functions.qualnames:
  kind: python_call_eq
  category: functions
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [create_archive_qualname,  create_archive.__qualname__.__eq__,  ["create_archive"],  true]
    - [get_interpreter_qualname, get_interpreter.__qualname__.__eq__, ["get_interpreter"], true]

# ---------------------------------------------------------------------------
# ZipAppError exception class — name and module affiliation
# ---------------------------------------------------------------------------

invariant zipapp_extra.classes.ZipAppError_name:
  description: "ZipAppError.__name__ == 'ZipAppError' — exception class name"
  category: classes
  kind: python_call_eq
  function: ZipAppError.__name__.__eq__
  args: ["ZipAppError"]
  expected: true

invariant zipapp_extra.module.ZipAppError_module:
  description: "ZipAppError.__module__ == 'zipapp' — the exception is defined in the zipapp module"
  category: module
  kind: python_call_eq
  function: ZipAppError.__module__.__eq__
  args: ["zipapp"]
  expected: true

invariant zipapp_extra.classes.ZipAppError_is_type:
  description: "type(ZipAppError).__name__ == 'type' — ZipAppError is a class object"
  category: classes
  kind: python_call_eq
  function: ZipAppError.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# ZipAppError class hierarchy — inherits from ValueError
# ---------------------------------------------------------------------------

invariant zipapp_extra.classes.ZipAppError_base_is_ValueError:
  description: "ZipAppError.__bases__[0].__name__ == 'ValueError' — ZipAppError inherits from ValueError"
  category: classes
  kind: python_call_eq
  function: ZipAppError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  expected: true

invariant zipapp_extra.classes.ZipAppError_qualname:
  description: "ZipAppError.__qualname__ == 'ZipAppError' — qualname matches simple class name (not nested)"
  category: classes
  kind: python_call_eq
  function: ZipAppError.__qualname__.__eq__
  args: ["ZipAppError"]
  expected: true
