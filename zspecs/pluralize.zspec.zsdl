spec: pluralize
version: ">=8.0.0"
backend: node(pluralize)

docs: https://github.com/blakeembrey/pluralize#readme

provenance:
  derived_from:
    - "pluralize README — https://github.com/blakeembrey/pluralize#readme"
    - "Test vectors verified with pluralize@8.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "pluralize source: pluralize.js"
  notes:
    - "pluralize exports the pluralize function as the module default; also has .singular(), .isPlural(), .isSingular() methods."
    - "pluralize(word) returns the plural form."
    - "pluralize(word, count) returns singular if count==1, plural otherwise."
    - "Irregular forms: person→people, mouse→mice, etc."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns string or boolean. No errors for string inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table pluralize.pluralize:
  kind: node_module_call_eq
  function: ~
  category: pluralize
  id_prefix: plur

  columns: [id, args, expected]
  rows:
    - [cat,       ["cat"],        "cats"]
    - [dog_two,   ["dog", 2],     "dogs"]
    - [dog_one,   ["dog", 1],     "dog"]
    - [person,    ["person"],     "people"]
    - [mouse,     ["mouse"],      "mice"]

table pluralize.singular:
  kind: node_module_call_eq
  function: singular
  category: singular
  id_prefix: sing

  columns: [id, args, expected]
  rows:
    - [cats,     ["cats"],    "cat"]
    - [people,   ["people"],  "person"]

table pluralize.predicates:
  kind: node_module_call_eq
  category: predicates
  id_prefix: pred

  columns: [id, function, args, expected]
  rows:
    - [isPlural.cats,    isPlural,    ["cats"],  true]
    - [isSingular.cat,   isSingular,  ["cat"],   true]
    - [isSingular.cats,  isSingular,  ["cats"],  false]
