spec: multiprocessing_extra2611
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Wave 621 theme: __init_subclass__, __subclasshook__, and __class_getitem__ dict-presence checks."
    - "multiprocessing.Process, multiprocessing.pool.Pool, IMapIterator, and ThreadPool do NOT define __init_subclass__, __subclasshook__, or __class_getitem__ in their own __dict__."
    - "multiprocessing.pool.AsyncResult (alias ApplyResult) defines __class_getitem__ in its own __dict__ (PEP 585 support). All other pool and synchronize classes do not."
    - "multiprocessing.synchronize.Lock, Event, Semaphore, Condition, and Barrier do NOT define any of the three dunders in their own __dict__."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __init_subclass__ dict-presence — multiprocessing.Process and pool classes
#
# None of Process, Pool, AsyncResult, IMapIterator, or ThreadPool define
# __init_subclass__ in their own __dict__.
# ---------------------------------------------------------------------------

table multiprocessing_extra2611.init_subclass_checks:
  description: "multiprocessing classes do NOT define __init_subclass__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2611
  columns: [id, function, args, expected]
  rows:
    - ["mp2611001", "multiprocessing.Process.__dict__.__contains__",              ["__init_subclass__"], false]
    - ["mp2611002", "multiprocessing.pool.Pool.__dict__.__contains__",            ["__init_subclass__"], false]
    - ["mp2611003", "multiprocessing.pool.AsyncResult.__dict__.__contains__",     ["__init_subclass__"], false]
    - ["mp2611004", "multiprocessing.pool.IMapIterator.__dict__.__contains__",    ["__init_subclass__"], false]
    - ["mp2611005", "multiprocessing.pool.ThreadPool.__dict__.__contains__",      ["__init_subclass__"], false]
    - ["mp2611006", "multiprocessing.synchronize.Lock.__dict__.__contains__",     ["__init_subclass__"], false]

# ---------------------------------------------------------------------------
# __subclasshook__ dict-presence — multiprocessing classes
#
# None of the multiprocessing classes define __subclasshook__ in their
# own __dict__. Inherited from object.
# ---------------------------------------------------------------------------

table multiprocessing_extra2611.subclasshook_checks:
  description: "multiprocessing classes do NOT define __subclasshook__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2611
  columns: [id, function, args, expected]
  rows:
    - ["mp2611007", "multiprocessing.Process.__dict__.__contains__",                  ["__subclasshook__"], false]
    - ["mp2611008", "multiprocessing.pool.Pool.__dict__.__contains__",                ["__subclasshook__"], false]
    - ["mp2611009", "multiprocessing.pool.AsyncResult.__dict__.__contains__",         ["__subclasshook__"], false]
    - ["mp2611010", "multiprocessing.pool.IMapIterator.__dict__.__contains__",        ["__subclasshook__"], false]
    - ["mp2611011", "multiprocessing.synchronize.Lock.__dict__.__contains__",         ["__subclasshook__"], false]
    - ["mp2611012", "multiprocessing.synchronize.Event.__dict__.__contains__",        ["__subclasshook__"], false]
    - ["mp2611013", "multiprocessing.synchronize.Semaphore.__dict__.__contains__",    ["__subclasshook__"], false]
    - ["mp2611014", "multiprocessing.synchronize.Condition.__dict__.__contains__",    ["__subclasshook__"], false]
    - ["mp2611015", "multiprocessing.synchronize.Barrier.__dict__.__contains__",      ["__subclasshook__"], false]

# ---------------------------------------------------------------------------
# __class_getitem__ dict-presence — multiprocessing classes
#
# multiprocessing.pool.AsyncResult defines __class_getitem__ in its own
# __dict__ (PEP 585 generic subscript). All other multiprocessing classes
# examined here do NOT define it in their own __dict__.
# ---------------------------------------------------------------------------

table multiprocessing_extra2611.class_getitem_checks:
  description: "AsyncResult defines __class_getitem__; Process, Pool, sync classes do not"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2611
  columns: [id, function, args, expected]
  rows:
    - ["mp2611016", "multiprocessing.Process.__dict__.__contains__",                  ["__class_getitem__"], false]
    - ["mp2611017", "multiprocessing.pool.Pool.__dict__.__contains__",                ["__class_getitem__"], false]
    - ["mp2611018", "multiprocessing.pool.AsyncResult.__dict__.__contains__",         ["__class_getitem__"], true]
    - ["mp2611019", "multiprocessing.pool.IMapIterator.__dict__.__contains__",        ["__class_getitem__"], false]
    - ["mp2611020", "multiprocessing.pool.ThreadPool.__dict__.__contains__",          ["__class_getitem__"], false]
    - ["mp2611021", "multiprocessing.synchronize.Lock.__dict__.__contains__",         ["__class_getitem__"], false]
    - ["mp2611022", "multiprocessing.synchronize.Event.__dict__.__contains__",        ["__class_getitem__"], false]
    - ["mp2611023", "multiprocessing.synchronize.Semaphore.__dict__.__contains__",    ["__class_getitem__"], false]
    - ["mp2611024", "multiprocessing.synchronize.Condition.__dict__.__contains__",    ["__class_getitem__"], false]
    - ["mp2611025", "multiprocessing.synchronize.Barrier.__dict__.__contains__",      ["__class_getitem__"], false]

# ---------------------------------------------------------------------------
# managers classes — all three dunders absent
#
# multiprocessing.managers.BaseManager and SyncManager do NOT define
# __init_subclass__, __subclasshook__, or __class_getitem__ in their own
# __dict__. Complementary check confirming the pattern holds for manager
# classes in addition to process, pool, and synchronize classes.
# ---------------------------------------------------------------------------

table multiprocessing_extra2611.managers_checks:
  description: "multiprocessing.managers classes do NOT define wave-621 dunders in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2611
  columns: [id, function, args, expected]
  rows:
    - ["mp2611026", "multiprocessing.managers.BaseManager.__dict__.__contains__",  ["__init_subclass__"], false]
    - ["mp2611027", "multiprocessing.managers.BaseManager.__dict__.__contains__",  ["__subclasshook__"],  false]
    - ["mp2611028", "multiprocessing.managers.BaseManager.__dict__.__contains__",  ["__class_getitem__"], false]
    - ["mp2611029", "multiprocessing.managers.SyncManager.__dict__.__contains__",  ["__init_subclass__"], false]
    - ["mp2611030", "multiprocessing.managers.SyncManager.__dict__.__contains__",  ["__subclasshook__"],  false]
    - ["mp2611031", "multiprocessing.managers.SyncManager.__dict__.__contains__",  ["__class_getitem__"], false]
