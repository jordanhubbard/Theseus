spec: http_cookies
version: ">=3.0"
backend: python_module(http.cookies)

docs: https://docs.python.org/3/library/http.cookies.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/http.cookies.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "http.cookies source: Lib/http/cookies.py (PSF; source inspection permitted)"
  not_derived_from:
    - "http.cookies source: internal cookie parsing internals"
  notes:
    - "SimpleCookie is a dict-like container mapping cookie names to Morsel objects."
    - "Morsel wraps a single cookie and exposes .key, .value, .coded_value plus attribute dict for directives."
    - "Morsel._reserved is a dict of valid cookie directives (path, domain, expires, etc.)."
    - "BaseCookie is a dict subclass; SimpleCookie extends BaseCookie."
    - "CookieError is raised for invalid cookie operations."
    - "Morsel.key, Morsel.value, and Morsel.coded_value all default to None before .set() is called."
    - "_LegalKeyChars and _LegalChars are module-level string constants defining valid cookie characters."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

table http_cookies.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: classname

  columns: [id, function, args, expected]
  rows:
    - [BaseCookie,   BaseCookie.__name__.__eq__,   ["BaseCookie"],   true]
    - [SimpleCookie, SimpleCookie.__name__.__eq__,  ["SimpleCookie"], true]
    - [Morsel,       Morsel.__name__.__eq__,        ["Morsel"],       true]
    - [CookieError,  CookieError.__name__.__eq__,   ["CookieError"],  true]

# ---------------------------------------------------------------------------
# SimpleCookie — length
# ---------------------------------------------------------------------------

invariant http_cookies.empty_len:
  description: "SimpleCookie().__len__() == 0 — newly created cookie jar is empty"
  category: SimpleCookie
  kind: python_call_eq
  function: SimpleCookie
  args: []
  method: __len__
  method_args: []
  expected: 0

# ---------------------------------------------------------------------------
# Morsel — default attribute values before set()
# ---------------------------------------------------------------------------

invariant http_cookies.morsel_key_default:
  description: "Morsel().key is None before set() is called"
  category: Morsel
  kind: python_call_eq
  function: Morsel
  args: []
  method: key
  expected: null

invariant http_cookies.morsel_value_default:
  description: "Morsel().value is None before set() is called"
  category: Morsel
  kind: python_call_eq
  function: Morsel
  args: []
  method: value
  expected: null

invariant http_cookies.morsel_coded_value_default:
  description: "Morsel().coded_value is None before set() is called"
  category: Morsel
  kind: python_call_eq
  function: Morsel
  args: []
  method: coded_value
  expected: null

# ---------------------------------------------------------------------------
# Morsel._reserved — cookie directive registry
# ---------------------------------------------------------------------------

invariant http_cookies.morsel_reserved_type:
  description: "Morsel._reserved is a dict"
  category: Morsel
  kind: python_call_eq
  function: Morsel._reserved.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant http_cookies.morsel_reserved_path:
  description: "Morsel._reserved contains 'path'"
  category: Morsel
  kind: python_call_eq
  function: Morsel._reserved.__contains__
  args: ["path"]
  expected: true

invariant http_cookies.morsel_reserved_domain:
  description: "Morsel._reserved contains 'domain'"
  category: Morsel
  kind: python_call_eq
  function: Morsel._reserved.__contains__
  args: ["domain"]
  expected: true

invariant http_cookies.morsel_reserved_httponly:
  description: "Morsel._reserved contains 'httponly'"
  category: Morsel
  kind: python_call_eq
  function: Morsel._reserved.__contains__
  args: ["httponly"]
  expected: true

invariant http_cookies.morsel_reserved_secure:
  description: "Morsel._reserved contains 'secure'"
  category: Morsel
  kind: python_call_eq
  function: Morsel._reserved.__contains__
  args: ["secure"]
  expected: true

invariant http_cookies.morsel_reserved_expires:
  description: "Morsel._reserved contains 'expires'"
  category: Morsel
  kind: python_call_eq
  function: Morsel._reserved.__contains__
  args: ["expires"]
  expected: true

invariant http_cookies.morsel_reserved_maxage:
  description: "Morsel._reserved contains 'max-age'"
  category: Morsel
  kind: python_call_eq
  function: Morsel._reserved.__contains__
  args: ["max-age"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level character constants
# ---------------------------------------------------------------------------

invariant http_cookies.legal_key_chars_type:
  description: "_LegalKeyChars is a str"
  category: constants
  kind: python_call_eq
  function: _LegalKeyChars.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant http_cookies.legal_chars_type:
  description: "_LegalChars is a str"
  category: constants
  kind: python_call_eq
  function: _LegalChars.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# CookieError — exception hierarchy
# ---------------------------------------------------------------------------

invariant http_cookies.cookie_error_is_exception:
  description: "CookieError is a subclass of Exception"
  category: CookieError
  kind: python_call_eq
  function: issubclass
  args: ["CookieError", "Exception"]
  expected: true

# ---------------------------------------------------------------------------
# SimpleCookie — BaseCookie inheritance
# ---------------------------------------------------------------------------

invariant http_cookies.simple_cookie_inherits_base:
  description: "SimpleCookie is a subclass of BaseCookie"
  category: SimpleCookie
  kind: python_call_eq
  function: issubclass
  args: ["SimpleCookie", "BaseCookie"]
  expected: true
