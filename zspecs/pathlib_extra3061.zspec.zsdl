spec: pp3061
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 651 (pp3061): __aexit__, __await__, __anext__ dict-presence for pathlib types."
    - "pathlib path objects represent filesystem paths; none define __aexit__ in their own __dict__."
    - "None of the pathlib path classes define __await__ or __anext__ in their own __dict__; async protocols are absent from the pathlib interface."
    - "pathlib.PosixPath is available on macOS/Darwin 25.4.0."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __aexit__ dict-presence — operator.contains(Cls.__dict__, '__aexit__')
#
# pathlib path types do not implement the async context manager protocol;
# none define __aexit__ in their own __dict__; all false.
# ---------------------------------------------------------------------------

table pp3061.aexit:
  description: "pathlib types __aexit__ dict-presence checks; wave 651"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp3061
  columns: [id, function, args, expected]
  rows:
    - ["pp3061001", operator.contains, [pathlib.PurePath.__dict__,        "__aexit__"], false]
    - ["pp3061002", operator.contains, [pathlib.PurePosixPath.__dict__,   "__aexit__"], false]
    - ["pp3061003", operator.contains, [pathlib.PureWindowsPath.__dict__, "__aexit__"], false]
    - ["pp3061004", operator.contains, [pathlib.Path.__dict__,            "__aexit__"], false]
    - ["pp3061005", operator.contains, [pathlib.PosixPath.__dict__,       "__aexit__"], false]

