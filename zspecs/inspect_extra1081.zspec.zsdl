spec: inspect_extra1081
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks inspect.FrameInfo class identity, stack/currentframe/getframeinfo qualnames, getmembers_static qualname (3.11+), and getattr_static/classify_class_attrs module identity — not covered in _extra976/_extra991"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra1081.frameinfo_class_identity:
  description: "inspect.FrameInfo class-level module and qualname identity"
  kind: python_call_eq
  category: frameinfo_identity
  id_prefix: ip1081fi
  columns: [id, function, args, expected]
  rows:
    - [ip1081fi001, inspect.FrameInfo.__qualname__.__eq__,                   ["FrameInfo"],                    true]
    - [ip1081fi002, inspect.FrameInfo.__module__.__eq__,                     ["inspect"],                      true]
    - [ip1081fi003, inspect.FrameInfo.__class__.__name__.__eq__,             ["type"],                         true]
    - [ip1081fi004, inspect.FrameInfo.__doc__.__class__.__name__.__eq__,     ["str"],                          true]
    - [ip1081fi005, inspect.FrameInfo.__name__.__eq__,                       ["FrameInfo"],                    true]
    - [ip1081fi006, inspect.Traceback.__qualname__.__eq__,                   ["Traceback"],                    true]
    - [ip1081fi007, inspect.Traceback.__module__.__eq__,                     ["inspect"],                      true]

table inspect_extra1081.frame_stack_qualnames:
  description: "inspect frame and stack utility function __qualname__ identity"
  kind: python_call_eq
  category: frame_stack_qualnames
  id_prefix: ip1081fs
  columns: [id, function, args, expected]
  rows:
    - [ip1081fs001, inspect.stack.__qualname__.__eq__,                       ["stack"],                        true]
    - [ip1081fs002, inspect.stack.__module__.__eq__,                         ["inspect"],                      true]
    - [ip1081fs003, inspect.currentframe.__qualname__.__eq__,                ["currentframe"],                 true]
    - [ip1081fs004, inspect.currentframe.__module__.__eq__,                  ["inspect"],                      true]
    - [ip1081fs005, inspect.getframeinfo.__qualname__.__eq__,                ["getframeinfo"],                 true]
    - [ip1081fs006, inspect.getframeinfo.__module__.__eq__,                  ["inspect"],                      true]
    - [ip1081fs007, inspect.getouterframes.__qualname__.__eq__,              ["getouterframes"],               true]
    - [ip1081fs008, inspect.getinnerframes.__qualname__.__eq__,              ["getinnerframes"],               true]

table inspect_extra1081.static_inspection_module_identity:
  description: "inspect.getattr_static and classify_class_attrs __module__ identity and related qualnames"
  kind: python_call_eq
  category: static_inspection_identity
  id_prefix: ip1081si
  columns: [id, function, args, expected]
  rows:
    - [ip1081si001, inspect.getattr_static.__module__.__eq__,               ["inspect"],                      true]
    - [ip1081si002, inspect.classify_class_attrs.__module__.__eq__,         ["inspect"],                      true]
    - [ip1081si003, inspect.getmembers.__qualname__.__eq__,                 ["getmembers"],                   true]
    - [ip1081si004, inspect.getmembers.__module__.__eq__,                   ["inspect"],                      true]
    - [ip1081si005, inspect.getmro.__module__.__eq__,                       ["inspect"],                      true]
    - [ip1081si006, inspect.isgetsetdescriptor.__qualname__.__eq__,         ["isgetsetdescriptor"],           true]
    - [ip1081si007, inspect.ismemberdescriptor.__qualname__.__eq__,         ["ismemberdescriptor"],           true]
    - [ip1081si008, inspect.isgetsetdescriptor.__module__.__eq__,           ["inspect"],                      true]
