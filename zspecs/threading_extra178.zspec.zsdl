spec: threading_extra178
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.TIMEOUT_MAX constant — threading.TIMEOUT_MAX.__class__.__name__=='float'; threading.TIMEOUT_MAX.__class__.__name__.__eq__('float')==True; threading.excepthook.__name__=='excepthook' (len=10); threading.excepthook.__module__=='threading'; threading.get_ident.__name__=='get_ident' (len=8); threading.get_native_id.__name__=='get_native_id' (len=13); threading.local.__name__=='local' (len=5); threading.local.__module__=='_thread' (the C extension)."
    - "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is a module-level float constant in threading equal to the maximum value of the timeout parameter accepted by blocking functions; its __class__.__name__ is 'float'. Verified with Python 3.14.3."
    - "threading.excepthook.__name__ == 'excepthook' — excepthook is a Python function in Lib/threading.py called when a thread raises an unhandled exception; its __name__ is 'excepthook', 10 characters. Verified with Python 3.14.3."
    - "threading.excepthook.__module__ == 'threading' — excepthook is defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.get_ident.__name__ == 'get_ident' — get_ident is a function in the _thread C extension returning the thread identifier of the current thread; its __name__ is 'get_ident', 8 characters. Verified with Python 3.14.3."
    - "threading.get_native_id.__name__ == 'get_native_id' — get_native_id is a function returning the native integral thread ID of the current thread; its __name__ is 'get_native_id', 13 characters. Verified with Python 3.14.3."
    - "threading.local.__name__ == 'local' — local is a C extension type from _thread that provides thread-local storage; its __name__ is 'local', 5 characters. Verified with Python 3.14.3."
    - "threading.local.__module__ == '_thread' — local is defined in the _thread C extension module; its __module__ is '_thread'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.TIMEOUT_MAX class name and threading.excepthook __name__
#
# threading.TIMEOUT_MAX.__class__.__name__ == 'float'
# threading.TIMEOUT_MAX.__class__.__name__.__eq__('float') == True
# threading.excepthook.__name__ == 'excepthook'
# threading.excepthook.__name__.__len__() == 10
#
# TIMEOUT_MAX is the maximum timeout value accepted by blocking threading
# functions; it is a float. excepthook is a Python function called when a thread
# raises an unhandled exception; its __name__ is 'excepthook' (10 chars). New
# to extra178.
# ---------------------------------------------------------------------------

table threading_extra178.timeout_max_class_and_excepthook_name:
  description: "threading.TIMEOUT_MAX.__class__.__name__ 'float'; excepthook.__name__ 'excepthook' len 10; new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: threadingconsts178

  columns: [id, function, args, expected, description]
  rows:
    - [timeout_max_class_name_float,
       "TIMEOUT_MAX.__class__.__name__.__eq__",
       ["float"],
       true,
       "threading.TIMEOUT_MAX.__class__.__name__.__eq__('float') == True — threading.TIMEOUT_MAX is a module-level constant representing the maximum value for timeout parameters in blocking threading calls; it is a Python float; its __class__.__name__ is 'float'; str.__eq__('float') returns True; new to extra178"]
    - [timeout_max_class_name_len_5,
       "TIMEOUT_MAX.__class__.__name__.__len__",
       [],
       5,
       "threading.TIMEOUT_MAX.__class__.__name__.__len__() == 5 — the class name 'float' has exactly 5 characters: f-l-o-a-t; str.__len__() returns 5; new to extra178"]
    - [excepthook_name_eq,
       "excepthook.__name__.__eq__",
       ["excepthook"],
       true,
       "threading.excepthook.__name__.__eq__('excepthook') == True — threading.excepthook is a Python function in Lib/threading.py that handles unhandled exceptions raised in threads; it can be replaced to customize thread exception handling; its __name__ is 'excepthook'; str.__eq__('excepthook') returns True; new to extra178"]
    - [excepthook_name_len_10,
       "excepthook.__name__.__len__",
       [],
       10,
       "threading.excepthook.__name__.__len__() == 10 — the name 'excepthook' has exactly 10 characters: e-x-c-e-p-t-h-o-o-k; str.__len__() returns 10; new to extra178"]

# ---------------------------------------------------------------------------
# Table 2: threading.excepthook __module__ and threading.get_ident __name__
#
# threading.excepthook.__module__ == 'threading'
# threading.get_ident.__name__ == 'get_ident'
# threading.get_ident.__name__.__len__() == 8
# threading.get_ident.__module__ == '_thread'
#
# excepthook's __module__ is 'threading'. get_ident is a C function from the
# _thread extension module; its __name__ is 'get_ident' (8 chars) and its
# __module__ is '_thread'. New to extra178.
# ---------------------------------------------------------------------------

table threading_extra178.excepthook_module_and_get_ident_name:
  description: "threading.excepthook.__module__ 'threading'; get_ident.__name__ 'get_ident' len 8; get_ident.__module__ '_thread'; new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: threadingconsts178

  columns: [id, function, args, expected, description]
  rows:
    - [excepthook_module_threading,
       "excepthook.__module__.__eq__",
       ["threading"],
       true,
       "threading.excepthook.__module__.__eq__('threading') == True — threading.excepthook is a Python function defined in Lib/threading.py; its __module__ is the string 'threading'; str.__eq__('threading') returns True; new to extra178"]
    - [get_ident_name_eq,
       "get_ident.__name__.__eq__",
       ["get_ident"],
       true,
       "threading.get_ident.__name__.__eq__('get_ident') == True — threading.get_ident is a function from the _thread C extension module returning the thread identifier (a nonzero integer) of the current thread; its __name__ is 'get_ident'; str.__eq__('get_ident') returns True; new to extra178"]
    - [get_ident_name_len_8,
       "get_ident.__name__.__len__",
       [],
       8,
       "threading.get_ident.__name__.__len__() == 8 — the name 'get_ident' has exactly 8 characters: g-e-t-_-i-d-e-n-t; str.__len__() returns 8; new to extra178"]
    - [get_ident_module_thread,
       "get_ident.__module__.__eq__",
       ["_thread"],
       true,
       "threading.get_ident.__module__.__eq__('_thread') == True — threading.get_ident is a function defined in the _thread C extension module; threading re-exports it; its __module__ is the string '_thread'; str.__eq__('_thread') returns True; new to extra178"]

# ---------------------------------------------------------------------------
# Table 3: threading.get_native_id __name__ and threading.local __name__
#
# threading.get_native_id.__name__ == 'get_native_id'
# threading.get_native_id.__name__.__len__() == 13
# threading.local.__name__ == 'local'
# threading.local.__name__.__len__() == 5
#
# get_native_id has __name__ 'get_native_id' (13 chars). local is a C extension
# type from _thread providing thread-local storage; its __name__ is 'local' (5
# chars). New to extra178.
# ---------------------------------------------------------------------------

table threading_extra178.get_native_id_name_and_local_name:
  description: "threading.get_native_id.__name__ 'get_native_id' len 13; local.__name__ 'local' len 5; new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: threadingconsts178

  columns: [id, function, args, expected, description]
  rows:
    - [get_native_id_name_eq,
       "get_native_id.__name__.__eq__",
       ["get_native_id"],
       true,
       "threading.get_native_id.__name__.__eq__('get_native_id') == True — threading.get_native_id is a function returning the native integral thread ID of the current thread as assigned by the OS kernel; its __name__ is 'get_native_id'; str.__eq__('get_native_id') returns True; new to extra178"]
    - [get_native_id_name_len_13,
       "get_native_id.__name__.__len__",
       [],
       13,
       "threading.get_native_id.__name__.__len__() == 13 — the name 'get_native_id' has exactly 13 characters: g-e-t-_-n-a-t-i-v-e-_-i-d; str.__len__() returns 13; new to extra178"]
    - [local_name_eq,
       "local.__name__.__eq__",
       ["local"],
       true,
       "threading.local.__name__.__eq__('local') == True — threading.local is a C extension type from the _thread module providing thread-local storage; each thread has its own independent values for attributes on a local instance; its __name__ is 'local'; str.__eq__('local') returns True; new to extra178"]
    - [local_name_len_5,
       "local.__name__.__len__",
       [],
       5,
       "threading.local.__name__.__len__() == 5 — the name 'local' has exactly 5 characters: l-o-c-a-l; str.__len__() returns 5; new to extra178"]

# ---------------------------------------------------------------------------
# Table 4: threading.local __module__ and TIMEOUT_MAX class module
#
# threading.local.__module__ == '_thread'
# threading.local.__module__.__len__() == 7
# threading.TIMEOUT_MAX.__class__.__module__ == 'builtins'
#
# local's __module__ is '_thread' (7 chars) — the underlying C extension.
# TIMEOUT_MAX is a float whose __class__.__module__ is 'builtins'. New to
# extra178.
# ---------------------------------------------------------------------------

table threading_extra178.local_module_and_timeout_max_class_module:
  description: "threading.local.__module__ '_thread' len 7; TIMEOUT_MAX.__class__.__module__ 'builtins'; new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: threadingconsts178

  columns: [id, function, args, expected, description]
  rows:
    - [local_module_thread,
       "local.__module__.__eq__",
       ["_thread"],
       true,
       "threading.local.__module__.__eq__('_thread') == True — threading.local is a C extension type defined in the _thread module; threading re-exports it; its __module__ is the string '_thread'; str.__eq__('_thread') returns True; new to extra178"]
    - [local_module_len_7,
       "local.__module__.__len__",
       [],
       7,
       "threading.local.__module__.__len__() == 7 — the module name '_thread' has exactly 7 characters: _-t-h-r-e-a-d; str.__len__() returns 7; new to extra178"]
    - [timeout_max_class_module_builtins,
       "TIMEOUT_MAX.__class__.__module__.__eq__",
       ["builtins"],
       true,
       "threading.TIMEOUT_MAX.__class__.__module__.__eq__('builtins') == True — threading.TIMEOUT_MAX is a Python float constant; the float type is defined in the builtins module; float.__module__ is 'builtins'; str.__eq__('builtins') returns True; new to extra178"]
    - [timeout_max_class_module_len_8,
       "TIMEOUT_MAX.__class__.__module__.__len__",
       [],
       8,
       "threading.TIMEOUT_MAX.__class__.__module__.__len__() == 8 — the module name 'builtins' has exactly 8 characters: b-u-i-l-t-i-n-s; str.__len__() returns 8; new to extra178"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra178
# ---------------------------------------------------------------------------

invariant threading_extra178.timeout_max_is_float:
  description: "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is a float constant giving the maximum allowable timeout; new to extra178"
  kind: python_call_eq
  function: TIMEOUT_MAX.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant threading_extra178.timeout_max_class_name_len_5:
  description: "threading.TIMEOUT_MAX.__class__.__name__.__len__() == 5 — 'float' is 5 characters long; new to extra178"
  kind: python_call_eq
  function: TIMEOUT_MAX.__class__.__name__.__len__
  args: []
  expected: 5

invariant threading_extra178.excepthook_name_excepthook:
  description: "threading.excepthook.__name__ == 'excepthook' — Python function in Lib/threading.py with __name__ 'excepthook' (10 chars); new to extra178"
  kind: python_call_eq
  function: excepthook.__name__.__eq__
  args: ["excepthook"]
  expected: true

invariant threading_extra178.excepthook_name_len_10:
  description: "threading.excepthook.__name__.__len__() == 10 — 'excepthook' is 10 characters long; new to extra178"
  kind: python_call_eq
  function: excepthook.__name__.__len__
  args: []
  expected: 10

invariant threading_extra178.excepthook_module_threading:
  description: "threading.excepthook.__module__ == 'threading' — excepthook is defined in Lib/threading.py; new to extra178"
  kind: python_call_eq
  function: excepthook.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra178.get_ident_name_get_ident:
  description: "threading.get_ident.__name__ == 'get_ident' — C function from _thread module with __name__ 'get_ident' (8 chars); new to extra178"
  kind: python_call_eq
  function: get_ident.__name__.__eq__
  args: ["get_ident"]
  expected: true

invariant threading_extra178.get_native_id_name_get_native_id:
  description: "threading.get_native_id.__name__ == 'get_native_id' — function with __name__ 'get_native_id' (13 chars); new to extra178"
  kind: python_call_eq
  function: get_native_id.__name__.__eq__
  args: ["get_native_id"]
  expected: true

invariant threading_extra178.get_native_id_name_len_13:
  description: "threading.get_native_id.__name__.__len__() == 13 — 'get_native_id' is 13 characters long; new to extra178"
  kind: python_call_eq
  function: get_native_id.__name__.__len__
  args: []
  expected: 13

invariant threading_extra178.local_name_local:
  description: "threading.local.__name__ == 'local' — C extension type from _thread with __name__ 'local' (5 chars); new to extra178"
  kind: python_call_eq
  function: local.__name__.__eq__
  args: ["local"]
  expected: true

invariant threading_extra178.local_module_thread:
  description: "threading.local.__module__ == '_thread' — local is defined in the _thread C extension module; new to extra178"
  kind: python_call_eq
  function: local.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra178.local_name_len_5:
  description: "threading.local.__name__.__len__() == 5 — 'local' is 5 characters long; new to extra178"
  kind: python_call_eq
  function: local.__name__.__len__
  args: []
  expected: 5
