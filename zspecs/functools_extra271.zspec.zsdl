spec: functools_extra271
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "functools.reduce.__module__ == '_functools' (len=10) — reduce is implemented in C, not in Lib/functools.py."
    - "functools.reduce.__class__.__name__ == 'builtin_function_or_method' (len=26) — longest class name in spec."
    - "functools.partial.__class__.__name__ == 'type' (len=4) — partial is a C-level class, not a Python function."
    - "functools.partial.__module__ == 'functools' (len=9) — partial is exposed in the functools namespace."
    - "functools.lru_cache.__class__.__name__ == 'function' (len=8) — lru_cache is a Python function (decorator factory)."
    - "functools.cached_property.__name__ == 'cached_property' (len=15) — longest name in spec."
    - "functools.wraps.__name__ == 'wraps' (len=5) — shortest name in spec alongside cached_property's 15."
    - "reduce.__name__ (6) < partial.__name__ (7) < lru_cache.__name__ (9) < cached_property.__name__ (15)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.reduce and functools.partial identity
#
# reduce is a C builtin (module == '_functools'); partial is a C class
# (class.__name__ == 'type'). Both are exposed through the functools namespace.
# reduce.__name__ (len=6) < partial.__name__ (len=7).
# reduce.__class__.__name__ == 'builtin_function_or_method' (len=26) is longest.
# ---------------------------------------------------------------------------

table functools_extra271.reduce_partial_identity:
  description: "functools.reduce(len=6) and functools.partial(len=7) identity — reduce is a C builtin from _functools(len=10); partial is a C class with class.__name__=='type'(len=4); reduce.__class__.__name__=='builtin_function_or_method'(len=26) is longest value; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftex271rp

  columns: [id, function, args, expected, description]
  rows:
    - [rd_name_eq,       reduce.__name__.__eq__,                     ["reduce"],                     true, "functools.reduce.__name__ == 'reduce'; verified with Python 3.14.3"]
    - [rd_name_len,      reduce.__name__.__len__,                    [],                             6,    "functools.reduce.__name__.__len__() == 6; verified with Python 3.14.3"]
    - [rd_mod_eq,        reduce.__module__.__eq__,                   ["_functools"],                 true, "functools.reduce.__module__ == '_functools' — C implementation; verified with Python 3.14.3"]
    - [rd_mod_len,       reduce.__module__.__len__,                  [],                             10,   "functools.reduce.__module__.__len__() == 10; verified with Python 3.14.3"]
    - [rd_qn_eq,         reduce.__qualname__.__eq__,                 ["reduce"],                     true, "functools.reduce.__qualname__ == 'reduce'; verified with Python 3.14.3"]
    - [rd_cls_eq,        reduce.__class__.__name__.__eq__,           ["builtin_function_or_method"], true, "functools.reduce.__class__.__name__ == 'builtin_function_or_method'; verified with Python 3.14.3"]
    - [rd_cls_len,       reduce.__class__.__name__.__len__,          [],                             26,   "functools.reduce.__class__.__name__.__len__() == 26 — longest class name value in spec; verified with Python 3.14.3"]
    - [pt_name_eq,       partial.__name__.__eq__,                    ["partial"],                    true, "functools.partial.__name__ == 'partial'; verified with Python 3.14.3"]
    - [pt_name_len,      partial.__name__.__len__,                   [],                             7,    "functools.partial.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [pt_mod_eq,        partial.__module__.__eq__,                  ["functools"],                  true, "functools.partial.__module__ == 'functools'; verified with Python 3.14.3"]
    - [pt_mod_len,       partial.__module__.__len__,                 [],                             9,    "functools.partial.__module__.__len__() == 9; verified with Python 3.14.3"]
    - [pt_qn_eq,         partial.__qualname__.__eq__,                ["partial"],                    true, "functools.partial.__qualname__ == 'partial'; verified with Python 3.14.3"]
    - [pt_cls_eq,        partial.__class__.__name__.__eq__,          ["type"],                       true, "functools.partial.__class__.__name__ == 'type' — partial is a C-level class; verified with Python 3.14.3"]
    - [pt_cls_len,       partial.__class__.__name__.__len__,         [],                             4,    "functools.partial.__class__.__name__.__len__() == 4; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# functools.lru_cache, functools.cached_property, functools.wraps identity
#
# lru_cache and wraps are Python functions (class.__name__ == 'function').
# cached_property is a Python class (class.__name__ == 'type').
# cached_property.__name__ (len=15) is the longest name in spec.
# wraps.__name__ (len=5) is the shortest name in spec.
# All three have __module__ == 'functools' (len=9).
# ---------------------------------------------------------------------------

table functools_extra271.lru_cache_cached_property_wraps_identity:
  description: "functools.lru_cache(len=9), cached_property(len=15), wraps(len=5) identity — all defined in functools(len=9); lru_cache and wraps are plain Python functions; cached_property is a class (type); cached_property name (15) is longest, wraps name (5) is shortest; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftex271lcw

  columns: [id, function, args, expected, description]
  rows:
    - [lc_name_eq,       lru_cache.__name__.__eq__,                  ["lru_cache"],                  true, "functools.lru_cache.__name__ == 'lru_cache'; verified with Python 3.14.3"]
    - [lc_name_len,      lru_cache.__name__.__len__,                 [],                             9,    "functools.lru_cache.__name__.__len__() == 9 — equals module name length; verified with Python 3.14.3"]
    - [lc_mod_eq,        lru_cache.__module__.__eq__,                ["functools"],                  true, "functools.lru_cache.__module__ == 'functools'; verified with Python 3.14.3"]
    - [lc_qn_eq,         lru_cache.__qualname__.__eq__,              ["lru_cache"],                  true, "functools.lru_cache.__qualname__ == 'lru_cache'; verified with Python 3.14.3"]
    - [lc_cls_eq,        lru_cache.__class__.__name__.__eq__,        ["function"],                   true, "functools.lru_cache.__class__.__name__ == 'function' — plain Python decorator factory; verified with Python 3.14.3"]
    - [cp_name_eq,       cached_property.__name__.__eq__,            ["cached_property"],             true, "functools.cached_property.__name__ == 'cached_property'; verified with Python 3.14.3"]
    - [cp_name_len,      cached_property.__name__.__len__,           [],                             15,   "functools.cached_property.__name__.__len__() == 15 — longest name in spec; verified with Python 3.14.3"]
    - [cp_mod_eq,        cached_property.__module__.__eq__,          ["functools"],                  true, "functools.cached_property.__module__ == 'functools'; verified with Python 3.14.3"]
    - [cp_qn_eq,         cached_property.__qualname__.__eq__,        ["cached_property"],             true, "functools.cached_property.__qualname__ == 'cached_property'; verified with Python 3.14.3"]
    - [cp_cls_eq,        cached_property.__class__.__name__.__eq__,  ["type"],                       true, "functools.cached_property.__class__.__name__ == 'type' — cached_property is a class; verified with Python 3.14.3"]
    - [wr_name_eq,       wraps.__name__.__eq__,                      ["wraps"],                      true, "functools.wraps.__name__ == 'wraps'; verified with Python 3.14.3"]
    - [wr_name_len,      wraps.__name__.__len__,                     [],                             5,    "functools.wraps.__name__.__len__() == 5 — shortest name in spec; verified with Python 3.14.3"]
    - [wr_mod_eq,        wraps.__module__.__eq__,                    ["functools"],                  true, "functools.wraps.__module__ == 'functools'; verified with Python 3.14.3"]
    - [wr_qn_eq,         wraps.__qualname__.__eq__,                  ["wraps"],                      true, "functools.wraps.__qualname__ == 'wraps'; verified with Python 3.14.3"]
    - [wr_cls_eq,        wraps.__class__.__name__.__eq__,            ["function"],                   true, "functools.wraps.__class__.__name__ == 'function' — plain Python decorator; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — functools_extra271
# ---------------------------------------------------------------------------

invariant functools_extra271.reduce_module_is_cfunctools:
  description: "functools.reduce.__module__ == '_functools' — reduce is a C builtin; its module is '_functools' (len=10), not 'functools' (len=9); this distinguishes it from all other members in this spec"
  category: identity
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra271.partial_is_type:
  description: "functools.partial.__class__.__name__ == 'type' — partial is a C-level class, unlike lru_cache and wraps which are plain Python functions with class.__name__=='function'"
  category: identity
  kind: python_call_eq
  function: partial.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra271.reduce_doc_is_str:
  description: "functools.reduce.__doc__.__class__.__name__ == 'str' — reduce has a docstring (not None)"
  category: identity
  kind: python_call_eq
  function: reduce.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra271.lru_cache_name_len_equals_module_len:
  description: "functools.lru_cache.__name__.__len__() == 9 == functools.lru_cache.__module__.__len__() — name 'lru_cache' and module 'functools' are both length 9"
  category: identity
  kind: python_call_eq
  function: lru_cache.__name__.__len__
  args: []
  expected: 9

invariant functools_extra271.cached_property_module_is_functools:
  description: "functools.cached_property.__module__ == 'functools' — cached_property is defined in the pure-Python functools module, not a C extension"
  category: identity
  kind: python_call_eq
  function: cached_property.__module__.__eq__
  args: ["functools"]
  expected: true
