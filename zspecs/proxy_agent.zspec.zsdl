spec: proxy_agent
version: ">=6.0.0"
backend: node(proxy-agent)

docs: https://github.com/TooTallNate/proxy-agents/tree/main/packages/proxy-agent#readme

provenance:
  derived_from:
    - "proxy-agent README — https://github.com/TooTallNate/proxy-agents/tree/main/packages/proxy-agent#readme"
    - "Test vectors verified with proxy-agent via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "proxy-agent source"
  notes:
    - "Universal http(s).Agent that auto-selects http/https/socks/pac proxies based on the URL scheme."
    - "Install: npm install proxy-agent"
    - "v6 CJS; named exports ProxyAgent (class) plus a `proxies` map of scheme → factory pair."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Connection errors propagate via the http request object; unsupported schemes throw on construction."
  stderr: "null"
  stickiness: "Each agent instance holds the proxy URL it was constructed with."
  codes: {}

invariant proxy_agent.has_ProxyAgent:
  description: "ProxyAgent class exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "ProxyAgent.constructor.name"}
  expected: "Function"

invariant proxy_agent.ProxyAgent_name:
  description: "ProxyAgent.name is 'ProxyAgent'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "ProxyAgent.name"}
  expected: "ProxyAgent"

invariant proxy_agent.proxies_has_http:
  description: "proxies map has 'http' scheme"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: proxies}
    - {method: hasOwnProperty, args: ["http"]}
  expected: true

invariant proxy_agent.proxies_has_https:
  description: "proxies map has 'https' scheme"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: proxies}
    - {method: hasOwnProperty, args: ["https"]}
  expected: true

invariant proxy_agent.proxies_has_socks:
  description: "proxies map has 'socks' scheme"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: proxies}
    - {method: hasOwnProperty, args: ["socks"]}
  expected: true

invariant proxy_agent.proxies_has_socks5:
  description: "proxies map has 'socks5' scheme"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: proxies}
    - {method: hasOwnProperty, args: ["socks5"]}
  expected: true
