spec: csv_extra
version: ">=3.2"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "Python csv documentation — https://docs.python.org/3/library/csv.html"
    - "RFC 4180 — Common Format and MIME Type for Comma-Separated Values (CSV) Files"
    - "Test vectors verified by running Python 3.12 csv module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
  notes:
    - "This spec extends csv.zspec.zsdl with DictReader, DictWriter, unix_dialect, and QUOTE_NOTNULL / QUOTE_STRINGS constants."
    - "csv.DictReader wraps reader; each row is returned as an OrderedDict (Python <3.8) or plain dict (Python 3.8+)."
    - "csv.DictReader(['a,b', '1,2'], fieldnames=['x','y']).__next__() == {'x': 'a', 'y': 'b'}."
    - "csv.DictWriter(f, fieldnames=[...]) writes dict rows; writeheader() writes the fieldnames row."
    - "csv.unix_dialect uses '\\n' (LF) as lineterminator, unlike csv.excel which uses '\\r\\n'."
    - "csv.unix_dialect.quoting == csv.QUOTE_ALL (1)."
    - "QUOTE_NOTNULL (4) and QUOTE_STRINGS (5) were added in Python 3.12."
    - "csv.Dialect is the abstract base class; csv.excel and csv.excel_tab are concrete subclasses."
    - "csv.excel_tab.quoting == 0 (QUOTE_MINIMAL), same as csv.excel."
    - "csv.excel_tab.lineterminator == '\\r\\n' (same CRLF as excel)."
    - "DictReader.fieldnames is populated from the first row when not supplied explicitly."
    - "All expected values verified by running Python 3.12 csv module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# csv.DictReader — class identity
# ---------------------------------------------------------------------------

invariant csv_extra.DictReader.class_name:
  description: "csv.DictReader.__name__ == 'DictReader'"
  category: classnames
  kind: python_call_eq
  function: DictReader.__name__.__eq__
  args: ["DictReader"]
  expected: true

invariant csv_extra.DictReader.module:
  description: "csv.DictReader.__module__ == 'csv'"
  category: classnames
  kind: python_call_eq
  function: DictReader.__module__.__eq__
  args: ["csv"]
  expected: true

# ---------------------------------------------------------------------------
# csv.DictReader — row parsing
# ---------------------------------------------------------------------------

invariant csv_extra.DictReader.basic_row:
  description: "DictReader(['x,y', '1,2']).__next__() == {'x': '1', 'y': '2'} — first data row as dict"
  category: DictReader
  kind: python_call_eq
  function: DictReader
  args: [["x,y", "1,2"]]
  method: __next__
  expected: {x: "1", y: "2"}

invariant csv_extra.DictReader.explicit_fieldnames:
  description: "DictReader(['a,b'], fieldnames=['col1','col2']).__next__() == {'col1': 'a', 'col2': 'b'}"
  category: DictReader
  kind: python_call_eq
  function: DictReader
  args: [["a,b"]]
  kwargs: {fieldnames: ["col1", "col2"]}
  method: __next__
  expected: {col1: "a", col2: "b"}

# ---------------------------------------------------------------------------
# csv.DictWriter — class identity
# ---------------------------------------------------------------------------

invariant csv_extra.DictWriter.class_name:
  description: "csv.DictWriter.__name__ == 'DictWriter'"
  category: classnames
  kind: python_call_eq
  function: DictWriter.__name__.__eq__
  args: ["DictWriter"]
  expected: true

invariant csv_extra.DictWriter.module:
  description: "csv.DictWriter.__module__ == 'csv'"
  category: classnames
  kind: python_call_eq
  function: DictWriter.__module__.__eq__
  args: ["csv"]
  expected: true

# ---------------------------------------------------------------------------
# csv.unix_dialect — class identity and properties
# ---------------------------------------------------------------------------

invariant csv_extra.unix_dialect.class_name:
  description: "csv.unix_dialect.__name__ == 'unix_dialect'"
  category: classnames
  kind: python_call_eq
  function: unix_dialect.__name__.__eq__
  args: ["unix_dialect"]
  expected: true

invariant csv_extra.unix_dialect.lineterminator:
  description: "csv.unix_dialect.lineterminator == '\\n' (LF, not CRLF)"
  category: unix_dialect
  kind: python_call_eq
  function: unix_dialect.lineterminator.__eq__
  args: ["\n"]
  expected: true

invariant csv_extra.unix_dialect.quoting:
  description: "csv.unix_dialect.quoting == 1 (QUOTE_ALL)"
  category: unix_dialect
  kind: python_call_eq
  function: unix_dialect.quoting.__eq__
  args: [1]
  expected: true

invariant csv_extra.unix_dialect.delimiter:
  description: "csv.unix_dialect.delimiter == ',' (standard comma separator)"
  category: unix_dialect
  kind: python_call_eq
  function: unix_dialect.delimiter.__eq__
  args: [","]
  expected: true

# ---------------------------------------------------------------------------
# csv.excel_tab — additional properties not in csv.zspec.zsdl
# ---------------------------------------------------------------------------

invariant csv_extra.excel_tab.lineterminator:
  description: "csv.excel_tab.lineterminator == '\\r\\n' (CRLF, same as excel)"
  category: excel_tab_dialect
  kind: python_call_eq
  function: excel_tab.lineterminator.__eq__
  args: ["\r\n"]
  expected: true

invariant csv_extra.excel_tab.quoting:
  description: "csv.excel_tab.quoting == 0 (QUOTE_MINIMAL)"
  category: excel_tab_dialect
  kind: python_call_eq
  function: excel_tab.quoting.__eq__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# Dialect inheritance
# ---------------------------------------------------------------------------

invariant csv_extra.excel.base_is_Dialect:
  description: "csv.excel.__bases__[0].__name__ == 'Dialect' — excel inherits from Dialect"
  category: classnames
  kind: python_call_eq
  function: excel.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Dialect"

invariant csv_extra.excel_tab.base_is_excel:
  description: "csv.excel_tab.__bases__[0].__name__ == 'excel' — excel_tab inherits from excel"
  category: classnames
  kind: python_call_eq
  function: excel_tab.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "excel"
