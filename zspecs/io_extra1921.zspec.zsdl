spec: io_extra1921
version: ">=3.9"
backend: python_module(io)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "Wave 575 (_extra1921): __slots__, __abstractmethods__, __subclasshook__, __init_subclass__ checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase are ABCs defined in the _io C extension; their __dict__ contains __abstractmethods__ (frozenset, possibly empty) because they are abstract base classes registered via ABCMeta machinery."
    - "io.BytesIO, io.StringIO, io.FileIO are concrete C extension types; their __dict__ does NOT contain __abstractmethods__."
    - "None of the io C extension types define Python-level __slots__; __slots__ is absent from all their __dict__s."
    - "None of the io types define __subclasshook__ in their own __dict__."
    - "None of the io types define __init_subclass__ in their own __dict__."
    - "io.IOBase.__abstractmethods__ == frozenset() — the set exists but is empty; the ABC machinery still marks the class as abstract."
    - "io.RawIOBase, io.BufferedIOBase, io.TextIOBase also carry __abstractmethods__ in __dict__ (frozenset)."
  created_at: "2026-04-12"

error_model: python_exceptions

table io_extra1921.slots_protocol:
  description: "io types __slots__ dict-presence checks — all false (C extension types, no Python __slots__)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1921

  columns: [id, function, args, expected]
  rows:
    - ["io1921001", "io.IOBase.__dict__.__contains__", ["__slots__"], false]
    - ["io1921002", "io.RawIOBase.__dict__.__contains__", ["__slots__"], false]
    - ["io1921003", "io.BufferedIOBase.__dict__.__contains__", ["__slots__"], false]
    - ["io1921004", "io.TextIOBase.__dict__.__contains__", ["__slots__"], false]
    - ["io1921005", "io.BytesIO.__dict__.__contains__", ["__slots__"], false]
    - ["io1921006", "io.StringIO.__dict__.__contains__", ["__slots__"], false]
    - ["io1921007", "io.FileIO.__dict__.__contains__", ["__slots__"], false]

table io_extra1921.abstractmethods_protocol:
  description: "io types __abstractmethods__ dict-presence checks — ABCs have it, concrete types do not"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1921

  columns: [id, function, args, expected]
  rows:
    - ["io1921011", "io.IOBase.__dict__.__contains__", ["__abstractmethods__"], true]
    - ["io1921012", "io.RawIOBase.__dict__.__contains__", ["__abstractmethods__"], true]
    - ["io1921013", "io.BufferedIOBase.__dict__.__contains__", ["__abstractmethods__"], true]
    - ["io1921014", "io.TextIOBase.__dict__.__contains__", ["__abstractmethods__"], true]
    - ["io1921015", "io.BytesIO.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["io1921016", "io.StringIO.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["io1921017", "io.FileIO.__dict__.__contains__", ["__abstractmethods__"], false]

