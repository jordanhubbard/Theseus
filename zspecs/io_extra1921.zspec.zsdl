    - ["io1921022", "io.RawIOBase.__dict__.__contains__", ["__subclasshook__"], false]
    - ["io1921023", "io.BufferedIOBase.__dict__.__contains__", ["__subclasshook__"], false]
    - ["io1921024", "io.TextIOBase.__dict__.__contains__", ["__subclasshook__"], false]
    - ["io1921025", "io.BytesIO.__dict__.__contains__", ["__subclasshook__"], false]
    - ["io1921026", "io.StringIO.__dict__.__contains__", ["__subclasshook__"], false]
    - ["io1921027", "io.FileIO.__dict__.__contains__", ["__subclasshook__"], false]

