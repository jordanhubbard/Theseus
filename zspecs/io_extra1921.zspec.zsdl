table io_extra1921.abstract_vs_concrete_cross:
  description: "Cross-check: ABCs have __abstractmethods__, concrete types do not; none have __slots__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1921

  columns: [id, function, args, expected]
  rows:
    - ["io1921041", "io.IOBase.__dict__.__contains__", ["__abstractmethods__"], true]
    - ["io1921042", "io.BytesIO.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["io1921043", "io.IOBase.__dict__.__contains__", ["__slots__"], false]
    - ["io1921044", "io.BytesIO.__dict__.__contains__", ["__slots__"], false]
    - ["io1921045", "io.TextIOBase.__dict__.__contains__", ["__abstractmethods__"], true]
    - ["io1921046", "io.StringIO.__dict__.__contains__", ["__abstractmethods__"], false]
