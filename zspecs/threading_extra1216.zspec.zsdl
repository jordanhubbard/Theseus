spec: threading_extra1216
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks threading.Thread.__mro__.__len__() == 2, threading.Condition.__mro__.__len__() == 2, threading.Event.__mro__.__len__() == 2, threading.Barrier.__mro__.__len__() == 2, threading.Timer.__mro__.__len__() == 3, threading.Semaphore.__mro__.__len__() == 2, threading.BoundedSemaphore.__mro__.__len__() == 3, threading.RLock.__class__.__name__ == 'function', threading.RLock.__module__ == 'threading', threading.RLock.__qualname__ == 'RLock', threading.Lock.__qualname__ == 'lock', threading.Timer.__bases__[0].__name__ == 'Thread', threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — not covered in _extra1186/_extra1201"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra1216.thread_condition_event_barrier_mro_len:
  description: "threading.Thread, Condition, Event, and Barrier __mro__.__len__() identity"
  kind: python_call_eq
  category: thread_condition_event_barrier_mro_len
  id_prefix: th1216tc
  columns: [id, function, args, expected]
  rows:
    - [th1216tc001, threading.Thread.__mro__.__len__,                          [],   2]
    - [th1216tc002, threading.Thread.__mro__.__class__.__name__.__eq__,        ["tuple"], true]
    - [th1216tc003, threading.Condition.__mro__.__len__,                       [],   2]
    - [th1216tc004, threading.Condition.__mro__.__class__.__name__.__eq__,     ["tuple"], true]
    - [th1216tc005, threading.Event.__mro__.__len__,                           [],   2]
    - [th1216tc006, threading.Event.__mro__.__class__.__name__.__eq__,         ["tuple"], true]
    - [th1216tc007, threading.Barrier.__mro__.__len__,                         [],   2]
    - [th1216tc008, threading.Barrier.__mro__.__class__.__name__.__eq__,       ["tuple"], true]

table threading_extra1216.timer_semaphore_boundedsemaphore_mro_len:
  description: "threading.Timer, Semaphore, and BoundedSemaphore __mro__.__len__() and inheritance identity"
  kind: python_call_eq
  category: timer_semaphore_boundedsemaphore_mro_len
  id_prefix: th1216ts
  columns: [id, function, args, expected]
  rows:
    - [th1216ts001, threading.Semaphore.__mro__.__len__,                       [],   2]
    - [th1216ts002, threading.Semaphore.__mro__.__class__.__name__.__eq__,     ["tuple"], true]
    - [th1216ts003, threading.BoundedSemaphore.__mro__.__len__,                [],   3]
    - [th1216ts004, threading.BoundedSemaphore.__mro__.__class__.__name__.__eq__, ["tuple"], true]
    - [th1216ts005, threading.Timer.__mro__.__len__,                           [],   3]
    - [th1216ts006, threading.Timer.__mro__.__class__.__name__.__eq__,         ["tuple"], true]
    - [th1216ts007, threading.Timer.__module__.__eq__,                         ["threading"], true]
    - [th1216ts008, threading.BoundedSemaphore.__module__.__eq__,              ["threading"], true]

table threading_extra1216.rlock_function_and_lock_qualname:
  description: "threading.RLock factory-function identity and threading.Lock qualname identity"
  kind: python_call_eq
  category: rlock_function_and_lock_qualname
  id_prefix: th1216rl
  columns: [id, function, args, expected]
  rows:
    - [th1216rl001, threading.RLock.__class__.__name__.__eq__,     ["function"],    true]
    - [th1216rl002, threading.RLock.__module__.__eq__,             ["threading"],   true]
    - [th1216rl003, threading.RLock.__qualname__.__eq__,           ["RLock"],       true]
    - [th1216rl004, threading.Lock.__qualname__.__eq__,            ["lock"],        true]
    - [th1216rl005, threading.Lock.__module__.__eq__,              ["_thread"],     true]
    - [th1216rl006, threading.Lock.__class__.__name__.__eq__,      ["type"],        true]
    - [th1216rl007, threading.Thread.__module__.__eq__,            ["threading"],   true]
    - [th1216rl008, threading.Condition.__module__.__eq__,         ["threading"],   true]
