spec: functools_extra30
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra29.zspec.zsdl."
    - "functools_extra29 covers: partial/cached_property/singledispatch class-level qualnames as table and standalone invariants."
    - "functools_extra28 covers: partial.__call__, partial.__new__; cached_property.__set_name__, cached_property.__get__; partialmethod.__get__; lru_cache qualname."
    - "functools_extra26 covers: combined __qualname__.__eq__ table for reduce/lru_cache/cache/wraps/total_ordering/singledispatch/cached_property/partialmethod."
    - "No prior functools spec records __module__ for singledispatch/total_ordering/cmp_to_key, or WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES class names and lengths, together in the extra30 namespace."
    - "Focus: __module__ attributes for singledispatch/total_ordering/cached_property/cmp_to_key; WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES container type and length invariants."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "Note: cmp_to_key.__module__ == '_functools' because it is implemented in the C extension module."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__eq__ table — Python-level functools callable module membership
#
# singledispatch, total_ordering, and cached_property are all defined in
# Lib/functools.py; their __module__ is 'functools'. wraps is also Python-level.
# No prior functools spec records all four __module__ values together in one
# table in the extra30 namespace.
# ---------------------------------------------------------------------------

table functools_extra30.callable_modules:
  kind: python_call_eq
  category: module_membership
  columns: [id, function, args, expected, description]
  rows:
    - [functools_extra30.callable_modules.singledispatch,
       singledispatch.__module__.__eq__,
       ["functools"],
       true,
       "functools.singledispatch.__module__ == 'functools'"]
    - [functools_extra30.callable_modules.total_ordering,
       total_ordering.__module__.__eq__,
       ["functools"],
       true,
       "functools.total_ordering.__module__ == 'functools'"]
    - [functools_extra30.callable_modules.cached_property,
       cached_property.__module__.__eq__,
       ["functools"],
       true,
       "functools.cached_property.__module__ == 'functools'"]
    - [functools_extra30.callable_modules.wraps,
       wraps.__module__.__eq__,
       ["functools"],
       true,
       "functools.wraps.__module__ == 'functools'"]

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — total_ordering and cmp_to_key qualnames
#
# functools.total_ordering is a Python-level decorator function defined at
# module scope; its qualname is 'total_ordering'. functools.cmp_to_key is
# a C-level builtin in _functools; its qualname is 'cmp_to_key'.
# No prior functools spec records these two qualnames together in the extra30
# namespace.
# ---------------------------------------------------------------------------

table functools_extra30.decorator_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [functools_extra30.decorator_qualnames.total_ordering,
       total_ordering.__qualname__.__eq__,
       ["total_ordering"],
       true,
       "functools.total_ordering.__qualname__ == 'total_ordering'"]
    - [functools_extra30.decorator_qualnames.cmp_to_key,
       cmp_to_key.__qualname__.__eq__,
       ["cmp_to_key"],
       true,
       "functools.cmp_to_key.__qualname__ == 'cmp_to_key'"]

# ---------------------------------------------------------------------------
# WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES container type names
#
# functools.WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES are module-level tuple
# constants. Their __class__.__name__ is 'tuple', confirming they are plain
# Python tuples and not any custom container subclass.
# No prior functools spec records these container type names in the extra30
# namespace.
# ---------------------------------------------------------------------------

table functools_extra30.wrapper_constants_types:
  kind: python_call_eq
  category: types
  columns: [id, function, args, expected, description]
  rows:
    - [functools_extra30.wrapper_constants_types.assignments_class,
       WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'"]
    - [functools_extra30.wrapper_constants_types.updates_class,
       WRAPPER_UPDATES.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple'"]

# ---------------------------------------------------------------------------
# cmp_to_key.__module__.__eq__ — C-extension module membership
#
# functools.cmp_to_key is implemented in the C extension _functools. Its
# __module__ is '_functools', not 'functools'. This records the distinction
# between C-level and Python-level functools symbols.
# No prior functools spec records this in the extra30 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra30.cmp_to_key.module:
  description: "functools.cmp_to_key.__module__ == '_functools' (C-extension)"
  category: module_membership
  kind: python_call_eq
  function: cmp_to_key.__module__.__eq__
  args: ["_functools"]
  expected: true

# ---------------------------------------------------------------------------
# WRAPPER_ASSIGNMENTS.__len__() — tuple length
#
# functools.WRAPPER_ASSIGNMENTS is a tuple of attribute name strings copied
# by functools.wraps from the wrapped function to the wrapper. Its length
# reflects the number of attributes in the standard wraps contract.
# Verified: len == 6 on Python 3.12+
# (includes __module__, __name__, __qualname__, __doc__, __annotate__,
# __type_params__).
# No prior functools spec records this length in the extra30 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra30.WRAPPER_ASSIGNMENTS.len:
  description: "len(functools.WRAPPER_ASSIGNMENTS) == 6"
  category: constants
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# WRAPPER_UPDATES.__len__() — tuple length
#
# functools.WRAPPER_UPDATES is a tuple of attribute names merged (rather than
# replaced) by functools.wraps. Its length is 1 — only '__dict__' is merged.
# No prior functools spec records this in the extra30 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra30.WRAPPER_UPDATES.len:
  description: "len(functools.WRAPPER_UPDATES) == 1"
  category: constants
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# singledispatch.__module__.__eq__ — standalone module membership
#
# functools.singledispatch is a Python-level function defined in functools.py.
# Its __module__ is 'functools', equal to the public module name.
# No prior functools spec records this standalone in the extra30 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra30.singledispatch.module:
  description: "functools.singledispatch.__module__ == 'functools'"
  category: module_membership
  kind: python_call_eq
  function: singledispatch.__module__.__eq__
  args: ["functools"]
  expected: true
