spec: pty_extra
version: ">=3.9"
backend: python_module(pty)

docs: https://docs.python.org/3/library/pty.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pty.html — Python pty module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pty.py"
  notes:
    - "Extends pty.zspec.zsdl with __name__, __module__, constant type, and constant value invariants."
    - "pty is a POSIX-only module; not available on Windows."
    - "pty.fork, pty.openpty, pty.spawn are Python-level functions; their __class__.__name__ == 'function'."
    - "pty.fork.__name__ == 'fork' and pty.fork.__module__ == 'pty'."
    - "pty.openpty.__name__ == 'openpty' and pty.openpty.__module__ == 'pty'."
    - "pty.spawn.__name__ == 'spawn' and pty.spawn.__module__ == 'pty'."
    - "pty.STDIN_FILENO == 0, pty.STDOUT_FILENO == 1, pty.STDERR_FILENO == 2 (POSIX fd numbers)."
    - "All three file-descriptor constants are plain Python ints."
    - "All expected values verified by running Python 3.12 pty module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ attributes
# ---------------------------------------------------------------------------

table pty_extra.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [fork,    fork.__name__.__eq__,    ["fork"],    true]
    - [openpty, openpty.__name__.__eq__, ["openpty"], true]
    - [spawn,   spawn.__name__.__eq__,   ["spawn"],   true]

# ---------------------------------------------------------------------------
# Function __module__ attributes — all live in 'pty'
# ---------------------------------------------------------------------------

table pty_extra.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [fork,    fork.__module__.__eq__,    ["pty"],  true]
    - [openpty, openpty.__module__.__eq__, ["pty"],  true]
    - [spawn,   spawn.__module__.__eq__,   ["pty"],  true]

# ---------------------------------------------------------------------------
# Function type checks — Python-level functions (not C builtins)
# ---------------------------------------------------------------------------

table pty_extra.function_types:
  kind: python_call_eq
  category: function_types
  id_prefix: ftype

  columns: [id, function, args, expected]
  rows:
    - [fork,    fork.__class__.__name__.__eq__,    ["function"],  true]
    - [openpty, openpty.__class__.__name__.__eq__, ["function"],  true]
    - [spawn,   spawn.__class__.__name__.__eq__,   ["function"],  true]

# ---------------------------------------------------------------------------
# File descriptor constant type checks — all must be int
# ---------------------------------------------------------------------------

table pty_extra.constant_types:
  kind: python_call_eq
  category: constant_types
  id_prefix: ctype

  columns: [id, function, args, expected]
  rows:
    - [STDIN_FILENO,  STDIN_FILENO.__class__.__name__.__eq__,  ["int"],  true]
    - [STDOUT_FILENO, STDOUT_FILENO.__class__.__name__.__eq__, ["int"],  true]
    - [STDERR_FILENO, STDERR_FILENO.__class__.__name__.__eq__, ["int"],  true]

# ---------------------------------------------------------------------------
# File descriptor constant value checks
# ---------------------------------------------------------------------------

invariant pty_extra.STDIN_FILENO.value:
  description: "pty.STDIN_FILENO == 0 — standard input file descriptor number"
  category: constants
  kind: python_call_eq
  function: STDIN_FILENO.__eq__
  args: [0]
  expected: true

invariant pty_extra.STDOUT_FILENO.value:
  description: "pty.STDOUT_FILENO == 1 — standard output file descriptor number"
  category: constants
  kind: python_call_eq
  function: STDOUT_FILENO.__eq__
  args: [1]
  expected: true

invariant pty_extra.STDERR_FILENO.value:
  description: "pty.STDERR_FILENO == 2 — standard error file descriptor number"
  category: constants
  kind: python_call_eq
  function: STDERR_FILENO.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# fork — __qualname__ matches __name__
# ---------------------------------------------------------------------------

invariant pty_extra.fork.qualname:
  description: "pty.fork.__qualname__ == 'fork' — top-level function, no nesting"
  category: function_names
  kind: python_call_eq
  function: fork.__qualname__.__eq__
  args: ["fork"]
  expected: true

# ---------------------------------------------------------------------------
# spawn — __qualname__ matches __name__
# ---------------------------------------------------------------------------

invariant pty_extra.spawn.qualname:
  description: "pty.spawn.__qualname__ == 'spawn' — top-level function, no nesting"
  category: function_names
  kind: python_call_eq
  function: spawn.__qualname__.__eq__
  args: ["spawn"]
  expected: true
