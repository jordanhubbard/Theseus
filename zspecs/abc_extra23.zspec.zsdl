spec: abc_extra23
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra22.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__.__len__() and __name__.__len__() and __qualname__.__len__() for all four core abc symbols."
    - "This spec covers: __module__.__len__() and __name__.__len__() and __qualname__.__len__() for abstractproperty; ABCMeta.register.__name__/__qualname__ lengths; cross-checks confirming __name__.__len__() == __qualname__.__len__() for top-level symbols."
    - "abc.abstractproperty.__module__.__len__() == 3 — 'abc' has length 3."
    - "abc.abstractproperty.__name__.__len__() == 16 — 'abstractproperty' has length 16."
    - "abc.abstractproperty.__qualname__.__len__() == 16 — top-level class so qualname equals name."
    - "abc.ABCMeta.register.__name__.__len__() == 8 — 'register' has length 8."
    - "abc.ABCMeta.register.__qualname__.__len__() == 16 — 'ABCMeta.register' has length 16."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abstractproperty __module__/__name__/__qualname__ string lengths
# (extra23 namespace)
#
# abc.abstractproperty is a deprecated decorator class that was once used to
# define abstract properties. Its __module__ is 'abc' (length 3), matching
# ABC/ABCMeta/abstractmethod. Its __name__ and __qualname__ are both
# 'abstractproperty' (length 16), which is longer than any of the four symbols
# covered in abc_extra22. No prior abc spec records abstractproperty length
# checks in the extra23 namespace.
# ---------------------------------------------------------------------------

table abc_extra23.abstractproperty_lens:
  description: "__module__/__name__/__qualname__ string lengths for abc.abstractproperty"
  kind: python_call_eq
  category: string_properties
  id_prefix: abstractproperty

  columns: [id, function, args, expected]
  rows:
    - [module_len,   abstractproperty.__module__.__len__,   [], 3]
    - [name_len,     abstractproperty.__name__.__len__,     [], 16]
    - [qualname_len, abstractproperty.__qualname__.__len__, [], 16]

# ---------------------------------------------------------------------------
# ABCMeta.register __name__ and __qualname__ string lengths
# (extra23 namespace)
#
# ABCMeta.register is a method on the ABCMeta metaclass used to register a
# class as a virtual subclass of an ABC. Its unqualified name 'register' has
# length 8. Its qualified name 'ABCMeta.register' has length 16 — the
# 7-character class prefix plus a dot plus the 8-character method name.
# No prior abc spec records ABCMeta.register name lengths in the extra23
# namespace.
# ---------------------------------------------------------------------------

table abc_extra23.abcmeta_register_lens:
  description: "__name__ and __qualname__ string lengths for ABCMeta.register"
  kind: python_call_eq
  category: string_properties
  id_prefix: register

  columns: [id, function, args, expected]
  rows:
    - [name_len,     "ABCMeta.register.__name__.__len__",     [], 8]
    - [qualname_len, "ABCMeta.register.__qualname__.__len__", [], 16]

# ---------------------------------------------------------------------------
# abstractproperty.__module__.__len__() == 3 — standalone (extra23 namespace)
#
# abstractproperty is defined in Lib/abc.py, so its __module__ is 'abc'
# (length 3). This matches ABC, ABCMeta, and abstractmethod. The
# consistency confirms that all pure-Python abc symbols share the same
# three-character module name. No prior abc spec records this standalone.
# ---------------------------------------------------------------------------

invariant abc_extra23.abstractproperty.module.len:
  description: "abc.abstractproperty.__module__.__len__() == 3 — 'abc' has length 3; pure-Python symbol"
  category: module_attrs
  kind: python_call_eq
  function: abstractproperty.__module__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# abstractproperty.__name__.__len__() == 16 — standalone (extra23 namespace)
#
# 'abstractproperty' is the longest __name__ among all top-level abc symbols.
# It has 16 characters, two more than abstractmethod (14) and one more than
# get_cache_token (15). No prior abc spec records this standalone.
# ---------------------------------------------------------------------------

invariant abc_extra23.abstractproperty.name.len:
  description: "abc.abstractproperty.__name__.__len__() == 16 — 'abstractproperty' has 16 characters, longest among top-level abc symbols"
  category: name_attrs
  kind: python_call_eq
  function: abstractproperty.__name__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# ABCMeta.register.__qualname__.__len__() == 16 — standalone (extra23 namespace)
#
# 'ABCMeta.register' has 16 characters: the 7-character class name 'ABCMeta',
# a single dot separator, and the 8-character method name 'register'. This
# illustrates the additive structure of qualified names for methods. No prior
# abc spec records this standalone.
# ---------------------------------------------------------------------------

invariant abc_extra23.abcmeta_register.qualname.len:
  description: "abc.ABCMeta.register.__qualname__.__len__() == 16 — 'ABCMeta.register' is 7 + 1 + 8 = 16 characters"
  category: qualname_attrs
  kind: python_call_eq
  function: "ABCMeta.register.__qualname__.__len__"
  args: []
  expected: 16
