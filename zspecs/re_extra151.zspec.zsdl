spec: re_extra151
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.Pattern.__dict__.__contains__ membership for key regex operation methods (match, search, sub, flags, pattern, groups, groupindex, findall, finditer, split, fullmatch, subn, scanner). Also covers re.Match.__dict__.__contains__ for match result attributes (group, groups, groupdict, start, end, span, string, re, pos, endpos, lastindex, lastgroup, regs, expand, __getitem__)."
    - "All checked Pattern methods (match, search, sub, flags, pattern, groups, groupindex, findall, finditer, split, fullmatch, subn, scanner) are in Pattern.__dict__ — confirmed with Python 3.14.3."
    - "All checked Match attributes (group, groups, groupdict, start, end, span, string, re, pos, endpos, lastindex, lastgroup, regs, expand, __getitem__) are in Match.__dict__."
    - "re.Pattern.__name__ == 'Pattern' (len=7); re.Match.__name__ == 'Match' (len=5)."
    - "re.Pattern.__module__ == 're' (len=2); re.Match.__module__ == 're' (len=2)."
    - "re.Pattern.__dict__.__len__() == 26; re.Match.__dict__.__len__() == 21 (confirmed in re_extra150)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern.__dict__.__contains__ — regex operation methods
# All present: match, search, sub, flags, pattern, groups, groupindex,
# findall, finditer, split, fullmatch, subn, scanner.
# ---------------------------------------------------------------------------

table re_extra151.Pattern_dict_contains_methods:
  description: "re.Pattern.__dict__.__contains__: match/search/sub/findall/finditer/split/fullmatch/subn/scanner all True (regex operation methods in Pattern)"
  kind: python_call_eq
  category: identity
  id_prefix: repat151

  columns: [id, function, args, expected, description]
  rows:
    - [has_match,     Pattern.__dict__.__contains__, ["match"],     true, "re.Pattern.__dict__.__contains__('match') == True (match() tries to apply the pattern at the start of the string; returns a Match object or None)"]
    - [has_search,    Pattern.__dict__.__contains__, ["search"],    true, "re.Pattern.__dict__.__contains__('search') == True (search() scans through the string looking for any location where the pattern matches)"]
    - [has_sub,       Pattern.__dict__.__contains__, ["sub"],       true, "re.Pattern.__dict__.__contains__('sub') == True (sub() replaces all occurrences of the pattern in the string with repl; Pattern.sub.__qualname__ == 'Pattern.sub' (len=11) as covered in re_extra150)"]
    - [has_findall,   Pattern.__dict__.__contains__, ["findall"],   true, "re.Pattern.__dict__.__contains__('findall') == True (findall() returns all non-overlapping matches as a list; Pattern.findall.__qualname__ == 'Pattern.findall' (len=15))"]
    - [has_finditer,  Pattern.__dict__.__contains__, ["finditer"],  true, "re.Pattern.__dict__.__contains__('finditer') == True (finditer() returns an iterator of Match objects for all non-overlapping matches)"]
    - [has_split,     Pattern.__dict__.__contains__, ["split"],     true, "re.Pattern.__dict__.__contains__('split') == True (split() splits the string by occurrences of the pattern; Pattern.split.__qualname__ == 'Pattern.split' (len=13))"]
    - [has_fullmatch, Pattern.__dict__.__contains__, ["fullmatch"], true, "re.Pattern.__dict__.__contains__('fullmatch') == True (fullmatch() tries to apply the pattern to the entire string; stricter than match() which only checks from the start)"]
    - [has_subn,      Pattern.__dict__.__contains__, ["subn"],      true, "re.Pattern.__dict__.__contains__('subn') == True (subn() is like sub() but also returns the number of replacements made as a (result, count) tuple)"]
    - [has_scanner,   Pattern.__dict__.__contains__, ["scanner"],   true, "re.Pattern.__dict__.__contains__('scanner') == True (scanner() returns a scanner object for iterative matching; Pattern.scanner.__qualname__ == 'Pattern.scanner' (len=15))"]

table re_extra151.Pattern_dict_contains_descriptors:
  description: "re.Pattern.__dict__.__contains__: flags/pattern/groups/groupindex all True (descriptor attributes in Pattern)"
  kind: python_call_eq
  category: identity
  id_prefix: repat151

  columns: [id, function, args, expected, description]
  rows:
    - [has_flags,      Pattern.__dict__.__contains__, ["flags"],      true, "re.Pattern.__dict__.__contains__('flags') == True (flags is a descriptor attribute returning the integer flags used to compile the pattern, e.g. re.IGNORECASE | re.MULTILINE)"]
    - [has_pattern,    Pattern.__dict__.__contains__, ["pattern"],    true, "re.Pattern.__dict__.__contains__('pattern') == True (pattern is a descriptor attribute returning the pattern string from which the Pattern was compiled)"]
    - [has_groups,     Pattern.__dict__.__contains__, ["groups"],     true, "re.Pattern.__dict__.__contains__('groups') == True (groups is a descriptor attribute returning the number of capturing groups in the pattern)"]
    - [has_groupindex, Pattern.__dict__.__contains__, ["groupindex"], true, "re.Pattern.__dict__.__contains__('groupindex') == True (groupindex is a descriptor attribute returning a dict mapping group names to group numbers)"]

# ---------------------------------------------------------------------------
# re.Match.__dict__.__contains__ — match result attributes
# All present: group, groups, groupdict, start, end, span, string, re, pos,
# endpos, lastindex, lastgroup, regs, expand, __getitem__.
# ---------------------------------------------------------------------------

table re_extra151.Match_dict_contains_accessors:
  description: "re.Match.__dict__.__contains__: group/groups/groupdict/start/end/span/expand/__getitem__ all True (match result accessor methods in Match)"
  kind: python_call_eq
  category: identity
  id_prefix: repat151

  columns: [id, function, args, expected, description]
  rows:
    - [has_group,      Match.__dict__.__contains__, ["group"],      true, "re.Match.__dict__.__contains__('group') == True (group() returns one or more subgroups of the match; group(0) returns the entire match; Match.group.__qualname__ == 'Match.group' (len=11))"]
    - [has_groups,     Match.__dict__.__contains__, ["groups"],     true, "re.Match.__dict__.__contains__('groups') == True (groups() returns a tuple of all subgroups of the match, from 1 up to however many groups the pattern has)"]
    - [has_groupdict,  Match.__dict__.__contains__, ["groupdict"],  true, "re.Match.__dict__.__contains__('groupdict') == True (groupdict() returns a dict of all named subgroups; Match.groupdict.__qualname__ == 'Match.groupdict' (len=15))"]
    - [has_start,      Match.__dict__.__contains__, ["start"],      true, "re.Match.__dict__.__contains__('start') == True (start() returns the index in the string where the match begins)"]
    - [has_end,        Match.__dict__.__contains__, ["end"],        true, "re.Match.__dict__.__contains__('end') == True (end() returns the index in the string past where the match ends; Match.end.__qualname__ == 'Match.end' (len=9))"]
    - [has_span,       Match.__dict__.__contains__, ["span"],       true, "re.Match.__dict__.__contains__('span') == True (span() returns a 2-tuple (start, end) of the match or the specified group)"]
    - [has_expand,     Match.__dict__.__contains__, ["expand"],     true, "re.Match.__dict__.__contains__('expand') == True (expand() returns the string obtained by doing backslash substitution on the template string)"]
    - [has_getitem,    Match.__dict__.__contains__, ["__getitem__"],true, "re.Match.__dict__.__contains__('__getitem__') == True (Match.__getitem__ enables subscript access: match[0] for whole match, match[1] for group 1, match['name'] for named group)"]

table re_extra151.Match_dict_contains_metadata:
  description: "re.Match.__dict__.__contains__: string/re/pos/endpos/lastindex/lastgroup/regs all True (match metadata descriptors in Match)"
  kind: python_call_eq
  category: identity
  id_prefix: repat151

  columns: [id, function, args, expected, description]
  rows:
    - [has_string,     Match.__dict__.__contains__, ["string"],     true, "re.Match.__dict__.__contains__('string') == True (string is a descriptor returning the string passed to match() or search(); the original subject string)"]
    - [has_re,         Match.__dict__.__contains__, ["re"],         true, "re.Match.__dict__.__contains__('re') == True (re is a descriptor returning the Pattern object whose match() or search() produced this Match; Match.re.__qualname__ == 'Match.re' (len=8, the shortest Match qualname, covered in re_extra150))"]
    - [has_pos,        Match.__dict__.__contains__, ["pos"],        true, "re.Match.__dict__.__contains__('pos') == True (pos is a descriptor returning the position in the string at which search started; Match.pos.__qualname__ == 'Match.pos' (len=9))"]
    - [has_endpos,     Match.__dict__.__contains__, ["endpos"],     true, "re.Match.__dict__.__contains__('endpos') == True (endpos is a descriptor returning the position past which the engine will not search; Match.endpos.__qualname__ == 'Match.endpos' (len=12))"]
    - [has_lastindex,  Match.__dict__.__contains__, ["lastindex"],  true, "re.Match.__dict__.__contains__('lastindex') == True (lastindex is a descriptor returning the integer index of the last matched capturing group, or None if no group matched)"]
    - [has_lastgroup,  Match.__dict__.__contains__, ["lastgroup"],  true, "re.Match.__dict__.__contains__('lastgroup') == True (lastgroup is a descriptor returning the name of the last matched capturing group, or None if it has no name or no group matched)"]
    - [has_regs,       Match.__dict__.__contains__, ["regs"],       true, "re.Match.__dict__.__contains__('regs') == True (regs is a descriptor returning a tuple of (start, end) pairs for the match and each group; used internally and by Match.span())"]

# ---------------------------------------------------------------------------
# re.Pattern and re.Match class identity
# re.Pattern.__name__ == 'Pattern' (len=7); re.Match.__name__ == 'Match' (len=5).
# re.Pattern.__module__ == 're' (len=2); re.Match.__module__ == 're' (len=2).
# These complement the __dict__.__len__ facts established in re_extra150.
# ---------------------------------------------------------------------------

table re_extra151.Pattern_Match_class_identity:
  description: "re.Pattern and Match class identity: __name__ and __module__ values (complementing dict lengths from re_extra150)"
  kind: python_call_eq
  category: identity
  id_prefix: repat151

  columns: [id, function, args, expected, description]
  rows:
    - [pat_name_eq,    Pattern.__name__.__eq__,  ["Pattern"], true, "re.Pattern.__name__ == 'Pattern' (len=7; the compiled regex type; 7 characters matching the length of 'decimal' and other module names in this spec family)"]
    - [pat_name_len,   Pattern.__name__.__len__, [],          7,    "re.Pattern.__name__.__len__() == 7 ('Pattern' has 7 characters)"]
    - [match_name_eq,  Match.__name__.__eq__,    ["Match"],   true, "re.Match.__name__ == 'Match' (len=5; the match result type)"]
    - [match_name_len, Match.__name__.__len__,   [],          5,    "re.Match.__name__.__len__() == 5 ('Match' has 5 characters; shorter than 'Pattern' by 2)"]
    - [pat_mod_eq,     Pattern.__module__.__eq__,["re"],      true, "re.Pattern.__module__ == 're' (len=2; Pattern is exposed via the public 're' module, even though implemented in the _sre C extension)"]
    - [match_mod_eq,   Match.__module__.__eq__,  ["re"],      true, "re.Match.__module__ == 're' (len=2; same public module as Pattern)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra151.Pattern.dict_has_match:
  description: "re.Pattern.__dict__.__contains__('match') == True — match() is defined directly in Pattern.__dict__; it tries to apply the pattern at the start of the string (not the whole string — use fullmatch for that); returns a Match object if successful, or None; this is the primary method for anchored matching without compiling a new pattern on each call"
  category: identity
  kind: python_call_eq
  function: Pattern.__dict__.__contains__
  args: ["match"]
  expected: true

invariant re_extra151.Pattern.dict_has_search:
  description: "re.Pattern.__dict__.__contains__('search') == True — search() is defined directly in Pattern.__dict__; it scans through the string looking for any location where the pattern matches (unlike match() which only checks the beginning); returns the first Match object found, or None"
  category: identity
  kind: python_call_eq
  function: Pattern.__dict__.__contains__
  args: ["search"]
  expected: true

invariant re_extra151.Pattern.dict_has_sub:
  description: "re.Pattern.__dict__.__contains__('sub') == True — sub() is defined directly in Pattern.__dict__; it replaces occurrences of the pattern with repl; repl can be a string (with backreference syntax like \\1 or \\g<name>) or a callable taking a Match and returning a string; Pattern.sub.__qualname__ == 'Pattern.sub' (len=11, the shortest Pattern method qualname, as covered in re_extra150)"
  category: identity
  kind: python_call_eq
  function: Pattern.__dict__.__contains__
  args: ["sub"]
  expected: true

invariant re_extra151.Pattern.dict_has_flags:
  description: "re.Pattern.__dict__.__contains__('flags') == True — flags is a descriptor defined directly in Pattern.__dict__; it returns the integer value of the compilation flags, e.g. re.compile('x', re.I | re.M).flags == re.I | re.M | re.U (the UNICODE flag is always added for str patterns); the flags value includes all defaults automatically added by the engine"
  category: identity
  kind: python_call_eq
  function: Pattern.__dict__.__contains__
  args: ["flags"]
  expected: true

invariant re_extra151.Match.dict_has_group:
  description: "re.Match.__dict__.__contains__('group') == True — group() is defined directly in Match.__dict__; it returns one or more subgroups of the match; group(0) or group() returns the entire match; group(1), group(2), ... return the captured groups; group('name') returns a named group; Match.group.__qualname__ == 'Match.group' (len=11)"
  category: identity
  kind: python_call_eq
  function: Match.__dict__.__contains__
  args: ["group"]
  expected: true

invariant re_extra151.Match.dict_has_groups:
  description: "re.Match.__dict__.__contains__('groups') == True — groups() is defined directly in Match.__dict__; it returns a tuple containing all the subgroups of the match (from 1 up to as many groups as the pattern has); unmatched optional groups default to None or to the default argument if provided"
  category: identity
  kind: python_call_eq
  function: Match.__dict__.__contains__
  args: ["groups"]
  expected: true

invariant re_extra151.Match.dict_has_re:
  description: "re.Match.__dict__.__contains__('re') == True — re is a descriptor defined directly in Match.__dict__; it returns the Pattern object whose match() or search() call produced this Match object; Match.re.__qualname__ == 'Match.re' (len=8), the shortest qualname in both Pattern and Match (as covered in re_extra150)"
  category: identity
  kind: python_call_eq
  function: Match.__dict__.__contains__
  args: ["re"]
  expected: true

invariant re_extra151.Pattern.name_len_7:
  description: "re.Pattern.__name__.__len__() == 7 ('Pattern' has 7 characters; the same length as 'decimal' (the module name covered in decimal specs) and 'pathlib' (the module name covered in pathlib specs); Pattern.__name__ length 7 matches the lengths of several module names in this spec family)"
  category: identity
  kind: python_call_eq
  function: Pattern.__name__.__len__
  args: []
  expected: 7
