spec: socket_extra2716
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/socket.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 628 theme: __neg__, __pos__, and __abs__ dict-presence checks (unary minus, unary plus, absolute value)."
    - "socket.socket is a network socket class; it does not implement unary arithmetic protocols."
    - "socket.AddressFamily is an IntEnum representing address families (AF_INET, AF_UNIX, etc.); IntEnum provides arithmetic via the int MRO, but AddressFamily does NOT define __neg__, __pos__, or __abs__ in its own __dict__."
    - "socket.SocketKind is an IntEnum representing socket types (SOCK_STREAM, SOCK_DGRAM, etc.); same reasoning as AddressFamily — its own __dict__ does not contain __neg__, __pos__, or __abs__."
    - "None of the socket public classes define __neg__, __pos__, or __abs__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __neg__ dict-presence — absent from all socket classes
# ---------------------------------------------------------------------------

table socket_extra2716.neg_protocol:
  description: "__neg__ is absent from all socket class __dict__s — none implement unary minus in their own dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2716

  columns: [id, function, args, expected]
  rows:
    - ["sk2716001", "socket.socket.__dict__.__contains__",        ["__neg__"], false]
    - ["sk2716002", "socket.AddressFamily.__dict__.__contains__", ["__neg__"], false]
    - ["sk2716003", "socket.SocketKind.__dict__.__contains__",    ["__neg__"], false]

