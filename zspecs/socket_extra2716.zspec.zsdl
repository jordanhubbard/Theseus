# Combined view — AddressFamily and SocketKind vs. all three protocols
# ---------------------------------------------------------------------------

table socket_extra2716.enum_unary_combined:
  description: "socket.AddressFamily and socket.SocketKind define none of __neg__, __pos__, __abs__ in their own __dict__"
