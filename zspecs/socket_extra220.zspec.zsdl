spec: socket_extra220
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html
rfcs:
  - "RFC 793 — Transmission Control Protocol (TCP)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.__name__ == 'socket' (6 chars)."
    - "socket.socket.__name__ == 'socket' (6 chars)."
    - "socket.gethostname.__name__ == 'gethostname' (11 chars)."
    - "socket.getfqdn.__name__ == 'getfqdn' (7 chars)."
    - "socket.gethostbyname.__name__ == 'gethostbyname' (13 chars)."
    - "socket.getaddrinfo.__name__ == 'getaddrinfo' (11 chars)."
    - "socket.setdefaulttimeout.__name__ == 'setdefaulttimeout' (17 chars)."
    - "socket.getdefaulttimeout.__name__ == 'getdefaulttimeout' (17 chars)."
    - "socket.create_connection.__name__ == 'create_connection' (17 chars)."
    - "socket.gaierror.__name__ == 'gaierror' (8 chars)."
    - "socket.herror.__name__ == 'herror' (6 chars)."
    - "socket.timeout.__name__ == 'TimeoutError' (12 chars) — Python 3.3+ socket.timeout is alias for TimeoutError."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket module and function __name__.__len__() checks (group A)
#
# socket.__name__.__len__()          == 6   ('socket')
# socket.socket.__name__.__len__()   == 6   ('socket')
# socket.gethostname.__name__.__len__() == 11 ('gethostname')
# socket.getfqdn.__name__.__len__()  == 7   ('getfqdn')
# socket.gethostbyname.__name__.__len__() == 13 ('gethostbyname')
# ---------------------------------------------------------------------------

