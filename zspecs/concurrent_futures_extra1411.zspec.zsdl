spec: concurrent_futures_extra1411
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures: Launching parallel tasks"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py, Lib/concurrent/futures/thread.py, Lib/concurrent/futures/process.py"
  notes:
    - "Wave 541 (_extra1411): focuses on __sizeof__ method type and presence, plus __reduce_ex__ checks for concurrent.futures classes."
    - "All concurrent.futures classes (Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor) have __sizeof__ with type 'method_descriptor'."
    - "All concurrent.futures classes have __reduce_ex__ with type 'method_descriptor'."
    - "None of these classes define __sizeof__ or __reduce_ex__ in their own __dict__ — both are inherited from object."
    - "concurrent.futures.Future.__sizeof__.__class__.__name__ == 'method_descriptor'; '__sizeof__' not in concurrent.futures.Future.__dict__."
    - "concurrent.futures.Executor.__sizeof__.__class__.__name__ == 'method_descriptor'; '__sizeof__' not in concurrent.futures.Executor.__dict__."
    - "concurrent.futures.ThreadPoolExecutor.__sizeof__.__class__.__name__ == 'method_descriptor'; '__sizeof__' not in ThreadPoolExecutor.__dict__."
    - "concurrent.futures.ProcessPoolExecutor.__sizeof__.__class__.__name__ == 'method_descriptor'; '__sizeof__' not in ProcessPoolExecutor.__dict__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table concurrent_futures_extra1411.sizeof_class_name:
  description: "concurrent.futures class __sizeof__.__class__.__name__ identity checks — Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor all inherit __sizeof__ from object; type is 'method_descriptor' for all; verified with Python 3.14.3"
  kind: python_call_eq
  category: sizeof_class_name
  id_prefix: cf1411sz
  columns: [id, function, args, expected]
  rows:
    - [cf1411sz001, concurrent.futures.Future.__sizeof__.__class__.__name__.__eq__,              ["method_descriptor"], true]
    - [cf1411sz002, concurrent.futures.Executor.__sizeof__.__class__.__name__.__eq__,            ["method_descriptor"], true]
    - [cf1411sz003, concurrent.futures.ThreadPoolExecutor.__sizeof__.__class__.__name__.__eq__,  ["method_descriptor"], true]
    - [cf1411sz004, concurrent.futures.ProcessPoolExecutor.__sizeof__.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [cf1411sz005, concurrent.futures.Future.__sizeof__.__class__.__name__.__eq__,              ["method_descriptor"], true]
    - [cf1411sz006, concurrent.futures.Executor.__sizeof__.__class__.__name__.__eq__,            ["method_descriptor"], true]

table concurrent_futures_extra1411.sizeof_not_in_dict:
  description: "concurrent.futures class __sizeof__ absence from own __dict__ — none of Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor define __sizeof__ directly; all inherit from object; __dict__.__contains__('__sizeof__') is False for each; verified with Python 3.14.3"
  kind: python_call_eq
  category: sizeof_dict_membership
  id_prefix: cf1411sd
  columns: [id, function, args, expected]
  rows:
    - [cf1411sd001, concurrent.futures.Future.__dict__.__contains__,              ["__sizeof__"], false]
    - [cf1411sd002, concurrent.futures.Executor.__dict__.__contains__,            ["__sizeof__"], false]
    - [cf1411sd003, concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,  ["__sizeof__"], false]
    - [cf1411sd004, concurrent.futures.ProcessPoolExecutor.__dict__.__contains__, ["__sizeof__"], false]
    - [cf1411sd005, concurrent.futures.Future.__dict__.__contains__,              ["__reduce_ex__"], false]
    - [cf1411sd006, concurrent.futures.Executor.__dict__.__contains__,            ["__reduce_ex__"], false]

table concurrent_futures_extra1411.reduce_ex_class_name:
  description: "concurrent.futures class __reduce_ex__.__class__.__name__ identity checks — all classes inherit __reduce_ex__ from object; type is 'method_descriptor'; none define __reduce_ex__ in their own __dict__; verified with Python 3.14.3"
  kind: python_call_eq
  category: reduce_ex_class_name
  id_prefix: cf1411rx
  columns: [id, function, args, expected]
  rows:
    - [cf1411rx001, concurrent.futures.Future.__reduce_ex__.__class__.__name__.__eq__,              ["method_descriptor"], true]
    - [cf1411rx002, concurrent.futures.Executor.__reduce_ex__.__class__.__name__.__eq__,            ["method_descriptor"], true]
    - [cf1411rx003, concurrent.futures.ThreadPoolExecutor.__reduce_ex__.__class__.__name__.__eq__,  ["method_descriptor"], true]
    - [cf1411rx004, concurrent.futures.ProcessPoolExecutor.__reduce_ex__.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [cf1411rx005, concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,  ["__reduce_ex__"], false]
    - [cf1411rx006, concurrent.futures.ProcessPoolExecutor.__dict__.__contains__, ["__reduce_ex__"], false]
