spec: in3016
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 648 (in3016): __iter__, __next__, __reversed__ dict-presence checks for inspect types."
    - "inspect types are introspection helpers — none define iterator protocol methods in their own __dict__."
    - "inspect.Signature supports parameter iteration via its 'parameters' OrderedDict attribute, but does not define __iter__ directly."
    - "inspect.BoundArguments exposes an 'arguments' OrderedDict but does not define __iter__ itself."
    - "Verified types: inspect.Parameter, inspect.BoundArguments, inspect.Signature, inspect.FullArgSpec, inspect.FrameInfo, inspect.ArgInfo, inspect.Traceback, inspect.ClosureVars."
    - "inspect.FullArgSpec, inspect.FrameInfo, inspect.ArgInfo, inspect.Traceback, and inspect.ClosureVars are namedtuple subclasses."
    - "inspect.Parameter, inspect.BoundArguments, and inspect.Signature are pure Python classes."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3016.iter:
  description: "inspect types __iter__ dict-presence checks; wave 648"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in3016
  columns: [id, function, args, expected]
  rows:
    - ["in3016001", operator.contains, [inspect.Parameter.__dict__,       "__iter__"], false]
    - ["in3016002", operator.contains, [inspect.BoundArguments.__dict__,  "__iter__"], false]
    - ["in3016003", operator.contains, [inspect.Signature.__dict__,       "__iter__"], false]
    - ["in3016004", operator.contains, [inspect.FullArgSpec.__dict__,     "__iter__"], false]
    - ["in3016005", operator.contains, [inspect.FrameInfo.__dict__,       "__iter__"], false]
    - ["in3016006", operator.contains, [inspect.ArgInfo.__dict__,         "__iter__"], false]

