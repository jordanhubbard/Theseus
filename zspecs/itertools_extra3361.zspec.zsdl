spec: it3361
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 671 (it3361): __invert__, __floor__, __ceil__ dict-presence checks for itertools types."
    - "Theme: __invert__/__floor__/__ceil__ dict-presence (unary ~x, math.floor(x), math.ceil(x))."
    - "All values False — itertools iterator types implement the iterator protocol only, not numeric protocols."
    - "No itertools iterator type defines __invert__, __floor__, or __ceil__ in its own __dict__."
    - "All 18 itertools iterator types are C-level types; they implement iterator protocol (__iter__/__next__), not bitwise or rounding protocols."
    - "itertools.pairwise requires Python >= 3.10."
    - "All 18 itertools iterator types are checked."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

