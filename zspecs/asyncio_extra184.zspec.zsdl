spec: asyncio_extra184
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-stream.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-stream.html — Python asyncio streams documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/streams.py"
  notes:
    - "This spec covers asyncio.StreamReader and asyncio.StreamWriter class identity. Both classes live in asyncio.streams (len=15). StreamReader.__name__=='StreamReader'(len=12); StreamReader.__module__=='asyncio.streams'; StreamReader.__qualname__=='StreamReader'; StreamReader.__bases__[0].__name__=='object' — StreamReader inherits directly from object. StreamWriter.__name__=='StreamWriter'(len=12); StreamWriter.__module__=='asyncio.streams'; StreamWriter.__qualname__=='StreamWriter'; StreamWriter.__bases__[0].__name__=='object' — StreamWriter also inherits directly from object in Python 3.10+."
    - "asyncio.StreamReader.__bases__[0].__name__ == 'object'. In Python 3.10+, StreamReader no longer inherits from FlowControlMixin; it inherits directly from object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.StreamWriter.__bases__[0].__name__ == 'object'. StreamWriter inherits directly from object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "Both __name__ values have len=12: 'StreamReader' and 'StreamWriter' each have 12 characters. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "Both __module__ values are 'asyncio.streams' (len=15). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.StreamReader class identity — __name__, __module__, __qualname__
#
# asyncio.StreamReader.__name__ == 'StreamReader' (len=12)
# asyncio.StreamReader.__module__ == 'asyncio.streams' (len=15)
# asyncio.StreamReader.__qualname__ == 'StreamReader'
#
# StreamReader is a class for reading bytes from an async stream.
# ---------------------------------------------------------------------------

table asyncio_extra184.streamreader_identity:
  description: "asyncio.StreamReader class identity: __name__=='StreamReader'(len=12), __module__=='asyncio.streams'(len=15), __qualname__=='StreamReader'; new to asyncio_extra184"
  kind: python_call_eq
  category: identity
  id_prefix: asynciostream184

  columns: [id, function, args, expected, description]
  rows:
    - [sr_name_eq,
       StreamReader.__name__.__eq__,
       ["StreamReader"],
       true,
       "asyncio.StreamReader.__name__.__eq__('StreamReader') == True — StreamReader is the async stream reading class; __name__ is 'StreamReader' (12 chars); str.__eq__('StreamReader') returns True; new to asyncio_extra184"]
    - [sr_name_len_12,
       StreamReader.__name__.__len__,
       [],
       12,
       "asyncio.StreamReader.__name__.__len__() == 12 — 'StreamReader' has 12 characters: S-t-r-e-a-m-R-e-a-d-e-r; same length as 'StreamWriter'; str.__len__() returns 12; new to asyncio_extra184"]
    - [sr_module_eq,
       StreamReader.__module__.__eq__,
       ["asyncio.streams"],
       true,
       "asyncio.StreamReader.__module__.__eq__('asyncio.streams') == True — StreamReader is defined in asyncio.streams (len=15); str.__eq__('asyncio.streams') returns True; new to asyncio_extra184"]
    - [sr_module_len_15,
       StreamReader.__module__.__len__,
       [],
       15,
       "asyncio.StreamReader.__module__.__len__() == 15 — 'asyncio.streams' has 15 characters; same module length as StreamWriter; str.__len__() returns 15; new to asyncio_extra184"]
    - [sr_qualname_eq,
       StreamReader.__qualname__.__eq__,
       ["StreamReader"],
       true,
       "asyncio.StreamReader.__qualname__.__eq__('StreamReader') == True — StreamReader is a top-level class so __qualname__ equals __name__; str.__eq__('StreamReader') returns True; new to asyncio_extra184"]

# ---------------------------------------------------------------------------
# Table 2: asyncio.StreamWriter class identity — __name__, __module__, __qualname__
#
# asyncio.StreamWriter.__name__ == 'StreamWriter' (len=12)
# asyncio.StreamWriter.__module__ == 'asyncio.streams' (len=15)
# asyncio.StreamWriter.__qualname__ == 'StreamWriter'
#
# StreamWriter is a class for writing bytes to an async stream.
# ---------------------------------------------------------------------------

table asyncio_extra184.streamwriter_identity:
  description: "asyncio.StreamWriter class identity: __name__=='StreamWriter'(len=12), __module__=='asyncio.streams'(len=15), __qualname__=='StreamWriter'; new to asyncio_extra184"
  kind: python_call_eq
  category: identity
  id_prefix: asynciostream184

  columns: [id, function, args, expected, description]
  rows:
    - [sw_name_eq,
       StreamWriter.__name__.__eq__,
       ["StreamWriter"],
       true,
       "asyncio.StreamWriter.__name__.__eq__('StreamWriter') == True — StreamWriter is the async stream writing class; __name__ is 'StreamWriter' (12 chars); str.__eq__('StreamWriter') returns True; new to asyncio_extra184"]
    - [sw_name_len_12,
       StreamWriter.__name__.__len__,
       [],
       12,
       "asyncio.StreamWriter.__name__.__len__() == 12 — 'StreamWriter' has 12 characters: S-t-r-e-a-m-W-r-i-t-e-r; same length as 'StreamReader'; str.__len__() returns 12; new to asyncio_extra184"]
    - [sw_module_eq,
       StreamWriter.__module__.__eq__,
       ["asyncio.streams"],
       true,
       "asyncio.StreamWriter.__module__.__eq__('asyncio.streams') == True — StreamWriter is defined in asyncio.streams (len=15); str.__eq__('asyncio.streams') returns True; new to asyncio_extra184"]
    - [sw_module_len_15,
       StreamWriter.__module__.__len__,
       [],
       15,
       "asyncio.StreamWriter.__module__.__len__() == 15 — 'asyncio.streams' has 15 characters; same module length as StreamReader; str.__len__() returns 15; new to asyncio_extra184"]
    - [sw_qualname_eq,
       StreamWriter.__qualname__.__eq__,
       ["StreamWriter"],
       true,
       "asyncio.StreamWriter.__qualname__.__eq__('StreamWriter') == True — StreamWriter is a top-level class so __qualname__ equals __name__; str.__eq__('StreamWriter') returns True; new to asyncio_extra184"]

# ---------------------------------------------------------------------------
# Table 3: asyncio.StreamReader and asyncio.StreamWriter base class identity
#
# asyncio.StreamReader.__bases__[0].__name__ == 'object'
# asyncio.StreamWriter.__bases__[0].__name__ == 'object'
#
# In Python 3.10+, both classes inherit directly from object.
# ---------------------------------------------------------------------------

table asyncio_extra184.stream_bases_identity:
  description: "asyncio.StreamReader and StreamWriter both inherit directly from object in Python 3.10+; bases[0].__name__=='object'; new to asyncio_extra184"
  kind: python_call_eq
  category: identity
  id_prefix: asynciostream184

  columns: [id, function, args, expected, description]
  rows:
    - [sr_base0_name_eq,
       "StreamReader.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "asyncio.StreamReader.__bases__[0].__name__.__eq__('object') == True — StreamReader inherits directly from object in Python 3.10+; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to asyncio_extra184"]
    - [sw_base0_name_eq,
       "StreamWriter.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "asyncio.StreamWriter.__bases__[0].__name__.__eq__('object') == True — StreamWriter inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to asyncio_extra184"]
    - [sr_base0_name_len_6,
       "StreamReader.__bases__[0].__name__.__len__",
       [],
       6,
       "asyncio.StreamReader.__bases__[0].__name__.__len__() == 6 — 'object' has 6 characters: o-b-j-e-c-t; str.__len__() returns 6; new to asyncio_extra184"]
    - [sw_base0_name_len_6,
       "StreamWriter.__bases__[0].__name__.__len__",
       [],
       6,
       "asyncio.StreamWriter.__bases__[0].__name__.__len__() == 6 — 'object' has 6 characters: o-b-j-e-c-t; str.__len__() returns 6; new to asyncio_extra184"]
    - [sr_name_eq_sw_name_len,
       StreamReader.__name__.__len__,
       [],
       12,
       "asyncio.StreamReader.__name__.__len__() == 12 — NAME LENGTHS: StreamReader=12 == StreamWriter=12; both stream classes have the same name length; str.__len__() returns 12; new to asyncio_extra184"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra184
# ---------------------------------------------------------------------------

invariant asyncio_extra184.streamreader_name_eq:
  description: "asyncio.StreamReader.__name__ == 'StreamReader' — async stream reading class; len=12; new to asyncio_extra184"
  category: identity
  kind: python_call_eq
  function: StreamReader.__name__.__eq__
  args: ["StreamReader"]
  expected: true

invariant asyncio_extra184.streamreader_module_eq:
  description: "asyncio.StreamReader.__module__ == 'asyncio.streams' — defined in asyncio.streams (len=15); new to asyncio_extra184"
  category: identity
  kind: python_call_eq
  function: StreamReader.__module__.__eq__
  args: ["asyncio.streams"]
  expected: true

invariant asyncio_extra184.streamreader_qualname_eq:
  description: "asyncio.StreamReader.__qualname__ == 'StreamReader' — top-level class so qualname equals name; new to asyncio_extra184"
  category: identity
  kind: python_call_eq
  function: StreamReader.__qualname__.__eq__
  args: ["StreamReader"]
  expected: true

invariant asyncio_extra184.streamreader_base_object:
  description: "asyncio.StreamReader.__bases__[0].__name__ == 'object' — StreamReader inherits directly from object in Python 3.10+; new to asyncio_extra184"
  category: identity
  kind: python_call_eq
  function: "StreamReader.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

