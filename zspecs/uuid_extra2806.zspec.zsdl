spec: uuid_extra2806
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra2791.zspec.zsdl — covers __iand__, __ior__, and __ixor__ absence for UUID, SafeUUID."
    - "uuid_extra2776.zspec.zsdl — covers __isub__, __imul__, and __itruediv__ absence for UUID, SafeUUID."
    - "decimal_extra204.zspec.zsdl — covers decimal.Decimal __dict__ membership for arithmetic dunders; same dict-presence pattern."
  notes:
    - "uuid.UUID.__dict__.__contains__('__ilshift__') == False — UUID is an immutable identifier type; it does not define in-place left-shift; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.UUID.__dict__.__contains__('__irshift__') == False — UUID does not define in-place right-shift; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.UUID.__dict__.__contains__('__ipow__') == False — UUID does not define in-place power; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.SafeUUID.__dict__.__contains__('__ilshift__') == False — SafeUUID (an IntEnum subclass) does not add in-place left-shift to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.SafeUUID.__dict__.__contains__('__irshift__') == False — SafeUUID does not add in-place right-shift to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.SafeUUID.__dict__.__contains__('__ipow__') == False — SafeUUID does not add in-place power to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: uuid.UUID.__dict__ — __ilshift__, __irshift__, __ipow__ absence
# UUID is a pure-Python class representing a universally unique identifier.
# It supports comparison operators (__eq__, __lt__, etc.) and __hash__, but
# not in-place shift or power operators (<<=, >>=, **=).
# ---------------------------------------------------------------------------

table uuid_extra2806.uuid_dict_ilshift_irshift_ipow:
  description: "uuid.UUID.__dict__ does not contain __ilshift__, __irshift__, or __ipow__ — UUID defines no in-place shift or power operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: uu2806

  columns: [id, function, args, expected]
  rows:
    - ["uu2806-uuid-ilshift", uuid.UUID.__dict__.__contains__, ["__ilshift__"], false]
    - ["uu2806-uuid-irshift", uuid.UUID.__dict__.__contains__, ["__irshift__"], false]
    - ["uu2806-uuid-ipow",    uuid.UUID.__dict__.__contains__, ["__ipow__"],    false]

# ---------------------------------------------------------------------------
# Table 2: uuid.SafeUUID.__dict__ — __ilshift__, __irshift__, __ipow__ absence
# SafeUUID is an IntEnum subclass with values -1 (unsafe) and 0 (safe).
# It does not add new in-place shift or power operators beyond those inherited
# from IntEnum; the __dict__ check is against SafeUUID's own namespace only.
# ---------------------------------------------------------------------------

table uuid_extra2806.safeuuid_dict_ilshift_irshift_ipow:
  description: "uuid.SafeUUID.__dict__ does not contain __ilshift__, __irshift__, or __ipow__ — SafeUUID (IntEnum subclass) defines no additional in-place shift or power operators in its own __dict__; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: uu2806

  columns: [id, function, args, expected]
  rows:
    - ["uu2806-safe-ilshift", uuid.SafeUUID.__dict__.__contains__, ["__ilshift__"], false]
    - ["uu2806-safe-irshift", uuid.SafeUUID.__dict__.__contains__, ["__irshift__"], false]
    - ["uu2806-safe-ipow",    uuid.SafeUUID.__dict__.__contains__, ["__ipow__"],    false]

# ---------------------------------------------------------------------------
# Table 3: uuid.UUID.__dict__ — per-dunder detail with descriptions
# Explicit per-dunder rows documenting why each operator is absent.
# ---------------------------------------------------------------------------

table uuid_extra2806.uuid_dict_detail:
  description: "uuid.UUID.__dict__ in-place shift/power operator absence detail — __ilshift__, __irshift__, and __ipow__ are not defined because UUID is an immutable identifier type, not an integer operand; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: uu2806

  columns: [id, function, args, expected, description]
  rows:
    - ["uu2806-d-ilshift", uuid.UUID.__dict__.__contains__, ["__ilshift__"], false, "uuid.UUID does not support <<= — UUIDs are immutable identifiers; in-place left-shift is undefined"]
    - ["uu2806-d-irshift", uuid.UUID.__dict__.__contains__, ["__irshift__"], false, "uuid.UUID does not support >>= — in-place right-shift has no meaning for a universally unique identifier"]
    - ["uu2806-d-ipow",    uuid.UUID.__dict__.__contains__, ["__ipow__"],    false, "uuid.UUID does not support **= — in-place power is undefined for UUID objects"]

# ---------------------------------------------------------------------------
# Table 4: cross-type summary — UUID and SafeUUID both lack all three dunders
# ---------------------------------------------------------------------------

table uuid_extra2806.all_types_all_dunders_absent:
  description: "uuid.UUID and uuid.SafeUUID both lack __ilshift__, __irshift__, and __ipow__ in __dict__ — neither uuid type defines in-place shift or power operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: uu2806

  columns: [id, function, args, expected]
  rows:
    - ["uu2806-x-uuid-ilshift", uuid.UUID.__dict__.__contains__,     ["__ilshift__"], false]
    - ["uu2806-x-uuid-irshift", uuid.UUID.__dict__.__contains__,     ["__irshift__"], false]
    - ["uu2806-x-uuid-ipow",    uuid.UUID.__dict__.__contains__,     ["__ipow__"],    false]
    - ["uu2806-x-safe-ilshift", uuid.SafeUUID.__dict__.__contains__, ["__ilshift__"], false]
    - ["uu2806-x-safe-irshift", uuid.SafeUUID.__dict__.__contains__, ["__irshift__"], false]
    - ["uu2806-x-safe-ipow",    uuid.SafeUUID.__dict__.__contains__, ["__ipow__"],    false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant uuid_extra2806.uuid_no_ilshift:
  description: "uuid.UUID.__dict__.__contains__('__ilshift__') == False — UUID does not define the <<= operator; UUID objects are immutable (the int field is fixed at construction); confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.UUID.__dict__.__contains__
  args: ["__ilshift__"]
  expected: false

invariant uuid_extra2806.uuid_no_irshift:
  description: "uuid.UUID.__dict__.__contains__('__irshift__') == False — UUID does not define the >>= operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.UUID.__dict__.__contains__
  args: ["__irshift__"]
  expected: false

invariant uuid_extra2806.uuid_no_ipow:
  description: "uuid.UUID.__dict__.__contains__('__ipow__') == False — UUID does not define the **= operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.UUID.__dict__.__contains__
  args: ["__ipow__"]
  expected: false

invariant uuid_extra2806.safeuuid_no_ilshift:
  description: "uuid.SafeUUID.__dict__.__contains__('__ilshift__') == False — SafeUUID is an IntEnum subclass and does not add __ilshift__ to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.SafeUUID.__dict__.__contains__
  args: ["__ilshift__"]
  expected: false

invariant uuid_extra2806.safeuuid_no_irshift:
  description: "uuid.SafeUUID.__dict__.__contains__('__irshift__') == False — SafeUUID does not add __irshift__ to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.SafeUUID.__dict__.__contains__
  args: ["__irshift__"]
  expected: false

invariant uuid_extra2806.safeuuid_no_ipow:
  description: "uuid.SafeUUID.__dict__.__contains__('__ipow__') == False — SafeUUID does not add __ipow__ to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.SafeUUID.__dict__.__contains__
  args: ["__ipow__"]
  expected: false
