spec: select
version: ">=3.2"
backend: python_module(select)

docs: https://docs.python.org/3/library/select.html

provenance:
  derived_from:
    - "Python select documentation — https://docs.python.org/3/library/select.html"
    - "Test vectors verified by running Python 3.14.3 select module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/selectmodule.c"
  notes:
    - "select is a POSIX-only module available on macOS, Linux, and FreeBSD; not available on Windows."
    - "select.select() is the core cross-platform I/O multiplexing function."
    - "select.poll() exists on Linux and macOS (via compatibility shim); not available on all POSIX platforms."
    - "select.kqueue and select.kevent are macOS/BSD-specific; not available on Linux."
    - "POLLIN, POLLOUT, POLLERR constants are present on both macOS and Linux."
    - "KQ_FILTER_READ and KQ_FILTER_WRITE are macOS/BSD-only kqueue filter constants."
    - "All expected values verified by running Python 3.14.3 select module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "select.select() raises OSError (select.error alias) on invalid file descriptors"
  stderr: "null"
  stickiness: "N/A"
  codes: {}

# ---------------------------------------------------------------------------
# Function name checks — cross-platform I/O multiplexing
# ---------------------------------------------------------------------------

invariant select.select.name:
  description: "select.select.__name__ == 'select'"
  category: functions
  kind: python_call_eq
  function: select.__name__.__eq__
  args: ["select"]
  expected: true

invariant select.poll.name:
  description: "select.poll.__name__ == 'poll'"
  category: functions
  kind: python_call_eq
  function: poll.__name__.__eq__
  args: ["poll"]
  expected: true

# ---------------------------------------------------------------------------
# Class / function name checks — macOS/BSD kqueue interface
# ---------------------------------------------------------------------------

invariant select.kqueue.name:
  description: "select.kqueue.__name__ == 'kqueue'"
  category: functions
  kind: python_call_eq
  function: kqueue.__name__.__eq__
  args: ["kqueue"]
  expected: true

invariant select.kevent.name:
  description: "select.kevent.__name__ == 'kevent'"
  category: functions
  kind: python_call_eq
  function: kevent.__name__.__eq__
  args: ["kevent"]
  expected: true

# ---------------------------------------------------------------------------
# POLL constants — cross-platform (macOS and Linux)
# ---------------------------------------------------------------------------

invariant select.POLLIN.is_int:
  description: "select.POLLIN.__class__.__name__ == 'int' — POLLIN is an integer constant"
  category: constants
  kind: python_call_eq
  function: POLLIN.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant select.POLLOUT.is_int:
  description: "select.POLLOUT.__class__.__name__ == 'int' — POLLOUT is an integer constant"
  category: constants
  kind: python_call_eq
  function: POLLOUT.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant select.POLLERR.is_int:
  description: "select.POLLERR.__class__.__name__ == 'int' — POLLERR is an integer constant"
  category: constants
  kind: python_call_eq
  function: POLLERR.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# KQueue constants — macOS/BSD only
# ---------------------------------------------------------------------------

invariant select.KQ_FILTER_READ.is_int:
  description: "select.KQ_FILTER_READ.__class__.__name__ == 'int' — KQ_FILTER_READ is an integer constant"
  category: constants
  kind: python_call_eq
  function: KQ_FILTER_READ.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant select.KQ_FILTER_WRITE.is_int:
  description: "select.KQ_FILTER_WRITE.__class__.__name__ == 'int' — KQ_FILTER_WRITE is an integer constant"
  category: constants
  kind: python_call_eq
  function: KQ_FILTER_WRITE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral — kqueue() constructor returns a kqueue object
# ---------------------------------------------------------------------------

invariant select.kqueue.instance_class:
  description: "select.kqueue().__class__.__name__ == 'kqueue' — constructor returns a kqueue instance"
  category: behavioral
  kind: python_call_eq
  function: kqueue
  args: []
  method: __class__
  method_args: []
  method_chain: __name__
  expected: "kqueue"

# ---------------------------------------------------------------------------
# Behavioral — poll() constructor returns a poll object
# ---------------------------------------------------------------------------

invariant select.poll.instance_class:
  description: "select.poll().__class__.__name__ == 'poll' — constructor returns a poll instance"
  category: behavioral
  kind: python_call_eq
  function: poll
  args: []
  method: __class__
  method_args: []
  method_chain: __name__
  expected: "poll"

