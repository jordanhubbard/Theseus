spec: hashlib_extra181
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashopenssl.c"
  notes:
    - "This spec covers: hashlib module identity attributes — __name__=='hashlib' (len=7); __package__=='' (hashlib.py is a module in the standard library, not a package, so __package__ is empty string); __spec__.__class__.__name__=='ModuleSpec'; hashlib.new.__class__.__name__=='function' (new is a Python-level wrapper function, not a C builtin); hashlib.md5.__class__.__name__=='builtin_function_or_method' (md5 is a C builtin exposed directly); hashlib.sha256.__class__.__name__=='builtin_function_or_method'; hashlib.algorithms_guaranteed.__class__.__name__=='set'; hashlib.algorithms_available.__class__.__name__=='set'."
    - "hashlib.__package__ == '' — hashlib is implemented as Lib/hashlib.py (a plain module file, not a package directory), so __package__ is the empty string rather than 'hashlib'."
    - "hashlib.new.__class__.__name__ == 'function' — hashlib.new is a Python-level wrapper that dispatches to the C-level hash constructors; it is NOT a builtin_function_or_method."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: hashlib module __name__ and __package__ identity
#
# hashlib.__name__ == 'hashlib' (len 7)
# hashlib.__package__ == '' (plain module, not a package)
# hashlib.__name__.__eq__('hashlib') == True
# hashlib.__package__.__eq__('') == True
#
# hashlib is implemented as Lib/hashlib.py.  Because it is a plain .py file
# (not a directory with __init__.py), __package__ is set to '' by the import
# system, not to 'hashlib'.  __name__ is always the fully-qualified module
# name used at import time. New to extra181.
# ---------------------------------------------------------------------------

table hashlib_extra181.module_name_and_package:
  description: "hashlib.__name__=='hashlib' (len=7); __package__=='' (plain module, not a package); new to extra181"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibmodule181

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq_hashlib,
       "__name__.__eq__",
       ["hashlib"],
       true,
       "hashlib.__name__.__eq__('hashlib') == True — hashlib.__name__ is the string 'hashlib', the module's fully-qualified name as registered in sys.modules; str.__eq__('hashlib') returns True; new to extra181"]
    - [name_len_7,
       "__name__.__len__",
       [],
       7,
       "hashlib.__name__.__len__() == 7 — the string 'hashlib' has 7 characters (h-a-s-h-l-i-b); str.__len__() returns 7; new to extra181"]
    - [package_eq_empty,
       "__package__.__eq__",
       [""],
       true,
       "hashlib.__package__.__eq__('') == True — hashlib is Lib/hashlib.py, a plain module file rather than a package directory; the import system sets __package__ to '' for top-level non-package modules; str.__eq__('') returns True; new to extra181"]
    - [package_not_hashlib,
       "__package__.__eq__",
       ["hashlib"],
       false,
       "hashlib.__package__.__eq__('hashlib') == False — hashlib is a plain module (not a package), so __package__ is '' not 'hashlib'; str.__eq__('hashlib') returns False; new to extra181"]

# ---------------------------------------------------------------------------
# Table 2: hashlib.__spec__ and hashlib.new class identity
#
# hashlib.__spec__.__class__.__name__ == 'ModuleSpec'
# hashlib.new.__class__.__name__ == 'function'
# hashlib.new.__class__.__name__ != 'builtin_function_or_method'
# hashlib.new.__class__.__name__ != 'type'
#
# Every imported module has a __spec__ attribute that is an instance of
# importlib.machinery.ModuleSpec.  hashlib.new is a Python-level function
# (def __hash_new ...) that dispatches to the appropriate C-level constructor;
# it is NOT a C builtin.  New to extra181.
# ---------------------------------------------------------------------------

table hashlib_extra181.spec_and_new_class:
  description: "hashlib.__spec__.__class__.__name__=='ModuleSpec'; hashlib.new.__class__.__name__=='function'; new to extra181"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibmodule181

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_modulespec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — every imported module carries a __spec__ attribute (an importlib.machinery.ModuleSpec instance) populated by the import system; its __class__.__name__ is 'ModuleSpec'; str.__eq__('ModuleSpec') returns True; new to extra181"]
    - [new_class_function,
       "new.__class__.__name__.__eq__",
       ["function"],
       true,
       "hashlib.new.__class__.__name__.__eq__('function') == True — hashlib.new is the Python-level wrapper function __hash_new defined in Lib/hashlib.py that dispatches to C-level hash constructors; it is a Python function object, so its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra181"]
    - [new_class_not_builtin,
       "new.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       false,
       "hashlib.new.__class__.__name__.__eq__('builtin_function_or_method') == False — hashlib.new is a pure-Python wrapper (not a C builtin); its __class__.__name__ is 'function', not 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns False; new to extra181"]
    - [spec_class_not_type,
       "__spec__.__class__.__name__.__eq__",
       ["type"],
       false,
       "hashlib.__spec__.__class__.__name__.__eq__('type') == False — __spec__ is an instance (a ModuleSpec object), not a class; its __class__.__name__ is 'ModuleSpec', not 'type'; str.__eq__('type') returns False; new to extra181"]

# ---------------------------------------------------------------------------
# Table 3: hashlib.md5, hashlib.sha256 and algorithm sets class identity
#
# hashlib.md5.__class__.__name__ == 'builtin_function_or_method'
# hashlib.sha256.__class__.__name__ == 'builtin_function_or_method'
# hashlib.algorithms_guaranteed.__class__.__name__ == 'set'
# hashlib.algorithms_available.__class__.__name__ == 'set'
#
# md5 and sha256 are C-level constructor functions exposed directly in the
# hashlib namespace (unlike hashlib.new which is a Python wrapper).
# algorithms_guaranteed and algorithms_available are plain Python set objects
# holding algorithm name strings.  New to extra181.
# ---------------------------------------------------------------------------

table hashlib_extra181.hash_constructors_and_algorithm_sets:
  description: "hashlib.md5 and sha256 are builtin_function_or_method; algorithms_guaranteed and algorithms_available are set; new to extra181"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibmodule181

  columns: [id, function, args, expected, description]
  rows:
    - [md5_class_builtin,
       "md5.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "hashlib.md5.__class__.__name__.__eq__('builtin_function_or_method') == True — hashlib.md5 is a C-level constructor function provided by the _hashlib or _md5 extension module; its __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra181"]
    - [sha256_class_builtin,
       "sha256.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "hashlib.sha256.__class__.__name__.__eq__('builtin_function_or_method') == True — hashlib.sha256 is a C-level constructor function provided by the _hashlib or _sha256 extension module; its __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra181"]
    - [algorithms_guaranteed_class_set,
       "algorithms_guaranteed.__class__.__name__.__eq__",
       ["set"],
       true,
       "hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set') == True — hashlib.algorithms_guaranteed is a frozenset-like plain set containing the names of hash algorithms guaranteed to be present on all platforms; its __class__.__name__ is 'set'; str.__eq__('set') returns True; new to extra181"]
    - [algorithms_available_class_set,
       "algorithms_available.__class__.__name__.__eq__",
       ["set"],
       true,
       "hashlib.algorithms_available.__class__.__name__.__eq__('set') == True — hashlib.algorithms_available is a plain set containing the names of all hash algorithms available on the current platform (a superset of algorithms_guaranteed); its __class__.__name__ is 'set'; str.__eq__('set') returns True; new to extra181"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra181
# ---------------------------------------------------------------------------

invariant hashlib_extra181.name_eq_hashlib:
  description: "hashlib.__name__ == 'hashlib' — the module's fully-qualified name is 'hashlib'; new to extra181"
  kind: python_call_eq
  function: __name__.__eq__
  args: ["hashlib"]
  expected: true

invariant hashlib_extra181.name_len_7:
  description: "hashlib.__name__.__len__() == 7 — 'hashlib' is a 7-character string; new to extra181"
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 7

invariant hashlib_extra181.package_empty:
  description: "hashlib.__package__ == '' — hashlib is Lib/hashlib.py (not a package directory), so __package__ is the empty string; new to extra181"
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant hashlib_extra181.spec_is_modulespec:
  description: "hashlib.__spec__.__class__.__name__ == 'ModuleSpec' — every imported module has a __spec__ attribute of type importlib.machinery.ModuleSpec; new to extra181"
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant hashlib_extra181.new_is_function:
  description: "hashlib.new.__class__.__name__ == 'function' — hashlib.new is the Python-level dispatcher __hash_new, not a C builtin; new to extra181"
  kind: python_call_eq
  function: new.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant hashlib_extra181.md5_is_builtin:
  description: "hashlib.md5.__class__.__name__ == 'builtin_function_or_method' — md5 is a C-level hash constructor, unlike hashlib.new which is a Python wrapper; new to extra181"
  kind: python_call_eq
  function: md5.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant hashlib_extra181.algorithms_guaranteed_is_set:
  description: "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' — the set of guaranteed algorithm names; new to extra181"
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__eq__
  args: ["set"]
  expected: true
