    - ["mp3211008", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__and__"], false]

# ---------------------------------------------------------------------------
# __or__ dict-presence — operator.contains(Cls.__dict__, '__or__')
#
# All 8 multiprocessing classes return false for __or__.
# managers._BaseSetProxy proxies set, and set defines __or__ for union (s | t).
#   However, _BaseSetProxy does NOT define __or__ in its own __dict__.
#   Set union through the proxy is accessed via the _method IPC callthrough
#   dispatch mechanism, not via a locally defined __or__ dunder.
# managers._BaseDictProxy proxies dict. dict gained __or__ in Python 3.9
#   (PEP 584, dict merging via |), but _BaseDictProxy does NOT expose __or__
#   in its own __dict__ — dict merging is not forwarded as an operator dunder.
# Process/Pool/AsyncResult/MapResult/SyncManager/BaseListProxy: none define
#   __or__ in their own __dict__; no union or bitwise OR semantics apply.
# ---------------------------------------------------------------------------

