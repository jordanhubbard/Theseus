    - ["mp3211002", operator.contains, [multiprocessing.pool.Pool.__dict__,               "__and__"], false]
    - ["mp3211003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__and__"], false]
    - ["mp3211004", operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__and__"], false]
    - ["mp3211005", operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__and__"], false]
    - ["mp3211006", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__and__"], false]
