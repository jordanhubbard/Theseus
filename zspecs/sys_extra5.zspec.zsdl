spec: sys_extra5
version: ">=3.9"
backend: python_module(sys)

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sys.html — Python sys module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/sysmodule.c"
  notes:
    - "This spec extends prior sys specs."
    - "Focus: sys function __name__ attributes and sys object types."
    - "sys.getdefaultencoding() == 'utf-8'."
    - "sys.getfilesystemencoding().__class__.__name__ == 'str'."
    - "sys.maxsize == 2**63 - 1 on 64-bit systems."
    - "sys.float_info.__class__.__name__ == 'float_info'."
    - "sys.int_info.__class__.__name__ == 'int_info'."
    - "sys.hash_info.__class__.__name__ == 'hash_info'."
    - "sys.version.__class__.__name__ == 'str'."
    - "sys.platform == 'darwin' on macOS."
    - "sys.byteorder == 'little' on little-endian systems."
    - "sys.hexversion.__class__.__name__ == 'int'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table sys_extra5.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [getdefaultencoding,    getdefaultencoding.__name__.__eq__,    ["getdefaultencoding"],    true]
    - [getfilesystemencoding, getfilesystemencoding.__name__.__eq__, ["getfilesystemencoding"], true]
    - [getrecursionlimit,     getrecursionlimit.__name__.__eq__,     ["getrecursionlimit"],     true]
    - [setrecursionlimit,     setrecursionlimit.__name__.__eq__,     ["setrecursionlimit"],     true]
    - [getsizeof,             getsizeof.__name__.__eq__,             ["getsizeof"],             true]
    - [intern,                intern.__name__.__eq__,                ["intern"],                true]
    - [exc_info,              exc_info.__name__.__eq__,              ["exc_info"],              true]

invariant sys_extra5.getdefaultencoding.value:
  description: "sys.getdefaultencoding() == 'utf-8'"
  category: encoding
  kind: python_call_eq
  function: getdefaultencoding
  args: []
  expected: "utf-8"

invariant sys_extra5.getfilesystemencoding.returns_str:
  description: "sys.getfilesystemencoding().__class__.__name__ == 'str'"
  category: encoding
  kind: python_call_eq
  function: getfilesystemencoding
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["str"]
  expected: true

invariant sys_extra5.float_info.class_name:
  description: "sys.float_info.__class__.__name__ == 'float_info'"
  category: info_structs
  kind: python_call_eq
  function: float_info.__class__.__name__.__eq__
  args: ["float_info"]
  expected: true

invariant sys_extra5.int_info.class_name:
  description: "sys.int_info.__class__.__name__ == 'int_info'"
  category: info_structs
  kind: python_call_eq
  function: int_info.__class__.__name__.__eq__
  args: ["int_info"]
  expected: true

invariant sys_extra5.hash_info.class_name:
  description: "sys.hash_info.__class__.__name__ == 'hash_info'"
  category: info_structs
  kind: python_call_eq
  function: hash_info.__class__.__name__.__eq__
  args: ["hash_info"]
  expected: true

invariant sys_extra5.version.class_name:
  description: "sys.version.__class__.__name__ == 'str'"
  category: attributes
  kind: python_call_eq
  function: version.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant sys_extra5.hexversion.class_name:
  description: "sys.hexversion.__class__.__name__ == 'int'"
  category: attributes
  kind: python_call_eq
  function: hexversion.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant sys_extra5.byteorder.is_str:
  description: "sys.byteorder.__class__.__name__ == 'str'"
  category: attributes
  kind: python_call_eq
  function: byteorder.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant sys_extra5.platform.is_str:
  description: "sys.platform.__class__.__name__ == 'str'"
  category: attributes
  kind: python_call_eq
  function: platform.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant sys_extra5.maxsize.ge_2_31:
  description: "sys.maxsize >= 2**31 - 1 — at least 32-bit int max"
  category: attributes
  kind: python_call_eq
  function: maxsize.__ge__
  args: [2147483647]
  expected: true
