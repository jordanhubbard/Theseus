spec: pty_extra5
version: ">=3.9"
backend: python_module(pty)

docs: https://docs.python.org/3/library/pty.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pty.html — Python pty module documentation"
    - "CPython source: Lib/pty.py (PSF; source inspection permitted)"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "pty internals: kernel TTY layer, file-descriptor allocation"
  notes:
    - "This spec extends pty.zspec.zsdl through pty_extra4.zspec.zsdl."
    - "pty covers: STDIN/STDOUT/STDERR_FILENO values and types, fork/openpty/spawn __name__ and __module__."
    - "pty_extra covers: function __name__/__module__/type tables, fd constant types and values, fork/spawn __qualname__."
    - "pty_extra2 covers: openpty __qualname__, CHILD value and type, spawn __doc__ is str, function qualnames table, fd ordering/non-negative/positive."
    - "pty_extra3 covers: module __name__, fork/openpty __doc__ is str, fork/openpty/spawn __code__ class, fd arithmetic (STDERR-STDIN/STDERR-STDOUT/STDOUT-STDIN)."
    - "pty_extra4 covers: module __package__/__loader__ class, setraw/__module__, tcgetattr/__module__/is_builtin, fork/__code__.co_name, openpty/__code__.co_name, spawn/__code__.co_name, STDIN+STDOUT==1/STDOUT+STDERR==3, CHILD==STDIN_FILENO."
    - "New here: pty module __doc__ type; pty.__file__ type; setraw.__name__; setraw.__qualname__; fork.__code__.co_varnames type; spawn.__code__.co_varnames type."
    - "pty is a pure Python module (Lib/pty.py); __file__ is a str ending in '.py'."
    - "pty.__doc__ is a str — the module has a module-level docstring."
    - "pty.setraw is imported from the tty module; pty_extra4 covers setraw.__module__ == 'tty' but not setraw.__name__ or __qualname__."
    - "setraw.__name__ == 'setraw' — the function name attribute of the tty.setraw function."
    - "setraw.__qualname__ == 'setraw' — top-level function in tty, qualname matches name."
    - "fork.__code__.co_varnames is a tuple — code object varnames are always stored as a tuple."
    - "spawn.__code__.co_varnames is a tuple — same invariant for the spawn function."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module __doc__ type — not covered in any prior pty spec
# pty_extra3 covers module __name__; the module __doc__ is a new axis.
# pty.py carries a module-level docstring describing the pseudo-terminal API.
# ---------------------------------------------------------------------------

invariant pty_extra5.module.doc_type:
  description: "pty.__doc__.__class__.__name__ == 'str' — the pty module has a string docstring"
  category: module_identity
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Module __file__ type — not covered in any prior pty spec
# pty is a pure Python module; __file__ is the path to pty.py as a str.
# ---------------------------------------------------------------------------

invariant pty_extra5.module.file_type:
  description: "pty.__file__.__class__.__name__ == 'str' — __file__ is a string path to pty.py"
  category: module_identity
  kind: python_call_eq
  function: __file__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# setraw.__name__ and setraw.__qualname__ — not covered in any prior pty spec
# pty_extra4 checks setraw.__module__ == 'tty' but not __name__ or __qualname__.
# setraw is the tty.setraw function imported into pty's namespace.
# ---------------------------------------------------------------------------

invariant pty_extra5.setraw.name:
  description: "pty.setraw.__name__ == 'setraw' — function name attribute of tty.setraw"
  category: imported_names
  kind: python_call_eq
  function: setraw.__name__.__eq__
  args: ["setraw"]
  expected: true

invariant pty_extra5.setraw.qualname:
  description: "pty.setraw.__qualname__ == 'setraw' — top-level function in tty, qualname matches name"
  category: imported_names
  kind: python_call_eq
  function: setraw.__qualname__.__eq__
  args: ["setraw"]
  expected: true

# ---------------------------------------------------------------------------
# fork.__code__.co_varnames and spawn.__code__.co_varnames type checks
# pty_extra3 checks that __code__ is a 'code' object.
# pty_extra4 checks co_name for fork, openpty, and spawn.
# New here: co_varnames is a tuple (local variable names in a code object).
# ---------------------------------------------------------------------------

table pty_extra5.function_code_co_varnames_types:
  kind: python_call_eq
  category: function_code
  id_prefix: co_varnames_type

  columns: [id, function, args, expected]
  rows:
    - [fork,  fork.__code__.co_varnames.__class__.__name__.__eq__,  ["tuple"], true]
    - [spawn, spawn.__code__.co_varnames.__class__.__name__.__eq__, ["tuple"], true]
