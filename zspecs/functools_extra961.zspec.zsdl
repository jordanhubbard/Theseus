spec: functools_extra961
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks functools.reduce, lru_cache, partial, total_ordering error behavior and identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra961.reduce_identity:
  description: "functools.reduce name and module identity"
  kind: python_call_eq
  category: identity
  id_prefix: ft961id
  columns: [id, function, args, expected]
  rows:
    - [ft961id001, functools.reduce.__name__.__eq__,   ["reduce"],    true]
    - [ft961id002, functools.reduce.__module__.__eq__,  ["_functools"], true]
    - [ft961id003, functools.partial.__name__.__eq__,   ["partial"],   true]
    - [ft961id004, functools.partial.__module__.__eq__, ["functools"], true]
    - [ft961id005, functools.lru_cache.__name__.__eq__, ["lru_cache"], true]
    - [ft961id006, functools.lru_cache.__module__.__eq__, ["functools"], true]

table functools_extra961.reduce_raises:
  description: "functools.reduce error conditions"
  kind: python_call_raises
  category: reduce_errors
  id_prefix: ft961re
  columns: [id, function, args, expected]
  rows:
    - [ft961re001, functools.reduce, [],                      TypeError]
    - [ft961re002, functools.reduce, ["lambda a,b: a+b", 42], TypeError]

table functools_extra961.lru_cache_raises:
  description: "functools.lru_cache error conditions on bad maxsize"
  kind: python_call_raises
  category: lru_cache_errors
  id_prefix: ft961lc
  columns: [id, function, args, expected]
  rows:
    - [ft961lc001, functools.lru_cache, ["3.14"],    TypeError]
    - [ft961lc002, functools.lru_cache, ["\"yes\""], TypeError]

table functools_extra961.partial_raises:
  description: "functools.partial and total_ordering error conditions"
  kind: python_call_raises
  category: partial_errors
  id_prefix: ft961pa
  columns: [id, function, args, expected]
  rows:
    - [ft961pa001, functools.partial,         [],        TypeError]
    - [ft961pa002, functools.partial,         ["42"],    TypeError]
    - [ft961pa003, functools.total_ordering,  ["object"], ValueError]
