spec: threading_extra92
version: ">=3.9"
backend: python_module(threading)
extends: threading_extra91

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra91.zspec.zsdl."
    - "This spec covers: threading.Thread.__dict__ membership for methods and properties; and Condition/Semaphore/Event __dict__ class names (Wave 251)."
    - "threading.Thread.__dict__.__contains__('start') == True — start is a method defined in Thread. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__contains__('run') == True — run is a method defined in Thread. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__contains__('join') == True — join is a method defined in Thread. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__contains__('is_alive') == True — is_alive is a method defined in Thread. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__contains__('daemon') == True — daemon is a property defined in Thread. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__contains__('name') == True — name is a property defined in Thread. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__contains__('ident') == True — ident is a property defined in Thread. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__contains__('native_id') == True — native_id is a property defined in Thread (Python 3.8+). Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is a mappingproxy. Verified with Python 3.14.3."
    - "threading.Condition.__dict__.__class__.__name__ == 'mappingproxy' — Condition class __dict__ is a mappingproxy. Verified with Python 3.14.3."
    - "threading.Semaphore.__dict__.__class__.__name__ == 'mappingproxy' — Semaphore class __dict__ is a mappingproxy. Verified with Python 3.14.3."
    - "threading.Event.__dict__.__class__.__name__ == 'mappingproxy' — Event class __dict__ is a mappingproxy. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Thread method dict membership
#
# Wave 251 theme: threading.Thread.__dict__ membership for core methods.
#
# threading.Thread.__dict__.__contains__('start')    == True
# threading.Thread.__dict__.__contains__('run')      == True
# threading.Thread.__dict__.__contains__('join')     == True
# threading.Thread.__dict__.__contains__('is_alive') == True
#
# Prior spec extra91 checked Thread method __qualname__ lengths. This spec (extra92) checks __dict__ membership. New to extra92.
# ---------------------------------------------------------------------------

table threading_extra92.thread_method_dict_membership:
  description: "Thread.__dict__ membership for start/run/join/is_alive methods; pure-Python Thread class in Lib/threading.py; wave 251; new to extra92"
  kind: python_call_eq
  category: membership
  id_prefix: threadingthreaddictmem92

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_dict_contains_start,
       "Thread.__dict__.__contains__",
       ["start"],
       true,
       "threading.Thread.__dict__.__contains__('start') == True — Thread.start is a pure-Python method defined in Lib/threading.py; because it is defined directly on the Thread class, 'start' is a key in Thread.__dict__; dict.__contains__('start') returns True; prior spec extra91 checked Thread.start.__qualname__ length; this spec (extra92) checks __dict__ membership; new to extra92"]
    - [Thread_dict_contains_run,
       "Thread.__dict__.__contains__",
       ["run"],
       true,
       "threading.Thread.__dict__.__contains__('run') == True — Thread.run is a pure-Python method defined in Lib/threading.py; 'run' is a key in Thread.__dict__; dict.__contains__('run') returns True; new to extra92"]
    - [Thread_dict_contains_join,
       "Thread.__dict__.__contains__",
       ["join"],
       true,
       "threading.Thread.__dict__.__contains__('join') == True — Thread.join is a pure-Python method defined in Lib/threading.py; 'join' is a key in Thread.__dict__; dict.__contains__('join') returns True; new to extra92"]
    - [Thread_dict_contains_is_alive,
       "Thread.__dict__.__contains__",
       ["is_alive"],
       true,
       "threading.Thread.__dict__.__contains__('is_alive') == True — Thread.is_alive is a pure-Python method defined in Lib/threading.py; 'is_alive' is a key in Thread.__dict__; dict.__contains__('is_alive') returns True; new to extra92"]

# ---------------------------------------------------------------------------
# Thread property dict membership
#
# Wave 251 theme: threading.Thread.__dict__ membership for properties.
#
# threading.Thread.__dict__.__contains__('daemon')    == True
# threading.Thread.__dict__.__contains__('name')      == True
# threading.Thread.__dict__.__contains__('ident')     == True
# threading.Thread.__dict__.__contains__('native_id') == True
#
# daemon, name, ident, and native_id are all property descriptors on Thread. New to extra92.
# ---------------------------------------------------------------------------

table threading_extra92.thread_property_dict_membership:
  description: "Thread.__dict__ membership for daemon/name/ident/native_id properties; property descriptors in Lib/threading.py; wave 251; new to extra92"
  kind: python_call_eq
  category: membership
  id_prefix: threadingthreaddictmem92

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_dict_contains_daemon,
       "Thread.__dict__.__contains__",
       ["daemon"],
       true,
       "threading.Thread.__dict__.__contains__('daemon') == True — Thread.daemon is a property descriptor defined in Lib/threading.py; because it is defined directly on the Thread class, 'daemon' is a key in Thread.__dict__; property descriptors appear in __dict__ just like methods; dict.__contains__('daemon') returns True; no prior threading spec checks property dict membership via threadingthreaddictmem92; new to extra92"]
    - [Thread_dict_contains_name,
       "Thread.__dict__.__contains__",
       ["name"],
       true,
       "threading.Thread.__dict__.__contains__('name') == True — Thread.name is a property descriptor defined in Lib/threading.py; 'name' is a key in Thread.__dict__; dict.__contains__('name') returns True; new to extra92"]
    - [Thread_dict_contains_ident,
       "Thread.__dict__.__contains__",
       ["ident"],
       true,
       "threading.Thread.__dict__.__contains__('ident') == True — Thread.ident is a property descriptor defined in Lib/threading.py that returns the thread identifier or None if the thread has not been started; 'ident' is a key in Thread.__dict__; dict.__contains__('ident') returns True; new to extra92"]
    - [Thread_dict_contains_native_id,
       "Thread.__dict__.__contains__",
       ["native_id"],
       true,
       "threading.Thread.__dict__.__contains__('native_id') == True — Thread.native_id is a property descriptor introduced in Python 3.8 in Lib/threading.py; it returns the native integral thread ID as assigned by the OS kernel; 'native_id' is a key in Thread.__dict__; dict.__contains__('native_id') returns True; new to extra92"]

# ---------------------------------------------------------------------------
# Thread dict class name
#
# Wave 251 theme: threading.Thread.__dict__.__class__.__name__ == 'mappingproxy'.
#
# threading.Thread.__dict__.__class__.__name__.__eq__('mappingproxy') == True
# threading.Thread.__dict__.__class__.__name__.__eq__('dict')         == False
# threading.Thread.__dict__.__contains__('start')                     == True  (re-confirm)
# threading.Thread.__dict__.__contains__('daemon')                    == True  (re-confirm)
#
# No prior threading spec checks Thread.__dict__.__class__.__name__ via threadingthreaddictmem92. New to extra92.
# ---------------------------------------------------------------------------

table threading_extra92.thread_dict_class_name:
  description: "Thread.__dict__.__class__.__name__ == 'mappingproxy'; class __dict__ is a read-only proxy; wave 251; new to extra92"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingthreaddictmem92

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_dict_class_name_eq_mappingproxy,
       "Thread.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "threading.Thread.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Thread is a pure-Python class in Lib/threading.py; class __dict__ in Python is a types.MappingProxyType, a read-only proxy that prevents direct assignment to the class namespace; __dict__.__class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; no prior threading spec checks Thread.__dict__.__class__.__name__ via threadingthreaddictmem92; new to extra92"]
    - [Thread_dict_class_name_ne_dict,
       "Thread.__dict__.__class__.__name__.__eq__",
       ["dict"],
       false,
       "threading.Thread.__dict__.__class__.__name__.__eq__('dict') == False — Thread class __dict__ is a mappingproxy (types.MappingProxyType), not a plain mutable dict; __dict__.__class__.__name__ is 'mappingproxy', not 'dict'; str.__eq__('dict') returns False; confirms the class namespace is protected from direct mutation; new to extra92"]
    - [Thread_dict_contains_start_reconfirm,
       "Thread.__dict__.__contains__",
       ["start"],
       true,
       "threading.Thread.__dict__.__contains__('start') == True — re-confirms that 'start' is in Thread.__dict__; the mappingproxy is still subscriptable and supports __contains__; dict.__contains__('start') returns True; new to extra92"]
    - [Thread_dict_contains_daemon_reconfirm,
       "Thread.__dict__.__contains__",
       ["daemon"],
       true,
       "threading.Thread.__dict__.__contains__('daemon') == True — re-confirms that 'daemon' is in Thread.__dict__; the mappingproxy supports __contains__ for membership tests; dict.__contains__('daemon') returns True; new to extra92"]

# ---------------------------------------------------------------------------
# Condition/Semaphore/Event __dict__ class names
#
# Wave 251 theme: synchronization primitive __dict__.__class__.__name__ == 'mappingproxy'.
#
# threading.Condition.__dict__.__class__.__name__.__eq__('mappingproxy') == True
# threading.Semaphore.__dict__.__class__.__name__.__eq__('mappingproxy') == True
# threading.Event.__dict__.__class__.__name__.__eq__('mappingproxy')     == True
# threading.Thread.__dict__.__class__.__name__.__eq__('mappingproxy')    == True  (re-confirm)
#
# No prior threading spec checks these sync primitive dict class names via threadingthreaddictmem92. New to extra92.
# ---------------------------------------------------------------------------

table threading_extra92.sync_primitive_dict_class_names:
  description: "Condition/Semaphore/Event/__dict__.__class__.__name__ == 'mappingproxy'; sync primitive classes in Lib/threading.py; wave 251; new to extra92"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingthreaddictmem92

  columns: [id, function, args, expected, description]
  rows:
    - [Condition_dict_class_name_eq_mappingproxy,
       "Condition.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "threading.Condition.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Condition is a pure-Python synchronization primitive class in Lib/threading.py; class __dict__ is a types.MappingProxyType; __dict__.__class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; no prior threading spec checks these sync primitive dict class names via threadingthreaddictmem92; new to extra92"]
    - [Semaphore_dict_class_name_eq_mappingproxy,
       "Semaphore.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "threading.Semaphore.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Semaphore is a pure-Python synchronization primitive class in Lib/threading.py; class __dict__ is a mappingproxy; __dict__.__class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; new to extra92"]
    - [Event_dict_class_name_eq_mappingproxy,
       "Event.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "threading.Event.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Event is a pure-Python synchronization primitive class in Lib/threading.py; class __dict__ is a mappingproxy; __dict__.__class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; new to extra92"]
    - [Thread_dict_class_name_eq_mappingproxy_reconfirm,
       "Thread.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "threading.Thread.__dict__.__class__.__name__.__eq__('mappingproxy') == True — re-confirms Thread class __dict__ is a mappingproxy; consistent with all other threading classes; str.__eq__('mappingproxy') returns True; new to extra92"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra92
# ---------------------------------------------------------------------------

invariant threading_extra92.Thread_dict_contains_start:
  description: "threading.Thread.__dict__.__contains__('start') == True — start method is defined in Thread.__dict__; wave 251; new to extra92"
  kind: python_call_eq
  function: "Thread.__dict__.__contains__"
  args: ["start"]
  expected: true

invariant threading_extra92.Thread_dict_contains_daemon:
  description: "threading.Thread.__dict__.__contains__('daemon') == True — daemon property is defined in Thread.__dict__; wave 251; new to extra92"
  kind: python_call_eq
  function: "Thread.__dict__.__contains__"
  args: ["daemon"]
  expected: true

invariant threading_extra92.Thread_dict_class_name_eq_mappingproxy:
  description: "threading.Thread.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Thread class __dict__ is a mappingproxy; wave 251; new to extra92"
  kind: python_call_eq
  function: "Thread.__dict__.__class__.__name__.__eq__"
  args: ["mappingproxy"]
  expected: true

invariant threading_extra92.Condition_dict_class_name_eq_mappingproxy:
  description: "threading.Condition.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Condition class __dict__ is a mappingproxy; wave 251; new to extra92"
  kind: python_call_eq
  function: "Condition.__dict__.__class__.__name__.__eq__"
  args: ["mappingproxy"]
  expected: true

invariant threading_extra92.Event_dict_class_name_eq_mappingproxy:
  description: "threading.Event.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Event class __dict__ is a mappingproxy; wave 251; new to extra92"
  kind: python_call_eq
  function: "Event.__dict__.__class__.__name__.__eq__"
  args: ["mappingproxy"]
  expected: true
