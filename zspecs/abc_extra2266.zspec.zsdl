spec: abc_extra2266
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/abc.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 598 (_extra2266): pickling/serialization protocol dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "abc.ABC, abc.ABCMeta, and abc.abstractmethod all lack custom pickle/copy/sizeof hooks in their __dict__."
  created_at: "2026-04-12"

