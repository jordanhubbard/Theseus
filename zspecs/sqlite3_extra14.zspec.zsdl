spec: sqlite3_extra14
version: ">=3.9"
backend: python_module(sqlite3)

docs: https://docs.python.org/3/library/sqlite3.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sqlite3.html — Python sqlite3 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sqlite3/__init__.py"
    - "CPython source: Modules/_sqlite/module.c"
    - "CPython source: Modules/_sqlite/connection.c"
    - "CPython source: Modules/_sqlite/cursor.c"
  notes:
    - "This spec extends sqlite3.zspec.zsdl and prior extras through sqlite3_extra13.zspec.zsdl."
    - "sqlite3_extra13 covers: connect(':memory:').__class__.__name__; in_transaction; total_changes; sqlite_version __class__.__name__ and __len__; version __len__; sqlite_version_info/__len__; version_info class_name/__len__."
    - "sqlite3_extra12 covers: paramstyle value/class_name; version class_name; Warning/InterfaceError/ProgrammingError __name__; Error/DatabaseError __module__; connect __qualname__; Row.__name__."
    - "sqlite3_extra11 covers: sqlite_version class_name; apilevel value/class_name; threadsafety class_name/ge1; exception __name__ table; sqlite_version_info class_name/len."
    - "sqlite3_extra10 covers: Connection/Cursor/Row __class__.__name__ == 'type'; connect __class__.__name__."
    - "sqlite3_extra9 covers: SQLITE_ABORT/SQLITE_CONSTRAINT/SQLITE_RANGE; complete_statement __name__/__module__; DatabaseError/Error MRO[1]; PARSE_DECLTYPES/PARSE_COLNAMES type; version/__len__."
    - "Focus: new axes — Cursor/Connection/Row __name__/__module__/__qualname__; connect/__qualname__; complete_statement boolean results."
    - "sqlite3.Cursor.__name__ == 'Cursor' — no prior spec checks Cursor.__name__ as a standalone invariant."
    - "sqlite3.Cursor.__module__ == 'sqlite3' — no prior spec checks Cursor.__module__."
    - "sqlite3.Connection.__name__ == 'Connection' — no prior spec checks Connection.__name__ as a standalone invariant."
    - "sqlite3.Connection.__module__ == 'sqlite3' — no prior spec checks Connection.__module__."
    - "sqlite3.Row.__name__ == 'Row' — sqlite3_extra12 checks Row.__name__ in a different namespace; standalone invariant under extra14 is new."
    - "sqlite3.Row.__module__ == 'sqlite3' — no prior spec checks Row.__module__."
    - "sqlite3.Cursor.__qualname__ == 'Cursor' — no prior spec checks Cursor.__qualname__."
    - "sqlite3.Connection.__qualname__ == 'Connection' — no prior spec checks Connection.__qualname__."
    - "sqlite3.Row.__qualname__ == 'Row' — no prior spec checks Row.__qualname__."
    - "sqlite3.connect.__qualname__ == 'connect' — sqlite3_extra12 checks connect.__qualname__ in a different namespace; standalone invariant under extra14 is new."
    - "sqlite3.complete_statement.__name__ == 'complete_statement' — sqlite3_extra9 checks complete_statement.__name__ in a table; standalone invariant under extra14 is new."
    - "sqlite3.complete_statement('SELECT 1;') == True — complete SQL statement (ends with semicolon); verified with Python 3.12."
    - "sqlite3.complete_statement('SELECT 1') == False — incomplete SQL statement (no semicolon)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Cursor, Connection, Row — __name__, __module__, __qualname__
#
# sqlite3_extra10 checks __class__.__name__ == 'type' for Cursor/Connection/Row
# (confirming they are class objects). sqlite3_extra12 checks Row.__name__.
# No prior spec checks __module__ or __qualname__ for any of the three, and
# no prior spec checks __name__ for Cursor or Connection as standalone invariants.
# ---------------------------------------------------------------------------

table sqlite3_extra14.class_name_module_qualname:
  kind: python_call_eq
  category: class_attrs
  id_prefix: ccr14

  columns: [id, function, args, expected]
  rows:
    - [Cursor_name,      Cursor.__name__.__eq__,      ["Cursor"],      true]
    - [Cursor_module,    Cursor.__module__.__eq__,    ["sqlite3"],     true]
    - [Cursor_qualname,  Cursor.__qualname__.__eq__,  ["Cursor"],      true]
    - [Conn_name,        Connection.__name__.__eq__,  ["Connection"],  true]
    - [Conn_module,      Connection.__module__.__eq__, ["sqlite3"],    true]
    - [Conn_qualname,    Connection.__qualname__.__eq__, ["Connection"], true]
    - [Row_name,         Row.__name__.__eq__,         ["Row"],         true]
    - [Row_module,       Row.__module__.__eq__,       ["sqlite3"],     true]
    - [Row_qualname,     Row.__qualname__.__eq__,     ["Row"],         true]

# ---------------------------------------------------------------------------
# sqlite3.connect.__qualname__
#
# sqlite3_extra12 checks connect.__qualname__ in its namespace. This standalone
# invariant under extra14 provides independent coverage of the same property.
# ---------------------------------------------------------------------------

invariant sqlite3_extra14.connect.qualname:
  description: "sqlite3.connect.__qualname__ == 'connect' — top-level connect function qualname"
  category: function_attrs
  kind: python_call_eq
  function: connect.__qualname__.__eq__
  args: ["connect"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.complete_statement — function identity and boolean results
#
# sqlite3_extra9 checks complete_statement.__name__ and __module__ in a table.
# No prior spec checks the actual boolean return values for a complete vs.
# incomplete SQL statement.
# ---------------------------------------------------------------------------

invariant sqlite3_extra14.complete_statement.name:
  description: "sqlite3.complete_statement.__name__ == 'complete_statement'"
  category: function_attrs
  kind: python_call_eq
  function: complete_statement.__name__.__eq__
  args: ["complete_statement"]
  expected: true

invariant sqlite3_extra14.complete_statement.with_semicolon:
  description: "sqlite3.complete_statement('SELECT 1;') == True — complete SQL ends with semicolon"
  category: complete_statement
  kind: python_call_eq
  function: complete_statement
  args: ["SELECT 1;"]
  expected: true

invariant sqlite3_extra14.complete_statement.without_semicolon:
  description: "sqlite3.complete_statement('SELECT 1') == False — incomplete SQL has no semicolon"
  category: complete_statement
  kind: python_call_eq
  function: complete_statement
  args: ["SELECT 1"]
  expected: false
