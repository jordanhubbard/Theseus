spec: itertools_extra175
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.accumulate class identity — itertools.accumulate.__name__=='accumulate' (len=10); itertools.accumulate.__module__=='itertools'; itertools.accumulate.__mro__.__len__()==2; itertools.combinations.__name__=='combinations' (len=12); itertools.combinations.__mro__.__len__()==2; itertools.permutations.__name__=='permutations' (len=12; same len as combinations); itertools.permutations.__mro__.__len__()==2; itertools.combinations_with_replacement.__name__=='combinations_with_replacement' (len=29; longest itertools class name)."
    - "itertools.accumulate.__name__ == 'accumulate' — accumulate is a C extension type in itertoolsmodule.c that returns running totals (or accumulated values with a custom function); its __name__ is 'accumulate', 10 characters. Verified with Python 3.14.3."
    - "itertools.accumulate.__module__ == 'itertools' — accumulate is defined in the itertools C extension module. Verified with Python 3.14.3."
    - "itertools.accumulate.__mro__.__len__() == 2 — accumulate is a C extension type inheriting directly from object; its MRO is (accumulate, object). Verified with Python 3.14.3."
    - "itertools.combinations.__name__ == 'combinations' — combinations is a C extension type in itertoolsmodule.c; its __name__ is 'combinations', 12 characters. Verified with Python 3.14.3."
    - "itertools.combinations.__mro__.__len__() == 2 — combinations inherits directly from object; its MRO is (combinations, object). Verified with Python 3.14.3."
    - "itertools.permutations.__name__ == 'permutations' — permutations is a C extension type; its __name__ is 'permutations', also 12 characters (same length as 'combinations'). Verified with Python 3.14.3."
    - "itertools.permutations.__mro__.__len__() == 2 — permutations inherits directly from object; MRO length 2. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__name__ == 'combinations_with_replacement' — this is the longest itertools class name at 29 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.accumulate class __name__ and __module__
#
# itertools.accumulate.__name__ == 'accumulate'
# itertools.accumulate.__name__.__len__() == 10
# itertools.accumulate.__module__ == 'itertools'
# itertools.accumulate.__module__.__len__() == 9
#
# itertools.accumulate is a C extension type defined in itertoolsmodule.c that
# makes an iterator yielding accumulated sums (or accumulated results of a
# binary function). Its __name__ is 'accumulate' (10 chars) and its __module__
# is 'itertools' (9 chars). New to extra175.
# ---------------------------------------------------------------------------

table itertools_extra175.accumulate_name_and_module:
  description: "itertools.accumulate.__name__ 'accumulate' len 10; __module__ 'itertools' len 9; new to extra175"
  kind: python_call_eq
  category: identity
  id_prefix: iteraccum175

  columns: [id, function, args, expected, description]
  rows:
    - [accumulate_name_eq,
       "accumulate.__name__.__eq__",
       ["accumulate"],
       true,
       "itertools.accumulate.__name__.__eq__('accumulate') == True — itertools.accumulate is a C extension type in itertoolsmodule.c that makes an iterator returning accumulated sums or accumulated results of a binary function; its __name__ is 'accumulate'; str.__eq__('accumulate') returns True; new to extra175"]
    - [accumulate_name_len_10,
       "accumulate.__name__.__len__",
       [],
       10,
       "itertools.accumulate.__name__.__len__() == 10 — the name 'accumulate' has exactly 10 characters: a-c-c-u-m-u-l-a-t-e; str.__len__() returns 10; new to extra175"]
    - [accumulate_module_itertools,
       "accumulate.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.accumulate.__module__.__eq__('itertools') == True — itertools.accumulate is a C extension type defined in the itertools module (itertoolsmodule.c); its __module__ is the string 'itertools'; str.__eq__('itertools') returns True; new to extra175"]
    - [accumulate_module_len_9,
       "accumulate.__module__.__len__",
       [],
       9,
       "itertools.accumulate.__module__.__len__() == 9 — the module name 'itertools' has exactly 9 characters: i-t-e-r-t-o-o-l-s; str.__len__() returns 9; new to extra175"]

# ---------------------------------------------------------------------------
# Table 2: itertools.accumulate __mro__ and itertools.combinations __name__
#
# itertools.accumulate.__mro__.__len__() == 2
# itertools.accumulate.__mro__[0].__name__ == 'accumulate'
# itertools.combinations.__name__ == 'combinations'
# itertools.combinations.__name__.__len__() == 12
#
# accumulate's MRO is (accumulate, object) — it inherits directly from object
# like all itertools C types. combinations is another C extension type whose
# __name__ is 'combinations' (12 chars). New to extra175.
# ---------------------------------------------------------------------------

table itertools_extra175.accumulate_mro_and_combinations_name:
  description: "itertools.accumulate.__mro__ len 2, mro[0] 'accumulate'; combinations.__name__ 'combinations' len 12; new to extra175"
  kind: python_call_eq
  category: identity
  id_prefix: iteraccum175

  columns: [id, function, args, expected, description]
  rows:
    - [accumulate_mro_len_2,
       "accumulate.__mro__.__len__",
       [],
       2,
       "itertools.accumulate.__mro__.__len__() == 2 — itertools.accumulate is a C extension type defined in itertoolsmodule.c that inherits directly from object with no intermediate base classes; its __mro__ is (accumulate, object), a tuple of length 2; tuple.__len__() returns 2; new to extra175"]
    - ["accumulate_mro_0_accumulate",
       "accumulate.__mro__[0].__name__.__eq__",
       ["accumulate"],
       true,
       "itertools.accumulate.__mro__[0].__name__.__eq__('accumulate') == True — the first entry in accumulate.__mro__ is the accumulate class itself; its __name__ is 'accumulate'; str.__eq__('accumulate') returns True; new to extra175"]
    - [combinations_name_eq,
       "combinations.__name__.__eq__",
       ["combinations"],
       true,
       "itertools.combinations.__name__.__eq__('combinations') == True — itertools.combinations is a C extension type in itertoolsmodule.c that emits r-length subsequences of elements from the input iterable; its __name__ is 'combinations'; str.__eq__('combinations') returns True; new to extra175"]
    - [combinations_name_len_12,
       "combinations.__name__.__len__",
       [],
       12,
       "itertools.combinations.__name__.__len__() == 12 — the name 'combinations' has exactly 12 characters: c-o-m-b-i-n-a-t-i-o-n-s; str.__len__() returns 12; new to extra175"]

# ---------------------------------------------------------------------------
# Table 3: itertools.combinations and itertools.permutations __mro__
#
# itertools.combinations.__mro__.__len__() == 2
# itertools.combinations.__mro__[0].__name__ == 'combinations'
# itertools.permutations.__name__ == 'permutations'
# itertools.permutations.__name__.__len__() == 12
#
# Both combinations and permutations are C extension types in itertoolsmodule.c
# that inherit directly from object, giving MRO length 2. The name
# 'permutations' is also 12 characters long (same as 'combinations'). New to
# extra175.
# ---------------------------------------------------------------------------

table itertools_extra175.combinations_mro_and_permutations_name:
  description: "itertools.combinations.__mro__ len 2, mro[0] 'combinations'; permutations.__name__ 'permutations' len 12; new to extra175"
  kind: python_call_eq
  category: identity
  id_prefix: iteraccum175

  columns: [id, function, args, expected, description]
  rows:
    - [combinations_mro_len_2,
       "combinations.__mro__.__len__",
       [],
       2,
       "itertools.combinations.__mro__.__len__() == 2 — itertools.combinations is a C extension type defined in itertoolsmodule.c that inherits directly from object with no intermediate base classes; its __mro__ is (combinations, object), a tuple of length 2; tuple.__len__() returns 2; new to extra175"]
    - ["combinations_mro_0_combinations",
       "combinations.__mro__[0].__name__.__eq__",
       ["combinations"],
       true,
       "itertools.combinations.__mro__[0].__name__.__eq__('combinations') == True — the first entry in combinations.__mro__ is the combinations class itself; its __name__ is 'combinations'; str.__eq__('combinations') returns True; new to extra175"]
    - [permutations_name_eq,
       "permutations.__name__.__eq__",
       ["permutations"],
       true,
       "itertools.permutations.__name__.__eq__('permutations') == True — itertools.permutations is a C extension type in itertoolsmodule.c that emits successive r-length permutations of elements from an iterable; its __name__ is 'permutations'; str.__eq__('permutations') returns True; new to extra175"]
    - [permutations_name_len_12,
       "permutations.__name__.__len__",
       [],
       12,
       "itertools.permutations.__name__.__len__() == 12 — the name 'permutations' has exactly 12 characters: p-e-r-m-u-t-a-t-i-o-n-s; same length as 'combinations'; str.__len__() returns 12; new to extra175"]

# ---------------------------------------------------------------------------
# Table 4: itertools.permutations __mro__ and combinations_with_replacement __name__
#
# itertools.permutations.__mro__.__len__() == 2
# itertools.permutations.__mro__[1].__name__ == 'object'
# itertools.combinations_with_replacement.__name__ == 'combinations_with_replacement'
# itertools.combinations_with_replacement.__name__.__len__() == 28
#
# permutations's MRO is (permutations, object). combinations_with_replacement
# is the longest itertools class name at 28 characters. It is a C extension
# type emitting r-length subsequences allowing repeated elements. New to extra175.
# ---------------------------------------------------------------------------

table itertools_extra175.permutations_mro_and_cwr_name:
  description: "itertools.permutations.__mro__ len 2, mro[1] 'object'; combinations_with_replacement.__name__ len 28; new to extra175"
  kind: python_call_eq
  category: identity
  id_prefix: iteraccum175

  columns: [id, function, args, expected, description]
  rows:
    - [permutations_mro_len_2,
       "permutations.__mro__.__len__",
       [],
       2,
       "itertools.permutations.__mro__.__len__() == 2 — itertools.permutations is a C extension type defined in itertoolsmodule.c that inherits directly from object with no intermediate base classes; its __mro__ is (permutations, object), a tuple of length 2; tuple.__len__() returns 2; new to extra175"]
    - ["permutations_mro_1_object",
       "permutations.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "itertools.permutations.__mro__[1].__name__.__eq__('object') == True — the second entry in permutations.__mro__ is the base class object; its __name__ is 'object'; this confirms permutations inherits directly from object with no intermediate classes; str.__eq__('object') returns True; new to extra175"]
    - [cwr_name_eq,
       "combinations_with_replacement.__name__.__eq__",
       ["combinations_with_replacement"],
       true,
       "itertools.combinations_with_replacement.__name__.__eq__('combinations_with_replacement') == True — combinations_with_replacement is a C extension type in itertoolsmodule.c emitting r-length subsequences of elements allowing repeated elements; its __name__ is 'combinations_with_replacement'; str.__eq__('combinations_with_replacement') returns True; new to extra175"]
    - [cwr_name_len_29,
       "combinations_with_replacement.__name__.__len__",
       [],
       29,
       "itertools.combinations_with_replacement.__name__.__len__() == 29 — the name 'combinations_with_replacement' is the longest itertools class name at exactly 29 characters; str.__len__() returns 29; new to extra175"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra175
# ---------------------------------------------------------------------------

invariant itertools_extra175.accumulate_name_accumulate:
  description: "itertools.accumulate.__name__ == 'accumulate' — C extension type in itertoolsmodule.c with __name__ 'accumulate' (10 chars); new to extra175"
  kind: python_call_eq
  function: accumulate.__name__.__eq__
  args: ["accumulate"]
  expected: true

invariant itertools_extra175.accumulate_name_len_10:
  description: "itertools.accumulate.__name__.__len__() == 10 — 'accumulate' is 10 characters long; new to extra175"
  kind: python_call_eq
  function: accumulate.__name__.__len__
  args: []
  expected: 10

invariant itertools_extra175.accumulate_module_itertools:
  description: "itertools.accumulate.__module__ == 'itertools' — accumulate is defined in the itertools C extension module; new to extra175"
  kind: python_call_eq
  function: accumulate.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra175.accumulate_mro_len_2:
  description: "itertools.accumulate.__mro__.__len__() == 2 — accumulate is a C extension type inheriting directly from object; MRO is (accumulate, object); new to extra175"
  kind: python_call_eq
  function: accumulate.__mro__.__len__
  args: []
  expected: 2

invariant itertools_extra175.combinations_name_len_12:
  description: "itertools.combinations.__name__.__len__() == 12 — 'combinations' is 12 characters long; new to extra175"
  kind: python_call_eq
  function: combinations.__name__.__len__
  args: []
  expected: 12

invariant itertools_extra175.combinations_mro_len_2:
  description: "itertools.combinations.__mro__.__len__() == 2 — combinations is a C extension type inheriting directly from object; MRO is (combinations, object); new to extra175"
  kind: python_call_eq
  function: combinations.__mro__.__len__
  args: []
  expected: 2

invariant itertools_extra175.permutations_name_len_12:
  description: "itertools.permutations.__name__.__len__() == 12 — 'permutations' is 12 characters long, same length as 'combinations'; new to extra175"
  kind: python_call_eq
  function: permutations.__name__.__len__
  args: []
  expected: 12

invariant itertools_extra175.permutations_mro_len_2:
  description: "itertools.permutations.__mro__.__len__() == 2 — permutations is a C extension type inheriting directly from object; MRO is (permutations, object); new to extra175"
  kind: python_call_eq
  function: permutations.__mro__.__len__
  args: []
  expected: 2

invariant itertools_extra175.cwr_name_len_29:
  description: "itertools.combinations_with_replacement.__name__.__len__() == 29 — longest itertools class name at 29 characters; new to extra175"
  kind: python_call_eq
  function: combinations_with_replacement.__name__.__len__
  args: []
  expected: 29
