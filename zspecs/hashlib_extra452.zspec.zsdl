spec: hashlib_extra452
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module identity and interface"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "hashlib.new and pbkdf2_hmac are pure-Python wrappers; their __name__ and __module__ are stable"
    - "algorithms_available and algorithms_guaranteed are frozenset/set depending on platform; __class__.__name__ is the portable check"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra452.function_names:
  description: "Identity checks on hashlib function __name__ attributes"
  kind: python_call_eq
  category: identity
  id_prefix: hln

  columns: [id, function, args, expected]
  rows:
    - [hln001, hashlib.new.__name__.__eq__,        ["new"],          true]
    - [hln002, hashlib.pbkdf2_hmac.__name__.__eq__, ["pbkdf2_hmac"], true]

table hashlib_extra452.function_modules:
  description: "Identity checks on hashlib function __module__ attributes"
  kind: python_call_eq
  category: identity
  id_prefix: hlm

  columns: [id, function, args, expected]
  rows:
    - [hlm001, hashlib.new.__module__.__eq__,        ["hashlib"], true]
    - [hlm002, hashlib.pbkdf2_hmac.__module__.__eq__, ["hashlib"], true]

table hashlib_extra452.algorithm_set_types:
  description: "algorithms_available and algorithms_guaranteed are set-like objects"
  kind: python_call_eq
  category: types
  id_prefix: hlt

  columns: [id, function, args, expected]
  rows:
    - [hlt001, hashlib.algorithms_available.__class__.__name__.__eq__,  ["set"], true]
    - [hlt002, hashlib.algorithms_guaranteed.__class__.__name__.__eq__, ["set"], true]

table hashlib_extra452.algorithm_membership:
  description: "Core algorithms are guaranteed to be present"
  kind: python_call_eq
  category: behavior
  id_prefix: hlg

  columns: [id, function, args, expected]
  rows:
    - [hlg001, hashlib.algorithms_guaranteed.__contains__, ["md5"],    true]
    - [hlg002, hashlib.algorithms_guaranteed.__contains__, ["sha1"],   true]
    - [hlg003, hashlib.algorithms_guaranteed.__contains__, ["sha256"], true]
    - [hlg004, hashlib.algorithms_guaranteed.__contains__, ["sha512"], true]
