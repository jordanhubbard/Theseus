spec: io_extra2641
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 io documentation — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bytesio.c"
    - "CPython source: Modules/_io/stringio.c"
    - "io_extra.zspec.zsdl — covers existing io invariants"
    - "io_extra2626.zspec.zsdl — covers __length_hint__/__missing__/__reversed__ dict-presence"
  notes:
    - "Wave 623 (io_extra2641) theme: __copy__, __deepcopy__, and __sizeof__ dict-presence checks."
    - "None of the io classes define __copy__ or __deepcopy__ in their own __dict__."
    - "__copy__ and __deepcopy__ are copy-protocol hooks; io stream classes do not implement custom copy semantics."
    - "io.BytesIO, io.BufferedReader, io.BufferedWriter, and io.BufferedRandom define __sizeof__ in their __dict__."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.StringIO, io.FileIO, and io.TextIOWrapper do NOT define __sizeof__ in their own __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __copy__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2641.no_copy_in_io_classes:
  description: "__copy__ is absent from all io class __dict__s — io stream classes do not implement the copy-protocol __copy__ hook"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2641

  columns: [id, function, args, expected]
  rows:
    - ["io2641001", "io.IOBase.__dict__.__contains__",         ["__copy__"], false]
    - ["io2641002", "io.RawIOBase.__dict__.__contains__",      ["__copy__"], false]
    - ["io2641003", "io.BufferedIOBase.__dict__.__contains__", ["__copy__"], false]
    - ["io2641004", "io.TextIOBase.__dict__.__contains__",     ["__copy__"], false]
    - ["io2641005", "io.BytesIO.__dict__.__contains__",        ["__copy__"], false]
    - ["io2641006", "io.StringIO.__dict__.__contains__",       ["__copy__"], false]

# ---------------------------------------------------------------------------
# __deepcopy__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2641.no_deepcopy_in_io_classes:
  description: "__deepcopy__ is absent from all io class __dict__s — io stream classes do not implement the copy-protocol __deepcopy__ hook"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2641

  columns: [id, function, args, expected]
  rows:
    - ["io2641007", "io.IOBase.__dict__.__contains__",          ["__deepcopy__"], false]
    - ["io2641008", "io.BytesIO.__dict__.__contains__",         ["__deepcopy__"], false]
    - ["io2641009", "io.StringIO.__dict__.__contains__",        ["__deepcopy__"], false]
    - ["io2641010", "io.FileIO.__dict__.__contains__",          ["__deepcopy__"], false]
    - ["io2641011", "io.BufferedReader.__dict__.__contains__",  ["__deepcopy__"], false]
    - ["io2641012", "io.BufferedWriter.__dict__.__contains__",  ["__deepcopy__"], false]

# ---------------------------------------------------------------------------
# __sizeof__ dict-presence — io concrete classes (selective presence)
# ---------------------------------------------------------------------------

table io_extra2641.sizeof_in_buffered_and_bytesio_only:
  description: "__sizeof__ is defined in io.BytesIO, io.BufferedReader, io.BufferedWriter, and io.BufferedRandom but absent from io.IOBase, io.TextIOBase, io.StringIO, io.FileIO, and io.TextIOWrapper"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2641

  columns: [id, function, args, expected]
  rows:
    - ["io2641013", "io.BytesIO.__dict__.__contains__",         ["__sizeof__"], true]
    - ["io2641014", "io.BufferedReader.__dict__.__contains__",  ["__sizeof__"], true]
    - ["io2641015", "io.BufferedWriter.__dict__.__contains__",  ["__sizeof__"], true]
    - ["io2641016", "io.BufferedRandom.__dict__.__contains__",  ["__sizeof__"], true]
    - ["io2641017", "io.IOBase.__dict__.__contains__",          ["__sizeof__"], false]
    - ["io2641018", "io.TextIOBase.__dict__.__contains__",      ["__sizeof__"], false]
    - ["io2641019", "io.StringIO.__dict__.__contains__",        ["__sizeof__"], false]
    - ["io2641020", "io.FileIO.__dict__.__contains__",          ["__sizeof__"], false]
    - ["io2641021", "io.TextIOWrapper.__dict__.__contains__",   ["__sizeof__"], false]

# ---------------------------------------------------------------------------
# Complementary: io stream classes have I/O methods but not copy-protocol hooks
# Confirms that io classes are sequential I/O objects, not copy-aware types
# ---------------------------------------------------------------------------

table io_extra2641.io_has_stream_methods_not_copy_hooks:
  description: "io.BytesIO defines read/write/getvalue/seek but NOT __copy__/__deepcopy__; io.StringIO similarly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2641

  columns: [id, function, args, expected]
  rows:
    - ["io2641022", "io.BytesIO.__dict__.__contains__",  ["read"],        true]
    - ["io2641023", "io.BytesIO.__dict__.__contains__",  ["write"],       true]
    - ["io2641024", "io.BytesIO.__dict__.__contains__",  ["getvalue"],    true]
    - ["io2641025", "io.BytesIO.__dict__.__contains__",  ["seek"],        true]
    - ["io2641026", "io.BytesIO.__dict__.__contains__",  ["__copy__"],    false]
    - ["io2641027", "io.BytesIO.__dict__.__contains__",  ["__deepcopy__"], false]
    - ["io2641028", "io.StringIO.__dict__.__contains__", ["read"],        true]
    - ["io2641029", "io.StringIO.__dict__.__contains__", ["write"],       true]
    - ["io2641030", "io.StringIO.__dict__.__contains__", ["getvalue"],    true]
    - ["io2641031", "io.StringIO.__dict__.__contains__", ["seek"],        true]
    - ["io2641032", "io.StringIO.__dict__.__contains__", ["__copy__"],    false]
    - ["io2641033", "io.StringIO.__dict__.__contains__", ["__deepcopy__"], false]
