spec: struct_extra1921
version: ">=3.9"
backend: python_module(struct)

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/struct.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 575 (_extra1921): __slots__ inheritance checks, __abstractmethods__ set membership, __subclasshook__ dict presence, __init_subclass__ dict presence."
    - "struct.Struct is a C extension type; its __dict__ does not contain __slots__, __abstractmethods__, __subclasshook__, or __init_subclass__."
    - "struct.error is an Exception subclass (bases: Exception); it does not define __slots__, __abstractmethods__, __subclasshook__, or __init_subclass__ in its own __dict__."
    - "struct.error.__dict__ contains __weakref__ (inherited from Exception machinery) but not __slots__."
    - "struct.error.__dict__ contains __doc__ but not __dict__ (exception classes do not need to redeclare __dict__ in their own class dict)."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

table struct_extra1921.slots_protocol:
  description: "struct types __slots__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1921

  columns: [id, function, args, expected]
  rows:
    - ["st1921001", "struct.Struct.__dict__.__contains__", ["__slots__"], false]
    - ["st1921002", "struct.error.__dict__.__contains__", ["__slots__"], false]
    - ["st1921003", "struct.Struct.__dict__.__contains__", ["__weakref__"], false]
    - ["st1921004", "struct.error.__dict__.__contains__", ["__weakref__"], true]
    - ["st1921005", "struct.Struct.__dict__.__contains__", ["__dict__"], false]
    - ["st1921006", "struct.error.__dict__.__contains__", ["__dict__"], false]
    - ["st1921007", "struct.Struct.__dict__.__contains__", ["__class_getitem__"], false]
    - ["st1921008", "struct.error.__dict__.__contains__", ["__class_getitem__"], false]

