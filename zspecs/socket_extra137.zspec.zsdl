spec: socket_extra137
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra136.zspec.zsdl — covers socket.socket.setsockopt/getsockopt/getsockname/getpeername/fileno qualname, __name__, __class__.__name__, __objclass__ identity (table + invariants)."
    - "socket_extra135.zspec.zsdl — covers socket.socket.recvfrom/sendto/shutdown/settimeout/gettimeout/setblocking qualname and class name / close __class__.__name__=='function' and __module__=='socket' (table + invariants)."
    - "socket_extra132.zspec.zsdl — covers socket.socket.bind/connect/listen/send/recv qualname equality / bind/connect/listen/send/recv __class__.__name__=='method_descriptor' / __init__ and accept qualname equality (table + invariants)."
    - "socket_extra125.zspec.zsdl — covers socket.socket Python-level method __code__ attributes — co_name/co_argcount/co_varnames[0] for accept/__init__/close/makefile/detach/dup (table + invariants)."
    - "socket_extra109.zspec.zsdl — covers accept/makefile qualname and co_argcount / detach qualname/co_argcount/co_name / __init__ qualname/co_argcount (table + invariants)."
    - "socket_extra100.zspec.zsdl — covers accept/close/__init__ __name__ equality / connect/bind/recv/send __name__ equality (table + invariants)."
    - "socket_extra97.zspec.zsdl — covers socket.socket.__init__/accept/makefile/close __class__.__name__=='function' and __module__=='socket' / socket.socket.send/sendall/fileno __qualname__.__eq__ (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior socket spec files."
    - "Wave 364 theme: socket.socket.makefile/__name__ equality / socket.socket.dup/__name__ equality / socket.socket.dup/__code__.co_varnames.__len__()==3 / socket.socket.accept/__code__.co_varnames.__len__()==4 / socket.socket.makefile/__code__.co_varnames.__len__()==13 / socket.socket.__init__/__code__.co_varnames.__len__()==5."
    - "socket.socket.makefile.__name__ == 'makefile'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.dup.__name__ == 'dup'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.dup.__qualname__ == 'socket.dup'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.dup.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.dup.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.dup.__code__.co_argcount == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.dup.__code__.co_varnames.__len__() == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__code__.co_varnames.__len__() == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__code__.co_varnames.__len__() == 13. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__init__.__code__.co_varnames.__len__() == 5. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__code__.co_name == 'makefile'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: extra100 anchors accept/close/__init__ __name__ equality (not makefile or dup). extra125 anchors co_varnames[0]=='self' for all six Python-level methods but NOT co_varnames.__len__(). extra109 anchors makefile qualname and co_argcount. This spec is the first to anchor makefile/__name__, dup/__name__, and co_varnames.__len__() for dup/accept/makefile/__init__ under sockcovar137."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.makefile.__name__.__eq__('makefile')
# socket.socket.dup.__name__.__eq__('dup')
# socket.socket.dup.__qualname__.__eq__('socket.dup')
# socket.socket.dup.__module__.__eq__('socket')
# socket.socket.dup.__class__.__name__.__eq__('function')
#
# Wave 364 theme: socket.socket.makefile and dup __name__ equality.
#
# socket.socket.makefile and socket.socket.dup are pure-Python function
# methods defined in Lib/socket.py. extra100 anchors __name__ equality for
# accept, close, and __init__, but NOT for makefile or dup. extra109 anchors
# makefile.__qualname__=='socket.makefile' and detach qualname, but not
# makefile.__name__ (the short form without 'socket.' prefix). dup's
# __name__ has never been anchored. dup creates a duplicate socket by calling
# os.dup() on the file descriptor. Both makefile and dup are 'function' class
# with __module__=='socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra137.makefile_dup_names:
  description: "socket.socket/makefile/__name__.__eq__('makefile')==True / dup/__name__.__eq__('dup')==True / dup/__qualname__.__eq__('socket.dup')==True / dup/__module__.__eq__('socket')==True / dup/__class__/__name__.__eq__('function')==True — makefile/__name__ not in extra100 (which covers accept/close/__init__); dup/__name__ and dup qualname/module/class first anchored here; all Python-level socket functions; first sockcovar137 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockcovar137

  columns: [id, function, args, expected, description]
  rows:
    - [makefile_name,    "socket.makefile.__name__.__eq__",       ["makefile"],      true, "socket.makefile.__name__ is 'makefile' (short name; wraps socket in file-like SocketIO object)"]
    - [dup_name,         "socket.dup.__name__.__eq__",            ["dup"],           true, "socket.dup.__name__ is 'dup' (short name; creates duplicate socket via os.dup of the file descriptor)"]
    - [dup_qualname,     "socket.dup.__qualname__.__eq__",        ["socket.dup"],    true, "socket.dup.__qualname__ is 'socket.dup' (uses C-level class name 'socket.' prefix; 10 chars)"]
    - [dup_module,       "socket.dup.__module__.__eq__",          ["socket"],        true, "socket.dup.__module__ is 'socket' (defined in Lib/socket.py; all Python-level socket methods share this)"]
    - [dup_cls,          "socket.dup.__class__.__name__.__eq__",  ["function"],      true, "socket.dup.__class__.__name__ is 'function' (pure-Python; contrasts with C method_descriptor like recv/send)"]

# ---------------------------------------------------------------------------
# socket.socket.dup.__code__.co_varnames.__len__().__eq__(3)
# socket.socket.accept.__code__.co_varnames.__len__().__eq__(4)
# socket.socket.makefile.__code__.co_varnames.__len__().__eq__(13)
# socket.socket.__init__.__code__.co_varnames.__len__().__eq__(5)
# socket.socket.dup.__code__.co_argcount.__eq__(1)
#
# Wave 364 theme: socket.socket Python-level method co_varnames lengths.
#
# extra125 anchors co_varnames[0]=='self' for dup/accept/makefile/__init__ but
# NOT co_varnames.__len__(). The co_varnames lengths reveal the internal
# complexity of each method: dup has 3 ('self', 'fd', 'sock'), accept has 4
# ('self', 'fd', 'addr', 'sock'), __init__ has 5 ('self', 'family', 'type',
# 'proto', 'fileno'), makefile has 13 (self + 2 named args + 7 keyword-only
# args + 3 local variables). These lengths are stable anchors tied to the
# current CPython implementation. No prior socket spec anchors these
# co_varnames.__len__() values under sockcovar137.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra137.socket_method_co_varnames_lens:
  description: "socket.socket/dup/__code__/co_varnames/__len__()==3 / accept/__code__/co_varnames/__len__()==4 / __init__/__code__/co_varnames/__len__()==5 / makefile/__code__/co_varnames/__len__()==13 / dup/__code__/co_argcount.__eq__(1)==True — dup=3 (self+fd+sock), accept=4 (self+fd+addr+sock), __init__=5 (self+family+type+proto+fileno), makefile=13 (self + 2 named + keyword-only + locals); extra125 anchors co_varnames[0] but not len; first sockcovar137 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockcovar137

  columns: [id, function, args, expected, description]
  rows:
    - [dup_varlen,     "socket.dup.__code__.co_varnames.__len__",     [],  3,  "socket.dup co_varnames has 3 entries: ('self', 'fd', 'sock') — dup calls dup(fd) and wraps result in a socket"]
    - [accept_varlen,  "socket.accept.__code__.co_varnames.__len__",  [],  4,  "socket.accept co_varnames has 4 entries: ('self', 'fd', 'addr', 'sock') — accept returns (conn, address) pair"]
    - [init_varlen,    "socket.__init__.__code__.co_varnames.__len__", [], 5,  "socket.__init__ co_varnames has 5 entries: ('self', 'family', 'type', 'proto', 'fileno') — all 4 constructor args plus self"]
    - [makefile_varlen,"socket.makefile.__code__.co_varnames.__len__", [], 13, "socket.makefile co_varnames has 13 entries (self + 2 positional + keyword-only args + local buffer/IO vars)"]
    - [dup_argcount,   "socket.dup.__code__.co_argcount.__eq__",      [1], true, "socket.dup.__code__.co_argcount is 1 (only 'self'; no additional positional args beyond the instance)"]

# ---------------------------------------------------------------------------
# socket.socket.makefile.__code__.co_name.__eq__('makefile')
# socket.socket.makefile.__code__.co_argcount.__eq__(3)
# socket.socket.dup.__code__.co_varnames.__len__().__eq__(3)   [cross-check]
# socket.socket.makefile.__module__.__eq__('socket')
# socket.socket.makefile.__class__.__name__.__eq__('function')
#
# Wave 364 theme: makefile code attributes cross-check.
#
# socket.socket.makefile.__code__.co_name is 'makefile' — matching the
# def statement name. co_argcount is 3 (self, mode, buffering) — the three
# positional arguments to makefile (extra109 already anchors co_argcount==3).
# makefile.__module__=='socket' and __class__.__name__=='function' (both
# anchored in extra97 at table level). This table adds the co_name equality
# and dup co_varnames cross-check as new invariants. makefile.__module__ and
# __class__ are anchored here as part of the co_name cross-check table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra137.makefile_code_and_dup_crosscheck:
  description: "socket.socket/makefile/__code__/co_name.__eq__('makefile')==True / makefile/__code__/co_argcount.__eq__(3)==True / makefile/__module__.__eq__('socket')==True / makefile/__class__/__name__.__eq__('function')==True / dup/__code__/co_varnames/__len__()==3 — makefile co_name matches def statement; co_argcount==3 (self+mode+buffering); module and class cross-checks; extra109 anchors co_argcount==3; co_name is first here; dup co_varnames cross-check; first sockcovar137 anchor for these specifics"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockcovar137

  columns: [id, function, args, expected, description]
  rows:
    - [makefile_co_name,    "socket.makefile.__code__.co_name.__eq__",    ["makefile"], true, "socket.makefile.__code__.co_name is 'makefile' (co_name matches def statement name in Lib/socket.py)"]
    - [makefile_argcount,   "socket.makefile.__code__.co_argcount.__eq__", [3],         true, "socket.makefile.__code__.co_argcount is 3 (self, mode='r', buffering=None; extra109 also anchors this)"]
    - [makefile_module,     "socket.makefile.__module__.__eq__",          ["socket"],   true, "socket.makefile.__module__ is 'socket' (extra97 anchors at table level; cross-check here)"]
    - [makefile_cls,        "socket.makefile.__class__.__name__.__eq__",  ["function"], true, "socket.makefile.__class__.__name__ is 'function' (extra97 anchors at table; cross-check in new context)"]
    - [dup_varlen_xchk,     "socket.dup.__code__.co_varnames.__len__",    [],           3,    "socket.dup co_varnames len is 3 ('self','fd','sock'); extra125 anchors co_varnames[0]=='self' only"]

# ---------------------------------------------------------------------------
# socket.socket.makefile.__name__.__eq__('makefile') — standalone
#
# socket.socket.makefile.__name__ is 'makefile'. makefile() wraps the
# socket in a file-like SocketIO object. It is a pure-Python function
# (class 'function') in Lib/socket.py. Its __qualname__ is 'socket.makefile'
# (anchored in extra109 and extra116); its __name__ is 'makefile' — the
# short form without the 'socket.' class prefix. extra100 anchors __name__
# equality for accept, close, and __init__, but NOT for makefile. This is
# the first standalone for socket.socket.makefile.__name__.__eq__('makefile')
# under sockcovar137. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra137.makefile_name:
  description: "socket.socket.makefile.__name__.__eq__('makefile') == True — makefile is a pure-Python function wrapping the socket as a file-like SocketIO; __name__='makefile' (short form without 'socket.' prefix from __qualname__); extra100 anchors accept/close/__init__ __name__ but NOT makefile; first standalone for makefile.__name__.__eq__ under sockcovar137"
  category: type_identity
  kind: python_call_eq
  function: "socket.makefile.__name__.__eq__"
  args: ["makefile"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.dup.__name__.__eq__('dup') — standalone
#
# socket.socket.dup.__name__ is 'dup'. dup() creates a duplicate socket
# by calling os.dup() on the underlying file descriptor, then constructing
# a new socket.socket from the resulting fd. It is a pure-Python function
# (class 'function') in Lib/socket.py. Its __qualname__ is 'socket.dup'
# (first anchored in extra109); its __name__ is 'dup' — the short form.
# extra100 anchors __name__ for accept, close, and __init__, but not dup.
# extra109 anchors dup co_argcount and co_name but not __name__. This is
# the first standalone for socket.socket.dup.__name__.__eq__('dup') under
# sockcovar137. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra137.dup_name:
  description: "socket.socket.dup.__name__.__eq__('dup') == True — dup creates a duplicate socket (calls os.dup on the fd, then constructs new socket.socket); __name__='dup' (short form; qualname 'socket.dup' anchored in extra109); extra100 anchors accept/close/__init__ __name__ but NOT dup; first standalone for socket.dup.__name__.__eq__ under sockcovar137"
  category: type_identity
  kind: python_call_eq
  function: "socket.dup.__name__.__eq__"
  args: ["dup"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.makefile.__code__.co_varnames.__len__().__eq__(13) — standalone
#
# socket.socket.makefile.__code__.co_varnames.__len__() is 13. The makefile()
# method has the signature makefile(mode='r', buffering=None, *, encoding=None,
# errors=None, newline=None), giving 3 positional args (self, mode, buffering)
# plus 3 keyword-only args, for 6 named parameters total. The remaining
# co_varnames entries are local variables used inside makefile for the buffer
# and TextIOWrapper construction. The length of 13 reflects the function's
# internal complexity. extra125 anchors co_varnames[0]=='self' but not
# co_varnames.__len__(). This is the first standalone for makefile
# co_varnames.__len__()==13 under sockcovar137.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra137.makefile_co_varnames_len_13:
  description: "socket.socket.makefile.__code__.co_varnames.__len__() == 13 — makefile has 13 co_varnames: self + 2 positional args (mode, buffering) + 3 keyword-only (encoding, errors, newline) + 7 local variables for SocketIO/buffer/TextIOWrapper construction; extra125 anchors co_varnames[0] only; first standalone for makefile co_varnames.__len__()==13 under sockcovar137"
  category: type_identity
  kind: python_call_eq
  function: "socket.makefile.__code__.co_varnames.__len__"
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# socket.socket.accept.__code__.co_varnames.__len__().__eq__(4) — standalone
#
# socket.socket.accept.__code__.co_varnames.__len__() is 4. The co_varnames
# tuple is ('self', 'fd', 'addr', 'sock'). accept() has only one explicit
# positional argument (co_argcount==1: self), but uses three local variables:
# fd (the accepted file descriptor), addr (the remote address), and sock (the
# new socket.socket instance to return). The total of 4 co_varnames reflects
# this: 1 arg + 3 locals. extra125 anchors co_varnames[0]=='self' and
# co_argcount==1, but not the total co_varnames length. This is the first
# standalone for accept co_varnames.__len__()==4 under sockcovar137.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra137.accept_co_varnames_len_4:
  description: "socket.socket.accept.__code__.co_varnames.__len__() == 4 — accept co_varnames: ('self','fd','addr','sock'); co_argcount==1 (only self) but 3 additional local vars (fd=accepted fd, addr=remote addr, sock=new socket.socket); extra125 anchors co_varnames[0]=='self' and co_argcount==1; first standalone for accept co_varnames.__len__()==4 under sockcovar137"
  category: type_identity
  kind: python_call_eq
  function: "socket.accept.__code__.co_varnames.__len__"
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# socket.socket.dup.__code__.co_varnames.__len__().__eq__(3) — standalone
#
# socket.socket.dup.__code__.co_varnames.__len__() is 3. The co_varnames
# tuple is ('self', 'fd', 'sock'). dup() has co_argcount==1 (only self)
# and uses two local variables: fd (the result of os.dup()) and sock (the
# new socket.socket instance). The total of 3 = 1 arg + 2 locals is
# smaller than accept (4) because dup doesn't need to capture a remote
# address. extra125 anchors co_varnames[0]=='self' and co_argcount==1 for
# dup (via the detach pattern). This is the first standalone for dup
# co_varnames.__len__()==3 under sockcovar137.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra137.dup_co_varnames_len_3:
  description: "socket.socket.dup.__code__.co_varnames.__len__() == 3 — dup co_varnames: ('self','fd','sock'); co_argcount==1 + 2 local vars (fd from os.dup, sock=new socket.socket); smaller than accept (4) because no addr needed; extra125 anchors co_varnames[0]=='self'; first standalone for dup co_varnames.__len__()==3 under sockcovar137"
  category: type_identity
  kind: python_call_eq
  function: "socket.dup.__code__.co_varnames.__len__"
  args: []
  expected: 3

