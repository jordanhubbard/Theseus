spec: shlex_rust
version: ">=3.9"
backend: rust_module(shlex_rust)

docs: https://docs.python.org/3/library/shlex.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shlex.html — Python shlex documentation (API surface)"
    - "POSIX shell quoting rules"
  not_derived_from:
    - "CPython source: Lib/shlex.py"
  notes:
    - "Clean-room Rust reimplementation of Python shlex module API, exposed via PyO3."
    - "May use the 'shlex' Rust crate (independent POSIX shell lexer implementation)."
    - "split(s: str) -> list[str] — tokenize shell string in POSIX mode; strips quotes."
    - "quote(s: str) -> str — return shell-safe representation; wraps unsafe tokens in single quotes."
    - "join(tokens: list[str]) -> str — quote each token and join with spaces."
    - "split('') returns [] (empty input yields no tokens)."
    - "split with unclosed quotes raises ValueError."
    - "All test vectors verified against Python 3.14.3."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# split — tokenize shell string
table shlex_rust.split.basic:
  kind: python_call_eq
  category: split
  id_prefix: split
  function: split

  columns: [id, args, expected]
  rows:
    - [simple_two_words,       ["hello world"],          ["hello", "world"]]
    - [double_quoted_phrase,   ["\"hello world\""],       ["hello world"]]
    - [single_quoted_phrase,   ["echo 'foo bar'"],        ["echo", "foo bar"]]
    - [empty_string,           [""],                      []]
    - [leading_trailing_space, ["  spaces  "],            ["spaces"]]
    - [equals_sign,            ["a=b"],                   ["a=b"]]
    - [four_words,             ["a b c d"],               ["a", "b", "c", "d"]]
    - [single_word,            ["hello"],                 ["hello"]]
    - [two_quoted_args,        ["echo 'hello' 'world'"],  ["echo", "hello", "world"]]

# quote — shell-escape a single string
table shlex_rust.quote.basic:
  kind: python_call_eq
  category: quote
  id_prefix: quote
  function: quote

  columns: [id, args, expected]
  rows:
    - [safe_word,         ["hello"],       "hello"]
    - [safe_alphanumeric, ["safe123"],     "safe123"]
    - [with_space,        ["hello world"], "'hello world'"]
    - [empty_string,      [""],            "''"]
    - [dollar_sign,       ["foo$bar"],     "'foo$bar'"]

# join — quote and join list of tokens
table shlex_rust.join.basic:
  kind: python_call_eq
  category: join
  id_prefix: join
  function: join

  columns: [id, args, expected]
  rows:
    - [two_safe_tokens,  [["echo", "hello"]],         "echo hello"]
    - [token_with_space, [["echo", "hello world"]],   "echo 'hello world'"]
    - [empty_list,       [[]],                         ""]
    - [single_token,     [["hello"]],                  "hello"]

# error cases
invariant shlex_rust.split.unclosed_double_quote:
  description: "split('unclosed \"quote') raises ValueError — no closing quotation"
  category: error
  kind: python_call_raises
  function: split
  args: ["unclosed \"quote"]
  expected_exception: ValueError

invariant shlex_rust.split.unclosed_single_quote:
  description: "split(\"it's a test\") raises ValueError — unmatched single quote in POSIX mode"
  category: error
  kind: python_call_raises
  function: split
  args: ["it's a test"]
  expected_exception: ValueError

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-19T20:09:59Z
  iterations: 1
  pass_count: 20
  fail_count: 0
  total_invariants: 20
  notes: Synthesis succeeded in 1 iteration(s). 20 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
