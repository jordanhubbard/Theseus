spec: fractions_extra11
version: ">=3.9"
backend: python_module(fractions)

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html — Python fractions documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fractions.py"
  notes:
    - "This spec extends fractions.zspec.zsdl and prior extras (fractions_extra through fractions_extra10)."
    - "fractions_extra4 covers Fraction(1,3) numerator/denominator; fractions_extra8 covers Fraction(1,2)."
    - "fractions_extra3 covers Fraction('3/5'); fractions_extra7 covers Fraction('3/7')."
    - "fractions_extra10 covers Fraction(2,5) coprime and Fraction('7/8')."
    - "No prior spec covers Fraction(2,4) where 2/4 auto-reduces to 1/2: numerator==1, denominator==2."
    - "No prior spec covers Fraction(3,1).__eq__(3) == True (integer equality check)."
    - "No prior spec covers Fraction('3/4') numerator==3 and denominator==4."
    - "No prior spec covers Fraction.__name__ == 'Fraction' as a standalone invariant."
    - "No prior spec covers Fraction.__module__ == 'fractions' as a standalone invariant."
    - "No prior spec covers Fraction(1,3).__class__.__name__ == 'Fraction'."
    - "No prior spec covers Fraction(0.5).numerator == 1 (float constructor)."
    - "No prior spec covers Fraction(0.25).numerator == 1, denominator == 4 (float constructor)."
    - "No prior spec covers Fraction(1,3).limit_denominator(5) as a string representation check."
    - "Fraction(2,4).numerator == 1 — auto-reduction: 2/4 reduces to 1/2, so numerator is 1."
    - "Fraction(2,4).denominator == 2 — auto-reduction: 2/4 reduces to 1/2, so denominator is 2."
    - "Fraction(3,1).__eq__(3) == True — a whole-number fraction equals its integer value."
    - "Fraction('3/4').numerator == 3 — string constructor, no reduction needed."
    - "Fraction('3/4').denominator == 4 — string constructor, no reduction needed."
    - "Fraction.__name__ == 'Fraction' — class name attribute."
    - "Fraction.__module__ == 'fractions' — class module attribute."
    - "Fraction(1,3).__class__.__name__ == 'Fraction' — instance class identity."
    - "Fraction(0.5).numerator == 1 — float 0.5 == 1/2 exactly, auto-constructed."
    - "Fraction(0.5).denominator == 2 — float 0.5 == 1/2 exactly, auto-constructed."
    - "Fraction(0.25).numerator == 1 — float 0.25 == 1/4 exactly, auto-constructed."
    - "Fraction(0.25).denominator == 4 — float 0.25 == 1/4 exactly, auto-constructed."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Fraction(2, 4) — auto-reduction to 1/2
#
# fractions_extra8 covers Fraction(1,2) numerator==1 and denominator==2
# (direct construction). No prior spec covers Fraction(2, 4) where the
# constructor auto-reduces 2/4 to 1/2 before storing. The result is the same
# fraction but tests that the GCD-based reduction is triggered.
# ---------------------------------------------------------------------------

invariant fractions_extra11.Fraction.two_fourths_numerator:
  description: "Fraction(2,4).numerator == 1 — 2/4 auto-reduces to 1/2, numerator is 1"
  category: reduction
  kind: python_call_eq
  function: Fraction
  args: [2, 4]
  method: numerator
  expected: 1

invariant fractions_extra11.Fraction.two_fourths_denominator:
  description: "Fraction(2,4).denominator == 2 — 2/4 auto-reduces to 1/2, denominator is 2"
  category: reduction
  kind: python_call_eq
  function: Fraction
  args: [2, 4]
  method: denominator
  expected: 2

# ---------------------------------------------------------------------------
# Fraction(3, 1) == 3 — integer equality via __eq__
#
# A Fraction with denominator 1 equals the corresponding integer. No prior
# spec covers __eq__ comparison of a Fraction against an integer.
# Fraction(3, 1).__eq__(3) returns True because Python compares across types.
# ---------------------------------------------------------------------------

invariant fractions_extra11.Fraction.whole_number_eq_int:
  description: "Fraction(3,1).__eq__(3) == True — whole-number fraction equals its integer value"
  category: comparison
  kind: python_call_eq
  function: Fraction
  args: [3, 1]
  method: __eq__
  method_args: [3]
  expected: true

# ---------------------------------------------------------------------------
# Fraction('3/4') — string constructor with new vector
#
# fractions_extra3 covers Fraction('3/5'); fractions_extra7 covers Fraction('3/7');
# fractions_extra10 covers Fraction('7/8'). No prior spec covers Fraction('3/4')
# which has both numerator==3 and denominator==4 (no reduction needed).
# ---------------------------------------------------------------------------

invariant fractions_extra11.Fraction.string_three_quarters_numerator:
  description: "Fraction('3/4').numerator == 3 — string constructor, no reduction"
  category: properties
  kind: python_call_eq
  function: Fraction
  args: ["3/4"]
  method: numerator
  expected: 3

invariant fractions_extra11.Fraction.string_three_quarters_denominator:
  description: "Fraction('3/4').denominator == 4 — string constructor, no reduction"
  category: properties
  kind: python_call_eq
  function: Fraction
  args: ["3/4"]
  method: denominator
  expected: 4

# ---------------------------------------------------------------------------
# Fraction.__name__ and Fraction.__module__ — class-level identity attributes
#
# fractions_extra10 covers dunder method names (__sub__, etc.) via
# Fraction.__sub__.__name__. No prior spec checks the class's own __name__
# or __module__ as standalone invariants.
# ---------------------------------------------------------------------------

invariant fractions_extra11.Fraction.class_name:
  description: "Fraction.__name__ == 'Fraction' — class name attribute"
  category: class_identity
  kind: python_call_eq
  function: Fraction.__name__.__eq__
  args: ["Fraction"]
  expected: true

invariant fractions_extra11.Fraction.class_module:
  description: "Fraction.__module__ == 'fractions' — class module attribute"
  category: class_identity
  kind: python_call_eq
  function: Fraction.__module__.__eq__
  args: ["fractions"]
  expected: true

# ---------------------------------------------------------------------------
# Fraction(1, 3).__class__.__name__ — instance class identity
#
# No prior spec checks the __class__.__name__ on a Fraction instance.
# Fraction(1, 3).__class__.__name__ == 'Fraction' confirms the runtime type.
# ---------------------------------------------------------------------------

invariant fractions_extra11.Fraction.instance_class_name:
  description: "Fraction(1,3).__class__.__name__ == 'Fraction' — instance type identity"
  category: class_identity
  kind: python_call_eq
  function: Fraction
  args: [1, 3]
  method: __class__
  method_chain: __name__
  expected: "Fraction"

# ---------------------------------------------------------------------------
# Fraction(0.5) and Fraction(0.25) — float constructor
#
# No prior spec covers constructing a Fraction from a float. 0.5 is exactly
# representable as a float (1/2) and 0.25 is exactly representable as a float
# (1/4). The constructor converts via the exact binary fraction.
# ---------------------------------------------------------------------------

invariant fractions_extra11.Fraction.float_half_numerator:
  description: "Fraction(0.5).numerator == 1 — float 0.5 == 1/2 exactly"
  category: construction
  kind: python_call_eq
  function: Fraction
  args: [0.5]
  method: numerator
  expected: 1

invariant fractions_extra11.Fraction.float_half_denominator:
  description: "Fraction(0.5).denominator == 2 — float 0.5 == 1/2 exactly"
  category: construction
  kind: python_call_eq
  function: Fraction
  args: [0.5]
  method: denominator
  expected: 2

invariant fractions_extra11.Fraction.float_quarter_numerator:
  description: "Fraction(0.25).numerator == 1 — float 0.25 == 1/4 exactly"
  category: construction
  kind: python_call_eq
  function: Fraction
  args: [0.25]
  method: numerator
  expected: 1

invariant fractions_extra11.Fraction.float_quarter_denominator:
  description: "Fraction(0.25).denominator == 4 — float 0.25 == 1/4 exactly"
  category: construction
  kind: python_call_eq
  function: Fraction
  args: [0.25]
  method: denominator
  expected: 4
