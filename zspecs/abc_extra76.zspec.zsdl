    - [uam_qualname_len,      update_abstractmethods.__qualname__.__len__,    [],                         22,   "update_abstractmethods.__qualname__.__len__() == 22 — len('update_abstractmethods') == 22; verified with Python 3.14.3"]
    - [absprop_qualname_len,  abstractproperty.__qualname__.__len__,          [],                         16,   "abstractproperty.__qualname__.__len__() == 16 — len('abstractproperty') == 16; verified with Python 3.14.3"]
