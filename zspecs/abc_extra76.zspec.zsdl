invariant abc_extra76.get_cache_token_class_name:
  description: "abc.get_cache_token.__class__.__name__.__eq__('builtin_function_or_method') returns True — get_cache_token is implemented in the _abc C extension module; NEW in extra76: first standalone __class__.__name__ invariant for get_cache_token in abcextra76 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: get_cache_token.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant abc_extra76.update_abstractmethods_qualname_len:
  description: "abc.update_abstractmethods.__qualname__.__len__() == 22 — len('update_abstractmethods') == 22; update_abstractmethods is a module-level function in abc.py; NEW in extra76: first standalone __qualname__.__len__ invariant for update_abstractmethods in abcextra76 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: update_abstractmethods.__qualname__.__len__
  args: []
  expected: 22

invariant abc_extra76.ABCMeta_new_co_varnames_len:
  description: "abc.ABCMeta.__new__.__code__.co_varnames.__len__() == 6 — co_varnames are (mcls, name, bases, namespace, kwargs, cls); ABCMeta.__new__ is a Python function that initializes the metaclass with six local variables; NEW in extra76: first standalone co_varnames.__len__ invariant for ABCMeta.__new__ in abcextra76 namespace; wave 245; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: ABCMeta.__new__.__code__.co_varnames.__len__
  args: []
  expected: 6

invariant abc_extra76.ABCMeta_dump_registry_co_varnames_len:
  description: "abc.ABCMeta._dump_registry.__code__.co_varnames.__len__() == 6 — co_varnames are (cls, file, _abc_registry, _abc_cache, _abc_negative_cache, _abc_negative_cache_version); _dump_registry has six locals; NEW in extra76: first standalone co_varnames.__len__ invariant for ABCMeta._dump_registry in abcextra76 namespace; wave 245; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: ABCMeta._dump_registry.__code__.co_varnames.__len__
  args: []
  expected: 6

invariant abc_extra76.abstractstaticmethod_qualname_len:
  description: "abc.abstractstaticmethod.__qualname__.__len__() == 20 — len('abstractstaticmethod') == 20; abstractstaticmethod is a deprecated but still-present class in abc; NEW in extra76: first standalone __qualname__.__len__ invariant for abstractstaticmethod in abcextra76 namespace; wave 245; verified with Python 3.14.3"
  category: identity
