spec: abc_extra76
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra75.zspec.zsdl."
    - "This spec covers: wave 245 theme — abc get_cache_token and update_abstractmethods code attributes + ABCMeta.__new__ co_varnames. NEW in extra76: get_cache_token.__class__.__name__=='builtin_function_or_method' (C builtin in _abc extension); get_cache_token.__doc__.__class__.__name__=='str'; update_abstractmethods.__doc__.__class__.__name__=='str'; update_abstractmethods.__qualname__=='update_abstractmethods'; update_abstractmethods.__qualname__.__len__()==22 (len('update_abstractmethods')==22); update_abstractmethods.__module__=='abc'; ABCMeta.__new__.__code__.co_varnames.__len__()==6 (mcls, name, bases, namespace, kwargs, cls); ABCMeta.__instancecheck__.__code__.co_varnames.__len__()==2 (cls, instance); ABCMeta.__subclasscheck__.__code__.co_varnames.__len__()==2 (cls, subclass); ABCMeta.register.__code__.co_varnames.__len__()==2 (cls, subclass); ABCMeta._dump_registry.__code__.co_varnames.__len__()==6 (cls, file, _abc_registry, _abc_cache, _abc_negative_cache, _abc_negative_cache_version); abstractproperty.__qualname__.__len__()==16; abstractclassmethod.__qualname__.__len__()==19; abstractstaticmethod.__qualname__.__len__()==20. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method'. get_cache_token is implemented in the _abc C extension. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.get_cache_token.__doc__.__class__.__name__ == 'str'. The docstring is a plain str. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__doc__.__class__.__name__ == 'str'. The docstring is a plain str. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__qualname__ == 'update_abstractmethods'. Simple top-level function qualname. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__qualname__.__len__() == 22. len('update_abstractmethods') == 22. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__module__ == 'abc'. update_abstractmethods is defined in abc.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__new__.__code__.co_varnames.__len__() == 6. co_varnames are (mcls, name, bases, namespace, kwargs, cls). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__instancecheck__.__code__.co_varnames.__len__() == 2. co_varnames are (cls, instance). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__subclasscheck__.__code__.co_varnames.__len__() == 2. co_varnames are (cls, subclass). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.register.__code__.co_varnames.__len__() == 2. co_varnames are (cls, subclass). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta._dump_registry.__code__.co_varnames.__len__() == 6. co_varnames are (cls, file, _abc_registry, _abc_cache, _abc_negative_cache, _abc_negative_cache_version). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractproperty.__qualname__.__len__() == 16. len('abstractproperty') == 16. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractclassmethod.__qualname__.__len__() == 19. len('abstractclassmethod') == 19. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractstaticmethod.__qualname__.__len__() == 20. len('abstractstaticmethod') == 20. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc get_cache_token identity and docstring class names — extra76
#
# Wave 245 theme: get_cache_token and update_abstractmethods code attributes +
# ABCMeta.__new__ co_varnames.
#
# get_cache_token.__class__.__name__ == 'builtin_function_or_method'
# get_cache_token.__doc__.__class__.__name__ == 'str'
# update_abstractmethods.__doc__.__class__.__name__ == 'str'
# update_abstractmethods.__module__ == 'abc'
# ---------------------------------------------------------------------------

table abc_extra76.get_cache_token_and_update_abstractmethods_doc_checks:
  description: "abc get_cache_token identity and docstring class name checks plus update_abstractmethods module check in abcextra76 namespace — wave 245 theme: get_cache_token/update_abstractmethods attributes; get_cache_token.__class__.__name__=='builtin_function_or_method' (C builtin in _abc extension); get_cache_token.__doc__.__class__.__name__=='str' (docstring is plain str); update_abstractmethods.__doc__.__class__.__name__=='str'; update_abstractmethods.__module__=='abc'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcextra76

  columns: [id, function, args, expected, description]
  rows:
    - [gct_class_name,     get_cache_token.__class__.__name__.__eq__,          ["builtin_function_or_method"], true, "get_cache_token.__class__.__name__ == 'builtin_function_or_method' — C builtin in _abc extension; verified with Python 3.14.3"]
    - [gct_doc_class_name, get_cache_token.__doc__.__class__.__name__.__eq__,  ["str"],                        true, "get_cache_token.__doc__.__class__.__name__ == 'str' — docstring is a plain str; verified with Python 3.14.3"]
    - [uam_doc_class_name, update_abstractmethods.__doc__.__class__.__name__.__eq__, ["str"],                  true, "update_abstractmethods.__doc__.__class__.__name__ == 'str' — docstring is a plain str; verified with Python 3.14.3"]
    - [uam_module,         update_abstractmethods.__module__.__eq__,           ["abc"],                        true, "update_abstractmethods.__module__ == 'abc' — defined in abc.py; verified with Python 3.14.3"]

