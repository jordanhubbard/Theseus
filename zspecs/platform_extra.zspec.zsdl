spec: platform_extra
version: ">=3.9"
backend: python_module(platform)

docs: https://docs.python.org/3/library/platform.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/platform.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/platform.py"
  notes:
    - "This spec extends platform.zspec.zsdl with aspects not covered there."
    - "platform.release(), platform.version(), platform.machine(), and platform.processor() all return str."
    - "platform.uname() returns a platform.uname_result named-tuple; the type name is 'uname_result'."
    - "platform.python_implementation() returns a str naming the implementation (e.g. 'CPython')."
    - "platform.system() returns a str such as 'Darwin', 'Linux', 'Windows'."
    - "platform.python_build() returns a 2-tuple (buildno, builddate) of strings."
    - "platform.architecture() is a function; architecture.__name__ == 'architecture'."
    - "All return types verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name checks — attributes not covered in platform.zspec.zsdl
# ---------------------------------------------------------------------------

table platform_extra.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, description, function, args, expected]
  rows:
    - [release,       "release.__name__ == 'release'",             release.__name__.__eq__,             ["release"],             true]
    - [version,       "version.__name__ == 'version'",             version.__name__.__eq__,             ["version"],             true]
    - [python_build,  "python_build.__name__ == 'python_build'",   python_build.__name__.__eq__,        ["python_build"],        true]

# ---------------------------------------------------------------------------
# Return-type checks — system(), machine(), processor()
# ---------------------------------------------------------------------------

invariant platform_extra.system_is_str:
  description: "system().__class__.__name__ == 'str' — system() always returns a str"
  category: return_types
  kind: python_call_eq
  function: system().__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant platform_extra.machine_is_str:
  description: "machine().__class__.__name__ == 'str' — machine() always returns a str"
  category: return_types
  kind: python_call_eq
  function: machine().__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant platform_extra.processor_is_str:
  description: "processor().__class__.__name__ == 'str' — processor() always returns a str"
  category: return_types
  kind: python_call_eq
  function: processor().__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant platform_extra.release_is_str:
  description: "release().__class__.__name__ == 'str' — release() always returns a str"
  category: return_types
  kind: python_call_eq
  function: release().__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant platform_extra.version_is_str:
  description: "version().__class__.__name__ == 'str' — version() always returns a str"
  category: return_types
  kind: python_call_eq
  function: version().__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant platform_extra.python_implementation_is_str:
  description: "python_implementation().__class__.__name__ == 'str'"
  category: return_types
  kind: python_call_eq
  function: python_implementation().__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# uname_result — named-tuple type returned by uname()
# ---------------------------------------------------------------------------

invariant platform_extra.uname_result_class_name:
  description: "uname().__class__.__name__ == 'uname_result' — uname() returns a uname_result named-tuple"
  category: uname_result
  kind: python_call_eq
  function: uname().__class__.__name__.__eq__
  args: ["uname_result"]
  expected: true

invariant platform_extra.uname_result_machine_is_str:
  description: "uname().machine.__class__.__name__ == 'str' — machine field is always a str"
  category: uname_result
  kind: python_call_eq
  function: uname().machine.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant platform_extra.uname_result_node_is_str:
  description: "uname().node.__class__.__name__ == 'str' — node field is always a str"
  category: uname_result
  kind: python_call_eq
  function: uname().node.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant platform_extra.uname_result_processor_is_str:
  description: "uname().processor.__class__.__name__ == 'str' — processor field is always a str"
  category: uname_result
  kind: python_call_eq
  function: uname().processor.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant platform_extra.uname_result_version_is_str:
  description: "uname().version.__class__.__name__ == 'str' — version field is always a str"
  category: uname_result
  kind: python_call_eq
  function: uname().version.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# python_build() — returns a 2-tuple of strings
# ---------------------------------------------------------------------------

invariant platform_extra.python_build_is_tuple:
  description: "python_build().__class__.__name__ == 'tuple' — python_build() returns a 2-tuple"
  category: python_build
  kind: python_call_eq
  function: python_build().__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant platform_extra.python_build_len:
  description: "len(python_build()) == 2 — (buildno, builddate)"
  category: python_build
  kind: python_call_eq
  function: python_build().__len__
  args: []
  expected: 2

invariant platform_extra.python_build_buildno_is_str:
  description: "python_build()[0].__class__.__name__ == 'str' — buildno is a str"
  category: python_build
  kind: python_call_eq
  function: python_build().__getitem__
  args: [0]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

invariant platform_extra.python_build_builddate_is_str:
  description: "python_build()[1].__class__.__name__ == 'str' — builddate is a str"
  category: python_build
  kind: python_call_eq
  function: python_build().__getitem__
  args: [1]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true
