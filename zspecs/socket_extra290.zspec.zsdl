spec: socket_extra290
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module __all__ members and constant class names"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/socket.py, Modules/socketmodule.c"
  notes:
    - "MSG_PEEK, MSG_OOB, SO_REUSEADDR, SO_REUSEPORT, SOL_SOCKET, TCP_NODELAY are int constants"
    - "socket.__all__ contains create_connection, create_server, socketpair, fromfd"
    - "SO_REUSEPORT may not be available on all platforms"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table socket_extra290.socket_constant_class_names:
  description: "socket constant class names for MSG_PEEK, MSG_OOB, SO_REUSEADDR, SO_REUSEPORT, SOL_SOCKET, TCP_NODELAY, SO_KEEPALIVE, SO_BROADCAST"
  kind: python_call_eq
  category: identity
  id_prefix: sock290a

  columns: [id, function, args, expected, description]
  rows:
    - [sock290a001, socket.MSG_PEEK.__class__.__name__, [], "int", "socket.MSG_PEEK is an int"]
    - [sock290a002, socket.MSG_OOB.__class__.__name__, [], "int", "socket.MSG_OOB is an int"]
    - [sock290a003, socket.SO_REUSEADDR.__class__.__name__, [], "int", "socket.SO_REUSEADDR is an int"]
    - [sock290a004, socket.SO_REUSEPORT.__class__.__name__, [], "int", "socket.SO_REUSEPORT is an int"]
    - [sock290a005, socket.SOL_SOCKET.__class__.__name__, [], "int", "socket.SOL_SOCKET is an int"]
    - [sock290a006, socket.TCP_NODELAY.__class__.__name__, [], "int", "socket.TCP_NODELAY is an int"]
    - [sock290a007, socket.SO_KEEPALIVE.__class__.__name__, [], "int", "socket.SO_KEEPALIVE is an int"]
    - [sock290a008, socket.SO_BROADCAST.__class__.__name__, [], "int", "socket.SO_BROADCAST is an int"]

table socket_extra290.socket_all_membership_functions:
  description: "socket.__all__ membership for additional functions (create_connection, create_server, socketpair, fromfd)"
  kind: python_call_eq
  category: identity
  id_prefix: sock290b

  columns: [id, function, args, expected, description]
  rows:
    - [sock290b001, socket.__all__.__contains__, ["create_connection"], true, "create_connection in socket.__all__"]
    - [sock290b002, socket.__all__.__contains__, ["create_server"], true, "create_server in socket.__all__"]
    - [sock290b003, socket.__all__.__contains__, ["socketpair"], true, "socketpair in socket.__all__"]
    - [sock290b004, socket.__all__.__contains__, ["fromfd"], true, "fromfd in socket.__all__"]
    - [sock290b005, socket.__all__.__contains__, ["socket"], true, "socket in socket.__all__"]
    - [sock290b006, socket.__all__.__contains__, ["AF_INET"], true, "AF_INET in socket.__all__"]
    - [sock290b007, socket.__all__.__contains__, ["SOCK_STREAM"], true, "SOCK_STREAM in socket.__all__"]
    - [sock290b008, socket.__all__.__contains__, ["SOCK_DGRAM"], true, "SOCK_DGRAM in socket.__all__"]
    - [sock290b009, socket.__all__.__contains__, ["error"], true, "error in socket.__all__"]
    - [sock290b010, socket.__all__.__contains__, ["timeout"], true, "timeout in socket.__all__"]
    - [sock290b011, socket.__all__.__contains__, ["gethostname"], true, "gethostname in socket.__all__"]
    - [sock290b012, socket.__all__.__contains__, ["getaddrinfo"], true, "getaddrinfo in socket.__all__"]
    - [sock290b013, socket.__all__.__contains__, ["setdefaulttimeout"], true, "setdefaulttimeout in socket.__all__"]
    - [sock290b014, socket.__all__.__contains__, ["getdefaulttimeout"], true, "getdefaulttimeout in socket.__all__"]

invariant socket_extra290.socket_all_len:
  description: "socket.__all__ length check (verify count)"
  category: identity
  kind: python_call_eq
  function: socket.__all__.__len__
  args: []
  expected: 129

invariant socket_extra290.socket_msg_peek_class:
  description: "socket.MSG_PEEK is an int"
  category: identity
  kind: python_call_eq
  function: socket.MSG_PEEK.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant socket_extra290.socket_so_reuseaddr_class:
  description: "socket.SO_REUSEADDR is an int"
  category: identity
  kind: python_call_eq
  function: socket.SO_REUSEADDR.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant socket_extra290.socket_sol_socket_class:
  description: "socket.SOL_SOCKET is an int"
  category: identity
  kind: python_call_eq
  function: socket.SOL_SOCKET.__class__.__name__.__eq__
  args: ["int"]
  expected: true
