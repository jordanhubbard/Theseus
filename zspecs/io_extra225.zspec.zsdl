spec: io_extra225
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bufferedio.c"
  notes:
    - "This spec covers: method __name__ and __qualname__ attributes for io.BytesIO.read, io.BytesIO.write, io.BytesIO.seek, io.BytesIO.getvalue, io.StringIO.read, io.StringIO.getvalue; class __name__ and __module__ attributes for io.IOBase and io.RawIOBase; io.open __name__ and __module__."
    - "io.BytesIO.read.__name__ == 'read' — C method wrapper; io.BytesIO.read.__qualname__ == 'BytesIO.read'."
    - "io.BytesIO.write.__name__ == 'write', __qualname__ == 'BytesIO.write'."
    - "io.BytesIO.seek.__name__ == 'seek', __qualname__ == 'BytesIO.seek'."
    - "io.StringIO.read.__name__ == 'read', __qualname__ == 'StringIO.read'."
    - "io.StringIO.getvalue.__name__ == 'getvalue', __qualname__ == 'StringIO.getvalue'."
    - "io.BytesIO.getvalue.__name__ == 'getvalue'."
    - "io.IOBase.__name__ == 'IOBase', __module__ == 'io' (NOT '_io'; the public alias has module 'io')."
    - "io.RawIOBase.__name__ == 'RawIOBase', __module__ == 'io'."
    - "io.open.__name__ == 'open', __module__ == '_io' (the built-in open is in the _io C extension)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BytesIO method __name__ values
# BytesIO.read, write, seek, getvalue are C wrappers; their __name__ is the
# unqualified method name string.
# ---------------------------------------------------------------------------

table io_extra225.bytesio_method_names:
  description: "io.BytesIO method __name__ attribute values for read, write, seek, getvalue"
  kind: python_call_eq
  category: method_names
  id_prefix: iobytesiomnames225

  columns: [id, function, args, expected]
  rows:
    - [read_name,     BytesIO.read.__name__.__eq__,     ["read"],     true]
    - [write_name,    BytesIO.write.__name__.__eq__,    ["write"],    true]
    - [seek_name,     BytesIO.seek.__name__.__eq__,     ["seek"],     true]
    - [getvalue_name, BytesIO.getvalue.__name__.__eq__, ["getvalue"], true]

# ---------------------------------------------------------------------------
# BytesIO method __qualname__ values
# The __qualname__ for each BytesIO method is 'BytesIO.<method>'.
# ---------------------------------------------------------------------------

table io_extra225.bytesio_method_qualnames:
  description: "io.BytesIO method __qualname__ attribute values for read, write, seek"
  kind: python_call_eq
  category: method_names
  id_prefix: iobytesioqualnames225

  columns: [id, function, args, expected]
  rows:
    - [read_qualname,  BytesIO.read.__qualname__.__eq__,  ["BytesIO.read"],  true]
    - [write_qualname, BytesIO.write.__qualname__.__eq__, ["BytesIO.write"], true]
    - [seek_qualname,  BytesIO.seek.__qualname__.__eq__,  ["BytesIO.seek"],  true]

# ---------------------------------------------------------------------------
# StringIO method __name__ and __qualname__ values
# io.StringIO.read and io.StringIO.getvalue follow the same pattern.
# ---------------------------------------------------------------------------

table io_extra225.stringio_method_names:
  description: "io.StringIO method __name__ and __qualname__ attribute values for read and getvalue"
  kind: python_call_eq
  category: method_names
  id_prefix: iostriomnames225

  columns: [id, function, args, expected]
  rows:
    - [read_name,          StringIO.read.__name__.__eq__,          ["read"],             true]
    - [read_qualname,      StringIO.read.__qualname__.__eq__,      ["StringIO.read"],    true]
    - [getvalue_name,      StringIO.getvalue.__name__.__eq__,      ["getvalue"],         true]
    - [getvalue_qualname,  StringIO.getvalue.__qualname__.__eq__,  ["StringIO.getvalue"], true]

# ---------------------------------------------------------------------------
# IOBase and RawIOBase class __name__ and __module__
# The public io.IOBase and io.RawIOBase names report __module__ == 'io',
# not '_io', because they are re-exported through the io wrapper.
# ---------------------------------------------------------------------------

table io_extra225.iobase_class_metadata:
  description: "io.IOBase and io.RawIOBase class __name__ and __module__ values"
  kind: python_call_eq
  category: class_metadata
  id_prefix: iobasemeta225

  columns: [id, function, args, expected]
  rows:
    - [iobase_name,       IOBase.__name__.__eq__,       ["IOBase"],    true]
    - [iobase_module,     IOBase.__module__.__eq__,     ["io"],        true]
    - [rawiobase_name,    RawIOBase.__name__.__eq__,    ["RawIOBase"], true]
    - [rawiobase_module,  RawIOBase.__module__.__eq__,  ["io"],        true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra225.BytesIO.read.name:
  description: "io.BytesIO.read.__name__ == 'read' — C slot wrapper; unqualified method name"
  category: method_names
  kind: python_call_eq
  function: BytesIO.read.__name__.__eq__
  args: ["read"]
  expected: true

invariant io_extra225.BytesIO.write.qualname:
  description: "io.BytesIO.write.__qualname__ == 'BytesIO.write' — qualname encodes the enclosing class"
  category: method_names
  kind: python_call_eq
  function: BytesIO.write.__qualname__.__eq__
  args: ["BytesIO.write"]
  expected: true

invariant io_extra225.StringIO.getvalue.name:
  description: "io.StringIO.getvalue.__name__ == 'getvalue'"
  category: method_names
  kind: python_call_eq
  function: StringIO.getvalue.__name__.__eq__
  args: ["getvalue"]
  expected: true

invariant io_extra225.IOBase.module:
  description: "io.IOBase.__module__ == 'io' — the public alias uses module 'io', not '_io'"
  category: class_metadata
  kind: python_call_eq
  function: IOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra225.open.name:
  description: "io.open.__name__ == 'open'"
  category: method_names
  kind: python_call_eq
  function: open.__name__.__eq__
  args: ["open"]
  expected: true

invariant io_extra225.open.module:
  description: "io.open.__module__ == '_io' — the built-in open function lives in the _io C extension"
  category: class_metadata
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["_io"]
  expected: true
