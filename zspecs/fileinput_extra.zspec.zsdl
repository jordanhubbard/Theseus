spec: fileinput_extra
version: ">=3.9"
backend: python_module(fileinput)

docs: https://docs.python.org/3/library/fileinput.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fileinput.html — Python fileinput module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fileinput.py"
  notes:
    - "This spec covers fileinput behaviors not in fileinput.zspec.zsdl."
    - "fileinput.input() is the module-level convenience function that returns or creates the global FileInput instance."
    - "fileinput.filename(), fileno(), lineno(), filelineno(), isfirstline() operate on the active global FileInput."
    - "fileinput.close() closes the global FileInput instance and releases it."
    - "fileinput.FileInput is the underlying class; the module-level functions delegate to a global instance."
    - "fileinput.hook_compressed() and fileinput.hook_encoded() are openhook factory functions."
    - "FileInput.__module__ == 'fileinput' — the class is defined in the fileinput module."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level function __name__ checks
#
# Each module-level function in fileinput must have a __name__ matching its
# own identifier. This is verified by calling __name__.__eq__ on each.
# ---------------------------------------------------------------------------

invariant fileinput_extra.input.name:
  description: "fileinput.input.__name__ == 'input'"
  category: functions
  kind: python_call_eq
  function: input.__name__.__eq__
  args: ["input"]
  expected: true

invariant fileinput_extra.filename.name:
  description: "fileinput.filename.__name__ == 'filename'"
  category: functions
  kind: python_call_eq
  function: filename.__name__.__eq__
  args: ["filename"]
  expected: true

invariant fileinput_extra.fileno.name:
  description: "fileinput.fileno.__name__ == 'fileno'"
  category: functions
  kind: python_call_eq
  function: fileno.__name__.__eq__
  args: ["fileno"]
  expected: true

invariant fileinput_extra.lineno.name:
  description: "fileinput.lineno.__name__ == 'lineno'"
  category: functions
  kind: python_call_eq
  function: lineno.__name__.__eq__
  args: ["lineno"]
  expected: true

invariant fileinput_extra.filelineno.name:
  description: "fileinput.filelineno.__name__ == 'filelineno'"
  category: functions
  kind: python_call_eq
  function: filelineno.__name__.__eq__
  args: ["filelineno"]
  expected: true

invariant fileinput_extra.isfirstline.name:
  description: "fileinput.isfirstline.__name__ == 'isfirstline'"
  category: functions
  kind: python_call_eq
  function: isfirstline.__name__.__eq__
  args: ["isfirstline"]
  expected: true

invariant fileinput_extra.close.name:
  description: "fileinput.close.__name__ == 'close'"
  category: functions
  kind: python_call_eq
  function: close.__name__.__eq__
  args: ["close"]
  expected: true

# ---------------------------------------------------------------------------
# Hook factory function __name__ checks
# ---------------------------------------------------------------------------

invariant fileinput_extra.hook_compressed.name:
  description: "fileinput.hook_compressed.__name__ == 'hook_compressed'"
  category: functions
  kind: python_call_eq
  function: hook_compressed.__name__.__eq__
  args: ["hook_compressed"]
  expected: true

invariant fileinput_extra.hook_encoded.name:
  description: "fileinput.hook_encoded.__name__ == 'hook_encoded'"
  category: functions
  kind: python_call_eq
  function: hook_encoded.__name__.__eq__
  args: ["hook_encoded"]
  expected: true

# ---------------------------------------------------------------------------
# FileInput class — name and module affiliation
# ---------------------------------------------------------------------------

invariant fileinput_extra.FileInput.name:
  description: "fileinput.FileInput.__name__ == 'FileInput'"
  category: classes
  kind: python_call_eq
  function: FileInput.__name__.__eq__
  args: ["FileInput"]
  expected: true

invariant fileinput_extra.FileInput.module:
  description: "fileinput.FileInput.__module__ == 'fileinput'"
  category: classes
  kind: python_call_eq
  function: FileInput.__module__.__eq__
  args: ["fileinput"]
  expected: true

# ---------------------------------------------------------------------------
# FileInput class — is a type (class object)
# ---------------------------------------------------------------------------

invariant fileinput_extra.FileInput.is_type:
  description: "type(fileinput.FileInput).__name__ == 'type' — FileInput is a class"
  category: classes
  kind: python_call_eq
  function: FileInput.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# isstdin function __name__ check
# ---------------------------------------------------------------------------

invariant fileinput_extra.isstdin.name:
  description: "fileinput.isstdin.__name__ == 'isstdin'"
  category: functions
  kind: python_call_eq
  function: isstdin.__name__.__eq__
  args: ["isstdin"]
  expected: true

# ---------------------------------------------------------------------------
# nextfile function __name__ check
# ---------------------------------------------------------------------------

invariant fileinput_extra.nextfile.name:
  description: "fileinput.nextfile.__name__ == 'nextfile'"
  category: functions
  kind: python_call_eq
  function: nextfile.__name__.__eq__
  args: ["nextfile"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level functions are callable
# ---------------------------------------------------------------------------

invariant fileinput_extra.input.is_callable:
  description: "fileinput.input is callable"
  category: functions
  kind: python_call_eq
  function: input.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant fileinput_extra.hook_compressed.is_callable:
  description: "fileinput.hook_compressed is callable"
  category: functions
  kind: python_call_eq
  function: hook_compressed.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant fileinput_extra.hook_encoded.is_callable:
  description: "fileinput.hook_encoded is callable"
  category: functions
  kind: python_call_eq
  function: hook_encoded.__class__.__name__.__eq__
  args: ["function"]
  expected: true
