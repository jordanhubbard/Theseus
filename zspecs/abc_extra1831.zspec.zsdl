spec: abc_extra1831
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "abc stdlib documentation"
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  not_derived_from:
    - "third-party ABC frameworks"
  notes:
    - "abstractmethod IS a descriptor (defines __get__) so it can wrap methods and preserve the descriptor protocol"
    - "abstractmethod defines __call__ to allow calling the abstract method on the class itself"
    - "abstractclassmethod and abstractstaticmethod were removed in Python 3.11"
    - "abstractproperty is deprecated but still present in Python 3.14"
    - "ABCMeta.__call__ is inherited from type, not defined in ABCMeta.__dict__"
  created_at: "2026-04-12"

table abc_extra1831.descriptor_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["ab1831-dp-001", "abc.ABC.__dict__.__contains__", ["__get__"], false]
    - ["ab1831-dp-002", "abc.ABC.__dict__.__contains__", ["__set__"], false]
    - ["ab1831-dp-003", "abc.ABCMeta.__dict__.__contains__", ["__get__"], false]
    - ["ab1831-dp-004", "abc.abstractmethod.__dict__.__contains__", ["__get__"], true]
    - ["ab1831-dp-005", "abc.abstractmethod.__dict__.__contains__", ["__set__"], false]
    - ["ab1831-dp-006", "abc.abstractmethod.__dict__.__contains__", ["__delete__"], false]
    - ["ab1831-dp-007", "abc.abstractmethod.__dict__.__contains__", ["__set_name__"], false]
    - ["ab1831-dp-008", "abc.ABC.__dict__.__contains__", ["__set_name__"], false]

