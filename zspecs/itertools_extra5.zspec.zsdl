spec: itertools_extra5
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools.zspec.zsdl through itertools_extra4.zspec.zsdl."
    - "Previous specs cover: __name__ for filterfalse, chain, compress, dropwhile, takewhile, groupby, accumulate, combinations, permutations, product, zip_longest, starmap, count, repeat, islice; __module__ for all 15 iterator types; class instance __class__.__name__ checks for takewhile/dropwhile/groupby/starmap/zip_longest/count/cycle/repeat; length hints; first element checks; and basic behavioral invariants for chain/compress."
    - "This spec adds: __qualname__ checks for compress/dropwhile/takewhile/filterfalse/groupby/accumulate (none yet recorded); pairwise (Python 3.10+) __name__/__module__/__qualname__; compress with a string iterable (new data vector); accumulate class identity via __class__.__name__."
    - "itertools.compress('ABCDE', [1,0,1,0,1]) yields 'A', 'C', 'E' — works with string iterables."
    - "itertools.pairwise is available from Python 3.10 (PEP 618 / bpo-42248)."
    - "itertools.pairwise.__name__ == 'pairwise' (Python 3.10+)."
    - "itertools.pairwise.__module__ == 'itertools' (Python 3.10+)."
    - "itertools.pairwise.__qualname__ == 'pairwise' (Python 3.10+)."
    - "itertools.accumulate([1,2,3,4]) yields running totals: 1, 3, 6, 10; its __class__.__name__ is 'accumulate'."
    - "itertools.compress class __qualname__ == 'compress' (top-level C type)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ table — iterator types not yet given __qualname__ invariants
#
# All itertools C types are top-level classes whose __qualname__ == __name__.
# Prior specs recorded __name__ and __module__ but no __qualname__ invariants.
# ---------------------------------------------------------------------------

table itertools_extra5.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [compress,     compress.__qualname__.__eq__,     ["compress"],     true]
    - [dropwhile,    dropwhile.__qualname__.__eq__,    ["dropwhile"],    true]
    - [takewhile,    takewhile.__qualname__.__eq__,    ["takewhile"],    true]
    - [filterfalse,  filterfalse.__qualname__.__eq__,  ["filterfalse"],  true]
    - [groupby,      groupby.__qualname__.__eq__,      ["groupby"],      true]
    - [accumulate,   accumulate.__qualname__.__eq__,   ["accumulate"],   true]

# ---------------------------------------------------------------------------
# pairwise — class identity (Python 3.10+)
#
# itertools.pairwise was added in Python 3.10. It yields consecutive
# overlapping pairs from the input iterable.
# pairwise([1,2,3,4]) -> (1,2), (2,3), (3,4)
# ---------------------------------------------------------------------------

invariant itertools_extra5.pairwise.name:
  description: "itertools.pairwise.__name__ == 'pairwise' (Python 3.10+)"
  category: pairwise
  kind: python_call_eq
  function: pairwise.__name__.__eq__
  args: ["pairwise"]
  expected: true
  version: ">=3.10"

invariant itertools_extra5.pairwise.module:
  description: "itertools.pairwise.__module__ == 'itertools' (Python 3.10+)"
  category: pairwise
  kind: python_call_eq
  function: pairwise.__module__.__eq__
  args: ["itertools"]
  expected: true
  version: ">=3.10"

invariant itertools_extra5.pairwise.qualname:
  description: "itertools.pairwise.__qualname__ == 'pairwise' (Python 3.10+)"
  category: pairwise
  kind: python_call_eq
  function: pairwise.__qualname__.__eq__
  args: ["pairwise"]
  expected: true
  version: ">=3.10"

invariant itertools_extra5.pairwise.class_name:
  description: "itertools.pairwise([1,2,3]).__class__.__name__ == 'pairwise' (Python 3.10+)"
  category: pairwise
  kind: python_call_eq
  function: pairwise
  args: [[1, 2, 3]]
  method: __class__.__name__.__eq__
  method_args: ["pairwise"]
  expected: true
  version: ">=3.10"

invariant itertools_extra5.pairwise.first_pair:
  description: "next(itertools.pairwise([1,2,3,4])) == (1,2) — first consecutive pair (Python 3.10+)"
  category: pairwise
  kind: python_call_eq
  function: pairwise
  args: [[1, 2, 3, 4]]
  method: __next__
  expected: [1, 2]
  version: ">=3.10"

# ---------------------------------------------------------------------------
# compress with string iterable — new data vector
#
# itertools_extra4 covers compress([1,2,3,4], [1,0,1,0]).
# This spec adds compress with a string iterable and a different selector
# pattern to produce a new, distinct result.
# compress('ABCDE', [1,0,1,0,1]) -> 'A', 'C', 'E'
# The result iterator class name is 'compress'.
# ---------------------------------------------------------------------------

invariant itertools_extra5.compress.string_iterable_class:
  description: "itertools.compress('ABCDE', [1,0,1,0,1]).__class__.__name__ == 'compress'"
  category: compress
  kind: python_call_eq
  function: compress
  args: ["ABCDE", [1, 0, 1, 0, 1]]
  method: __class__.__name__.__eq__
  method_args: ["compress"]
  expected: true

invariant itertools_extra5.compress.string_iterable_first:
  description: "next(itertools.compress('ABCDE', [1,0,1,0,1])) == 'A' — first selected element"
  category: compress
  kind: python_call_eq
  function: compress
  args: ["ABCDE", [1, 0, 1, 0, 1]]
  method: __next__
  expected: "A"

# ---------------------------------------------------------------------------
# accumulate — class identity for the iterator object
#
# itertools_extra4 covers accumulate.__name__ == 'accumulate' (the class).
# This spec adds the instance class name check: an accumulate iterator's
# __class__.__name__ is also 'accumulate'.
# ---------------------------------------------------------------------------

invariant itertools_extra5.accumulate.instance_class_name:
  description: "itertools.accumulate([1,2,3]).__class__.__name__ == 'accumulate'"
  category: accumulate
  kind: python_call_eq
  function: accumulate
  args: [[1, 2, 3]]
  method: __class__.__name__.__eq__
  method_args: ["accumulate"]
  expected: true

invariant itertools_extra5.accumulate.first_element:
  description: "next(itertools.accumulate([1,2,3,4])) == 1 — first running total is the first element"
  category: accumulate
  kind: python_call_eq
  function: accumulate
  args: [[1, 2, 3, 4]]
  method: __next__
  expected: 1
