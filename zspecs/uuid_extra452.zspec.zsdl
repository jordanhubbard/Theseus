spec: uuid_extra452
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module identity and namespace constants"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "uuid generation functions are pure-Python; __name__ and __module__ are stable across platforms"
    - "NAMESPACE_* constants are UUID instances defined in RFC 4122"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra452.function_names:
  description: "Identity checks on uuid generation function __name__ attributes"
  kind: python_call_eq
  category: identity
  id_prefix: uln

  columns: [id, function, args, expected]
  rows:
    - [uln001, uuid.uuid1.__name__.__eq__, ["uuid1"], true]
    - [uln002, uuid.uuid3.__name__.__eq__, ["uuid3"], true]
    - [uln003, uuid.uuid4.__name__.__eq__, ["uuid4"], true]
    - [uln004, uuid.uuid5.__name__.__eq__, ["uuid5"], true]

table uuid_extra452.function_modules:
  description: "Identity checks on uuid generation function __module__ attributes"
  kind: python_call_eq
  category: identity
  id_prefix: ulm

  columns: [id, function, args, expected]
  rows:
    - [ulm001, uuid.uuid1.__module__.__eq__, ["uuid"], true]
    - [ulm002, uuid.uuid3.__module__.__eq__, ["uuid"], true]
    - [ulm003, uuid.uuid4.__module__.__eq__, ["uuid"], true]
    - [ulm004, uuid.uuid5.__module__.__eq__, ["uuid"], true]

table uuid_extra452.namespace_types:
  description: "NAMESPACE_* constants are UUID instances"
  kind: python_call_eq
  category: types
  id_prefix: uns

  columns: [id, function, args, expected]
  rows:
    - [uns001, uuid.NAMESPACE_DNS.__class__.__name__.__eq__,  ["UUID"], true]
    - [uns002, uuid.NAMESPACE_URL.__class__.__name__.__eq__,  ["UUID"], true]
    - [uns003, uuid.NAMESPACE_OID.__class__.__name__.__eq__,  ["UUID"], true]
    - [uns004, uuid.NAMESPACE_X500.__class__.__name__.__eq__, ["UUID"], true]

table uuid_extra452.namespace_values:
  description: "NAMESPACE_* constants have the RFC 4122 canonical hex values"
  kind: python_call_eq
  category: behavior
  id_prefix: unv

  columns: [id, function, args, expected]
  rows:
    - [unv001, uuid.NAMESPACE_DNS.hex.__eq__,  ["6ba7b8109dad11d180b400c04fd430c8"], true]
    - [unv002, uuid.NAMESPACE_URL.hex.__eq__,  ["6ba7b8119dad11d180b400c04fd430c8"], true]
    - [unv003, uuid.NAMESPACE_OID.hex.__eq__,  ["6ba7b8129dad11d180b400c04fd430c8"], true]
    - [unv004, uuid.NAMESPACE_X500.hex.__eq__, ["6ba7b8149dad11d180b400c04fd430c8"], true]
