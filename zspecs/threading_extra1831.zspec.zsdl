spec: threading_extra1831
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/threading.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 569 (_extra1831): descriptor protocol (__get__/__set__/__delete__); __call__ callable protocol; threading module-level function and constant presence for threading types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table threading_extra1831.descriptor_protocol:
  description: "threading types descriptor protocol dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1831

  columns: [id, function, args, expected]
  rows:
    - ["th1831001", "threading.Thread.__dict__.__contains__", ["__get__"], false]
    - ["th1831002", "threading.Thread.__dict__.__contains__", ["__set__"], false]
    - ["th1831003", "threading.Thread.__dict__.__contains__", ["__delete__"], false]
    - ["th1831004", "threading.Event.__dict__.__contains__", ["__get__"], false]
    - ["th1831005", "threading.Condition.__dict__.__contains__", ["__get__"], false]
    - ["th1831006", "threading.Semaphore.__dict__.__contains__", ["__get__"], false]
    - ["th1831007", "threading.Barrier.__dict__.__contains__", ["__get__"], false]
    - ["th1831008", "threading.Timer.__dict__.__contains__", ["__get__"], false]

table threading_extra1831.callable_protocol:
  description: "threading types __call__ and __init__ callable protocol dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1831

  columns: [id, function, args, expected]
  rows:
    - ["th1831101", "threading.Thread.__dict__.__contains__", ["__call__"], false]
    - ["th1831102", "threading.Event.__dict__.__contains__", ["__call__"], false]
    - ["th1831103", "threading.Condition.__dict__.__contains__", ["__call__"], false]
    - ["th1831104", "threading.Semaphore.__dict__.__contains__", ["__call__"], false]
    - ["th1831105", "threading.Barrier.__dict__.__contains__", ["__call__"], false]
    - ["th1831106", "threading.Timer.__dict__.__contains__", ["__call__"], false]
    - ["th1831107", "threading.Thread.__dict__.__contains__", ["__init__"], true]
    - ["th1831108", "threading.Condition.__dict__.__contains__", ["__init__"], true]

table threading_extra1831.threading_module_functions:
  description: "threading module-level function and constant presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1831

  columns: [id, function, args, expected]
  rows:
    - ["th1831201", "threading.__dict__.__contains__", ["current_thread"], true]
    - ["th1831202", "threading.__dict__.__contains__", ["main_thread"], true]
    - ["th1831203", "threading.__dict__.__contains__", ["active_count"], true]
    - ["th1831204", "threading.__dict__.__contains__", ["enumerate"], true]
    - ["th1831205", "threading.__dict__.__contains__", ["settrace"], true]
    - ["th1831206", "threading.__dict__.__contains__", ["setprofile"], true]
    - ["th1831207", "threading.__dict__.__contains__", ["stack_size"], true]
    - ["th1831208", "threading.__dict__.__contains__", ["TIMEOUT_MAX"], true]
    - ["th1831209", "threading.__dict__.__contains__", ["local"], true]
    - ["th1831210", "threading.__dict__.__contains__", ["excepthook"], true]
