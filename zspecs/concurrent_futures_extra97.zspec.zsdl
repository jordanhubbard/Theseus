spec: concurrent_futures_extra97
version: ">=3.9"
backend: python_module(concurrent.futures)
extends: concurrent_futures_extra96

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec extends concurrent_futures_extra96.zspec.zsdl."
    - "This spec covers: wave 254 theme — concurrent.futures ThreadPoolExecutor and ProcessPoolExecutor method class names and qualnames. NEW in extra97: ThreadPoolExecutor.submit.__class__.__name__=='function'; ThreadPoolExecutor.submit.__qualname__=='ThreadPoolExecutor.submit' (len=25); ThreadPoolExecutor.shutdown.__qualname__=='ThreadPoolExecutor.shutdown' (len=27); ThreadPoolExecutor.map.__qualname__=='Executor.map' (len=12, inherited from Executor); ProcessPoolExecutor.submit.__qualname__=='ProcessPoolExecutor.submit' (len=26); ProcessPoolExecutor.map.__qualname__=='ProcessPoolExecutor.map' (len=23); ProcessPoolExecutor.shutdown.__qualname__=='ProcessPoolExecutor.shutdown' (len=28); Executor.map.__qualname__=='Executor.map' (len=12); Executor.submit.__qualname__=='Executor.submit' (len=15); Future.set_result.__qualname__=='Future.set_result' (len=17); Future.set_exception.__qualname__=='Future.set_exception' (len=20). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ThreadPoolExecutor.map.__qualname__ == 'Executor.map' (len=12). ThreadPoolExecutor inherits map from Executor base class; the qualname reflects the defining class. ThreadPoolExecutor.submit.__qualname__ is 'ThreadPoolExecutor.submit' (len=25) because submit is defined in ThreadPoolExecutor itself (Lib/concurrent/futures/thread.py). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ProcessPoolExecutor.map.__qualname__ == 'ProcessPoolExecutor.map' (len=23). ProcessPoolExecutor defines its own map override in Lib/concurrent/futures/process.py, unlike ThreadPoolExecutor which inherits map from Executor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures ThreadPoolExecutor method qualnames — extra97
#
# Wave 254 theme: ThreadPoolExecutor and ProcessPoolExecutor method qualnames.
#
# ThreadPoolExecutor.submit.__qualname__   == 'ThreadPoolExecutor.submit'   (len=25)
# ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown' (len=27)
# ThreadPoolExecutor.__init__.__qualname__ == 'ThreadPoolExecutor.__init__' (len=27)
# ThreadPoolExecutor.map.__qualname__      == 'Executor.map'               (len=12, inherited)
# All methods have __class__.__name__ == 'function'
# ---------------------------------------------------------------------------

table concurrent_futures_extra97.tpe_method_qualnames:
  description: "concurrent.futures.ThreadPoolExecutor method qualname checks in cftpequalname97 namespace — wave 254 theme: ThreadPoolExecutor method qualnames reveal which methods are defined in ThreadPoolExecutor itself vs inherited from Executor; ThreadPoolExecutor.submit is defined in Lib/concurrent/futures/thread.py: submit.__class__.__name__.__eq__('function')==True; submit.__qualname__.__eq__('ThreadPoolExecutor.submit')==True (len=25: 'ThreadPoolExecutor.'=20 + 'submit'=6, minus 1 for the dot overlap... actually 'ThreadPoolExecutor.'=20 chars, 'submit'=6 chars, total=26? No: len('ThreadPoolExecutor.submit')=25); submit.__qualname__.__len__()==25; ThreadPoolExecutor.shutdown.__qualname__.__eq__('ThreadPoolExecutor.shutdown')==True (len=27: 'ThreadPoolExecutor.'=20 + 'shutdown'=8, but actually len('ThreadPoolExecutor.shutdown')=27); ThreadPoolExecutor.__init__.__qualname__.__eq__('ThreadPoolExecutor.__init__')==True (len=27: same as shutdown); ThreadPoolExecutor.map.__qualname__.__eq__('Executor.map')==True (len=12: map is inherited from Executor base class, so qualname reflects defining class 'Executor', not 'ThreadPoolExecutor'); all four methods have class='function' (pure-Python); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cftpequalname97

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_submit_cls,  "ThreadPoolExecutor.submit.__class__.__name__.__eq__",    ["function"],                       true, "ThreadPoolExecutor.submit.__class__.__name__ == 'function' — Python function in thread.py; verified with Python 3.14.3"]
    - [tpe_submit_qeq,  "ThreadPoolExecutor.submit.__qualname__.__eq__",           ["ThreadPoolExecutor.submit"],      true, "ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit' (len=25); verified with Python 3.14.3"]
    - [tpe_submit_qlen, "ThreadPoolExecutor.submit.__qualname__.__len__",          [],                                 25,   "ThreadPoolExecutor.submit.__qualname__.__len__() == 25; verified with Python 3.14.3"]
    - [tpe_shut_qeq,    "ThreadPoolExecutor.shutdown.__qualname__.__eq__",         ["ThreadPoolExecutor.shutdown"],    true, "ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown' (len=27); verified with Python 3.14.3"]
    - [tpe_shut_qlen,   "ThreadPoolExecutor.shutdown.__qualname__.__len__",        [],                                 27,   "ThreadPoolExecutor.shutdown.__qualname__.__len__() == 27; verified with Python 3.14.3"]
    - [tpe_init_qeq,    "ThreadPoolExecutor.__init__.__qualname__.__eq__",         ["ThreadPoolExecutor.__init__"],    true, "ThreadPoolExecutor.__init__.__qualname__ == 'ThreadPoolExecutor.__init__' (len=27, same as shutdown); verified with Python 3.14.3"]
    - [tpe_init_qlen,   "ThreadPoolExecutor.__init__.__qualname__.__len__",        [],                                 27,   "ThreadPoolExecutor.__init__.__qualname__.__len__() == 27; verified with Python 3.14.3"]
    - [tpe_map_qeq,     "ThreadPoolExecutor.map.__qualname__.__eq__",              ["Executor.map"],                   true, "ThreadPoolExecutor.map.__qualname__ == 'Executor.map' (len=12, inherited from Executor); verified with Python 3.14.3"]
    - [tpe_map_qlen,    "ThreadPoolExecutor.map.__qualname__.__len__",             [],                                 12,   "ThreadPoolExecutor.map.__qualname__.__len__() == 12 (reflects Executor as defining class); verified with Python 3.14.3"]
    - [tpe_map_cls,     "ThreadPoolExecutor.map.__class__.__name__.__eq__",        ["function"],                       true, "ThreadPoolExecutor.map.__class__.__name__ == 'function' — inherited Python function; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures ProcessPoolExecutor method qualnames — extra97
#
# ProcessPoolExecutor.submit.__qualname__   == 'ProcessPoolExecutor.submit'   (len=26)
# ProcessPoolExecutor.map.__qualname__      == 'ProcessPoolExecutor.map'      (len=23)
# ProcessPoolExecutor.shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown' (len=28)
# All methods have __class__.__name__ == 'function'
# ---------------------------------------------------------------------------

table concurrent_futures_extra97.ppe_method_qualnames:
  description: "concurrent.futures.ProcessPoolExecutor method qualname checks in cftpequalname97 namespace — wave 254 theme: ProcessPoolExecutor method qualnames; ProcessPoolExecutor defines its own submit, map, and shutdown in Lib/concurrent/futures/process.py (unlike ThreadPoolExecutor which inherits map from Executor); ProcessPoolExecutor.submit.__qualname__.__eq__('ProcessPoolExecutor.submit')==True (len=26: len('ProcessPoolExecutor.submit')=26, one more than ThreadPoolExecutor.submit at 25 because 'ProcessPoolExecutor'=19 chars vs 'ThreadPoolExecutor'=18 chars); ProcessPoolExecutor.submit.__qualname__.__len__()==26; ProcessPoolExecutor.map.__qualname__.__eq__('ProcessPoolExecutor.map')==True (len=23: 'ProcessPoolExecutor.'=20 + 'map'=3; unlike ThreadPoolExecutor.map which inherits from Executor with qualname 'Executor.map'=12); ProcessPoolExecutor.map.__qualname__.__len__()==23; ProcessPoolExecutor.shutdown.__qualname__.__eq__('ProcessPoolExecutor.shutdown')==True (len=28, one more than ThreadPoolExecutor.shutdown at 27); all methods have class='function' (pure-Python); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cftpequalname97a

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_submit_cls,  "ProcessPoolExecutor.submit.__class__.__name__.__eq__",   ["function"],                        true, "ProcessPoolExecutor.submit.__class__.__name__ == 'function' — Python function in process.py; verified with Python 3.14.3"]
    - [ppe_submit_qeq,  "ProcessPoolExecutor.submit.__qualname__.__eq__",          ["ProcessPoolExecutor.submit"],      true, "ProcessPoolExecutor.submit.__qualname__ == 'ProcessPoolExecutor.submit' (len=26); verified with Python 3.14.3"]
    - [ppe_submit_qlen, "ProcessPoolExecutor.submit.__qualname__.__len__",         [],                                  26,   "ProcessPoolExecutor.submit.__qualname__.__len__() == 26 (one more than ThreadPoolExecutor.submit at 25); verified with Python 3.14.3"]
    - [ppe_map_qeq,     "ProcessPoolExecutor.map.__qualname__.__eq__",             ["ProcessPoolExecutor.map"],         true, "ProcessPoolExecutor.map.__qualname__ == 'ProcessPoolExecutor.map' (len=23, own definition unlike TPE); verified with Python 3.14.3"]
    - [ppe_map_qlen,    "ProcessPoolExecutor.map.__qualname__.__len__",            [],                                  23,   "ProcessPoolExecutor.map.__qualname__.__len__() == 23 (vs ThreadPoolExecutor.map len=12 which inherits from Executor); verified with Python 3.14.3"]
    - [ppe_shut_qeq,    "ProcessPoolExecutor.shutdown.__qualname__.__eq__",        ["ProcessPoolExecutor.shutdown"],    true, "ProcessPoolExecutor.shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown' (len=28); verified with Python 3.14.3"]
    - [ppe_shut_qlen,   "ProcessPoolExecutor.shutdown.__qualname__.__len__",       [],                                  28,   "ProcessPoolExecutor.shutdown.__qualname__.__len__() == 28 (longest shutdown qualname; one more than ThreadPoolExecutor.shutdown at 27); verified with Python 3.14.3"]
    - [ppe_map_cls,     "ProcessPoolExecutor.map.__class__.__name__.__eq__",       ["function"],                        true, "ProcessPoolExecutor.map.__class__.__name__ == 'function' — Python function; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures Executor and Future method qualnames — extra97
#
# Executor.map.__qualname__           == 'Executor.map'           (len=12)
# Executor.submit.__qualname__        == 'Executor.submit'        (len=15)
# Future.set_result.__qualname__      == 'Future.set_result'      (len=17)
# Future.set_exception.__qualname__   == 'Future.set_exception'   (len=20)
# ---------------------------------------------------------------------------

table concurrent_futures_extra97.executor_future_qualnames:
  description: "concurrent.futures.Executor and Future method qualname checks in cftpequalname97 namespace — wave 254 theme: Executor base class and Future method qualnames; concurrent.futures.Executor is the abstract base defined in Lib/concurrent/futures/_base.py; Executor.map.__qualname__.__eq__('Executor.map')==True (len=12: 'Executor.'=9 + 'map'=3); Executor.map is the concrete implementation that ThreadPoolExecutor inherits (so ThreadPoolExecutor.map.__qualname__ == 'Executor.map', the base class qualname); Executor.submit.__qualname__.__eq__('Executor.submit')==True (len=15: 'Executor.'=9 + 'submit'=6; this is the abstract stub that raises NotImplementedError); Executor.submit.__qualname__.__len__()==15; concurrent.futures.Future is also defined in _base.py; Future.set_result.__qualname__.__eq__('Future.set_result')==True (len=17: 'Future.'=7 + 'set_result'=10); Future.set_exception.__qualname__.__eq__('Future.set_exception')==True (len=20: 'Future.'=7 + 'set_exception'=13); all four methods have class='function' (pure-Python, all defined in _base.py); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cftpequalname97b

  columns: [id, function, args, expected, description]
  rows:
    - [exec_map_qeq,    "Executor.map.__qualname__.__eq__",                ["Executor.map"],          true, "Executor.map.__qualname__ == 'Executor.map' (len=12); verified with Python 3.14.3"]
    - [exec_map_qlen,   "Executor.map.__qualname__.__len__",               [],                         12,   "Executor.map.__qualname__.__len__() == 12; verified with Python 3.14.3"]
    - [exec_map_cls,    "Executor.map.__class__.__name__.__eq__",          ["function"],               true, "Executor.map.__class__.__name__ == 'function' — Python function in _base.py; verified with Python 3.14.3"]
    - [exec_sub_qeq,    "Executor.submit.__qualname__.__eq__",             ["Executor.submit"],        true, "Executor.submit.__qualname__ == 'Executor.submit' (len=15); verified with Python 3.14.3"]
    - [exec_sub_qlen,   "Executor.submit.__qualname__.__len__",            [],                         15,   "Executor.submit.__qualname__.__len__() == 15; verified with Python 3.14.3"]
    - [exec_sub_cls,    "Executor.submit.__class__.__name__.__eq__",       ["function"],               true, "Executor.submit.__class__.__name__ == 'function' — Python function (abstract stub); verified with Python 3.14.3"]
    - [fut_setr_qeq,    "Future.set_result.__qualname__.__eq__",           ["Future.set_result"],      true, "Future.set_result.__qualname__ == 'Future.set_result' (len=17); verified with Python 3.14.3"]
    - [fut_setr_qlen,   "Future.set_result.__qualname__.__len__",          [],                         17,   "Future.set_result.__qualname__.__len__() == 17; verified with Python 3.14.3"]
    - [fut_sete_qeq,    "Future.set_exception.__qualname__.__eq__",        ["Future.set_exception"],   true, "Future.set_exception.__qualname__ == 'Future.set_exception' (len=20); verified with Python 3.14.3"]
    - [fut_sete_qlen,   "Future.set_exception.__qualname__.__len__",       [],                         20,   "Future.set_exception.__qualname__.__len__() == 20 (longest among set_result=17 and set_exception=20); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra97
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra97.TPE_map_qualname_is_Executor_map:
  description: "concurrent.futures.ThreadPoolExecutor.map.__qualname__.__eq__('Executor.map') returns True — ThreadPoolExecutor.map.__qualname__ is 'Executor.map' (len=12), NOT 'ThreadPoolExecutor.map'; this reveals that ThreadPoolExecutor inherits map from the Executor base class and does NOT override it; the __qualname__ attribute always reflects the class where the method was originally defined; this contrasts with ThreadPoolExecutor.submit (qualname='ThreadPoolExecutor.submit', len=25) and shutdown (qualname='ThreadPoolExecutor.shutdown', len=27) which are defined in ThreadPoolExecutor itself (in Lib/concurrent/futures/thread.py); ProcessPoolExecutor does override map (qualname='ProcessPoolExecutor.map', len=23); ThreadPoolExecutor.map.__module__ is 'concurrent.futures._base' (the _base submodule where Executor is defined); NEW in extra97: first standalone TPE map qualname invariant in cftpequalname97 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ThreadPoolExecutor.map.__qualname__.__eq__"
  args: ["Executor.map"]
  expected: true

invariant concurrent_futures_extra97.PPE_map_qualname_len_23:
  description: "concurrent.futures.ProcessPoolExecutor.map.__qualname__.__len__() == 23 — ProcessPoolExecutor.map.__qualname__ is 'ProcessPoolExecutor.map' (len=23: 'ProcessPoolExecutor.'=20 + 'map'=3); unlike ThreadPoolExecutor which inherits map from Executor (giving qualname='Executor.map', len=12), ProcessPoolExecutor defines its own map override in Lib/concurrent/futures/process.py; this difference (qualname len=23 vs 12 for inherited) reflects a key design distinction: ProcessPoolExecutor must handle the process-pool-specific serialization constraints in map; ProcessPoolExecutor.submit.__qualname__.__len__() is 26 and ProcessPoolExecutor.shutdown.__qualname__.__len__() is 28; all ProcessPoolExecutor methods have class='function'; NEW in extra97: first standalone PPE map qualname length invariant in cftpequalname97 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ProcessPoolExecutor.map.__qualname__.__len__"
  args: []
  expected: 23

invariant concurrent_futures_extra97.TPE_submit_qualname_len_25:
  description: "concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__len__() == 25 — ThreadPoolExecutor.submit.__qualname__ is 'ThreadPoolExecutor.submit' (25 chars: len('ThreadPoolExecutor')=18 + 1 (dot) + len('submit')=6 = 25); submit is defined in ThreadPoolExecutor itself (Lib/concurrent/futures/thread.py), not inherited from Executor; compare with ProcessPoolExecutor.submit.__qualname__.__len__()==26 (one more because 'ProcessPoolExecutor' is 19 chars vs 18); Executor.submit.__qualname__.__len__() is 15 ('Executor.submit'); ThreadPoolExecutor.submit.__class__.__name__ is 'function'; ThreadPoolExecutor.submit.__module__ is 'concurrent.futures.thread' (the thread submodule, not _base); NEW in extra97: first standalone TPE.submit qualname length invariant in cftpequalname97 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ThreadPoolExecutor.submit.__qualname__.__len__"
  args: []
  expected: 25

invariant concurrent_futures_extra97.Future_set_exception_qualname_len_20:
  description: "concurrent.futures.Future.set_exception.__qualname__.__len__() == 20 — Future.set_exception.__qualname__ is 'Future.set_exception' (20 chars: 'Future.'=7 + 'set_exception'=13); this is 3 chars longer than Future.set_result.__qualname__.__len__()==17 ('Future.set_result' = 'Future.'=7 + 'set_result'=10); both set_result and set_exception are defined in Lib/concurrent/futures/_base.py; both have class='function' (pure-Python); Future.set_exception.__module__ is 'concurrent.futures._base'; Future.set_exception raises InvalidStateError if the future is already resolved; Future.set_result similarly raises InvalidStateError if already resolved; NEW in extra97: first standalone Future.set_exception qualname length invariant in cftpequalname97 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Future.set_exception.__qualname__.__len__"
  args: []
  expected: 20

invariant concurrent_futures_extra97.PPE_shutdown_qualname_len_28:
  description: "concurrent.futures.ProcessPoolExecutor.shutdown.__qualname__.__len__() == 28 — ProcessPoolExecutor.shutdown.__qualname__ is 'ProcessPoolExecutor.shutdown' (28 chars: 'ProcessPoolExecutor.'=20 + 'shutdown'=8); this is the longest shutdown qualname across the executor hierarchy: Executor.shutdown.__qualname__.__len__() would be 'Executor.shutdown'=17, ThreadPoolExecutor.shutdown.__qualname__.__len__() is 27, ProcessPoolExecutor.shutdown.__qualname__.__len__() is 28; ProcessPoolExecutor.shutdown is defined in Lib/concurrent/futures/process.py; ProcessPoolExecutor.shutdown.__class__.__name__ is 'function'; NEW in extra97: first standalone PPE.shutdown qualname length invariant in cftpequalname97 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ProcessPoolExecutor.shutdown.__qualname__.__len__"
  args: []
  expected: 28
