spec: binary_to_decimal
version: ">=1.0.9"
backend: node(binary-to-decimal)

docs: https://www.npmjs.com/package/binary-to-decimal

provenance:
  derived_from:
    - "binary-to-decimal README — https://www.npmjs.com/package/binary-to-decimal"
    - "Test vectors verified with binary-to-decimal via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "binary-to-decimal source"
  notes:
    - "binary-to-decimal is an npm package. Install: npm install binary-to-decimal"
    - "Exports a named 'decimal' function that converts a binary string to a decimal integer."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table binary_to_decimal.decimal:
  kind: node_module_call_eq
  function: decimal
  category: numbers
  id_prefix: b2dec

  columns: [id, args, expected]
  rows:
    - [zero,        ["0"],        0]
    - [one,         ["1"],        1]
    - [four,        ["100"],      4]
    - [ten,         ["1010"],     10]
    - [twofiftyfive, ["11111111"], 255]
