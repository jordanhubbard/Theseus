spec: asyncio_extra188
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "asyncio.Lock.__name__ == 'Lock' (len=4); __module__ == 'asyncio.locks'; __qualname__ == 'Lock'."
    - "asyncio.Lock.__bases__[0].__name__ == '_ContextManagerMixin' — Lock's first base class."
    - "asyncio.Event.__name__ == 'Event' (len=5); __module__ == 'asyncio.locks'; __qualname__ == 'Event'."
    - "asyncio.Event.__bases__[0].__name__ == '_LoopBoundMixin' — Event's sole base class."
    - "Length ordering: Lock(4) < Event(5)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.Lock class identity — name, module, qualname
#
# asyncio.Lock.__name__.__eq__('Lock') == True (len=4)
# asyncio.Lock.__module__.__eq__('asyncio.locks') == True
# asyncio.Lock.__qualname__.__eq__('Lock') == True
# ---------------------------------------------------------------------------

table asyncio_extra188.lock_identity:
  description: "asyncio.Lock name (len=4), module (asyncio.locks), and qualname identity; new to asyncio_extra188"
  kind: python_call_eq
  category: identity
  id_prefix: asynciolock188

  columns: [id, function, args, expected, description]
  rows:
    - [lock_name_eq,
       Lock.__name__.__eq__,
       ["Lock"],
       true,
       "asyncio.Lock.__name__.__eq__('Lock') == True — class name string identity; str.__eq__ returns True; new to asyncio_extra188"]
    - [lock_name_len_4,
       Lock.__name__.__len__,
       [],
       4,
       "asyncio.Lock.__name__.__len__() == 4 — 'Lock' has 4 characters: L-o-c-k; str.__len__() returns 4; new to asyncio_extra188"]
    - [lock_module_eq,
       Lock.__module__.__eq__,
       ["asyncio.locks"],
       true,
       "asyncio.Lock.__module__.__eq__('asyncio.locks') == True — Lock is defined in asyncio.locks submodule; str.__eq__ returns True; new to asyncio_extra188"]
    - [lock_qualname_eq,
       Lock.__qualname__.__eq__,
       ["Lock"],
       true,
       "asyncio.Lock.__qualname__.__eq__('Lock') == True — top-level class so qualname equals simple name; str.__eq__ returns True; new to asyncio_extra188"]
    - [lock_bases0_name_eq,
       "Lock.__bases__[0].__name__.__eq__",
       ["_ContextManagerMixin"],
       true,
       "asyncio.Lock.__bases__[0].__name__.__eq__('_ContextManagerMixin') == True — Lock's first base class is _ContextManagerMixin; str.__eq__ returns True; new to asyncio_extra188"]

# ---------------------------------------------------------------------------
# Table 2: asyncio.Event class identity — name, module, qualname
#
# asyncio.Event.__name__.__eq__('Event') == True (len=5)
# asyncio.Event.__module__.__eq__('asyncio.locks') == True
# asyncio.Event.__qualname__.__eq__('Event') == True
# ---------------------------------------------------------------------------

table asyncio_extra188.event_identity:
  description: "asyncio.Event name (len=5), module (asyncio.locks), and qualname identity; new to asyncio_extra188"
  kind: python_call_eq
  category: identity
  id_prefix: asynciolock188

  columns: [id, function, args, expected, description]
  rows:
    - [event_name_eq,
       Event.__name__.__eq__,
       ["Event"],
       true,
       "asyncio.Event.__name__.__eq__('Event') == True — class name string identity; str.__eq__ returns True; new to asyncio_extra188"]
    - [event_name_len_5,
       Event.__name__.__len__,
       [],
       5,
       "asyncio.Event.__name__.__len__() == 5 — 'Event' has 5 characters: E-v-e-n-t; str.__len__() returns 5; new to asyncio_extra188"]
    - [event_module_eq,
       Event.__module__.__eq__,
       ["asyncio.locks"],
       true,
       "asyncio.Event.__module__.__eq__('asyncio.locks') == True — Event is defined in asyncio.locks submodule; str.__eq__ returns True; new to asyncio_extra188"]
    - [event_qualname_eq,
       Event.__qualname__.__eq__,
       ["Event"],
       true,
       "asyncio.Event.__qualname__.__eq__('Event') == True — top-level class so qualname equals simple name; str.__eq__ returns True; new to asyncio_extra188"]
    - [event_bases0_name_eq,
       "Event.__bases__[0].__name__.__eq__",
       ["_LoopBoundMixin"],
       true,
       "asyncio.Event.__bases__[0].__name__.__eq__('_LoopBoundMixin') == True — Event's sole base class is _LoopBoundMixin; str.__eq__ returns True; new to asyncio_extra188"]

# ---------------------------------------------------------------------------
# Table 3: asyncio.Lock vs asyncio.Event name length ordering
#
# Lock(4) < Event(5) — length ordering anchor
# ---------------------------------------------------------------------------

table asyncio_extra188.lock_event_length_ordering:
  description: "asyncio.Lock and asyncio.Event name length ordering: Lock(4) < Event(5); new to asyncio_extra188"
  kind: python_call_eq
  category: identity
  id_prefix: asynciolock188

  columns: [id, function, args, expected, description]
  rows:
    - [lock_name_len_ordering,
       Lock.__name__.__len__,
       [],
       4,
       "asyncio.Lock.__name__.__len__() == 4 — ordering anchor: Lock(4) is shorter than Event(5); str.__len__() returns 4; new to asyncio_extra188"]
    - [event_name_len_ordering,
       Event.__name__.__len__,
       [],
       5,
       "asyncio.Event.__name__.__len__() == 5 — ordering ceiling: Lock(4) < Event(5); str.__len__() returns 5; new to asyncio_extra188"]
    - [lock_module_len_eq,
       Lock.__module__.__len__,
       [],
       13,
       "asyncio.Lock.__module__.__len__() == 13 — 'asyncio.locks' has 13 characters; str.__len__() returns 13; new to asyncio_extra188"]
    - [event_module_len_eq,
       Event.__module__.__len__,
       [],
       13,
       "asyncio.Event.__module__.__len__() == 13 — 'asyncio.locks' has 13 characters; same module as Lock; str.__len__() returns 13; new to asyncio_extra188"]
    - [lock_qualname_len_eq,
       Lock.__qualname__.__len__,
       [],
       4,
       "asyncio.Lock.__qualname__.__len__() == 4 — qualname is 'Lock', same length as __name__; str.__len__() returns 4; new to asyncio_extra188"]

