invariant asyncio_extra188.lock_name_eq:
  description: "asyncio.Lock.__name__.__eq__('Lock') == True — class name identity; len=4; new to asyncio_extra188"
  category: identity
  kind: python_call_eq
  function: Lock.__name__.__eq__
  args: ["Lock"]
  expected: true

