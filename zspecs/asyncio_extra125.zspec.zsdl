    - [ct_co_argc,     asyncio.create_task.__code__.co_argcount.__eq__,     [1],                true, "asyncio.create_task.__code__.co_argcount == 1 (coro); verified with Python 3.14.3"]
    - [ct_co_varlen,   asyncio.create_task.__code__.co_varnames.__len__,    [],                 3,    "asyncio.create_task.__code__.co_varnames.__len__() == 3 (coro, kwargs, loop); verified with Python 3.14.3"]
    - [ct_module_eq,   asyncio.create_task.__module__.__eq__,               ["asyncio.tasks"],  true, "asyncio.create_task.__module__ == 'asyncio.tasks' (all four functions in same module); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra125
# ---------------------------------------------------------------------------

invariant asyncio_extra125.gather_co_argcount_is_0:
  description: "asyncio.gather.__code__.co_argcount.__eq__(0) returns True — asyncio.gather is defined as 'async def gather(*coros_or_futures, return_exceptions=False)'; co_argcount counts only regular positional parameters (those before any * or *args); since gather's only explicit param before the variadic is none (the *coros_or_futures is the variadic itself), co_argcount==0; this contrasts with asyncio.sleep (co_argcount==2: delay, result) and asyncio.wait (co_argcount==1: fs); asyncio.gather.__code__.co_varnames[0] is 'return_exceptions' (the keyword-only default that appears first in co_varnames ordering despite not being a positional param); asyncio.gather.__code__.co_varnames.__len__() is 9; NEW in extra125: first standalone gather co_argcount invariant in asynciocodeattrs125 namespace; wave 255; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: asyncio.gather.__code__.co_argcount.__eq__
  args: [0]
  expected: true

invariant asyncio_extra125.gather_co_varnames_len_9:
  description: "asyncio.gather.__code__.co_varnames.__len__() == 9 — asyncio.gather has 9 co_varnames: return_exceptions, coros_or_futures, loop, cur_task, _done_callback, arg_to_fut, done_futs, arg, fut; this is the most co_varnames among the four coroutine functions in this spec (sleep=5, wait=4, create_task=3); the 9 varnames reflect the complex internal implementation of gather which tracks callbacks, futures mapping, and done futures; asyncio.gather.__code__.co_argcount is 0 (variadic pattern); asyncio.gather.__code__.co_name is 'gather' (len=6); asyncio.gather.__module__ is 'asyncio.tasks'; NEW in extra125: first standalone gather co_varnames length invariant in asynciocodeattrs125 namespace; wave 255; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: asyncio.gather.__code__.co_varnames.__len__
  args: []
  expected: 9

invariant asyncio_extra125.sleep_co_argcount_is_2:
  description: "asyncio.sleep.__code__.co_argcount.__eq__(2) returns True — asyncio.sleep is defined as 'async def sleep(delay, result=None)' with two positional parameters: delay (required) and result (optional, default None); co_argcount counts both positional params regardless of whether they have defaults; asyncio.sleep.__code__.co_varnames[0] is 'delay'; asyncio.sleep.__code__.co_varnames.__len__() is 5 (delay, result, loop, future, h); compare co_argcount values: gather=0, sleep=2, wait=1, create_task=1; sleep has the highest co_argcount (2) among the four functions; sleep.__code__.co_name is 'sleep' (len=5); NEW in extra125: first standalone sleep co_argcount invariant in asynciocodeattrs125 namespace; wave 255; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: asyncio.sleep.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant asyncio_extra125.wait_co_varnames_0_is_fs:
  description: "asyncio.wait.__code__.co_varnames.__getitem__(0).__eq__('fs') returns 'fs' — asyncio.wait.__code__.co_varnames[0] is 'fs' (len=2: the shortest first varname in this spec; gather[0]='return_exceptions'=17 chars, sleep[0]='delay'=5 chars, wait[0]='fs'=2 chars, create_task[0]='coro'=4 chars); wait is defined as 'async def wait(fs, *, timeout=None, return_when=ALL_COMPLETED)' with 'fs' as the single positional parameter (an iterable of awaitables); asyncio.wait.__code__.co_argcount is 1; asyncio.wait.__code__.co_varnames.__len__() is 4 (fs, timeout, return_when, loop); asyncio.wait.__module__ is 'asyncio.tasks'; NEW in extra125: first standalone wait co_varnames[0] invariant in asynciocodeattrs125 namespace; wave 255; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: asyncio.wait.__code__.co_varnames.__getitem__
  args: [0]
  expected: "fs"

invariant asyncio_extra125.create_task_co_name_len_11:
  description: "asyncio.create_task.__code__.co_name.__len__() == 11 — asyncio.create_task.__code__.co_name is 'create_task' (11 chars: 'create'=6 + '_'=1 + 'task'=4 = 11); this is the longest co_name among the four asyncio coroutine functions in this spec: wait=4, sleep=5, gather=6, create_task=11; asyncio.create_task is defined as 'def create_task(coro, **kwargs)' (not async itself, but creates a Task coroutine); asyncio.create_task.__code__.co_argcount is 1 (coro); asyncio.create_task.__code__.co_varnames.__len__() is 3 (coro, kwargs, loop); asyncio.create_task.__qualname__ is 'create_task' (len=11, module-level); asyncio.create_task.__module__ is 'asyncio.tasks'; NEW in extra125: first standalone create_task co_name length invariant in asynciocodeattrs125 namespace; wave 255; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: asyncio.create_task.__code__.co_name.__len__
  args: []
  expected: 11
