spec: asyncio_extra125
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
  notes:
    - "This spec covers: wave 255 theme — asyncio module-level coroutine function __code__ attributes for gather, sleep, and wait. NEW in extra125: asyncio.gather.__code__.co_name=='gather' (len=6); asyncio.gather.__code__.co_argcount==0 (gather takes only *coros_or_futures variadic arg); asyncio.gather.__code__.co_varnames[0]=='return_exceptions' (the keyword-only default arg comes first in co_varnames); asyncio.gather.__code__.co_varnames.__len__()==9; asyncio.sleep.__code__.co_name=='sleep' (len=5); asyncio.sleep.__code__.co_argcount==2 (delay, result); asyncio.sleep.__code__.co_varnames[0]=='delay'; asyncio.sleep.__code__.co_varnames.__len__()==5; asyncio.wait.__code__.co_name=='wait' (len=4); asyncio.wait.__code__.co_argcount==1 (fs); asyncio.wait.__code__.co_varnames[0]=='fs'; asyncio.wait.__code__.co_varnames.__len__()==4; asyncio.create_task.__code__.co_name=='create_task' (len=11); asyncio.create_task.__code__.co_argcount==1. All are Python coroutine functions (class='function') in asyncio.tasks module. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.gather.__code__.co_argcount == 0. gather is defined as 'async def gather(*coros_or_futures, return_exceptions=False)' — the *args parameter is NOT counted by co_argcount (only positional parameters before *args are counted); so co_argcount==0 while co_varnames[0] is 'return_exceptions' (the keyword-only default that appears first in co_varnames ordering). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.gather.__code__.co_varnames.__len__() == 9. The 9 varnames are: return_exceptions, coros_or_futures, loop, cur_task, _done_callback, arg_to_fut, done_futs, arg, fut. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.sleep.__code__.co_argcount == 2. sleep is defined as 'async def sleep(delay, result=None)' — two positional parameters: delay and result. co_varnames[0]=='delay'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.wait.__code__.co_argcount == 1. wait is defined as 'async def wait(fs, *, timeout=None, return_when=ALL_COMPLETED)' — one positional parameter: fs. co_varnames[0]=='fs'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.gather __code__ attributes — extra125
#
# Wave 255 theme: asyncio coroutine function __code__ attributes.
#
# asyncio.gather.__code__.co_name          == 'gather'            (len=6)
# asyncio.gather.__code__.co_argcount      == 0                   (*coros variadic, not counted)
# asyncio.gather.__code__.co_varnames[0]   == 'return_exceptions' (len=17)
# asyncio.gather.__code__.co_varnames.__len__() == 9
# asyncio.gather.__qualname__              == 'gather'            (len=6)
# asyncio.gather.__module__                == 'asyncio.tasks'
# ---------------------------------------------------------------------------

table asyncio_extra125.asyncio_gather_code_attrs:
  description: "asyncio.gather __code__ attribute checks in asynciocodeattrs125 namespace — wave 255 theme: asyncio.gather is a coroutine function (class='function') defined in Lib/asyncio/tasks.py; asyncio.gather.__code__.co_name.__eq__('gather')==True (len=6: the code object name matches the function name); asyncio.gather.__code__.co_name.__len__()==6; asyncio.gather.__code__.co_argcount.__eq__(0)==True (gather is defined as 'async def gather(*coros_or_futures, return_exceptions=False)'; the *args variadic is not counted by co_argcount — only positional params before *args are counted; since there are none, co_argcount==0); asyncio.gather.__code__.co_varnames.__getitem__(0).__eq__('return_exceptions')==True (first varname is 'return_exceptions', len=17, appearing first in co_varnames even though it is a keyword-only default param); asyncio.gather.__code__.co_varnames.__len__()==9 (9 total varnames: return_exceptions, coros_or_futures, loop, cur_task, _done_callback, arg_to_fut, done_futs, arg, fut); asyncio.gather.__qualname__.__eq__('gather')==True (len=6, module-level function so qualname equals name); asyncio.gather.__module__.__eq__('asyncio.tasks')==True (defined in Lib/asyncio/tasks.py); asyncio.gather.__class__.__name__.__eq__('function')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_inspection
  id_prefix: asynciocodeattrs125

  columns: [id, function, args, expected, description]
  rows:
    - [g_co_name_eq,  asyncio.gather.__code__.co_name.__eq__,                      ["gather"],             true, "asyncio.gather.__code__.co_name == 'gather' (len=6, matches function name); verified with Python 3.14.3"]
    - [g_co_name_len, asyncio.gather.__code__.co_name.__len__,                      [],                     6,    "asyncio.gather.__code__.co_name.__len__() == 6; verified with Python 3.14.3"]
    - [g_co_argc,     asyncio.gather.__code__.co_argcount.__eq__,                   [0],                    true, "asyncio.gather.__code__.co_argcount == 0 (*coros variadic not counted by co_argcount); verified with Python 3.14.3"]
    - [g_co_var0,     asyncio.gather.__code__.co_varnames.__getitem__,              [0],                    "return_exceptions", "asyncio.gather.__code__.co_varnames[0] == 'return_exceptions' (len=17, first co_varname); verified with Python 3.14.3"]
    - [g_co_varlen,   asyncio.gather.__code__.co_varnames.__len__,                  [],                     9,    "asyncio.gather.__code__.co_varnames.__len__() == 9 (return_exceptions, coros_or_futures, + 7 locals); verified with Python 3.14.3"]
    - [g_qualname_eq, asyncio.gather.__qualname__.__eq__,                           ["gather"],             true, "asyncio.gather.__qualname__ == 'gather' (len=6, module-level function); verified with Python 3.14.3"]
    - [g_module_eq,   asyncio.gather.__module__.__eq__,                             ["asyncio.tasks"],      true, "asyncio.gather.__module__ == 'asyncio.tasks' (defined in Lib/asyncio/tasks.py); verified with Python 3.14.3"]
    - [g_cls_eq,      asyncio.gather.__class__.__name__.__eq__,                     ["function"],           true, "asyncio.gather.__class__.__name__ == 'function' (pure-Python coroutine function); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.sleep __code__ attributes — extra125
#
# asyncio.sleep.__code__.co_name          == 'sleep'   (len=5)
# asyncio.sleep.__code__.co_argcount      == 2         (delay, result)
# asyncio.sleep.__code__.co_varnames[0]   == 'delay'   (len=5)
# asyncio.sleep.__code__.co_varnames.__len__() == 5
# asyncio.sleep.__qualname__              == 'sleep'   (len=5)
# asyncio.sleep.__module__                == 'asyncio.tasks'
# ---------------------------------------------------------------------------

table asyncio_extra125.asyncio_sleep_code_attrs:
  description: "asyncio.sleep __code__ attribute checks in asynciocodeattrs125 namespace — wave 255 theme: asyncio.sleep is a coroutine function (class='function') in Lib/asyncio/tasks.py; asyncio.sleep.__code__.co_name.__eq__('sleep')==True (len=5, one less than gather's co_name length of 6); asyncio.sleep.__code__.co_name.__len__()==5; asyncio.sleep.__code__.co_argcount.__eq__(2)==True (sleep is defined as 'async def sleep(delay, result=None)' with two positional parameters: delay and result); asyncio.sleep.__code__.co_varnames.__getitem__(0).__eq__('delay')==True (first varname is the first positional param 'delay', len=5); asyncio.sleep.__code__.co_varnames.__len__()==5 (5 total varnames: delay, result, loop, future, h); asyncio.sleep.__qualname__.__eq__('sleep')==True (len=5, module-level function); asyncio.sleep.__module__.__eq__('asyncio.tasks')==True (same module as gather and wait); asyncio.sleep.__class__.__name__.__eq__('function')==True; contrast with asyncio.gather which has co_argcount==0 (variadic) while sleep has co_argcount==2 (two positional params); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_inspection
  id_prefix: asynciocodeattrs125a

  columns: [id, function, args, expected, description]
  rows:
    - [s_co_name_eq,  asyncio.sleep.__code__.co_name.__eq__,               ["sleep"],          true, "asyncio.sleep.__code__.co_name == 'sleep' (len=5, one less than gather's 6); verified with Python 3.14.3"]
    - [s_co_name_len, asyncio.sleep.__code__.co_name.__len__,               [],                 5,    "asyncio.sleep.__code__.co_name.__len__() == 5; verified with Python 3.14.3"]
    - [s_co_argc,     asyncio.sleep.__code__.co_argcount.__eq__,            [2],                true, "asyncio.sleep.__code__.co_argcount == 2 (delay, result); verified with Python 3.14.3"]
    - [s_co_var0,     asyncio.sleep.__code__.co_varnames.__getitem__,       [0],                "delay", "asyncio.sleep.__code__.co_varnames[0] == 'delay' (first positional param, len=5); verified with Python 3.14.3"]
    - [s_co_varlen,   asyncio.sleep.__code__.co_varnames.__len__,           [],                 5,    "asyncio.sleep.__code__.co_varnames.__len__() == 5 (delay, result, loop, future, h); verified with Python 3.14.3"]
    - [s_qualname_eq, asyncio.sleep.__qualname__.__eq__,                    ["sleep"],          true, "asyncio.sleep.__qualname__ == 'sleep' (len=5, module-level); verified with Python 3.14.3"]
    - [s_module_eq,   asyncio.sleep.__module__.__eq__,                      ["asyncio.tasks"],  true, "asyncio.sleep.__module__ == 'asyncio.tasks' (same as gather and wait); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
