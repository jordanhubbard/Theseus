# asyncio.create_task.__code__.co_name   == 'create_task' (len=11)
# asyncio.create_task.__code__.co_argcount == 1           (coro)
# asyncio.create_task.__code__.co_varnames.__len__() == 3
# ---------------------------------------------------------------------------

table asyncio_extra125.asyncio_wait_create_task_code_attrs:
  description: "asyncio.wait and asyncio.create_task __code__ attribute checks in asynciocodeattrs125 namespace — wave 255 theme: asyncio.wait.__code__.co_name.__eq__('wait')==True (len=4, the shortest co_name among gather/sleep/wait: gather=6, sleep=5, wait=4); asyncio.wait.__code__.co_name.__len__()==4; asyncio.wait.__code__.co_argcount.__eq__(1)==True (wait is defined as 'async def wait(fs, *, timeout=None, return_when=ALL_COMPLETED)' with one positional parameter: fs; the keyword-only args timeout and return_when are not counted by co_argcount); asyncio.wait.__code__.co_varnames.__getitem__(0).__eq__('fs')==True (first varname is 'fs', len=2, the shortest first co_varname in this spec); asyncio.wait.__code__.co_varnames.__len__()==4 (4 total varnames: fs, timeout, return_when, loop); asyncio.wait.__module__.__eq__('asyncio.tasks')==True; asyncio.create_task.__code__.co_name.__eq__('create_task')==True (len=11, the longest co_name in this spec: create_task=11 vs gather=6, sleep=5, wait=4); asyncio.create_task.__code__.co_argcount.__eq__(1)==True (one positional param: coro); asyncio.create_task.__code__.co_varnames.__len__()==3 (3 varnames: coro, kwargs, loop); asyncio.create_task.__module__.__eq__('asyncio.tasks')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_inspection
  id_prefix: asynciocodeattrs125b

  columns: [id, function, args, expected, description]
  rows:
    - [w_co_name_eq,   asyncio.wait.__code__.co_name.__eq__,               ["wait"],           true, "asyncio.wait.__code__.co_name == 'wait' (len=4, shortest co_name in spec); verified with Python 3.14.3"]
    - [w_co_name_len,  asyncio.wait.__code__.co_name.__len__,               [],                 4,    "asyncio.wait.__code__.co_name.__len__() == 4; verified with Python 3.14.3"]
    - [w_co_argc,      asyncio.wait.__code__.co_argcount.__eq__,            [1],                true, "asyncio.wait.__code__.co_argcount == 1 (only fs; keyword-only timeout and return_when not counted); verified with Python 3.14.3"]
    - [w_co_var0,      asyncio.wait.__code__.co_varnames.__getitem__,       [0],                "fs", "asyncio.wait.__code__.co_varnames[0] == 'fs' (len=2, shortest first varname in spec); verified with Python 3.14.3"]
    - [w_co_varlen,    asyncio.wait.__code__.co_varnames.__len__,           [],                 4,    "asyncio.wait.__code__.co_varnames.__len__() == 4 (fs, timeout, return_when, loop); verified with Python 3.14.3"]
    - [w_module_eq,    asyncio.wait.__module__.__eq__,                      ["asyncio.tasks"],  true, "asyncio.wait.__module__ == 'asyncio.tasks'; verified with Python 3.14.3"]
