spec: struct_extra188
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "struct.error.__name__ == 'error' — the exception class uses a lowercase name."
    - "struct.error.__module__ == 'struct' — the exception is attributed to the pure-Python struct module, not _struct."
    - "struct.error.__bases__[0].__name__ == 'Exception' — struct.error inherits directly from Exception, not ValueError or OSError."
    - "struct.error.__class__.__name__ == 'type' — struct.error is a class object."
    - "struct.__name__ == 'struct' and struct.__package__ == '' — top-level stdlib module."
    - "struct.__spec__.name == 'struct' — the ModuleSpec .name attribute (not .__name__) holds the module name."
    - "struct.error.__qualname__ == 'error' — no class nesting in the struct module."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.error exception class — name, module, qualname
# ---------------------------------------------------------------------------

table structerror188.error.identity:
  kind: python_call_eq
  category: class_identity
  id_prefix: structerror188

  columns: [id, function, args, expected, description]
  rows:
    - [error_name,     error.__name__.__eq__,     ["error"],  true, "struct.error.__name__ == 'error'"]
    - [error_module,   error.__module__.__eq__,   ["struct"], true, "struct.error.__module__ == 'struct'"]
    - [error_qualname, error.__qualname__.__eq__,  ["error"],  true, "struct.error.__qualname__ == 'error'"]

# ---------------------------------------------------------------------------
# struct.error base class and metaclass
# ---------------------------------------------------------------------------

table structerror188.error.bases:
  kind: python_call_eq
  category: class_identity
  id_prefix: structerror188

  columns: [id, function, args, expected, description]
  rows:
    - [error_class_name, error.__class__.__name__.__eq__, ["type"], true, "struct.error.__class__.__name__ == 'type' (struct.error is a class)"]

# ---------------------------------------------------------------------------
# struct module identity — __name__, __package__, __spec__.name
# ---------------------------------------------------------------------------

table structerror188.module_identity:
  kind: python_call_eq
  category: module_identity
  id_prefix: structerror188

  columns: [id, function, args, expected, description]
  rows:
    - [module_name,      __name__.__eq__,          ["struct"], true, "struct.__name__ == 'struct'"]
    - [module_package,   __package__.__eq__,        [""],       true, "struct.__package__ == ''"]
    - [spec_name,        __spec__.name.__eq__,      ["struct"], true, "struct.__spec__.name == 'struct'"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant structerror188.error.name:
  description: "struct.error.__name__ == 'error'"
  category: class_identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

invariant structerror188.error.module:
  description: "struct.error.__module__ == 'struct'"
  category: class_identity
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["struct"]
  expected: true

invariant structerror188.error.bases_exception:
  description: "struct.error.__bases__[0].__name__ == 'Exception' — struct.error inherits from Exception"
  category: class_identity
  kind: python_call_eq
  function: error.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant structerror188.error.class_name:
  description: "struct.error.__class__.__name__ == 'type' — struct.error is a class object"
  category: class_identity
  kind: python_call_eq
  function: error.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant structerror188.module.name:
  description: "struct.__name__ == 'struct'"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["struct"]
  expected: true

invariant structerror188.module.package:
  description: "struct.__package__ == '' (top-level stdlib module, no package prefix)"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant structerror188.module.spec_name:
  description: "struct.__spec__.name == 'struct' — ModuleSpec .name attribute holds the module name"
  category: module_identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["struct"]
  expected: true

invariant structerror188.error.qualname:
  description: "struct.error.__qualname__ == 'error' — no class nesting in the struct module"
  category: class_identity
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["error"]
  expected: true

