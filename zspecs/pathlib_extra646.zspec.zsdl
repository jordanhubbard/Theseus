spec: pathlib_extra646
version: ">=3.9"
backend: python_module(pathlib)
docs: "Behavioral spec for pathlib.PurePosixPath, PureWindowsPath, and PurePath method qualnames and __doc__ class identity."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module class and method reference"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Qualname strings reflect standard CPython class hierarchy naming."
    - "PurePath.joinpath, is_absolute, is_relative_to, and relative_to are inherited by all PurePath subclasses."
  created_at: "2026-04-12T00:00:00Z"

table pathlib_extra646.purepath_subclass_qualnames:
  description: "Qualnames of PurePosixPath and PureWindowsPath __init__ and __str__ methods."
  kind: python_call_eq
  category: qualname
  id_prefix: pl646qn
  columns: [id, function, args, expected]
  rows:
    - [pl646qn001, pathlib.PurePosixPath.__init__.__qualname__.__eq__, ["PurePosixPath.__init__"], true]
    - [pl646qn002, pathlib.PurePosixPath.__str__.__qualname__.__eq__, ["PurePosixPath.__str__"], true]
    - [pl646qn003, pathlib.PureWindowsPath.__init__.__qualname__.__eq__, ["PureWindowsPath.__init__"], true]
    - [pl646qn004, pathlib.PureWindowsPath.__str__.__qualname__.__eq__, ["PureWindowsPath.__str__"], true]

table pathlib_extra646.doc_class_names:
  description: "Class name of __doc__ attribute for pathlib public classes."
  kind: python_call_eq
  category: doc_type
  id_prefix: pl646dc
  columns: [id, function, args, expected]
  rows:
    - [pl646dc001, pathlib.PurePath.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [pl646dc002, pathlib.Path.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [pl646dc003, pathlib.PosixPath.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [pl646dc004, pathlib.WindowsPath.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [pl646dc005, pathlib.PurePosixPath.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [pl646dc006, pathlib.PureWindowsPath.__doc__.__class__.__name__.__eq__, ["str"], true]

table pathlib_extra646.purepath_method_qualnames:
  description: "Qualnames of PurePath navigation and predicate methods."
  kind: python_call_eq
  category: qualname
  id_prefix: pl646mt
  columns: [id, function, args, expected]
  rows:
    - [pl646mt001, pathlib.PurePath.joinpath.__qualname__.__eq__, ["PurePath.joinpath"], true]
    - [pl646mt002, pathlib.PurePath.is_absolute.__qualname__.__eq__, ["PurePath.is_absolute"], true]
    - [pl646mt003, pathlib.PurePath.is_relative_to.__qualname__.__eq__, ["PurePath.is_relative_to"], true]
    - [pl646mt004, pathlib.PurePath.relative_to.__qualname__.__eq__, ["PurePath.relative_to"], true]
