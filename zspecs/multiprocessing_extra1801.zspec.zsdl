spec: multiprocessing_extra1801
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/multiprocessing.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 567 (_extra1801): __bool__/__len__ truth-value and context manager protocol dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table multiprocessing_extra1801.truth_protocol:
  description: "multiprocessing types __bool__ and __len__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1801

  columns: [id, function, args, expected]
  rows:
    - ["mp1801001", "multiprocessing.Process.__dict__.__contains__", ["__bool__"], false]
    - ["mp1801002", "multiprocessing.Process.__dict__.__contains__", ["__len__"], false]
    - ["mp1801003", "multiprocessing.pool.Pool.__dict__.__contains__", ["__bool__"], false]
    - ["mp1801004", "multiprocessing.pool.Pool.__dict__.__contains__", ["__len__"], false]

table multiprocessing_extra1801.context_manager_protocol:
  description: "multiprocessing context manager protocol dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1801

  columns: [id, function, args, expected]
  rows:
    - ["mp1801005", "multiprocessing.pool.Pool.__dict__.__contains__", ["__enter__"], true]
    - ["mp1801006", "multiprocessing.pool.Pool.__dict__.__contains__", ["__exit__"], true]
    - ["mp1801007", "multiprocessing.Process.__dict__.__contains__", ["__enter__"], false]
    - ["mp1801008", "multiprocessing.Process.__dict__.__contains__", ["__exit__"], false]
    - ["mp1801009", "multiprocessing.managers.BaseManager.__dict__.__contains__", ["__enter__"], true]
    - ["mp1801010", "multiprocessing.managers.BaseManager.__dict__.__contains__", ["__exit__"], true]

table multiprocessing_extra1801.process_attrs:
  description: "multiprocessing Process attribute dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1801

  columns: [id, function, args, expected]
  rows:
    - ["mp1801011", "multiprocessing.Process.__dict__.__contains__", ["start"], true]
    - ["mp1801012", "multiprocessing.Process.__dict__.__contains__", ["run"], true]
    - ["mp1801013", "multiprocessing.Process.__dict__.__contains__", ["join"], true]
    - ["mp1801014", "multiprocessing.Process.__dict__.__contains__", ["terminate"], true]
    - ["mp1801015", "multiprocessing.Process.__dict__.__contains__", ["kill"], true]
    - ["mp1801016", "multiprocessing.Process.__dict__.__contains__", ["is_alive"], true]
    - ["mp1801017", "multiprocessing.Process.__dict__.__contains__", ["pid"], true]
    - ["mp1801018", "multiprocessing.Process.__dict__.__contains__", ["exitcode"], true]
    - ["mp1801019", "multiprocessing.Process.__dict__.__contains__", ["name"], true]
    - ["mp1801020", "multiprocessing.Process.__dict__.__contains__", ["daemon"], true]
