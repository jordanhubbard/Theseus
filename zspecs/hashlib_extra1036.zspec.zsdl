spec: hashlib_extra1036
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks hashlib function __reduce__.__qualname__ and module __doc__ class identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra1036.hash_constructor_reduce_qualnames:
  description: "hashlib hash constructor __reduce__.__qualname__ identity"
  kind: python_call_eq
  category: reduce_qualnames
  id_prefix: hl1036x
  columns: [id, function, args, expected]
  rows:
    - [hl1036x001, hashlib.md5.__reduce__.__qualname__.__eq__,        ["md5.__reduce__"],        true]
    - [hl1036x002, hashlib.sha256.__reduce__.__qualname__.__eq__,     ["sha256.__reduce__"],     true]
    - [hl1036x003, hashlib.sha512.__reduce__.__qualname__.__eq__,     ["sha512.__reduce__"],     true]
    - [hl1036x004, hashlib.new.__reduce__.__qualname__.__eq__,        ["new.__reduce__"],        true]
    - [hl1036x005, hashlib.pbkdf2_hmac.__reduce__.__qualname__.__eq__, ["pbkdf2_hmac.__reduce__"], true]

table hashlib_extra1036.hash_sizeof_qualnames:
  description: "hashlib hash function __sizeof__.__qualname__ identity"
  kind: python_call_eq
  category: sizeof_qualnames
  id_prefix: hl1036s
  columns: [id, function, args, expected]
  rows:
    - [hl1036s001, hashlib.md5.__sizeof__.__qualname__.__eq__,        ["md5.__sizeof__"],        true]
    - [hl1036s002, hashlib.sha256.__sizeof__.__qualname__.__eq__,     ["sha256.__sizeof__"],     true]
    - [hl1036s003, hashlib.sha512.__sizeof__.__qualname__.__eq__,     ["sha512.__sizeof__"],     true]
    - [hl1036s004, hashlib.new.__sizeof__.__qualname__.__eq__,        ["new.__sizeof__"],        true]
    - [hl1036s005, hashlib.pbkdf2_hmac.__sizeof__.__qualname__.__eq__, ["pbkdf2_hmac.__sizeof__"], true]

table hashlib_extra1036.module_doc_class_identity:
  description: "hashlib module __doc__ class identity and module-level attribute checks"
  kind: python_call_eq
  category: module_identity
  id_prefix: hl1036m
  columns: [id, function, args, expected]
  rows:
    - [hl1036m001, hashlib.__doc__.__class__.__name__.__eq__,         ["str"],     true]
    - [hl1036m002, hashlib.__name__.__eq__,                           ["hashlib"], true]
    - [hl1036m003, hashlib.md5.__module__.__eq__,                     ["_hashlib"], true]
    - [hl1036m004, hashlib.sha256.__module__.__eq__,                  ["_hashlib"], true]
    - [hl1036m005, hashlib.new.__module__.__eq__,                     ["hashlib"], true]
