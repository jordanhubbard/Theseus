spec: re_extra1591
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — descriptor protocol checks via __dict__.__contains__ for re.Pattern, re.Match, re.error, and re.RegexFlag"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for descriptor protocol: re.Pattern and re.Match are C-level types that do not implement the descriptor protocol — they define no __get__, __set__, or __delete__ in their own __dict__"
    - "re.Pattern defines matching methods (match, search, findall, finditer, sub, subn, split, scanner) and copy protocol (__copy__, __deepcopy__); re.Match defines group extraction methods and supports __getitem__ for indexed group access"
  created_at: "2026-04-12"
error_model: python_exceptions

table re_extra1591.pattern_no_descriptor:
  description: "re.Pattern is a C-level compiled regex type, not a descriptor — it defines no __get__, __set__, or __delete__ in its own __dict__; re.error and re.RegexFlag likewise have no descriptor protocol methods"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1591pn

  columns: [id, function, args, expected]
  rows:
    - [re1591pn001, re.Pattern.__dict__.__contains__,   ["__get__"],      false]
    - [re1591pn002, re.Pattern.__dict__.__contains__,   ["__set__"],      false]
    - [re1591pn003, re.Pattern.__dict__.__contains__,   ["__delete__"],   false]
    - [re1591pn004, re.Pattern.__dict__.__contains__,   ["__set_name__"], false]
    - [re1591pn005, re.error.__dict__.__contains__,     ["__get__"],      false]
    - [re1591pn006, re.error.__dict__.__contains__,     ["__set__"],      false]
    - [re1591pn007, re.error.__dict__.__contains__,     ["__delete__"],   false]
    - [re1591pn008, re.RegexFlag.__dict__.__contains__,  ["__get__"],      false]
    - [re1591pn009, re.RegexFlag.__dict__.__contains__,  ["__set__"],      false]
    - [re1591pn010, re.RegexFlag.__dict__.__contains__,  ["__delete__"],   false]
    - [re1591pn011, re.Pattern.__dict__.__contains__,   ["__repr__"],     true]
    - [re1591pn012, re.Pattern.__dict__.__contains__,   ["__copy__"],     true]
    - [re1591pn013, re.Pattern.__dict__.__contains__,   ["__deepcopy__"], true]
    - [re1591pn014, re.Pattern.__dict__.__contains__,   ["match"],        true]
    - [re1591pn015, re.Pattern.__dict__.__contains__,   ["search"],       true]
    - [re1591pn016, re.Pattern.__dict__.__contains__,   ["findall"],      true]
    - [re1591pn017, re.Pattern.__dict__.__contains__,   ["finditer"],     true]
    - [re1591pn018, re.Pattern.__dict__.__contains__,   ["sub"],          true]
    - [re1591pn019, re.Pattern.__dict__.__contains__,   ["subn"],         true]
    - [re1591pn020, re.Pattern.__dict__.__contains__,   ["split"],        true]
    - [re1591pn021, re.Pattern.__dict__.__contains__,   ["fullmatch"],    true]
    - [re1591pn022, re.Pattern.__dict__.__contains__,   ["scanner"],      true]
    - [re1591pn023, re.Pattern.__dict__.__contains__,   ["flags"],        true]
    - [re1591pn024, re.Pattern.__dict__.__contains__,   ["groups"],       true]
    - [re1591pn025, re.Pattern.__dict__.__contains__,   ["groupindex"],   true]
    - [re1591pn026, re.Pattern.__dict__.__contains__,   ["pattern"],      true]
    - [re1591pn027, re.Pattern.__dict__.__contains__,   ["__call__"],     false]

table re_extra1591.match_no_descriptor:
  description: "re.Match is a C-level match result type, not a descriptor — it defines no __get__, __set__, or __delete__ in its own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1591mn

  columns: [id, function, args, expected]
  rows:
    - [re1591mn001, re.Match.__dict__.__contains__, ["__get__"],      false]
    - [re1591mn002, re.Match.__dict__.__contains__, ["__set__"],      false]
    - [re1591mn003, re.Match.__dict__.__contains__, ["__delete__"],   false]
    - [re1591mn004, re.Match.__dict__.__contains__, ["__set_name__"], false]
    - [re1591mn005, re.Match.__dict__.__contains__, ["__call__"],     false]
    - [re1591mn006, re.Match.__dict__.__contains__, ["__repr__"],     true]
    - [re1591mn007, re.Match.__dict__.__contains__, ["__getitem__"],  true]
    - [re1591mn008, re.Match.__dict__.__contains__, ["group"],        true]
    - [re1591mn009, re.Match.__dict__.__contains__, ["groups"],       true]
    - [re1591mn010, re.Match.__dict__.__contains__, ["groupdict"],    true]
