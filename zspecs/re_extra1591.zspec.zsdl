    - [re1591mn015, re.Match.__dict__.__contains__, ["__copy__"],     true]
    - [re1591mn016, re.Match.__dict__.__contains__, ["__deepcopy__"], true]
    - [re1591mn017, re.Match.__dict__.__contains__, ["pos"],          true]
    - [re1591mn018, re.Match.__dict__.__contains__, ["endpos"],       true]
    - [re1591mn019, re.Match.__dict__.__contains__, ["lastindex"],    true]
    - [re1591mn020, re.Match.__dict__.__contains__, ["lastgroup"],    true]
    - [re1591mn021, re.Match.__dict__.__contains__, ["regs"],         true]
    - [re1591mn022, re.Match.__dict__.__contains__, ["string"],       true]
    - [re1591mn023, re.Match.__dict__.__contains__, ["re"],           true]
    - [re1591mn024, re.Match.__dict__.__contains__, ["__iter__"],     false]
    - [re1591mn025, re.Match.__dict__.__contains__, ["__len__"],      false]

