    - [sk1441tw002, "error.__subclasshook__.__class__.__name__.__eq__",   ["builtin_function_or_method"], true, "socket.error.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'"]
    - [sk1441tw003, "timeout.__subclasshook__.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "socket.timeout.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'"]
    - [sk1441tw004, "socket.__instancecheck__.__class__.__name__.__eq__",  ["builtin_function_or_method"], true, "socket.socket.__instancecheck__.__class__.__name__ == 'builtin_function_or_method'"]
    - [sk1441tw005, "error.__instancecheck__.__class__.__name__.__eq__",   ["builtin_function_or_method"], true, "socket.error.__instancecheck__.__class__.__name__ == 'builtin_function_or_method'"]
    - [sk1441tw006, "timeout.__instancecheck__.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "socket.timeout.__instancecheck__.__class__.__name__ == 'builtin_function_or_method'"]
