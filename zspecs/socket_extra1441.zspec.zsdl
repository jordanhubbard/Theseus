spec: socket_extra1441
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html
rfcs:
  - "RFC 791 — Internet Protocol"
  - "POSIX.1-2017 — Sockets interface"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "RFC 791 — Internet Protocol, DARPA, September 1981"
    - "POSIX.1-2017 — Portable Operating System Interface"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
    - "socket_extra.zspec.zsdl — covers create_connection/create_server/setdefaulttimeout/htons/ntohs names (table); setdefaulttimeout(None)==None; inet_aton broadcast/len; inet_ntoa loopback/broadcast/zero; htons/ntohs/ntohl zero; htonl(1) little-endian."
    - "socket_extra2.zspec.zsdl — covers AF_INET/AF_INET6/AF_UNIX AddressFamily class names; SOCK_STREAM/SOCK_DGRAM/SOCK_RAW SocketKind class names; AF_INET==2/SOCK_STREAM==1/SOCK_DGRAM==2; gethostname/getfqdn return str; socket.error.__name__=='OSError'; socket.timeout.__name__=='TimeoutError'; timeout.__bases__[0].__name__=='OSError'."
  notes:
    - "This spec does NOT duplicate invariants present in any prior socket spec."
    - "Wave 543 theme: __subclasshook__ and __instancecheck__ checks for socket.socket, socket.error, and socket.timeout."
    - "socket.socket is a Python class defined in Lib/socket.py that wraps a C-level _socket.socket object."
    - "socket.error is an alias for OSError (a built-in C-level exception type) in Python 3.3+."
    - "socket.timeout is an alias for TimeoutError (a built-in C-level exception type) in Python 3.3+."
    - "socket.socket.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__instancecheck__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "__subclasshook__ in socket.socket.__dict__ == False — not defined on socket.socket; inherited from type. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "__instancecheck__ in socket.socket.__dict__ == False — not defined on socket.socket; inherited from type. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error (OSError).__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout (TimeoutError).__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "__subclasshook__ in socket.error.__dict__ == False — OSError is a built-in C type; __subclasshook__ inherited from type. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "__subclasshook__ in socket.timeout.__dict__ == False — TimeoutError is a built-in C type; __subclasshook__ inherited from type. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All three classes (socket.socket, socket.error/OSError, socket.timeout/TimeoutError) share the same metaclass protocol: both methods are 'builtin_function_or_method' and absent from their __dict__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket — __subclasshook__ and __instancecheck__ type and dict checks
#
# Wave 543 theme: socket.socket is a Python-level class wrapping _socket.socket.
# Its metaclass is the standard type. __subclasshook__ and __instancecheck__ are
# inherited from type at the C level; class name is 'builtin_function_or_method'.
# Neither is defined in socket.socket.__dict__.
# ---------------------------------------------------------------------------

table socket_extra1441.socket_class_subclasshook:
  description: "socket.socket.__subclasshook__.__class__.__name__=='builtin_function_or_method' and not in socket.__dict__ — socket.socket is a Python class wrapping _socket.socket; metaclass is standard type; __subclasshook__/__instancecheck__ inherited at C level; no Python-level override; wave 543 first sk1441sc anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sk1441sc

  columns: [id, function, args, expected, description]
  rows:
    - [sk1441sc001, "socket.__subclasshook__.__class__.__name__.__eq__",  ["builtin_function_or_method"], true,  "socket.socket.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — C-level type metaclass inheritance"]
    - [sk1441sc002, "socket.__dict__.__contains__",                        ["__subclasshook__"],           false, "socket.socket.__dict__ does not contain '__subclasshook__' — inherited from type; not defined on socket.socket"]
    - [sk1441sc003, "socket.__instancecheck__.__class__.__name__.__eq__", ["builtin_function_or_method"],  true,  "socket.socket.__instancecheck__.__class__.__name__ == 'builtin_function_or_method' — C-level type metaclass inheritance"]
    - [sk1441sc004, "socket.__dict__.__contains__",                        ["__instancecheck__"],           false, "socket.socket.__dict__ does not contain '__instancecheck__' — inherited from type; not defined on socket.socket"]
    - [sk1441sc005, "socket.__subclasshook__.__class__.__name__.__eq__",  ["classmethod_descriptor"],      false, "socket.socket.__subclasshook__.__class__.__name__ is NOT 'classmethod_descriptor' — it is 'builtin_function_or_method'"]
    - [sk1441sc006, "socket.__instancecheck__.__class__.__name__.__eq__", ["wrapper_descriptor"],           false, "socket.socket.__instancecheck__.__class__.__name__ is NOT 'wrapper_descriptor' — it is 'builtin_function_or_method'"]

# ---------------------------------------------------------------------------
# socket.error (OSError) and socket.timeout (TimeoutError) — __subclasshook__
# and __instancecheck__ type and dict checks
#
# socket.error is an alias for OSError; socket.timeout is an alias for
# TimeoutError. Both are built-in C-level exception types. Their metaclass
# is the standard type. Both methods are 'builtin_function_or_method' and
# absent from their respective __dict__.
# ---------------------------------------------------------------------------

table socket_extra1441.error_timeout_subclasshook:
  description: "socket.error and socket.timeout __subclasshook__/__instancecheck__ class names == 'builtin_function_or_method'; both absent from their __dict__ — error==OSError and timeout==TimeoutError are built-in C exception types; metaclass is standard type; C-level inheritance; wave 543 first sk1441et anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sk1441et

  columns: [id, function, args, expected, description]
  rows:
    - [sk1441et001, "error.__subclasshook__.__class__.__name__.__eq__",   ["builtin_function_or_method"], true,  "socket.error (OSError).__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — built-in C exception type"]
    - [sk1441et002, "error.__dict__.__contains__",                         ["__subclasshook__"],           false, "socket.error.__dict__ does not contain '__subclasshook__' — OSError is C-level; __subclasshook__ inherited from type"]
    - [sk1441et003, "error.__instancecheck__.__class__.__name__.__eq__",  ["builtin_function_or_method"],  true,  "socket.error (OSError).__instancecheck__.__class__.__name__ == 'builtin_function_or_method' — built-in C exception type"]
    - [sk1441et004, "error.__dict__.__contains__",                         ["__instancecheck__"],           false, "socket.error.__dict__ does not contain '__instancecheck__' — OSError is C-level; __instancecheck__ inherited from type"]
    - [sk1441et005, "timeout.__subclasshook__.__class__.__name__.__eq__", ["builtin_function_or_method"],  true,  "socket.timeout (TimeoutError).__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — built-in C exception type"]
    - [sk1441et006, "timeout.__dict__.__contains__",                       ["__subclasshook__"],            false, "socket.timeout.__dict__ does not contain '__subclasshook__' — TimeoutError is C-level; __subclasshook__ inherited from type"]

# ---------------------------------------------------------------------------
# Three-way symmetry: socket.socket, socket.error, socket.timeout
#
# All three classes use the standard type metaclass and share the same
# __subclasshook__ / __instancecheck__ pattern. This table anchors the
# three-way symmetry in the wave 543 namespace under sk1441tw.
# ---------------------------------------------------------------------------

table socket_extra1441.three_way_symmetry:
  description: "socket.socket, socket.error, socket.timeout all have __subclasshook__.__class__.__name__=='builtin_function_or_method' and '__subclasshook__' absent from their __dict__ — three-way symmetry across a Python wrapper class (socket.socket) and two built-in C exception aliases (error/OSError, timeout/TimeoutError); confirms uniform metaclass protocol; wave 543 sk1441tw anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sk1441tw

