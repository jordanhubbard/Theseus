spec: uuid_extra1501
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module UUID and SafeUUID class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 547 (_extra1501): async protocol method dict-presence checks for uuid.UUID and uuid.SafeUUID."
    - "uuid is a sync-only UUID generation module; neither UUID nor SafeUUID implements __await__, __aiter__, __anext__, __aenter__, or __aexit__."
    - "Positive anchor columns confirm that genuine dunder methods (__init__, __hash__, __eq__) ARE in uuid.UUID.__dict__."
    - "uuid.SafeUUID is an Enum subclass; its __dict__ contains member names (safe, unsafe, unknown) but no async protocol methods."
    - "All results verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID — async protocol absent
# ---------------------------------------------------------------------------

table uuid_extra1501.UUID.async_protocol_absent:
  description: "uuid.UUID has no async protocol methods in its __dict__"
  kind: python_call_eq
  category: async_protocol
  id_prefix: uu1501ua
  columns: [id, function, args, expected]
  rows:
    - [uu1501ua001, uuid.UUID.__dict__.__contains__, ["__await__"],  false]
    - [uu1501ua002, uuid.UUID.__dict__.__contains__, ["__aiter__"],  false]
    - [uu1501ua003, uuid.UUID.__dict__.__contains__, ["__anext__"],  false]
    - [uu1501ua004, uuid.UUID.__dict__.__contains__, ["__aenter__"], false]
    - [uu1501ua005, uuid.UUID.__dict__.__contains__, ["__aexit__"],  false]
    - [uu1501ua006, uuid.UUID.__dict__.__contains__, ["__init__"],   true]

# ---------------------------------------------------------------------------
# uuid.UUID — sync protocol methods present (positive anchors)
# ---------------------------------------------------------------------------

table uuid_extra1501.UUID.sync_methods_present:
  description: "uuid.UUID sync dunder methods are present in its __dict__"
  kind: python_call_eq
  category: async_protocol
  id_prefix: uu1501us
  columns: [id, function, args, expected]
  rows:
    - [uu1501us001, uuid.UUID.__dict__.__contains__, ["__hash__"],    true]
    - [uu1501us002, uuid.UUID.__dict__.__contains__, ["__eq__"],      true]
    - [uu1501us003, uuid.UUID.__dict__.__contains__, ["__str__"],     true]
    - [uu1501us004, uuid.UUID.__dict__.__contains__, ["__repr__"],    true]
    - [uu1501us005, uuid.UUID.__dict__.__contains__, ["__int__"],     true]
    - [uu1501us006, uuid.UUID.__dict__.__contains__, ["__setattr__"], true]

# ---------------------------------------------------------------------------
# uuid.SafeUUID — async protocol absent, member names present
# ---------------------------------------------------------------------------

table uuid_extra1501.SafeUUID.async_protocol_absent:
  description: "uuid.SafeUUID has no async protocol methods in its __dict__; enum members ARE present"
  kind: python_call_eq
  category: async_protocol
  id_prefix: uu1501fa
  columns: [id, function, args, expected]
  rows:
    - [uu1501fa001, uuid.SafeUUID.__dict__.__contains__, ["__await__"],  false]
    - [uu1501fa002, uuid.SafeUUID.__dict__.__contains__, ["__aiter__"],  false]
    - [uu1501fa003, uuid.SafeUUID.__dict__.__contains__, ["__anext__"],  false]
    - [uu1501fa004, uuid.SafeUUID.__dict__.__contains__, ["__aenter__"], false]
    - [uu1501fa005, uuid.SafeUUID.__dict__.__contains__, ["__aexit__"],  false]
    - [uu1501fa006, uuid.SafeUUID.__dict__.__contains__, ["safe"],       true]
    - [uu1501fa007, uuid.SafeUUID.__dict__.__contains__, ["unsafe"],     true]
    - [uu1501fa008, uuid.SafeUUID.__dict__.__contains__, ["unknown"],    true]
