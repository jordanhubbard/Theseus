spec: asyncio_extra2536
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio synchronization primitives, queues, and task documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/futures.py"
    - "CPython source: Lib/asyncio/tasks.py"
  notes:
    - "Theme: __format__, __bytes__, and __fspath__ dict-presence — checking whether asyncio classes define custom formatting, bytes conversion, and filesystem path protocol in their class __dict__."
    - "asyncio.Queue is a pure-Python FIFO queue for coroutines; it carries no string-formatting override, bytes conversion, or OS path protocol. Verified with Python 3.14."
    - "asyncio.Task wraps a coroutine as a Future subclass for scheduling; it provides no __format__, __bytes__, or __fspath__ in its own class __dict__. Verified with Python 3.14."
    - "asyncio.Future is the base awaitable class; its state is get/set via result() and exception() — no formatting, bytes, or path protocol defined. Verified with Python 3.14."
    - "asyncio.Lock is a mutual-exclusion primitive for coroutines; it exposes acquire/release only and defines no protocol dunders for formatting, bytes, or paths. Verified with Python 3.14."
    - "asyncio.Event is a flag-based synchronization primitive; truth is accessed via is_set(), not __format__ or __bytes__. Verified with Python 3.14."
    - "asyncio.Semaphore tracks an internal counter via acquire/release; despite the counter it defines no formatting, bytes, or path protocol in its class __dict__. Verified with Python 3.14."
    - "asyncio.Condition wraps a lock with wait/notify; it has no string-formatting, bytes, or path semantics. Verified with Python 3.14."
    - "asyncio.Barrier synchronizes a fixed number of coroutines; it exposes no formatting, bytes conversion, or path protocol. Verified with Python 3.14."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.Queue and asyncio.Task — __format__/__bytes__/__fspath__ absence
#
# Theme: custom formatting, bytes conversion, and path protocol absent from
# asyncio.Queue and asyncio.Task __dict__.
# Queue is a coroutine-safe FIFO with no string-format or byte-stream role.
# Task wraps a coroutine as a Future; it has no path or bytes semantics.
# ---------------------------------------------------------------------------

table asyncio_extra2536.queue_task_format_bytes_fspath:
  description: "__format__, __bytes__, __fspath__ absent from asyncio.Queue and asyncio.Task __dict__; wave 2536"
  kind: python_call_eq
  category: protocol_dict_presence
  id_prefix: as2536

  columns: [id, function, args, expected]
  rows:
    - ["as2536-001", asyncio.Queue.__dict__.__contains__, ["__format__"], false]
    - ["as2536-002", asyncio.Queue.__dict__.__contains__, ["__bytes__"],  false]
    - ["as2536-003", asyncio.Queue.__dict__.__contains__, ["__fspath__"], false]
    - ["as2536-004", asyncio.Task.__dict__.__contains__,  ["__format__"], false]
    - ["as2536-005", asyncio.Task.__dict__.__contains__,  ["__bytes__"],  false]
    - ["as2536-006", asyncio.Task.__dict__.__contains__,  ["__fspath__"], false]

