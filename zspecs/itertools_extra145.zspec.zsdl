spec: itertools_extra145
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools module-level attributes (__name__ len 9, __doc__ len 1386); itertools.chain.from_iterable classmethods (__class__.__name__ 'builtin_function_or_method', __qualname__ 'chain.from_iterable' len 19, __doc__ len 88); itertools C-type __doc__ lengths (chain 190, cycle 95, product 681, combinations 134); itertools C-type __name__ lengths (chain 5, combinations 12, combinations_with_replacement 29, zip_longest 11) (Wave 273)."
    - "itertools.__name__ == 'itertools' (len 9). Verified with Python 3.14.3."
    - "len(itertools.__doc__) == 1386 — the module-level docstring. Verified with Python 3.14.3."
    - "itertools.chain.from_iterable is a builtin_function_or_method; __qualname__ == 'chain.from_iterable' (len 19); __doc__ len == 88. Verified with Python 3.14.3."
    - "len(itertools.chain.__doc__) == 190; len(itertools.cycle.__doc__) == 95; len(itertools.product.__doc__) == 681; len(itertools.combinations.__doc__) == 134. Verified with Python 3.14.3."
    - "len(itertools.chain.__name__) == 5; len(itertools.combinations.__name__) == 12; len(itertools.combinations_with_replacement.__name__) == 29; len(itertools.zip_longest.__name__) == 11. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools module-level attributes
#
# Wave 273 theme: itertools module identity attributes.
#
# itertools.__name__ == 'itertools' (len 9)
# itertools.__name__.__class__.__name__ == 'str'
# len(itertools.__doc__) == 1386
#
# The itertools C extension module has a module-level docstring describing
# its contents and behaviour. New to extra145.
# ---------------------------------------------------------------------------

table itertools_extra145.module_level_attrs:
  description: "itertools module-level __name__ (len 9), __doc__ (len 1386); module identity attributes; wave 273; new to extra145"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsmod145

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_eq_itertools,
       "__name__.__eq__",
       ["itertools"],
       true,
       "itertools.__name__.__eq__('itertools') == True — the module __name__ is 'itertools'; str.__eq__('itertools') returns True; new to extra145"]
    - [module_name_len_eq_9,
       "__name__.__len__",
       [],
       9,
       "itertools.__name__.__len__() == 9 — __name__ is 'itertools' which has 9 characters; len('itertools') == 9; new to extra145"]
    - [module_name_class_eq_str,
       "__name__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.__name__.__class__.__name__.__eq__('str') == True — the module __name__ attribute is a plain Python string; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra145"]
    - [module_doc_len_eq_1386,
       "__doc__.__len__",
       [],
       1386,
       "itertools.__doc__.__len__() == 1386 — the itertools module has a module-level docstring of 1386 characters describing all its iterators and their behaviour; len(__doc__) == 1386; verified with Python 3.14.3; new to extra145"]

# ---------------------------------------------------------------------------
# Table 2: itertools.chain.from_iterable classmethod identity
#
# Wave 273 theme: itertools.chain.from_iterable — the alternative constructor
# classmethod on the chain type.
#
# itertools.chain.from_iterable.__class__.__name__ == 'builtin_function_or_method'
# itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable' (len 19)
# len(itertools.chain.from_iterable.__doc__) == 88
#
# from_iterable is defined as a C classmethod on the chain type; it is exposed
# as a builtin_function_or_method; its qualname uses dot notation. New to extra145.
# ---------------------------------------------------------------------------

table itertools_extra145.chain_from_iterable_identity:
  description: "itertools.chain.from_iterable: builtin_function_or_method, __qualname__ 'chain.from_iterable' len 19, __doc__ len 88; wave 273; new to extra145"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolschain145

  columns: [id, function, args, expected, description]
  rows:
    - [from_iterable_class_eq_builtin,
       "chain.from_iterable.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.chain.from_iterable.__class__.__name__.__eq__('builtin_function_or_method') == True — from_iterable is a C classmethod on the chain type, exposed as a builtin_function_or_method; str.__eq__('builtin_function_or_method') returns True; new to extra145"]
    - [from_iterable_qualname_eq,
       "chain.from_iterable.__qualname__.__eq__",
       ["chain.from_iterable"],
       true,
       "itertools.chain.from_iterable.__qualname__.__eq__('chain.from_iterable') == True — the classmethod's __qualname__ uses dot notation 'chain.from_iterable'; str.__eq__('chain.from_iterable') returns True; new to extra145"]
    - [from_iterable_qualname_len_eq_19,
       "chain.from_iterable.__qualname__.__len__",
       [],
       19,
       "itertools.chain.from_iterable.__qualname__.__len__() == 19 — __qualname__ is 'chain.from_iterable' which has 19 characters; len('chain.from_iterable') == 19; new to extra145"]
    - [from_iterable_doc_len_eq_88,
       "chain.from_iterable.__doc__.__len__",
       [],
       88,
       "itertools.chain.from_iterable.__doc__.__len__() == 88 — the from_iterable docstring 'Alternative chain() constructor taking a single iterable argument that evaluates lazily.' has 88 characters; len(__doc__) == 88; verified with Python 3.14.3; new to extra145"]

# ---------------------------------------------------------------------------
# Table 3: itertools C-type __doc__ lengths
#
# Wave 273 theme: itertools C-type docstring lengths.
#
# len(itertools.chain.__doc__) == 190
# len(itertools.cycle.__doc__) == 95
# len(itertools.product.__doc__) == 681
# len(itertools.combinations.__doc__) == 134
#
# Each itertools C extension type has a type-level docstring embedded in the
# C source. These lengths are stable across patch versions. New to extra145.
# ---------------------------------------------------------------------------

table itertools_extra145.type_doc_lengths:
  description: "itertools C-type __doc__ lengths: chain 190, cycle 95, product 681, combinations 134; embedded C docstrings; wave 273; new to extra145"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsdoclen145

  columns: [id, function, args, expected, description]
  rows:
    - [chain_doc_len_eq_190,
       "chain.__doc__.__len__",
       [],
       190,
       "itertools.chain.__doc__.__len__() == 190 — the chain type docstring has 190 characters; the chain type lazily chains multiple iterables; len(__doc__) == 190; verified with Python 3.14.3; new to extra145"]
    - [cycle_doc_len_eq_95,
       "cycle.__doc__.__len__",
       [],
       95,
       "itertools.cycle.__doc__.__len__() == 95 — the cycle type docstring has 95 characters; cycle(p) cycles through iterable p indefinitely; len(__doc__) == 95; verified with Python 3.14.3; new to extra145"]
    - [product_doc_len_eq_681,
       "product.__doc__.__len__",
       [],
       681,
       "itertools.product.__doc__.__len__() == 681 — the product type docstring has 681 characters; product computes Cartesian products of input iterables; len(__doc__) == 681; verified with Python 3.14.3; new to extra145"]
    - [combinations_doc_len_eq_134,
       "combinations.__doc__.__len__",
       [],
       134,
       "itertools.combinations.__doc__.__len__() == 134 — the combinations type docstring has 134 characters; combinations(p, r) yields r-length subsequences of p without repeated elements; len(__doc__) == 134; verified with Python 3.14.3; new to extra145"]

# ---------------------------------------------------------------------------
# Table 4: itertools C-type __name__ lengths
#
# Wave 273 theme: itertools C-type __name__ string lengths.
#
# len(itertools.chain.__name__) == 5
# len(itertools.combinations.__name__) == 12
# len(itertools.combinations_with_replacement.__name__) == 29
# len(itertools.zip_longest.__name__) == 11
#
# The __name__ length varies widely across itertools types; notably
# combinations_with_replacement has the longest name at 29 characters.
# New to extra145.
# ---------------------------------------------------------------------------

table itertools_extra145.type_name_lengths:
  description: "itertools C-type __name__ lengths: chain 5, combinations 12, combinations_with_replacement 29, zip_longest 11; wave 273; new to extra145"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsnamelen145

  columns: [id, function, args, expected, description]
  rows:
    - [chain_name_len_eq_5,
       "chain.__name__.__len__",
       [],
       5,
       "itertools.chain.__name__.__len__() == 5 — __name__ is 'chain' which has 5 characters; len('chain') == 5; new to extra145"]
    - [combinations_name_len_eq_12,
       "combinations.__name__.__len__",
       [],
       12,
       "itertools.combinations.__name__.__len__() == 12 — __name__ is 'combinations' which has 12 characters; len('combinations') == 12; new to extra145"]
    - [combinations_with_replacement_name_len_eq_29,
       "combinations_with_replacement.__name__.__len__",
       [],
       29,
       "itertools.combinations_with_replacement.__name__.__len__() == 29 — __name__ is 'combinations_with_replacement' which has 29 characters; the longest name among all itertools types; len('combinations_with_replacement') == 29; new to extra145"]
    - [zip_longest_name_len_eq_11,
       "zip_longest.__name__.__len__",
       [],
       11,
       "itertools.zip_longest.__name__.__len__() == 11 — __name__ is 'zip_longest' which has 11 characters; len('zip_longest') == 11; new to extra145"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra145
# ---------------------------------------------------------------------------

invariant itertools_extra145.module_name_len:
  description: "len(itertools.__name__) == 9 — __name__ is 'itertools'; wave 273; new to extra145"
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 9

invariant itertools_extra145.module_doc_len:
  description: "len(itertools.__doc__) == 1386 — module-level docstring has 1386 characters; wave 273; new to extra145"
  kind: python_call_eq
  function: __doc__.__len__
  args: []
  expected: 1386

invariant itertools_extra145.from_iterable_is_builtin:
  description: "itertools.chain.from_iterable.__class__.__name__ == 'builtin_function_or_method' — C classmethod on chain type; wave 273; new to extra145"
  kind: python_call_eq
  function: chain.from_iterable.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant itertools_extra145.from_iterable_qualname_len:
  description: "len(itertools.chain.from_iterable.__qualname__) == 19 — qualname is 'chain.from_iterable'; wave 273; new to extra145"
  kind: python_call_eq
  function: chain.from_iterable.__qualname__.__len__
  args: []
  expected: 19

invariant itertools_extra145.from_iterable_doc_len:
  description: "len(itertools.chain.from_iterable.__doc__) == 88 — from_iterable docstring has 88 characters; wave 273; new to extra145"
  kind: python_call_eq
  function: chain.from_iterable.__doc__.__len__
  args: []
  expected: 88

invariant itertools_extra145.chain_doc_len:
  description: "len(itertools.chain.__doc__) == 190 — chain type docstring has 190 characters; wave 273; new to extra145"
  kind: python_call_eq
  function: chain.__doc__.__len__
  args: []
  expected: 190

invariant itertools_extra145.cycle_doc_len:
  description: "len(itertools.cycle.__doc__) == 95 — cycle type docstring has 95 characters; wave 273; new to extra145"
  kind: python_call_eq
  function: cycle.__doc__.__len__
  args: []
  expected: 95

invariant itertools_extra145.product_doc_len:
  description: "len(itertools.product.__doc__) == 681 — product type docstring has 681 characters; wave 273; new to extra145"
  kind: python_call_eq
  function: product.__doc__.__len__
  args: []
  expected: 681

invariant itertools_extra145.combinations_with_replacement_name_len:
  description: "len(itertools.combinations_with_replacement.__name__) == 29 — longest name among itertools types; wave 273; new to extra145"
  kind: python_call_eq
  function: combinations_with_replacement.__name__.__len__
  args: []
  expected: 29

invariant itertools_extra145.zip_longest_name_len:
  description: "len(itertools.zip_longest.__name__) == 11 — __name__ is 'zip_longest'; wave 273; new to extra145"
  kind: python_call_eq
  function: zip_longest.__name__.__len__
  args: []
  expected: 11
