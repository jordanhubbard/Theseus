spec: jwt_rust
version: ">=3.9"
backend: rust_module(jwt_rust)

docs: https://pyjwt.readthedocs.io/en/stable/

provenance:
  derived_from:
    - "https://pyjwt.readthedocs.io/en/stable/ — PyJWT documentation"
  not_derived_from:
    - "PyJWT source: jwt/__init__.py"
  notes:
    - "PyJWT provides JSON Web Token implementation."
    - "jwt.encode({'sub': 'user1'}, 'secret', algorithm='HS256') returns a token string."
    - "jwt.decode(token, 'secret', algorithms=['HS256'])['sub'] == 'user1'."
    - "Token is a non-empty string."
    - "Decoded payload has the original claims."
    - "Expose jwt_encode_decode_sub(sub) -> str: decode(encode({'sub': sub}, 'secret'))['sub']."
    - "Expose jwt_token_nonempty(payload) -> bool: len(jwt.encode(payload, 'secret')) > 0."
    - "All test vectors verified against PyJWT 2.10.1."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# jwt_encode_decode_sub — roundtrip encode/decode subject claim
table jwt_rust.token.roundtrip:
  kind: python_call_eq
  category: roundtrip
  id_prefix: jwt_rt
  function: jwt_encode_decode_sub

  columns: [id, args, expected]
  rows:
    - [user1, ["user1"], "user1"]
    - [admin, ["admin"], "admin"]
    - [test,  ["test"],  "test"]

# jwt_token_nonempty — encoded token is non-empty
invariant jwt_rust.token.nonempty:
  description: "jwt.encode produces non-empty string"
  category: token
  kind: python_call_eq
  function: jwt_token_nonempty
  args: [{"sub": "user"}]
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T01:22:04Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
