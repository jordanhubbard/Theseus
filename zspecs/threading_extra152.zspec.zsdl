spec: threading_extra152
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.__dict__.__len__() 81; threading.__dict__.__class__.__name__ 'dict'; threading.__dict__.__contains__ checks for TIMEOUT_MAX, excepthook, get_ident, stack_size, active_count (Wave 280)."
    - "threading.__dict__.__len__() == 81 — the threading module dict has 81 entries in Python 3.14.3; includes all public classes, functions, constants, and dunder attributes. Verified with Python 3.14.3."
    - "threading.__dict__.__class__.__name__ == 'dict' — the module __dict__ of a pure-Python module is a plain dict, not a mappingproxy. Verified with Python 3.14.3."
    - "threading.__dict__.__contains__('TIMEOUT_MAX') == True — TIMEOUT_MAX is a float constant (sys.maxsize) exported into threading from _thread. Verified with Python 3.14.3."
    - "threading.__dict__.__contains__('excepthook') == True — excepthook is a Python function in Lib/threading.py handling unhandled exceptions in threads. Verified with Python 3.14.3."
    - "threading.__dict__.__contains__('get_ident') == True — get_ident is imported from _thread and returns the current thread identifier. Verified with Python 3.14.3."
    - "threading.__dict__.__contains__('stack_size') == True — stack_size is imported from _thread and gets or sets the thread stack size. Verified with Python 3.14.3."
    - "threading.__dict__.__contains__('active_count') == True — active_count is a Python function in Lib/threading.py returning the number of alive threads. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.__dict__ — module dict identity (plain dict, len 81)
#
# Wave 280 theme: threading module dict type and size.
#
# threading.__dict__.__class__.__name__ == 'dict'
# threading.__dict__.__len__() == 81
#
# threading is a pure-Python module (with C helper imports from _thread);
# its module __dict__ is a plain dict with 81 entries in Python 3.14.3.
# New to extra152.
# ---------------------------------------------------------------------------

table threading_extra152.module_dict_identity:
  description: "threading.__dict__: plain dict (not mappingproxy), len 81; module-level dict for threading; wave 280; new to extra152"
  kind: python_call_eq
  category: identity
  id_prefix: threadingmoddict152

  columns: [id, function, args, expected, description]
  rows:
    - [module_dict_class_eq_dict,
       "__dict__.__class__.__name__.__eq__",
       ["dict"],
       true,
       "threading.__dict__.__class__.__name__.__eq__('dict') == True — the module __dict__ of a pure-Python module is a plain Python dict, not a mappingproxy; threading's __dict__.__class__.__name__ is 'dict'; str.__eq__('dict') returns True; new to extra152"]
    - [module_dict_len_eq_81,
       "__dict__.__len__",
       [],
       81,
       "threading.__dict__.__len__() == 81 — the threading module dict has 81 entries in Python 3.14.3; includes all public classes (Thread, Lock, Semaphore, etc.), functions, constants, and dunder attributes; len == 81; verified with Python 3.14.3; new to extra152"]

# ---------------------------------------------------------------------------
# Table 2: threading.__dict__.__contains__ — constants and C imports
#
# Wave 280 theme: threading module dict membership for TIMEOUT_MAX and C imports.
#
# threading.__dict__.__contains__('TIMEOUT_MAX') == True
# threading.__dict__.__contains__('get_ident') == True
# threading.__dict__.__contains__('stack_size') == True
#
# TIMEOUT_MAX is a float constant re-exported from _thread.
# get_ident and stack_size are C builtins imported from _thread.
# New to extra152.
# ---------------------------------------------------------------------------

table threading_extra152.module_dict_contains_c_imports:
  description: "threading.__dict__.__contains__: TIMEOUT_MAX True, get_ident True, stack_size True; C-level constants and imports from _thread in module dict; wave 280; new to extra152"
  kind: python_call_eq
  category: identity
  id_prefix: threadingmdcc152

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_TIMEOUT_MAX,
       "__dict__.__contains__",
       ["TIMEOUT_MAX"],
       true,
       "threading.__dict__.__contains__('TIMEOUT_MAX') == True — TIMEOUT_MAX is a float constant imported from _thread into the threading namespace; it represents the maximum value for a timeout argument; dict.__contains__('TIMEOUT_MAX') returns True; new to extra152"]
    - [dict_contains_get_ident,
       "__dict__.__contains__",
       ["get_ident"],
       true,
       "threading.__dict__.__contains__('get_ident') == True — get_ident is a C builtin function imported from _thread into threading; it returns an integer identifying the current thread; dict.__contains__('get_ident') returns True; new to extra152"]
    - [dict_contains_stack_size,
       "__dict__.__contains__",
       ["stack_size"],
       true,
       "threading.__dict__.__contains__('stack_size') == True — stack_size is a C builtin function imported from _thread into threading; it returns or sets the thread stack size for new threads; dict.__contains__('stack_size') returns True; new to extra152"]

# ---------------------------------------------------------------------------
# Table 3: threading.__dict__.__contains__ — Python-level functions
#
# Wave 280 theme: threading module dict membership for Python-defined functions.
#
# threading.__dict__.__contains__('excepthook') == True
# threading.__dict__.__contains__('active_count') == True
#
# Both are Python functions defined in Lib/threading.py.
# New to extra152.
# ---------------------------------------------------------------------------

table threading_extra152.module_dict_contains_python_fns:
  description: "threading.__dict__.__contains__: excepthook True, active_count True; Python-defined functions in module dict; wave 280; new to extra152"
  kind: python_call_eq
  category: identity
  id_prefix: threadingmdcpython152

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_excepthook,
       "__dict__.__contains__",
       ["excepthook"],
       true,
       "threading.__dict__.__contains__('excepthook') == True — excepthook is a Python function defined in Lib/threading.py that handles unhandled exceptions in threads (added in Python 3.8); dict.__contains__('excepthook') returns True; new to extra152"]
    - [dict_contains_active_count,
       "__dict__.__contains__",
       ["active_count"],
       true,
       "threading.__dict__.__contains__('active_count') == True — active_count is a Python function defined in Lib/threading.py that returns the number of Thread objects currently alive; dict.__contains__('active_count') returns True; new to extra152"]
    - [excepthook_class_eq_function,
       "excepthook.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.excepthook.__class__.__name__.__eq__('function') == True — excepthook is a pure-Python function defined in Lib/threading.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra152"]
    - [active_count_class_eq_function,
       "active_count.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.active_count.__class__.__name__.__eq__('function') == True — active_count is a pure-Python function defined in Lib/threading.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra152"]
    - [excepthook_module_eq_threading,
       "excepthook.__module__.__eq__",
       ["threading"],
       true,
       "threading.excepthook.__module__.__eq__('threading') == True — excepthook is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra152"]
    - [active_count_module_eq_threading,
       "active_count.__module__.__eq__",
       ["threading"],
       true,
       "threading.active_count.__module__.__eq__('threading') == True — active_count is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra152"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra152
# ---------------------------------------------------------------------------

invariant threading_extra152.module_dict_class_dict:
  description: "threading.__dict__.__class__.__name__ == 'dict' — module __dict__ of a pure-Python module is a plain dict; wave 280; new to extra152"
  kind: python_call_eq
  function: __dict__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant threading_extra152.module_dict_len:
  description: "len(threading.__dict__) == 81 — threading module dict has 81 entries in Python 3.14.3; wave 280; new to extra152"
  kind: python_call_eq
  function: __dict__.__len__
  args: []
  expected: 81

invariant threading_extra152.dict_contains_TIMEOUT_MAX:
  description: "threading.__dict__.__contains__('TIMEOUT_MAX') == True — float constant re-exported from _thread; wave 280; new to extra152"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["TIMEOUT_MAX"]
  expected: true

invariant threading_extra152.dict_contains_excepthook:
  description: "threading.__dict__.__contains__('excepthook') == True — Python function handling unhandled thread exceptions; wave 280; new to extra152"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["excepthook"]
  expected: true

invariant threading_extra152.dict_contains_get_ident:
  description: "threading.__dict__.__contains__('get_ident') == True — C builtin returning current thread id; wave 280; new to extra152"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["get_ident"]
  expected: true

invariant threading_extra152.dict_contains_stack_size:
  description: "threading.__dict__.__contains__('stack_size') == True — C builtin for thread stack size; wave 280; new to extra152"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["stack_size"]
  expected: true

invariant threading_extra152.dict_contains_active_count:
  description: "threading.__dict__.__contains__('active_count') == True — Python function returning number of alive threads; wave 280; new to extra152"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["active_count"]
  expected: true

invariant threading_extra152.excepthook_class_function:
  description: "threading.excepthook.__class__.__name__ == 'function' — pure-Python function for thread exception handling; wave 280; new to extra152"
  kind: python_call_eq
  function: excepthook.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra152.active_count_module:
  description: "threading.active_count.__module__ == 'threading' — function defined in Lib/threading.py; wave 280; new to extra152"
  kind: python_call_eq
  function: active_count.__module__.__eq__
  args: ["threading"]
  expected: true

