spec: io_extra1096
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module io.open function, io.open_code function, DEFAULT_BUFFER_SIZE, BufferedReader/BufferedWriter/BufferedRandom, and IncrementalNewlineDecoder documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks io.open and io.open_code function qualname/module, io.DEFAULT_BUFFER_SIZE class name, BufferedReader/BufferedWriter/BufferedRandom class module/qualname/name, and IncrementalNewlineDecoder module/qualname; none of these were covered in _extra1066 or _extra1081"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra1096.open_function_identity:
  description: "io.open and io.open_code function __qualname__ and __module__ checks"
  kind: python_call_eq
  category: open_function_identity
  id_prefix: io1096of
  columns: [id, function, args, expected]
  rows:
    - [io1096of001, io.open.__qualname__.__eq__,        ["open"],       true]
    - [io1096of002, io.open.__module__.__eq__,          ["io"],         true]
    - [io1096of003, io.open_code.__qualname__.__eq__,   ["open_code"],  true]
    - [io1096of004, io.open_code.__module__.__eq__,     ["io"],         true]
    - [io1096of005, io.open.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [io1096of006, io.open_code.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [io1096of007, io.DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__, ["int"], true]

table io_extra1096.buffered_concrete_class_identity:
  description: "io.BufferedReader, io.BufferedWriter, and io.BufferedRandom class __name__, __module__, and __qualname__ checks"
  kind: python_call_eq
  category: buffered_concrete_class_identity
  id_prefix: io1096bc
  columns: [id, function, args, expected]
  rows:
    - [io1096bc001, io.BufferedReader.__name__.__eq__,       ["BufferedReader"],  true]
    - [io1096bc002, io.BufferedReader.__module__.__eq__,     ["io"],              true]
    - [io1096bc003, io.BufferedReader.__qualname__.__eq__,   ["BufferedReader"],  true]
    - [io1096bc004, io.BufferedWriter.__name__.__eq__,       ["BufferedWriter"],  true]
    - [io1096bc005, io.BufferedWriter.__module__.__eq__,     ["io"],              true]
    - [io1096bc006, io.BufferedWriter.__qualname__.__eq__,   ["BufferedWriter"],  true]
    - [io1096bc007, io.BufferedRandom.__name__.__eq__,       ["BufferedRandom"],  true]
    - [io1096bc008, io.BufferedRandom.__module__.__eq__,     ["io"],              true]
    - [io1096bc009, io.BufferedRandom.__qualname__.__eq__,   ["BufferedRandom"],  true]

table io_extra1096.incremental_newline_decoder_identity:
  description: "io.IncrementalNewlineDecoder class __name__, __module__, and __qualname__ checks"
  kind: python_call_eq
  category: incremental_newline_decoder_identity
  id_prefix: io1096nd
  columns: [id, function, args, expected]
  rows:
    - [io1096nd001, io.IncrementalNewlineDecoder.__name__.__eq__,       ["IncrementalNewlineDecoder"], true]
    - [io1096nd002, io.IncrementalNewlineDecoder.__module__.__eq__,     ["io"],                        true]
    - [io1096nd003, io.IncrementalNewlineDecoder.__qualname__.__eq__,   ["IncrementalNewlineDecoder"], true]
    - [io1096nd004, io.BufferedReader.__name__.__eq__,                  ["BufferedWriter"],            false]
    - [io1096nd005, io.BufferedRandom.__module__.__eq__,                ["_io"],                       false]
    - [io1096nd006, io.DEFAULT_BUFFER_SIZE.__eq__,                      [8192],                        true]
