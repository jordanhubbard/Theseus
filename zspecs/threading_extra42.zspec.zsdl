spec: threading_extra42
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra41.zspec.zsdl."
    - "Prior specs covered: Thread/__name__/__qualname__.__len__()==6; Thread method __qualname__.__len__() for start/run/join/is_alive/__init__/__repr__/getName/setName; Event method __qualname__.__len__(); Condition method __qualname__.__len__() for wait/notify/notify_all/__enter__; Semaphore/__name__/__qualname__.__len__()==9; Barrier/__name__/__qualname__.__len__()==7; Timer/__name__/__qualname__.__len__()==5; threading.local/__name__/__qualname__.__len__()==6; Lock/__name__/__len__()==4; RLock/__dict__.__class__.__name__.__len__()==12; current_thread/__name__/main_thread/__name__; threading.__all__.__len__()==28; TIMEOUT_MAX; active_count/enumerate/settrace/setprofile/stack_size __name__ lengths; Thread property __class__.__name__.__len__() for daemon/name/ident/native_id; pure-Python class __module__.__len__()==9 for Thread/Semaphore/Condition/Barrier/Event/Timer; threading.local.__module__.__len__()==7; Barrier.__name__=='Barrier'; Barrier.__module__=='threading'; Condition.__name__=='Condition'; Condition.__module__=='threading'; Semaphore.__name__=='Semaphore'; Semaphore.__module__=='threading'; RLock.__name__=='RLock'; RLock.__module__=='threading'."
    - "This spec covers: threading.Timer.__name__ == 'Timer'; threading.Timer.__module__ == 'threading'; threading.Timer.__bases__[0].__name__ == 'Thread'; threading.BoundedSemaphore.__name__ == 'BoundedSemaphore'; threading.BoundedSemaphore.__module__ == 'threading'; threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'; threading.local.__name__ == '_local' (C-extension type from _thread module, NOT 'local'); threading.TIMEOUT_MAX == 9223372036.0 (platform float, 2^33 - 2^0 on 64-bit Darwin); threading.excepthook.__name__ == '_excepthook' (C-extension wrapper from _thread module, NOT 'excepthook')."
    - "Key findings: threading.Timer.__name__ is 'Timer' (5 chars) and threading.Timer.__module__ is 'threading' (9 chars) — Timer is a pure-Python subclass of Thread defined in Lib/threading.py. threading.Timer.__bases__[0].__name__ is 'Thread' — Timer inherits directly from Thread as its only base class. threading.BoundedSemaphore.__name__ is 'BoundedSemaphore' (16 chars) and __module__ is 'threading' (9 chars); its single base class is Semaphore (threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'). CRITICAL: threading.local.__name__ is '_local' (NOT 'local') because threading.local is actually the C-extension type _thread._local re-exported; its __module__ is '_thread' (7 chars). Similarly, threading.excepthook.__name__ is '_excepthook' (NOT 'excepthook') because threading.excepthook is a C-extension function from _thread with the internal name '_excepthook'; its __module__ is '_thread'. threading.TIMEOUT_MAX is 9223372036.0 — a float equal to 2^33 - 1 seconds (the maximum timeout for threading primitives on 64-bit Darwin; platform-dependent but stable on this system). These are all new to the extra42 namespace."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.Timer identity metadata — extra42 namespace
#
# threading.Timer.__name__ is 'Timer' (5 chars), threading.Timer.__module__
# is 'threading' (9 chars), and threading.Timer.__bases__[0].__name__ is
# 'Thread' (6 chars). Timer is a pure-Python subclass of Thread defined in
# Lib/threading.py that runs a function after a delay. It has exactly one
# base class: Thread. Prior specs recorded Timer/__name__.__len__()==5 and
# __module__.__len__()==9, but not the string equality invariants nor the
# base class __name__. These three equality invariants are new to extra42.
# ---------------------------------------------------------------------------

invariant threading_extra42.Timer_name:
  description: "threading.Timer.__name__ == 'Timer' — pure-Python Thread subclass; 5-char name; runs a function after a delay; same __name__ length as Timer.__qualname__.__len__()==5"
  category: identity
  kind: python_call_eq
  function: Timer.__name__.__eq__
  args: ["Timer"]
  expected: true

invariant threading_extra42.Timer_module:
  description: "threading.Timer.__module__ == 'threading' — pure-Python class defined in Lib/threading.py; 9-char module name; same as Thread/Semaphore/Condition/Barrier/Event"
  category: module_metadata
  kind: python_call_eq
  function: Timer.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra42.Timer_bases_name:
  description: "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer inherits directly from Thread; single base class; Thread is the only threading class that Timer extends"
  category: class_hierarchy
  kind: python_call_eq
  function: "Timer.__bases__[0].__name__.__eq__"
  args: ["Thread"]
  expected: true

# ---------------------------------------------------------------------------
# threading.BoundedSemaphore identity metadata — extra42 namespace
#
# threading.BoundedSemaphore.__name__ is 'BoundedSemaphore' (16 chars),
# threading.BoundedSemaphore.__module__ is 'threading' (9 chars), and
# threading.BoundedSemaphore.__bases__[0].__name__ is 'Semaphore' (9 chars).
# BoundedSemaphore is a pure-Python subclass of Semaphore defined in
# Lib/threading.py. Its __name__ (16 chars) is the longest class __name__
# among the major threading synchronization primitives. The base class name
# 'Semaphore' coincidentally has the same length (9 chars) as __module__.
# Prior specs recorded __name__/__qualname__.__len__() for BoundedSemaphore
# but not the string equality invariants nor the __bases__[0].__name__.
# These three equality invariants are new to the extra42 namespace.
# ---------------------------------------------------------------------------

invariant threading_extra42.BoundedSemaphore_name:
  description: "threading.BoundedSemaphore.__name__ == 'BoundedSemaphore' — pure-Python Semaphore subclass; 16-char name; longest class __name__ among threading sync primitives"
  category: identity
  kind: python_call_eq
  function: BoundedSemaphore.__name__.__eq__
  args: ["BoundedSemaphore"]
  expected: true

invariant threading_extra42.BoundedSemaphore_module:
  description: "threading.BoundedSemaphore.__module__ == 'threading' — pure-Python class defined in Lib/threading.py; 9-char module name; same length as BoundedSemaphore.__bases__[0].__name__"
  category: module_metadata
  kind: python_call_eq
  function: BoundedSemaphore.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra42.BoundedSemaphore_bases_name:
  description: "threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — BoundedSemaphore inherits directly from Semaphore; single base class; 9-char base name == __module__ length"
  category: class_hierarchy
  kind: python_call_eq
  function: "BoundedSemaphore.__bases__[0].__name__.__eq__"
  args: ["Semaphore"]
  expected: true

# ---------------------------------------------------------------------------
# threading.local __name__ — extra42 namespace
#
# threading.local.__name__ is '_local' (NOT 'local'). threading.local is
# actually the C-extension type _thread._local re-exported via the threading
# module. The type's internal C name is '_local' (6 chars with underscore
# prefix), and its __module__ is '_thread' (7 chars), not 'threading'. This
# is a common gotcha: the public API name is 'threading.local' but the
# underlying type's __name__ is '_local'. Prior specs recorded
# threading.local/__qualname__.__len__()==6 (which matches '_local') but
# did not record the actual string value. This equality invariant is new to
# the extra42 namespace.
# ---------------------------------------------------------------------------

invariant threading_extra42.local_name:
  description: "threading.local.__name__ == '_local' — NOT 'local'; this is the C-extension type _thread._local re-exported; internal C name has underscore prefix; 6 chars"
  category: identity
  kind: python_call_eq
  function: local.__name__.__eq__
  args: ["_local"]
  expected: true

# ---------------------------------------------------------------------------
# threading.TIMEOUT_MAX — extra42 namespace
#
# threading.TIMEOUT_MAX is 9223372036.0 — a float value representing the
# maximum timeout (in seconds) that threading primitives accept on this
# platform. On 64-bit Darwin it equals 2^33 - 2^0 = 9223372036 seconds.
# This is a platform-dependent constant; the value 9223372036.0 is verified
# on macOS/Darwin 25.4.0 (arm64). Prior specs recorded TIMEOUT_MAX being
# present in threading.__all__ but did not record its numeric value. This
# equality invariant is new to the extra42 namespace.
# ---------------------------------------------------------------------------

invariant threading_extra42.TIMEOUT_MAX_value:
  description: "threading.TIMEOUT_MAX == 9223372036.0 — float; platform-dependent maximum timeout for threading primitives; verified 9223372036.0 on macOS/Darwin 25.4.0 64-bit"
  category: constants
  kind: python_call_eq
  function: TIMEOUT_MAX.__eq__
  args: [9223372036.0]
  expected: true

# ---------------------------------------------------------------------------
# threading.excepthook __name__ — extra42 namespace
#
# threading.excepthook.__name__ is '_excepthook' (NOT 'excepthook'). Like
# threading.local, threading.excepthook is a C-extension function from the
# _thread module re-exported via threading. Its internal C name is
# '_excepthook' (11 chars with underscore prefix) and its __module__ is
# '_thread' (7 chars), not 'threading'. The underscore-prefixed internal
# name is the actual __name__ despite the public attribute being
# threading.excepthook (no underscore). Prior specs did not record this
# value; this equality invariant is new to the extra42 namespace.
# ---------------------------------------------------------------------------

invariant threading_extra42.excepthook_name:
  description: "threading.excepthook.__name__ == '_excepthook' — NOT 'excepthook'; C-extension function from _thread re-exported via threading; internal name has underscore prefix; 11 chars"
  category: identity
  kind: python_call_eq
  function: excepthook.__name__.__eq__
  args: ["_excepthook"]
  expected: true
