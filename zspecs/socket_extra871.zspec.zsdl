spec: socket_extra871
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - socket
  not_derived_from:
    - ssl
    - http
  notes:
    - Covers socket module network utility function qualnames and module-level attributes
  created_at: "2026-04-12"

table socket_extra871.network_util_qualnames:
  description: Verify qualnames of socket module network utility functions
  kind: python_call_eq
  category: qualname
  id_prefix: sk871nu
  columns: [id, function, args, expected]
  rows:
    - [sk871nu001, socket.gethostbyaddr.__qualname__.__eq__, ["gethostbyaddr"], true]
    - [sk871nu002, socket.gethostbyname.__qualname__.__eq__, ["gethostbyname"], true]
    - [sk871nu003, socket.getservbyname.__qualname__.__eq__, ["getservbyname"], true]
    - [sk871nu004, socket.getservbyport.__qualname__.__eq__, ["getservbyport"], true]
    - [sk871nu005, socket.inet_aton.__qualname__.__eq__, ["inet_aton"], true]
    - [sk871nu006, socket.inet_ntoa.__qualname__.__eq__, ["inet_ntoa"], true]
    - [sk871nu007, socket.inet_pton.__qualname__.__eq__, ["inet_pton"], true]
    - [sk871nu008, socket.inet_ntop.__qualname__.__eq__, ["inet_ntop"], true]

table socket_extra871.module_attrs:
  description: Verify socket module-level dunder attributes and __all__ type
  kind: python_call_eq
  category: module_identity
  id_prefix: sk871mo
  columns: [id, function, args, expected]
  rows:
    - [sk871mo001, socket.__name__.__eq__, ["socket"], true]
    - [sk871mo002, socket.__package__.__eq__, ["socket"], true]
    - [sk871mo003, socket.__spec__.__class__.__name__.__eq__, ["ModuleSpec"], true]
    - [sk871mo004, socket.__all__.__class__.__name__.__eq__, ["list"], true]
