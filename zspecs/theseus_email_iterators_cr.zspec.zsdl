spec: theseus_email_iterators_cr
version: ">=3.0"
backend: python_cleanroom(theseus_email_iterators_cr)
blocks: email.iterators

docs: https://docs.python.org/3/library/email.iterators.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/email.iterators.html"
  not_derived_from:
    - "CPython source: Lib/email/iterators.py"
  notes:
    - "Clean-room email.iterators module. Do NOT import email.iterators."

error_model: python_exceptions

invariant theseus_email_iterators_cr.emailitr2_body_line:
  description: "body_line_iterator() iterates over message body lines"
  category: behavior
  kind: python_call_eq
  function: emailitr2_body_line
  args: []
  expected: true

invariant theseus_email_iterators_cr.emailitr2_typed_subpart:
  description: "typed_subpart_iterator() filters subparts by type"
  category: behavior
  kind: python_call_eq
  function: emailitr2_typed_subpart
  args: []
  expected: true

invariant theseus_email_iterators_cr.emailitr2_walk:
  description: "walk() iterates over all message parts"
  category: behavior
  kind: python_call_eq
  function: emailitr2_walk
  args: []
  expected: true
