spec: decimal_extra1261
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "Wave 531 spec: decimal has NO __all__ attribute in Python 3.14."
    - "decimal.__dict__.__contains__('__all__') == False (confirmed with Python 3.14.3)."
    - "Alternative angle used per wave-531 instructions: decimal.__dict__.__contains__ checks for public names."
    - "Table dc1261aa covers decimal.__dict__.__contains__ for core classes: Decimal, Context, DefaultContext, BasicContext, ExtendedContext."
    - "Table dc1261bb covers decimal.__dict__.__contains__ for exception classes and rounding mode constants."
    - "Table dc1261cc covers decimal.__dict__.__contains__ for utility functions, precision constants, and NOT-in checks."
    - "decimal.__dict__.__contains__('Decimal') == True (the primary arbitrary-precision number class)."
    - "decimal.__dict__.__contains__('Context') == True (the arithmetic context class controlling precision and rounding)."
    - "decimal.__dict__.__contains__('DefaultContext') == True (the module-level default arithmetic context)."
    - "decimal.__dict__.__contains__('BasicContext') == True (the context specified in the General Decimal Arithmetic spec)."
    - "decimal.__dict__.__contains__('ExtendedContext') == True (the extended arithmetic context per the GDA spec)."
    - "decimal.__dict__.__contains__('FloatOperation') == True (exception/flag for mixed float/Decimal operations)."
    - "decimal.__dict__.__contains__('ROUND_HALF_UP') == True (most commonly expected rounding mode)."
    - "decimal.__dict__.__contains__('ROUND_CEILING') == True (round towards positive infinity)."
    - "decimal.__dict__.__contains__('ROUND_05UP') == True (round if last digit would have been 0 or 5; GDA mode)."
    - "decimal.__dict__.__contains__('getcontext') == True (function returning the current thread context)."
    - "decimal.__dict__.__contains__('setcontext') == True (function setting the current thread context)."
    - "decimal.__dict__.__contains__('localcontext') == True (context manager for a local arithmetic context)."
    - "decimal.__dict__.__contains__('HAVE_THREADS') == True (boolean; True when threading support is compiled in)."
    - "decimal.__dict__.__contains__('HAVE_CONTEXTVAR') == True (boolean; True when contextvars is supported)."
    - "decimal.__dict__.__contains__('MIN_ETINY') == True (minimum value for Etiny; most negative exponent)."
    - "decimal.__dict__.__contains__('MAX_EMAX') == True (maximum exponent value)."
    - "decimal.__dict__.__contains__('__all__') == False (decimal intentionally has no __all__)."
    - "decimal.__dict__.__contains__('match') == False ('match' is not a decimal symbol; it belongs to re)."
    - "decimal.__dict__.__contains__('open') == False ('open' belongs to io/builtins; not decimal)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.__dict__ membership for core classes
# decimal has NO __all__; wave-531 uses __dict__.__contains__ instead.
# decimal.__dict__.__contains__('__all__') == False (confirmed; intentional omission).
# Core classes: Decimal, Context, DefaultContext, BasicContext, ExtendedContext.
# Also verifies that 'match' and 'compile' (re module names) are not in decimal.
# ---------------------------------------------------------------------------

table decimal_extra1261.dict_type_and_core_classes_in:
  description: "decimal has no __all__; uses __dict__.__contains__ per wave-531; Decimal/Context/DefaultContext/BasicContext/ExtendedContext are in __dict__; __all__ itself is not; wave-531 novel checks"
  kind: python_call_eq
  category: module_identity
  id_prefix: dc1261aa

  columns: [id, function, args, expected, description]
  rows:
    - [dc1261aa001, "__dict__.__contains__", ["__all__"],         false, "decimal.__dict__.__contains__('__all__') == False (decimal intentionally omits __all__; public names are determined by convention and the module's own documentation rather than an explicit list)"]
    - [dc1261aa002, "__dict__.__contains__", ["Decimal"],         true,  "decimal.__dict__.__contains__('Decimal') == True (the primary class for arbitrary-precision decimal floating-point arithmetic; immutable; implements the General Decimal Arithmetic specification)"]
    - [dc1261aa003, "__dict__.__contains__", ["Context"],         true,  "decimal.__dict__.__contains__('Context') == True (arithmetic context object specifying precision, rounding mode, and enabled traps; each thread has its own Context instance)"]
    - [dc1261aa004, "__dict__.__contains__", ["DefaultContext"],  true,  "decimal.__dict__.__contains__('DefaultContext') == True (the default Context used as a template; not the same as the thread-local context returned by getcontext())"]
    - [dc1261aa005, "__dict__.__contains__", ["BasicContext"],    true,  "decimal.__dict__.__contains__('BasicContext') == True (the context prescribed by the General Decimal Arithmetic spec for basic arithmetic; uses more restrictive trap settings)"]
    - [dc1261aa006, "__dict__.__contains__", ["ExtendedContext"], true,  "decimal.__dict__.__contains__('ExtendedContext') == True (the extended-precision GDA context; uses permissive trap settings; designed for maximum GDA compatibility)"]
    - [dc1261aa007, "__dict__.__contains__", ["match"],           false, "decimal.__dict__.__contains__('match') == False ('match' is a function in the re module; it is not defined or imported in the decimal module namespace)"]
    - [dc1261aa008, "__dict__.__contains__", ["compile"],         false, "decimal.__dict__.__contains__('compile') == False ('compile' belongs to re and builtins; it is not a decimal symbol and is not in decimal.__dict__)"]

# ---------------------------------------------------------------------------
# decimal.__dict__ membership for exception classes and rounding constants
# Exception classes: DecimalException, Clamped, InvalidOperation, DivisionByZero,
#   Inexact, Rounded, Subnormal, Overflow, Underflow, FloatOperation.
# Rounding mode constants: ROUND_UP, ROUND_DOWN, ROUND_CEILING, ROUND_FLOOR,
#   ROUND_HALF_UP, ROUND_HALF_DOWN, ROUND_HALF_EVEN, ROUND_05UP.
# ---------------------------------------------------------------------------

table decimal_extra1261.dict_exceptions_and_rounding_in:
  description: "decimal.__dict__.__contains__ True for exception classes (DecimalException/Clamped/FloatOperation/Overflow/Underflow) and rounding constants (ROUND_CEILING/ROUND_HALF_UP/ROUND_05UP/ROUND_FLOOR); wave-531 novel checks"
  kind: python_call_eq
  category: module_identity
  id_prefix: dc1261bb

  columns: [id, function, args, expected, description]
  rows:
    - [dc1261bb001, "__dict__.__contains__", ["DecimalException"],  true,  "decimal.__dict__.__contains__('DecimalException') == True (root exception for all decimal-specific exceptions; extends ArithmeticError; MRO length 5 as established in decimal_extra126)"]
    - [dc1261bb002, "__dict__.__contains__", ["Clamped"],           true,  "decimal.__dict__.__contains__('Clamped') == True (exception/signal raised when a number's exponent is clamped to Emax or Emin to fit the current context)"]
    - [dc1261bb003, "__dict__.__contains__", ["FloatOperation"],    true,  "decimal.__dict__.__contains__('FloatOperation') == True (exception/signal raised when a float is mixed with a Decimal in an operation; disabled by default in DefaultContext)"]
    - [dc1261bb004, "__dict__.__contains__", ["Overflow"],          true,  "decimal.__dict__.__contains__('Overflow') == True (exception/signal raised when the result exponent exceeds Emax; extends both Inexact and Rounded; MRO length 8 per decimal_extra126)"]
    - [dc1261bb005, "__dict__.__contains__", ["Underflow"],         true,  "decimal.__dict__.__contains__('Underflow') == True (exception/signal raised when the result is subnormal and inexact; extends Inexact, Rounded, and Subnormal; MRO length 9 per decimal_extra126)"]
    - [dc1261bb006, "__dict__.__contains__", ["ROUND_CEILING"],     true,  "decimal.__dict__.__contains__('ROUND_CEILING') == True (rounding mode: round towards positive infinity; rounds up for positive numbers, does not round up for negative numbers)"]
    - [dc1261bb007, "__dict__.__contains__", ["ROUND_HALF_UP"],     true,  "decimal.__dict__.__contains__('ROUND_HALF_UP') == True (rounding mode: round to nearest with ties going away from zero; the commonly expected 'school' rounding rule)"]
    - [dc1261bb008, "__dict__.__contains__", ["ROUND_05UP"],        true,  "decimal.__dict__.__contains__('ROUND_05UP') == True (rounding mode: round away from zero if the last digit would have been 0 or 5; rounds to zero otherwise; specified by the GDA)"]

# ---------------------------------------------------------------------------
# decimal.__dict__ membership for utility functions, precision constants, NOT-in checks
# Functions: getcontext, setcontext, localcontext.
# Constants: HAVE_THREADS, HAVE_CONTEXTVAR, MAX_PREC, MAX_EMAX, MIN_EMIN, MIN_ETINY.
# NOT in decimal.__dict__: __all__, match, compile, open, io, re.
# ---------------------------------------------------------------------------

table decimal_extra1261.dict_functions_constants_and_not_in:
  description: "decimal.__dict__.__contains__ True for getcontext/setcontext/localcontext/HAVE_THREADS/HAVE_CONTEXTVAR/MIN_ETINY/MAX_EMAX; False for open/io/re (wrong-module names); wave-531 novel checks"
  kind: python_call_eq
  category: module_identity
  id_prefix: dc1261cc

  columns: [id, function, args, expected, description]
  rows:
    - [dc1261cc001, "__dict__.__contains__", ["getcontext"],    true,  "decimal.__dict__.__contains__('getcontext') == True (function that returns the current thread's arithmetic Context; each thread has an independent context initialized from DefaultContext)"]
    - [dc1261cc002, "__dict__.__contains__", ["setcontext"],    true,  "decimal.__dict__.__contains__('setcontext') == True (function that sets the current thread's arithmetic Context; takes a Context object; thread-local so it does not affect other threads)"]
    - [dc1261cc003, "__dict__.__contains__", ["localcontext"],  true,  "decimal.__dict__.__contains__('localcontext') == True (context manager that creates a temporary local arithmetic context; on exit restores the previous context; essential for scoped precision changes)"]
    - [dc1261cc004, "__dict__.__contains__", ["HAVE_THREADS"],  true,  "decimal.__dict__.__contains__('HAVE_THREADS') == True (boolean constant; True when the decimal module was compiled with thread support; affects whether thread-local contexts are used)"]
    - [dc1261cc005, "__dict__.__contains__", ["HAVE_CONTEXTVAR"], true, "decimal.__dict__.__contains__('HAVE_CONTEXTVAR') == True (boolean constant; True when contextvars is supported for propagating decimal context across async tasks)"]
    - [dc1261cc006, "__dict__.__contains__", ["MIN_ETINY"],     true,  "decimal.__dict__.__contains__('MIN_ETINY') == True (integer constant; the minimum allowable Etiny value — the most negative representable exponent accounting for subnormals)"]
    - [dc1261cc007, "__dict__.__contains__", ["open"],          false, "decimal.__dict__.__contains__('open') == False ('open' is a builtin I/O function from io/builtins; it is not present in the decimal module namespace)"]
    - [dc1261cc008, "__dict__.__contains__", ["io"],            false, "decimal.__dict__.__contains__('io') == False ('io' module is not imported by decimal; decimal has no file I/O operations and does not depend on the io module)"]
