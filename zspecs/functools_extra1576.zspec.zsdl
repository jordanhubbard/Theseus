spec: functools_extra1576
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __str__/__repr__/__bytes__ protocol"
    - "functools.partial.__dict__.__contains__('__repr__') == True — partial defines its own __repr__ in the C extension type dict."
    - "functools.partial.__dict__.__contains__('__str__') == False — partial inherits __str__ from object; no override in its own __dict__."
    - "functools.partialmethod.__dict__.__contains__('__repr__') == True — partialmethod defines its own __repr__ in Lib/functools.py."
    - "functools.cached_property does not define __repr__ or __str__ in its own __dict__; inherits from object."
    - "functools.reduce(str.__add__, ['a','b','c']) == 'abc' — reduce applies str.__add__ left-to-right over the list."
    - "functools.reduce(max, ['apple','banana','cherry']) == 'cherry' — max on strings uses lexicographic order."
    - "functools.reduce(lambda x,y: x*y, range(1,6)) == 120 — factorial of 5 via numeric reduce; str(result) == '120'."
    - "functools.lru_cache cache_info namedtuple has __class__.__name__ == 'CacheInfo' and str contains 'CacheInfo'."
    - "lru_cache-decorated function has __wrapped__ attribute whose __class__.__name__ is 'function'."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: partial — __repr__ and __str__ protocol dict-presence checks
#
# __str__/__repr__ protocol: partial defines its own __repr__ at the C level.
# __str__ is NOT defined in partial's own __dict__; it is inherited from object.
# __bytes__ is not defined anywhere in the functools hierarchy.
# ---------------------------------------------------------------------------

table functools_extra1576.partial_str_repr_protocol:
  description: "functools.partial __dict__ presence of __repr__, __str__, __bytes__ — str/repr protocol; new to extra1576"
  kind: python_call_eq
  category: str_repr_protocol
  id_prefix: fu1576pa

  columns: [id, function, args, expected, description]
  rows:
    - ["fu1576pa001",
       "partial.__dict__.__contains__",
       ["__repr__"],
       true,
       "functools.partial.__dict__.__contains__('__repr__') == True — partial defines its own __repr__ in the C extension type; wave 552; new to extra1576"]
    - ["fu1576pa002",
       "partial.__dict__.__contains__",
       ["__str__"],
       false,
       "functools.partial.__dict__.__contains__('__str__') == False — partial does not define __str__; inherits from object; wave 552; new to extra1576"]
    - ["fu1576pa003",
       "partial.__dict__.__contains__",
       ["__bytes__"],
       false,
       "functools.partial.__dict__.__contains__('__bytes__') == False — partial defines no __bytes__; not a bytes-convertible type; wave 552; new to extra1576"]
    - ["fu1576pa004",
       "partial.__dict__.__contains__",
       ["__format__"],
       false,
       "functools.partial.__dict__.__contains__('__format__') == False — partial defines no __format__; inherits from object; wave 552; new to extra1576"]

# ---------------------------------------------------------------------------
# Table 2: partialmethod — __repr__ and __str__ protocol dict-presence checks
#
# partialmethod (Python class in Lib/functools.py) defines its own __repr__
# but does not define __str__ or __bytes__.
# ---------------------------------------------------------------------------

table functools_extra1576.partialmethod_str_repr_protocol:
  description: "functools.partialmethod __dict__ presence of __repr__, __str__, __bytes__ — str/repr protocol; new to extra1576"
  kind: python_call_eq
  category: str_repr_protocol
  id_prefix: fu1576pm

  columns: [id, function, args, expected, description]
  rows:
    - ["fu1576pm001",
       "partialmethod.__dict__.__contains__",
       ["__repr__"],
       true,
       "functools.partialmethod.__dict__.__contains__('__repr__') == True — partialmethod defines its own __repr__ in Lib/functools.py; wave 552; new to extra1576"]
    - ["fu1576pm002",
       "partialmethod.__dict__.__contains__",
       ["__str__"],
       false,
       "functools.partialmethod.__dict__.__contains__('__str__') == False — partialmethod does not define __str__; inherits from object; wave 552; new to extra1576"]
    - ["fu1576pm003",
       "partialmethod.__dict__.__contains__",
       ["__bytes__"],
       false,
       "functools.partialmethod.__dict__.__contains__('__bytes__') == False — partialmethod defines no __bytes__; wave 552; new to extra1576"]

# ---------------------------------------------------------------------------
# Table 3: cached_property — __repr__ and __str__ protocol dict-presence checks
#
# cached_property (Python descriptor class in Lib/functools.py) inherits
# __repr__ and __str__ from object; neither is defined in its own __dict__.
# ---------------------------------------------------------------------------

table functools_extra1576.cached_property_str_repr_protocol:
  description: "functools.cached_property __dict__ presence of __repr__, __str__, __bytes__ — str/repr protocol; new to extra1576"
  kind: python_call_eq
  category: str_repr_protocol
  id_prefix: fu1576cp

  columns: [id, function, args, expected, description]
  rows:
    - ["fu1576cp001",
       "cached_property.__dict__.__contains__",
       ["__repr__"],
       false,
       "functools.cached_property.__dict__.__contains__('__repr__') == False — cached_property does not define __repr__ in its own __dict__; inherits from object; wave 552; new to extra1576"]
    - ["fu1576cp002",
       "cached_property.__dict__.__contains__",
       ["__str__"],
       false,
       "functools.cached_property.__dict__.__contains__('__str__') == False — cached_property does not define __str__ in its own __dict__; wave 552; new to extra1576"]
    - ["fu1576cp003",
       "cached_property.__dict__.__contains__",
       ["__bytes__"],
       false,
       "functools.cached_property.__dict__.__contains__('__bytes__') == False — cached_property defines no __bytes__; wave 552; new to extra1576"]

# ---------------------------------------------------------------------------
# Table 4: reduce with string operations — str representation of results
#
# reduce applies a binary function left-to-right over a sequence.
# These rows verify that string results from reduce are the correct Python str
# type (class name 'str') and have the correct value.
# ---------------------------------------------------------------------------

table functools_extra1576.reduce_string_results:
  description: "functools.reduce on string sequences produces correct str results — __str__ protocol via str concatenation and comparison; new to extra1576"
  kind: python_call_eq
  category: reduce_strings
  id_prefix: fu1576rs

  columns: [id, function, args, expected, description]
  rows:
    - ["fu1576rs001",
       "reduce",
       [str.__add__, ["a", "b", "c"]],
       "abc",
       "functools.reduce(str.__add__, ['a','b','c']) == 'abc' — left-fold with str.__add__; wave 552; new to extra1576"]
    - ["fu1576rs002",
       "reduce",
       [max, ["apple", "banana", "cherry"]],
       "cherry",
       "functools.reduce(max, ['apple','banana','cherry']) == 'cherry' — lexicographic max via reduce; wave 552; new to extra1576"]
    - ["fu1576rs003",
       "reduce",
       [min, ["apple", "banana", "cherry"]],
       "apple",
       "functools.reduce(min, ['apple','banana','cherry']) == 'apple' — lexicographic min via reduce; wave 552; new to extra1576"]
    - ["fu1576rs004",
       "reduce",
       [str.__add__, ["hello", " ", "world"]],
       "hello world",
       "functools.reduce(str.__add__, ['hello',' ','world']) == 'hello world' — multi-item str concatenation; wave 552; new to extra1576"]
    - ["fu1576rs005",
       "reduce",
       [max, ["z", "a", "m", "b"]],
       "z",
       "functools.reduce(max, ['z','a','m','b']) == 'z' — single-char lexicographic max; wave 552; new to extra1576"]
    - ["fu1576rs006",
       "reduce",
       [min, ["z", "a", "m", "b"]],
       "a",
       "functools.reduce(min, ['z','a','m','b']) == 'a' — single-char lexicographic min; wave 552; new to extra1576"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1576
# ---------------------------------------------------------------------------

invariant functools_extra1576.partial_has_repr:
  description: "functools.partial.__dict__.__contains__('__repr__') == True — partial defines its own __repr__; wave 552; new to extra1576"
  kind: python_call_eq
  function: partial.__dict__.__contains__
  args: ["__repr__"]
  expected: true

invariant functools_extra1576.partial_no_str:
  description: "functools.partial.__dict__.__contains__('__str__') == False — partial does not define __str__ in its own __dict__; wave 552; new to extra1576"
  kind: python_call_eq
  function: partial.__dict__.__contains__
  args: ["__str__"]
  expected: false

invariant functools_extra1576.partialmethod_has_repr:
  description: "functools.partialmethod.__dict__.__contains__('__repr__') == True — partialmethod defines its own __repr__; wave 552; new to extra1576"
  kind: python_call_eq
  function: partialmethod.__dict__.__contains__
  args: ["__repr__"]
  expected: true

invariant functools_extra1576.partialmethod_no_str:
  description: "functools.partialmethod.__dict__.__contains__('__str__') == False — partialmethod does not define __str__ in its own __dict__; wave 552; new to extra1576"
  kind: python_call_eq
  function: partialmethod.__dict__.__contains__
  args: ["__str__"]
  expected: false

invariant functools_extra1576.cached_property_no_repr:
  description: "functools.cached_property.__dict__.__contains__('__repr__') == False — cached_property does not define __repr__ in its own __dict__; wave 552; new to extra1576"
  kind: python_call_eq
  function: cached_property.__dict__.__contains__
  args: ["__repr__"]
  expected: false

invariant functools_extra1576.reduce_str_add:
  description: "functools.reduce(str.__add__, ['a','b','c']) == 'abc' — str concatenation via reduce; wave 552; new to extra1576"
  kind: python_call_eq
  function: reduce
  args: [str.__add__, ["a", "b", "c"]]
  expected: "abc"

invariant functools_extra1576.reduce_max_str:
  description: "functools.reduce(max, ['apple','banana','cherry']) == 'cherry' — lexicographic max via reduce; wave 552; new to extra1576"
  kind: python_call_eq
  function: reduce
  args: [max, ["apple", "banana", "cherry"]]
  expected: "cherry"
