spec: datetime_extra11
version: ">=3.9"
backend: python_module(datetime)

docs: https://docs.python.org/3/library/datetime.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/datetime.html — Python datetime module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_datetimemodule.c"
    - "CPython source: Lib/datetime.py"
  notes:
    - "This spec extends datetime.zspec.zsdl and prior extras through datetime_extra10.zspec.zsdl."
    - "datetime_extra (extra1) covers: MINYEAR/MAXYEAR values, time/timezone/timedelta __name__, timezone.utc class name, date/datetime bounds class names."
    - "datetime_extra2 covers: MINYEAR/MAXYEAR, timezone/timedelta/date/time __name__, timezone.utc class name, datetime.fromisoformat.__name__."
    - "datetime_extra3 covers: datetime/__module__, date/__module__, timezone/__module__, tzinfo/__module__."
    - "datetime_extra4 covers: __qualname__ for datetime/date/time/timedelta/timezone/tzinfo (table)."
    - "datetime_extra5 covers: time/__module__, additional __qualname__ table."
    - "datetime_extra6–8 cover: fromisoformat/timetuple/isoweekday/timedelta normalization."
    - "datetime_extra9 covers: date.min/max isoformat+toordinal; timedelta.min/max.days; timedelta.resolution.microseconds; timezone.utc.tzname/utcoffset; datetime.min.isoformat."
    - "datetime_extra10 covers: date(2026,4,9) constructor attributes; timedelta(days=1/.hours=24) normalization; timedelta.__name__ in extra10 namespace."
    - "NEW in extra11 — Axis 1: class method __name__ on datetime/date alternate constructors (strptime, fromordinal, fromtimestamp)."
    - "NEW in extra11 — Axis 2: date.min and date.max year/month/day field values."
    - "NEW in extra11 — Axis 3: MRO lengths for datetime/timezone/timedelta (not covered in any prior spec)."
    - "NEW in extra11 — Axis 4: MINYEAR and MAXYEAR are plain int class members (class name check)."
    - "datetime.datetime.strptime.__name__ == 'strptime' — class method name; not covered in prior extras."
    - "datetime.date.fromordinal.__name__ == 'fromordinal' — not in any prior spec."
    - "datetime.date.fromtimestamp.__name__ == 'fromtimestamp' — not in any prior spec."
    - "datetime.date.min.year == 1, .month == 1, .day == 1 — field values of the min sentinel."
    - "datetime.date.max.year == 9999, .month == 12, .day == 31 — field values of the max sentinel."
    - "len(datetime.datetime.__mro__) == 3 — ZoneInfo -> date -> object MRO; not covered before."
    - "len(datetime.timezone.__mro__) == 3 — timezone -> tzinfo -> object; not covered before."
    - "len(datetime.timedelta.__mro__) == 2 — timedelta -> object; not covered before."
    - "datetime.MINYEAR.__class__.__name__ == 'int' — module constant is a plain integer."
    - "datetime.MAXYEAR.__class__.__name__ == 'int' — module constant is a plain integer."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Alternate constructor __name__ attributes — strptime, fromordinal, fromtimestamp
#
# time.zspec.zsdl covers strptime/__name__ on the time module. In the datetime
# module, datetime.datetime.strptime/__name__ has never been checked in any
# prior datetime spec. date.fromordinal and date.fromtimestamp are also new.
# ---------------------------------------------------------------------------

invariant datetime_extra11.datetime.strptime_name:
  description: "datetime.datetime.strptime.__name__ == 'strptime' — class method name"
  category: class_method_names
  kind: python_call_eq
  function: datetime.strptime.__name__.__eq__
  args: ["strptime"]
  expected: true

invariant datetime_extra11.date.fromordinal_name:
  description: "datetime.date.fromordinal.__name__ == 'fromordinal' — class method name"
  category: class_method_names
  kind: python_call_eq
  function: date.fromordinal.__name__.__eq__
  args: ["fromordinal"]
  expected: true

invariant datetime_extra11.date.fromtimestamp_name:
  description: "datetime.date.fromtimestamp.__name__ == 'fromtimestamp' — class method name"
  category: class_method_names
  kind: python_call_eq
  function: date.fromtimestamp.__name__.__eq__
  args: ["fromtimestamp"]
  expected: true

# ---------------------------------------------------------------------------
# date.min sentinel field values — year, month, day
#
# Prior specs check date.min.__class__.__name__ == 'date' (extra) and
# date.min.isoformat() (extra9). No prior spec checks the numeric field
# values .year, .month, .day of the date.min sentinel directly.
# ---------------------------------------------------------------------------

invariant datetime_extra11.date.min_year:
  description: "datetime.date.min.year == 1 — earliest representable year"
  category: date_sentinels
  kind: python_call_eq
  function: date.min.year.__eq__
  args: [1]
  expected: true

invariant datetime_extra11.date.min_month:
  description: "datetime.date.min.month == 1 — earliest representable month"
  category: date_sentinels
  kind: python_call_eq
  function: date.min.month.__eq__
  args: [1]
  expected: true

invariant datetime_extra11.date.min_day:
  description: "datetime.date.min.day == 1 — earliest representable day"
  category: date_sentinels
  kind: python_call_eq
  function: date.min.day.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# date.max sentinel field values — year, month, day
#
# Same rationale as date.min above: only the class name and isoformat() of
# date.max have been covered in prior specs; the numeric fields are new.
# ---------------------------------------------------------------------------

invariant datetime_extra11.date.max_year:
  description: "datetime.date.max.year == 9999 — latest representable year"
  category: date_sentinels
  kind: python_call_eq
  function: date.max.year.__eq__
  args: [9999]
  expected: true

invariant datetime_extra11.date.max_month:
  description: "datetime.date.max.month == 12 — latest representable month"
  category: date_sentinels
  kind: python_call_eq
  function: date.max.month.__eq__
  args: [12]
  expected: true

invariant datetime_extra11.date.max_day:
  description: "datetime.date.max.day == 31 — latest representable day"
  category: date_sentinels
  kind: python_call_eq
  function: date.max.day.__eq__
  args: [31]
  expected: true

# ---------------------------------------------------------------------------
# MRO lengths — datetime, timezone, timedelta
#
# No prior spec checks len(__mro__) for any datetime class. The MRO lengths
# are: datetime (3: datetime->date->object), timezone (3: timezone->tzinfo->object),
# timedelta (2: timedelta->object). tzinfo MRO len is 2 (tzinfo->object).
# ---------------------------------------------------------------------------

invariant datetime_extra11.datetime.mro_length:
  description: "len(datetime.datetime.__mro__) == 3 — datetime -> date -> object"
  category: class_hierarchy
  kind: python_call_eq
  function: datetime.__mro__.__len__
  args: []
  expected: 3

invariant datetime_extra11.timezone.mro_length:
  description: "len(datetime.timezone.__mro__) == 3 — timezone -> tzinfo -> object"
  category: class_hierarchy
  kind: python_call_eq
  function: timezone.__mro__.__len__
  args: []
  expected: 3

invariant datetime_extra11.timedelta.mro_length:
  description: "len(datetime.timedelta.__mro__) == 2 — timedelta -> object"
  category: class_hierarchy
  kind: python_call_eq
  function: timedelta.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# MINYEAR and MAXYEAR are plain int instances
#
# Prior specs verify MINYEAR == 1 and MAXYEAR == 9999. No prior spec checks
# that these module-level constants are instances of int (not some subclass).
# ---------------------------------------------------------------------------

invariant datetime_extra11.MINYEAR.class_name:
  description: "datetime.MINYEAR.__class__.__name__ == 'int' — module constant is a plain integer"
  category: module_constants
  kind: python_call_eq
  function: MINYEAR.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant datetime_extra11.MAXYEAR.class_name:
  description: "datetime.MAXYEAR.__class__.__name__ == 'int' — module constant is a plain integer"
  category: module_constants
  kind: python_call_eq
  function: MAXYEAR.__class__.__name__.__eq__
  args: ["int"]
  expected: true
