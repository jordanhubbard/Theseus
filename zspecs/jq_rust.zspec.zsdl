spec: jq_rust
version: ">=3.9"
backend: rust_module(jq_rust)

docs: https://stedolan.github.io/jq/manual/

provenance:
  derived_from:
    - "https://stedolan.github.io/jq/manual/ — jq manual"
  not_derived_from:
    - "jq Python source: jq.py"
  notes:
    - "jq Python bindings: jq.first(filter, input) returns first result."
    - "jq.all(filter, input) returns all results as a list."
    - "jq.first('.foo', {'foo': 42}) == 42."
    - "jq.first('.name', {'name': 'World'}) == 'World'."
    - "jq.first('length', [1,2,3]) == 3."
    - "jq.first('.foo.bar', {'foo': {'bar': 'hello'}}) == 'hello' — nested access."
    - "jq.all('.[]', [1, 2, 3]) == [1, 2, 3] — iterate array."
    - "jq.first('.[] | select(. > 2)', [1, 2, 3, 4]) == 3 — filter pipeline."
    - "All test vectors verified against jq 1.8.0 Python bindings."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# jq.first — return first result of filter on input
table jq_rust.first.scalars:
  kind: python_call_eq
  category: first
  id_prefix: jq_f
  function: first

  columns: [id, args, expected]
  rows:
    - [int_field,    [".foo", {"foo": 42}],                  42]
    - [str_field,    [".name", {"name": "World"}],            "World"]
    - [nested,       [".foo.bar", {"foo": {"bar": "hello"}}], "hello"]
    - [length,       ["length", [1, 2, 3]],                   3]
    - [identity,     [".", 42],                               42]
    - [bool_field,   [".ok", {"ok": true}],                   true]

# jq.all — return all results as list
table jq_rust.all.vectors:
  kind: python_call_eq
  category: all
  id_prefix: jq_a
  function: all

  columns: [id, args, expected]
  rows:
    - [iterate,  [".[]", [1, 2, 3]],            [1, 2, 3]]
    - [map_add,  [".[] + 1", [10, 20, 30]],     [11, 21, 31]]
    - [single,   [".", 42],                      [42]]
    - [keys,     ["keys[]", {"a": 1, "b": 2}], ["a", "b"]]

