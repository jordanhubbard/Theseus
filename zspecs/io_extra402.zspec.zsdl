spec: io_extra402
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "io.FileIO methods read, write, seek, tell, close, readable, writable, seekable each report __name__ matching their Python-level name"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.FileIO method __name__ identity
# ---------------------------------------------------------------------------

table io_extra402.fileio_method_names:
  description: "io.FileIO method __name__ identity — read, write, seek, tell, close, readable, writable, seekable; each method's __name__ matches its Python-level name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: iofileio402

  columns: [id, function, args, expected]
  rows:
    - [read_name,     io.FileIO.read.__name__.__eq__,     ["read"],     true]
    - [write_name,    io.FileIO.write.__name__.__eq__,    ["write"],    true]
    - [seek_name,     io.FileIO.seek.__name__.__eq__,     ["seek"],     true]
    - [tell_name,     io.FileIO.tell.__name__.__eq__,     ["tell"],     true]
    - [close_name,    io.FileIO.close.__name__.__eq__,    ["close"],    true]
    - [readable_name, io.FileIO.readable.__name__.__eq__, ["readable"], true]
    - [writable_name, io.FileIO.writable.__name__.__eq__, ["writable"], true]
    - [seekable_name, io.FileIO.seekable.__name__.__eq__, ["seekable"], true]
