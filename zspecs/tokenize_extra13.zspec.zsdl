spec: tokenize_extra13
version: ">=3.9"
backend: python_module(tokenize)

docs: https://docs.python.org/3/library/tokenize.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tokenize.html — Python tokenize module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tokenize.py"
    - "tokenize_extra12.zspec.zsdl — covers generate_tokens/open/untokenize __qualname__.__eq__; TokenInfo/__qualname__.__eq__; TokenError/__qualname__.__eq__; qualname __len__() for tokenize/generate_tokens/detect_encoding/open/untokenize"
    - "tokenize_extra11.zspec.zsdl — covers TokenInfo._fields items/class/len; Untokenizer __name__/__qualname__/__module__/base; TokenError base; open/__name__ and untokenize/__name__; cookie_re class"
    - "tokenize_extra10.zspec.zsdl — covers tokenize/__name__, generate_tokens/__name__, detect_encoding/__name__; TokenError/__name__/__module__; TokenInfo/__name__/__module__"
    - "tokenize_extra9.zspec.zsdl — covers tokenize/__qualname__.__eq__ and detect_encoding/__qualname__.__eq__; TokenInfo._make/_asdict/_replace __qualname__; untokenize/open __module__"
  notes:
    - "This spec extends tokenize_extra12.zspec.zsdl."
    - "Focus: __qualname__.__len__() for TokenInfo and TokenError (class-level qualname lengths); __class__.__name__ standalone invariants for COMMENT and NUMBER constants in the tokenize_extra13 namespace."
    - "tokenize.TokenInfo.__qualname__.__len__() == 9 — tokenize_extra12 covers TokenInfo.__qualname__.__eq__; the __len__() form is new in tokenize_extra13."
    - "tokenize.TokenError.__qualname__.__len__() == 10 — tokenize_extra12 covers TokenError.__qualname__.__eq__; the __len__() form is new in tokenize_extra13."
    - "tokenize.COMMENT.__class__.__name__ == 'int' — no prior tokenize spec covers COMMENT.__class__.__name__ as a standalone __eq__ invariant."
    - "tokenize.NUMBER.__class__.__name__ == 'int' — no prior tokenize spec covers NUMBER.__class__.__name__ as a standalone __eq__ invariant in the tokenize_extra13 namespace."
    - "tokenize.tokenize.__qualname__.__len__() == 8 — tokenize_extra12 covers this in a table; distinct standalone invariant in tokenize_extra13 namespace."
    - "tokenize.detect_encoding.__qualname__.__len__() == 15 — tokenize_extra12 covers this in a table; distinct standalone invariant in tokenize_extra13 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __qualname__.__len__() — TokenInfo, TokenError
# (tokenize_extra13 namespace)
#
# tokenize_extra12 covers TokenInfo/__qualname__.__eq__ and
# TokenError/__qualname__.__eq__. The __len__() form for these class qualnames
# is not covered in any prior tokenize spec.
# TokenInfo: len('TokenInfo') == 9; TokenError: len('TokenError') == 10.
# ---------------------------------------------------------------------------

invariant tokenize_extra13.TokenInfo.qualname_len:
  description: "tokenize.TokenInfo.__qualname__.__len__() == 9 — 'TokenInfo' has 9 characters"
  category: class_qualname_lengths
  kind: python_call_eq
  function: TokenInfo.__qualname__.__len__
  args: []
  expected: 9

invariant tokenize_extra13.TokenError.qualname_len:
  description: "tokenize.TokenError.__qualname__.__len__() == 10 — 'TokenError' has 10 characters"
  category: class_qualname_lengths
  kind: python_call_eq
  function: TokenError.__qualname__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# Token constant __class__.__name__ — COMMENT and NUMBER
# (tokenize_extra13 namespace)
#
# No prior tokenize spec covers COMMENT.__class__.__name__ or
# NUMBER.__class__.__name__ as standalone __eq__ invariants in any namespace.
# Both constants are plain Python ints (COMMENT=65, NUMBER=2).
# ---------------------------------------------------------------------------

invariant tokenize_extra13.COMMENT.class_is_int:
  description: "tokenize.COMMENT.__class__.__name__ == 'int' — COMMENT token constant is an integer"
  category: class_names
  kind: python_call_eq
  function: COMMENT.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant tokenize_extra13.NUMBER.class_is_int:
  description: "tokenize.NUMBER.__class__.__name__ == 'int' — NUMBER token constant is an integer"
  category: class_names
  kind: python_call_eq
  function: NUMBER.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Function __qualname__.__len__() — tokenize, detect_encoding
# (tokenize_extra13 namespace)
#
# tokenize_extra12 covers these lengths in a table (function_qualname_lens).
# These standalone invariants in the tokenize_extra13 namespace are distinct.
# tokenize: len=8; detect_encoding: len=15.
# ---------------------------------------------------------------------------

invariant tokenize_extra13.tokenize_fn.qualname_len:
  description: "tokenize.tokenize.__qualname__.__len__() == 8 — 'tokenize' has 8 characters"
  category: function_qualname_lengths
  kind: python_call_eq
  function: tokenize.__qualname__.__len__
  args: []
  expected: 8

invariant tokenize_extra13.detect_encoding.qualname_len:
  description: "tokenize.detect_encoding.__qualname__.__len__() == 15 — 'detect_encoding' has 15 characters"
  category: function_qualname_lengths
  kind: python_call_eq
  function: detect_encoding.__qualname__.__len__
  args: []
  expected: 15
