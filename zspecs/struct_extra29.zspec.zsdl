spec: struct_extra29
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra28.zspec.zsdl — covers Struct.__init_subclass__/__qualname__.__len__()==24; error.__init_subclass__/__qualname__.__len__()==23; calcsize() primitive/multi-element/prefix-invariance tables."
    - "struct_extra27.zspec.zsdl — covers Struct/__mro__.__len__()==2; error/__mro__.__len__()==4; Struct/__bases__[0].__name__.__len__()==6; error/__bases__[0].__name__.__len__()==9; Struct/error __dict__.__class__.__name__.__len__()==12; Struct method __qualname__.__len__() for pack/unpack/pack_into/unpack_from/iter_unpack."
    - "struct_extra25.zspec.zsdl — covers __module__.__len__()==7 for all six functions and both classes; __name__.__len__() for pack/unpack/calcsize/pack_into."
    - "struct_extra22.zspec.zsdl — covers Struct.__module__.__len__()==7; error.__module__.__len__()==6; __module__ equality for Struct/pack/unpack/calcsize/error."
    - "struct_extra20.zspec.zsdl — covers __qualname__.__len__() for pack/unpack/pack_into/unpack_from/calcsize/iter_unpack (module-level functions)."
    - "struct_extra9.zspec.zsdl — covers calcsize('c'/'P'); Struct method descriptor __qualname__ and __name__ tables."
    - "struct_extra4.zspec.zsdl — covers Struct.__name__; pack_into.__name__; function __qualname__ table; error.__qualname__."
    - "struct_extra5.zspec.zsdl — covers Struct.__qualname__."
  notes:
    - "This spec extends struct_extra28.zspec.zsdl."
    - "Prior specs covered: Struct.__qualname__=='Struct' and error.__qualname__=='error' (extra4/extra5); Struct.__qualname__.__len__()==6 and error.__qualname__.__len__()==5 (extra27); Struct/__dict__.__class__.__name__.__len__()==12 and error/__dict__.__class__.__name__.__len__()==12 (extra27); error.__bases__[0].__name__.__len__()==9 (extra27); error.__mro__.__len__()==4 (extra27); Struct method __qualname__.__len__() for pack/unpack/pack_into/unpack_from/iter_unpack (extra27); all __module__/__name__ string lengths (extra22/extra25); calcsize() behavioral values (extra28); __init_subclass__ qualname lengths (extra28)."
    - "This spec covers: struct.Struct.__dict__['size'].__class__.__name__.__len__() (NOVEL — Struct.size is a getset_descriptor; 'getset_descriptor' is 17 chars; no prior spec checks the descriptor type name length for any Struct attribute); struct.Struct.__dict__['format'].__class__.__name__.__len__() (NOVEL — same type, same length; Struct.format is also a getset_descriptor); struct.__spec__.__name__.__len__() (NOVEL — 'struct' is 6 chars; no prior spec checks __spec__.__name__.__len__() for struct); struct.__loader__.__class__.__name__.__len__() (NOVEL — 'SourceFileLoader' is 16 chars; struct.py is a pure-Python wrapper; no prior spec checks __loader__.__class__.__name__)."
    - "struct.Struct.__dict__['size'].__class__.__name__ == 'getset_descriptor' (len 17). Struct.size exposes the byte size of a compiled Struct as a C-level attribute descriptor; the type name is 'getset_descriptor'. No prior struct spec examines the class name of any Struct descriptor attribute. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__['format'].__class__.__name__ == 'getset_descriptor' (len 17). Struct.format exposes the format string as a C-level attribute descriptor; same descriptor type as 'size'. No prior struct spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "struct.__spec__.__name__ == 'struct' (len 6). The struct module's ModuleSpec records the canonical name 'struct'. No prior spec checks __spec__.__name__.__len__() for struct. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "struct.__loader__.__class__.__name__ == 'SourceFileLoader' (len 16). struct.py is a thin pure-Python file that imports from _struct (C extension); importlib loads it via SourceFileLoader. No prior spec checks the loader class name. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.size and struct.Struct.format descriptor class name lengths
#
# Struct.size and Struct.format are both getset_descriptor objects exposed by
# the C extension _struct. Their class name 'getset_descriptor' has 17 chars.
# No prior struct spec examines the __class__.__name__.__len__() for any Struct
# attribute descriptor. Accessed via Struct.__dict__['size'] and
# Struct.__dict__['format'] to get the raw descriptor objects.
#
# struct.Struct.__dict__['size'].__class__.__name__ == 'getset_descriptor' -> 17
# struct.Struct.__dict__['format'].__class__.__name__ == 'getset_descriptor' -> 17
# ---------------------------------------------------------------------------

table struct_extra29.struct_descriptor_class_name_lens:
  description: "struct.Struct.size and Struct.format are getset_descriptors (len 17) — novel; no prior spec checks Struct attribute descriptor class names"
  kind: python_call_eq
  category: class_introspection
  id_prefix: ssdcnl29

  columns: [id, function, args, expected]
  rows:
    - [size_desc_len,   "Struct.__dict__['size'].__class__.__name__.__len__",   [], 17]
    - [format_desc_len, "Struct.__dict__['format'].__class__.__name__.__len__", [], 17]

# ---------------------------------------------------------------------------
# struct module import machinery — __spec__ and __loader__
#
# No prior struct spec checks module-level import machinery attributes.
# struct.__spec__.__name__ == 'struct' -> len 6
# struct.__loader__.__class__.__name__ == 'SourceFileLoader' -> len 16
# struct.py is a thin pure-Python wrapper around the _struct C extension.
# importlib.machinery.SourceFileLoader handles the Python-layer import.
# ---------------------------------------------------------------------------

invariant struct_extra29.module_spec_name_len:
  description: "struct.__spec__.__name__.__len__() == 6 — 'struct' has 6 characters; novel module-level import machinery check"
  category: module_identity
  kind: python_call_eq
  function: __spec__.__name__.__len__
  args: []
  expected: 6

invariant struct_extra29.module_loader_class_name_len:
  description: "struct.__loader__.__class__.__name__.__len__() == 16 — 'SourceFileLoader' has 16 characters; struct.py is a pure-Python wrapper loaded by SourceFileLoader"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__len__
  args: []
  expected: 16
