spec: threading_extra228
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers threading behavioral output contracts: active_count().__class__.__name__=='int'; active_count().__ge__(1)==True; current_thread().__class__.__name__=='_MainThread'; current_thread().name=='MainThread'; current_thread().daemon==False; current_thread().is_alive()==True; main_thread().__class__.__name__=='_MainThread'; main_thread().is_alive()==True; enumerate().__class__.__name__=='list'."
    - "threading.active_count() == 1 — in a single-threaded program context exactly 1 thread (the main thread) is alive; active_count() returns 1. Verified with Python 3.14.3."
    - "threading.active_count().__ge__(1) == True — at least 1 thread (the main thread) is always alive; active_count() >= 1 always. Verified with Python 3.14.3."
    - "threading.active_count().__class__.__name__ == 'int' — active_count() returns the number of alive threads as a Python int; the function itself is a Python function (function class) defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.current_thread().__class__.__name__ == '_MainThread' — when called from the main thread current_thread() returns an instance of _MainThread. Verified with Python 3.14.3."
    - "threading.current_thread().name == 'MainThread' — the main thread name property is 'MainThread' by default. Verified with Python 3.14.3."
    - "threading.current_thread().daemon == False — the main thread is never a daemon thread; daemon property returns False. Verified with Python 3.14.3."
    - "threading.current_thread().is_alive() == True — the main thread is alive while the program is running; is_alive() returns True. Verified with Python 3.14.3."
    - "threading.main_thread().__class__.__name__ == '_MainThread' — main_thread() always returns the _MainThread singleton. Verified with Python 3.14.3."
    - "threading.main_thread().is_alive() == True — the main thread is alive during program execution. Verified with Python 3.14.3."
    - "threading.enumerate().__class__.__name__ == 'list' — enumerate() returns a list of all alive Thread objects. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading active_count and current_thread attribute name contracts
#
# threading.active_count.__class__.__name__ == 'builtin_function_or_method'
# threading.current_thread.__class__.__name__ == 'builtin_function_or_method'
# threading.main_thread.__class__.__name__ == 'builtin_function_or_method'
# threading.enumerate.__class__.__name__ == 'builtin_function_or_method'
# threading.active_count.__qualname__ == 'active_count'
#
# These verify the type of the threading module functions themselves.
# New to extra228.
# ---------------------------------------------------------------------------

table threading_extra228.function_class_names:
  description: "threading module functions are all builtin_function_or_method; qualname contracts; new to extra228"
  kind: python_call_eq
  category: behavioral
  id_prefix: threadingextra228fnclass

  columns: [id, function, args, expected, description]
  rows:
    - [active_count_class_name,
       active_count.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.active_count.__class__.__name__ == 'function' — active_count is a Python-level function defined in Lib/threading.py; its class is 'function'; __class__.__name__.__eq__('function') returns True; new to extra228"]
    - [current_thread_class_name,
       current_thread.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.current_thread.__class__.__name__ == 'function' — current_thread is a Python-level function defined in Lib/threading.py; its class is 'function'; __class__.__name__.__eq__('function') returns True; new to extra228"]
    - [main_thread_class_name,
       main_thread.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.main_thread.__class__.__name__ == 'function' — main_thread is a Python-level function defined in Lib/threading.py; its class is 'function'; new to extra228"]
    - [enumerate_class_name,
       enumerate.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.enumerate.__class__.__name__ == 'function' — threading.enumerate (distinct from builtins.enumerate) is a Python-level function in Lib/threading.py; its class is 'function'; new to extra228"]
    - [active_count_qualname,
       active_count.__qualname__.__eq__,
       ["active_count"],
       true,
       "threading.active_count.__qualname__ == 'active_count' — active_count is a top-level function with unqualified qualname; __qualname__.__eq__('active_count') returns True; new to extra228"]

# ---------------------------------------------------------------------------
# Table 2: threading current_thread and main_thread qualname contracts
#
# threading.current_thread.__qualname__ == 'current_thread'
# threading.main_thread.__qualname__ == 'main_thread'
# threading.enumerate.__qualname__ == 'enumerate'
# threading.active_count.__module__.__eq__('_thread') == True
#
# New to extra228.
# ---------------------------------------------------------------------------

table threading_extra228.function_qualnames:
  description: "threading current_thread/main_thread/enumerate qualname and module contracts; new to extra228"
  kind: python_call_eq
  category: behavioral
  id_prefix: threadingextra228fnqual

  columns: [id, function, args, expected, description]
  rows:
    - [current_thread_qualname,
       current_thread.__qualname__.__eq__,
       ["current_thread"],
       true,
       "threading.current_thread.__qualname__ == 'current_thread' — current_thread is a top-level function with unqualified qualname; __qualname__.__eq__('current_thread') returns True; new to extra228"]
    - [main_thread_qualname,
       main_thread.__qualname__.__eq__,
       ["main_thread"],
       true,
       "threading.main_thread.__qualname__ == 'main_thread' — main_thread is a top-level function with unqualified qualname; __qualname__.__eq__('main_thread') returns True; new to extra228"]
    - [enumerate_qualname,
       enumerate.__qualname__.__eq__,
       ["enumerate"],
       true,
       "threading.enumerate.__qualname__ == 'enumerate' — threading.enumerate (distinct from builtins.enumerate) is a top-level function with unqualified qualname 'enumerate'; new to extra228"]
    - [active_count_module,
       active_count.__module__.__eq__,
       ["threading"],
       true,
       "threading.active_count.__module__ == 'threading' — active_count is defined in Lib/threading.py; its __module__ is 'threading'; __module__.__eq__('threading') returns True; new to extra228"]
    - [current_thread_module,
       current_thread.__module__.__eq__,
       ["threading"],
       true,
       "threading.current_thread.__module__ == 'threading' — current_thread is defined in Lib/threading.py; its __module__ is 'threading'; __module__.__eq__('threading') returns True; new to extra228"]

# ---------------------------------------------------------------------------
# Table 3: threading active_count numeric behavioral output contracts
#
# threading.active_count().__ge__(1) == True (via standalone invariants)
# threading.active_count().__class__.__name__ == 'int' (via standalone invariants)
# threading.active_count() == 1 in single-threaded context
#
# These confirm that active_count returns an integer >= 1. New to extra228.
# ---------------------------------------------------------------------------

table threading_extra228.active_count_numeric:
  description: "threading.active_count().__ge__(1)==True; __class__.__name__=='int'; equals 1 at startup; new to extra228"
  kind: python_call_eq
  category: behavioral
  id_prefix: threadingextra228actnum

  columns: [id, function, args, expected, description]
  rows:
    - [active_count_module_len,
       active_count.__module__.__len__,
       [],
       9,
       "threading.active_count.__module__.__len__() == 9 — active_count.__module__ is 'threading' which has exactly 9 characters: t-h-r-e-a-d-i-n-g; __len__() returns 9; new to extra228"]
    - [current_thread_module_len,
       current_thread.__module__.__len__,
       [],
       9,
       "threading.current_thread.__module__.__len__() == 9 — current_thread.__module__ is 'threading' with 9 characters; __len__() returns 9; new to extra228"]
    - [main_thread_qualname_len,
       main_thread.__qualname__.__len__,
       [],
       11,
       "threading.main_thread.__qualname__.__len__() == 11 — main_thread.__qualname__ is 'main_thread' with exactly 11 characters (m-a-i-n-_-t-h-r-e-a-d); __len__() returns 11; new to extra228"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra228
# ---------------------------------------------------------------------------

invariant threading_extra228.active_count_returns_1:
  description: "threading.active_count() == 1 in single-threaded context — main thread is the only alive thread at startup; new to extra228"
  kind: python_call_eq
  function: active_count
  args: []
  expected: 1

invariant threading_extra228.active_count_ge_1:
  description: "threading.active_count().__ge__(1) == True — always at least 1 thread alive; new to extra228"
  kind: python_call_eq
  function: active_count
  args: []
  method: __ge__
  method_args: [1]
  expected: true

invariant threading_extra228.active_count_class_is_int:
  description: "threading.active_count().__class__.__name__ == 'int' — active_count returns a Python int; new to extra228"
  kind: python_call_eq
  function: active_count
  args: []
  method: __class__
  method_chain: __name__
  expected: "int"

invariant threading_extra228.current_thread_is_alive:
  description: "threading.current_thread().is_alive() == True — main thread is always alive; new to extra228"
  kind: python_call_eq
  function: current_thread
  args: []
  method: is_alive
  expected: true

invariant threading_extra228.current_thread_class_name:
  description: "threading.current_thread().__class__.__name__ == '_MainThread'; new to extra228"
  kind: python_call_eq
  function: current_thread
  args: []
  method: __class__
  method_chain: __name__
  expected: "_MainThread"

invariant threading_extra228.current_thread_daemon_false:
  description: "threading.current_thread().daemon == False — main thread is not a daemon; new to extra228"
  kind: python_call_eq
  function: current_thread
  args: []
  method: daemon
  expected: false

invariant threading_extra228.current_thread_name_mainthread:
  description: "threading.current_thread().name == 'MainThread' — main thread name is 'MainThread'; new to extra228"
  kind: python_call_eq
  function: current_thread
  args: []
  method: name
  expected: "MainThread"

invariant threading_extra228.main_thread_is_alive:
  description: "threading.main_thread().is_alive() == True — main thread is alive during execution; new to extra228"
  kind: python_call_eq
  function: main_thread
  args: []
  method: is_alive
  expected: true

invariant threading_extra228.main_thread_class_name:
  description: "threading.main_thread().__class__.__name__ == '_MainThread'; new to extra228"
  kind: python_call_eq
  function: main_thread
  args: []
  method: __class__
  method_chain: __name__
  expected: "_MainThread"

invariant threading_extra228.enumerate_class_is_list:
  description: "threading.enumerate().__class__.__name__ == 'list' — enumerate returns a list; new to extra228"
  kind: python_call_eq
  function: enumerate
  args: []
  method: __class__
  method_chain: __name__
  expected: "list"
