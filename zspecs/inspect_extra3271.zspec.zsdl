spec: in3271
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 665 (in3271): __rand__, __ror__, __rxor__ dict-presence checks for inspect types."
    - "Theme: __rand__/__ror__/__rxor__ reflected bitwise logical dict-presence."
    - "Reflected operators are called when the left operand doesn't support the operation."
    - "All values False — callable/iterator/inspection/synchronization types have no reflected bitwise logical operators."
    - "No inspect type defines __rand__, __ror__, or __rxor__ in its own __dict__."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception types."
    - "None of these types implement reflected bitwise logical protocols directly."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3271.rand:
  description: "inspect types __rand__ dict-presence checks; wave 665"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: in3271
  columns: [id, function, args, expected]
  rows:
    - ["in3271001", operator.contains, [inspect.Parameter.__dict__,           "__rand__"], false]
    - ["in3271002", operator.contains, [inspect.Signature.__dict__,           "__rand__"], false]
    - ["in3271003", operator.contains, [inspect.BoundArguments.__dict__,      "__rand__"], false]
    - ["in3271004", operator.contains, [inspect.FrameInfo.__dict__,           "__rand__"], false]
    - ["in3271005", operator.contains, [inspect.ArgInfo.__dict__,             "__rand__"], false]
    - ["in3271006", operator.contains, [inspect.FullArgSpec.__dict__,         "__rand__"], false]
    - ["in3271007", operator.contains, [inspect.Attribute.__dict__,           "__rand__"], false]
    - ["in3271008", operator.contains, [inspect.ClassFoundException.__dict__, "__rand__"], false]
    - ["in3271009", operator.contains, [inspect.EndOfBlock.__dict__,          "__rand__"], false]

