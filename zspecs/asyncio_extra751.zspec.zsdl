spec: asyncio_extra751
version: ">=3.9"
backend: python_module(asyncio)
docs: Cover asyncio module-level functions identity via __qualname__ and __module__ attributes
error_model: python_exceptions
provenance:
  derived_from:
    - asyncio standard library documentation
    - CPython source asyncio/runners.py
    - CPython source asyncio/tasks.py
  not_derived_from:
    - any third-party asyncio extensions
    - uvloop or other alternative event loop implementations
  notes:
    - qualname and module attributes confirm symbol routing across asyncio submodules
    - wait_for.__module__ is intentionally omitted as it varies across minor versions
    - ensure_future and create_task are included as common coroutine scheduling entry points
  created_at: "2026-04-12"

table asyncio_extra751.name:
  description: Identity checks for asyncio module-level function __qualname__ and __module__ attributes
  kind: python_call_eq
  category: module_identity
  id_prefix: as751xx
  columns: [id, function, args, expected]
  rows:
    - [as751xx001, asyncio.run.__qualname__.__eq__, ["run"], true]
    - [as751xx002, asyncio.run.__module__.__eq__, ["asyncio.runners"], true]
    - [as751xx003, asyncio.sleep.__qualname__.__eq__, ["sleep"], true]
    - [as751xx004, asyncio.sleep.__module__.__eq__, ["asyncio.tasks"], true]
    - [as751xx005, asyncio.gather.__qualname__.__eq__, ["gather"], true]
    - [as751xx006, asyncio.gather.__module__.__eq__, ["asyncio.tasks"], true]
    - [as751xx007, asyncio.wait.__qualname__.__eq__, ["wait"], true]
    - [as751xx008, asyncio.wait.__module__.__eq__, ["asyncio.tasks"], true]
    - [as751xx009, asyncio.wait_for.__qualname__.__eq__, ["wait_for"], true]
    - [as751xx010, asyncio.create_task.__qualname__.__eq__, ["create_task"], true]
    - [as751xx011, asyncio.ensure_future.__qualname__.__eq__, ["ensure_future"], true]
    - [as751xx012, asyncio.get_event_loop.__qualname__.__eq__, ["get_event_loop"], true]
