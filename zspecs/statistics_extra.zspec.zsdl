spec: statistics_extra
version: ">=3.8"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html — Python statistics module documentation"
    - "Test vectors verified by running Python 3.12 statistics module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
  notes:
    - "This spec extends statistics.zspec.zsdl with coverage not already present there."
    - "NormalDist.variance == stdev**2; for NormalDist(0,1) variance==1.0, for NormalDist(5,2) variance==4.0."
    - "NormalDist.pdf(x) returns the probability density at x; pdf(mu) is the peak density 1/(sigma*sqrt(2*pi))."
    - "NormalDist(0,1).cdf(0.0) == 0.5 — exactly half the standard normal lies below the mean."
    - "NormalDist.__class__.__name__ == 'NormalDist' — class identity check."
    - "StatisticsError.__name__ == 'StatisticsError' and __module__ == 'statistics'."
    - "StatisticsError is a subclass of ValueError."
    - "statistics.median of a single-element list returns that element unchanged."
    - "statistics.mode on a list with a unique most-frequent value returns that value."
    - "statistics.multimode returns all modes when several values tie; result is a list."
    - "statistics.multimode([1,1,2,2,3]) == [1, 2] — two tied modes returned in order of first appearance."
    - "statistics.harmonic_mean([1,2,4]) == 12/7 ≈ 1.7142857... (Python 3.6+)."
    - "statistics.stdev of a two-element list: stdev([2,4]) == sqrt(2) ≈ 1.4142135623730951."
    - "All expected values verified by running Python 3.12 statistics module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# StatisticsError — class identity and hierarchy
# ---------------------------------------------------------------------------

invariant statistics_extra.StatisticsError.class_name:
  description: "StatisticsError.__name__ == 'StatisticsError'"
  category: classnames
  kind: python_call_eq
  function: StatisticsError.__name__.__eq__
  args: ["StatisticsError"]
  expected: true

invariant statistics_extra.StatisticsError.module:
  description: "StatisticsError.__module__ == 'statistics'"
  category: classnames
  kind: python_call_eq
  function: StatisticsError.__module__.__eq__
  args: ["statistics"]
  expected: true

invariant statistics_extra.StatisticsError.base_is_ValueError:
  description: "StatisticsError.__bases__[0].__name__ == 'ValueError'"
  category: classnames
  kind: python_call_eq
  function: StatisticsError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "ValueError"

# ---------------------------------------------------------------------------
# StatisticsError — additional error cases not in statistics.zspec.zsdl
# ---------------------------------------------------------------------------

invariant statistics_extra.median.empty_raises:
  description: "statistics.median([]) raises StatisticsError — median requires at least one data point"
  category: error
  kind: python_call_raises
  function: median
  args: [[]]
  expected_exception: StatisticsError

invariant statistics_extra.stdev.empty_raises:
  description: "statistics.stdev([]) raises StatisticsError — stdev requires at least two data points"
  category: error
  kind: python_call_raises
  function: stdev
  args: [[]]
  expected_exception: StatisticsError

invariant statistics_extra.stdev.single_raises:
  description: "statistics.stdev([5]) raises StatisticsError — stdev requires at least two data points"
  category: error
  kind: python_call_raises
  function: stdev
  args: [[5]]
  expected_exception: StatisticsError

# ---------------------------------------------------------------------------
# NormalDist — deeper attributes (variance, pdf, cdf)
# ---------------------------------------------------------------------------

invariant statistics_extra.NormalDist.standard_variance:
  description: "NormalDist(0, 1).variance == 1.0 — variance equals stdev squared for standard normal"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [0, 1]
  method: variance
  expected: 1.0

invariant statistics_extra.NormalDist.custom_variance:
  description: "NormalDist(5.0, 2.0).variance == 4.0 — variance == stdev**2 == 4"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [5.0, 2.0]
  method: variance
  expected: 4.0

invariant statistics_extra.NormalDist.cdf_at_mean:
  description: "NormalDist(0, 1).cdf(0.0) == 0.5 — exactly half the distribution lies below the mean"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [0, 1]
  method: cdf
  method_args: [0.0]
  expected: 0.5

# ---------------------------------------------------------------------------
# NormalDist — class identity
# ---------------------------------------------------------------------------

invariant statistics_extra.NormalDist.class_name:
  description: "NormalDist(0,1).__class__.__name__ == 'NormalDist'"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist.__name__.__eq__
  args: ["NormalDist"]
  expected: true

# ---------------------------------------------------------------------------
# multimode — returns all tied modes (Python 3.8+)
# ---------------------------------------------------------------------------

invariant statistics_extra.multimode.two_modes:
  description: "statistics.multimode([1,1,2,2,3]) == [1, 2] — tied modes returned in order of first appearance"
  category: multimode
  kind: python_call_eq
  function: multimode
  args: [[1, 1, 2, 2, 3]]
  expected: [1, 2]

invariant statistics_extra.multimode.single_mode:
  description: "statistics.multimode([1,1,2]) == [1] — single mode returned as a one-element list"
  category: multimode
  kind: python_call_eq
  function: multimode
  args: [[1, 1, 2]]
  expected: [1]

# ---------------------------------------------------------------------------
# harmonic_mean (Python 3.6+)
# ---------------------------------------------------------------------------

invariant statistics_extra.harmonic_mean.one_two_four:
  description: "statistics.harmonic_mean([1,2,4]) == 12/7 ≈ 1.7142857142857142"
  category: harmonic_mean
  kind: python_call_eq
  function: harmonic_mean
  args: [[1, 2, 4]]
  expected: 1.7142857142857142

# ---------------------------------------------------------------------------
# stdev — additional vectors not in statistics.zspec.zsdl
# ---------------------------------------------------------------------------

invariant statistics_extra.stdev.two_elements:
  description: "statistics.stdev([2, 4]) == sqrt(2) ≈ 1.4142135623730951"
  category: stdev
  kind: python_call_eq
  function: stdev
  args: [[2, 4]]
  expected: 1.4142135623730951
