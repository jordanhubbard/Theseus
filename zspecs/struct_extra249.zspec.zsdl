spec: struct_extra249
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "Wave 249 theme: struct module identity and additional struct.error raise cases."
    - "struct.__name__ == 'struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__package__ == ''. struct is a top-level stdlib module; __package__ is empty string. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'pack' in struct.__doc__ == False. struct.__doc__ describes the module but does not contain the word 'pack' directly. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'pack' in struct.pack.__doc__ == True. struct.pack's own docstring contains 'pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__module__ == 'struct'. struct.error is defined in the struct C extension. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__qualname__ == 'error'. struct.error is a top-level exception class in the struct module. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__bases__[0].__name__ == 'Exception'. struct.error directly inherits from Exception. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack('s', 'x') raises struct.error. The 's' format requires a bytes object; passing a str raises struct.error. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack('>H', -1) raises struct.error. 'H' is unsigned short requiring 0 <= value <= 65535; -1 is out of range. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack('>H', b'x') raises struct.error. '>H' requires exactly 2 bytes; b'x' is 1 byte. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack('Z', 0) raises struct.error. 'Z' is not a valid struct format character. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.__doc__ does not contain the word 'pack' (it describes byte order prefixes and format characters, not the pack function by name). struct.pack.__doc__ does contain 'pack'."
    - "Note: struct.error inherits directly from Exception (not from ValueError or OSError). It has __qualname__ == 'error' (lowercase, not 'Error')."
    - "Note: The 's' format (Pascal string) requires bytes argument; passing a plain str raises struct.error: 'argument for 's' must be a bytes object'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.__name__.__eq__('struct')
# struct.__package__.__eq__('')
# struct.error.__module__.__eq__('struct')
# struct.error.__qualname__.__eq__('error')
#
# Wave 249 theme: struct module identity and struct.error class identity.
#
# struct.__name__ is 'struct'. struct.__package__ is '' (empty string) because
# struct is a standalone top-level module. struct.error is the exception class
# raised by all struct packing/unpacking failures. Its __module__ is 'struct'
# and its __qualname__ is 'error' (lowercase, not 'Error'). struct.error
# inherits directly from Exception. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra249.module_and_error_identity:
  description: "struct module identity and struct.error class identity — __name__.__eq__('struct')==True / __package__.__eq__('')==True / error.__module__.__eq__('struct')==True / error.__qualname__.__eq__('error')==True — struct is a top-level C extension module (__package__ empty string); struct.error is lowercase name (not 'Error'), inherits from Exception, defined in _struct C extension; wave 249 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: structmod249

  columns: [id, function, args, expected, description]
  rows:
    - [module_name,     __name__.__eq__,               ["struct"],  true, "struct.__name__ == 'struct'; top-level C extension module for C struct packing"]
    - [module_pkg,      __package__.__eq__,            [""],        true, "struct.__package__ == ''; standalone module, __package__ is empty string"]
    - [error_module,    error.__module__.__eq__,       ["struct"],  true, "struct.error.__module__ == 'struct'; exception defined in the struct C extension"]
    - [error_qualname,  error.__qualname__.__eq__,     ["error"],   true, "struct.error.__qualname__ == 'error'; lowercase name, top-level exception on the module"]

# ---------------------------------------------------------------------------
# struct.error.__bases__[0].__name__.__eq__('Exception')
#
# Wave 249 theme: struct.error base class identity.
#
# struct.error inherits directly from Exception (not from ValueError, OSError,
# or any other intermediate class). struct.error.__bases__ is a 1-tuple
# containing Exception. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra249.error_base_class:
  description: "struct.error base class identity — error.__bases__[0].__name__.__eq__('Exception')==True — struct.error inherits directly from Exception (not ValueError/OSError); __bases__ is a 1-tuple; base class __name__ is 'Exception'; wave 249 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: type_identity
  id_prefix: structmod249

  columns: [id, function, args, expected, description]
  rows:
    - [error_base,  "error.__bases__[0].__name__.__eq__",  ["Exception"], true, "struct.error.__bases__[0].__name__ == 'Exception'; struct.error inherits directly from Exception"]

# ---------------------------------------------------------------------------
# struct.pack('s', 'x') raises struct.error
# struct.pack('>H', -1) raises struct.error
# struct.unpack('>H', b'x') raises struct.error
# struct.pack('Z', 0) raises struct.error
#
# Wave 249 theme: struct.error raise cases for type mismatch, range error,
# buffer size mismatch, and bad format character.
#
# Four additional struct.error cases:
# - pack('s', 'x'): 's' format requires bytes; str argument raises struct.error.
# - pack('>H', -1): 'H' unsigned short requires 0..65535; -1 out of range.
# - unpack('>H', b'x'): '>H' needs 2 bytes buffer; b'x' (1 byte) is too short.
# - pack('Z', 0): 'Z' is not a valid format character; raises struct.error.
# All verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra249.pack_s_str_raises:
  description: "struct.pack('s', 'x') raises struct.error — 's' format code requires a bytes object argument; passing str 'x' instead of bytes b'x' raises struct.error: 'argument for s must be a bytes object'; first standalone for pack/s/str raises under structmod249; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: errors
  kind: python_call_raises
  function: pack
  args: ["s", "x"]
  raises: error

invariant struct_extra249.pack_H_negative_raises:
  description: "struct.pack('>H', -1) raises struct.error — 'H' unsigned short format requires 0 <= value <= 65535; -1 is below the valid range and raises struct.error: 'H format requires 0 <= number <= 65535'; first standalone for pack/>H/-1 raises under structmod249; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: errors
  kind: python_call_raises
  function: pack
  args: [">H", -1]
  raises: error

invariant struct_extra249.unpack_H_short_buffer_raises:
  description: "struct.unpack('>H', b'x') raises struct.error — '>H' format requires exactly 2 bytes; b'x' is 1 byte, causing struct.error: 'unpack requires a buffer of 2 bytes'; first standalone for unpack/>H/short-buffer raises under structmod249; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: errors
  kind: python_call_raises
  function: unpack
  args: [">H", "b'x'"]
  raises: error

invariant struct_extra249.pack_bad_format_char_raises:
  description: "struct.pack('Z', 0) raises struct.error — 'Z' is not a valid struct format character; raises struct.error: 'bad char in struct format'; valid format chars are b/B/c/d/e/f/h/H/i/I/l/L/n/N/p/P/q/Q/s/x/?; first standalone for pack/bad-format-char raises under structmod249; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: errors
  kind: python_call_raises
  function: pack
  args: ["Z", 0]
  raises: error
