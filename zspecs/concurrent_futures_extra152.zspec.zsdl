spec: concurrent_futures_extra152
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: concurrent.futures FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED string constant values and lengths. concurrent.futures.FIRST_COMPLETED.__eq__('FIRST_COMPLETED')==True (the constant's value is its own name — 'FIRST_COMPLETED'); concurrent.futures.FIRST_EXCEPTION.__eq__('FIRST_EXCEPTION')==True (same pattern — value equals name); concurrent.futures.ALL_COMPLETED.__eq__('ALL_COMPLETED')==True; concurrent.futures.FIRST_COMPLETED.__class__.__name__=='str' (all three constants are plain Python str objects, NOT enum.Enum values; established in extra151); concurrent.futures.FIRST_COMPLETED.__len__()==15 (len('FIRST_COMPLETED')==15: 'FIRST'=5+'_'=1+'COMPLETED'=9=15); concurrent.futures.FIRST_EXCEPTION.__len__()==15 (len('FIRST_EXCEPTION')==15: 'FIRST'=5+'_'=1+'EXCEPTION'=9=15); concurrent.futures.ALL_COMPLETED.__len__()==13 (len('ALL_COMPLETED')==13: 'ALL'=3+'_'=1+'COMPLETED'=9=13); FIRST_COMPLETED and FIRST_EXCEPTION have the same length (15) while ALL_COMPLETED is shorter (13). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.FIRST_COMPLETED.__eq__('FIRST_COMPLETED') — the three return_when constants are plain Python str objects whose string value equals the constant name; FIRST_COMPLETED.__eq__('FIRST_COMPLETED')==True; this self-naming property means repr(FIRST_COMPLETED) is \"'FIRST_COMPLETED'\"; this was first confirmed in extra151 (FIRST_COMPLETED.__class__.__name__=='str'); new in extra152: the actual string equality checks confirming the value of each constant. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "len comparisons: FIRST_COMPLETED(15) == FIRST_EXCEPTION(15) > ALL_COMPLETED(13) — both FIRST_COMPLETED and FIRST_EXCEPTION have length 15 because both start with 'FIRST_' (6 chars) followed by a 9-char word ('COMPLETED'=9, 'EXCEPTION'=9); ALL_COMPLETED is 2 chars shorter at 13 because 'ALL'=3 is 2 chars shorter than 'FIRST'=5; the common suffix '_COMPLETED' (len=10) is shared by FIRST_COMPLETED and ALL_COMPLETED. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures constant string values — extra152
#
# concurrent.futures.FIRST_COMPLETED.__eq__('FIRST_COMPLETED')  == True
# concurrent.futures.FIRST_EXCEPTION.__eq__('FIRST_EXCEPTION')  == True
# concurrent.futures.ALL_COMPLETED.__eq__('ALL_COMPLETED')       == True
# concurrent.futures.FIRST_COMPLETED.__class__.__name__.__eq__('str') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra152.cf_return_when_constant_values:
  description: "concurrent.futures return_when constant string value checks in cfconstval152 namespace — concurrent.futures.FIRST_COMPLETED.__eq__('FIRST_COMPLETED')==True (FIRST_COMPLETED is a plain str whose value is the string 'FIRST_COMPLETED'; it is one of the three return_when constants accepted by wait()); concurrent.futures.FIRST_EXCEPTION.__eq__('FIRST_EXCEPTION')==True (similarly, FIRST_EXCEPTION's string value is 'FIRST_EXCEPTION' — used to make wait() return when any future raises an exception); concurrent.futures.ALL_COMPLETED.__eq__('ALL_COMPLETED')==True (ALL_COMPLETED's value is 'ALL_COMPLETED' — the default for wait(); waits until all futures are done); concurrent.futures.FIRST_COMPLETED.__class__.__name__=='str' (len=3; all three constants are plain Python str objects, NOT enum.Enum members; this was established in extra151); all three constants are self-named: their string value equals the constant name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfconstval152

  columns: [id, function, args, expected, description]
  rows:
    - [firstcomp_val_eq,  "concurrent.futures.FIRST_COMPLETED.__eq__",             ["FIRST_COMPLETED"],  true,  "concurrent.futures.FIRST_COMPLETED == 'FIRST_COMPLETED' (self-named string constant); verified with Python 3.14.3"]
    - [firstexc_val_eq,   "concurrent.futures.FIRST_EXCEPTION.__eq__",             ["FIRST_EXCEPTION"],  true,  "concurrent.futures.FIRST_EXCEPTION == 'FIRST_EXCEPTION' (self-named string constant); verified with Python 3.14.3"]
    - [allcomp_val_eq,    "concurrent.futures.ALL_COMPLETED.__eq__",               ["ALL_COMPLETED"],    true,  "concurrent.futures.ALL_COMPLETED == 'ALL_COMPLETED' (self-named string constant, default for wait()); verified with Python 3.14.3"]
    - [firstcomp_cls_eq,  "concurrent.futures.FIRST_COMPLETED.__class__.__name__.__eq__",  ["str"],     true,  "concurrent.futures.FIRST_COMPLETED.__class__.__name__ == 'str' (plain str, not Enum; established in extra151); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures constant string lengths — extra152
#
# concurrent.futures.FIRST_COMPLETED.__len__().__eq__(15)  == True
# concurrent.futures.FIRST_EXCEPTION.__len__().__eq__(15)  == True
# concurrent.futures.ALL_COMPLETED.__len__().__eq__(13)    == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra152.cf_return_when_constant_lengths:
  description: "concurrent.futures return_when constant string length checks in cfconstlen152 namespace — concurrent.futures.FIRST_COMPLETED.__len__()==15 (len('FIRST_COMPLETED')==15: 'FIRST'=5+'_'=1+'COMPLETED'=9=15); concurrent.futures.FIRST_EXCEPTION.__len__()==15 (len('FIRST_EXCEPTION')==15: 'FIRST'=5+'_'=1+'EXCEPTION'=9=15; same length as FIRST_COMPLETED because 'COMPLETED' and 'EXCEPTION' both have 9 chars); concurrent.futures.ALL_COMPLETED.__len__()==13 (len('ALL_COMPLETED')==13: 'ALL'=3+'_'=1+'COMPLETED'=9=13; 2 chars shorter than FIRST_COMPLETED because 'ALL'=3 is 2 chars shorter than 'FIRST'=5); length comparison: FIRST_COMPLETED(15) == FIRST_EXCEPTION(15) > ALL_COMPLETED(13); the common suffix '_COMPLETED' (10 chars) is shared by FIRST_COMPLETED and ALL_COMPLETED; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfconstlen152

  columns: [id, function, args, expected, description]
  rows:
    - [firstcomp_len_eq,  "concurrent.futures.FIRST_COMPLETED.__len__",  [],  15,  "concurrent.futures.FIRST_COMPLETED.__len__() == 15 (len('FIRST_COMPLETED'): 'FIRST'=5+'_'=1+'COMPLETED'=9=15); verified with Python 3.14.3"]
    - [firstexc_len_eq,   "concurrent.futures.FIRST_EXCEPTION.__len__",  [],  15,  "concurrent.futures.FIRST_EXCEPTION.__len__() == 15 (len('FIRST_EXCEPTION'): 'FIRST'=5+'_'=1+'EXCEPTION'=9=15; same as FIRST_COMPLETED); verified with Python 3.14.3"]
    - [allcomp_len_eq,    "concurrent.futures.ALL_COMPLETED.__len__",    [],  13,  "concurrent.futures.ALL_COMPLETED.__len__() == 13 (len('ALL_COMPLETED'): 'ALL'=3+'_'=1+'COMPLETED'=9=13; 2 shorter than FIRST_COMPLETED); verified with Python 3.14.3"]
    - [firstcomp_len_eq2, "concurrent.futures.FIRST_COMPLETED.__len__",  [],  15,  "concurrent.futures.FIRST_COMPLETED.__len__() == 15 confirming FIRST_COMPLETED==FIRST_EXCEPTION in length; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra152
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra152.cf_FIRST_COMPLETED_value_eq:
  description: "concurrent.futures.FIRST_COMPLETED.__eq__('FIRST_COMPLETED') returns True — concurrent.futures.FIRST_COMPLETED is a plain Python str whose value is the string 'FIRST_COMPLETED' (len=15); the constant is self-named: its string content equals the constant's identifier; FIRST_COMPLETED is passed as the return_when argument to concurrent.futures.wait() to make it return as soon as any single future completes; FIRST_COMPLETED.__class__.__name__=='str' (established in extra151; NOT an Enum); FIRST_COMPLETED.__len__()==15 ('FIRST'=5+'_'=1+'COMPLETED'=9=15); compare: FIRST_EXCEPTION.__len__()==15 (same length) and ALL_COMPLETED.__len__()==13 (2 shorter); NEW in extra152: first standalone FIRST_COMPLETED string value equality invariant in cfconstval152 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.FIRST_COMPLETED.__eq__"
  args: ["FIRST_COMPLETED"]
  expected: true

invariant concurrent_futures_extra152.cf_FIRST_EXCEPTION_value_eq:
  description: "concurrent.futures.FIRST_EXCEPTION.__eq__('FIRST_EXCEPTION') returns True — concurrent.futures.FIRST_EXCEPTION is a plain Python str whose value is the string 'FIRST_EXCEPTION' (len=15); FIRST_EXCEPTION is self-named like the other return_when constants; it is passed to concurrent.futures.wait() to make it return when any future raises an exception (or when all are done without exception); FIRST_EXCEPTION.__len__()==15 ('FIRST'=5+'_'=1+'EXCEPTION'=9=15; same length as FIRST_COMPLETED because 'EXCEPTION' and 'COMPLETED' are both 9 chars); FIRST_EXCEPTION.__class__.__name__=='str' (plain string, not Enum); NEW in extra152: first standalone FIRST_EXCEPTION string value equality invariant in cfconstval152 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.FIRST_EXCEPTION.__eq__"
  args: ["FIRST_EXCEPTION"]
  expected: true

invariant concurrent_futures_extra152.cf_ALL_COMPLETED_value_eq:
  description: "concurrent.futures.ALL_COMPLETED.__eq__('ALL_COMPLETED') returns True — concurrent.futures.ALL_COMPLETED is a plain Python str whose value is the string 'ALL_COMPLETED' (len=13); ALL_COMPLETED is the default value for concurrent.futures.wait()'s return_when parameter (wait blocks until all futures are done when return_when=ALL_COMPLETED); ALL_COMPLETED.__len__()==13 ('ALL'=3+'_'=1+'COMPLETED'=9=13; 2 chars shorter than FIRST_COMPLETED=15 and FIRST_EXCEPTION=15, because 'ALL'=3 is 2 shorter than 'FIRST'=5); ALL_COMPLETED.__class__.__name__=='str' (plain string); len ordering: FIRST_COMPLETED(15) == FIRST_EXCEPTION(15) > ALL_COMPLETED(13); NEW in extra152: first standalone ALL_COMPLETED string value equality invariant in cfconstval152 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ALL_COMPLETED.__eq__"
  args: ["ALL_COMPLETED"]
  expected: true

invariant concurrent_futures_extra152.cf_FIRST_COMPLETED_len_15:
  description: "concurrent.futures.FIRST_COMPLETED.__len__() == 15 — concurrent.futures.FIRST_COMPLETED is the string 'FIRST_COMPLETED' which has 15 characters: 'F'+'I'+'R'+'S'+'T'=5+'_'=1+'C'+'O'+'M'+'P'+'L'+'E'+'T'+'E'+'D'=9, total=15; FIRST_COMPLETED.__len__()==15; FIRST_EXCEPTION.__len__()==15 as well (same length since 'EXCEPTION'=9=='COMPLETED'=9); ALL_COMPLETED.__len__()==13 (2 shorter — 'ALL'=3 vs 'FIRST'=5); these length values are new in extra152 (extra151 covered FIRST_COMPLETED.__class__.__name__=='str' but not string lengths); NEW in extra152: first standalone FIRST_COMPLETED string length invariant in cfconstlen152 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.FIRST_COMPLETED.__len__"
  args: []
  expected: 15

invariant concurrent_futures_extra152.cf_ALL_COMPLETED_len_13:
  description: "concurrent.futures.ALL_COMPLETED.__len__() == 13 — concurrent.futures.ALL_COMPLETED is the string 'ALL_COMPLETED' which has 13 characters: 'A'+'L'+'L'=3+'_'=1+'C'+'O'+'M'+'P'+'L'+'E'+'T'+'E'+'D'=9, total=13; ALL_COMPLETED.__len__()==13 is 2 shorter than FIRST_COMPLETED.__len__()==15 and FIRST_EXCEPTION.__len__()==15 because the prefix 'ALL'=3 is 2 chars shorter than 'FIRST'=5; ALL_COMPLETED is the default return_when value for concurrent.futures.wait(); the shared suffix '_COMPLETED' (10 chars including underscore) connects FIRST_COMPLETED and ALL_COMPLETED; NEW in extra152: first standalone ALL_COMPLETED string length invariant in cfconstlen152 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ALL_COMPLETED.__len__"
  args: []
  expected: 13
