spec: urllib_request_extra4
version: ">=3.0"
backend: python_module(urllib.request)

docs: https://docs.python.org/3/library/urllib.request.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.request.html — Python urllib.request module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/request.py"
  notes:
    - "This spec extends urllib_request.zspec.zsdl through urllib_request_extra3.zspec.zsdl."
    - "urllib_request.zspec.zsdl covers: class_names table, function_names table, Request construction (type/host/full_url/get_method), pathname2url absolute path, URLError reason, HTTPError code/msg."
    - "urllib_request_extra.zspec.zsdl covers: urlretrieve/__name__, url2pathname/__name__, pathname2url/__name__, urlopen/__name__, Request/__name__, HTTPError/__name__, URLError/__name__, Request/__module__, URLError/__module__, HTTPError/__module__, HTTPError.__bases__[0].__name__."
    - "urllib_request_extra2.zspec.zsdl covers: function __qualname__ table, class __qualname__ table, urlopen/__module__, urlretrieve/__module__, build_opener/__module__."
    - "urllib_request_extra3.zspec.zsdl covers: HTTPDefaultErrorHandler/__qualname__, HTTPRedirectHandler/__qualname__, url2pathname/__qualname__, pathname2url/__qualname__, class __module__ table, install_opener/__module__, HTTPRedirectHandler base, Request.selector, url2pathname round-trip."
    - "Focus: new axes not present in any prior urllib.request spec."
    - "Request with data — get_method() returns 'POST' when data is provided (no explicit method); not checked in any prior spec."
    - "Request with explicit method='PUT' — get_method() returns 'PUT'; only GET and POST covered so far."
    - "Request.get_header() — retrieves a header set during construction; not checked in any prior spec."
    - "HTTPHandler.__bases__[0].__name__ == 'AbstractHTTPHandler' — intermediate base class; not checked in any prior spec."
    - "FileHandler.__bases__[0].__name__ == 'BaseHandler' — not checked in any prior spec."
    - "AbstractHTTPHandler.__bases__[0].__name__ == 'BaseHandler' — not checked in any prior spec."
    - "Request.__bases__[0].__name__ == 'object' — Request has a single base (object); not checked in any prior spec."
    - "OpenerDirector.__bases__[0].__name__ == 'object' — not checked in any prior spec."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Request.get_method() — data-driven POST and explicit PUT
#
# urllib_request.zspec.zsdl covers get_method() for GET (no data) and
# explicit GET and POST via kwargs. The POST-via-data case (no method kwarg,
# but data is provided) and explicit PUT are new axes.
# ---------------------------------------------------------------------------

invariant urllib_request_extra4.req_get_method_data_post:
  description: "Request('http://example.com', data=b'body').get_method() == 'POST' — data triggers POST"
  category: Request
  kind: python_call_eq
  function: Request
  args: ["http://example.com"]
  kwargs: {data: !ascii "body"}
  method: get_method
  method_args: []
  expected: "POST"

invariant urllib_request_extra4.req_get_method_put:
  description: "Request('http://example.com', method='PUT').get_method() == 'PUT'"
  category: Request
  kind: python_call_eq
  function: Request
  args: ["http://example.com"]
  kwargs: {method: "PUT"}
  method: get_method
  method_args: []
  expected: "PUT"

# ---------------------------------------------------------------------------
# Request.get_header() — header retrieval
#
# No prior spec tests Request.get_header(). get_header() returns the value
# of a request header set during construction (via the headers kwarg).
# ---------------------------------------------------------------------------

invariant urllib_request_extra4.req_get_header_accept:
  description: "Request('http://example.com', headers={'Accept': 'text/html'}).get_header('Accept') == 'text/html'"
  category: Request
  kind: python_call_eq
  function: Request
  args: ["http://example.com"]
  kwargs: {headers: {Accept: "text/html"}}
  method: get_header
  method_args: ["Accept"]
  expected: "text/html"

# ---------------------------------------------------------------------------
# Inheritance hierarchy — classes not verified in prior specs
#
# urllib_request_extra.zspec.zsdl checks HTTPError.__bases__[0].__name__.
# urllib_request_extra3.zspec.zsdl checks HTTPRedirectHandler.__bases__[0].__name__.
# New: Request, OpenerDirector, HTTPHandler, FileHandler, AbstractHTTPHandler bases.
# ---------------------------------------------------------------------------

table urllib_request_extra4.base_class_names:
  kind: python_call_eq
  category: hierarchy
  id_prefix: base

  columns: [id, function, args, expected]
  rows:
    - [Request_base,              Request.__bases__.__getitem__,              [0], "object"]
    - [OpenerDirector_base,       OpenerDirector.__bases__.__getitem__,       [0], "object"]
    - [FileHandler_base,          FileHandler.__bases__.__getitem__,          [0], "BaseHandler"]
    - [HTTPHandler_base,          HTTPHandler.__bases__.__getitem__,          [0], "AbstractHTTPHandler"]
    - [AbstractHTTPHandler_base,  AbstractHTTPHandler.__bases__.__getitem__,  [0], "BaseHandler"]

# ---------------------------------------------------------------------------
# AbstractHTTPHandler identity — not checked in any prior spec
#
# urllib_request exports AbstractHTTPHandler; prior specs never mention it.
# ---------------------------------------------------------------------------

invariant urllib_request_extra4.AbstractHTTPHandler.name:
  description: "urllib.request.AbstractHTTPHandler.__name__ == 'AbstractHTTPHandler'"
  category: class_names
  kind: python_call_eq
  function: AbstractHTTPHandler.__name__.__eq__
  args: ["AbstractHTTPHandler"]
  expected: true

invariant urllib_request_extra4.AbstractHTTPHandler.module:
  description: "urllib.request.AbstractHTTPHandler.__module__ == 'urllib.request'"
  category: modules
  kind: python_call_eq
  function: AbstractHTTPHandler.__module__.__eq__
  args: ["urllib.request"]
  expected: true

invariant urllib_request_extra4.AbstractHTTPHandler.qualname:
  description: "urllib.request.AbstractHTTPHandler.__qualname__ == 'AbstractHTTPHandler'"
  category: qualnames
  kind: python_call_eq
  function: AbstractHTTPHandler.__qualname__.__eq__
  args: ["AbstractHTTPHandler"]
  expected: true

# ---------------------------------------------------------------------------
# Request.type for HTTPS scheme
#
# urllib_request.zspec.zsdl checks Request.type for 'http' scheme only.
# The 'https' scheme is a new axis.
# ---------------------------------------------------------------------------

invariant urllib_request_extra4.req_type_https:
  description: "Request('https://secure.example.com').type == 'https'"
  category: Request
  kind: python_call_eq
  function: Request
  args: ["https://secure.example.com"]
  method: type
  expected: "https"
