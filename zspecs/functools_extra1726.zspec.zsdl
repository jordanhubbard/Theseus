spec: functools_extra1726
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/functools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 562 (_extra1726): comparison/ordering protocol dict-presence checks."
    - "functools types do not define comparison operators in their own __dict__."
    - "functools.partial.__dict__.__contains__('__lt__') is False — partial is a C extension type with no ordering."
    - "functools.cached_property.__dict__.__contains__('__lt__') is False — cached_property is a pure-Python descriptor with no ordering."
    - "functools._lru_cache_wrapper.__dict__.__contains__('__lt__') is False — _lru_cache_wrapper is a C extension type with no ordering."
    - "functools.partialmethod.__dict__.__contains__('__lt__') is False — partialmethod is a pure-Python class with no ordering."
    - "None of the four types define __le__, __gt__, __ge__, or __ne__ in their own __dict__ either."
    - "functools.partial.__dict__.__contains__('__eq__') is False — partial does not define __eq__ in its own dict."
    - "functools.cached_property.__dict__.__contains__('__hash__') is False — cached_property does not define __hash__ in its own dict."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table functools_extra1726.comparison_protocol:
  description: "functools types comparison protocol dict-presence checks — __lt__, __le__, __gt__, __ge__, __ne__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1726

  columns: [id, function, args, expected]
  rows:
    - ["fu1726001", "functools.partial.__dict__.__contains__", ["__lt__"], false]
    - ["fu1726002", "functools.partial.__dict__.__contains__", ["__le__"], false]
    - ["fu1726003", "functools.partial.__dict__.__contains__", ["__gt__"], false]
    - ["fu1726004", "functools.partial.__dict__.__contains__", ["__ge__"], false]
    - ["fu1726005", "functools.partial.__dict__.__contains__", ["__ne__"], false]
    - ["fu1726006", "functools.cached_property.__dict__.__contains__", ["__lt__"], false]
    - ["fu1726007", "functools.cached_property.__dict__.__contains__", ["__le__"], false]
    - ["fu1726008", "functools.cached_property.__dict__.__contains__", ["__gt__"], false]
    - ["fu1726009", "functools.cached_property.__dict__.__contains__", ["__ge__"], false]
    - ["fu1726010", "functools.cached_property.__dict__.__contains__", ["__ne__"], false]
    - ["fu1726011", "functools._lru_cache_wrapper.__dict__.__contains__", ["__lt__"], false]
    - ["fu1726012", "functools._lru_cache_wrapper.__dict__.__contains__", ["__le__"], false]
    - ["fu1726013", "functools._lru_cache_wrapper.__dict__.__contains__", ["__gt__"], false]
    - ["fu1726014", "functools._lru_cache_wrapper.__dict__.__contains__", ["__ge__"], false]
    - ["fu1726015", "functools._lru_cache_wrapper.__dict__.__contains__", ["__ne__"], false]
    - ["fu1726016", "functools.partialmethod.__dict__.__contains__", ["__lt__"], false]
    - ["fu1726017", "functools.partialmethod.__dict__.__contains__", ["__le__"], false]
    - ["fu1726018", "functools.partialmethod.__dict__.__contains__", ["__gt__"], false]
    - ["fu1726019", "functools.partialmethod.__dict__.__contains__", ["__ge__"], false]
    - ["fu1726020", "functools.partialmethod.__dict__.__contains__", ["__ne__"], false]

table functools_extra1726.eq_hash_protocol:
  description: "functools types __eq__ and __hash__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1726

  columns: [id, function, args, expected]
  rows:
    - ["fu1726021", "functools.partial.__dict__.__contains__", ["__eq__"], false]
    - ["fu1726022", "functools.partial.__dict__.__contains__", ["__hash__"], false]
    - ["fu1726023", "functools.cached_property.__dict__.__contains__", ["__eq__"], false]
    - ["fu1726024", "functools.cached_property.__dict__.__contains__", ["__hash__"], false]
    - ["fu1726025", "functools._lru_cache_wrapper.__dict__.__contains__", ["__eq__"], false]
