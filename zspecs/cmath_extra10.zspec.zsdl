spec: cmath_extra10
version: ">=3.9"
backend: python_module(cmath)

docs: https://docs.python.org/3/library/cmath.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/cmath.html — Python cmath module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/cmathmodule.c"
  notes:
    - "This spec extends cmath.zspec.zsdl and prior extras through cmath_extra9.zspec.zsdl."
    - "cmath_extra3: __qualname__ for sqrt/exp/log/sin/cos/tan/phase/polar/rect/isnan/isinf/isfinite/isclose."
    - "cmath_extra9: __name__ for asin/acos/atan/sinh/cosh/tanh; __module__ for exp/log/sin/cos/tan/asin/acos/atan/sinh/cosh/tanh/isinf/isnan/isfinite."
    - "No prior spec covers __qualname__ for asin/acos/atan/sinh/cosh/tanh."
    - "No prior spec covers cmath.__name__ == 'cmath' or cmath.__package__ == ''."
    - "cmath.asin.__qualname__ == 'asin' — C builtin qualname equals name at module level."
    - "cmath.acos.__qualname__ == 'acos' — C builtin qualname equals name at module level."
    - "cmath.atan.__qualname__ == 'atan' — C builtin qualname equals name at module level."
    - "cmath.sinh.__qualname__ == 'sinh' — C builtin qualname equals name at module level."
    - "cmath.cosh.__qualname__ == 'cosh' — C builtin qualname equals name at module level."
    - "cmath.tanh.__qualname__ == 'tanh' — C builtin qualname equals name at module level."
    - "cmath.__name__ == 'cmath' — module __name__ attribute equals the module name string."
    - "cmath.__package__ == '' — top-level module; package is empty string."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# cmath inverse trig and hyperbolic function __qualname__ table
#
# cmath_extra3 covered __qualname__ for sqrt/exp/log/sin/cos/tan/phase/polar/
# rect/isnan/isinf/isfinite/isclose. cmath_extra9 covered __name__ for
# asin/acos/atan/sinh/cosh/tanh. No prior spec covers __qualname__ for the
# inverse trig and hyperbolic functions. For C builtins at module level,
# __qualname__ equals __name__.
# ---------------------------------------------------------------------------

table cmath_extra10.invtrig_qualnames:
  description: "__qualname__ == function name for cmath inverse trig and hyperbolic functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: cqn

  columns: [id, function, args, expected]
  rows:
    - [asin, asin.__qualname__.__eq__, ["asin"], true]
    - [acos, acos.__qualname__.__eq__, ["acos"], true]
    - [atan, atan.__qualname__.__eq__, ["atan"], true]
    - [sinh, sinh.__qualname__.__eq__, ["sinh"], true]
    - [cosh, cosh.__qualname__.__eq__, ["cosh"], true]
    - [tanh, tanh.__qualname__.__eq__, ["tanh"], true]

# ---------------------------------------------------------------------------
# cmath module-level identity attributes
#
# No prior spec checks cmath.__name__ or cmath.__package__ as callable
# invariants. cmath.__name__ == 'cmath' confirms the module's own name
# attribute. cmath.__package__ == '' confirms it is a top-level module
# with no package prefix.
# ---------------------------------------------------------------------------

invariant cmath_extra10.module.name:
  description: "cmath.__name__ == 'cmath' — module name attribute equals module name"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["cmath"]
  expected: true

invariant cmath_extra10.module.package:
  description: "cmath.__package__ == '' — top-level module has empty package string"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true
