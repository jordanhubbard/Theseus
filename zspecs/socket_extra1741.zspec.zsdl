spec: socket_extra1741
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/socket.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 563 (_extra1741): descriptor protocol dict-presence checks."
    - "socket.socket is not a descriptor — it defines no __get__, __set__, __delete__, or __set_name__ in its own __dict__."
    - "socket.socket.__dict__.__contains__('__get__') is False — socket.socket is a file-descriptor wrapper, not a descriptor."
    - "socket.socket.__dict__.__contains__('__set__') is False — socket.socket defines no __set__."
    - "socket.socket.__dict__.__contains__('__delete__') is False — socket.socket defines no __delete__."
    - "socket.socket.__dict__.__contains__('__set_name__') is False — socket.socket does not participate in class creation hooks."
    - "socket.AddressFamily (IntEnum subclass) is not a descriptor: all four checks are False."
    - "socket.SocketKind (IntEnum subclass) is not a descriptor: all four checks are False."
    - "Complementary checks: socket.AF_INET.__class__.__name__ == 'AddressFamily'; socket.SOCK_STREAM.__class__.__name__ == 'SocketKind'."
    - "socket.AF_INET.__class__.__name__.__eq__('AddressFamily') is True — AF_INET is an IntEnum member of socket.AddressFamily."
    - "socket.SOCK_STREAM.__class__.__name__.__eq__('SocketKind') is True — SOCK_STREAM is an IntEnum member of socket.SocketKind."
    - "socket.AF_UNIX.__class__.__name__.__eq__('AddressFamily') is True — AF_UNIX is an IntEnum member of socket.AddressFamily."
    - "socket.SOCK_DGRAM.__class__.__name__.__eq__('SocketKind') is True — SOCK_DGRAM is an IntEnum member of socket.SocketKind."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: descriptor protocol dict-presence checks for socket types
#
# Wave 563 theme: which socket types define __get__, __set__, __delete__,
# __set_name__ in their own __dict__.
#
# socket.socket: Python class wrapping a file descriptor — no descriptor protocol.
#   __get__: False, __set__: False, __delete__: False, __set_name__: False.
# socket.AddressFamily: IntEnum subclass — also no descriptor protocol.
#   __get__: False, __set__: False, __delete__: False, __set_name__: False.
# socket.SocketKind: IntEnum subclass — also no descriptor protocol.
#   __get__: False, __set__: False, __delete__: False, __set_name__: False.
# ---------------------------------------------------------------------------

table socket_extra1741.descriptor_protocol:
  description: "socket types descriptor protocol dict-presence checks — wave 563 _extra1741"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1741

  columns: [id, function, args, expected]
  rows:
    - ["sk1741001", "socket.socket.__dict__.__contains__",        ["__get__"],      false]
    - ["sk1741002", "socket.socket.__dict__.__contains__",        ["__set__"],      false]
    - ["sk1741003", "socket.socket.__dict__.__contains__",        ["__delete__"],   false]
    - ["sk1741004", "socket.socket.__dict__.__contains__",        ["__set_name__"], false]
    - ["sk1741005", "socket.AddressFamily.__dict__.__contains__", ["__get__"],      false]
    - ["sk1741006", "socket.AddressFamily.__dict__.__contains__", ["__set__"],      false]
    - ["sk1741007", "socket.AddressFamily.__dict__.__contains__", ["__delete__"],   false]
    - ["sk1741008", "socket.AddressFamily.__dict__.__contains__", ["__set_name__"], false]
    - ["sk1741009", "socket.SocketKind.__dict__.__contains__",    ["__get__"],      false]
    - ["sk1741010", "socket.SocketKind.__dict__.__contains__",    ["__set__"],      false]
    - ["sk1741011", "socket.SocketKind.__dict__.__contains__",    ["__delete__"],   false]
    - ["sk1741012", "socket.SocketKind.__dict__.__contains__",    ["__set_name__"], false]

# ---------------------------------------------------------------------------
# Table 2: socket constant class identity
#
# socket.AF_INET and socket.AF_UNIX are IntEnum members of socket.AddressFamily.
# socket.SOCK_STREAM and socket.SOCK_DGRAM are IntEnum members of socket.SocketKind.
#
# socket.AF_INET.__class__.__name__   == 'AddressFamily'
# socket.AF_UNIX.__class__.__name__   == 'AddressFamily'
# socket.SOCK_STREAM.__class__.__name__ == 'SocketKind'
# socket.SOCK_DGRAM.__class__.__name__  == 'SocketKind'
#
# 'AddressFamily' has 13 chars; 'SocketKind' has 10 chars.
# Verified Python 3.14 on macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra1741.socket_constant_class_identity:
  description: "socket constant class identity — AF_INET/AF_UNIX are AddressFamily; SOCK_STREAM/SOCK_DGRAM are SocketKind — wave 563 _extra1741"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1741

  columns: [id, function, args, expected]
  rows:
    - ["sk1741013", "socket.AF_INET.__class__.__name__.__eq__",      ["AddressFamily"], true]
    - ["sk1741014", "socket.AF_UNIX.__class__.__name__.__eq__",      ["AddressFamily"], true]
    - ["sk1741015", "socket.SOCK_STREAM.__class__.__name__.__eq__",  ["SocketKind"],    true]
    - ["sk1741016", "socket.SOCK_DGRAM.__class__.__name__.__eq__",   ["SocketKind"],    true]
    - ["sk1741017", "socket.AF_INET.__class__.__name__.__len__",      [],               13]
    - ["sk1741018", "socket.SOCK_STREAM.__class__.__name__.__len__",  [],               10]
    - ["sk1741019", "socket.AF_INET.__class__.__name__.__eq__",      ["SocketKind"],    false]
    - ["sk1741020", "socket.SOCK_STREAM.__class__.__name__.__eq__",  ["AddressFamily"], false]
    - ["sk1741021", "socket.AddressFamily.__name__.__eq__",          ["AddressFamily"], true]
    - ["sk1741022", "socket.SocketKind.__name__.__eq__",             ["SocketKind"],    true]
    - ["sk1741023", "socket.AddressFamily.__name__.__len__",         [],               13]
    - ["sk1741024", "socket.SocketKind.__name__.__len__",            [],               10]
