spec: bisect_extra18
version: ">=3.9"
backend: python_module(bisect)

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bisect.html — Python bisect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/bisect.py"
    - "CPython source: Modules/_bisectmodule.c"
  notes:
    - "This spec extends bisect.zspec.zsdl through bisect_extra17.zspec.zsdl."
    - "bisect_extra15 covers all 6 callables' __qualname__ in a unified table."
    - "bisect_extra17 covers standalone __module__ invariants and __qualname__.__len__() for all 6 callables."
    - "NOT yet covered: standalone __qualname__.__eq__ invariants for bisect_left/insort_left/bisect_right/insort_right in extra18 namespace; a unified extra18 table cross-checking all 6 callables' __qualname__ using __eq__."
    - "Focus: standalone __qualname__.__eq__ invariants for all 4 core functions plus alias confirmation in extra18 namespace; unified extra18 __qualname__.__eq__ table."
    - "bisect.bisect_left.__qualname__ == 'bisect_left' — C extension builtin. Verified Python 3.12 macOS."
    - "bisect.bisect_right.__qualname__ == 'bisect_right' — C extension builtin. Verified."
    - "bisect.bisect.__qualname__ == 'bisect_right' — bisect is an alias of bisect_right. Verified."
    - "bisect.insort_left.__qualname__ == 'insort_left' — C extension builtin. Verified."
    - "bisect.insort_right.__qualname__ == 'insort_right' — C extension builtin. Verified."
    - "bisect.insort.__qualname__ == 'insort_right' — insort is an alias of insort_right. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Standalone __qualname__.__eq__ invariants — core functions (extra18 namespace)
#
# bisect_extra15 covers all 6 callables in a table. bisect_extra17 covers
# alias qualname standalone invariants. These extra18 standalone invariants
# provide independent anchors for the 4 core (non-alias) functions in the
# extra18 namespace, confirming qualname matches the function name.
# ---------------------------------------------------------------------------

invariant bisect_extra18.bisect_left.qualname:
  description: "bisect.bisect_left.__qualname__ == 'bisect_left' — C extension function qualname"
  category: function_qualnames
  kind: python_call_eq
  function: bisect_left.__qualname__.__eq__
  args: ["bisect_left"]
  expected: true

invariant bisect_extra18.bisect_right.qualname:
  description: "bisect.bisect_right.__qualname__ == 'bisect_right' — C extension function qualname"
  category: function_qualnames
  kind: python_call_eq
  function: bisect_right.__qualname__.__eq__
  args: ["bisect_right"]
  expected: true

invariant bisect_extra18.insort_left.qualname:
  description: "bisect.insort_left.__qualname__ == 'insort_left' — C extension function qualname"
  category: function_qualnames
  kind: python_call_eq
  function: insort_left.__qualname__.__eq__
  args: ["insort_left"]
  expected: true

invariant bisect_extra18.insort_right.qualname:
  description: "bisect.insort_right.__qualname__ == 'insort_right' — C extension function qualname"
  category: function_qualnames
  kind: python_call_eq
  function: insort_right.__qualname__.__eq__
  args: ["insort_right"]
  expected: true

# ---------------------------------------------------------------------------
# Unified __qualname__.__eq__ table for all 6 bisect callables (extra18)
#
# This table consolidates __qualname__.__eq__ for all 6 bisect callables in
# the extra18 namespace. Alias functions (bisect, insort) carry the __qualname__
# of their aliased function. id_prefix bqeq18 does not conflict with prior specs.
# ---------------------------------------------------------------------------

table bisect_extra18.qualname_eq:
  description: "__qualname__.__eq__ for all 6 bisect callables — aliases resolve to aliased function qualname"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: bqeq18

  columns: [id, function, args, expected]
  rows:
    - [bisect_left,  bisect_left.__qualname__.__eq__,  ["bisect_left"],  true]
    - [bisect_right, bisect_right.__qualname__.__eq__, ["bisect_right"], true]
    - [insort_left,  insort_left.__qualname__.__eq__,  ["insort_left"],  true]
    - [insort_right, insort_right.__qualname__.__eq__, ["insort_right"], true]
    - [bisect,       bisect.__qualname__.__eq__,       ["bisect_right"], true]
    - [insort,       insort.__qualname__.__eq__,       ["insort_right"], true]
