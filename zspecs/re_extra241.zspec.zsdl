  id_prefix: repattern241

  columns: [id, function, args, expected]
  rows:
    - [match_name_len,   Pattern.match.__name__.__len__,   [], 5]
    - [search_name_len,  Pattern.search.__name__.__len__,  [], 6]
    - [findall_name_len, Pattern.findall.__name__.__len__, [], 7]
