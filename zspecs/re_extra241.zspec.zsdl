spec: re_extra241
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra240.zspec.zsdl — covers Match class identity and method name/qualname checks"
  notes:
    - "This spec covers: re.Pattern (compiled pattern) class identity contracts and method name/qualname checks."
    - "re.Pattern.__name__ == 'Pattern' — the class name is 7 characters; verified Python 3.14.3 macOS."
    - "re.Pattern.__module__ == 're' — Pattern is defined in the 're' module (not '_sre'); verified Python 3.14.3 macOS."
    - "re.Pattern.__qualname__ == 'Pattern' — qualname matches __name__ for a top-level class; verified Python 3.14.3 macOS."
    - "re.Pattern.__bases__[0].__name__ == 'object' — Pattern inherits directly from object; verified Python 3.14.3 macOS."
    - "re.Pattern.__class__.__name__ == 'type' — Pattern is a class object; verified Python 3.14.3 macOS."
    - "re.Pattern.match.__name__ == 'match' — length 5; verified Python 3.14.3 macOS."
    - "re.Pattern.match.__qualname__ == 'Pattern.match' — length 13; verified Python 3.14.3 macOS."
    - "re.Pattern.search.__name__ == 'search' — length 6; verified Python 3.14.3 macOS."
    - "re.Pattern.search.__qualname__ == 'Pattern.search' — length 14; verified Python 3.14.3 macOS."
    - "re.Pattern.findall.__name__ == 'findall' — length 7; verified Python 3.14.3 macOS."
    - "re.Pattern.findall.__qualname__ == 'Pattern.findall' — length 15; verified Python 3.14.3 macOS."
    - "re.Pattern.sub.__name__ == 'sub' — length 3; verified Python 3.14.3 macOS."
    - "re.Pattern.sub.__qualname__ == 'Pattern.sub' — length 11; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern class identity contracts
# These verify the class object's identity attributes.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra241.Pattern.name_eq:
  description: "re.Pattern.__name__ == 'Pattern' — class name is 'Pattern'; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra241.Pattern.name_len:
  description: "len(re.Pattern.__name__) == 7 — 'Pattern' has 7 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__name__.__len__
  args: []
  expected: 7

invariant re_extra241.Pattern.module_eq:
  description: "re.Pattern.__module__ == 're' — Pattern is defined in the 're' module; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra241.Pattern.module_len:
  description: "len(re.Pattern.__module__) == 2 — 're' has 2 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__module__.__len__
  args: []
  expected: 2

invariant re_extra241.Pattern.qualname_eq:
  description: "re.Pattern.__qualname__ == 'Pattern' — qualname matches __name__ for a top-level class; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__qualname__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra241.Pattern.qualname_len:
  description: "len(re.Pattern.__qualname__) == 7 — 'Pattern' has 7 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__qualname__.__len__
  args: []
  expected: 7

invariant re_extra241.Pattern.class_is_type:
  description: "re.Pattern.__class__.__name__ == 'type' — Pattern is a class object (its metaclass is type); verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# re.Pattern.__bases__[0].__name__ identity contract
# Pattern inherits directly from object.
# Accessed via __bases__.__getitem__(0).__name__.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra241.Pattern.base_name:
  description: "re.Pattern.__bases__[0].__name__ == 'object' — Pattern inherits directly from object; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

invariant re_extra241.Pattern.base_name_len:
  description: "len(re.Pattern.__bases__[0].__name__) == 6 — 'object' has 6 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__bases__.__getitem__
  args: [0]
  method: __name__
  method_chain: __len__
  expected: 6

# ---------------------------------------------------------------------------
# re.Pattern method name identity contracts
# match, search, findall, sub are primary Pattern methods.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra241.Pattern.match.name_eq:
  description: "re.Pattern.match.__name__ == 'match' — method name is 'match'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Pattern.match.__name__.__eq__
  args: ["match"]
  expected: true

invariant re_extra241.Pattern.match.qualname_eq:
  description: "re.Pattern.match.__qualname__ == 'Pattern.match' — qualname is 'Pattern.match'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Pattern.match.__qualname__.__eq__
  args: ["Pattern.match"]
  expected: true

invariant re_extra241.Pattern.search.name_eq:
  description: "re.Pattern.search.__name__ == 'search' — method name is 'search'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Pattern.search.__name__.__eq__
  args: ["search"]
  expected: true

invariant re_extra241.Pattern.search.qualname_eq:
  description: "re.Pattern.search.__qualname__ == 'Pattern.search' — qualname is 'Pattern.search'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Pattern.search.__qualname__.__eq__
  args: ["Pattern.search"]
  expected: true

invariant re_extra241.Pattern.findall.name_eq:
  description: "re.Pattern.findall.__name__ == 'findall' — method name is 'findall'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Pattern.findall.__name__.__eq__
  args: ["findall"]
  expected: true

invariant re_extra241.Pattern.sub.name_eq:
  description: "re.Pattern.sub.__name__ == 'sub' — method name is 'sub'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Pattern.sub.__name__.__eq__
  args: ["sub"]
  expected: true

