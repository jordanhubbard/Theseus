spec: strip_color
version: ">=0.1.0"
backend: node(strip-color)

docs: https://github.com/jonschlinkert/strip-color#readme

provenance:
  derived_from:
    - "strip-color README — https://github.com/jonschlinkert/strip-color#readme"
    - "ANSI escape sequences — ECMA-48 / ISO/IEC 6429"
    - "Test vectors verified with strip-color via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "strip-color source"
  notes:
    - "Strip ANSI color escape sequences from a string — used wherever you need plain text from a colored tty output."
    - "Install: npm install strip-color"
    - "v0.1 CJS; module export IS the function."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on string input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant strip_color.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant strip_color.strips_red:
  description: "Strips ANSI red foreground (\\u001b[31m ... \\u001b[0m)"
  category: strip
  kind: node_chain_eq
  entry: module
  entry_args: ["\x1b[31mred\x1b[0m text"]
  chain: []
  expected: "red text"

invariant strip_color.strips_bold_blue:
  description: "Strips ANSI bold + blue (\\u001b[1m\\u001b[34m)"
  category: strip
  kind: node_chain_eq
  entry: module
  entry_args: ["\x1b[1m\x1b[34mhello\x1b[0m world"]
  chain: []
  expected: "hello world"

invariant strip_color.passthrough_plain_text:
  description: "Plain text unchanged"
  category: passthrough
  kind: node_chain_eq
  entry: module
  entry_args: ["hello world"]
  chain: []
  expected: "hello world"

invariant strip_color.empty_string_passthrough:
  description: "Empty string passes through"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: [""]
  chain: []
  expected: ""

invariant strip_color.strips_256_color:
  description: "Strips 256-color sequence (\\u001b[38;5;201m)"
  category: strip
  kind: node_chain_eq
  entry: module
  entry_args: ["\x1b[38;5;201mmagenta\x1b[0m"]
  chain: []
  expected: "magenta"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:25:07Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
