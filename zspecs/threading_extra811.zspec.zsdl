spec: threading_extra811
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "CPython threading module source"
    - "Python 3.9+ language reference"
  not_derived_from:
    - "any third-party library"
  notes:
    - "Covers threading.Condition and Barrier method qualnames"
    - "Condition methods: __init__, acquire, release, wait, notify, notify_all, __enter__, __exit__"
    - "Barrier methods: __init__, wait, reset, abort"
  created_at: "2026-04-12"

table threading_extra811.condition_identity:
  description: "threading.Condition method qualname identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: th811cd
  columns: [id, function, args, expected]
  rows:
    - [th811cd001, "threading.Condition.__init__.__qualname__.__eq__", ["Condition.__init__"], true]
    - [th811cd002, "threading.Condition.acquire.__qualname__.__eq__", ["Condition.acquire"], true]
    - [th811cd003, "threading.Condition.release.__qualname__.__eq__", ["Condition.release"], true]
    - [th811cd004, "threading.Condition.wait.__qualname__.__eq__", ["Condition.wait"], true]
    - [th811cd005, "threading.Condition.notify.__qualname__.__eq__", ["Condition.notify"], true]
    - [th811cd006, "threading.Condition.notify_all.__qualname__.__eq__", ["Condition.notify_all"], true]
    - [th811cd007, "threading.Condition.__enter__.__qualname__.__eq__", ["Condition.__enter__"], true]
    - [th811cd008, "threading.Condition.__exit__.__qualname__.__eq__", ["Condition.__exit__"], true]

table threading_extra811.barrier_identity:
  description: "threading.Barrier method qualname identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: th811br
  columns: [id, function, args, expected]
  rows:
    - [th811br001, "threading.Barrier.__init__.__qualname__.__eq__", ["Barrier.__init__"], true]
    - [th811br002, "threading.Barrier.wait.__qualname__.__eq__", ["Barrier.wait"], true]
    - [th811br003, "threading.Barrier.reset.__qualname__.__eq__", ["Barrier.reset"], true]
    - [th811br004, "threading.Barrier.abort.__qualname__.__eq__", ["Barrier.abort"], true]
