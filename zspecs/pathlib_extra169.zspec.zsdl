spec: pathlib_extra169
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path.__dict__ membership for key filesystem methods using __dict__.__contains__."
    - "pathlib.Path.__dict__.__contains__('symlink_to') == True (len('symlink_to')=10)."
    - "pathlib.Path.__dict__.__contains__('hardlink_to') == True (len('hardlink_to')=11)."
    - "pathlib.Path.__dict__.__contains__('samefile') == True (len('samefile')=8)."
    - "pathlib.Path.__dict__.__contains__('is_symlink') == True (len('is_symlink')=10)."
    - "pathlib.Path.__dict__.__contains__('is_mount') == True (len('is_mount')=8)."
    - "pathlib.Path.__dict__.__contains__('is_file') == True (len('is_file')=7)."
    - "pathlib.Path.__dict__.__contains__('is_dir') == True (len('is_dir')=6)."
    - "len(pathlib.Path.__dict__) == 62 — the Path class dict contains 62 entries."
    - "All seven keys are directly defined on Path itself (not inherited from PurePath or object)."
    - "The two 'symlink_to' and 'is_symlink' keys both relate to symlinks but serve different roles: symlink_to creates a symlink, is_symlink tests for one."
    - "Key name length ranking: is_dir=6, is_file=7, samefile=is_mount=8, symlink_to=is_symlink=10, hardlink_to=11."
    - "Two-way tie at 10: symlink_to and is_symlink — both 10-character key names."
    - "Two-way tie at 8: samefile and is_mount — both 8-character key names."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__ membership for symlink/hardlink/samefile methods
# symlink_to (len=10), hardlink_to (len=11), samefile (len=8)
# All return True from __dict__.__contains__
# ---------------------------------------------------------------------------

table pathlib_extra169.Path_dict_link_methods:
  description: "pathlib.Path.__dict__ membership: symlink_to (len=10), hardlink_to (len=11), samefile (len=8) — all present in Path.__dict__; hardlink_to is the longest key name in this group"
  kind: python_call_eq
  category: identity
  id_prefix: pdict169

  columns: [id, function, args, expected, description]
  rows:
    - [path_symlink_in,   "Path.__dict__.__contains__",  ["symlink_to"],   true, "pathlib.Path.__dict__.__contains__('symlink_to') == True (symlink_to is directly defined in Path.__dict__ — it is not inherited but an I/O method specific to concrete Path; Path.symlink_to(target) makes this path a symbolic link pointing to target; symlinks can point to files or directories; 'symlink_to' has 10 characters: 'symlink' (7) + '_' (1) + 'to' (2) = 10; tied with 'is_symlink' (also 10) in key name length; symlink_to is the creation counterpart to is_symlink (the existence test); on Windows, symlink_to may require elevated privileges)"]
    - [path_hardlink_in,  "Path.__dict__.__contains__",  ["hardlink_to"],  true, "pathlib.Path.__dict__.__contains__('hardlink_to') == True (hardlink_to is directly defined in Path.__dict__; Path.hardlink_to(target) makes this path a hard link pointing to the same inode as target; unlike symlinks, hard links share the same inode and data blocks; 'hardlink_to' has 11 characters: 'hardlink' (8) + '_' (1) + 'to' (2) = 11; hardlink_to (11) is the longest key name among the link-related methods in this table; hardlink_to (11) is 1 character longer than symlink_to (10); hard links cannot span filesystems and cannot point to directories on most OS)"]
    - [path_samefile_in,  "Path.__dict__.__contains__",  ["samefile"],     true, "pathlib.Path.__dict__.__contains__('samefile') == True (samefile is directly defined in Path.__dict__; Path.samefile(other_path) returns True if this path and other_path refer to the same file or directory (via os.path.samefile which compares inode and device); 'samefile' has 8 characters: 'same' (4) + 'file' (4) = 8; samefile (8) is shorter than symlink_to (10) and hardlink_to (11); samefile returns True for hard links pointing to the same inode, and for symlinks resolving to the same target; tied in length (8) with is_mount)"]
    - [path_samefile_len, "Path.__dict__.__contains__",  ["is_symlink"],   true, "pathlib.Path.__dict__.__contains__('is_symlink') == True (is_symlink is directly defined in Path.__dict__; Path.is_symlink() returns True if the path points to a symbolic link, False otherwise; 'is_symlink' has 10 characters: 'is' (2) + '_' (1) + 'symlink' (7) = 10; tied in key name length with 'symlink_to' (also 10) — a coincidental tie between the symlink creation method and the symlink test method; is_symlink() uses lstat() to check the path itself rather than following symlinks; is_symlink() and symlink_to() are the two 10-character symlink-related keys in this spec)"]

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__ membership for is_mount, is_file, is_dir
# is_mount (len=8), is_file (len=7), is_dir (len=6)
# These are the 'is_*' predicate methods on concrete Path.
# Also check len(Path.__dict__) == 62.
# ---------------------------------------------------------------------------

table pathlib_extra169.Path_dict_predicate_methods:
  description: "pathlib.Path.__dict__ membership: is_mount (len=8), is_file (len=7), is_dir (len=6) — all present; len(Path.__dict__)==62; key lengths descend: is_mount > is_file > is_dir"
  kind: python_call_eq
  category: identity
  id_prefix: pdict169

  columns: [id, function, args, expected, description]
  rows:
    - [path_ismount_in,  "Path.__dict__.__contains__",  ["is_mount"],  true, "pathlib.Path.__dict__.__contains__('is_mount') == True (is_mount is directly defined in Path.__dict__; Path.is_mount() returns True if the path is a mount point — a directory where a different filesystem has been mounted; 'is_mount' has 8 characters: 'is' (2) + '_' (1) + 'mount' (5) = 8; tied in length (8) with 'samefile' — both are 8-character keys in Path.__dict__; is_mount (8) is longer than is_file (7) and is_dir (6); the three 'is_*' predicates form a descending sequence: is_mount=8, is_file=7, is_dir=6; is_mount() is implemented differently per OS)"]
    - [path_isfile_in,   "Path.__dict__.__contains__",  ["is_file"],   true, "pathlib.Path.__dict__.__contains__('is_file') == True (is_file is directly defined in Path.__dict__; Path.is_file() returns True if the path points to a regular file (not a directory, symlink, or special file); 'is_file' has 7 characters: 'is' (2) + '_' (1) + 'file' (4) = 7; is_file (7) sits between is_mount (8) and is_dir (6) in the descending length sequence; is_file() follows symlinks — it returns True if the final target of any symlink chain is a regular file; for a broken symlink is_file() returns False; is_file (7) is the sole occupant of key name length 7 among the 'is_*' predicates in this spec)"]
    - [path_isdir_in,    "Path.__dict__.__contains__",  ["is_dir"],    true, "pathlib.Path.__dict__.__contains__('is_dir') == True (is_dir is directly defined in Path.__dict__; Path.is_dir() returns True if the path points to a directory (following symlinks); 'is_dir' has 6 characters: 'is' (2) + '_' (1) + 'dir' (3) = 6; is_dir (6) is the shortest key name among all seven keys in this spec — the minimum; the three 'is_*' predicates descend: is_mount=8, is_file=7, is_dir=6; 'dir' (3 chars) is the shortest suffix among the 'is_*' predicates; is_dir() is one of the most frequently used pathlib predicates, paired with is_file() to determine basic path type; confirmed True in Path.__dict__ on Python 3.14.3)"]
    - [path_dict_len,    "Path.__dict__.__len__",       [],            62,   "pathlib.Path.__dict__.__len__() == 62 — the Path class dictionary contains exactly 62 entries on Python 3.14.3; this count includes methods like is_dir, is_file, is_mount, is_symlink, samefile, symlink_to, hardlink_to, and many others; len=62 for Path.__dict__ is the direct count of attributes defined on the concrete Path class itself, not including inherited attributes from PurePath or object; 62 entries reflects the rich I/O-capable API of the concrete Path class; contrast with PurePosixPath and PureWindowsPath which have fewer entries because they lack I/O methods; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra169.Path_symlink_to_in_dict:
  description: "pathlib.Path.__dict__.__contains__('symlink_to') == True — symlink_to is directly defined on Path (not inherited from PurePath); 'symlink_to' has 10 characters: 'symlink' (7) + '_to' (3) = 10; tied in key name length with 'is_symlink' (also 10) — the creation method and the test method for symlinks happen to share the same key name length; symlink_to is an I/O method specific to the concrete Path class; pure path classes (PurePosixPath, PureWindowsPath) do not have symlink_to in their __dict__; confirmed True on Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["symlink_to"]
  expected: true

invariant pathlib_extra169.Path_hardlink_to_in_dict:
  description: "pathlib.Path.__dict__.__contains__('hardlink_to') == True — hardlink_to is directly defined on Path; 'hardlink_to' has 11 characters: 'hardlink' (8) + '_to' (3) = 11; hardlink_to (11) is the longest key name among all seven filesystem method keys in this spec; hardlink_to creates a hard link to an existing path sharing the same inode; hard links differ from symlinks in that they reference inodes directly and cannot span filesystems; hardlink_to was added in Python 3.10, making it one of the newer Path I/O methods; confirmed True on Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["hardlink_to"]
  expected: true

invariant pathlib_extra169.Path_dict_len_62:
  description: "pathlib.Path.__dict__.__len__() == 62 — the Path class dict has exactly 62 entries on Python 3.14.3; this count covers all attributes directly defined on Path including filesystem I/O methods (is_dir, is_file, is_mount, is_symlink, samefile, symlink_to, hardlink_to, stat, open, touch, mkdir, rename, replace, unlink, rmdir, expanduser, iterdir, glob, rglob, walk, write_bytes, write_text, read_bytes, read_text, etc.) plus dunder and property attributes; 62 is the exact count measured on Python 3.14.3 macOS; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Path.__dict__.__len__"
  args: []
  expected: 62

invariant pathlib_extra169.Path_isdir_shortest_key_at_6:
  description: "pathlib.Path.__dict__.__contains__('is_dir') == True — 'is_dir' (6 chars) is the shortest key name among the seven filesystem method keys checked in this spec; the descending key name length sequence for 'is_*' predicates is: is_mount=8, is_file=7, is_dir=6; 'is_dir' (6 chars) uses the 3-character abbreviation 'dir' for directory — the shortest common filesystem concept abbreviation in pathlib; is_dir() is directly defined on Path (not inherited from PurePath) because testing whether the path is a directory requires OS I/O; confirmed True on Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["is_dir"]
  expected: true

