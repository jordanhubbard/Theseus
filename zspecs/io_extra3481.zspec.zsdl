spec: io3481
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io: Core tools for working with streams"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 679 (io3481): __enter__, __exit__, __call__ dict-presence checks for io types."
    - "Classes covered: io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.FileIO, io.BytesIO, io.StringIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.BufferedRWPair, io.TextIOWrapper."
    - "All io stream classes return false for __enter__ and __exit__ in their own __dict__: these methods are defined on io.IOBase (not shown in these tests) and inherited by all subclasses. The dict-presence check is for the class's own __dict__ only."
    - "No io class defines __call__ in its own __dict__: io stream classes are I/O abstractions, not callables."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __enter__ dict-presence — operator.contains(Cls.__dict__, '__enter__')
#
# No io subclass defines __enter__ in its own __dict__; all false.
# __enter__ is defined on io.IOBase and inherited by all subclasses.
# The dict-presence check tests only the class's own __dict__.
# ---------------------------------------------------------------------------

table io3481.enter:
