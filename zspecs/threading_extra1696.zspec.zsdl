spec: threading_extra1696
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python threading documentation — https://docs.python.org/3/library/threading.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "threading.zspec.zsdl — covers class __name__ checks (Barrier, BoundedSemaphore, Condition), function names, TIMEOUT_MAX, active_count, Lock, Event, Semaphore, current_thread.is_alive"
    - "threading_extra.zspec.zsdl — covers class_modules table, threading.local name/module, current_thread class name, get_ident, TIMEOUT_MAX type, stack_size"
    - "threading_extra1681.zspec.zsdl — covers __call__ callable protocol and thread execution interface attrs"
  notes:
    - "Wave 560 (_extra1696): pickling protocol — which stdlib types define __reduce__, __getstate__, __setstate__, __getnewargs__, __getnewargs_ex__ in their own __dict__."
    - "threading.Thread is a pure Python class — it is NOT picklable and defines none of the pickling protocol methods in its __dict__."
    - "threading.Event is a pure Python class — NOT picklable, no pickling protocol methods in its __dict__."
    - "threading.Condition is a pure Python class — NOT picklable, no pickling protocol methods in its __dict__."
    - "threading.Semaphore is a pure Python class — NOT picklable, no pickling protocol methods in its __dict__."
    - "threading.BoundedSemaphore is a pure Python class — NOT picklable, no pickling protocol methods in its __dict__."
    - "threading.Timer is a pure Python Thread subclass — NOT picklable, no pickling protocol methods in its __dict__."
    - "threading.local is a C extension type (_thread.local) — NOT picklable, no pickling protocol methods in its __dict__."
    - "threading.Lock is a factory function returning a C-level lock object; the lock type is not picklable."
    - "None of the threading classes define __copy__ or __deepcopy__ in their __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: pickling_protocol_absent
#
# Confirms that none of the public threading classes define __reduce__,
# __getstate__, __setstate__, __getnewargs__, or __getnewargs_ex__ in their
# own __dict__.  Threading primitives are inherently non-picklable because
# they hold OS-level synchronization resources that cannot be serialized.
# ---------------------------------------------------------------------------

table threading_extra1696.pickling_protocol_absent:
  description: "threading classes do not define pickling protocol methods in their __dict__"
  kind: python_call_eq
  category: pickling_protocol_absent
  id_prefix: th1696

  columns: [id, function, args, expected]
  rows:
    - ["th1696001", "threading.Thread.__dict__.__contains__",          ["__reduce__"],       false]
    - ["th1696002", "threading.Thread.__dict__.__contains__",          ["__getstate__"],     false]
    - ["th1696003", "threading.Thread.__dict__.__contains__",          ["__setstate__"],     false]
    - ["th1696004", "threading.Thread.__dict__.__contains__",          ["__getnewargs__"],   false]
    - ["th1696005", "threading.Thread.__dict__.__contains__",          ["__getnewargs_ex__"], false]
    - ["th1696006", "threading.Event.__dict__.__contains__",           ["__reduce__"],       false]
    - ["th1696007", "threading.Event.__dict__.__contains__",           ["__getstate__"],     false]
    - ["th1696008", "threading.Event.__dict__.__contains__",           ["__setstate__"],     false]
    - ["th1696009", "threading.Condition.__dict__.__contains__",       ["__reduce__"],       false]
    - ["th1696010", "threading.Condition.__dict__.__contains__",       ["__getstate__"],     false]
    - ["th1696011", "threading.Condition.__dict__.__contains__",       ["__setstate__"],     false]
    - ["th1696012", "threading.Semaphore.__dict__.__contains__",       ["__reduce__"],       false]
    - ["th1696013", "threading.Semaphore.__dict__.__contains__",       ["__getstate__"],     false]
    - ["th1696014", "threading.Semaphore.__dict__.__contains__",       ["__setstate__"],     false]
    - ["th1696015", "threading.BoundedSemaphore.__dict__.__contains__", ["__reduce__"],      false]
    - ["th1696016", "threading.BoundedSemaphore.__dict__.__contains__", ["__getstate__"],    false]
    - ["th1696017", "threading.Timer.__dict__.__contains__",           ["__reduce__"],       false]
    - ["th1696018", "threading.Timer.__dict__.__contains__",           ["__getstate__"],     false]
    - ["th1696019", "threading.local.__dict__.__contains__",           ["__reduce__"],       false]
    - ["th1696020", "threading.local.__dict__.__contains__",           ["__getstate__"],     false]

# ---------------------------------------------------------------------------
# Table 2: copy_protocol_absent
#
# Verifies that __copy__ and __deepcopy__ are also absent from threading
# class __dict__ entries.  No threading class supports custom copy protocol.
# ---------------------------------------------------------------------------

table threading_extra1696.copy_protocol_absent:
  description: "threading classes do not define __copy__ or __deepcopy__ in their __dict__"
  kind: python_call_eq
  category: copy_protocol_absent
  id_prefix: th1696

  columns: [id, function, args, expected]
  rows:
    - ["th1696030", "threading.Thread.__dict__.__contains__",           ["__copy__"],     false]
    - ["th1696031", "threading.Thread.__dict__.__contains__",           ["__deepcopy__"], false]
    - ["th1696032", "threading.Event.__dict__.__contains__",            ["__copy__"],     false]
    - ["th1696033", "threading.Event.__dict__.__contains__",            ["__deepcopy__"], false]
    - ["th1696034", "threading.Condition.__dict__.__contains__",        ["__copy__"],     false]
    - ["th1696035", "threading.Condition.__dict__.__contains__",        ["__deepcopy__"], false]
    - ["th1696036", "threading.Semaphore.__dict__.__contains__",        ["__copy__"],     false]
    - ["th1696037", "threading.Semaphore.__dict__.__contains__",        ["__deepcopy__"], false]
    - ["th1696038", "threading.local.__dict__.__contains__",            ["__copy__"],     false]
    - ["th1696039", "threading.local.__dict__.__contains__",            ["__deepcopy__"], false]

# ---------------------------------------------------------------------------
# Table 3: pickling_absent_vs_execution_present
#
# Contrasts the absent pickling methods with the present execution/lifecycle
# methods on threading.Thread and the synchronization interface on Event and
# Condition, confirming the design intention: these are execution primitives,
# not serializable data containers.
# ---------------------------------------------------------------------------

table threading_extra1696.pickling_absent_vs_execution_present:
  description: "threading pickling absent, execution/synchronization methods present"
  kind: python_call_eq
  category: pickling_absent_vs_execution_present
  id_prefix: th1696

  columns: [id, function, args, expected]
  rows:
    - ["th1696040", "threading.Thread.__dict__.__contains__", ["__reduce__"],   false]
    - ["th1696041", "threading.Thread.__dict__.__contains__", ["__getstate__"], false]
    - ["th1696042", "threading.Thread.__dict__.__contains__", ["run"],          true]
    - ["th1696043", "threading.Thread.__dict__.__contains__", ["start"],        true]
    - ["th1696044", "threading.Thread.__dict__.__contains__", ["join"],         true]
    - ["th1696045", "threading.Thread.__dict__.__contains__", ["is_alive"],     true]
    - ["th1696046", "threading.Event.__dict__.__contains__",  ["__reduce__"],   false]
    - ["th1696047", "threading.Event.__dict__.__contains__",  ["__getstate__"], false]
    - ["th1696048", "threading.Event.__dict__.__contains__",  ["set"],          true]
    - ["th1696049", "threading.Event.__dict__.__contains__",  ["clear"],        true]
    - ["th1696050", "threading.Event.__dict__.__contains__",  ["wait"],         true]
    - ["th1696051", "threading.Condition.__dict__.__contains__", ["__reduce__"],   false]
    - ["th1696052", "threading.Condition.__dict__.__contains__", ["__getstate__"], false]
    - ["th1696053", "threading.Condition.__dict__.__contains__", ["acquire"],      true]
    - ["th1696054", "threading.Condition.__dict__.__contains__", ["release"],      true]
    - ["th1696055", "threading.Condition.__dict__.__contains__", ["wait"],         true]
    - ["th1696056", "threading.Condition.__dict__.__contains__", ["notify"],       true]
