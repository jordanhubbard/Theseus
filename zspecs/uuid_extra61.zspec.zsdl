spec: uuid_extra61
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra60.zspec.zsdl — covers UUID.__repr__/__str__/__hash__/__eq__ co_name and co_argcount (table) / SafeUUID/__class__/__name__=='type' / SafeUUID/__name__/'module'/'qualname' (table) / SafeUUID/__bases__[0].__name__=='IntEnum' (table + invariants)."
    - "uuid_extra7.zspec.zsdl — covers SafeUUID/__name__/__module__/__qualname__ / SafeUUID.safe.value==0 / SafeUUID.unsafe.value==-1 / SafeUUID.__bases__[0].__name__=='IntEnum' / NAMESPACE_* version==1 (table) / uuid1/__class__/__name__=='UUID' / uuid1/uuid4 version (standalone invariants)."
    - "uuid_extra6.zspec.zsdl — covers RESERVED_NCS/RFC_4122/RESERVED_MICROSOFT/RESERVED_FUTURE __class__.__name__=='str' (table) / UUID.bytes/__bytes_le/__fields class names / UUID.fields.__len__()==6."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra60; it does NOT duplicate invariants present in those files."
    - "Wave 236 theme: uuid module __spec__ identity + UUID.__dict__ contents + uuid module __file__ checks."
    - "uuid.__name__.__eq__('uuid') — the module's own __name__ attribute. uuid_extra covers UUID.__name__=='UUID' (class name). No prior uuid spec checks the module __name__ attribute directly. In python_module(uuid), __name__ is the module-level __name__ attribute == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__spec__.name.__eq__('uuid') — ModuleSpec.name for the uuid module. No prior uuid spec checks __spec__.name in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__spec__.__class__.__name__.__eq__('ModuleSpec') — the type of the module spec object. No prior uuid spec checks __spec__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader') — uuid is a pure-Python module (Lib/uuid.py) loaded by SourceFileLoader. No prior uuid spec checks __loader__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__file__.__contains__('.py') — uuid.py is a .py file; __file__ contains '.py'. No prior uuid spec checks __file__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__class__.__name__.__eq__('mappingproxy') — the __dict__ of a class is always a mappingproxy. No prior uuid spec checks UUID.__dict__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__init__') — UUID defines __init__ in Lib/uuid.py; it is present in UUID.__dict__. No prior uuid spec checks UUID.__dict__.__contains__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__repr__') — UUID defines __repr__ in Lib/uuid.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__str__') — UUID defines __str__ in Lib/uuid.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__hash__') — UUID defines __hash__ in Lib/uuid.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__eq__') — UUID defines __eq__ in Lib/uuid.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid module __spec__ and loader identity
#
# Wave 236 theme: module spec, spec class name, and loader class name.
#
# No prior uuid spec checks __spec__.name, __spec__.__class__.__name__, or
# __loader__.__class__.__name__ in any form. These three anchors establish
# the module identity of uuid at the spec level.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra61.uuid_module_spec:
  description: "uuid.__name__.__eq__('uuid')==True / uuid.__spec__.name.__eq__('uuid')==True / uuid.__spec__.__class__.__name__.__eq__('ModuleSpec')==True / uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader')==True — module __name__/spec.name/spec class/loader class identity for uuid; no prior uuid spec checks __spec__.name/__spec__.__class__.__name__/__loader__.__class__.__name__; first module spec identity anchor for uuid module"
  kind: python_call_eq
  category: module_spec
  id_prefix: uuidspec61

  columns: [id, function, args, expected]
  rows:
    - [module_name_eq_uuid,           __name__.__eq__,                              ["uuid"],             true]
    - [spec_name_eq_uuid,             __spec__.name.__eq__,                         ["uuid"],             true]
    - [spec_class_name_ModuleSpec,    __spec__.__class__.__name__.__eq__,           ["ModuleSpec"],       true]
    - [loader_class_name_SourceFile,  __loader__.__class__.__name__.__eq__,         ["SourceFileLoader"], true]

# ---------------------------------------------------------------------------
# uuid.__file__.__contains__('.py')
#
# Wave 236 theme: module file path content check.
#
# uuid is a pure-Python module loaded from Lib/uuid.py. Its __file__ attribute
# is the path to uuid.py and contains '.py'. No prior uuid spec checks
# __file__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra61.file_contains_dot_py:
  description: "uuid.__file__.__contains__('.py') == True — uuid is a pure-Python module; __file__ is the path to uuid.py; no prior uuid spec checks __file__.__contains__('.py'); first __file__ content anchor for uuid module"
  category: module_spec
  kind: python_call_eq
  function: __file__.__contains__
  args: [".py"]
  expected: true

# ---------------------------------------------------------------------------
# UUID.__dict__.__class__.__name__ == 'mappingproxy'
#
# Wave 236 theme: UUID class __dict__ type identity.
#
# The __dict__ of any Python class is a mappingproxy. uuid.UUID is a
# pure-Python class; its __dict__.__class__.__name__ is 'mappingproxy'.
# No prior uuid spec checks UUID.__dict__.__class__.__name__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra61.UUID_dict_mappingproxy:
  description: "uuid.UUID.__dict__.__class__.__name__.__eq__('mappingproxy') == True — class __dict__ is always a mappingproxy; no prior uuid spec checks UUID.__dict__.__class__.__name__; first mappingproxy type anchor for uuid.UUID.__dict__"
  category: class_dict
  kind: python_call_eq
  function: UUID.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# UUID.__dict__.__contains__ checks for core dunder methods
#
# Wave 236 theme: UUID class defines its own dunder methods.
#
# uuid.UUID is a pure-Python class in Lib/uuid.py. It defines __init__,
# __repr__, __str__, __hash__, and __eq__ directly (not inherited). All five
# are present in UUID.__dict__. No prior uuid spec checks UUID.__dict__.__contains__
# for any of these methods. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra61.UUID_dict_contains:
  description: "uuid.UUID.__dict__.__contains__('__init__')==True / __contains__('__repr__')==True / __contains__('__str__')==True / __contains__('__hash__')==True / __contains__('__eq__')==True — UUID defines all five dunder methods in Lib/uuid.py; they are present in UUID.__dict__ (not inherited); no prior uuid spec checks UUID.__dict__.__contains__ for any method; first UUID.__dict__ content anchor for core dunder methods"
  kind: python_call_eq
  category: class_dict
  id_prefix: uuidspec61

  columns: [id, function, args, expected]
  rows:
    - [UUID_dict_has_init,   UUID.__dict__.__contains__, ["__init__"],   true]
    - [UUID_dict_has_repr,   UUID.__dict__.__contains__, ["__repr__"],   true]
    - [UUID_dict_has_str,    UUID.__dict__.__contains__, ["__str__"],    true]
    - [UUID_dict_has_hash,   UUID.__dict__.__contains__, ["__hash__"],   true]
    - [UUID_dict_has_eq,     UUID.__dict__.__contains__, ["__eq__"],     true]

# ---------------------------------------------------------------------------
# uuid.__spec__.name.__eq__('uuid') — standalone
#
# uuid.__spec__.name is the canonical module name in the ModuleSpec. It equals
# 'uuid'. No prior uuid spec checks __spec__.name in any form. First spec.name
# standalone for the uuid module.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra61.spec_name_uuid:
  description: "uuid.__spec__.name.__eq__('uuid') == True — uuid.__spec__.name is the canonical module name; no prior uuid spec checks __spec__.name in any form; first spec.name standalone for uuid module"
  category: module_spec
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["uuid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader') — standalone
#
# uuid is a pure-Python module. Its __loader__.__class__.__name__ is
# 'SourceFileLoader'. No prior uuid spec checks __loader__.__class__.__name__.
# First loader class standalone for uuid module.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra61.loader_SourceFileLoader:
  description: "uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — uuid is a pure-Python module loaded by SourceFileLoader; no prior uuid spec checks __loader__.__class__.__name__; first loader class standalone for uuid module"
  category: module_spec
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('__init__') — standalone
#
# UUID.__init__ is defined in Lib/uuid.py. It is present in UUID.__dict__.
# No prior uuid spec checks UUID.__dict__.__contains__ for any method.
# First UUID.__dict__ content standalone for '__init__'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra61.UUID_dict_has_init:
  description: "uuid.UUID.__dict__.__contains__('__init__') == True — UUID defines __init__ in Lib/uuid.py; it is in UUID.__dict__; no prior uuid spec checks UUID.__dict__.__contains__; first UUID.__dict__ content standalone for '__init__'"
  category: class_dict
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('__repr__') — standalone
#
# UUID.__repr__ is defined in Lib/uuid.py. It is present in UUID.__dict__.
# No prior uuid spec checks UUID.__dict__.__contains__('__repr__').
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra61.UUID_dict_has_repr:
  description: "uuid.UUID.__dict__.__contains__('__repr__') == True — UUID defines __repr__ in Lib/uuid.py; it is in UUID.__dict__; no prior uuid spec checks UUID.__dict__.__contains__('__repr__'); first __repr__ content standalone for UUID.__dict__"
  category: class_dict
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["__repr__"]
  expected: true
