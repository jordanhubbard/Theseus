spec: io_extra127
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec extends io_extra126.zspec.zsdl."
    - "This spec covers: io.UnsupportedOperation class identity attributes not yet covered."
    - "io_extra10 covered UnsupportedOperation.__name__=='UnsupportedOperation' and __module__=='io'."
    - "io_extra11 covered UnsupportedOperation.__bases__.__len__()==2, __bases__[0].__name__=='OSError', __bases__[1].__name__=='ValueError'."
    - "io_extra12 covered UnsupportedOperation.__mro__.__len__()==6 and __mro__[1].__name__=='OSError'."
    - "io_extra13 covered UnsupportedOperation.__mro__[0].__name__=='UnsupportedOperation'."
    - "io_extra126 covered UnsupportedOperation.__qualname__=='UnsupportedOperation' and __qualname__.__len__()==20."
    - "NOT yet covered: __mro__[2].__name__=='ValueError'; __mro__[3].__name__=='Exception'; __mro__[4].__name__=='BaseException'; __mro__[5].__name__=='object'; __bases__[0].__module__=='builtins'; __bases__[1].__module__=='builtins'; __module__.__len__()==2."
    - "UnsupportedOperation.__mro__[2].__name__ == 'ValueError' (len 10) — ValueError enters MRO after OSError due to C3 linearization."
    - "UnsupportedOperation.__mro__[3].__name__ == 'Exception' (len 9) — shared ancestor of OSError and ValueError."
    - "UnsupportedOperation.__mro__[4].__name__ == 'BaseException' (len 13) — root of exception hierarchy above Exception."
    - "UnsupportedOperation.__mro__[5].__name__ == 'object' (len 6) — the universal base class at the end of every MRO."
    - "UnsupportedOperation.__bases__[0].__module__ == 'builtins' (len 8) — OSError is defined in builtins."
    - "UnsupportedOperation.__bases__[1].__module__ == 'builtins' (len 8) — ValueError is defined in builtins."
    - "UnsupportedOperation.__module__.__len__() == 2 — 'io' has 2 characters."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.UnsupportedOperation MRO entries [2], [3], [4], [5]
# __mro__[2].__name__ == 'ValueError' (10 chars) — enters via C3 linearization after OSError.
# __mro__[3].__name__ == 'Exception' (9 chars) — shared ancestor of OSError and ValueError.
# __mro__[4].__name__ == 'BaseException' (13 chars) — root of exception hierarchy above Exception.
# __mro__[5].__name__ == 'object' (6 chars) — universal base at end of every MRO.
# io_extra12 covered __mro__.__len__()==6 and __mro__[1].__name__=='OSError'.
# io_extra13 covered __mro__[0].__name__=='UnsupportedOperation'.
# NO prior spec asserts __mro__[2], [3], [4], or [5] by name equality.
# ---------------------------------------------------------------------------

table io_extra127.UnsupportedOperation_mro_entries_2_to_5:
  description: "io.UnsupportedOperation __mro__[2]=='ValueError'(10); [3]=='Exception'(9); [4]=='BaseException'(13); [5]=='object'(6); all name equality assertions novel; io_extra12 covered [1]=='OSError'; io_extra13 covered [0]=='UnsupportedOperation'"
  kind: python_call_eq
  category: type_identity
  id_prefix: iomro127a

  columns: [id, function, args, expected, description]
  rows:
    - [mro2_name_eq,   "UnsupportedOperation.__mro__[2].__name__.__eq__",   ["ValueError"],     true,  "io.UnsupportedOperation.__mro__[2].__name__ == 'ValueError' (C3 linearization places ValueError after OSError in the MRO because UnsupportedOperation inherits from both)"]
    - [mro2_name_len,  "UnsupportedOperation.__mro__[2].__name__.__len__",  [],                 10,    "io.UnsupportedOperation.__mro__[2].__name__.__len__() == 10 ('ValueError' has 10 characters: 'Value'(5)+'Error'(5)==10)"]
    - [mro3_name_eq,   "UnsupportedOperation.__mro__[3].__name__.__eq__",   ["Exception"],      true,  "io.UnsupportedOperation.__mro__[3].__name__ == 'Exception' (9 chars; shared ancestor of OSError and ValueError; Exception is the base for all non-system-exiting exceptions)"]
    - [mro3_name_len,  "UnsupportedOperation.__mro__[3].__name__.__len__",  [],                 9,     "io.UnsupportedOperation.__mro__[3].__name__.__len__() == 9 ('Exception' has 9 characters)"]
    - [mro4_name_eq,   "UnsupportedOperation.__mro__[4].__name__.__eq__",   ["BaseException"],  true,  "io.UnsupportedOperation.__mro__[4].__name__ == 'BaseException' (13 chars; root of exception hierarchy; parent of Exception, KeyboardInterrupt, SystemExit, GeneratorExit)"]
    - [mro4_name_len,  "UnsupportedOperation.__mro__[4].__name__.__len__",  [],                 13,    "io.UnsupportedOperation.__mro__[4].__name__.__len__() == 13 ('BaseException' has 13 characters: 'Base'(4)+'Exception'(9)==13)"]
    - [mro5_name_eq,   "UnsupportedOperation.__mro__[5].__name__.__eq__",   ["object"],         true,  "io.UnsupportedOperation.__mro__[5].__name__ == 'object' (6 chars; universal base class; every class in Python ultimately inherits from object)"]
    - [mro5_name_len,  "UnsupportedOperation.__mro__[5].__name__.__len__",  [],                 6,     "io.UnsupportedOperation.__mro__[5].__name__.__len__() == 6 ('object' has 6 characters; appears last in every MRO under the C3 algorithm)"]

# ---------------------------------------------------------------------------
# io.UnsupportedOperation base class module assertions
# __bases__[0].__module__ == 'builtins' (len 8) — OSError lives in builtins.
# __bases__[1].__module__ == 'builtins' (len 8) — ValueError lives in builtins.
# __module__.__len__() == 2 — UnsupportedOperation itself lives in 'io' (2 chars).
# io_extra11 covered __bases__[0].__name__=='OSError' and __bases__[1].__name__=='ValueError'.
# NO prior spec asserts __bases__[0].__module__ or __bases__[1].__module__.
# NO prior spec asserts __module__.__len__() == 2 (only __module__.__eq__('io') was covered).
# ---------------------------------------------------------------------------

table io_extra127.UnsupportedOperation_bases_module_assertions:
  description: "io.UnsupportedOperation.__bases__[0].__module__=='builtins'(8); [1].__module__=='builtins'(8); __module__.__len__()==2; all novel; io_extra11 covered base __name__ equality; io_extra10 covered __module__.__eq__('io') but not __len__()"
  kind: python_call_eq
  category: type_identity
  id_prefix: iomro127b

  columns: [id, function, args, expected, description]
  rows:
    - [base0_mod_eq,   "UnsupportedOperation.__bases__[0].__module__.__eq__",   ["builtins"],  true,  "io.UnsupportedOperation.__bases__[0].__module__ == 'builtins' (OSError is defined in the builtins module; it is a built-in exception type)"]
    - [base0_mod_len,  "UnsupportedOperation.__bases__[0].__module__.__len__",  [],            8,     "io.UnsupportedOperation.__bases__[0].__module__.__len__() == 8 ('builtins' has 8 characters: 'built'(5)+'ins'(3)==8)"]
    - [base1_mod_eq,   "UnsupportedOperation.__bases__[1].__module__.__eq__",   ["builtins"],  true,  "io.UnsupportedOperation.__bases__[1].__module__ == 'builtins' (ValueError is defined in the builtins module; both direct bases of UnsupportedOperation are built-in exception types)"]
    - [base1_mod_len,  "UnsupportedOperation.__bases__[1].__module__.__len__",  [],            8,     "io.UnsupportedOperation.__bases__[1].__module__.__len__() == 8 ('builtins' has 8 characters; same as __bases__[0].__module__.__len__())"]
    - [mod_len_eq_2,   "UnsupportedOperation.__module__.__len__",               [],            2,     "io.UnsupportedOperation.__module__.__len__() == 2 ('io' has 2 characters; UnsupportedOperation is defined in the io module; io_extra10 covered __module__.__eq__('io') but not __len__()==2)"]
    - [both_bases_same_mod, "UnsupportedOperation.__bases__[0].__module__.__eq__", ["builtins"], true, "both direct bases of UnsupportedOperation live in 'builtins': __bases__[0].__module__==__bases__[1].__module__=='builtins'; OSError and ValueError are both primitive built-in exceptions"]
    - [mod_len_lt_base_mod_len, "UnsupportedOperation.__module__.__len__.__lt__", [8],        true,  "len('io') < len('builtins') (2 < 8; the defining module 'io' is shorter than the base classes' defining module 'builtins')"]
    - [mro4_gt_mro3,  "UnsupportedOperation.__mro__[4].__name__.__len__.__gt__", [9],         true,  "len('BaseException') > len('Exception') (13 > 9; the parent class name is longer than the child class name in this case)"]

# ---------------------------------------------------------------------------
# io.UnsupportedOperation MRO length and name inequality assertions
# Confirms the complete MRO structure through cross-index comparisons.
# __mro__[2].__name__ != __mro__[3].__name__: 'ValueError' != 'Exception'.
# __mro__[4].__name__ != __mro__[5].__name__: 'BaseException' != 'object'.
# __mro__[3].__name__.__len__() < __mro__[4].__name__.__len__(): 9 < 13.
# No prior spec covers cross-index name inequality for UnsupportedOperation MRO.
# ---------------------------------------------------------------------------

table io_extra127.UnsupportedOperation_mro_cross_comparisons:
  description: "io.UnsupportedOperation MRO cross-comparisons: ValueError(10)!=Exception(9); BaseException(13)!=object(6); len(Exception)==9 < len(BaseException)==13; all novel cross-index assertions for UnsupportedOperation MRO"
  kind: python_call_eq
  category: type_identity
  id_prefix: iomro127c

  columns: [id, function, args, expected, description]
  rows:
    - [mro2_ne_mro3,   "UnsupportedOperation.__mro__[2].__name__.__eq__",      ["Exception"],      false, "io.UnsupportedOperation.__mro__[2].__name__ != 'Exception' (position 2 is 'ValueError', not 'Exception'; Exception comes at position 3)"]
    - [mro3_ne_mro4,   "UnsupportedOperation.__mro__[3].__name__.__eq__",      ["BaseException"],  false, "io.UnsupportedOperation.__mro__[3].__name__ != 'BaseException' (position 3 is 'Exception', not 'BaseException'; BaseException comes at position 4)"]
    - [mro5_is_object, "UnsupportedOperation.__mro__[5].__name__.__eq__",      ["object"],         true,  "io.UnsupportedOperation.__mro__[5].__name__ == 'object' (object is always the final entry; no class comes after object in any Python MRO under C3 linearization)"]
    - [mro3_len_9,     "UnsupportedOperation.__mro__[3].__name__.__len__",     [],                 9,     "io.UnsupportedOperation.__mro__[3].__name__.__len__() == 9 ('Exception' has 9 characters; Exception is the root for all non-fatal exceptions in Python)"]
    - [mro3_lt_mro4,   "UnsupportedOperation.__mro__[3].__name__.__len__.__lt__", [13],            true,  "len('Exception') < len('BaseException') (9 < 13; despite Exception being a subclass of BaseException, its name is 4 chars shorter)"]
    - [mro2_len_gt_mro3_len, "UnsupportedOperation.__mro__[2].__name__.__len__.__gt__", [9],       true,  "len('ValueError') > len('Exception') (10 > 9; 'ValueError' is 1 character longer than 'Exception')"]
    - [mro4_ne_object, "UnsupportedOperation.__mro__[4].__name__.__eq__",      ["object"],         false, "io.UnsupportedOperation.__mro__[4].__name__ != 'object' (position 4 is 'BaseException', not 'object'; object appears at position 5, the very end)"]
    - [mro5_ne_base,   "UnsupportedOperation.__mro__[5].__name__.__eq__",      ["BaseException"],  false, "io.UnsupportedOperation.__mro__[5].__name__ != 'BaseException' (position 5 is 'object', not 'BaseException'; object always terminates the MRO)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra127.UnsupportedOperation.mro_ValueError_at_index_2:
  description: "io.UnsupportedOperation.__mro__[2].__name__ == 'ValueError' (10 chars; C3 linearization for multiple inheritance places ValueError at MRO index 2 because UnsupportedOperation(OSError, ValueError) inherits from both OSError and ValueError; OSError appears first at index 1, then ValueError at index 2 before their shared ancestor Exception at index 3; this MRO slot was not asserted by any prior io_extra spec — io_extra12 only covered __mro__[1] and __mro__.__len__()); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: type_identity
  kind: python_call_eq
  function: "UnsupportedOperation.__mro__[2].__name__.__eq__"
  args: ["ValueError"]
  expected: true

invariant io_extra127.UnsupportedOperation.mro_BaseException_at_index_4:
  description: "io.UnsupportedOperation.__mro__[4].__name__ == 'BaseException' (13 chars; BaseException is the root of the exception hierarchy above Exception; it is a direct parent of Exception in Python's built-in exception tree; all exceptions must be subclasses of BaseException; 'BaseException' at 13 chars is the longest name in the UnsupportedOperation MRO; no prior io_extra spec asserts __mro__[4].__name__ for UnsupportedOperation); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: type_identity
  kind: python_call_eq
  function: "UnsupportedOperation.__mro__[4].__name__.__eq__"
  args: ["BaseException"]
  expected: true

invariant io_extra127.UnsupportedOperation.mro_object_at_index_5:
  description: "io.UnsupportedOperation.__mro__[5].__name__ == 'object' (6 chars; object is the universal base class and always terminates every Python class MRO under the C3 linearization algorithm; there are exactly 6 entries in UnsupportedOperation's MRO: [UnsupportedOperation, OSError, ValueError, Exception, BaseException, object]; index 5 is the final entry; no prior io_extra spec asserts __mro__[5].__name__ for UnsupportedOperation); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: type_identity
  kind: python_call_eq
  function: "UnsupportedOperation.__mro__[5].__name__.__eq__"
  args: ["object"]
  expected: true

invariant io_extra127.UnsupportedOperation.bases_OSError_module_builtins:
  description: "io.UnsupportedOperation.__bases__[0].__module__ == 'builtins' (8 chars; OSError is defined in the builtins module as a built-in C exception type; 'builtins' is the module where all built-in exception types live in Python's import system; io_extra11 covered __bases__[0].__name__=='OSError' but did not check __module__; this is the first spec to assert __bases__[0].__module__=='builtins' for UnsupportedOperation); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: type_identity
  kind: python_call_eq
  function: "UnsupportedOperation.__bases__[0].__module__.__eq__"
  args: ["builtins"]
  expected: true

invariant io_extra127.UnsupportedOperation.module_len_2:
  description: "io.UnsupportedOperation.__module__.__len__() == 2 ('io' has 2 characters; UnsupportedOperation is defined in the io module; 'io' is one of the shortest module names in the Python standard library; io_extra10 covered __module__.__eq__('io') but did not assert the length of the module name string; this is the first spec to assert that UnsupportedOperation.__module__ is exactly 2 characters long); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: type_identity
  kind: python_call_eq
  function: UnsupportedOperation.__module__.__len__
  args: []
  expected: 2
