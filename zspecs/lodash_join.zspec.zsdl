spec: lodash_join
version: ">=4.0.0"
backend: node(lodash.join)

docs: https://lodash.com/docs/#join

provenance:
  derived_from:
    - "lodash.join README — https://www.npmjs.com/package/lodash.join"
    - "Test vectors verified with lodash.join@4.0.4 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.join exports the _.join function directly as module.exports."
    - "join(array, separator) converts array to a string joined by separator."
    - "Defaults to ',' separator if omitted."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a joined string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_join.join:
  kind: node_module_call_eq
  function: ~
  category: join
  id_prefix: ljoin

  columns: [id, args, expected]
  rows:
    - [dash,     [[1, 2, 3], "-"],    "1-2-3"]
    - [comma,    [["a", "b", "c"], ","], "a,b,c"]
    - [space,    [["foo", "bar"], " "], "foo bar"]
    - [empty,    [[], "-"],           ""]

