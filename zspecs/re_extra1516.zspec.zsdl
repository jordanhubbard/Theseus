spec: re_extra1516
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module Pattern, Match, error documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "PCRE source code"
  notes:
    - "Wave 548 (_extra1516): arithmetic/numeric operator __dict__ presence checks for re module classes."
    - "re.Pattern, re.Match, and re.error are pattern-matching and exception types, not numeric types. None define __add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__, or __pow__ in their own __dict__."
    - "re.Pattern defines comparison operators (__eq__, __ne__, __lt__, __le__, __gt__, __ge__, __hash__) but not arithmetic operators."
    - "re.Match defines __getitem__ for named/indexed group access (match[0], match['name']) but no arithmetic operators."
    - "re.error is an Exception subclass with an overridden __init__ (to store pattern and pos) but no arithmetic operators."
    - "Positive anchors confirm pattern-matching methods (match, search, findall) are present in re.Pattern.__dict__, and result-extraction methods (group, groups, span) are present in re.Match.__dict__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra1516.pattern_arithmetic_ops:
  description: "re.Pattern arithmetic operator absence — __add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__, __pow__ are all absent from re.Pattern.__dict__; Pattern defines comparison operators but not arithmetic ones; positive anchors show pattern-matching methods ARE present; wave 548"
  kind: python_call_eq
  category: arithmetic_ops
  id_prefix: re1516pa
  columns: [id, function, args, expected, description]
  rows:
    - [re1516pa001,
       re.Pattern.__dict__.__contains__,
       ["__add__"],
       false,
       "re.Pattern.__dict__.__contains__('__add__') == False — re.Pattern is the compiled regular expression type; it is not a numeric type and defines no __add__; Pattern objects cannot be added together; the + quantifier in regex syntax is a string-level construct, not a Python-level __add__ on Pattern objects; verified with Python 3.14.3"]
    - [re1516pa002,
       re.Pattern.__dict__.__contains__,
       ["__mul__"],
       false,
       "re.Pattern.__dict__.__contains__('__mul__') == False — re.Pattern does not implement __mul__; pattern multiplication has no defined semantics; re.Pattern.__dict__ contains match, search, fullmatch, findall, sub, subn, split, finditer — pattern-matching methods only, no arithmetic operators; verified with Python 3.14.3"]
    - [re1516pa003,
       re.Pattern.__dict__.__contains__,
       ["__sub__"],
       false,
       "re.Pattern.__dict__.__contains__('__sub__') == False — re.Pattern does not implement __sub__; subtraction is undefined for compiled regex pattern objects; Pattern objects are opaque compiled state machines, not numeric values; verified with Python 3.14.3"]
    - [re1516pa004,
       re.Pattern.__dict__.__contains__,
       ["__truediv__"],
       false,
       "re.Pattern.__dict__.__contains__('__truediv__') == False — re.Pattern does not implement __truediv__; division is undefined for Pattern objects; contrast with pathlib.PurePath which defines __truediv__ for path joining — no such operator exists on Pattern; re.Pattern.__dict__ has no arithmetic operators whatsoever; verified with Python 3.14.3"]
    - [re1516pa005,
       re.Pattern.__dict__.__contains__,
       ["__floordiv__"],
       false,
       "re.Pattern.__dict__.__contains__('__floordiv__') == False — re.Pattern does not implement __floordiv__; floor division is absent from re.Pattern.__dict__; the floor // operator has no defined semantics for compiled regex patterns; verified with Python 3.14.3"]
    - [re1516pa006,
       re.Pattern.__dict__.__contains__,
       ["__mod__"],
       false,
       "re.Pattern.__dict__.__contains__('__mod__') == False — re.Pattern does not implement __mod__; modulo is absent from re.Pattern.__dict__; the % operator has no defined semantics for Pattern objects (contrast with str.__mod__ for % string formatting); verified with Python 3.14.3"]
    - [re1516pa007,
       re.Pattern.__dict__.__contains__,
       ["match"],
       true,
       "re.Pattern.__dict__.__contains__('match') == True — positive anchor: re.Pattern defines 'match' in its own __dict__; match attempts to apply the pattern at the start of the string; pattern-matching methods are defined while all arithmetic operators are absent; verified with Python 3.14.3"]
    - [re1516pa008,
       re.Pattern.__dict__.__contains__,
       ["findall"],
       true,
       "re.Pattern.__dict__.__contains__('findall') == True — positive anchor: re.Pattern defines 'findall' in its own __dict__; findall returns all non-overlapping matches as a list; stream I/O methods and arithmetic operators are absent from Pattern; only pattern-matching, substitution, and splitting operations are defined; verified with Python 3.14.3"]
    - [re1516pa009,
       re.Pattern.__dict__.__contains__,
       ["__pow__"],
       false,
       "re.Pattern.__dict__.__contains__('__pow__') == False — re.Pattern does not implement __pow__; exponentiation is absent from re.Pattern.__dict__; the complete set of absent arithmetic operators from Pattern: __add__, __radd__, __mul__, __rmul__, __sub__, __rsub__, __truediv__, __rtruediv__, __floordiv__, __rfloordiv__, __mod__, __rmod__, __pow__, __rpow__; none are defined; verified with Python 3.14.3"]

table re_extra1516.match_arithmetic_ops:
  description: "re.Match arithmetic operator absence — __add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__, __pow__ are all absent from re.Match.__dict__; Match defines __getitem__ for group access but not arithmetic operators; positive anchors show result-extraction methods ARE present; wave 548"
  kind: python_call_eq
  category: arithmetic_ops
  id_prefix: re1516ma
  columns: [id, function, args, expected, description]
  rows:
    - [re1516ma001,
       re.Match.__dict__.__contains__,
       ["__add__"],
       false,
       "re.Match.__dict__.__contains__('__add__') == False — re.Match is the match object type returned by pattern matching; it is not a numeric type and defines no __add__; Match objects represent a single match result — they are result containers, not numeric values; verified with Python 3.14.3"]
    - [re1516ma002,
       re.Match.__dict__.__contains__,
       ["__mul__"],
       false,
       "re.Match.__dict__.__contains__('__mul__') == False — re.Match does not implement __mul__; multiplication is undefined for match result objects; re.Match.__dict__ contains group, groups, groupdict, start, end, span, expand, and __getitem__ — result-extraction methods only; verified with Python 3.14.3"]
    - [re1516ma003,
       re.Match.__dict__.__contains__,
       ["__truediv__"],
       false,
       "re.Match.__dict__.__contains__('__truediv__') == False — re.Match does not implement __truediv__; the division operator has no defined semantics for match result objects; re.Match.__dict__ does NOT define __truediv__ — unlike pathlib.PurePath which defines it for path joining; verified with Python 3.14.3"]
    - [re1516ma004,
       re.Match.__dict__.__contains__,
       ["__mod__"],
       false,
       "re.Match.__dict__.__contains__('__mod__') == False — re.Match does not implement __mod__; modulo is absent from re.Match.__dict__; no arithmetic operators appear in re.Match.__dict__; the only subscript-style operator is __getitem__ for group access (match[0], match['name']), not numeric modulo; verified with Python 3.14.3"]
    - [re1516ma005,
       re.Match.__dict__.__contains__,
       ["__getitem__"],
       true,
       "re.Match.__dict__.__contains__('__getitem__') == True — positive anchor: re.Match defines __getitem__ in its own __dict__ for subscript group access (match[0] == match.group(0)); __getitem__ is a subscript operator, not an arithmetic operator; it coexists with the complete absence of __add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__, __pow__; verified with Python 3.14.3"]
    - [re1516ma006,
       re.Match.__dict__.__contains__,
       ["group"],
       true,
       "re.Match.__dict__.__contains__('group') == True — positive anchor: re.Match defines 'group' in its own __dict__; group() is the primary method for extracting the matched substring or capturing group; result-extraction methods are defined while all arithmetic operators (__add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__, __pow__) are absent; verified with Python 3.14.3"]
    - [re1516ma007,
       re.Match.__dict__.__contains__,
       ["__sub__"],
       false,
       "re.Match.__dict__.__contains__('__sub__') == False — re.Match does not implement __sub__; subtraction is undefined for match result objects; the complete absent arithmetic set from Match: __add__, __radd__, __sub__, __rsub__, __mul__, __rmul__, __truediv__, __rtruediv__, __floordiv__, __rfloordiv__, __mod__, __rmod__, __pow__, __rpow__; verified with Python 3.14.3"]
    - [re1516ma008,
       re.Match.__dict__.__contains__,
       ["span"],
       true,
       "re.Match.__dict__.__contains__('span') == True — positive anchor: re.Match defines 'span' in its own __dict__; span() returns the (start, end) tuple of the match position; positional methods (start, end, span) and group methods (group, groups, groupdict) are defined while all fourteen arithmetic operators are absent; verified with Python 3.14.3"]
    - [re1516ma009,
       re.Match.__dict__.__contains__,
       ["__floordiv__"],
       false,
       "re.Match.__dict__.__contains__('__floordiv__') == False — re.Match does not implement __floordiv__; floor division is undefined for match objects; re.Match is a result container for a single regex match, not a numeric type; verified with Python 3.14.3"]

table re_extra1516.error_arithmetic_ops:
  description: "re.error arithmetic operator absence — all arithmetic operators absent from re.error.__dict__; error is an Exception subclass with __init__ for pattern/pos storage but no arithmetic; cross-checks confirm Pattern and Match also lack all arithmetic dunders; wave 548"
  kind: python_call_eq
  category: arithmetic_ops
  id_prefix: re1516er
  columns: [id, function, args, expected, description]
  rows:
    - [re1516er001,
       re.error.__dict__.__contains__,
       ["__add__"],
       false,
       "re.error.__dict__.__contains__('__add__') == False — re.error is the exception class raised for invalid regular expression patterns; as an Exception subclass it defines no arithmetic operators; exception objects are not addable; __add__ is absent from re.error.__dict__ and from the entire Exception hierarchy; verified with Python 3.14.3"]
    - [re1516er002,
       re.error.__dict__.__contains__,
       ["__mul__"],
       false,
       "re.error.__dict__.__contains__('__mul__') == False — re.error does not implement __mul__; exception types define no arithmetic operators; the Exception hierarchy (Exception, BaseException, object) does not define __mul__ either; verified with Python 3.14.3"]
    - [re1516er003,
       re.error.__dict__.__contains__,
       ["__truediv__"],
       false,
       "re.error.__dict__.__contains__('__truediv__') == False — re.error does not implement __truediv__; division is undefined for exception objects; re.error is not a path-like object (which would use __truediv__ for joining) or a numeric type (which would use __truediv__ for division); verified with Python 3.14.3"]
    - [re1516er004,
       re.error.__dict__.__contains__,
       ["__init__"],
       true,
       "re.error.__dict__.__contains__('__init__') == True — positive anchor: re.error defines __init__ in its own __dict__ to capture the invalid pattern and position; re.error.__init__ stores pattern, pos, and msg attributes describing the regex error; exception initialization is defined while all arithmetic operators (__add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__, __pow__) are absent; verified with Python 3.14.3"]
    - [re1516er005,
       re.error.__dict__.__contains__,
       ["__mod__"],
       false,
       "re.error.__dict__.__contains__('__mod__') == False — re.error does not implement __mod__; modulo is absent from re.error.__dict__; exception types do not implement format-string semantics via % even though str defines __mod__ for % formatting; verified with Python 3.14.3"]
    - [re1516er006,
       re.error.__dict__.__contains__,
       ["__floordiv__"],
       false,
       "re.error.__dict__.__contains__('__floordiv__') == False — re.error does not implement __floordiv__; floor division is absent; the complete set of absent arithmetic operators from re.error: __add__, __radd__, __mul__, __rmul__, __sub__, __rsub__, __truediv__, __rtruediv__, __floordiv__, __rfloordiv__, __mod__, __rmod__, __pow__, __rpow__; none defined; verified with Python 3.14.3"]
    - [re1516er007,
       re.Pattern.__dict__.__contains__,
       ["__radd__"],
       false,
       "re.Pattern.__dict__.__contains__('__radd__') == False — cross-check: re.Pattern also lacks __radd__; neither the forward __add__ nor the reflected __radd__ is defined on Pattern; confirmed that none of the three main re classes (Pattern, Match, error) define any arithmetic operator dunder in their __dict__; verified with Python 3.14.3"]
    - [re1516er008,
       re.Match.__dict__.__contains__,
       ["__rmul__"],
       false,
       "re.Match.__dict__.__contains__('__rmul__') == False — cross-check: re.Match also lacks __rmul__; the reflected multiplication operator is absent from Match just as __mul__ is absent; all three re classes (Pattern, Match, error) are entirely free of arithmetic operator dunders in their own __dict__; verified with Python 3.14.3"]
    - [re1516er009,
       re.error.__dict__.__contains__,
       ["__sub__"],
       false,
       "re.error.__dict__.__contains__('__sub__') == False — re.error does not implement __sub__; subtraction is absent; the summary for wave 548 re module: all three classes (Pattern, Match, error) define zero arithmetic operators (__add__, __radd__, __mul__, __rmul__, __sub__, __rsub__, __truediv__, __rtruediv__, __floordiv__, __rfloordiv__, __mod__, __rmod__, __pow__, __rpow__) in their own __dict__; verified with Python 3.14.3"]
