table multiprocessing_extra242.basemanager_method_identity:
  description: "multiprocessing.managers.BaseManager method identity — start(len=5), connect(len=7), join(len=4), get_server(len=10, longest __name__) are the lifecycle/connection methods; __init__(len=8) initializes; all have __module__=='multiprocessing.managers'(len=24); BaseManager.get_server.__qualname__=='BaseManager.get_server'(len=22, longest qualname); BaseManager does NOT have shutdown (contrast with SyncManager which provides managed object lifecycle); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mp242bm

  columns: [id, function, args, expected, description]
  rows:
    - [bm_start_name_eq,   BaseManager.start.__name__.__eq__,      ["start"],                    true, "BaseManager.start.__name__ == 'start'; verified with Python 3.14.3"]
