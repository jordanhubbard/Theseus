spec: multiprocessing_extra242
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#managers — Managers documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/managers.py (BaseManager and SyncManager implementation)"
  notes:
    - "multiprocessing.managers.SyncManager.__name__ == 'SyncManager' (len=11); __module__ == 'multiprocessing.managers' (len=24); __bases__[0].__name__ == 'BaseManager' (len=11)."
    - "multiprocessing.managers.SyncManager.start.__qualname__ == 'BaseManager.start' (len=17) — start is inherited from BaseManager, not overridden in SyncManager."
    - "multiprocessing.managers.BaseManager.start.__name__ == 'start' (len=5); __qualname__ == 'BaseManager.start' (len=17); __module__ == 'multiprocessing.managers' (len=24)."
    - "multiprocessing.managers.BaseManager.connect.__name__ == 'connect' (len=7); __qualname__ == 'BaseManager.connect' (len=19)."
    - "multiprocessing.managers.BaseManager.join.__name__ == 'join' (len=4); __qualname__ == 'BaseManager.join' (len=16)."
    - "multiprocessing.managers.BaseManager.get_server.__name__ == 'get_server' (len=10); __qualname__ == 'BaseManager.get_server' (len=22) — longest qualname in this spec."
    - "multiprocessing.managers.BaseManager.__init__.__name__ == '__init__' (len=8); __qualname__ == 'BaseManager.__init__' (len=20)."
    - "BaseManager does NOT have a 'shutdown' method — verified Python 3.14.3. BaseManager public methods: address, connect, get_server, join, register, start."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.managers.SyncManager class identity
#
# SyncManager.__name__ == 'SyncManager' (len=11)
# SyncManager.__module__ == 'multiprocessing.managers' (len=24)
# SyncManager.__bases__[0].__name__ == 'BaseManager' (len=11)
# SyncManager.start.__qualname__ == 'BaseManager.start' (len=17) — inherited
# ---------------------------------------------------------------------------

table multiprocessing_extra242.syncmanager_class_identity:
  description: "multiprocessing.managers.SyncManager class identity — SyncManager(len=11) inherits from BaseManager(len=11, same length); __module__=='multiprocessing.managers'(len=24); SyncManager.start.__qualname__=='BaseManager.start'(len=17) because start is inherited from BaseManager, not overridden in SyncManager; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mp242sm

  columns: [id, function, args, expected, description]
  rows:
    - [sm_name_eq,      SyncManager.__name__.__eq__,                       ["SyncManager"],              true, "multiprocessing.managers.SyncManager.__name__ == 'SyncManager'; verified with Python 3.14.3"]
    - [sm_name_len,     SyncManager.__name__.__len__,                      [],                           11,   "multiprocessing.managers.SyncManager.__name__.__len__() == 11; verified with Python 3.14.3"]
    - [sm_mod_eq,       SyncManager.__module__.__eq__,                     ["multiprocessing.managers"], true, "multiprocessing.managers.SyncManager.__module__ == 'multiprocessing.managers'; verified with Python 3.14.3"]
    - [sm_mod_len,      SyncManager.__module__.__len__,                    [],                           24,   "multiprocessing.managers.SyncManager.__module__.__len__() == 24; verified with Python 3.14.3"]
    - [sm_base_eq,      "SyncManager.__bases__[0].__name__.__eq__",        ["BaseManager"],              true, "multiprocessing.managers.SyncManager.__bases__[0].__name__ == 'BaseManager'; verified with Python 3.14.3"]
    - [sm_base_len,     "SyncManager.__bases__[0].__name__.__len__",       [],                           11,   "multiprocessing.managers.SyncManager.__bases__[0].__name__.__len__() == 11; verified with Python 3.14.3"]
    - [sm_start_name,   SyncManager.start.__name__.__eq__,                 ["start"],                    true, "multiprocessing.managers.SyncManager.start.__name__ == 'start'; verified with Python 3.14.3"]
    - [sm_start_qual,   SyncManager.start.__qualname__.__eq__,             ["BaseManager.start"],        true, "multiprocessing.managers.SyncManager.start.__qualname__ == 'BaseManager.start' (inherited); verified with Python 3.14.3"]
    - [sm_start_qlen,   SyncManager.start.__qualname__.__len__,            [],                           17,   "multiprocessing.managers.SyncManager.start.__qualname__.__len__() == 17; verified with Python 3.14.3"]

