    - [bm_start_qual_len,  BaseManager.start.__qualname__.__len__, [],                           17,   "BaseManager.start.__qualname__.__len__() == 17; verified with Python 3.14.3"]
    - [bm_start_mod_eq,    BaseManager.start.__module__.__eq__,    ["multiprocessing.managers"], true, "BaseManager.start.__module__ == 'multiprocessing.managers'; verified with Python 3.14.3"]
    - [bm_conn_name_eq,    BaseManager.connect.__name__.__eq__,    ["connect"],                  true, "BaseManager.connect.__name__ == 'connect'; verified with Python 3.14.3"]
    - [bm_conn_name_len,   BaseManager.connect.__name__.__len__,   [],                           7,    "BaseManager.connect.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [bm_conn_qual_eq,    BaseManager.connect.__qualname__.__eq__, ["BaseManager.connect"],     true, "BaseManager.connect.__qualname__ == 'BaseManager.connect'; verified with Python 3.14.3"]
    - [bm_conn_qual_len,   BaseManager.connect.__qualname__.__len__,[],                          19,   "BaseManager.connect.__qualname__.__len__() == 19; verified with Python 3.14.3"]
    - [bm_join_name_eq,    BaseManager.join.__name__.__eq__,       ["join"],                     true, "BaseManager.join.__name__ == 'join'; verified with Python 3.14.3"]
    - [bm_join_name_len,   BaseManager.join.__name__.__len__,      [],                           4,    "BaseManager.join.__name__.__len__() == 4; verified with Python 3.14.3"]
    - [bm_join_qual_eq,    BaseManager.join.__qualname__.__eq__,   ["BaseManager.join"],         true, "BaseManager.join.__qualname__ == 'BaseManager.join'; verified with Python 3.14.3"]
