# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra242
# ---------------------------------------------------------------------------

invariant multiprocessing_extra242.syncmanager_start_inherited:
  description: "multiprocessing.managers.SyncManager.start.__qualname__.__eq__('BaseManager.start') returns True — SyncManager inherits start from BaseManager without overriding it, so the qualname remains 'BaseManager.start'(len=17) not 'SyncManager.start'; this is similar to how ThreadPoolExecutor.map inherits qualname 'Executor.map'; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: SyncManager.start.__qualname__.__eq__
  args: ["BaseManager.start"]
  expected: true

invariant multiprocessing_extra242.basemanager_get_server_longest_qualname:
  description: "multiprocessing.managers.BaseManager.get_server.__qualname__.__len__() == 22 — 'BaseManager.get_server'(len=22) is the longest qualname in this spec; BaseManager.__init__.__qualname__ has len=20; BaseManager.connect.__qualname__ has len=19; BaseManager.start.__qualname__ has len=17; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: BaseManager.get_server.__qualname__.__len__
  args: []
  expected: 22
