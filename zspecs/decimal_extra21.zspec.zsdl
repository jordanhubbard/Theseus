spec: decimal_extra21
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec extends decimal_extra through decimal_extra20."
    - "decimal_extra20 covers signal exception __qualname__.__eq__ and rounding-mode string constants."
    - "No prior spec covers __qualname__ for Decimal class methods (from_float, sqrt, ln, log10, exp, __add__, __mul__, __str__)."
    - "All Decimal class methods are top-level inside the Decimal class; __qualname__ takes the form 'Decimal.<method>'."
    - "Focus: decimal.Decimal class method __qualname__ values verified via __qualname__.__eq__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal class method __qualname__ values
#
# Prior specs (decimal_extra through decimal_extra20) cover __qualname__ for
# the Decimal and Context classes themselves and for the signal exception
# classes.  No prior spec records __qualname__ for individual Decimal methods
# (from_float, sqrt, ln, log10, exp, __add__, __mul__, __str__).
# For all methods defined directly on Decimal the qualname is 'Decimal.<name>'.
# ---------------------------------------------------------------------------

table decimal_extra21.method_qualnames:
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [from_float, Decimal.from_float.__qualname__.__eq__, ["Decimal.from_float"], true, "Decimal.from_float.__qualname__ == 'Decimal.from_float'"]
    - [sqrt,       Decimal.sqrt.__qualname__.__eq__,       ["Decimal.sqrt"],       true, "Decimal.sqrt.__qualname__ == 'Decimal.sqrt'"]
    - [ln,         Decimal.ln.__qualname__.__eq__,         ["Decimal.ln"],         true, "Decimal.ln.__qualname__ == 'Decimal.ln'"]
    - [log10,      Decimal.log10.__qualname__.__eq__,      ["Decimal.log10"],      true, "Decimal.log10.__qualname__ == 'Decimal.log10'"]
    - [exp,        Decimal.exp.__qualname__.__eq__,        ["Decimal.exp"],        true, "Decimal.exp.__qualname__ == 'Decimal.exp'"]
    - [add,        Decimal.__add__.__qualname__.__eq__,    ["Decimal.__add__"],    true, "Decimal.__add__.__qualname__ == 'Decimal.__add__'"]
    - [mul,        Decimal.__mul__.__qualname__.__eq__,    ["Decimal.__mul__"],    true, "Decimal.__mul__.__qualname__ == 'Decimal.__mul__'"]
    - [str,        Decimal.__str__.__qualname__.__eq__,    ["Decimal.__str__"],    true, "Decimal.__str__.__qualname__ == 'Decimal.__str__'"]

# ---------------------------------------------------------------------------
# Method __qualname__ length invariants
#
# Length invariants confirm exact spelling and that no nesting prefix appears.
# ---------------------------------------------------------------------------

invariant decimal_extra21.from_float.qualname_len:
  description: "len(decimal.Decimal.from_float.__qualname__) == 20 — 'Decimal.from_float' is 18 chars"
  category: method_identity
  kind: python_call_eq
  function: Decimal.from_float.__qualname__.__len__
  args: []
  expected: 18

invariant decimal_extra21.sqrt.qualname_len:
  description: "len(decimal.Decimal.sqrt.__qualname__) == 12 — 'Decimal.sqrt' is 12 chars"
  category: method_identity
  kind: python_call_eq
  function: Decimal.sqrt.__qualname__.__len__
  args: []
  expected: 12

invariant decimal_extra21.ln.qualname_len:
  description: "len(decimal.Decimal.ln.__qualname__) == 10 — 'Decimal.ln' is 10 chars"
  category: method_identity
  kind: python_call_eq
  function: Decimal.ln.__qualname__.__len__
  args: []
  expected: 10

invariant decimal_extra21.log10.qualname_len:
  description: "len(decimal.Decimal.log10.__qualname__) == 13 — 'Decimal.log10' is 13 chars"
  category: method_identity
  kind: python_call_eq
  function: Decimal.log10.__qualname__.__len__
  args: []
  expected: 13

invariant decimal_extra21.exp.qualname_len:
  description: "len(decimal.Decimal.exp.__qualname__) == 11 — 'Decimal.exp' is 11 chars"
  category: method_identity
  kind: python_call_eq
  function: Decimal.exp.__qualname__.__len__
  args: []
  expected: 11
