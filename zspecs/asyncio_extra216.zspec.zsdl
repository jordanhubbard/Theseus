spec: asyncio_extra216
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks documentation"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queues"
    - "https://docs.python.org/3/library/asyncio-subprocess.html — asyncio Subprocess"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/subprocess.py"
  notes:
    - "asyncio.FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED are plain str values."
    - "asyncio.FIRST_COMPLETED == 'FIRST_COMPLETED'; len == 15."
    - "asyncio.FIRST_EXCEPTION == 'FIRST_EXCEPTION'; len == 15."
    - "asyncio.ALL_COMPLETED == 'ALL_COMPLETED'; len == 13."
    - "asyncio.Queue(maxsize=5).maxsize == 5 (int); asyncio.Queue().maxsize == 0."
    - "asyncio.subprocess.PIPE == -1, STDOUT == -2, DEVNULL == -3 (all int)."
    - "asyncio.iscoroutinefunction.__module__ == 'asyncio.coroutines'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio module-level wait constants — extra216 namespace
#
# asyncio.FIRST_COMPLETED, FIRST_EXCEPTION, and ALL_COMPLETED are plain str
# objects used as sentinel values for asyncio.wait(return_when=...).
# ---------------------------------------------------------------------------

table asyncio_extra216.wait_constants_eq:
  description: "asyncio wait-constant string equality checks in extra216 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio216waitconst

  columns: [id, function, args, expected, description]
  rows:
    - [first_completed_eq,  FIRST_COMPLETED.__eq__,  ["FIRST_COMPLETED"],  true,  "asyncio.FIRST_COMPLETED == 'FIRST_COMPLETED'"]
    - [first_exception_eq,  FIRST_EXCEPTION.__eq__,  ["FIRST_EXCEPTION"],  true,  "asyncio.FIRST_EXCEPTION == 'FIRST_EXCEPTION'"]
    - [all_completed_eq,    ALL_COMPLETED.__eq__,    ["ALL_COMPLETED"],    true,  "asyncio.ALL_COMPLETED == 'ALL_COMPLETED'"]

# ---------------------------------------------------------------------------
# asyncio wait-constant type and class name — extra216 namespace
#
# All three constants are plain str instances; __class__.__name__ == 'str'.
# ---------------------------------------------------------------------------

table asyncio_extra216.wait_constants_type:
  description: "asyncio wait-constant __class__.__name__ checks in extra216 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio216waittype

  columns: [id, function, args, expected, description]
  rows:
    - [first_completed_type,  FIRST_COMPLETED.__class__.__name__.__eq__,  ["str"],  true,  "asyncio.FIRST_COMPLETED is a plain str"]
    - [first_exception_type,  FIRST_EXCEPTION.__class__.__name__.__eq__,  ["str"],  true,  "asyncio.FIRST_EXCEPTION is a plain str"]
    - [all_completed_type,    ALL_COMPLETED.__class__.__name__.__eq__,    ["str"],  true,  "asyncio.ALL_COMPLETED is a plain str"]

# ---------------------------------------------------------------------------
# asyncio wait-constant length — extra216 namespace
#
# FIRST_COMPLETED and FIRST_EXCEPTION each have 15 characters; ALL_COMPLETED
# has 13 characters.
# ---------------------------------------------------------------------------

table asyncio_extra216.wait_constants_len:
  description: "asyncio wait-constant len() checks in extra216 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio216waitlen

  columns: [id, function, args, expected, description]
  rows:
    - [first_completed_len,  FIRST_COMPLETED.__len__,  [],  15,  "len(asyncio.FIRST_COMPLETED) == 15"]
    - [first_exception_len,  FIRST_EXCEPTION.__len__,  [],  15,  "len(asyncio.FIRST_EXCEPTION) == 15"]
    - [all_completed_len,    ALL_COMPLETED.__len__,    [],  13,  "len(asyncio.ALL_COMPLETED) == 13"]

# ---------------------------------------------------------------------------
# asyncio.subprocess constants — extra216 namespace
#
# asyncio.subprocess.PIPE == -1, STDOUT == -2, DEVNULL == -3, all int.
# These mirror the values of the standard subprocess module sentinels.
# ---------------------------------------------------------------------------

table asyncio_extra216.subprocess_constants:
  description: "asyncio.subprocess sentinel constant value checks in extra216 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio216subproc

  columns: [id, function, args, expected, description]
  rows:
    - [pipe_value,    subprocess.PIPE.__eq__,    [-1],  true,  "asyncio.subprocess.PIPE == -1"]
    - [stdout_value,  subprocess.STDOUT.__eq__,  [-2],  true,  "asyncio.subprocess.STDOUT == -2"]
    - [devnull_value, subprocess.DEVNULL.__eq__,  [-3],  true,  "asyncio.subprocess.DEVNULL == -3"]

# ---------------------------------------------------------------------------
# asyncio.subprocess constant class names — extra216 namespace
# ---------------------------------------------------------------------------

table asyncio_extra216.subprocess_constant_types:
  description: "asyncio.subprocess constant __class__.__name__ checks in extra216 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio216subproctype

  columns: [id, function, args, expected, description]
  rows:
    - [pipe_type,    subprocess.PIPE.__class__.__name__.__eq__,    ["int"],  true,  "asyncio.subprocess.PIPE is int"]
    - [stdout_type,  subprocess.STDOUT.__class__.__name__.__eq__,  ["int"],  true,  "asyncio.subprocess.STDOUT is int"]
    - [devnull_type, subprocess.DEVNULL.__class__.__name__.__eq__,  ["int"],  true,  "asyncio.subprocess.DEVNULL is int"]

# ---------------------------------------------------------------------------
# asyncio.iscoroutinefunction module — extra216 namespace
#
# asyncio.iscoroutinefunction lives in asyncio.coroutines.
# ---------------------------------------------------------------------------

invariant asyncio_extra216.iscoroutinefunction_module:
  description: "asyncio.iscoroutinefunction.__module__ == 'asyncio.coroutines'"
  category: identity
  kind: python_call_eq
  function: asyncio.iscoroutinefunction.__module__.__eq__
  args: ["asyncio.coroutines"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.FIRST_COMPLETED __eq__ standalone — extra216 namespace
# ---------------------------------------------------------------------------

invariant asyncio_extra216.FIRST_COMPLETED_eq:
  description: "asyncio.FIRST_COMPLETED.__eq__('FIRST_COMPLETED') returns True"
  category: identity
  kind: python_call_eq
  function: asyncio.FIRST_COMPLETED.__eq__
  args: ["FIRST_COMPLETED"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.ALL_COMPLETED __eq__ standalone — extra216 namespace
# ---------------------------------------------------------------------------

invariant asyncio_extra216.ALL_COMPLETED_eq:
  description: "asyncio.ALL_COMPLETED.__eq__('ALL_COMPLETED') returns True"
  category: identity
  kind: python_call_eq
  function: asyncio.ALL_COMPLETED.__eq__
  args: ["ALL_COMPLETED"]
  expected: true

