spec: struct_extra2776
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra2761.zspec.zsdl — covers __matmul__, __truediv__, and __iadd__ absence for Struct, struct.error."
    - "struct_extra2746.zspec.zsdl — covers __imatmul__, __ifloordiv__, __imod__ absence for Struct, struct.error."
    - "decimal_extra204.zspec.zsdl — covers decimal.Decimal __dict__ membership for arithmetic dunders; same dict-presence pattern."
  notes:
    - "struct.Struct.__dict__.__contains__('__isub__') == False — struct.Struct is a binary format descriptor; it defines no in-place subtraction operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.Struct.__dict__.__contains__('__imul__') == False — struct.Struct defines no in-place multiplication operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.Struct.__dict__.__contains__('__itruediv__') == False — struct.Struct defines no in-place true division operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.error.__dict__.__contains__('__isub__') == False — struct.error is an Exception subclass; exception types never define in-place subtraction; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.error.__dict__.__contains__('__imul__') == False — struct.error defines no in-place multiplication operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.error.__dict__.__contains__('__itruediv__') == False — struct.error defines no in-place true division operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: struct.Struct.__dict__ — __isub__, __imul__, __itruediv__ absence
# struct.Struct is the compiled format object returned by struct.Struct(fmt).
# It exposes pack/unpack/pack_into/unpack_from/iter_unpack methods and the
# size/format attributes. In-place arithmetic operators (-=, *=, /=) are
# undefined for a binary format descriptor.
# ---------------------------------------------------------------------------

table struct_extra2776.struct_dict_isub_imul_itruediv:
  description: "struct.Struct.__dict__ does not contain __isub__, __imul__, or __itruediv__ — Struct is a binary format descriptor, not a numeric type; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2776

  columns: [id, function, args, expected]
  rows:
    - ["st2776-struct-isub",     struct.Struct.__dict__.__contains__,  ["__isub__"],     false]
    - ["st2776-struct-imul",     struct.Struct.__dict__.__contains__,  ["__imul__"],     false]
    - ["st2776-struct-itruediv", struct.Struct.__dict__.__contains__,  ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# Table 2: struct.error.__dict__ — __isub__, __imul__, __itruediv__ absence
# struct.error is a subclass of Exception raised on pack/unpack failures.
# Exception types never define in-place arithmetic operators in their own __dict__.
# ---------------------------------------------------------------------------

table struct_extra2776.error_dict_isub_imul_itruediv:
  description: "struct.error.__dict__ does not contain __isub__, __imul__, or __itruediv__ — struct.error is an Exception subclass; exception types define no in-place arithmetic operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2776

  columns: [id, function, args, expected]
  rows:
    - ["st2776-error-isub",     struct.error.__dict__.__contains__,  ["__isub__"],     false]
    - ["st2776-error-imul",     struct.error.__dict__.__contains__,  ["__imul__"],     false]
    - ["st2776-error-itruediv", struct.error.__dict__.__contains__,  ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# Table 3: struct.Struct.__dict__ — per-dunder detail with descriptions
# ---------------------------------------------------------------------------

table struct_extra2776.struct_dict_detail:
  description: "struct.Struct.__dict__ in-place operator absence detail — __isub__, __imul__, and __itruediv__ are not defined because Struct is a packing/unpacking tool, not a numeric operand; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2776

  columns: [id, function, args, expected, description]
  rows:
    - ["st2776-d-isub",     struct.Struct.__dict__.__contains__, ["__isub__"],     false, "struct.Struct does not support -= — binary format descriptors have no subtraction semantics"]
    - ["st2776-d-imul",     struct.Struct.__dict__.__contains__, ["__imul__"],     false, "struct.Struct does not support *= — multiplying a format descriptor has no defined meaning"]
    - ["st2776-d-itruediv", struct.Struct.__dict__.__contains__, ["__itruediv__"], false, "struct.Struct does not support /= — division is undefined for a binary format descriptor"]

# ---------------------------------------------------------------------------
# Table 4: cross-type summary — Struct and error both lack all three dunders
# ---------------------------------------------------------------------------

table struct_extra2776.all_types_all_dunders_absent:
  description: "struct.Struct and struct.error both lack __isub__, __imul__, and __itruediv__ in __dict__ — neither struct type defines in-place arithmetic operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2776

  columns: [id, function, args, expected]
  rows:
    - ["st2776-x-struct-isub",     struct.Struct.__dict__.__contains__, ["__isub__"],     false]
    - ["st2776-x-struct-imul",     struct.Struct.__dict__.__contains__, ["__imul__"],     false]
    - ["st2776-x-struct-itruediv", struct.Struct.__dict__.__contains__, ["__itruediv__"], false]
    - ["st2776-x-error-isub",      struct.error.__dict__.__contains__,  ["__isub__"],     false]
    - ["st2776-x-error-imul",      struct.error.__dict__.__contains__,  ["__imul__"],     false]
    - ["st2776-x-error-itruediv",  struct.error.__dict__.__contains__,  ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant struct_extra2776.struct_no_isub:
  description: "struct.Struct.__dict__.__contains__('__isub__') == False — struct.Struct does not define the -= operator; it is a binary packing/unpacking tool with no numeric semantics; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["__isub__"]
  expected: false

invariant struct_extra2776.struct_no_imul:
  description: "struct.Struct.__dict__.__contains__('__imul__') == False — struct.Struct does not define the *= operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["__imul__"]
  expected: false

invariant struct_extra2776.struct_no_itruediv:
  description: "struct.Struct.__dict__.__contains__('__itruediv__') == False — struct.Struct does not define the /= operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["__itruediv__"]
  expected: false

invariant struct_extra2776.error_no_isub:
  description: "struct.error.__dict__.__contains__('__isub__') == False — struct.error (Exception subclass) does not define the -= operator; exception types carry no arithmetic semantics; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.error.__dict__.__contains__
  args: ["__isub__"]
  expected: false

invariant struct_extra2776.error_no_imul:
  description: "struct.error.__dict__.__contains__('__imul__') == False — struct.error does not define the *= operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.error.__dict__.__contains__
  args: ["__imul__"]
  expected: false

invariant struct_extra2776.error_no_itruediv:
  description: "struct.error.__dict__.__contains__('__itruediv__') == False — struct.error does not define the /= operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.error.__dict__.__contains__
  args: ["__itruediv__"]
