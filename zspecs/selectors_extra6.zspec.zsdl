spec: selectors_extra6
version: ">=3.9"
backend: python_module(selectors)

docs: https://docs.python.org/3/library/selectors.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/selectors.html — Python selectors module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/selectors.py"
  notes:
    - "Extends selectors.zspec.zsdl through selectors_extra5.zspec.zsdl."
    - "selectors_extra4 covers: __qualname__ for SelectSelector/KqueueSelector/PollSelector/BaseSelector/SelectorKey/DefaultSelector (class-level)."
    - "selectors_extra5 covers: BaseSelector/SelectSelector/KqueueSelector __mro__ lengths; KqueueSelector.__module__; SelectorKey base; EVENT_READ XOR/ADD."
    - "This spec adds: __qualname__ for BaseSelector instance methods register/unregister/select/close/get_map/get_key — no prior selectors spec checks method-level __qualname__ for any of these; SelectSelector method __qualname__ for register/unregister/select; KqueueSelector method __qualname__ for register/unregister/select."
    - "BaseSelector.register.__qualname__ == 'BaseSelector.register' — abstract method defined on the base class."
    - "BaseSelector.unregister.__qualname__ == 'BaseSelector.unregister' — abstract method."
    - "BaseSelector.select.__qualname__ == 'BaseSelector.select' — abstract method."
    - "BaseSelector.close.__qualname__ == 'BaseSelector.close' — concrete method on the base class."
    - "BaseSelector.get_map.__qualname__ == 'BaseSelector.get_map' — abstract method."
    - "BaseSelector.get_key.__qualname__ == 'BaseSelector.get_key' — concrete helper method."
    - "SelectSelector.register.__qualname__ == 'SelectSelector.register' — overrides base."
    - "SelectSelector.unregister.__qualname__ == 'SelectSelector.unregister' — inherits from _BaseSelectorImpl."
    - "SelectSelector.select.__qualname__ == 'SelectSelector.select' — concrete implementation."
    - "KqueueSelector.register.__qualname__ == 'KqueueSelector.register' — overrides base."
    - "KqueueSelector.unregister.__qualname__ == 'KqueueSelector.unregister' — inherits from _BaseSelectorImpl."
    - "KqueueSelector.select.__qualname__ == 'KqueueSelector.select' — concrete implementation."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BaseSelector method __qualname__ attributes
#
# No prior selectors spec checks __qualname__ for any method on any selector
# class. BaseSelector defines abstract and concrete methods whose __qualname__
# follows the 'ClassName.method_name' pattern for class-level definitions.
# ---------------------------------------------------------------------------

table selectors_extra6.BaseSelector_method_qualnames:
  description: "BaseSelector method __qualname__ values — none covered in any prior selectors spec"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: bsqname

  columns: [id, function, args, expected]
  rows:
    - [register,   "BaseSelector.register.__qualname__.__eq__",   ["BaseSelector.register"],   true]
    - [unregister, "BaseSelector.unregister.__qualname__.__eq__", ["BaseSelector.unregister"], true]
    - [select,     "BaseSelector.select.__qualname__.__eq__",     ["BaseSelector.select"],     true]
    - [close,      "BaseSelector.close.__qualname__.__eq__",      ["BaseSelector.close"],      true]
    - [get_map,    "BaseSelector.get_map.__qualname__.__eq__",    ["BaseSelector.get_map"],    true]
    - [get_key,    "BaseSelector.get_key.__qualname__.__eq__",    ["BaseSelector.get_key"],    true]

# ---------------------------------------------------------------------------
# SelectSelector method __qualname__ attributes
#
# No prior selectors spec checks method-level __qualname__ for SelectSelector.
# register and select are overridden directly on SelectSelector; unregister
# is inherited from _BaseSelectorImpl but still has SelectSelector.unregister
# as its __qualname__ on macOS Python 3.12.
# ---------------------------------------------------------------------------

table selectors_extra6.SelectSelector_method_qualnames:
  description: "SelectSelector method __qualname__ values — no prior spec covers method-level qualnames"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: ssqname

  columns: [id, function, args, expected]
  rows:
    - [register,   "SelectSelector.register.__qualname__.__eq__",   ["SelectSelector.register"],   true]
    - [unregister, "SelectSelector.unregister.__qualname__.__eq__", ["SelectSelector.unregister"], true]
    - [select,     "SelectSelector.select.__qualname__.__eq__",     ["SelectSelector.select"],     true]

# ---------------------------------------------------------------------------
# KqueueSelector method __qualname__ attributes
#
# No prior selectors spec checks method-level __qualname__ for KqueueSelector.
# register and select are overridden; unregister is from _BaseSelectorImpl.
# ---------------------------------------------------------------------------

table selectors_extra6.KqueueSelector_method_qualnames:
  description: "KqueueSelector method __qualname__ values — no prior spec covers method-level qualnames"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: kqsqname

  columns: [id, function, args, expected]
  rows:
    - [register,   "KqueueSelector.register.__qualname__.__eq__",   ["KqueueSelector.register"],   true]
    - [unregister, "KqueueSelector.unregister.__qualname__.__eq__", ["KqueueSelector.unregister"], true]
    - [select,     "KqueueSelector.select.__qualname__.__eq__",     ["KqueueSelector.select"],     true]
