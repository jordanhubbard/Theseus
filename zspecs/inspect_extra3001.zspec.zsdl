spec: in3001
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 647 (in3001): __getitem__, __setitem__, __delitem__ dict-presence checks for inspect types."
    - "inspect types are introspection helpers — none define item access or mutation operators."
    - "inspect.BoundArguments exposes an 'arguments' attribute (an OrderedDict) but does not itself define __getitem__."
    - "inspect.Signature supports parameter iteration but does not define __getitem__ for key-based access."
    - "Verified types: inspect.Parameter, inspect.BoundArguments, inspect.Signature, inspect.FullArgSpec, inspect.FrameInfo, inspect.ArgInfo, inspect.Traceback, inspect.ClosureVars."
    - "inspect.FullArgSpec, inspect.FrameInfo, inspect.ArgInfo, inspect.Traceback, and inspect.ClosureVars are namedtuple subclasses."
    - "inspect.Parameter, inspect.BoundArguments, and inspect.Signature are pure Python classes."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3001.getitem:
  description: "inspect types __getitem__ dict-presence checks; wave 647"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in3001
  columns: [id, function, args, expected]
  rows:
    - ["in3001001", operator.contains, [inspect.Parameter.__dict__,       "__getitem__"], false]
    - ["in3001002", operator.contains, [inspect.BoundArguments.__dict__,  "__getitem__"], false]
    - ["in3001003", operator.contains, [inspect.Signature.__dict__,       "__getitem__"], false]
    - ["in3001004", operator.contains, [inspect.FullArgSpec.__dict__,     "__getitem__"], false]
    - ["in3001005", operator.contains, [inspect.FrameInfo.__dict__,       "__getitem__"], false]
    - ["in3001006", operator.contains, [inspect.ArgInfo.__dict__,         "__getitem__"], false]

