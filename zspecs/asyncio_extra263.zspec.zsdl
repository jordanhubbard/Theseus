spec: asyncio_extra263
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/events.py"
    - "CPython source: Lib/asyncio/base_events.py"
  notes:
    - "AbstractServer is defined in asyncio.events and is a pure Python abstract base class inheriting from object."
    - "Server is defined in asyncio.base_events and inherits from AbstractServer."
    - "Handle and TimerHandle are both defined in asyncio.events."
    - "Handle inherits from object; TimerHandle inherits from Handle."
    - "Handle.cancel and Handle.cancelled qualnames use the 'Handle.' prefix."
    - "TimerHandle.cancel overrides Handle.cancel; its qualname is 'TimerHandle.cancel'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# AbstractServer — class identity
#
# asyncio.AbstractServer is a pure-Python ABC defined in asyncio.events.
# It inherits from object (no other bases).
# ---------------------------------------------------------------------------

invariant asyncio_extra263.abstract_server.name:
  description: "asyncio.AbstractServer.__name__ == 'AbstractServer'"
  category: identity
  kind: python_call_eq
  function: AbstractServer.__name__.__eq__
  args: ["AbstractServer"]
  expected: true

invariant asyncio_extra263.abstract_server.module:
  description: "asyncio.AbstractServer.__module__ == 'asyncio.events'"
  category: identity
  kind: python_call_eq
  function: AbstractServer.__module__.__eq__
  args: ["asyncio.events"]
  expected: true

invariant asyncio_extra263.abstract_server.base:
  description: "asyncio.AbstractServer.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: AbstractServer.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Server — class identity
#
# asyncio.Server is defined in asyncio.base_events and inherits from
# AbstractServer.
# ---------------------------------------------------------------------------

invariant asyncio_extra263.server.name:
  description: "asyncio.Server.__name__ == 'Server'"
  category: identity
  kind: python_call_eq
  function: Server.__name__.__eq__
  args: ["Server"]
  expected: true

invariant asyncio_extra263.server.module:
  description: "asyncio.Server.__module__ == 'asyncio.base_events'"
  category: identity
  kind: python_call_eq
  function: Server.__module__.__eq__
  args: ["asyncio.base_events"]
  expected: true

invariant asyncio_extra263.server.base:
  description: "asyncio.Server.__bases__[0].__name__ == 'AbstractServer'"
  category: identity
  kind: python_call_eq
  function: Server.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "AbstractServer"

# ---------------------------------------------------------------------------
# Handle — class identity and method qualnames
#
# asyncio.Handle is defined in asyncio.events and inherits from object.
# cancel() and cancelled() are instance methods; their qualnames use the
# 'Handle.' prefix.
# ---------------------------------------------------------------------------

invariant asyncio_extra263.handle.name:
  description: "asyncio.Handle.__name__ == 'Handle'"
  category: identity
  kind: python_call_eq
  function: Handle.__name__.__eq__
  args: ["Handle"]
  expected: true

invariant asyncio_extra263.handle.module:
  description: "asyncio.Handle.__module__ == 'asyncio.events'"
  category: identity
  kind: python_call_eq
  function: Handle.__module__.__eq__
  args: ["asyncio.events"]
  expected: true

invariant asyncio_extra263.handle.base:
  description: "asyncio.Handle.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: Handle.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant asyncio_extra263.handle.cancel_qualname:
  description: "asyncio.Handle.cancel.__qualname__ == 'Handle.cancel'"
  category: identity
  kind: python_call_eq
  function: Handle.cancel.__qualname__.__eq__
  args: ["Handle.cancel"]
  expected: true

invariant asyncio_extra263.handle.cancelled_qualname:
  description: "asyncio.Handle.cancelled.__qualname__ == 'Handle.cancelled'"
  category: identity
  kind: python_call_eq
  function: Handle.cancelled.__qualname__.__eq__
  args: ["Handle.cancelled"]
  expected: true

# ---------------------------------------------------------------------------
# TimerHandle — class identity
#
# asyncio.TimerHandle is defined in asyncio.events and inherits from Handle.
# TimerHandle.cancel overrides Handle.cancel; its qualname is
# 'TimerHandle.cancel'.
# ---------------------------------------------------------------------------

invariant asyncio_extra263.timer_handle.name:
  description: "asyncio.TimerHandle.__name__ == 'TimerHandle'"
  category: identity
  kind: python_call_eq
  function: TimerHandle.__name__.__eq__
  args: ["TimerHandle"]
  expected: true

invariant asyncio_extra263.timer_handle.module:
  description: "asyncio.TimerHandle.__module__ == 'asyncio.events'"
  category: identity
  kind: python_call_eq
  function: TimerHandle.__module__.__eq__
  args: ["asyncio.events"]
  expected: true

invariant asyncio_extra263.timer_handle.base:
  description: "asyncio.TimerHandle.__bases__[0].__name__ == 'Handle'"
  category: identity
  kind: python_call_eq
  function: TimerHandle.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Handle"

invariant asyncio_extra263.timer_handle.cancel_qualname:
  description: "asyncio.TimerHandle.cancel.__qualname__ == 'TimerHandle.cancel' — overrides Handle.cancel"
  category: identity
  kind: python_call_eq
  function: TimerHandle.cancel.__qualname__.__eq__
  args: ["TimerHandle.cancel"]
  expected: true
