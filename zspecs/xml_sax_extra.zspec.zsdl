spec: xml_sax_extra
version: ">=3.0"
backend: python_module(xml.sax)

docs: https://docs.python.org/3/library/xml.sax.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/xml.sax.html — Python xml.sax documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/xml/sax/__init__.py"
  notes:
    - "This spec extends xml_sax.zspec.zsdl."
    - "xml_sax.zspec.zsdl covers __name__ for make_parser, parse, parseString, handler classes, and exception classes."
    - "This spec adds __qualname__ checks for functions and handler classes, and __module__ checks for top-level functions."
    - "For module-level functions: parse.__qualname__ == 'parse', parseString.__qualname__ == 'parseString', make_parser.__qualname__ == 'make_parser'."
    - "For handler base classes (in xml.sax.handler submodule, re-exported to xml.sax): ContentHandler.__qualname__ == 'ContentHandler', etc."
    - "parse.__module__ == 'xml.sax' — all three top-level functions are defined directly in xml.sax."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for top-level functions
# ---------------------------------------------------------------------------

table xml_sax_extra.function_qualnames:
  kind: python_call_eq
  category: functions
  id_prefix: fqname

  columns: [id, function, args, expected]
  rows:
    - [parse,       parse.__qualname__.__eq__,       ["parse"],       true]
    - [parseString, parseString.__qualname__.__eq__,  ["parseString"], true]
    - [make_parser, make_parser.__qualname__.__eq__,  ["make_parser"], true]

# ---------------------------------------------------------------------------
# __qualname__ checks for handler base classes
# ---------------------------------------------------------------------------

table xml_sax_extra.handler_class_qualnames:
  kind: python_call_eq
  category: classes
  id_prefix: hqname

  columns: [id, function, args, expected]
  rows:
    - [contenthandler,  ContentHandler.__qualname__.__eq__,  ["ContentHandler"],  true]
    - [errorhandler,    ErrorHandler.__qualname__.__eq__,    ["ErrorHandler"],    true]
    - [dtdhandler,      DTDHandler.__qualname__.__eq__,      ["DTDHandler"],      true]
    - [entityresolver,  EntityResolver.__qualname__.__eq__,  ["EntityResolver"],  true]

# ---------------------------------------------------------------------------
# __qualname__ checks for exception classes
# ---------------------------------------------------------------------------

table xml_sax_extra.exception_class_qualnames:
  kind: python_call_eq
  category: classes
  id_prefix: eqname

  columns: [id, function, args, expected]
  rows:
    - [saxexception,       SAXException.__qualname__.__eq__,       ["SAXException"],       true]
    - [saxparseexception,  SAXParseException.__qualname__.__eq__,  ["SAXParseException"],  true]

# ---------------------------------------------------------------------------
# __module__ checks for top-level functions
# (xml_sax.zspec.zsdl covers __module__.startswith for exception classes;
#  this spec adds exact __module__ == 'xml.sax' for the top-level functions.)
# ---------------------------------------------------------------------------

table xml_sax_extra.function_modules:
  kind: python_call_eq
  category: functions
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [parse,       parse.__module__.__eq__,       ["xml.sax"], true]
    - [parseString, parseString.__module__.__eq__,  ["xml.sax"], true]
    - [make_parser, make_parser.__module__.__eq__,  ["xml.sax"], true]
