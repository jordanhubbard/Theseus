spec: etag
version: ">=1.0.0"
backend: node(etag)

docs: https://github.com/jshttp/etag#readme

provenance:
  derived_from:
    - "etag README — https://github.com/jshttp/etag#readme"
    - "RFC 7232 — HTTP/1.1 Conditional Requests — ETag format"
    - "Test vectors verified with etag@1.8.1 via Node.js 25.6.0 on macOS/Darwin 25.4.0, 2026-04-09"
    - "etag source: index.js (MIT; source inspection permitted)"
  not_derived_from:
    - "etag source: internal SHA1 hash implementation"
  notes:
    - "etag(entity, [options]) returns a quoted ETag string. The format is \"<hex-length>-<base64url-sha1>\"."
    - "String entities are hashed using length (hex) + SHA1 (base64url). Buffer entities use the same scheme."
    - "Weak ETags use W/ prefix followed by a quoted hash: W/\"...\". Strong ETags are just a quoted hash."
    - "etag('') returns the ETag for an empty string (length 0, SHA1 of empty string)."
    - "The module exports a single function as the CJS default export. Invariants use function: ~ to call it directly."
    - "ETag values are deterministic content hashes and are pinned exactly."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "etag does not throw for string or Buffer inputs. node exits 0 for all invariants."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# etag(entity) — strong ETags (default, no options)
# ---------------------------------------------------------------------------

table etag.strong:
  kind: node_module_call_eq
  function: ~
  id_prefix: strong

  columns: [id, category, args, expected]
  rows:
    - [empty,       empty,   [""],                  "\"0-2jmj7l5rSw0yVb/vlWAYkK/YBwk\""]
    - [a,           single,  ["a"],                 "\"1-hvfkN/qlp/zhXR3cuerq6jd2Z7g\""]
    - [hello,       word,    ["hello"],             "\"5-qvTGHdzF6KLavt4PO0gs2a6pQ00\""]
    - [test,        word,    ["test"],              "\"4-qUqP5cyxm6YcTAhz05Hph5gvu9M\""]
    - [foo,         word,    ["foo"],               "\"3-C+7Hteo/D9vJXQ3UfzxbwnXaijM\""]
    - [bar,         word,    ["bar"],               "\"3-Ys23Ag/5IOWqZCw9QGaVDdHwH00\""]
    - [hello_world, phrase,  ["hello world"],       "\"b-Kq5sNclPz7QV2+lfQIuc6R7oRu0\""]
    - [digits,      numeric, ["1234"],              "\"4-cRDtpNCeBiql5KOQsKVyrA0sAiA\""]
    - [long_str,    long,    ["this is a longer test string for etag"], "\"25-3dDZBgaSHs/3PYXcITQIyR7F+2o\""]

# ---------------------------------------------------------------------------
# etag(entity, {weak: true}) — weak ETags
# ---------------------------------------------------------------------------

table etag.weak:
  kind: node_module_call_eq
  function: ~
  id_prefix: weak

  columns: [id, category, args, expected]
  rows:
    - [empty_weak,  empty,  ["", {"weak": true}],      "W/\"0-2jmj7l5rSw0yVb/vlWAYkK/YBwk\""]
    - [hello_weak,  word,   ["hello", {"weak": true}],  "W/\"5-qvTGHdzF6KLavt4PO0gs2a6pQ00\""]
    - [foo_weak,    word,   ["foo", {"weak": true}],    "W/\"3-C+7Hteo/D9vJXQ3UfzxbwnXaijM\""]
    - [bar_weak,    word,   ["bar", {"weak": true}],    "W/\"3-Ys23Ag/5IOWqZCw9QGaVDdHwH00\""]
