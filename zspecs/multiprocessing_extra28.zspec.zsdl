spec: multiprocessing_extra28
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "This spec extends multiprocessing_extra27.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', Process.__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() for Pool/Queue/Lock/Event/Semaphore/Barrier, Process method __qualname__.__len__() for start/run/join/terminate/is_alive, current_process __module__.__len__()."
    - "This spec covers: Process.kill.__qualname__.__len__(); Pool method __qualname__.__len__() for map/apply/close/terminate/join; Pool additional method __qualname__.__len__() for apply_async/map_async/starmap/imap; AuthenticationError.__bases__[0].__name__; ProcessError.__bases__[0].__name__; BufferTooShort.__bases__[0].__name__; exception __mro__.__len__() for AuthenticationError/ProcessError; Process.__mro__.__len__(); Pool.__mro__.__len__()."
    - "Process.kill.__qualname__ == 'BaseProcess.kill' — length 16 (inherited from BaseProcess)."
    - "Pool.map.__qualname__ == 'Pool.map' — length 8."
    - "Pool.apply.__qualname__ == 'Pool.apply' — length 10."
    - "Pool.close.__qualname__ == 'Pool.close' — length 10."
    - "Pool.terminate.__qualname__ == 'Pool.terminate' — length 14."
    - "Pool.join.__qualname__ == 'Pool.join' — length 9."
    - "Pool.apply_async.__qualname__ == 'Pool.apply_async' — length 16."
    - "Pool.map_async.__qualname__ == 'Pool.map_async' — length 14."
    - "Pool.starmap.__qualname__ == 'Pool.starmap' — length 12."
    - "Pool.imap.__qualname__ == 'Pool.imap' — length 9."
    - "AuthenticationError.__bases__[0].__name__ == 'ProcessError' — subclasses ProcessError."
    - "ProcessError.__bases__[0].__name__ == 'Exception' — direct subclass of Exception."
    - "BufferTooShort.__bases__[0].__name__ == 'ProcessError' — subclasses ProcessError."
    - "AuthenticationError.__mro__.__len__() == 5 — [AuthenticationError, ProcessError, Exception, BaseException, object]."
    - "ProcessError.__mro__.__len__() == 4 — [ProcessError, Exception, BaseException, object]."
    - "Process.__mro__.__len__() == 3 — [Process, BaseProcess, object]."
    - "Pool.__mro__.__len__() == 2 — [Pool, object]."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Pool method __qualname__ length table — extra28 namespace
#
# multiprocessing.pool.Pool methods carry 'Pool.' as their __qualname__
# prefix (Pool is defined directly, not inherited from a BaseContext).
# Core lifecycle methods:
#   Pool.map.__qualname__       == 'Pool.map'       (8)
#   Pool.apply.__qualname__     == 'Pool.apply'     (10)
#   Pool.close.__qualname__     == 'Pool.close'     (10)
#   Pool.terminate.__qualname__ == 'Pool.terminate' (14)
#   Pool.join.__qualname__      == 'Pool.join'      (9)
# No prior spec has measured __qualname__.__len__() for Pool instance methods.
# ---------------------------------------------------------------------------

table multiprocessing_extra28.pool_method_qualname_lengths:
  description: "multiprocessing Pool method __qualname__ lengths for map/apply/close/terminate/join in extra28 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: poolmqualnamelen28

  columns: [id, function, args, expected]
  rows:
    - [map,       Pool.map.__qualname__.__len__,       [], 8]
    - [apply,     Pool.apply.__qualname__.__len__,     [], 10]
    - [close,     Pool.close.__qualname__.__len__,     [], 10]
    - [terminate, Pool.terminate.__qualname__.__len__, [], 14]
    - [join,      Pool.join.__qualname__.__len__,      [], 9]

# ---------------------------------------------------------------------------
# Pool async/iter method __qualname__ length table — extra28 namespace
#
# Additional Pool methods for async and iterator dispatch:
#   Pool.apply_async.__qualname__ == 'Pool.apply_async' (16)
#   Pool.map_async.__qualname__   == 'Pool.map_async'   (14)
#   Pool.starmap.__qualname__     == 'Pool.starmap'     (12)
#   Pool.imap.__qualname__        == 'Pool.imap'        (9)
# ---------------------------------------------------------------------------

table multiprocessing_extra28.pool_async_method_qualname_lengths:
  description: "multiprocessing Pool async/iter method __qualname__ lengths for apply_async/map_async/starmap/imap in extra28 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: poolamqualnamelen28

  columns: [id, function, args, expected]
  rows:
    - [apply_async, Pool.apply_async.__qualname__.__len__, [], 16]
    - [map_async,   Pool.map_async.__qualname__.__len__,   [], 14]
    - [starmap,     Pool.starmap.__qualname__.__len__,     [], 12]
    - [imap,        Pool.imap.__qualname__.__len__,        [], 9]

# ---------------------------------------------------------------------------
# Exception __bases__[0].__name__ table — extra28 namespace
#
# multiprocessing exception hierarchy via __bases__[0].__name__:
#   AuthenticationError.__bases__[0].__name__ == 'ProcessError' — two-level hierarchy
#   ProcessError.__bases__[0].__name__         == 'Exception'    — direct Exception subclass
#   BufferTooShort.__bases__[0].__name__       == 'ProcessError' — same as AuthenticationError
# Both AuthenticationError and BufferTooShort sit at the same depth below
# ProcessError, while ProcessError itself is a direct Exception subclass.
# No prior spec measures __bases__[0].__name__ for these three exceptions.
# ---------------------------------------------------------------------------

table multiprocessing_extra28.exception_bases_names:
  description: "multiprocessing exception __bases__[0].__name__ for AuthenticationError/ProcessError/BufferTooShort in extra28 namespace"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: excbasename28

  columns: [id, function, args, expected]
  rows:
    - [AuthenticationError, "AuthenticationError.__bases__[0].__name__.__eq__", ["ProcessError"], true]
    - [ProcessError,        "ProcessError.__bases__[0].__name__.__eq__",        ["Exception"],    true]
    - [BufferTooShort,      "BufferTooShort.__bases__[0].__name__.__eq__",      ["ProcessError"], true]

# ---------------------------------------------------------------------------
# Class __mro__.__len__() table — extra28 namespace
#
# MRO depths for key multiprocessing classes:
#   Process.__mro__.__len__()           == 3 — [Process, BaseProcess, object]
#   Pool.__mro__.__len__()              == 2 — [Pool, object]
#   AuthenticationError.__mro__.__len__() == 5 — [AuthenticationError, ProcessError, Exception, BaseException, object]
#   ProcessError.__mro__.__len__()      == 4 — [ProcessError, Exception, BaseException, object]
# Process has depth 3 because it inherits from BaseProcess; Pool is flat
# (depth 2) because it inherits directly from object.
# ---------------------------------------------------------------------------

table multiprocessing_extra28.class_mro_lengths:
  description: "multiprocessing class __mro__.__len__() for Process/Pool/AuthenticationError/ProcessError in extra28 namespace"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: clsmrolen28

  columns: [id, function, args, expected, method, method_args, description]
  rows:
    - [Process,             Process.__mro__,             [], !ascii "", __len__, [], "Process MRO depth == 3"]
    - [Pool,                Pool.__mro__,                [], !ascii "", __len__, [], "Pool MRO depth == 2"]
    - [AuthenticationError, AuthenticationError.__mro__, [], !ascii "", __len__, [], "AuthenticationError MRO depth == 5"]
    - [ProcessError,        ProcessError.__mro__,        [], !ascii "", __len__, [], "ProcessError MRO depth == 4"]

# ---------------------------------------------------------------------------
# Process.kill qualname length — extra28 standalone invariant
#
# Process.kill.__qualname__ == 'BaseProcess.kill' (length 16) — the kill
# method, like all core Process methods, is inherited from BaseProcess.
# Prior spec (extra27) confirmed start/run/join/terminate/is_alive; this
# invariant adds kill to the verified set.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra28.Process.kill_qualname_len:
  description: "multiprocessing.Process.kill.__qualname__.__len__() == 16 — 'BaseProcess.kill' inherited from BaseProcess"
  category: method_names
  kind: python_call_eq
  function: Process.kill.__qualname__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# AuthenticationError.__bases__[0].__name__ string equality — extra28 standalone
#
# Confirms that AuthenticationError subclasses ProcessError (not Exception
# directly). This is the two-level structure: AuthenticationError →
# ProcessError → Exception → BaseException → object.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra28.AuthenticationError.base_name_eq:
  description: "multiprocessing.AuthenticationError.__bases__[0].__name__ == 'ProcessError' — subclasses ProcessError"
  category: class_hierarchy
  kind: python_call_eq
  function: AuthenticationError.__bases__[0].__name__.__eq__
  args: ["ProcessError"]
  expected: true

# ---------------------------------------------------------------------------
# ProcessError.__bases__[0].__name__ string equality — extra28 standalone
#
# Confirms that ProcessError is a direct Exception subclass, serving as the
# root of the multiprocessing exception hierarchy below Exception.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra28.ProcessError.base_name_eq:
  description: "multiprocessing.ProcessError.__bases__[0].__name__ == 'Exception' — ProcessError is the multiprocessing exception root"
  category: class_hierarchy
  kind: python_call_eq
  function: ProcessError.__bases__[0].__name__.__eq__
  args: ["Exception"]
  expected: true
