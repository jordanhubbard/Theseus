spec: concurrent_futures_extra9
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
  notes:
    - "This spec extends concurrent_futures.zspec.zsdl and prior extras through concurrent_futures_extra8.zspec.zsdl."
    - "extra8 covers: Future.__bases__[0]=='object'; Future.mro[1]=='object'; CancelledError/BrokenExecutor MRO[1] and MRO[2]; as_completed/wait __class__.__name__=='function'; FIRST_COMPLETED/__len__()==15; FIRST_EXCEPTION/__len__()==15; ALL_COMPLETED/__len__()==13."
    - "extra6 covers: __qualname__ for ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor/CancelledError/TimeoutError/BrokenExecutor/as_completed/wait; FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED __class__.__name__=='str'."
    - "base spec covers: Future.cancel/__name__; Future.result/__name__; Future.add_done_callback/__name__."
    - "This spec adds NEW axes:"
    - "  (1) Future additional method names: cancelled, running, done, exception, set_result — not in any prior spec."
    - "  (2) InvalidStateError.__qualname__, __module__, __bases__[0].__name__ — base spec has __name__ only."
    - "  (3) ThreadPoolExecutor and ProcessPoolExecutor __class__.__name__ == 'type' — metaclass type check not previously covered."
    - "  (4) as_completed and wait __qualname__ is covered in extra6; __name__ is covered in extra5. __class__.__name__ covered in extra8. New: as_completed.__class__.__name__ already covered — instead check ThreadPoolExecutor.__mro__[2].__name__ == 'object' (MRO depth 2 for executors — MRO[1] is Executor, MRO[2] is object)."
    - "concurrent.futures.Future.cancelled.__name__ == 'cancelled'."
    - "concurrent.futures.Future.running.__name__ == 'running'."
    - "concurrent.futures.Future.done.__name__ == 'done'."
    - "concurrent.futures.Future.exception.__name__ == 'exception'."
    - "concurrent.futures.Future.set_result.__name__ == 'set_result'."
    - "concurrent.futures.InvalidStateError.__qualname__ == 'InvalidStateError' — top-level exception class."
    - "concurrent.futures.InvalidStateError.__module__ == 'concurrent.futures._base'."
    - "concurrent.futures.InvalidStateError.__bases__[0].__name__ == 'Error' — inherits from _base.Error."
    - "concurrent.futures.ThreadPoolExecutor.__class__.__name__ == 'type' — plain Python class."
    - "concurrent.futures.ProcessPoolExecutor.__class__.__name__ == 'type' — plain Python class."
    - "concurrent.futures.ThreadPoolExecutor.__mro__[2].__name__ == 'object' — MRO: [ThreadPoolExecutor, Executor, object]."
    - "concurrent.futures.ProcessPoolExecutor.__mro__[2].__name__ == 'object' — MRO: [ProcessPoolExecutor, Executor, object]."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Future additional method names
#
# The base spec checks cancel, result, and add_done_callback.__name__.
# This spec adds the remaining Future state-query methods: cancelled, running,
# done, exception, and set_result — all defined in _base.Future, not covered
# in any prior concurrent_futures spec.
# ---------------------------------------------------------------------------

table concurrent_futures_extra9.Future.method_names:
  description: "concurrent.futures.Future methods have correct __name__"
  kind: python_call_eq
  category: method_names
  id_prefix: fmname

  columns: [id, function, args, expected]
  rows:
    - [cancelled,   Future.cancelled.__name__.__eq__,   ["cancelled"],   true]
    - [running,     Future.running.__name__.__eq__,     ["running"],     true]
    - [done,        Future.done.__name__.__eq__,        ["done"],        true]
    - [exception,   Future.exception.__name__.__eq__,   ["exception"],   true]
    - [set_result,  Future.set_result.__name__.__eq__,  ["set_result"],  true]

# ---------------------------------------------------------------------------
# InvalidStateError — qualname, module, and base class
#
# The base spec confirms InvalidStateError.__name__ == 'InvalidStateError'.
# No prior spec checks __qualname__, __module__, or __bases__[0].__name__.
# InvalidStateError is defined in concurrent.futures._base and inherits from
# _base.Error (the same internal Error class that CancelledError inherits from).
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra9.InvalidStateError.qualname:
  description: "concurrent.futures.InvalidStateError.__qualname__ == 'InvalidStateError'"
  category: exception_qualnames
  kind: python_call_eq
  function: InvalidStateError.__qualname__.__eq__
  args: ["InvalidStateError"]
  expected: true

invariant concurrent_futures_extra9.InvalidStateError.module:
  description: "concurrent.futures.InvalidStateError.__module__ == 'concurrent.futures._base'"
  category: exception_modules
  kind: python_call_eq
  function: InvalidStateError.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra9.InvalidStateError.base_is_Error:
  description: "concurrent.futures.InvalidStateError.__bases__[0].__name__ == 'Error'"
  category: exception_hierarchy
  kind: python_call_eq
  function: InvalidStateError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Error"

# ---------------------------------------------------------------------------
# ThreadPoolExecutor and ProcessPoolExecutor — metaclass type check
#
# No prior spec checks the __class__.__name__ ('type') of the executor classes.
# Plain Python classes have type as their metaclass, so __class__.__name__ == 'type'.
# This is an orthogonal dimension from __name__, __qualname__, __module__,
# __bases__, and MRO, none of which verify the metaclass.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra9.ThreadPoolExecutor.class_is_type:
  description: "concurrent.futures.ThreadPoolExecutor.__class__.__name__ == 'type' — plain Python class"
  category: class_types
  kind: python_call_eq
  function: ThreadPoolExecutor.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant concurrent_futures_extra9.ProcessPoolExecutor.class_is_type:
  description: "concurrent.futures.ProcessPoolExecutor.__class__.__name__ == 'type' — plain Python class"
  category: class_types
  kind: python_call_eq
  function: ProcessPoolExecutor.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# Executor subclass MRO[2] — depth-2 MRO entry for concrete executors
#
# extra7 checks ThreadPoolExecutor.__bases__[0].__name__ == 'Executor' and
# ProcessPoolExecutor.__bases__[0].__name__ == 'Executor'. extra8 checks
# Future.__mro__[1] == 'object'. This spec adds MRO[2] for both executor
# classes: since both inherit from Executor which inherits from object,
# __mro__[2].__name__ == 'object' for each.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra9.ThreadPoolExecutor.mro_index2:
  description: "concurrent.futures.ThreadPoolExecutor.__mro__[2].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: ThreadPoolExecutor.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "object"

invariant concurrent_futures_extra9.ProcessPoolExecutor.mro_index2:
  description: "concurrent.futures.ProcessPoolExecutor.__mro__[2].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: ProcessPoolExecutor.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "object"
