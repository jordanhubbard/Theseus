spec: hashlib_extra254
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
  notes:
    - "Wave 254 theme: hmac module function and class identity — hmac.new, hmac.digest, hmac.compare_digest, hmac.HMAC."
    - "hmac.new.__name__ == 'new'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hmac.new.__module__ == 'hmac'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hmac.new.__class__.__name__ == 'function'. hmac.new is a plain Python function defined in Lib/hmac.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hmac.HMAC.__name__ == 'HMAC'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hmac.HMAC.__module__ == 'hmac'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hmac.HMAC.__bases__[0].__name__ == 'object'. HMAC inherits directly from object (no intermediate base class). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hmac.digest.__name__ == 'digest'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hmac.digest.__module__ == 'hmac'. hmac.digest is defined in Lib/hmac.py (not _hashlib). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hmac.digest.__class__.__name__ == 'function'. hmac.digest is a pure Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hmac.compare_digest.__name__ == 'compare_digest'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hmac.compare_digest.__module__ == '_hashlib'. compare_digest is implemented in the C _hashlib extension and re-exported by hmac. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hmac.compare_digest.__class__.__name__ == 'builtin_function_or_method'. compare_digest is a C builtin from _hashlib. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hmac module-level function identity: new, digest, compare_digest
#
# Wave 254 theme: hmac module function __name__, __module__, __class__.__name__.
#
# hmac.new is a pure Python factory function (Lib/hmac.py) that creates HMAC
# instances. hmac.digest is also a pure Python function in hmac.py. By contrast,
# hmac.compare_digest is re-exported from the C _hashlib extension — its
# __module__ is '_hashlib' and its __class__.__name__ is 'builtin_function_or_method'.
# This table groups the three module-level callable identity checks together.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra254.hmac_function_identity:
  description: "hmac.new, hmac.digest, hmac.compare_digest __name__ and __module__ identity — new and digest are pure Python functions in Lib/hmac.py (__module__=='hmac', __class__.__name__=='function'); compare_digest is a C builtin re-exported from _hashlib (__module__=='_hashlib', __class__.__name__=='builtin_function_or_method'); wave 254 theme: hmac callable identity; verified with Python 3.14.3"
  kind: python_call_eq
  category: function_identity
  id_prefix: hmacfnident254

  columns: [id, function, args, expected, description]
  rows:
    - [new_name_eq,                   new.__name__.__eq__,                          ["new"],                       true, "hmac.new.__name__ == 'new'; pure Python factory in Lib/hmac.py"]
    - [new_module_eq,                 new.__module__.__eq__,                        ["hmac"],                      true, "hmac.new.__module__ == 'hmac'; defined in Lib/hmac.py"]
    - [new_class_eq,                  new.__class__.__name__.__eq__,                ["function"],                  true, "hmac.new.__class__.__name__ == 'function'; pure Python function"]
    - [digest_name_eq,                digest.__name__.__eq__,                       ["digest"],                    true, "hmac.digest.__name__ == 'digest'; pure Python function in Lib/hmac.py"]
    - [digest_module_eq,              digest.__module__.__eq__,                     ["hmac"],                      true, "hmac.digest.__module__ == 'hmac'; defined in Lib/hmac.py (not _hashlib)"]
    - [digest_class_eq,               digest.__class__.__name__.__eq__,             ["function"],                  true, "hmac.digest.__class__.__name__ == 'function'; pure Python function"]
    - [compare_digest_name_eq,        compare_digest.__name__.__eq__,               ["compare_digest"],            true, "hmac.compare_digest.__name__ == 'compare_digest'; C builtin re-exported from _hashlib"]
    - [compare_digest_module_eq,      compare_digest.__module__.__eq__,             ["_hashlib"],                  true, "hmac.compare_digest.__module__ == '_hashlib'; implemented in C extension"]
    - [compare_digest_class_eq,       compare_digest.__class__.__name__.__eq__,     ["builtin_function_or_method"], true, "hmac.compare_digest.__class__.__name__ == 'builtin_function_or_method'; C builtin"]

# ---------------------------------------------------------------------------
# hmac.HMAC class identity
#
# Wave 254 theme: hmac.HMAC class __name__, __module__, __bases__[0].__name__.
#
# hmac.HMAC is the core class that wraps hash objects to provide HMAC
# functionality. It inherits directly from object with no intermediate base.
# Its __name__ is 'HMAC', __module__ is 'hmac', and __bases__[0].__name__
# is 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra254.HMAC_class_identity:
  description: "hmac.HMAC class __name__, __module__, and __bases__[0].__name__ identity — HMAC.__name__=='HMAC'; HMAC.__module__=='hmac' (defined in Lib/hmac.py); HMAC.__bases__[0].__name__=='object' (inherits directly from object with no intermediate base class); wave 254 theme: HMAC class identity; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_identity
  id_prefix: hmacclsident254

  columns: [id, function, args, expected, description]
  rows:
    - [HMAC_name_eq,        HMAC.__name__.__eq__,               ["HMAC"],    true, "hmac.HMAC.__name__ == 'HMAC'; the HMAC keyed-hash message authentication code class"]
    - [HMAC_module_eq,      HMAC.__module__.__eq__,             ["hmac"],    true, "hmac.HMAC.__module__ == 'hmac'; defined in Lib/hmac.py"]
    - [HMAC_base_name_eq,   "HMAC.__bases__[0].__name__.__eq__", ["object"],  true, "hmac.HMAC.__bases__[0].__name__ == 'object'; HMAC inherits directly from object"]

# ---------------------------------------------------------------------------
# Standalone invariants — hmac function and class identity
# ---------------------------------------------------------------------------

invariant hashlib_extra254.hmac_new_is_function:
  description: "hmac.new.__class__.__name__.__eq__('function') == True — hmac.new is a plain Python function defined in Lib/hmac.py; it creates HMAC instances as a convenience factory; contrasts with hmac.compare_digest which is a C builtin from _hashlib; wave 254; verified with Python 3.14.3"
  category: function_identity
  kind: python_call_eq
  function: new.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant hashlib_extra254.hmac_compare_digest_module_is_hashlib:
  description: "hmac.compare_digest.__module__.__eq__('_hashlib') == True — compare_digest is implemented in the C _hashlib extension module and re-exported by hmac; this is why its __class__.__name__ is 'builtin_function_or_method' rather than 'function'; the _hashlib module provides constant-time comparison to prevent timing attacks; wave 254; verified with Python 3.14.3"
  category: function_identity
  kind: python_call_eq
  function: compare_digest.__module__.__eq__
  args: ["_hashlib"]
  expected: true

invariant hashlib_extra254.HMAC_bases_object:
  description: "hmac.HMAC.__bases__[0].__name__.__eq__('object') == True — HMAC inherits directly from object; it has no intermediate base class; HMAC wraps a hash object (from hashlib) and tracks an inner and outer hash context implementing the RFC 2104 HMAC construction; wave 254; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "HMAC.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
