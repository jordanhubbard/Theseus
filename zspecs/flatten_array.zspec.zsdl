spec: flatten_array
version: ">=1.0.0"
backend: node(flatten-array)

docs: https://www.npmjs.com/package/flatten-array

provenance:
  derived_from:
    - "flatten-array README — https://www.npmjs.com/package/flatten-array"
    - "Test vectors verified with flatten-array via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "flatten-array source"
  notes:
    - "flatten-array is an npm package. Install: npm install flatten-array"
    - "Recursively flattens a nested array to a single flat array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table flatten_array.flatten:
  kind: node_module_call_eq
  function: ~
  category: arrays
  id_prefix: flatarr

  columns: [id, args, expected]
  rows:
    - [shallow, [[[1, 2], [3, 4]]],      [1, 2, 3, 4]]
    - [deep,    [[[1, [2, [3, 4]]]]],    [1, 2, 3, 4]]
    - [flat,    [[[1, 2, 3]]],           [1, 2, 3]]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T18:17:47Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
