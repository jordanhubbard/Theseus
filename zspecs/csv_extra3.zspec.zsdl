spec: csv_extra3
version: ">=3.2"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "Python csv documentation — https://docs.python.org/3/library/csv.html"
    - "Test vectors verified by running Python 3.12 csv module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
    - "csv.zspec.zsdl — covers reader parsing, QUOTE_* constant values, excel dialect properties, field_size_limit"
    - "csv_extra.zspec.zsdl — covers DictReader, DictWriter, unix_dialect name/properties, excel_tab properties, __bases__"
    - "csv_extra2.zspec.zsdl — covers Dialect.__module__, list_dialects(), QUOTE_* class type checks, QUOTE_* pinned values"
    - "_csv.zspec.zsdl — covers _csv C-extension Dialect/__name__, Error, reader/writer names"
  notes:
    - "This spec covers additional class __name__ checks for csv public API: Dialect, excel, excel_tab, unix_dialect, Sniffer, reader, writer, DictReader, DictWriter."
    - "csv.reader and csv.writer are C-extension types; their __name__ reflects the type name, not a function name."
    - "csv.Sniffer is a pure-Python class defined in csv.py."
    - "QUOTE_ALL and QUOTE_MINIMAL are plain int values (class name 'int')."
    - "All expected values verified by running Python 3.12 csv module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ checks — Dialect family
# ---------------------------------------------------------------------------

invariant csv_extra3.Dialect.name:
  description: "csv.Dialect.__name__ == 'Dialect'"
  category: classnames
  kind: python_call_eq
  function: Dialect.__name__.__eq__
  args: ["Dialect"]
  expected: true

invariant csv_extra3.excel.name:
  description: "csv.excel.__name__ == 'excel'"
  category: classnames
  kind: python_call_eq
  function: excel.__name__.__eq__
  args: ["excel"]
  expected: true

invariant csv_extra3.excel_tab.name:
  description: "csv.excel_tab.__name__ == 'excel_tab'"
  category: classnames
  kind: python_call_eq
  function: excel_tab.__name__.__eq__
  args: ["excel_tab"]
  expected: true

invariant csv_extra3.unix_dialect.name:
  description: "csv.unix_dialect.__name__ == 'unix_dialect'"
  category: classnames
  kind: python_call_eq
  function: unix_dialect.__name__.__eq__
  args: ["unix_dialect"]
  expected: true

invariant csv_extra3.Sniffer.name:
  description: "csv.Sniffer.__name__ == 'Sniffer'"
  category: classnames
  kind: python_call_eq
  function: Sniffer.__name__.__eq__
  args: ["Sniffer"]
  expected: true

# ---------------------------------------------------------------------------
# Type __name__ checks — reader and writer (C-extension types)
# ---------------------------------------------------------------------------

invariant csv_extra3.reader.name:
  description: "csv.reader.__name__ == 'reader'"
  category: classnames
  kind: python_call_eq
  function: reader.__name__.__eq__
  args: ["reader"]
  expected: true

invariant csv_extra3.writer.name:
  description: "csv.writer.__name__ == 'writer'"
  category: classnames
  kind: python_call_eq
  function: writer.__name__.__eq__
  args: ["writer"]
  expected: true

# ---------------------------------------------------------------------------
# Class __name__ checks — DictReader and DictWriter
# ---------------------------------------------------------------------------

invariant csv_extra3.DictReader.name:
  description: "csv.DictReader.__name__ == 'DictReader'"
  category: classnames
  kind: python_call_eq
  function: DictReader.__name__.__eq__
  args: ["DictReader"]
  expected: true

invariant csv_extra3.DictWriter.name:
  description: "csv.DictWriter.__name__ == 'DictWriter'"
  category: classnames
  kind: python_call_eq
  function: DictWriter.__name__.__eq__
  args: ["DictWriter"]
  expected: true

# ---------------------------------------------------------------------------
# QUOTE_ALL and QUOTE_MINIMAL — class type is int
# ---------------------------------------------------------------------------

invariant csv_extra3.QUOTE_ALL.class_name:
  description: "csv.QUOTE_ALL.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: QUOTE_ALL.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant csv_extra3.QUOTE_MINIMAL.class_name:
  description: "csv.QUOTE_MINIMAL.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: QUOTE_MINIMAL.__class__.__name__.__eq__
  args: ["int"]
  expected: true
