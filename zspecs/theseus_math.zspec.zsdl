spec: theseus_math
version: ">=3.9"
backend: python_cleanroom(theseus_math)
blocks: math

docs: https://docs.python.org/3/library/math.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/math.html"
  notes:
    - "Clean-room math utilities. Do NOT import math, cmath, or numpy."
    - "Implement using only Python arithmetic, integer ops, and known series/algorithms."
    - "factorial(n): product of integers 1..n; factorial(0)=1; factorial(5)=120."
    - "gcd(a, b): Euclidean algorithm; gcd(48, 18)=6."
    - "isqrt(n): integer square root floor; isqrt(17)=4."
    - "Export: factorial(n: int) -> int, gcd(a: int, b: int) -> int, isqrt(n: int) -> int."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_math.factorial_five:
  description: "factorial(5) == 120"
  category: factorial
  kind: python_call_eq
  function: math_factorial_five
  args: []
  expected: 120

invariant theseus_math.gcd_result:
  description: "gcd(48, 18) == 6"
  category: gcd
  kind: python_call_eq
  function: math_gcd
  args: []
  expected: 6

invariant theseus_math.isqrt_result:
  description: "isqrt(17) == 4"
  category: isqrt
  kind: python_call_eq
  function: math_isqrt
  args: []
  expected: 4
