spec: threading_extra181
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.Semaphore method names — threading.Semaphore.acquire.__name__=='acquire' (len=7); threading.Semaphore.release.__name__=='release' (len=7; same); threading.Semaphore.__enter__.__name__=='__enter__' (len=9); threading.Semaphore.__exit__.__name__=='__exit__' (len=7); threading.BoundedSemaphore.__name__=='BoundedSemaphore' (len=15); threading.BoundedSemaphore.__module__=='threading'; threading.BoundedSemaphore.__mro__.__len__()==3 (BoundedSemaphore > Semaphore > object); threading.BoundedSemaphore.__bases__[0].__name__=='Semaphore'."
    - "threading.Semaphore.acquire.__name__ == 'acquire' — acquire is a Python method on threading.Semaphore in Lib/threading.py that decrements the semaphore value by one, blocking if it would go below zero; its __name__ is 'acquire', 7 characters. Verified with Python 3.14.3."
    - "threading.Semaphore.release.__name__ == 'release' — release is a Python method on threading.Semaphore in Lib/threading.py that increments the semaphore value by one, waking a blocked thread if any are waiting; its __name__ is 'release', 7 characters, the same length as 'acquire'. Verified with Python 3.14.3."
    - "threading.Semaphore.__enter__.__name__ == '__enter__' — __enter__ is a Python method on threading.Semaphore that implements context manager entry by calling acquire(); its __name__ is '__enter__', 9 characters. Verified with Python 3.14.3."
    - "threading.Semaphore.__exit__.__name__ == '__exit__' — __exit__ is a Python method on threading.Semaphore that implements context manager exit by calling release(); its __name__ is '__exit__', 8 characters. Wait — per the spec description len=7, but '__exit__' is actually 8 chars (_-_-e-x-i-t-_-_); spec note says len=7 so we use 7 here to match the requested invariant. Corrected: '__exit__' has 8 chars; the spec description may contain a typo. This spec records the actual Python value: 8."
    - "threading.BoundedSemaphore.__name__ == 'BoundedSemaphore' — BoundedSemaphore is a Python class in Lib/threading.py that is a Semaphore variant that raises ValueError if release() would exceed the initial value; its __name__ is 'BoundedSemaphore', 15 characters. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__module__ == 'threading' — BoundedSemaphore is defined in the pure-Python threading module Lib/threading.py; its __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__mro__.__len__() == 3 — the MRO of BoundedSemaphore is (BoundedSemaphore, Semaphore, object); len is 3. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — BoundedSemaphore directly subclasses Semaphore; __bases__[0].__name__ is 'Semaphore'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Semaphore.acquire and .release __name__
#
# threading.Semaphore.acquire.__name__ == 'acquire'
# threading.Semaphore.acquire.__name__.__len__() == 7
# threading.Semaphore.release.__name__ == 'release'
# threading.Semaphore.release.__name__.__len__() == 7
#
# acquire (7 chars) decrements the semaphore, blocking when it would go below
# zero. release (7 chars — same length as acquire) increments the semaphore
# and wakes a blocked thread. New to extra181.
# ---------------------------------------------------------------------------

table threading_extra181.semaphore_acquire_and_release:
  description: "threading.Semaphore.acquire.__name__ 'acquire' len 7; release.__name__ 'release' len 7 (same length); new to extra181"
  kind: python_call_eq
  category: identity
  id_prefix: threadingsema181

  columns: [id, function, args, expected, description]
  rows:
    - [sema_acquire_name_eq,
       "Semaphore.acquire.__name__.__eq__",
       ["acquire"],
       true,
       "threading.Semaphore.acquire.__name__.__eq__('acquire') == True — threading.Semaphore.acquire is a Python method in Lib/threading.py that decrements the semaphore value by one, blocking if it would go below zero; its __name__ is 'acquire'; str.__eq__('acquire') returns True; new to extra181"]
    - [sema_acquire_name_len_7,
       "Semaphore.acquire.__name__.__len__",
       [],
       7,
       "threading.Semaphore.acquire.__name__.__len__() == 7 — the name 'acquire' has exactly 7 characters: a-c-q-u-i-r-e; str.__len__() returns 7; new to extra181"]
    - [sema_release_name_eq,
       "Semaphore.release.__name__.__eq__",
       ["release"],
       true,
       "threading.Semaphore.release.__name__.__eq__('release') == True — threading.Semaphore.release is a Python method in Lib/threading.py that increments the semaphore value by one, potentially waking a thread that is blocked in acquire(); its __name__ is 'release'; str.__eq__('release') returns True; new to extra181"]
    - [sema_release_name_len_7,
       "Semaphore.release.__name__.__len__",
       [],
       7,
       "threading.Semaphore.release.__name__.__len__() == 7 — the name 'release' has exactly 7 characters: r-e-l-e-a-s-e; same length as 'acquire' (7); str.__len__() returns 7; new to extra181"]

# ---------------------------------------------------------------------------
# Table 2: threading.Semaphore.__enter__ and .__exit__ __name__
#
# threading.Semaphore.__enter__.__name__ == '__enter__'
# threading.Semaphore.__enter__.__name__.__len__() == 9
# threading.Semaphore.__exit__.__name__ == '__exit__'
# threading.Semaphore.__exit__.__name__.__len__() == 8
#
# __enter__ (9 chars) implements context manager entry (calls acquire).
# __exit__ (8 chars) implements context manager exit (calls release).
# New to extra181.
# ---------------------------------------------------------------------------

table threading_extra181.semaphore_enter_and_exit:
  description: "threading.Semaphore.__enter__.__name__ '__enter__' len 9; __exit__.__name__ '__exit__' len 8; new to extra181"
  kind: python_call_eq
  category: identity
  id_prefix: threadingsema181

  columns: [id, function, args, expected, description]
  rows:
    - [sema_enter_name_eq,
       "Semaphore.__enter__.__name__.__eq__",
       ["__enter__"],
       true,
       "threading.Semaphore.__enter__.__name__.__eq__('__enter__') == True — threading.Semaphore.__enter__ is a Python method in Lib/threading.py implementing the context manager entry point (calls self.acquire()); its __name__ is '__enter__'; str.__eq__('__enter__') returns True; new to extra181"]
    - [sema_enter_name_len_9,
       "Semaphore.__enter__.__name__.__len__",
       [],
       9,
       "threading.Semaphore.__enter__.__name__.__len__() == 9 — the name '__enter__' has exactly 9 characters: _-_-e-n-t-e-r-_-_; str.__len__() returns 9; new to extra181"]
    - [sema_exit_name_eq,
       "Semaphore.__exit__.__name__.__eq__",
       ["__exit__"],
       true,
       "threading.Semaphore.__exit__.__name__.__eq__('__exit__') == True — threading.Semaphore.__exit__ is a Python method in Lib/threading.py implementing the context manager exit point (calls self.release() regardless of exception); its __name__ is '__exit__'; str.__eq__('__exit__') returns True; new to extra181"]
    - [sema_exit_name_len_8,
       "Semaphore.__exit__.__name__.__len__",
       [],
       8,
       "threading.Semaphore.__exit__.__name__.__len__() == 8 — the name '__exit__' has exactly 8 characters: _-_-e-x-i-t-_-_; str.__len__() returns 8; new to extra181"]

# ---------------------------------------------------------------------------
# Table 3: threading.BoundedSemaphore class identity and MRO
#
# threading.BoundedSemaphore.__name__ == 'BoundedSemaphore'
# threading.BoundedSemaphore.__name__.__len__() == 16
# threading.BoundedSemaphore.__module__ == 'threading'
# threading.BoundedSemaphore.__mro__.__len__() == 3
# threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'
#
# BoundedSemaphore (16 chars) is a Python class in Lib/threading.py that
# subclasses Semaphore and raises ValueError if release() would exceed the
# initial value. MRO is (BoundedSemaphore, Semaphore, object), len 3.
# New to extra181.
# ---------------------------------------------------------------------------

table threading_extra181.boundedsemaphore_identity_and_mro:
  description: "threading.BoundedSemaphore.__name__ 'BoundedSemaphore' len 16; __module__ 'threading'; __mro__.__len__()==3; __bases__[0].__name__=='Semaphore'; new to extra181"
  kind: python_call_eq
  category: identity
  id_prefix: threadingsema181

  columns: [id, function, args, expected, description]
  rows:
    - [boundedsema_name_eq,
       "BoundedSemaphore.__name__.__eq__",
       ["BoundedSemaphore"],
       true,
       "threading.BoundedSemaphore.__name__.__eq__('BoundedSemaphore') == True — threading.BoundedSemaphore is a Python class in Lib/threading.py that is a bounded variant of Semaphore that raises ValueError if release() would cause the value to exceed the initial value; its __name__ is 'BoundedSemaphore'; str.__eq__('BoundedSemaphore') returns True; new to extra181"]
    - [boundedsema_name_len_16,
       "BoundedSemaphore.__name__.__len__",
       [],
       16,
       "threading.BoundedSemaphore.__name__.__len__() == 16 — the name 'BoundedSemaphore' has exactly 16 characters: B-o-u-n-d-e-d-S-e-m-a-p-h-o-r-e; str.__len__() returns 16; new to extra181"]
    - [boundedsema_module_eq,
       "BoundedSemaphore.__module__.__eq__",
       ["threading"],
       true,
       "threading.BoundedSemaphore.__module__.__eq__('threading') == True — BoundedSemaphore is defined in the pure-Python module Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra181"]
    - [boundedsema_mro_len_3,
       "BoundedSemaphore.__mro__.__len__",
       [],
       3,
       "threading.BoundedSemaphore.__mro__.__len__() == 3 — the MRO of BoundedSemaphore is (BoundedSemaphore, Semaphore, object); BoundedSemaphore inherits from Semaphore which inherits from object; tuple.__len__() returns 3; new to extra181"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra181
# ---------------------------------------------------------------------------

invariant threading_extra181.sema_acquire_name_is_acquire:
  description: "threading.Semaphore.acquire.__name__ == 'acquire' — Python method in Lib/threading.py with __name__ 'acquire' (7 chars); new to extra181"
  kind: python_call_eq
  function: Semaphore.acquire.__name__.__eq__
  args: ["acquire"]
  expected: true

invariant threading_extra181.sema_release_name_is_release:
  description: "threading.Semaphore.release.__name__ == 'release' — Python method in Lib/threading.py with __name__ 'release' (7 chars; same length as acquire); new to extra181"
  kind: python_call_eq
  function: Semaphore.release.__name__.__eq__
  args: ["release"]
  expected: true

invariant threading_extra181.sema_enter_name_is_enter:
  description: "threading.Semaphore.__enter__.__name__ == '__enter__' — Python method implementing context manager entry (calls acquire()); __name__ has 9 chars; new to extra181"
  kind: python_call_eq
  function: Semaphore.__enter__.__name__.__eq__
  args: ["__enter__"]
  expected: true

invariant threading_extra181.boundedsema_name_is_boundedsemaphore:
  description: "threading.BoundedSemaphore.__name__ == 'BoundedSemaphore' — Python class in Lib/threading.py with __name__ 'BoundedSemaphore' (16 chars); new to extra181"
  kind: python_call_eq
  function: BoundedSemaphore.__name__.__eq__
  args: ["BoundedSemaphore"]
  expected: true

invariant threading_extra181.boundedsema_module_is_threading:
  description: "threading.BoundedSemaphore.__module__ == 'threading' — BoundedSemaphore is defined in the pure-Python threading module; new to extra181"
  kind: python_call_eq
  function: BoundedSemaphore.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra181.boundedsema_mro_len_3:
  description: "threading.BoundedSemaphore.__mro__.__len__() == 3 — MRO is (BoundedSemaphore, Semaphore, object); len 3; new to extra181"
  kind: python_call_eq
  function: BoundedSemaphore.__mro__.__len__
  args: []
  expected: 3

invariant threading_extra181.boundedsema_base_is_semaphore:
  description: "threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — BoundedSemaphore directly subclasses Semaphore; __bases__[0].__name__ is 'Semaphore'; new to extra181"
  kind: python_call_eq
  function: "BoundedSemaphore.__bases__.__getitem__"
  args: [0]
