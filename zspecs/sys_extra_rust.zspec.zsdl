spec: sys_extra_rust
version: ">=3.9"
backend: rust_module(sys_extra_rust)

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sys.html — sys module"
  notes:
    - "sys provides access to Python interpreter variables."
    - "sys.version is non-empty."
    - "sys.platform is non-empty."
    - "sys.maxsize > 0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant sys_extra_rust.version_nonempty:
  description: "sys.version is non-empty"
  category: version
  kind: python_call_eq
  function: sys_extra_version_nonempty
  args: []
  expected: true

invariant sys_extra_rust.platform_nonempty:
  description: "sys.platform is non-empty"
  category: platform
  kind: python_call_eq
  function: sys_extra_platform_nonempty
  args: []
  expected: true

invariant sys_extra_rust.maxsize_positive:
  description: "sys.maxsize > 0"
  category: maxsize
  kind: python_call_eq
  function: sys_extra_maxsize_positive
  args: []
  expected: true

