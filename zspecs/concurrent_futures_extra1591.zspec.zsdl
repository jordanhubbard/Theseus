spec: concurrent_futures_extra1591
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for descriptor protocol"
    - "concurrent.futures classes do not implement __get__, __set__, or __delete__ in their own __dict__"
    - "Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12"

table concurrent_futures_extra1591.future_executor_no_descriptor:
  description: "concurrent.futures Future, Executor, ThreadPoolExecutor, and ProcessPoolExecutor do not define descriptor protocol methods"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1591fe

  columns: [id, function, args, expected]
  rows:
    - ["cf1591fe001", "concurrent.futures.Future.__dict__.__contains__",              ["__get__"],    false]
    - ["cf1591fe002", "concurrent.futures.Future.__dict__.__contains__",              ["__set__"],    false]
    - ["cf1591fe003", "concurrent.futures.Future.__dict__.__contains__",              ["__delete__"], false]
    - ["cf1591fe004", "concurrent.futures.Executor.__dict__.__contains__",            ["__get__"],    false]
    - ["cf1591fe005", "concurrent.futures.Executor.__dict__.__contains__",            ["__set__"],    false]
    - ["cf1591fe006", "concurrent.futures.Executor.__dict__.__contains__",            ["__delete__"], false]
    - ["cf1591fe007", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__get__"],    false]
    - ["cf1591fe008", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__set__"],    false]
    - ["cf1591fe009", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__delete__"], false]
    - ["cf1591fe010", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__get__"],    false]
    - ["cf1591fe011", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__set__"],    false]
    - ["cf1591fe012", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__delete__"], false]
    - ["cf1591fe013", "concurrent.futures.Future.__dict__.__contains__",              ["cancel"],     true]
    - ["cf1591fe014", "concurrent.futures.Future.__dict__.__contains__",              ["result"],     true]
    - ["cf1591fe015", "concurrent.futures.Future.__dict__.__contains__",              ["done"],       true]
    - ["cf1591fe016", "concurrent.futures.Future.__dict__.__contains__",              ["exception"],  true]
    - ["cf1591fe017", "concurrent.futures.Future.__dict__.__contains__",              ["add_done_callback"], true]
    - ["cf1591fe018", "concurrent.futures.Executor.__dict__.__contains__",            ["submit"],     true]
    - ["cf1591fe019", "concurrent.futures.Executor.__dict__.__contains__",            ["map"],        true]
    - ["cf1591fe020", "concurrent.futures.Executor.__dict__.__contains__",            ["shutdown"],   true]
    - ["cf1591fe021", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["submit"],     true]
    - ["cf1591fe022", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["submit"],     true]
    - ["cf1591fe023", "concurrent.futures.Future.__dict__.__contains__",              ["__doc__"],    true]
    - ["cf1591fe024", "concurrent.futures.Future.__dict__.__contains__",              ["__module__"], true]
    - ["cf1591fe025", "concurrent.futures.Executor.__dict__.__contains__",            ["__doc__"],    true]
    - ["cf1591fe026", "concurrent.futures.Future.__dict__.__contains__",              ["__set_name__"],  false]
    - ["cf1591fe027", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__doc__"],    true]
    - ["cf1591fe028", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__doc__"],    true]

table concurrent_futures_extra1591.exceptions_no_descriptor:
  description: "concurrent.futures exception classes do not define descriptor protocol methods in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1591ex

  columns: [id, function, args, expected]
  rows:
    - ["cf1591ex001", "concurrent.futures.CancelledError.__dict__.__contains__",  ["__get__"],    false]
    - ["cf1591ex002", "concurrent.futures.CancelledError.__dict__.__contains__",  ["__set__"],    false]
    - ["cf1591ex003", "concurrent.futures.CancelledError.__dict__.__contains__",  ["__delete__"], false]
    - ["cf1591ex004", "concurrent.futures.TimeoutError.__dict__.__contains__",    ["__get__"],    false]
    - ["cf1591ex005", "concurrent.futures.TimeoutError.__dict__.__contains__",    ["__set__"],    false]
    - ["cf1591ex006", "concurrent.futures.TimeoutError.__dict__.__contains__",    ["__delete__"], false]
    - ["cf1591ex007", "concurrent.futures.BrokenExecutor.__dict__.__contains__",  ["__get__"],    false]
    - ["cf1591ex008", "concurrent.futures.BrokenExecutor.__dict__.__contains__",  ["__set__"],    false]
    - ["cf1591ex009", "concurrent.futures.BrokenExecutor.__dict__.__contains__",  ["__delete__"], false]
    - ["cf1591ex010", "concurrent.futures.CancelledError.__dict__.__contains__",  ["__module__"], true]
    - ["cf1591ex011", "concurrent.futures.CancelledError.__dict__.__contains__",  ["__doc__"],    true]
    - ["cf1591ex012", "concurrent.futures.TimeoutError.__dict__.__contains__",    ["__doc__"],    true]
    - ["cf1591ex013", "concurrent.futures.BrokenExecutor.__dict__.__contains__",  ["__module__"], true]
    - ["cf1591ex014", "concurrent.futures.BrokenExecutor.__dict__.__contains__",  ["__doc__"],    true]
    - ["cf1591ex015", "concurrent.futures.CancelledError.__dict__.__contains__",  ["__set_name__"], false]
    - ["cf1591ex016", "concurrent.futures.TimeoutError.__dict__.__contains__",    ["__set_name__"], false]
    - ["cf1591ex017", "concurrent.futures.BrokenExecutor.__dict__.__contains__",  ["__set_name__"], false]
    - ["cf1591ex018", "concurrent.futures.CancelledError.__dict__.__contains__",  ["__init__"],   false]
    - ["cf1591ex019", "concurrent.futures.TimeoutError.__dict__.__contains__",    ["__init__"],   false]
    - ["cf1591ex020", "concurrent.futures.BrokenExecutor.__dict__.__contains__",  ["__init__"],   false]
    - ["cf1591ex021", "concurrent.futures.CancelledError.__dict__.__contains__",  ["__subclasshook__"], false]
    - ["cf1591ex022", "concurrent.futures.TimeoutError.__dict__.__contains__",    ["__module__"], false]
    - ["cf1591ex023", "concurrent.futures.BrokenExecutor.__dict__.__contains__",  ["__weakref__"], true]
