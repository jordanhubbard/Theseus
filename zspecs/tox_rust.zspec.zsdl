  derived_from:
    - "https://tox.wiki/ — tox automation tool"
  notes:
    - "tox provides test automation across multiple Python environments."
    - "tox.__version__ is non-empty."
    - "tox.config is importable."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant tox_rust.has_config_module:
  description: "tox.config is importable"
