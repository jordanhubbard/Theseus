  kind: python_call_eq
  function: tox_has_version_info
  args: []
  expected: true

invariant tox_rust.version_nonempty:
  description: "tox.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: tox_version_nonempty
  args: []
  expected: true

