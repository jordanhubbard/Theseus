spec: threading_extra146
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.local deeper introspection — __name__ '_local', __module__ '_thread', MRO len 2, __init__.__class__.__name__ 'wrapper_descriptor', __dict__.__class__.__name__ 'mappingproxy', __doc__ len 17 (Thread-local data); threading.TIMEOUT_MAX — __class__.__name__ 'float'; threading.Thread class attrs — __doc__ len 247, __dict__.__class__.__name__ 'mappingproxy', MRO len 2; threading.BoundedSemaphore — __name__ 'BoundedSemaphore' len 16, __bases__[0].__name__ 'Semaphore', MRO len 3; threading module __name__ len 9, __doc__ len 59 (Wave 273)."
    - "threading.local.__name__ == '_local' (the C type's underlying name); __module__ == '_thread'; MRO len == 2 [_local, object]; __init__.__class__.__name__ == 'wrapper_descriptor'; __dict__.__class__.__name__ == 'mappingproxy'; __doc__ == 'Thread-local data' (len 17). Verified with Python 3.14.3."
    - "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is the maximum value for the timeout parameter (9223372036.0 on Darwin). Verified with Python 3.14.3."
    - "threading.Thread.__doc__ len == 247; threading.Thread.__dict__.__class__.__name__ == 'mappingproxy'; MRO len == 2. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__name__ == 'BoundedSemaphore' (len 16); __bases__[0].__name__ == 'Semaphore'; MRO len == 3. Verified with Python 3.14.3."
    - "len(threading.__name__) == 9; len(threading.__doc__) == 59. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.local deeper introspection
#
# Wave 273 theme: threading.local — C extension type for thread-local storage.
#
# threading.local.__name__ == '_local' (C type name is '_local')
# threading.local.__module__ == '_thread'
# len(threading.local.__mro__) == 2
# threading.local.__init__.__class__.__name__ == 'wrapper_descriptor'
# threading.local.__dict__.__class__.__name__ == 'mappingproxy'
# len(threading.local.__doc__) == 17
#
# threading.local is the C extension class _thread._local from _threadmodule.c.
# Its __name__ is '_local' (lowercase, with underscore); __module__ is '_thread'.
# __init__ on a C extension type is a wrapper_descriptor. New to extra146.
# ---------------------------------------------------------------------------

table threading_extra146.local_deep_introspection:
  description: "threading.local: __name__ '_local', __module__ '_thread', MRO len 2, __init__.__class__=='wrapper_descriptor', __dict__.__class__=='mappingproxy', __doc__ len 17; wave 273; new to extra146"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadinglocal146

  columns: [id, function, args, expected, description]
  rows:
    - [local_name_eq__local,
       "local.__name__.__eq__",
       ["_local"],
       true,
       "threading.local.__name__.__eq__('_local') == True — threading.local is the C extension class _thread._local; the underlying C type name is '_local' (with underscore); __name__ is '_local'; str.__eq__('_local') returns True; new to extra146"]
    - [local_module_eq__thread,
       "local.__module__.__eq__",
       ["_thread"],
       true,
       "threading.local.__module__.__eq__('_thread') == True — threading.local is implemented in _threadmodule.c and exposed via the _thread C extension; __module__ is '_thread'; str.__eq__('_thread') returns True; new to extra146"]
    - [local_mro_len_eq_2,
       "local.__mro__.__len__",
       [],
       2,
       "threading.local.__mro__.__len__() == 2 — threading.local's MRO is [_local, object]; it inherits directly from object with no intermediate base; len(__mro__) is 2; new to extra146"]
    - [local_init_class_eq_wrapper_descriptor,
       "local.__init__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "threading.local.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — when accessed on a C extension type, __init__ is exposed as a 'wrapper_descriptor'; this is the standard slot wrapper for C-implemented special methods; str.__eq__('wrapper_descriptor') returns True; new to extra146"]
    - [local_dict_class_eq_mappingproxy,
       "local.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "threading.local.__dict__.__class__.__name__.__eq__('mappingproxy') == True — all Python type objects expose their __dict__ as a read-only mappingproxy; threading.local is no exception; __dict__.__class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; new to extra146"]
    - [local_doc_len_eq_17,
       "local.__doc__.__len__",
       [],
       17,
       "threading.local.__doc__.__len__() == 17 — threading.local.__doc__ is 'Thread-local data' which has 17 characters; len('Thread-local data') == 17; verified with Python 3.14.3; new to extra146"]

# ---------------------------------------------------------------------------
# Table 2: threading.TIMEOUT_MAX and threading module attrs
#
# Wave 273 theme: threading.TIMEOUT_MAX float identity; module-level attrs.
#
# threading.TIMEOUT_MAX.__class__.__name__ == 'float'
# len(threading.__name__) == 9
# len(threading.__doc__) == 59
#
# TIMEOUT_MAX is a float constant (platform-dependent value). The module __doc__
# is a short docstring. New to extra146.
# ---------------------------------------------------------------------------

table threading_extra146.timeout_max_and_module_attrs:
  description: "threading.TIMEOUT_MAX.__class__.__name__=='float'; threading.__name__ len 9; threading.__doc__ len 59; wave 273; new to extra146"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingmod146

  columns: [id, function, args, expected, description]
  rows:
    - [timeout_max_class_eq_float,
       "TIMEOUT_MAX.__class__.__name__.__eq__",
       ["float"],
       true,
       "threading.TIMEOUT_MAX.__class__.__name__.__eq__('float') == True — TIMEOUT_MAX is the platform-specific maximum timeout value (9223372036.0 on Darwin); it is a Python float; __class__.__name__ is 'float'; str.__eq__('float') returns True; new to extra146"]
    - [module_name_eq_threading,
       "__name__.__eq__",
       ["threading"],
       true,
       "threading.__name__.__eq__('threading') == True — the module __name__ is 'threading'; str.__eq__('threading') returns True; new to extra146"]
    - [module_name_len_eq_9,
       "__name__.__len__",
       [],
       9,
       "threading.__name__.__len__() == 9 — __name__ is 'threading' which has 9 characters; len('threading') == 9; new to extra146"]
    - [module_doc_len_eq_59,
       "__doc__.__len__",
       [],
       59,
       "threading.__doc__.__len__() == 59 — the threading module has a short module-level docstring of 59 characters; len(__doc__) == 59; verified with Python 3.14.3; new to extra146"]

# ---------------------------------------------------------------------------
# Table 3: threading.Thread deeper class attributes
#
# Wave 273 theme: threading.Thread __doc__, __dict__ class, MRO.
#
# len(threading.Thread.__doc__) == 247
# threading.Thread.__dict__.__class__.__name__ == 'mappingproxy'
# len(threading.Thread.__mro__) == 2
# threading.Thread.__init__.__class__.__name__ == 'function'
#
# Thread is a pure-Python class; its __dict__ is exposed as a mappingproxy;
# __init__ is a function (Python function, not wrapper_descriptor as for C types).
# New to extra146.
# ---------------------------------------------------------------------------

table threading_extra146.thread_deep_attrs:
  description: "threading.Thread: __doc__ len 247, __dict__.__class__=='mappingproxy', MRO len 2, __init__.__class__=='function'; wave 273; new to extra146"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingthread146

  columns: [id, function, args, expected, description]
  rows:
    - [thread_doc_len_eq_247,
       "Thread.__doc__.__len__",
       [],
       247,
       "threading.Thread.__doc__.__len__() == 247 — the Thread class docstring has 247 characters; Thread is the main class for representing thread activity; len(__doc__) == 247; verified with Python 3.14.3; new to extra146"]
    - [thread_dict_class_eq_mappingproxy,
       "Thread.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "threading.Thread.__dict__.__class__.__name__.__eq__('mappingproxy') == True — all Python type objects expose __dict__ as a read-only mappingproxy; Thread is a Python class so its namespace is wrapped in a mappingproxy; str.__eq__('mappingproxy') returns True; new to extra146"]
    - [thread_mro_len_eq_2,
       "Thread.__mro__.__len__",
       [],
       2,
       "threading.Thread.__mro__.__len__() == 2 — Thread inherits directly from object; MRO is [Thread, object]; len(__mro__) is 2; new to extra146"]
    - [thread_init_class_eq_function,
       "Thread.__init__.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Thread.__init__.__class__.__name__.__eq__('function') == True — Thread is a Python class so its __init__ is a plain Python function (not a wrapper_descriptor as for C types); __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra146"]

# ---------------------------------------------------------------------------
# Table 4: threading.BoundedSemaphore class identity
#
# Wave 273 theme: threading.BoundedSemaphore — Semaphore subclass.
#
# threading.BoundedSemaphore.__name__ == 'BoundedSemaphore' (len 16)
# threading.BoundedSemaphore.__module__ == 'threading'
# threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'
# len(threading.BoundedSemaphore.__mro__) == 3
#
# BoundedSemaphore subclasses Semaphore; its MRO is
# [BoundedSemaphore, Semaphore, object] (length 3). New to extra146.
# ---------------------------------------------------------------------------

table threading_extra146.bounded_semaphore_identity:
  description: "threading.BoundedSemaphore: __name__ 'BoundedSemaphore' len 16, __module__ 'threading', __bases__[0]=='Semaphore', MRO len 3; wave 273; new to extra146"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingboundsem146

  columns: [id, function, args, expected, description]
  rows:
    - [boundedsemaphore_class_name_eq_type,
       "BoundedSemaphore.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.BoundedSemaphore.__class__.__name__.__eq__('type') == True — BoundedSemaphore is a Python class defined in Lib/threading.py; its metaclass is the built-in type; str.__eq__('type') returns True; new to extra146"]
    - [boundedsemaphore_name_eq,
       "BoundedSemaphore.__name__.__eq__",
       ["BoundedSemaphore"],
       true,
       "threading.BoundedSemaphore.__name__.__eq__('BoundedSemaphore') == True — the class __name__ is 'BoundedSemaphore'; str.__eq__('BoundedSemaphore') returns True; new to extra146"]
    - [boundedsemaphore_name_len_eq_16,
       "BoundedSemaphore.__name__.__len__",
       [],
       16,
       "threading.BoundedSemaphore.__name__.__len__() == 16 — __name__ is 'BoundedSemaphore' which has 16 characters; len('BoundedSemaphore') == 16; new to extra146"]
    - [boundedsemaphore_module_eq_threading,
       "BoundedSemaphore.__module__.__eq__",
       ["threading"],
       true,
       "threading.BoundedSemaphore.__module__.__eq__('threading') == True — BoundedSemaphore is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra146"]
    - [boundedsemaphore_bases_first_eq_Semaphore,
       "BoundedSemaphore.__bases__[0].__name__.__eq__",
       ["Semaphore"],
       true,
       "threading.BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore') == True — BoundedSemaphore is defined as 'class BoundedSemaphore(Semaphore):'; its single base class is Semaphore; __bases__[0].__name__ is 'Semaphore'; str.__eq__('Semaphore') returns True; new to extra146"]
    - [boundedsemaphore_mro_len_eq_3,
       "BoundedSemaphore.__mro__.__len__",
       [],
       3,
       "threading.BoundedSemaphore.__mro__.__len__() == 3 — BoundedSemaphore inherits from Semaphore which inherits from object; MRO is [BoundedSemaphore, Semaphore, object]; len(__mro__) is 3; new to extra146"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra146
# ---------------------------------------------------------------------------

invariant threading_extra146.local_name:
  description: "threading.local.__name__ == '_local' — the C extension type name is '_local' with underscore; wave 273; new to extra146"
  kind: python_call_eq
  function: local.__name__.__eq__
  args: ["_local"]
  expected: true

invariant threading_extra146.local_mro_len:
  description: "len(threading.local.__mro__) == 2 — MRO is [_local, object]; wave 273; new to extra146"
  kind: python_call_eq
  function: local.__mro__.__len__
  args: []
  expected: 2

invariant threading_extra146.local_init_class:
  description: "threading.local.__init__.__class__.__name__ == 'wrapper_descriptor' — C extension __init__ is a wrapper_descriptor on the type; wave 273; new to extra146"
  kind: python_call_eq
  function: local.__init__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant threading_extra146.local_dict_class:
  description: "threading.local.__dict__.__class__.__name__ == 'mappingproxy' — type __dict__ is always a mappingproxy; wave 273; new to extra146"
  kind: python_call_eq
  function: local.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant threading_extra146.local_doc_len:
  description: "len(threading.local.__doc__) == 17 — __doc__ is 'Thread-local data'; wave 273; new to extra146"
  kind: python_call_eq
  function: local.__doc__.__len__
  args: []
  expected: 17

invariant threading_extra146.timeout_max_is_float:
  description: "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is a float constant; wave 273; new to extra146"
  kind: python_call_eq
  function: TIMEOUT_MAX.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant threading_extra146.module_name_len:
  description: "len(threading.__name__) == 9 — __name__ is 'threading'; wave 273; new to extra146"
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 9

invariant threading_extra146.module_doc_len:
  description: "len(threading.__doc__) == 59 — threading module docstring has 59 characters; wave 273; new to extra146"
  kind: python_call_eq
  function: __doc__.__len__
  args: []
  expected: 59

invariant threading_extra146.thread_dict_class:
  description: "threading.Thread.__dict__.__class__.__name__ == 'mappingproxy' — Python class __dict__ is a mappingproxy; wave 273; new to extra146"
  kind: python_call_eq
  function: Thread.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant threading_extra146.thread_doc_len:
  description: "len(threading.Thread.__doc__) == 247 — Thread class docstring has 247 characters; wave 273; new to extra146"
  kind: python_call_eq
  function: Thread.__doc__.__len__
  args: []
  expected: 247

invariant threading_extra146.boundedsemaphore_name_len:
  description: "len(threading.BoundedSemaphore.__name__) == 16 — __name__ is 'BoundedSemaphore'; wave 273; new to extra146"
  kind: python_call_eq
  function: BoundedSemaphore.__name__.__len__
  args: []
  expected: 16

invariant threading_extra146.boundedsemaphore_mro_len:
  description: "len(threading.BoundedSemaphore.__mro__) == 3 — MRO is [BoundedSemaphore, Semaphore, object]; wave 273; new to extra146"
  kind: python_call_eq
  function: BoundedSemaphore.__mro__.__len__
  args: []
  expected: 3
