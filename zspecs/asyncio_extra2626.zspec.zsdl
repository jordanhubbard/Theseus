spec: asyncio_extra2626
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
  notes:
    - "Wave 622 theme: __length_hint__, __missing__, and __reversed__ dict-presence checks."
    - "None of the asyncio classes (Queue, Task, Future, Lock, Event, Semaphore, Condition, Barrier, StreamReader) define __length_hint__, __missing__, or __reversed__ in their own __dict__."
    - "__length_hint__ is an iterator protocol method; asyncio classes are not iterators/sized-iterators."
    - "__missing__ is a dict fallback method; asyncio classes are not dict subclasses."
    - "__reversed__ is a reversed-iteration protocol method; asyncio classes are not sequences."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __length_hint__ dict-presence — asyncio classes
#
# None of Queue, Task, Future, Lock, Event, Semaphore, Condition, Barrier,
# or StreamReader define __length_hint__ in their own __dict__.
# ---------------------------------------------------------------------------

table asyncio_extra2626.length_hint_checks:
  description: "asyncio classes do NOT define __length_hint__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2626
  columns: [id, function, args, expected]
  rows:
    - ["as2626001", "asyncio.Queue.__dict__.__contains__",       ["__length_hint__"], false]
    - ["as2626002", "asyncio.Task.__dict__.__contains__",        ["__length_hint__"], false]
    - ["as2626003", "asyncio.Future.__dict__.__contains__",      ["__length_hint__"], false]
    - ["as2626004", "asyncio.Lock.__dict__.__contains__",        ["__length_hint__"], false]
    - ["as2626005", "asyncio.Event.__dict__.__contains__",       ["__length_hint__"], false]
    - ["as2626006", "asyncio.Semaphore.__dict__.__contains__",   ["__length_hint__"], false]
    - ["as2626007", "asyncio.Condition.__dict__.__contains__",   ["__length_hint__"], false]
    - ["as2626008", "asyncio.Barrier.__dict__.__contains__",     ["__length_hint__"], false]
    - ["as2626009", "asyncio.StreamReader.__dict__.__contains__", ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# __missing__ dict-presence — asyncio classes
#
# None of the asyncio classes define __missing__ in their own __dict__.
# __missing__ is a dict-subclass hook and is unrelated to asyncio classes.
# ---------------------------------------------------------------------------

table asyncio_extra2626.missing_checks:
  description: "asyncio classes do NOT define __missing__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2626
  columns: [id, function, args, expected]
  rows:
    - ["as2626010", "asyncio.Queue.__dict__.__contains__",        ["__missing__"], false]
    - ["as2626011", "asyncio.Task.__dict__.__contains__",         ["__missing__"], false]
    - ["as2626012", "asyncio.Future.__dict__.__contains__",       ["__missing__"], false]
    - ["as2626013", "asyncio.Lock.__dict__.__contains__",         ["__missing__"], false]
    - ["as2626014", "asyncio.Event.__dict__.__contains__",        ["__missing__"], false]
    - ["as2626015", "asyncio.Semaphore.__dict__.__contains__",    ["__missing__"], false]
    - ["as2626016", "asyncio.Condition.__dict__.__contains__",    ["__missing__"], false]
    - ["as2626017", "asyncio.Barrier.__dict__.__contains__",      ["__missing__"], false]
    - ["as2626018", "asyncio.StreamReader.__dict__.__contains__", ["__missing__"], false]

# ---------------------------------------------------------------------------
# __reversed__ dict-presence — asyncio classes
#
# None of the asyncio classes define __reversed__ in their own __dict__.
# __reversed__ is a sequence/iterator protocol method unrelated to asyncio
# concurrency primitives.
# ---------------------------------------------------------------------------

table asyncio_extra2626.reversed_checks:
  description: "asyncio classes do NOT define __reversed__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2626
  columns: [id, function, args, expected]
  rows:
    - ["as2626019", "asyncio.Queue.__dict__.__contains__",        ["__reversed__"], false]
    - ["as2626020", "asyncio.Task.__dict__.__contains__",         ["__reversed__"], false]
    - ["as2626021", "asyncio.Future.__dict__.__contains__",       ["__reversed__"], false]
    - ["as2626022", "asyncio.Lock.__dict__.__contains__",         ["__reversed__"], false]
    - ["as2626023", "asyncio.Event.__dict__.__contains__",        ["__reversed__"], false]
    - ["as2626024", "asyncio.Semaphore.__dict__.__contains__",    ["__reversed__"], false]
    - ["as2626025", "asyncio.Condition.__dict__.__contains__",    ["__reversed__"], false]
    - ["as2626026", "asyncio.Barrier.__dict__.__contains__",      ["__reversed__"], false]
    - ["as2626027", "asyncio.StreamReader.__dict__.__contains__", ["__reversed__"], false]

# ---------------------------------------------------------------------------
# Cross-check: all three dunders absent from Queue, Task, and Future
#
# Consolidating the negative results for the three most-used asyncio classes
# to confirm all three wave-622 dunders are absent from their own __dict__.
# ---------------------------------------------------------------------------

table asyncio_extra2626.combined_absent_checks:
  description: "asyncio Queue, Task, and Future each lack all three wave-622 dunders in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2626
  columns: [id, function, args, expected]
  rows:
    - ["as2626028", "asyncio.Queue.__dict__.__contains__",   ["__length_hint__"], false]
    - ["as2626029", "asyncio.Queue.__dict__.__contains__",   ["__missing__"],     false]
    - ["as2626030", "asyncio.Queue.__dict__.__contains__",   ["__reversed__"],    false]
    - ["as2626031", "asyncio.Task.__dict__.__contains__",    ["__length_hint__"], false]
    - ["as2626032", "asyncio.Task.__dict__.__contains__",    ["__missing__"],     false]
    - ["as2626033", "asyncio.Task.__dict__.__contains__",    ["__reversed__"],    false]
    - ["as2626034", "asyncio.Future.__dict__.__contains__",  ["__length_hint__"], false]
    - ["as2626035", "asyncio.Future.__dict__.__contains__",  ["__missing__"],     false]
    - ["as2626036", "asyncio.Future.__dict__.__contains__",  ["__reversed__"],    false]
