spec: struct_extra228
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.Struct.__mro__[0].__name__ == 'Struct' — MRO head is Struct itself."
    - "struct.Struct.__mro__[1].__name__ == 'object' — MRO tail is object."
    - "len(struct.Struct.__mro__) == 2 — Struct MRO has exactly 2 entries (Struct, object)."
    - "struct.pack('!H', 1).__class__.__name__ == 'bytes' — pack() returns bytes."
    - "struct.unpack('!H', b'\\x00\\x01').__class__.__name__ == 'tuple' — unpack() returns tuple."
    - "struct.pack('B', 0).__len__() == 1 — packing a single unsigned byte yields 1 byte."
    - "struct.pack('H', 0).__len__() == 2 — packing unsigned short yields 2 bytes."
    - "struct.pack('I', 0).__len__() == 4 — packing unsigned int yields 4 bytes."
    - "struct.Struct.pack.__qualname__ == 'Struct.pack' — Struct instance method qualname."
    - "struct.Struct.unpack.__qualname__ == 'Struct.unpack' — Struct instance method qualname."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct MRO contracts
#
# struct.Struct.__mro__[0].__name__ == 'Struct'
# struct.Struct.__mro__[1].__name__ == 'object'
# len(struct.Struct.__mro__)         == 2
#
# struct.Struct is a C-extension class (Modules/_struct.c) that inherits
# directly from object with no intermediate base classes. Its MRO has
# exactly 2 entries: [Struct, object].
# ---------------------------------------------------------------------------

table struct_extra228.struct_mro_entries:
  description: "Struct.__mro__[0].__name__=='Struct'; Struct.__mro__[1].__name__=='object'; len(Struct.__mro__)==2; struct.Struct MRO contracts; new to extra228"
  kind: python_call_eq
  category: mro
  id_prefix: struct228

  columns: [id, function, args, expected, description]
  rows:
    - [struct_mro_len_2,
       "Struct.__mro__.__len__",
       [],
       2,
       "struct.Struct.__mro__.__len__() == 2 — Struct inherits directly from object; MRO has exactly 2 entries; new anchor in extra228 namespace; verified Python 3.14.3"]

invariant struct_extra228.struct_mro_0:
  description: "struct.Struct.__mro__[0].__name__ == 'Struct' — MRO head is the class itself"
  category: mro
  kind: python_call_eq
  function: Struct.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "Struct"

invariant struct_extra228.struct_mro_1:
  description: "struct.Struct.__mro__[1].__name__ == 'object' — MRO tail is object; Struct has no intermediate base classes"
  category: mro
  kind: python_call_eq
  function: Struct.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# struct.pack / struct.unpack result type contracts
#
# struct.pack('!H', 1).__class__.__name__            == 'bytes'
# struct.unpack('!H', b'\x00\x01').__class__.__name__ == 'tuple'
#
# pack() always returns a bytes object containing the packed binary data.
# unpack() always returns a tuple whose elements are the unpacked values.
# These types are invariant regardless of format string or platform.
# ---------------------------------------------------------------------------

table struct_extra228.pack_unpack_result_types:
  description: "pack result type is 'bytes'; unpack result type is 'tuple'; pack/unpack return type contracts; new to extra228"
  kind: python_call_eq
  category: result_type
  id_prefix: struct228a

  columns: [id, function, args, expected, description]
  rows:
    - [pack_returns_bytes,
       "pack.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "struct.pack.__class__.__name__.__eq__('builtin_function_or_method') == True — pack is a C-extension function (builtin_function_or_method); confirms it is not a Python function; new anchor in extra228 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.pack output length contracts
#
# struct.pack('B', 0).__len__() == 1  — unsigned char: 1 byte
# struct.pack('H', 0).__len__() == 2  — unsigned short: 2 bytes
# struct.pack('I', 0).__len__() == 4  — unsigned int: 4 bytes
#
# The byte length of struct.pack output is determined by the format
# character under native byte order. 'B'=1, 'H'=2, 'I'=4.
# ---------------------------------------------------------------------------

table struct_extra228.pack_output_lengths:
  description: "pack('B',0) len==1; pack('H',0) len==2; pack('I',0) len==4; pack output byte length contracts; new to extra228"
  kind: python_call_eq
  category: output_length
  id_prefix: struct228b

  columns: [id, function, args, expected, description]
  rows:
    - [pack_B_len_1,
       "pack.__call__",
       ["B", 0],
       null,
       "struct.pack('B', 0) returns bytes of length 1 — format 'B' is unsigned char (1 byte); portable size contract; new anchor in extra228 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.Struct instance method qualname contracts
#
# struct.Struct.pack.__qualname__         == 'Struct.pack'
# struct.Struct.unpack.__qualname__       == 'Struct.unpack'
# struct.Struct.pack_into.__qualname__    == 'Struct.pack_into'
# struct.Struct.unpack_from.__qualname__  == 'Struct.unpack_from'
#
# Struct instance methods have qualnames prefixed with 'Struct.' (7 chars).
# pack and unpack qualnames are 11 and 13 characters respectively.
# ---------------------------------------------------------------------------

table struct_extra228.struct_method_qualnames:
  description: "Struct.pack.__qualname__=='Struct.pack'; Struct.unpack.__qualname__=='Struct.unpack'; Struct.pack_into.__qualname__=='Struct.pack_into'; Struct.unpack_from.__qualname__=='Struct.unpack_from'; Struct method qualname contracts; new to extra228"
  kind: python_call_eq
  category: identity
  id_prefix: struct228c

  columns: [id, function, args, expected, description]
  rows:
    - [struct_pack_qualname_eq,
       "Struct.pack.__qualname__.__eq__",
       ["Struct.pack"],
       true,
       "struct.Struct.pack.__qualname__.__eq__('Struct.pack') == True — Struct.pack packs values using the pre-compiled format; __qualname__ is 'Struct.pack' (11 characters); new anchor in extra228 namespace; verified Python 3.14.3"]
    - [struct_unpack_qualname_eq,
       "Struct.unpack.__qualname__.__eq__",
       ["Struct.unpack"],
       true,
       "struct.Struct.unpack.__qualname__.__eq__('Struct.unpack') == True — Struct.unpack unpacks bytes using the pre-compiled format returning a tuple; __qualname__ is 'Struct.unpack' (13 characters); new anchor in extra228 namespace; verified Python 3.14.3"]
    - [struct_pack_into_qualname_eq,
       "Struct.pack_into.__qualname__.__eq__",
       ["Struct.pack_into"],
       true,
       "struct.Struct.pack_into.__qualname__.__eq__('Struct.pack_into') == True — Struct.pack_into packs into a buffer at a given offset; __qualname__ is 'Struct.pack_into' (16 characters); new anchor in extra228 namespace; verified Python 3.14.3"]
    - [struct_unpack_from_qualname_eq,
       "Struct.unpack_from.__qualname__.__eq__",
       ["Struct.unpack_from"],
       true,
       "struct.Struct.unpack_from.__qualname__.__eq__('Struct.unpack_from') == True — Struct.unpack_from unpacks from a buffer at a given offset; __qualname__ is 'Struct.unpack_from' (18 characters); longest of the listed Struct method qualnames; new anchor in extra228 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant struct_extra228.struct_mro_len_2:
  description: "struct.Struct.__mro__.__len__() == 2 — struct.Struct is a C-extension class implemented in Modules/_struct.c; it inherits directly from object with no intermediate abstract base classes or mixin classes; the MRO therefore contains exactly two entries: [Struct, object]; this minimal two-entry MRO distinguishes Struct from classes that inherit from collections.abc or other abstract bases; extra228 is the first namespace to anchor Struct.__mro__.__len__() as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: mro
  kind: python_call_eq
  function: "Struct.__mro__.__len__"
  args: []
  expected: 2

invariant struct_extra228.struct_pack_qualname_eq:
  description: "struct.Struct.pack.__qualname__.__eq__('Struct.pack') == True — Struct.pack is an instance method that packs values using the format string compiled into the Struct instance (avoiding re-parsing the format on each call); its __qualname__ is 'Struct.pack' (11 characters: 'Struct.' (7) + 'pack' (4)); this contrasts with the module-level struct.pack whose __qualname__ is just 'pack' (4 characters); the 'Struct.' prefix length of 7 is the same for all Struct instance methods; extra228 is the first namespace to anchor Struct.pack.__qualname__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "Struct.pack.__qualname__.__eq__"
  args: ["Struct.pack"]
  expected: true

invariant struct_extra228.struct_unpack_qualname_eq:
  description: "struct.Struct.unpack.__qualname__.__eq__('Struct.unpack') == True — Struct.unpack unpacks bytes using the pre-compiled format and returns a tuple of values; its __qualname__ is 'Struct.unpack' (13 characters: 'Struct.' (7) + 'unpack' (6)); this contrasts with module-level struct.unpack whose __qualname__ is 'unpack' (6 characters); extra228 is the first namespace to anchor Struct.unpack.__qualname__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "Struct.unpack.__qualname__.__eq__"
  args: ["Struct.unpack"]
  expected: true
