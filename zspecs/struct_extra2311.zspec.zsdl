spec: struct_extra2311
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/struct.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 601 (_extra2311): __abstractmethods__ absence checks and additional dict-presence."
    - "struct.Struct is a C extension type with no abstract methods."
    - "struct.error is a pure-Python Exception subclass with no abstract methods."
    - "__abstractmethods__ is absent from both class dicts; accessing it raises AttributeError."
    - "Additional dict-presence checks confirm that sequence, buffer, and numeric dunders are not defined directly on struct.Struct."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __abstractmethods__ absence from __dict__ — struct.Struct and struct.error
#
# Neither struct.Struct nor struct.error is abstract. __abstractmethods__ is
# absent from both class dicts. All expected false.
# ---------------------------------------------------------------------------

table struct_extra2311.struct_abstract:
  description: "struct.Struct and struct.error __abstractmethods__ absence — wave 601 _extra2311"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2311
  columns: [id, function, args, expected]
  rows:
    - ["st2311001", "struct.Struct.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["st2311002", "struct.error.__dict__.__contains__", ["__abstractmethods__"], false]

# ---------------------------------------------------------------------------
# Table 2: __abstractmethods__ direct attribute access raises AttributeError
#
# Since __abstractmethods__ is absent from both class dicts and is not
# inherited, accessing it raises AttributeError for both types.
# ---------------------------------------------------------------------------

table struct_extra2311.struct_abstract_attr_error:
  description: "struct types raise AttributeError on __abstractmethods__ access — wave 601 _extra2311"
  kind: python_call_raises
  category: attribute_access
  id_prefix: st2311
  columns: [id, function, args, expected]
  rows:
    - ["st2311003", "struct.Struct.__abstractmethods__.__len__", [], "AttributeError"]
    - ["st2311004", "struct.error.__abstractmethods__.__len__", [], "AttributeError"]
    - ["st2311005", "struct.Struct.__abstractmethods__.__contains__", ["pack"], "AttributeError"]
    - ["st2311006", "struct.error.__abstractmethods__.__contains__", ["args"], "AttributeError"]

# ---------------------------------------------------------------------------
# Table 3: struct.Struct dict-presence for sequence/format/numeric dunders
#
# struct.Struct is a binary packing helper, not a sequence or numeric type.
# None of these dunders appear in struct.Struct.__dict__ directly.
# All expected false.
# ---------------------------------------------------------------------------

table struct_extra2311.struct_dict_contains:
  description: "struct.Struct dict-presence checks for unimplemented protocol dunders — wave 601 _extra2311"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2311
  columns: [id, function, args, expected]
  rows:
    - ["st2311007", "struct.Struct.__dict__.__contains__", ["__format__"], false]
    - ["st2311008", "struct.Struct.__dict__.__contains__", ["__bytes__"], false]
    - ["st2311009", "struct.Struct.__dict__.__contains__", ["__contains__"], false]
    - ["st2311010", "struct.Struct.__dict__.__contains__", ["__iter__"], false]
    - ["st2311011", "struct.Struct.__dict__.__contains__", ["__add__"], false]
    - ["st2311012", "struct.Struct.__dict__.__contains__", ["__mul__"], false]
    - ["st2311013", "struct.Struct.__dict__.__contains__", ["__len__"], false]

# ---------------------------------------------------------------------------
# Table 4: struct.error dict-presence for exception and protocol dunders
#
# struct.error is an Exception subclass. Common dunders it does not override
# directly are not in its own __dict__. All expected false.
# ---------------------------------------------------------------------------

table struct_extra2311.struct_error_dict_contains:
  description: "struct.error dict-presence checks for unimplemented dunders — wave 601 _extra2311"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2311
  columns: [id, function, args, expected]
  rows:
    - ["st2311014", "struct.error.__dict__.__contains__", ["__format__"], false]
    - ["st2311015", "struct.error.__dict__.__contains__", ["__bytes__"], false]
    - ["st2311016", "struct.error.__dict__.__contains__", ["__contains__"], false]
    - ["st2311017", "struct.error.__dict__.__contains__", ["__iter__"], false]
    - ["st2311018", "struct.error.__dict__.__contains__", ["__add__"], false]
    - ["st2311019", "struct.error.__dict__.__contains__", ["__mul__"], false]
    - ["st2311020", "struct.error.__dict__.__contains__", ["__len__"], false]
    - ["st2311021", "struct.error.__dict__.__contains__", ["__buffer__"], false]
    - ["st2311022", "struct.error.__dict__.__contains__", ["__release_buffer__"], false]
