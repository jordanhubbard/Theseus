spec: re_extra1036
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module Pattern and Match documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks re.Pattern and re.Match attribute descriptor class names via getset_descriptor"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra1036.pattern_attr_descriptors:
  description: "re.Pattern attribute descriptor class name checks"
  kind: python_call_eq
  category: pattern_attr_descriptors
  id_prefix: re1036pa
  columns: [id, function, args, expected]
  rows:
    - [re1036pa001, re.Pattern.pattern.__class__.__name__.__eq__,    ["getset_descriptor"], true]
    - [re1036pa002, re.Pattern.flags.__class__.__name__.__eq__,      ["getset_descriptor"], true]
    - [re1036pa003, re.Pattern.groups.__class__.__name__.__eq__,     ["getset_descriptor"], true]
    - [re1036pa004, re.Pattern.groupindex.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [re1036pa005, re.Pattern.__doc__.__class__.__name__.__eq__,    ["str"],               true]
    - [re1036pa006, re.Pattern.__class__.__name__.__eq__,            ["type"],              true]

table re_extra1036.match_attr_descriptors:
  description: "re.Match attribute descriptor class name checks"
  kind: python_call_eq
  category: match_attr_descriptors
  id_prefix: re1036ma
  columns: [id, function, args, expected]
  rows:
    - [re1036ma001, re.Match.pos.__class__.__name__.__eq__,    ["getset_descriptor"], true]
    - [re1036ma002, re.Match.endpos.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [re1036ma003, re.Match.re.__class__.__name__.__eq__,     ["getset_descriptor"], true]
    - [re1036ma004, re.Match.string.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [re1036ma005, re.Match.lastindex.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [re1036ma006, re.Match.lastgroup.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [re1036ma007, re.Match.__doc__.__class__.__name__.__eq__, ["str"],               true]

table re_extra1036.module_identity:
  description: "re module-level class and constant identity checks"
  kind: python_call_eq
  category: module_identity
  id_prefix: re1036mi
  columns: [id, function, args, expected]
  rows:
    - [re1036mi001, re.Pattern.__name__.__eq__,      ["re.Pattern"], true]
    - [re1036mi002, re.Match.__name__.__eq__,         ["re.Match"],   true]
    - [re1036mi003, re.error.__name__.__eq__,         ["error"],      true]
    - [re1036mi004, re.error.__module__.__eq__,       ["re"],         true]
    - [re1036mi005, re.error.__class__.__name__.__eq__, ["type"],     true]
    - [re1036mi006, re.Match.__class__.__name__.__eq__, ["type"],     true]
    - [re1036mi007, re.Pattern.__class__.__name__.__eq__, ["type"],   true]
