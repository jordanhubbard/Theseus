spec: abc_extra2086
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/abc.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2086 (_extra2086): __format__, __bytes__, __fspath__, __buffer__/__release_buffer__ dict-presence checks."
    - "abc.ABCMeta is the metaclass for abstract base classes; abc.ABC is a helper base class; abc.abstractmethod is a plain function decorator."
    - "None of these abc constructs define __format__, __bytes__, __fspath__, __buffer__, or __release_buffer__ in their own __dict__."
    - "__format__ is the string-formatting protocol; ABCMeta and ABC use the default type.__format__ / object.__format__."
    - "__bytes__ is the bytes-conversion protocol; abc constructs have no binary representation."
    - "__fspath__ is the filesystem-path protocol; abstract base class machinery is not path-like."
    - "__buffer__ and __release_buffer__ are the PEP 688 buffer protocol; abc constructs do not expose raw memory buffers."
    - "ABCMeta does define __instancecheck__ and __subclasscheck__ for isinstance/issubclass delegation, but none of the checked protocols."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table abc_extra2086.format_protocol:
  description: "abc.ABCMeta, abc.ABC, abc.abstractmethod __format__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2086

  columns: [id, function, args, expected]
  rows:
    - ["ab2086001", "abc.ABCMeta.__dict__.__contains__", ["__format__"], false]
    - ["ab2086002", "abc.ABC.__dict__.__contains__", ["__format__"], false]
    - ["ab2086003", "abc.abstractmethod.__dict__.__contains__", ["__format__"], false]

