spec: hashlib_extra2206
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/hashlib.html"
    - "CPython source: Modules/_blake2/"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave _extra2206: rich comparison operator protocol dict-presence — __lt__, __le__, __gt__, __ge__, __eq__, __ne__."
    - "hashlib.blake2b and hashlib.blake2s are C extension hash types from _blake2. They are NOT orderable and define none of the rich comparison operators in their own __dict__."
    - "blake2b and blake2s instances cannot be meaningfully ordered or equality-compared as objects; they are hash-accumulator types, not value types."
    - "blake2b.__dict__ contains: copy, digest, hexdigest, update, name, block_size, digest_size, SALT_SIZE, PERSON_SIZE, MAX_KEY_SIZE, MAX_DIGEST_SIZE."
    - "blake2s.__dict__ contains the same set of keys as blake2b."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table hashlib_extra2206.blake2b_rich_comparison_protocol:
  description: "hashlib.blake2b rich comparison operator protocol dict-presence — blake2b defines none of __lt__, __le__, __gt__, __ge__, __eq__, __ne__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2206

  columns: [id, function, args, expected]
  rows:
    - ["hl2206001", "hashlib.blake2b.__dict__.__contains__", ["__lt__"], false]
    - ["hl2206002", "hashlib.blake2b.__dict__.__contains__", ["__le__"], false]
    - ["hl2206003", "hashlib.blake2b.__dict__.__contains__", ["__gt__"], false]
    - ["hl2206004", "hashlib.blake2b.__dict__.__contains__", ["__ge__"], false]
    - ["hl2206005", "hashlib.blake2b.__dict__.__contains__", ["__eq__"], false]
    - ["hl2206006", "hashlib.blake2b.__dict__.__contains__", ["__ne__"], false]

