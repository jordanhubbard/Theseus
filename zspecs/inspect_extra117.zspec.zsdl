spec: inspect_extra117
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra116.zspec.zsdl."
    - "This spec covers: inspect.BlockFinder and inspect.EndOfBlock class attributes not yet covered — BlockFinder.__name__ ('BlockFinder', len 11), BlockFinder.__module__ ('inspect', len 7), BlockFinder.__bases__[0].__name__ ('object'), BlockFinder.__mro__.__len__ (2); EndOfBlock.__name__ ('EndOfBlock', len 10), EndOfBlock.__module__ ('inspect', len 7), EndOfBlock.__bases__[0].__name__ ('Exception'), EndOfBlock.__mro__.__len__ (4), EndOfBlock.__mro__ entry names; wave 268."
    - "inspect.BlockFinder.__name__ == 'BlockFinder'. Verified with Python 3.14.3."
    - "inspect.BlockFinder.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.BlockFinder.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "inspect.BlockFinder.__mro__.__len__() == 2. Verified with Python 3.14.3."
    - "inspect.EndOfBlock.__name__ == 'EndOfBlock'. Verified with Python 3.14.3."
    - "inspect.EndOfBlock.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.EndOfBlock.__bases__[0].__name__ == 'Exception'. Verified with Python 3.14.3."
    - "inspect.EndOfBlock.__mro__.__len__() == 4. Verified with Python 3.14.3."
    - "inspect.EndOfBlock.__mro__[0].__name__ == 'EndOfBlock'. Verified with Python 3.14.3."
    - "inspect.EndOfBlock.__mro__[1].__name__ == 'Exception'. Verified with Python 3.14.3."
    - "inspect.EndOfBlock.__mro__[2].__name__ == 'BaseException'. Verified with Python 3.14.3."
    - "inspect.EndOfBlock.__mro__[3].__name__ == 'object'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.BlockFinder class name, module, and MRO
#
# Wave 268 theme: inspect.BlockFinder is a pure-Python helper class defined in
# Lib/inspect.py that implements tokenize.TokenEater callbacks to detect block
# boundaries. Its __name__ is 'BlockFinder' (11 chars), __module__ is 'inspect'
# (7 chars), and it inherits directly from object — so its __mro__ has exactly
# 2 entries: BlockFinder (index 0) and object (index 1). __bases__[0].__name__
# is 'object'. Previously covered: none for BlockFinder specifically. New here:
# __name__, __module__, __bases__[0].__name__, __mro__.__len__, __name__.__len__.
#
# BlockFinder.__name__ == 'BlockFinder'       (len 11)
# BlockFinder.__module__ == 'inspect'         (len 7)
# BlockFinder.__bases__[0].__name__ == 'object'
# BlockFinder.__mro__.__len__() == 2
#
# New to extra117.
# ---------------------------------------------------------------------------

table inspect_extra117.blockfinder_class_attrs:
  description: "inspect.BlockFinder: __name__='BlockFinder'(11), __module__='inspect'(7), __bases__[0]='object', __mro__ len=2; pure-Python tokenizer helper; inherits directly from object; wave 268; new to extra117"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectbfca117

  columns: [id, function, args, expected, description]
  rows:
    - [blockfinder_name,
       "BlockFinder.__name__.__eq__",
       ["BlockFinder"],
       true,
       "inspect.BlockFinder.__name__.__eq__('BlockFinder') == True — the pure-Python tokenizer helper class name is 'BlockFinder'; defined in Lib/inspect.py; str.__eq__('BlockFinder') returns True; new to extra117"]
    - [blockfinder_name_len,
       "BlockFinder.__name__.__len__",
       [],
       11,
       "inspect.BlockFinder.__name__.__len__() == 11 — 'BlockFinder' has 11 chars: B-l-o-c-k(5)+F-i-n-d-e-r(6); str.__len__() returns 11; new to extra117"]
    - [blockfinder_module,
       "BlockFinder.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.BlockFinder.__module__.__eq__('inspect') == True — BlockFinder is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra117"]
    - [blockfinder_bases0_name,
       "BlockFinder.__bases__.__getitem__",
       [0],
       "object",
       "inspect.BlockFinder.__bases__[0].__name__ == 'object' — BlockFinder inherits directly from object with no intermediate base class; tuple.__getitem__(0).__name__ returns 'object'; new to extra117"]
    - [blockfinder_mro_len,
       "BlockFinder.__mro__.__len__",
       [],
       2,
       "inspect.BlockFinder.__mro__.__len__() == 2 — the MRO has 2 entries: [BlockFinder, object]; simple single-inheritance chain; tuple.__len__() returns 2; new to extra117"]

# ---------------------------------------------------------------------------
# Table 2: inspect.EndOfBlock class name, module, and MRO
#
# Wave 268 theme: inspect.EndOfBlock is a pure-Python exception class defined in
# Lib/inspect.py that BlockFinder raises to signal the end of a block. Its
# __name__ is 'EndOfBlock' (10 chars), __module__ is 'inspect' (7 chars), and
# it inherits from Exception. Its full MRO is [EndOfBlock, Exception,
# BaseException, object] — 4 entries. BlockFinder has 2 MRO entries while
# EndOfBlock has 4 (because Exception adds two more ancestors). Previously
# covered: none for EndOfBlock specifically. New here: __name__, __module__,
# __bases__[0].__name__, __mro__.__len__, and individual MRO entry names.
#
# EndOfBlock.__name__ == 'EndOfBlock'              (len 10)
# EndOfBlock.__module__ == 'inspect'               (len 7)
# EndOfBlock.__bases__[0].__name__ == 'Exception'
# EndOfBlock.__mro__.__len__() == 4
#
# New to extra117.
# ---------------------------------------------------------------------------

table inspect_extra117.endofblock_class_attrs:
  description: "inspect.EndOfBlock: __name__='EndOfBlock'(10), __module__='inspect'(7), __bases__[0]='Exception', __mro__ len=4 ([EndOfBlock, Exception, BaseException, object]); exception subclass; wave 268; new to extra117"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspecteobc117

  columns: [id, function, args, expected, description]
  rows:
    - [endofblock_name,
       "EndOfBlock.__name__.__eq__",
       ["EndOfBlock"],
       true,
       "inspect.EndOfBlock.__name__.__eq__('EndOfBlock') == True — the exception class used by BlockFinder to signal block end; defined in Lib/inspect.py; str.__eq__('EndOfBlock') returns True; new to extra117"]
    - [endofblock_name_len,
       "EndOfBlock.__name__.__len__",
       [],
       10,
       "inspect.EndOfBlock.__name__.__len__() == 10 — 'EndOfBlock' has 10 chars: E-n-d(3)+O-f(2)+B-l-o-c-k(5); 1 char shorter than BlockFinder (11); str.__len__() returns 10; new to extra117"]
    - [endofblock_module,
       "EndOfBlock.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.EndOfBlock.__module__.__eq__('inspect') == True — EndOfBlock is defined in Lib/inspect.py; __module__ is 'inspect'; same module as BlockFinder; str.__eq__('inspect') returns True; new to extra117"]
    - [endofblock_bases0_name,
       "EndOfBlock.__bases__.__getitem__",
       [0],
       "Exception",
       "inspect.EndOfBlock.__bases__[0].__name__ == 'Exception' — EndOfBlock inherits directly from Exception; this gives it a 4-entry MRO vs BlockFinder's 2-entry MRO; tuple.__getitem__(0).__name__ returns 'Exception'; new to extra117"]
    - [endofblock_mro_len,
       "EndOfBlock.__mro__.__len__",
       [],
       4,
       "inspect.EndOfBlock.__mro__.__len__() == 4 — the MRO is [EndOfBlock, Exception, BaseException, object]; inheriting from Exception adds 2 ancestors beyond object; tuple.__len__() returns 4; new to extra117"]
    - [endofblock_mro1_name,
       "EndOfBlock.__mro__.__getitem__",
       [1],
       "Exception",
       "inspect.EndOfBlock.__mro__[1].__name__ == 'Exception' — the second MRO entry is the direct base class Exception; tuple.__getitem__(1).__name__ returns 'Exception'; new to extra117"]

# ---------------------------------------------------------------------------
# Table 3: BlockFinder vs EndOfBlock class attribute comparison
#
# Wave 268 theme: BlockFinder and EndOfBlock are companion classes in inspect.py
# — BlockFinder uses tokenize callbacks to find blocks, raising EndOfBlock when
# done. Both have __module__ == 'inspect' (7 chars). BlockFinder.__name__ has 11
# chars vs EndOfBlock.__name__ has 10 chars. BlockFinder.__mro__.__len__ is 2
# (inherits from object) while EndOfBlock.__mro__.__len__ is 4 (inherits from
# Exception which itself inherits from BaseException and object). The MRO length
# difference (4 - 2 = 2) matches the extra ancestors added by Exception.
#
# Both: __module__ == 'inspect'   (len 7)
# BlockFinder: __name__ len 11, __mro__ len 2
# EndOfBlock:  __name__ len 10, __mro__ len 4
#
# New to extra117.
# ---------------------------------------------------------------------------

table inspect_extra117.blockfinder_vs_endofblock:
  description: "inspect BlockFinder vs EndOfBlock: both module='inspect'(7); BlockFinder name len=11 mro len=2; EndOfBlock name len=10 mro len=4; MRO length difference=2 from Exception ancestry; wave 268; new to extra117"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectbfvseob117

  columns: [id, function, args, expected, description]
  rows:
    - [bf_module_len,
       "BlockFinder.__module__.__len__",
       [],
       7,
       "inspect.BlockFinder.__module__.__len__() == 7 — 'inspect' has 7 chars; same as EndOfBlock.__module__.__len__(); both classes share the same module; str.__len__() returns 7; new to extra117"]
    - [eob_module_len,
       "EndOfBlock.__module__.__len__",
       [],
       7,
       "inspect.EndOfBlock.__module__.__len__() == 7 — 'inspect' has 7 chars; same as BlockFinder.__module__.__len__(); str.__len__() returns 7; new to extra117"]
    - [bf_name_len_11,
       "BlockFinder.__name__.__len__",
       [],
       11,
       "inspect.BlockFinder.__name__.__len__() == 11 — 'BlockFinder' has 11 chars; 1 more than EndOfBlock (10); str.__len__() returns 11; new to extra117"]
    - [eob_name_len_10,
       "EndOfBlock.__name__.__len__",
       [],
       10,
       "inspect.EndOfBlock.__name__.__len__() == 10 — 'EndOfBlock' has 10 chars; 1 fewer than BlockFinder (11); str.__len__() returns 10; new to extra117"]
    - [bf_mro_len_2,
       "BlockFinder.__mro__.__len__",
       [],
       2,
       "inspect.BlockFinder.__mro__.__len__() == 2 — [BlockFinder, object]; inherits directly from object; half the MRO length of EndOfBlock (4); tuple.__len__() returns 2; new to extra117"]
    - [eob_mro_len_4,
       "EndOfBlock.__mro__.__len__",
       [],
       4,
       "inspect.EndOfBlock.__mro__.__len__() == 4 — [EndOfBlock, Exception, BaseException, object]; inheriting from Exception adds 2 more MRO entries vs BlockFinder; tuple.__len__() returns 4; new to extra117"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra117
# ---------------------------------------------------------------------------

invariant inspect_extra117.blockfinder_name:
  description: "inspect.BlockFinder.__name__ == 'BlockFinder' — pure-Python tokenizer helper class; name length 11; wave 268; new to extra117"
  kind: python_call_eq
  function: BlockFinder.__name__.__eq__
  args: ["BlockFinder"]
  expected: true

invariant inspect_extra117.blockfinder_bases0_object:
  description: "inspect.BlockFinder.__bases__[0].__name__ == 'object' — BlockFinder inherits directly from object; 2-entry MRO; wave 268; new to extra117"
  kind: python_call_eq
  function: "BlockFinder.__bases__.__getitem__"
  args: [0]
  expected: "object"

invariant inspect_extra117.endofblock_name:
  description: "inspect.EndOfBlock.__name__ == 'EndOfBlock' — exception signaling block end; name length 10; wave 268; new to extra117"
  kind: python_call_eq
  function: EndOfBlock.__name__.__eq__
  args: ["EndOfBlock"]
  expected: true

invariant inspect_extra117.endofblock_bases0_exception:
  description: "inspect.EndOfBlock.__bases__[0].__name__ == 'Exception' — EndOfBlock inherits from Exception; gives 4-entry MRO; wave 268; new to extra117"
  kind: python_call_eq
  function: "EndOfBlock.__bases__.__getitem__"
  args: [0]
  expected: "Exception"

invariant inspect_extra117.endofblock_mro_len:
  description: "inspect.EndOfBlock.__mro__.__len__() == 4 — MRO is [EndOfBlock, Exception, BaseException, object]; 4 entries vs BlockFinder's 2; wave 268; new to extra117"
  kind: python_call_eq
  function: EndOfBlock.__mro__.__len__
  args: []
  expected: 4
