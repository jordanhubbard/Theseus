spec: io3196
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io: Core tools for working with streams"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 660 (io3196): __pow__, __lshift__, __rshift__ dict-presence checks for io types."
    - "Classes covered: io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.FileIO, io.BytesIO, io.StringIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.BufferedRWPair, io.TextIOWrapper."
    - "No io class defines __pow__ in its own __dict__: stream I/O classes are not numeric types and do not implement the exponentiation operator."
    - "No io class defines __lshift__ in its own __dict__: stream I/O classes are not integer types and do not implement the left-shift operator."
    - "No io class defines __rshift__ in its own __dict__: stream I/O classes are not integer types and do not implement the right-shift operator."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __pow__ dict-presence — operator.contains(Cls.__dict__, '__pow__')
#
# No io class defines __pow__ in its own __dict__; all false.
# io stream classes are sequential I/O abstractions, not numeric types.
# ---------------------------------------------------------------------------

table io3196.pow:
  description: "io types __pow__ dict-presence checks; wave 660"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
