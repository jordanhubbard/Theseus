spec: multiprocessing_extra554
backend: python_module(multiprocessing.pool)
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html#module-multiprocessing.pool — multiprocessing.pool API"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers Pool async method names and result class name/module attributes"
    - "AsyncResult is an alias for ApplyResult; both names are tested separately"
    - "IMapUnorderedIterator is the result type returned by Pool.imap_unordered"
  created_at: "2026-04-12T00:00:00Z"

