# __ge__:   PurePath=true; PurePosixPath, PureWindowsPath, Path, PosixPath=false.
# __repr__: PurePath=true; PurePosixPath, PureWindowsPath, Path, PosixPath=false.
# __str__:  PurePath=true; PurePosixPath, PureWindowsPath, Path, PosixPath=false.
# ---------------------------------------------------------------------------

