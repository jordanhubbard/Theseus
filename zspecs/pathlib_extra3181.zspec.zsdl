    - ["pp3181012", operator.contains, [pathlib.PurePosixPath.__dict__,   "__mod__"], false]
    - ["pp3181013", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__mod__"], false]
    - ["pp3181014", operator.contains, [pathlib.Path.__dict__,             "__mod__"], false]
    - ["pp3181015", operator.contains, [pathlib.PosixPath.__dict__,        "__mod__"], false]

