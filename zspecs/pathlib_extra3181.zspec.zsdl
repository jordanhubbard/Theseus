spec: pp3181
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 659 (pp3181): __truediv__, __floordiv__, __mod__ dict-presence checks for pathlib types."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS only)."
    - "pathlib.PurePath defines __truediv__ in its own __dict__ (true): the / operator is the canonical path-joining API (e.g. Path('/foo') / 'bar')."
    - "pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, and pathlib.PosixPath do NOT define __truediv__ in their own __dict__: they inherit it from PurePath."
    - "No pathlib class defines __floordiv__ in its own __dict__: path objects do not support floor division."
    - "No pathlib class defines __mod__ in its own __dict__: path objects do not support the modulo operator."
    - "pathlib.PosixPath is available on macOS/POSIX systems and verified false for __truediv__, __floordiv__, and __mod__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __truediv__ dict-presence — operator.contains(Cls.__dict__, '__truediv__')
#
# pathlib.PurePath defines __truediv__ in its own __dict__ (true):
# the / operator is how pathlib implements path joining.
# Subclasses (PurePosixPath, PureWindowsPath, Path, PosixPath) inherit
# __truediv__ from PurePath and do not re-define it in their own __dict__.
# ---------------------------------------------------------------------------

table pp3181.truediv:
  description: "pathlib types __truediv__ dict-presence checks; wave 659"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3181

  columns: [id, function, args, expected]
  rows:
    - ["pp3181001", operator.contains, [pathlib.PurePath.__dict__,        "__truediv__"], true]
    - ["pp3181002", operator.contains, [pathlib.PurePosixPath.__dict__,   "__truediv__"], false]
    - ["pp3181003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__truediv__"], false]
    - ["pp3181004", operator.contains, [pathlib.Path.__dict__,             "__truediv__"], false]
    - ["pp3181005", operator.contains, [pathlib.PosixPath.__dict__,        "__truediv__"], false]

# ---------------------------------------------------------------------------
# __floordiv__ dict-presence — operator.contains(Cls.__dict__, '__floordiv__')
#
# No pathlib class defines __floordiv__ in its own __dict__; all false.
# pathlib types represent immutable filesystem paths; floor division is not supported.
# ---------------------------------------------------------------------------

table pp3181.floordiv:
  description: "pathlib types __floordiv__ dict-presence checks; wave 659"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3181

  columns: [id, function, args, expected]
  rows:
    - ["pp3181006", operator.contains, [pathlib.PurePath.__dict__,        "__floordiv__"], false]
    - ["pp3181007", operator.contains, [pathlib.PurePosixPath.__dict__,   "__floordiv__"], false]
    - ["pp3181008", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__floordiv__"], false]
    - ["pp3181009", operator.contains, [pathlib.Path.__dict__,             "__floordiv__"], false]
    - ["pp3181010", operator.contains, [pathlib.PosixPath.__dict__,        "__floordiv__"], false]

# ---------------------------------------------------------------------------
# __mod__ dict-presence — operator.contains(Cls.__dict__, '__mod__')
#
# No pathlib class defines __mod__ in its own __dict__; all false.
# pathlib types do not implement the modulo operator.
# ---------------------------------------------------------------------------

