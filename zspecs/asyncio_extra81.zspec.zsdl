table asyncio_extra81.gather_and_shield_code_attrs:
  description: "asyncio gather and shield code attribute checks in asyncioextra81 namespace — wave 245 theme: gather/shield code attributes; gather.__code__.co_name=='gather'; gather.__code__.co_argcount==0 (*coros_or_futures is VAR_POSITIONAL so co_argcount is 0); shield.__code__.co_name=='shield'; shield.__code__.co_argcount==1 (arg is the only positional parameter); verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: asyncioextra81c

  columns: [id, function, args, expected, description]
  rows:
    - [gather_co_name,     gather.__code__.co_name.__eq__,    ["gather"], true, "gather.__code__.co_name == 'gather' — pure Python function in asyncio.tasks; verified with Python 3.14.3"]
    - [gather_co_argcount, gather.__code__.co_argcount.__eq__, [0],       true, "gather.__code__.co_argcount == 0 — *coros_or_futures is VAR_POSITIONAL so co_argcount is 0; verified with Python 3.14.3"]
    - [shield_co_name,     shield.__code__.co_name.__eq__,    ["shield"], true, "shield.__code__.co_name == 'shield' — pure Python function in asyncio.tasks; verified with Python 3.14.3"]
    - [shield_co_argcount, shield.__code__.co_argcount.__eq__, [1],       true, "shield.__code__.co_argcount == 1 — arg is the only positional parameter; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra81
# ---------------------------------------------------------------------------

invariant asyncio_extra81.get_event_loop_class_name:
  description: "asyncio.get_event_loop.__class__.__name__.__eq__('builtin_function_or_method') returns True — get_event_loop is implemented in the _asyncio C extension module, not as a pure Python function; NEW in extra81: first standalone __class__.__name__ invariant for get_event_loop in asyncioextra81 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: get_event_loop.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant asyncio_extra81.get_running_loop_class_name:
  description: "asyncio.get_running_loop.__class__.__name__.__eq__('builtin_function_or_method') returns True — get_running_loop is implemented in the _asyncio C extension module, not a Python function; NEW in extra81: first standalone __class__.__name__ invariant for get_running_loop in asyncioextra81 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: get_running_loop.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant asyncio_extra81.new_event_loop_co_argcount:
  description: "asyncio.new_event_loop.__code__.co_argcount.__eq__(0) returns True — new_event_loop takes no positional parameters; it is a pure Python function in asyncio.events; NEW in extra81: first standalone co_argcount invariant for new_event_loop in asyncioextra81 namespace; wave 245; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: new_event_loop.__code__.co_argcount.__eq__
  args: [0]
  expected: true

invariant asyncio_extra81.gather_co_argcount:
  description: "asyncio.gather.__code__.co_argcount.__eq__(0) returns True — *coros_or_futures is VAR_POSITIONAL so co_argcount is 0; gather is a pure Python function in asyncio.tasks; NEW in extra81: first standalone co_argcount invariant for gather in asyncioextra81 namespace; wave 245; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: gather.__code__.co_argcount.__eq__
  args: [0]
  expected: true

invariant asyncio_extra81.run_co_argcount:
  description: "asyncio.run.__code__.co_argcount.__eq__(1) returns True — main is the only positional parameter; debug and loop_factory are keyword-only; run is a pure Python function in asyncio.runners; NEW in extra81: first standalone co_argcount invariant for run in asyncioextra81 namespace; wave 245; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: run.__code__.co_argcount.__eq__
  args: [1]
  expected: true
