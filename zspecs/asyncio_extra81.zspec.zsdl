spec: asyncio_extra81
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks and Coroutines"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_asynciomodule.c"
  notes:
    - "This spec extends asyncio_extra80.zspec.zsdl."
    - "This spec covers: wave 245 theme — asyncio get_event_loop/new_event_loop/set_event_loop function identity. NEW in extra81: get_event_loop.__class__.__name__=='builtin_function_or_method' (get_event_loop is a C builtin in _asyncio, not a Python function); get_event_loop.__module__=='_asyncio'; get_event_loop.__qualname__=='get_event_loop'; new_event_loop.__code__.co_name=='new_event_loop' (pure Python in asyncio.events); new_event_loop.__code__.co_argcount==0; set_event_loop.__code__.co_name=='set_event_loop'; set_event_loop.__code__.co_argcount==1 (loop); get_running_loop.__class__.__name__=='builtin_function_or_method' (C builtin); get_running_loop.__module__=='_asyncio'; asyncio.run.__code__.co_name=='run'; asyncio.run.__code__.co_argcount==1 (main only; debug and loop_factory are keyword-only); ensure_future.__code__.co_name=='ensure_future'; ensure_future.__code__.co_argcount==1; gather.__code__.co_name=='gather'; gather.__code__.co_argcount==0 (*coros_or_futures is VAR_POSITIONAL); shield.__code__.co_name=='shield'; shield.__code__.co_argcount==1 (arg). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.get_event_loop.__class__.__name__ == 'builtin_function_or_method'. get_event_loop is implemented in the _asyncio C extension, not as a pure Python function. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.get_event_loop.__module__ == '_asyncio'. get_event_loop belongs to the _asyncio C extension module. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.new_event_loop.__code__.co_name == 'new_event_loop'. new_event_loop is a pure Python function in asyncio.events. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.new_event_loop.__code__.co_argcount == 0. new_event_loop takes no positional parameters. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.set_event_loop.__code__.co_name == 'set_event_loop'. set_event_loop is a pure Python function in asyncio.events. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.set_event_loop.__code__.co_argcount == 1. Only loop is a positional parameter. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.get_running_loop.__class__.__name__ == 'builtin_function_or_method'. get_running_loop is implemented in the _asyncio C extension. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.get_running_loop.__module__ == '_asyncio'. get_running_loop belongs to the _asyncio C extension. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.run.__code__.co_name == 'run'. run is a pure Python function in asyncio.runners. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.run.__code__.co_argcount == 1. Only main is a positional parameter; debug and loop_factory are keyword-only. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.ensure_future.__code__.co_name == 'ensure_future'. ensure_future is a pure Python function in asyncio.tasks. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.ensure_future.__code__.co_argcount == 1. Only coro_or_future is a positional parameter; loop is keyword-only. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.gather.__code__.co_name == 'gather'. gather is a pure Python function in asyncio.tasks. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.gather.__code__.co_argcount == 0. *coros_or_futures is VAR_POSITIONAL so co_argcount is 0. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.shield.__code__.co_name == 'shield'. shield is a pure Python function in asyncio.tasks. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.shield.__code__.co_argcount == 1. Only arg is a positional parameter. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio get_event_loop and get_running_loop identity — extra81
#
# Wave 245 theme: get_event_loop/new_event_loop/set_event_loop function identity.
#
# get_event_loop.__class__.__name__ == 'builtin_function_or_method'
# get_event_loop.__module__ == '_asyncio'
# get_running_loop.__class__.__name__ == 'builtin_function_or_method'
# get_running_loop.__module__ == '_asyncio'
# ---------------------------------------------------------------------------

table asyncio_extra81.get_event_loop_and_get_running_loop_identity:
  description: "asyncio get_event_loop and get_running_loop identity checks in asyncioextra81 namespace — wave 245 theme: get_event_loop/new_event_loop/set_event_loop function identity; get_event_loop.__class__.__name__=='builtin_function_or_method' (C builtin in _asyncio); get_event_loop.__module__=='_asyncio'; get_event_loop.__qualname__=='get_event_loop'; get_running_loop.__class__.__name__=='builtin_function_or_method' (also a C builtin); get_running_loop.__module__=='_asyncio'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioextra81

  columns: [id, function, args, expected, description]
  rows:
    - [get_el_class_name,     get_event_loop.__class__.__name__.__eq__,     ["builtin_function_or_method"], true, "get_event_loop.__class__.__name__ == 'builtin_function_or_method' — C builtin in _asyncio extension; verified with Python 3.14.3"]
    - [get_el_module,         get_event_loop.__module__.__eq__,             ["_asyncio"],                  true, "get_event_loop.__module__ == '_asyncio' — belongs to the _asyncio C extension module; verified with Python 3.14.3"]
    - [get_el_qualname,       get_event_loop.__qualname__.__eq__,           ["get_event_loop"],            true, "get_event_loop.__qualname__ == 'get_event_loop' — C builtins use their simple name as qualname; verified with Python 3.14.3"]
    - [get_rl_class_name,     get_running_loop.__class__.__name__.__eq__,   ["builtin_function_or_method"], true, "get_running_loop.__class__.__name__ == 'builtin_function_or_method' — also a C builtin in _asyncio; verified with Python 3.14.3"]
    - [get_rl_module,         get_running_loop.__module__.__eq__,           ["_asyncio"],                  true, "get_running_loop.__module__ == '_asyncio' — belongs to the _asyncio C extension; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio new_event_loop and set_event_loop code attributes — extra81
#
# new_event_loop.__code__.co_name == 'new_event_loop'
# new_event_loop.__code__.co_argcount == 0
# set_event_loop.__code__.co_name == 'set_event_loop'
# set_event_loop.__code__.co_argcount == 1
# ---------------------------------------------------------------------------

table asyncio_extra81.new_event_loop_and_set_event_loop_code_attrs:
  description: "asyncio new_event_loop and set_event_loop code attribute checks in asyncioextra81 namespace — wave 245 theme: new_event_loop/set_event_loop code attributes; new_event_loop.__code__.co_name=='new_event_loop' (pure Python in asyncio.events); new_event_loop.__code__.co_argcount==0 (no positional parameters); set_event_loop.__code__.co_name=='set_event_loop'; set_event_loop.__code__.co_argcount==1 (loop is the only positional parameter); verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: asyncioextra81a

  columns: [id, function, args, expected, description]
  rows:
    - [new_el_co_name,     new_event_loop.__code__.co_name.__eq__,    ["new_event_loop"], true, "new_event_loop.__code__.co_name == 'new_event_loop' — pure Python function in asyncio.events; verified with Python 3.14.3"]
    - [new_el_co_argcount, new_event_loop.__code__.co_argcount.__eq__, [0],               true, "new_event_loop.__code__.co_argcount == 0 — no positional parameters; verified with Python 3.14.3"]
    - [set_el_co_name,     set_event_loop.__code__.co_name.__eq__,    ["set_event_loop"], true, "set_event_loop.__code__.co_name == 'set_event_loop' — pure Python function in asyncio.events; verified with Python 3.14.3"]
    - [set_el_co_argcount, set_event_loop.__code__.co_argcount.__eq__, [1],               true, "set_event_loop.__code__.co_argcount == 1 — loop is the only positional parameter; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio run and ensure_future code attributes — extra81
#
# run.__code__.co_name == 'run'
# run.__code__.co_argcount == 1
# ensure_future.__code__.co_name == 'ensure_future'
# ensure_future.__code__.co_argcount == 1
# ---------------------------------------------------------------------------

table asyncio_extra81.run_and_ensure_future_code_attrs:
  description: "asyncio run and ensure_future code attribute checks in asyncioextra81 namespace — wave 245 theme: run/ensure_future code attributes; run.__code__.co_name=='run'; run.__code__.co_argcount==1 (main is the only positional parameter; debug and loop_factory are keyword-only); ensure_future.__code__.co_name=='ensure_future'; ensure_future.__code__.co_argcount==1 (coro_or_future is the only positional parameter); verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: asyncioextra81b

  columns: [id, function, args, expected, description]
  rows:
    - [run_co_name,              run.__code__.co_name.__eq__,              ["run"],           true, "run.__code__.co_name == 'run' — pure Python function in asyncio.runners; verified with Python 3.14.3"]
    - [run_co_argcount,          run.__code__.co_argcount.__eq__,          [1],               true, "run.__code__.co_argcount == 1 — main is the only positional parameter; debug/loop_factory are keyword-only; verified with Python 3.14.3"]
    - [ensure_future_co_name,    ensure_future.__code__.co_name.__eq__,    ["ensure_future"], true, "ensure_future.__code__.co_name == 'ensure_future' — pure Python function in asyncio.tasks; verified with Python 3.14.3"]
    - [ensure_future_co_argcount, ensure_future.__code__.co_argcount.__eq__, [1],             true, "ensure_future.__code__.co_argcount == 1 — coro_or_future is the only positional parameter; verified with Python 3.14.3"]

