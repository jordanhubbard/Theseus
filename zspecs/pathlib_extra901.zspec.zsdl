spec: pathlib_extra901
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __module__ and __name__ attributes of pathlib path classes"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra901.pure_path_modules:
  description: "pathlib pure path class __module__ identity"
  kind: python_call_eq
  category: pure_path_modules
  id_prefix: pl901p
  columns: [id, function, args, expected]
  rows:
    - [pl901p001, pathlib.PurePath.__module__.__eq__,        ["pathlib"], true]
    - [pl901p002, pathlib.PurePosixPath.__module__.__eq__,   ["pathlib"], true]
    - [pl901p003, pathlib.PureWindowsPath.__module__.__eq__, ["pathlib"], true]
    - [pl901p004, pathlib.PurePath.__class__.__name__.__eq__,        ["type"], true]
    - [pl901p005, pathlib.PurePosixPath.__class__.__name__.__eq__,   ["type"], true]
    - [pl901p006, pathlib.PureWindowsPath.__class__.__name__.__eq__, ["type"], true]

table pathlib_extra901.concrete_path_modules:
  description: "pathlib concrete path class __module__ identity"
  kind: python_call_eq
  category: concrete_path_modules
  id_prefix: pl901c
  columns: [id, function, args, expected]
  rows:
    - [pl901c001, pathlib.Path.__module__.__eq__,      ["pathlib"], true]
    - [pl901c002, pathlib.Path.__class__.__name__.__eq__, ["type"],    true]
    - [pl901c003, pathlib.Path.__name__.__eq__,        ["Path"],     true]
    - [pl901c004, pathlib.PurePath.__name__.__eq__,    ["PurePath"], true]
    - [pl901c005, pathlib.PurePosixPath.__name__.__eq__,   ["PurePosixPath"],   true]
    - [pl901c006, pathlib.PureWindowsPath.__name__.__eq__, ["PureWindowsPath"], true]

table pathlib_extra901.module_name_checks:
  description: "pathlib module __name__ and path class name identity"
  kind: python_call_eq
  category: module_name_checks
  id_prefix: pl901n
  columns: [id, function, args, expected]
  rows:
    - [pl901n001, pathlib.__name__.__eq__,                    ["pathlib"],         true]
    - [pl901n002, pathlib.__spec__.name.__eq__,               ["pathlib"],         true]
    - [pl901n003, pathlib.PurePath.__qualname__.__eq__,       ["PurePath"],        true]
    - [pl901n004, pathlib.PurePosixPath.__qualname__.__eq__,  ["PurePosixPath"],   true]
    - [pl901n005, pathlib.PureWindowsPath.__qualname__.__eq__, ["PureWindowsPath"], true]
    - [pl901n006, pathlib.Path.__qualname__.__eq__,           ["Path"],            true]
    - [pl901n007, pathlib.Path.__module__.__class__.__name__.__eq__, ["str"],       true]
