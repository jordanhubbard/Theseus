spec: decimal_extra230
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal special value contracts (Infinity, NaN)."
    - "decimal.Decimal('Infinity').__str__() == 'Infinity' — positive infinity string representation; verified Python 3.14.3 macOS."
    - "decimal.Decimal('-Infinity').__str__() == '-Infinity' — negative infinity string representation; verified Python 3.14.3 macOS."
    - "decimal.Decimal('Infinity').is_infinite() == True — Infinity is infinite; verified Python 3.14.3 macOS."
    - "decimal.Decimal('NaN').is_nan() == True — NaN is not-a-number; verified Python 3.14.3 macOS."
    - "decimal.Decimal('Infinity').is_finite() == False — Infinity is not finite; verified Python 3.14.3 macOS."
    - "decimal.Decimal('1.0').is_finite() == True — normal value is finite; verified Python 3.14.3 macOS."
    - "decimal.Decimal('0').is_zero() == True — zero is zero; verified Python 3.14.3 macOS."
    - "decimal.Decimal('0').is_signed() == False — positive zero is not signed; verified Python 3.14.3 macOS."
    - "decimal.Decimal('-0').is_signed() == True — negative zero is signed; verified Python 3.14.3 macOS."
    - "decimal.Decimal('1.5').is_signed() == False — positive value is not signed; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal Infinity string representation contracts
# Infinity and -Infinity have canonical string forms.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra230.Decimal.infinity_str:
  description: "decimal.Decimal('Infinity').__str__() == 'Infinity' — positive infinity string representation; verified Python 3.14.3 macOS"
  category: special_values
  kind: python_call_eq
  function: Decimal
  args: ["Infinity"]
  method: __str__
  expected: "Infinity"

invariant decimal_extra230.Decimal.neg_infinity_str:
  description: "decimal.Decimal('-Infinity').__str__() == '-Infinity' — negative infinity string representation; verified Python 3.14.3 macOS"
  category: special_values
  kind: python_call_eq
  function: Decimal
  args: ["-Infinity"]
  method: __str__
  expected: "-Infinity"

# ---------------------------------------------------------------------------
# decimal.Decimal is_infinite() predicate contracts
# is_infinite() returns True only for Infinity and -Infinity.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra230.Decimal.infinity_is_infinite:
  description: "decimal.Decimal('Infinity').is_infinite() == True — Infinity is infinite; verified Python 3.14.3 macOS"
  category: special_values
  kind: python_call_eq
  function: Decimal
  args: ["Infinity"]
  method: is_infinite
  expected: true

invariant decimal_extra230.Decimal.neg_infinity_is_infinite:
  description: "decimal.Decimal('-Infinity').is_infinite() == True — negative Infinity is also infinite; verified Python 3.14.3 macOS"
  category: special_values
  kind: python_call_eq
  function: Decimal
  args: ["-Infinity"]
  method: is_infinite
  expected: true

# ---------------------------------------------------------------------------
# decimal.Decimal is_nan() predicate contracts
# is_nan() returns True for NaN (quiet NaN) and sNaN (signaling NaN).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra230.Decimal.nan_is_nan:
  description: "decimal.Decimal('NaN').is_nan() == True — quiet NaN is a NaN; verified Python 3.14.3 macOS"
  category: special_values
  kind: python_call_eq
  function: Decimal
  args: ["NaN"]
  method: is_nan
  expected: true

# ---------------------------------------------------------------------------
# decimal.Decimal is_finite() predicate contracts
# is_finite() returns False for Infinity and NaN, True for normal values.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra230.Decimal.infinity_not_finite:
  description: "decimal.Decimal('Infinity').is_finite() == False — Infinity is not finite; verified Python 3.14.3 macOS"
  category: special_values
  kind: python_call_eq
  function: Decimal
  args: ["Infinity"]
  method: is_finite
  expected: false

invariant decimal_extra230.Decimal.normal_is_finite:
  description: "decimal.Decimal('1.0').is_finite() == True — normal value 1.0 is finite; verified Python 3.14.3 macOS"
  category: special_values
  kind: python_call_eq
  function: Decimal
  args: ["1.0"]
  method: is_finite
  expected: true

# ---------------------------------------------------------------------------
# decimal.Decimal is_zero() and is_signed() predicate contracts
# is_zero() checks for zero; is_signed() distinguishes positive and negative.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra230.Decimal.zero_is_zero:
  description: "decimal.Decimal('0').is_zero() == True — zero value satisfies is_zero(); verified Python 3.14.3 macOS"
  category: special_values
  kind: python_call_eq
  function: Decimal
  args: ["0"]
  method: is_zero
  expected: true

invariant decimal_extra230.Decimal.zero_not_signed:
  description: "decimal.Decimal('0').is_signed() == False — positive zero has no sign bit set; verified Python 3.14.3 macOS"
  category: special_values
  kind: python_call_eq
  function: Decimal
  args: ["0"]
  method: is_signed
  expected: false

invariant decimal_extra230.Decimal.neg_zero_is_signed:
  description: "decimal.Decimal('-0').is_signed() == True — negative zero has sign bit set; verified Python 3.14.3 macOS"
  category: special_values
  kind: python_call_eq
  function: Decimal
  args: ["-0"]
  method: is_signed
  expected: true

invariant decimal_extra230.Decimal.positive_not_signed:
  description: "decimal.Decimal('1.5').is_signed() == False — positive value 1.5 has no sign bit set; verified Python 3.14.3 macOS"
  category: special_values
  kind: python_call_eq
  function: Decimal
  args: ["1.5"]
  method: is_signed
  expected: false
