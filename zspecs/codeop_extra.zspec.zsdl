spec: codeop_extra
version: ">=3.9"
backend: python_module(codeop)

docs: https://docs.python.org/3/library/codeop.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/codeop.html — Python codeop module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/codeop.py"
  notes:
    - "The codeop module provides utilities for compiling interactive Python statements."
    - "compile_command is a module-level function; its __name__ == 'compile_command' and __module__ == 'codeop'."
    - "CommandCompiler is a callable class (instances behave like compile_command); __name__ == 'CommandCompiler', __module__ == 'codeop'."
    - "Compile is an internal helper class used by CommandCompiler; __name__ == 'Compile', __module__ == 'codeop'."
    - "All three objects are defined at module level in codeop and have __module__ == 'codeop'."
    - "CommandCompiler.__bases__[0].__name__ == 'object' — CommandCompiler directly inherits from object."
    - "Compile.__bases__[0].__name__ == 'object' — Compile directly inherits from object."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# compile_command — function name and module affiliation
# ---------------------------------------------------------------------------

invariant codeop_extra.compile_command.name:
  description: "codeop.compile_command.__name__ == 'compile_command'"
  category: functions
  kind: python_call_eq
  function: compile_command.__name__.__eq__
  args: ["compile_command"]
  expected: true

invariant codeop_extra.compile_command.module:
  description: "codeop.compile_command.__module__ == 'codeop'"
  category: functions
  kind: python_call_eq
  function: compile_command.__module__.__eq__
  args: ["codeop"]
  expected: true

invariant codeop_extra.compile_command.is_callable:
  description: "codeop.compile_command is callable — it accepts source and returns a code object or None"
  category: functions
  kind: python_call_eq
  function: compile_command.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# CommandCompiler — class name and module affiliation
# ---------------------------------------------------------------------------

invariant codeop_extra.commandcompiler.name:
  description: "codeop.CommandCompiler.__name__ == 'CommandCompiler'"
  category: classes
  kind: python_call_eq
  function: CommandCompiler.__name__.__eq__
  args: ["CommandCompiler"]
  expected: true

invariant codeop_extra.commandcompiler.module:
  description: "codeop.CommandCompiler.__module__ == 'codeop'"
  category: classes
  kind: python_call_eq
  function: CommandCompiler.__module__.__eq__
  args: ["codeop"]
  expected: true

invariant codeop_extra.commandcompiler.is_type:
  description: "codeop.CommandCompiler is a class (type)"
  category: classes
  kind: python_call_eq
  function: CommandCompiler.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant codeop_extra.commandcompiler.base_is_object:
  description: "codeop.CommandCompiler.__bases__[0].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: CommandCompiler.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

invariant codeop_extra.commandcompiler.bases_len:
  description: "len(codeop.CommandCompiler.__bases__) == 1 — CommandCompiler has exactly one direct base"
  category: class_hierarchy
  kind: python_call_eq
  function: CommandCompiler.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# Compile — class name and module affiliation
# ---------------------------------------------------------------------------

invariant codeop_extra.compile.name:
  description: "codeop.Compile.__name__ == 'Compile'"
  category: classes
  kind: python_call_eq
  function: Compile.__name__.__eq__
  args: ["Compile"]
  expected: true

invariant codeop_extra.compile.module:
  description: "codeop.Compile.__module__ == 'codeop'"
  category: classes
  kind: python_call_eq
  function: Compile.__module__.__eq__
  args: ["codeop"]
  expected: true

invariant codeop_extra.compile.is_type:
  description: "codeop.Compile is a class (type)"
  category: classes
  kind: python_call_eq
  function: Compile.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant codeop_extra.compile.base_is_object:
  description: "codeop.Compile.__bases__[0].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: Compile.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

invariant codeop_extra.compile.bases_len:
  description: "len(codeop.Compile.__bases__) == 1 — Compile has exactly one direct base"
  category: class_hierarchy
  kind: python_call_eq
  function: Compile.__bases__.__len__
  args: []
  expected: 1
