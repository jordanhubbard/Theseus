spec: re_extra90
version: ">=3.9"
backend: python_module(re)
extends: re_extra89

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends all prior re specs through re_extra89."
    - "Prior specs covered: Pattern/Match class identity; Pattern/Match __dict__ membership; method qualnames; re.error/__name__; module-level function qualnames; re.RegexFlag hierarchy; re module constants; Pattern/Match __dict__.__class__.__name__; Pattern/Match __qualname__ and length; PatternError attributes; re.NOFLAG value; Pattern/Match method __doc__.__len__(); re.Pattern/__dict__.__contains__; re module-level function __qualname__ for all functions."
    - "This spec covers: re.Pattern and re.Match class identity — __name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__(). Also re.RegexFlag class identity attributes."
    - "re.Pattern.__name__ == 'Pattern' — re.Pattern is the public API name for the compiled regex type."
    - "re.Pattern.__module__ == 're' — Pattern is exposed via the re module (not _sre)."
    - "re.Pattern.__qualname__ == 'Pattern' — top-level class; qualname equals bare name."
    - "re.Pattern.__bases__[0].__name__ == 'object' — Pattern has no intermediate base class."
    - "re.Pattern.__mro__.__len__() == 2 — MRO: [Pattern, object]."
    - "re.Match.__name__ == 'Match' — Match is the public API name for regex match objects."
    - "re.Match.__module__ == 're' — Match is exposed via the re module (not _sre)."
    - "re.Match.__qualname__ == 'Match' — top-level class; qualname equals bare name."
    - "re.Match.__bases__[0].__name__ == 'object' — Match has no intermediate base class."
    - "re.Match.__mro__.__len__() == 2 — MRO: [Match, object]."
    - "re.RegexFlag.__name__ == 'RegexFlag' — IntFlag subclass for regex flag constants."
    - "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' — RegexFlag directly inherits from IntFlag."
    - "re.RegexFlag.__mro__.__len__() == 7 — MRO: [RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object]."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern class identity: __name__, __module__, __qualname__
# re.Pattern is the public API alias for the compiled regex type; it is exposed
# via the re module namespace, so __module__ == 're' (not '_sre').
# Not covered in any prior re spec at this specific table.
# ---------------------------------------------------------------------------

table re_extra90.Pattern_identity_name_module:
  description: "re.Pattern __name__/__module__/__qualname__ string equality"
  kind: python_call_eq
  category: class_identity
  id_prefix: repatternid90

  columns: [id, function, args, expected]
  rows:
    - [pattern_name,     Pattern.__name__.__eq__,     ["Pattern"], true]
    - [pattern_module,   Pattern.__module__.__eq__,   ["re"],      true]
    - [pattern_qualname, Pattern.__qualname__.__eq__,  ["Pattern"], true]

# ---------------------------------------------------------------------------
# re.Pattern class identity: __bases__[0].__name__ and __mro__.__len__()
# Pattern has no intermediate base class; __bases__[0] is object and MRO length is 2.
# Not covered in any prior re spec at this specific table.
# ---------------------------------------------------------------------------

table re_extra90.Pattern_identity_bases_mro:
  description: "re.Pattern __bases__[0].__name__ and __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: repatternid90

  columns: [id, function, args, expected]
  rows:
    - [pattern_base0,  "Pattern.__bases__[0].__name__.__eq__", ["object"], true]
    - [pattern_mrolen, Pattern.__mro__.__len__,                [],         2]

# ---------------------------------------------------------------------------
# re.Match class identity: __name__, __module__, __qualname__, bases, MRO
# Match is the public API alias for the regex match object type; like Pattern,
# its __module__ is 're'.
# Not covered in any prior re spec at this specific table.
# ---------------------------------------------------------------------------

table re_extra90.Match_identity:
  description: "re.Match __name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: repatternid90

  columns: [id, function, args, expected]
  rows:
    - [match_name,     Match.__name__.__eq__,                ["Match"],   true]
    - [match_module,   Match.__module__.__eq__,              ["re"],      true]
    - [match_qualname, Match.__qualname__.__eq__,            ["Match"],   true]
    - [match_base0,    "Match.__bases__[0].__name__.__eq__", ["object"],  true]
    - [match_mrolen,   Match.__mro__.__len__,                [],          2]

# ---------------------------------------------------------------------------
# re.RegexFlag class identity
# RegexFlag is an IntFlag subclass; __bases__[0] is IntFlag and MRO length is 7
# (RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object).
# Not covered in any prior re spec at this specific table.
# ---------------------------------------------------------------------------

table re_extra90.RegexFlag_identity:
  description: "re.RegexFlag __name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: repatternid90

  columns: [id, function, args, expected]
  rows:
    - [regexflag_name,     RegexFlag.__name__.__eq__,                   ["RegexFlag"], true]
    - [regexflag_module,   RegexFlag.__module__.__eq__,                 ["re"],        true]
    - [regexflag_qualname, RegexFlag.__qualname__.__eq__,               ["RegexFlag"], true]
    - [regexflag_base0,    "RegexFlag.__bases__[0].__name__.__eq__",    ["IntFlag"],   true]
    - [regexflag_mrolen,   RegexFlag.__mro__.__len__,                   [],            7]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra90.Pattern.name:
  description: "re.Pattern.__name__ == 'Pattern' (public API name for the compiled regex type)"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra90.Pattern.module:
  description: "re.Pattern.__module__ == 're' (exposed via re module, not _sre)"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra90.Pattern.mro_len:
  description: "re.Pattern.__mro__.__len__() == 2 (MRO: Pattern, object; no intermediate base)"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__mro__.__len__
  args: []
  expected: 2

invariant re_extra90.Match.module:
  description: "re.Match.__module__ == 're' (exposed via re module, not _sre)"
  category: class_identity
  kind: python_call_eq
  function: Match.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra90.RegexFlag.mro_len:
  description: "re.RegexFlag.__mro__.__len__() == 7 (MRO: RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object)"
  category: class_identity
  kind: python_call_eq
  function: RegexFlag.__mro__.__len__
  args: []
  expected: 7
