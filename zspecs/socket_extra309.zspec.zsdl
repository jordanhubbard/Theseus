spec: socket_extra309
version: ">=3.8"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "socket.socket is a Python class whose __module__ is 'socket' (the Python wrapper, not '_socket')."
    - "socket.create_connection and socket.create_server are Python functions in 'socket' module."
    - "socket.create_server was added in Python 3.8."
    - "socket.getaddrinfo is a Python wrapper function in 'socket' module (wraps _socket.getaddrinfo)."
    - "socket.gethostbyaddr is a C-level built-in from '_socket': __module__ == '_socket'."
    - "socket.inet_aton and socket.inet_ntoa are C-level built-ins from '_socket': __module__ == '_socket'."
    - "socket.htons is a C-level built-in from '_socket': __module__ == '_socket'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket — the main socket class
# __module__ is 'socket' (the Python wrapper level, not '_socket')
# ---------------------------------------------------------------------------

invariant socket_extra309.socket.name:
  description: "socket.socket.__name__ == 'socket'"
  category: classnames
  kind: python_call_eq
  function: socket.__name__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra309.socket.module:
  description: "socket.socket.__module__ == 'socket' — the Python wrapper class"
  category: classnames
  kind: python_call_eq
  function: socket.__module__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.create_connection — Python function (added in Python 3.2)
# ---------------------------------------------------------------------------

invariant socket_extra309.create_connection.name:
  description: "socket.create_connection.__name__ == 'create_connection'"
  category: functions
  kind: python_call_eq
  function: create_connection.__name__.__eq__
  args: ["create_connection"]
  expected: true

invariant socket_extra309.create_connection.module:
  description: "socket.create_connection.__module__ == 'socket'"
  category: functions
  kind: python_call_eq
  function: create_connection.__module__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.create_server — Python function (added in Python 3.8)
# ---------------------------------------------------------------------------

invariant socket_extra309.create_server.name:
  description: "socket.create_server.__name__ == 'create_server'"
  category: functions
  kind: python_call_eq
  function: create_server.__name__.__eq__
  args: ["create_server"]
  expected: true

invariant socket_extra309.create_server.module:
  description: "socket.create_server.__module__ == 'socket'"
  category: functions
  kind: python_call_eq
  function: create_server.__module__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.getaddrinfo — Python wrapper function in 'socket' module
# (wraps _socket.getaddrinfo; they are distinct objects)
# ---------------------------------------------------------------------------

invariant socket_extra309.getaddrinfo.name:
  description: "socket.getaddrinfo.__name__ == 'getaddrinfo'"
  category: functions
  kind: python_call_eq
  function: getaddrinfo.__name__.__eq__
  args: ["getaddrinfo"]
  expected: true

invariant socket_extra309.getaddrinfo.module:
  description: "socket.getaddrinfo.__module__ == 'socket' — Python-level wrapper function"
  category: functions
  kind: python_call_eq
  function: getaddrinfo.__module__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.gethostbyaddr — C-level built-in from '_socket' extension
# ---------------------------------------------------------------------------

invariant socket_extra309.gethostbyaddr.name:
  description: "socket.gethostbyaddr.__name__ == 'gethostbyaddr'"
  category: functions
  kind: python_call_eq
  function: gethostbyaddr.__name__.__eq__
  args: ["gethostbyaddr"]
  expected: true

invariant socket_extra309.gethostbyaddr.module:
  description: "socket.gethostbyaddr.__module__ == '_socket' — C-level built-in from the C extension"
  category: functions
  kind: python_call_eq
  function: gethostbyaddr.__module__.__eq__
  args: ["_socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.inet_aton — C-level built-in from '_socket' extension
# ---------------------------------------------------------------------------

invariant socket_extra309.inet_aton.name:
  description: "socket.inet_aton.__name__ == 'inet_aton'"
  category: functions
  kind: python_call_eq
  function: inet_aton.__name__.__eq__
  args: ["inet_aton"]
  expected: true

invariant socket_extra309.inet_aton.module:
  description: "socket.inet_aton.__module__ == '_socket' — C-level built-in"
  category: functions
  kind: python_call_eq
  function: inet_aton.__module__.__eq__
  args: ["_socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.inet_ntoa — C-level built-in from '_socket' extension
# ---------------------------------------------------------------------------

invariant socket_extra309.inet_ntoa.name:
  description: "socket.inet_ntoa.__name__ == 'inet_ntoa'"
  category: functions
  kind: python_call_eq
  function: inet_ntoa.__name__.__eq__
  args: ["inet_ntoa"]
  expected: true

invariant socket_extra309.inet_ntoa.module:
  description: "socket.inet_ntoa.__module__ == '_socket' — C-level built-in"
  category: functions
  kind: python_call_eq
  function: inet_ntoa.__module__.__eq__
  args: ["_socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.htons — C-level built-in from '_socket' extension
# ---------------------------------------------------------------------------

invariant socket_extra309.htons.name:
  description: "socket.htons.__name__ == 'htons'"
  category: functions
  kind: python_call_eq
  function: htons.__name__.__eq__
  args: ["htons"]
  expected: true

invariant socket_extra309.htons.module:
  description: "socket.htons.__module__ == '_socket' — C-level built-in"
  category: functions
  kind: python_call_eq
  function: htons.__module__.__eq__
  args: ["_socket"]
  expected: true
