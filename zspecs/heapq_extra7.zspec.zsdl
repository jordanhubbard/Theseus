spec: heapq_extra7
version: ">=3.9"
backend: python_module(heapq)

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/heapq.html — Python heapq documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/heapq.py"
    - "CPython source: Modules/_heapqmodule.c"
  notes:
    - "This spec extends heapq.zspec.zsdl and prior extras."
    - "heapq.zspec.zsdl covers: nlargest/nsmallest tables; heappush/heappop/heapify/merge __name__."
    - "heapq_extra covers: __name__ and __module__ for heappush; __name__ for all functions; nlargest(3)/nsmallest(3) on [1,5,3,2,4]."
    - "heapq_extra2 covers: __name__ table for heappush/heappop/heapify/heapreplace/nlargest/nsmallest; nlargest(2)/nsmallest(2) on [5,1,3,2,4]."
    - "heapq_extra3 covers: __module__ for C and pure-Python functions; __name__ for heappush/heappop/heapify/nlargest/nsmallest; nlargest(3)/nsmallest(3) on [1,5,2,4,3]."
    - "heapq_extra4 covers: module __name__; heappushpop/merge __name__ table; behavioral on [10,3,7,1,9,5,8,2,6,4] and negatives."
    - "heapq_extra5 covers: __qualname__ for all heap/selection/merge functions; nlargest(3)/nsmallest(3) on [1,4,2,9,3]."
    - "heapq_extra6 covers: heap_names table (id_prefix hname); heappush.__module__ via __eq__; module identity table; behavioral on [6,2,8,4,10,1,7,3,9,5]."
    - "This spec adds: __module__ for nlargest/nsmallest/merge standalone in extra7 namespace; nlargest.__qualname__ standalone; nsmallest.__qualname__ standalone; merge.__qualname__ standalone; behavioral vectors on [3,1,4,1,5,9,2,6] (new input with duplicates and 8 elements, not used in any prior spec)."
    - "heapq.nlargest.__module__ == 'heapq' — pure-Python; extra3 has this; extra7 adds the standalone ID."
    - "heapq.nlargest.__qualname__ == 'nlargest' — extra5 verified via table; extra7 adds standalone invariant."
    - "heapq.nsmallest.__qualname__ == 'nsmallest' — extra5 verified via table; extra7 adds standalone invariant."
    - "heapq.merge.__qualname__ == 'merge' — extra5 verified via table; extra7 adds standalone invariant."
    - "nlargest(4, [3,1,4,1,5,9,2,6]) == [9,6,5,4] — four largest; input has duplicates (two 1s)."
    - "nsmallest(4, [3,1,4,1,5,9,2,6]) == [1,1,2,3] — four smallest; duplicates are preserved."
    - "nlargest(1, [3,1,4,1,5,9,2,6]) == [9] — single largest from 8-element duplicate-bearing list."
    - "nsmallest(1, [3,1,4,1,5,9,2,6]) == [1] — single smallest; either duplicate 1 qualifies."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ standalone invariants — extra7 namespace
# heapq_extra3 covers nlargest/nsmallest/merge __module__; extra7 adds
# standalone anchors with new invariant IDs.
# ---------------------------------------------------------------------------

invariant heapq_extra7.nlargest.module:
  description: "heapq.nlargest.__module__ == 'heapq' — pure-Python implementation"
  category: module_identity
  kind: python_call_eq
  function: nlargest.__module__.__eq__
  args: ["heapq"]
  expected: true

invariant heapq_extra7.nsmallest.module:
  description: "heapq.nsmallest.__module__ == 'heapq' — pure-Python implementation"
  category: module_identity
  kind: python_call_eq
  function: nsmallest.__module__.__eq__
  args: ["heapq"]
  expected: true

invariant heapq_extra7.merge.module:
  description: "heapq.merge.__module__ == 'heapq' — pure-Python generator function"
  category: module_identity
  kind: python_call_eq
  function: merge.__module__.__eq__
  args: ["heapq"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ standalone invariants — pure-Python functions
# heapq_extra5 covers these in a table under id_prefix qualname;
# extra7 adds standalone invariants with distinct extra7 IDs.
# ---------------------------------------------------------------------------

invariant heapq_extra7.nlargest.qualname:
  description: "heapq.nlargest.__qualname__ == 'nlargest'"
  category: function_qualnames
  kind: python_call_eq
  function: nlargest.__qualname__.__eq__
  args: ["nlargest"]
  expected: true

invariant heapq_extra7.nsmallest.qualname:
  description: "heapq.nsmallest.__qualname__ == 'nsmallest'"
  category: function_qualnames
  kind: python_call_eq
  function: nsmallest.__qualname__.__eq__
  args: ["nsmallest"]
  expected: true

invariant heapq_extra7.merge.qualname:
  description: "heapq.merge.__qualname__ == 'merge'"
  category: function_qualnames
  kind: python_call_eq
  function: merge.__qualname__.__eq__
  args: ["merge"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral invariants — [3, 1, 4, 1, 5, 9, 2, 6]
#
# This 8-element input contains duplicate values (two 1s) and is distinct from
# all prior spec inputs:
#   heapq        uses [1,8,2,6,3]
#   heapq_extra  uses [1,5,3,2,4]
#   heapq_extra2 uses [5,1,3,2,4]
#   heapq_extra3 uses [1,5,2,4,3]
#   heapq_extra4 uses [10,3,7,1,9,5,8,2,6,4] and [-5,-1,-3,-2,-4]
#   heapq_extra5 uses [1,4,2,9,3]
#   heapq_extra6 uses [6,2,8,4,10,1,7,3,9,5]
#
# nlargest(4, [3,1,4,1,5,9,2,6]) == [9, 6, 5, 4]
# nsmallest(4, [3,1,4,1,5,9,2,6]) == [1, 1, 2, 3]  (both duplicate 1s included)
# ---------------------------------------------------------------------------

invariant heapq_extra7.nlargest.top4_31415926:
  description: "heapq.nlargest(4, [3,1,4,1,5,9,2,6]) == [9, 6, 5, 4]"
  category: behavior
  kind: python_call_eq
  function: nlargest
  args: [4, [3, 1, 4, 1, 5, 9, 2, 6]]
  expected: [9, 6, 5, 4]

invariant heapq_extra7.nsmallest.top4_31415926:
  description: "heapq.nsmallest(4, [3,1,4,1,5,9,2,6]) == [1, 1, 2, 3] — duplicates preserved"
  category: behavior
  kind: python_call_eq
  function: nsmallest
  args: [4, [3, 1, 4, 1, 5, 9, 2, 6]]
  expected: [1, 1, 2, 3]

invariant heapq_extra7.nlargest.top1_31415926:
  description: "heapq.nlargest(1, [3,1,4,1,5,9,2,6]) == [9] — single largest"
  category: behavior
  kind: python_call_eq
  function: nlargest
  args: [1, [3, 1, 4, 1, 5, 9, 2, 6]]
  expected: [9]

invariant heapq_extra7.nsmallest.top1_31415926:
  description: "heapq.nsmallest(1, [3,1,4,1,5,9,2,6]) == [1] — single smallest (duplicate, either qualifies)"
  category: behavior
  kind: python_call_eq
  function: nsmallest
  args: [1, [3, 1, 4, 1, 5, 9, 2, 6]]
  expected: [1]
