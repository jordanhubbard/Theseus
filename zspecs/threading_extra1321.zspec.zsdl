spec: threading_extra1321
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "Wave 535 (_extra1321): focuses on __repr__ and __str__ output class checks for threading classes."
    - "threading.Thread defines __repr__ as a Python function; __str__ inherits from object as wrapper_descriptor."
    - "threading.Thread.__repr__.__qualname__ == 'Thread.__repr__' — defined in the class body in Lib/threading.py."
    - "threading.Barrier defines __repr__ as a Python function; __str__ inherits from object."
    - "threading.Barrier.__repr__.__qualname__ == 'Barrier.__repr__' — defined in the class body."
    - "threading.Condition defines __repr__ as a Python function; __str__ inherits from object."
    - "threading.Condition.__repr__.__qualname__ == 'Condition.__repr__' — defined in the class body."
    - "threading.Event defines __repr__ as a Python function; __str__ inherits from object."
    - "threading.Event.__repr__.__qualname__ == 'Event.__repr__' — defined in the class body."
    - "repr(threading.Thread).__class__.__name__ == 'str' — repr of any class object is always a str."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table threading_extra1321.thread_barrier_repr_str_checks:
  description: "threading.Thread and Barrier __repr__ and __str__ class name and qualname; both define __repr__ as Python functions"
  kind: python_call_eq
  category: repr_str_class_checks
  id_prefix: th1321tb
  columns: [id, function, args, expected]
  rows:
    - [th1321tb001, threading.Thread.__repr__.__class__.__name__.__eq__,   ["function"],         true]
    - [th1321tb002, threading.Thread.__repr__.__qualname__.__eq__,         ["Thread.__repr__"],  true]
    - [th1321tb003, threading.Thread.__str__.__class__.__name__.__eq__,    ["wrapper_descriptor"], true]
    - [th1321tb004, threading.Thread.__str__.__qualname__.__eq__,          ["object.__str__"],   true]
    - [th1321tb005, threading.Barrier.__repr__.__class__.__name__.__eq__,  ["function"],         true]
    - [th1321tb006, threading.Barrier.__repr__.__qualname__.__eq__,        ["Barrier.__repr__"], true]
    - [th1321tb007, threading.Barrier.__str__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true]
    - [th1321tb008, repr(threading.Thread).__class__.__name__.__eq__,      ["str"],              true]

table threading_extra1321.condition_event_repr_str_checks:
  description: "threading.Condition and Event __repr__ and __str__ class name and qualname; both define __repr__ as Python functions"
  kind: python_call_eq
  category: repr_str_class_checks
  id_prefix: th1321ce
  columns: [id, function, args, expected]
  rows:
    - [th1321ce001, threading.Condition.__repr__.__class__.__name__.__eq__,  ["function"],            true]
    - [th1321ce002, threading.Condition.__repr__.__qualname__.__eq__,        ["Condition.__repr__"],  true]
    - [th1321ce003, threading.Condition.__str__.__class__.__name__.__eq__,   ["wrapper_descriptor"],  true]
    - [th1321ce004, threading.Condition.__str__.__qualname__.__eq__,         ["object.__str__"],      true]
    - [th1321ce005, threading.Event.__repr__.__class__.__name__.__eq__,      ["function"],            true]
    - [th1321ce006, threading.Event.__repr__.__qualname__.__eq__,            ["Event.__repr__"],      true]
    - [th1321ce007, threading.Event.__str__.__class__.__name__.__eq__,       ["wrapper_descriptor"],  true]
    - [th1321ce008, repr(threading.Barrier).__class__.__name__.__eq__,       ["str"],                 true]

table threading_extra1321.repr_of_class_objects_str_check:
  description: "repr() of threading class objects always returns a str; covers Thread, Barrier, Condition, Event, and confirms __str__ inheritance pattern"
  kind: python_call_eq
  category: repr_str_class_checks
  id_prefix: th1321rc
  columns: [id, function, args, expected]
  rows:
    - [th1321rc001, repr(threading.Thread).__class__.__name__.__eq__,      ["str"],  true]
    - [th1321rc002, repr(threading.Barrier).__class__.__name__.__eq__,     ["str"],  true]
    - [th1321rc003, repr(threading.Condition).__class__.__name__.__eq__,   ["str"],  true]
    - [th1321rc004, repr(threading.Event).__class__.__name__.__eq__,       ["str"],  true]
    - [th1321rc005, threading.Event.__str__.__qualname__.__eq__,           ["object.__str__"],     true]
    - [th1321rc006, threading.Barrier.__str__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true]
    - [th1321rc007, threading.Barrier.__str__.__qualname__.__eq__,         ["object.__str__"],     true]
    - [th1321rc008, threading.Condition.__repr__.__class__.__name__.__eq__, ["function"],          true]
