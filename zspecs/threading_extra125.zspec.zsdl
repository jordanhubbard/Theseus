spec: threading_extra125
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra124.zspec.zsdl."
    - "This spec covers: threading.Thread class method __code__.co_varnames elements — Thread.__init__ co_varnames[0]='self', [1]='group', [2]='target', len=9, co_argcount=6; Thread.start/run/join/is_alive co_varnames[0]='self'; wave 275."
    - "threading.Thread.__init__.__code__.co_varnames = ('self', 'group', 'target', 'name', 'args', 'kwargs', 'daemon', 'context', 'target_name'). Verified with Python 3.14.3."
    - "threading.Thread.__init__.__code__.co_varnames[0] == 'self' (len 4). Verified with Python 3.14.3."
    - "threading.Thread.__init__.__code__.co_varnames[1] == 'group' (len 5). Verified with Python 3.14.3."
    - "threading.Thread.__init__.__code__.co_varnames[2] == 'target' (len 6). Verified with Python 3.14.3."
    - "threading.Thread.__init__.__code__.co_varnames.__len__() == 9. Verified with Python 3.14.3."
    - "threading.Thread.__init__.__code__.co_argcount == 6. Verified with Python 3.14.3."
    - "threading.Thread.start.__code__.co_varnames[0] == 'self' (len 4); len=1; co_argcount=1. Verified with Python 3.14.3."
    - "threading.Thread.run.__code__.co_varnames[0] == 'self' (len 4); len=1; co_argcount=1. Verified with Python 3.14.3."
    - "threading.Thread.join.__code__.co_varnames[0] == 'self' (len 4); [1]='timeout'(7); len=2; co_argcount=2. Verified with Python 3.14.3."
    - "threading.Thread.is_alive.__code__.co_varnames[0] == 'self' (len 4); len=1; co_argcount=1. Verified with Python 3.14.3."
    - "Thread.__init__ has the most complex co_varnames (len=9) among the Thread methods covered here; start/run/is_alive share the minimal pattern (len=1, co_varnames=('self',)); join has len=2 with 'timeout' as a second param."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread.__init__ co_varnames elements [0]-[2] and length
#
# Wave 275 theme: threading.Thread.__init__(self, group=None, target=None,
# name=None, args=(), kwargs=None, *, daemon=None) is a pure-Python method
# defined in Lib/threading.py. Its co_varnames has 9 entries:
#   co_varnames[0] == 'self'         (4 chars) — the instance
#   co_varnames[1] == 'group'        (5 chars) — reserved, must be None
#   co_varnames[2] == 'target'       (6 chars) — callable run in thread
#   co_varnames[3] == 'name'         (4 chars) — thread name
#   co_varnames[4] == 'args'         (4 chars) — positional args tuple
#   co_varnames[5] == 'kwargs'       (6 chars) — keyword args dict
#   co_varnames[6] == 'daemon'       (6 chars) — daemon flag
#   co_varnames[7] == 'context'      (7 chars) — internal local for context
#   co_varnames[8] == 'target_name'  (11 chars)— internal local for target name
# co_argcount == 6: self+group+target+name+args+kwargs are positional params.
# 'daemon' is a keyword-only param; 'context' and 'target_name' are internals.
#
# New to extra125.
# ---------------------------------------------------------------------------

table threading_extra125.thread_init_co_varnames:
  description: "threading.Thread.__init__ co_varnames[0]='self'(4), [1]='group'(5), [2]='target'(6); total len=9; co_argcount=6; most complex Thread method co_varnames; wave 275; new to extra125"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingthicv125

  columns: [id, function, args, expected, description]
  rows:
    - [init_cv0_eq,
       "Thread.__init__.__code__.co_varnames.__getitem__",
       [0],
       "self",
       "threading.Thread.__init__.__code__.co_varnames[0] == 'self' — the instance parameter; first positional in Thread.__init__(self, group=None, target=None, ...); tuple.__getitem__(0) returns 'self'; new to extra125"]
    - [init_cv1_eq,
       "Thread.__init__.__code__.co_varnames.__getitem__",
       [1],
       "group",
       "threading.Thread.__init__.__code__.co_varnames[1] == 'group' — reserved thread group parameter; must be None; included for compatibility with Java thread groups; 'group' has 5 chars; tuple.__getitem__(1) returns 'group'; new to extra125"]
    - [init_cv1_len,
       "Thread.__init__.__code__.co_varnames.__getitem__(1).__len__",
       [],
       5,
       "threading.Thread.__init__.__code__.co_varnames[1].__len__() == 5 — 'group' has 5 chars: g-r-o-u-p; one more than 'self' (4) and one less than 'target' (6); str.__len__() returns 5; new to extra125"]
    - [init_cv2_eq,
       "Thread.__init__.__code__.co_varnames.__getitem__",
       [2],
       "target",
       "threading.Thread.__init__.__code__.co_varnames[2] == 'target' — the callable that is invoked in the new thread by the run() method; 'target' has 6 chars; tuple.__getitem__(2) returns 'target'; new to extra125"]
    - [init_cv2_len,
       "Thread.__init__.__code__.co_varnames.__getitem__(2).__len__",
       [],
       6,
       "threading.Thread.__init__.__code__.co_varnames[2].__len__() == 6 — 'target' has 6 chars: t-a-r-g-e-t; same length as 'kwargs' (co_varnames[5]) and 'daemon' (co_varnames[6]); str.__len__() returns 6; new to extra125"]
    - [init_cv_len_9,
       "Thread.__init__.__code__.co_varnames.__len__",
       [],
       9,
       "threading.Thread.__init__.__code__.co_varnames.__len__() == 9 — Thread.__init__ has 9 entries: self+group+target+name+args+kwargs (6 positional) + daemon (keyword-only) + context+target_name (2 internal locals); tuple.__len__() returns 9; new to extra125"]
    - [init_co_argcount_eq_6,
       "Thread.__init__.__code__.co_argcount.__eq__",
       [6],
       true,
       "threading.Thread.__init__.__code__.co_argcount.__eq__(6) == True — 6 positional params: self, group, target, name, args, kwargs; 'daemon' is keyword-only (not counted by co_argcount); 'context' and 'target_name' are internal locals; int.__eq__(6) returns True; new to extra125"]

# ---------------------------------------------------------------------------
# Table 2: threading.Thread.start, run, is_alive co_varnames (all len=1)
#
# Wave 275 theme: Thread.start(self), Thread.run(self), and Thread.is_alive(self)
# are all pure-Python methods with co_varnames = ('self',) and len = 1.
# These are the simplest Thread methods — only 'self' with no additional
# declared parameters or internal locals. co_argcount == 1 for all three.
# Thread.start dispatches to the C-level thread start; Thread.run calls the
# target; Thread.is_alive checks if the thread is still running.
#
# Thread.start.__code__.co_varnames[0] == 'self'  len = 1
# Thread.run.__code__.co_varnames[0] == 'self'    len = 1
# Thread.is_alive.__code__.co_varnames[0] == 'self'  len = 1
#
# New to extra125.
# ---------------------------------------------------------------------------

table threading_extra125.thread_start_run_is_alive_co_varnames:
  description: "threading.Thread.start/run/is_alive co_varnames[0]='self'(4); all tuple len=1; all co_argcount=1; simplest Thread method co_varnames; all self-only; wave 275; new to extra125"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingthsricv125

  columns: [id, function, args, expected, description]
  rows:
    - [start_cv0_eq,
       "Thread.start.__code__.co_varnames.__getitem__",
       [0],
       "self",
       "threading.Thread.start.__code__.co_varnames[0] == 'self' — the instance parameter; Thread.start(self) initiates thread execution; 'self' has 4 chars; tuple.__getitem__(0) returns 'self'; new to extra125"]
    - [start_cv_len_1,
       "Thread.start.__code__.co_varnames.__len__",
       [],
       1,
       "threading.Thread.start.__code__.co_varnames.__len__() == 1 — Thread.start has only 'self' as a local; no additional parameters or internal variables in co_varnames; tuple.__len__() returns 1; new to extra125"]
    - [run_cv0_eq,
       "Thread.run.__code__.co_varnames.__getitem__",
       [0],
       "self",
       "threading.Thread.run.__code__.co_varnames[0] == 'self' — the instance parameter; Thread.run(self) calls self._target with self._args and self._kwargs; tuple.__getitem__(0) returns 'self'; new to extra125"]
    - [run_cv_len_1,
       "Thread.run.__code__.co_varnames.__len__",
       [],
       1,
       "threading.Thread.run.__code__.co_varnames.__len__() == 1 — Thread.run has only 'self'; no additional parameters; tuple.__len__() returns 1; new to extra125"]
    - [is_alive_cv0_eq,
       "Thread.is_alive.__code__.co_varnames.__getitem__",
       [0],
       "self",
       "threading.Thread.is_alive.__code__.co_varnames[0] == 'self' — the instance parameter; Thread.is_alive(self) returns True if the thread is still running; tuple.__getitem__(0) returns 'self'; new to extra125"]
    - [is_alive_cv_len_1,
       "Thread.is_alive.__code__.co_varnames.__len__",
       [],
       1,
       "threading.Thread.is_alive.__code__.co_varnames.__len__() == 1 — Thread.is_alive has only 'self'; no additional locals; tuple.__len__() returns 1; new to extra125"]

# ---------------------------------------------------------------------------
# Table 3: threading.Thread.join co_varnames and Thread method co_varnames comparison
#
# Wave 275 theme: Thread.join(self, timeout=None) has co_varnames of length 2:
#   co_varnames[0] == 'self'     (4 chars)
#   co_varnames[1] == 'timeout'  (7 chars)
# co_argcount == 2: both 'self' and 'timeout' are positional params.
# Compare Thread method co_varnames lengths:
#   Thread.__init__: len=9 (most complex: 6 positional + daemon + 2 internal)
#   Thread.join:     len=2 (self + timeout)
#   Thread.start:    len=1 (self only)
#   Thread.run:      len=1 (self only)
#   Thread.is_alive: len=1 (self only)
# Thread.join has intermediate complexity between __init__ (9) and start/run/is_alive (1).
#
# New to extra125.
# ---------------------------------------------------------------------------

table threading_extra125.thread_join_and_method_len_comparison:
  description: "threading.Thread.join co_varnames[0]='self'(4), [1]='timeout'(7); len=2; co_argcount=2; Thread method co_varnames lengths: __init__=9, join=2, start=run=is_alive=1; wave 275; new to extra125"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingthjlc125

  columns: [id, function, args, expected, description]
  rows:
    - [join_cv0_eq,
       "Thread.join.__code__.co_varnames.__getitem__",
       [0],
       "self",
       "threading.Thread.join.__code__.co_varnames[0] == 'self' — the instance parameter; Thread.join(self, timeout=None) blocks until the thread terminates; tuple.__getitem__(0) returns 'self'; new to extra125"]
    - [join_cv1_eq,
       "Thread.join.__code__.co_varnames.__getitem__",
       [1],
       "timeout",
       "threading.Thread.join.__code__.co_varnames[1] == 'timeout' — optional join timeout; Thread.join waits up to 'timeout' seconds for the thread to finish; 'timeout' has 7 chars; same param name as Event.wait co_varnames[1] (extra124); tuple.__getitem__(1) returns 'timeout'; new to extra125"]
    - [join_cv1_len,
       "Thread.join.__code__.co_varnames.__getitem__(1).__len__",
       [],
       7,
       "threading.Thread.join.__code__.co_varnames[1].__len__() == 7 — 'timeout' has 7 chars: t-i-m-e-o-u-t; same string and length as Event.wait co_varnames[1] (extra124); str.__len__() returns 7; new to extra125"]
    - [join_cv_len_2,
       "Thread.join.__code__.co_varnames.__len__",
       [],
       2,
       "threading.Thread.join.__code__.co_varnames.__len__() == 2 — Thread.join has 2 local variable names: 'self' and 'timeout'; more complex than start/run/is_alive (all len=1) but simpler than __init__ (len=9); tuple.__len__() returns 2; new to extra125"]
    - [join_co_argcount_eq_2,
       "Thread.join.__code__.co_argcount.__eq__",
       [2],
       true,
       "threading.Thread.join.__code__.co_argcount.__eq__(2) == True — join(self, timeout=None) has 2 declared positional params; both co_varnames entries are declared params (no internal locals); int.__eq__(2) returns True; new to extra125"]
    - [init_cv_len_gt_join,
       "Thread.__init__.__code__.co_varnames.__len__().__gt__",
       [2],
       true,
       "threading.Thread.__init__.__code__.co_varnames.__len__().__gt__(2) == True — Thread.__init__ co_varnames len (9) is greater than Thread.join co_varnames len (2); int.__gt__(2) returns True; new to extra125"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra125
# ---------------------------------------------------------------------------

invariant threading_extra125.thread_init_cv0_self:
  description: "threading.Thread.__init__.__code__.co_varnames[0] == 'self' — instance param; 4 chars; co_varnames len=9 (most complex Thread method); wave 275; new to extra125"
  kind: python_call_eq
  function: "Thread.__init__.__code__.co_varnames.__getitem__"
  args: [0]
  expected: "self"

invariant threading_extra125.thread_init_cv1_group:
  description: "threading.Thread.__init__.__code__.co_varnames[1] == 'group' — reserved thread group param; 5 chars; co_argcount=6; wave 275; new to extra125"
  kind: python_call_eq
  function: "Thread.__init__.__code__.co_varnames.__getitem__"
  args: [1]
  expected: "group"

invariant threading_extra125.thread_init_cv_len:
  description: "threading.Thread.__init__.__code__.co_varnames.__len__() == 9 — most complex Thread method; 6 positional + daemon (kw-only) + 2 internal locals; wave 275; new to extra125"
  kind: python_call_eq
  function: "Thread.__init__.__code__.co_varnames.__len__"
  args: []
  expected: 9

invariant threading_extra125.thread_join_cv1_timeout:
  description: "threading.Thread.join.__code__.co_varnames[1] == 'timeout' — optional timeout param; 7 chars; same as Event.wait co_varnames[1] (extra124); wave 275; new to extra125"
  kind: python_call_eq
  function: "Thread.join.__code__.co_varnames.__getitem__"
  args: [1]
  expected: "timeout"

invariant threading_extra125.thread_start_cv_len:
  description: "threading.Thread.start.__code__.co_varnames.__len__() == 1 — only 'self'; simplest Thread method co_varnames; shared with run and is_alive; wave 275; new to extra125"
  kind: python_call_eq
  function: "Thread.start.__code__.co_varnames.__len__"
  args: []
  expected: 1
