spec: logging
version: ">=3.2"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "Python logging documentation — https://docs.python.org/3/library/logging.html"
    - "Test vectors verified by running Python 3.14.3 logging module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
  notes:
    - "logging.DEBUG=10, INFO=20, WARNING=30, ERROR=40, CRITICAL=50, NOTSET=0."
    - "logging.WARN=30 is a deprecated alias for WARNING. logging.FATAL=50 is a deprecated alias for CRITICAL."
    - "logging.getLevelName(level_int) returns the level name string."
    - "logging.getLevelName(level_name_str) returns the level int (reverse lookup, Python 3.4+)."
    - "logging.getLevelName(99) returns 'Level 99' for unknown integer levels."
    - "Logging levels are integers; higher value means higher severity."
    - "All expected values verified by running Python 3.14.3 logging module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Level constants — pin exact integer values via attribute chaining
#
# Access pattern: getattr(logging, 'NOTSET') → int, then .__eq__(0) → True.
# ---------------------------------------------------------------------------

table logging.level_values:
  kind: python_call_eq
  category: level_int
  id_prefix: level

  columns: [id, function, args, expected]
  rows:
    - [notset,   NOTSET.__eq__,   [0],  true]
    - [debug,    DEBUG.__eq__,    [10], true]
    - [info,     INFO.__eq__,     [20], true]
    - [warning,  WARNING.__eq__,  [30], true]
    - [error,    ERROR.__eq__,    [40], true]
    - [critical, CRITICAL.__eq__,  [50], true]

# Deprecated aliases — WARN == WARNING, FATAL == CRITICAL

invariant logging.levels.warn_alias:
  description: "logging.WARN == 30 — WARN is a deprecated alias for WARNING"
  category: level_int
  kind: python_call_eq
  function: WARN.__eq__
  args: [30]
  expected: true

invariant logging.levels.fatal_alias:
  description: "logging.FATAL == 50 — FATAL is a deprecated alias for CRITICAL"
  category: level_int
  kind: python_call_eq
  function: FATAL.__eq__
  args: [50]
  expected: true

# ---------------------------------------------------------------------------
# getLevelName — integer → name string
# ---------------------------------------------------------------------------

table logging.getLevelName.int_to_str:
  kind: python_call_eq
  category: int_to_name
  function: getLevelName
  id_prefix: lname

  columns: [id, args, expected]
  rows:
    - [notset_name,   [0],  "NOTSET"]
    - [debug_name,    [10], "DEBUG"]
    - [info_name,     [20], "INFO"]
    - [warning_name,  [30], "WARNING"]
    - [error_name,    [40], "ERROR"]
    - [critical_name, [50], "CRITICAL"]
    - [unknown_99,    [99], "Level 99"]

# ---------------------------------------------------------------------------
# getLevelName — name string → integer (reverse lookup, Python 3.4+)
# ---------------------------------------------------------------------------

table logging.getLevelName.str_to_int:
  kind: python_call_eq
  category: name_to_int
  function: getLevelName
  id_prefix: lnum

  columns: [id, args, expected]
  rows:
    - [notset_int,    ["NOTSET"],    0]
    - [debug_int,     ["DEBUG"],     10]
    - [info_int,      ["INFO"],      20]
    - [warning_int,   ["WARNING"],   30]
    - [error_int,     ["ERROR"],     40]
    - [critical_int,  ["CRITICAL"],  50]

# ---------------------------------------------------------------------------
# Level ordering — severity increases with integer value
# ---------------------------------------------------------------------------

invariant logging.levels.notset_lt_debug:
  description: "logging.NOTSET < logging.DEBUG — NOTSET(0) is below all real levels"
  category: ordering
  kind: python_call_eq
  function: NOTSET.__lt__
  args: [10]
  expected: true

invariant logging.levels.debug_lt_info:
  description: "logging.DEBUG < logging.INFO"
  category: ordering
  kind: python_call_eq
  function: DEBUG.__lt__
  args: [20]
  expected: true

invariant logging.levels.info_lt_warning:
  description: "logging.INFO < logging.WARNING"
  category: ordering
  kind: python_call_eq
  function: INFO.__lt__
  args: [30]
  expected: true

invariant logging.levels.warning_lt_error:
  description: "logging.WARNING < logging.ERROR"
  category: ordering
  kind: python_call_eq
  function: WARNING.__lt__
  args: [40]
  expected: true

invariant logging.levels.error_lt_critical:
  description: "logging.ERROR < logging.CRITICAL"
  category: ordering
  kind: python_call_eq
  function: ERROR.__lt__
  args: [50]
  expected: true

# ---------------------------------------------------------------------------
# Class name metadata — verify __name__ of core logging classes
# ---------------------------------------------------------------------------

table logging.class_names:
  kind: python_call_eq
  category: classes
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [logger,        Logger.__name__.__eq__,        ["Logger"],        true]
    - [handler,       Handler.__name__.__eq__,        ["Handler"],       true]
    - [formatter,     Formatter.__name__.__eq__,      ["Formatter"],     true]
    - [filter,        Filter.__name__.__eq__,         ["Filter"],        true]
    - [stream,        StreamHandler.__name__.__eq__,  ["StreamHandler"], true]
    - [file,          FileHandler.__name__.__eq__,    ["FileHandler"],   true]
    - [logrecord,     LogRecord.__name__.__eq__,      ["LogRecord"],     true]
    - [loggeradapter, LoggerAdapter.__name__.__eq__,  ["LoggerAdapter"], true]

# ---------------------------------------------------------------------------
# Function name metadata — verify __name__ of top-level logging functions
# ---------------------------------------------------------------------------

table logging.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [getlogger,    getLogger.__name__.__eq__,    ["getLogger"],    true]
    - [basicconfig,  basicConfig.__name__.__eq__,  ["basicConfig"],  true]
    - [getlevelname, getLevelName.__name__.__eq__,  ["getLevelName"], true]
    - [makelogrecord, makeLogRecord.__name__.__eq__, ["makeLogRecord"], true]
    - [disable,      disable.__name__.__eq__,       ["disable"],      true]
