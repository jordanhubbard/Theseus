spec: asyncio_extra77
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio TaskGroup"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/taskgroups.py"
  notes:
    - "This spec extends asyncio_extra76.zspec.zsdl."
    - "This spec covers: wave 243 theme — asyncio Condition.__dict__ content + TaskGroup.__dict__ content. NEW in extra77: Condition.__dict__.__class__.__name__=='mappingproxy'; Condition.__dict__.__contains__('wait')==True; Condition.__dict__.__contains__('notify')==True; Condition.__dict__.__contains__('notify_all')==True; Condition.__dict__.__contains__('wait_for')==True; TaskGroup.__dict__.__class__.__name__=='mappingproxy'; TaskGroup.__dict__.__contains__('create_task')==True; TaskGroup.__dict__.__contains__('__aenter__')==True; TaskGroup.__dict__.__contains__('__aexit__')==True. NOTE: Condition.__dict__ does NOT contain 'acquire' or 'release' — those are inherited from the underlying lock; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Condition.__dict__.__class__.__name__ == 'mappingproxy'. Condition is a Python class in asyncio/locks.py; its __dict__ is a read-only mappingproxy. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Condition.__dict__.__contains__('wait') == True. Condition defines wait as a coroutine method directly in asyncio/locks.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Condition.__dict__.__contains__('notify') == True. Condition defines notify directly in asyncio/locks.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Condition.__dict__.__contains__('notify_all') == True. Condition defines notify_all directly in asyncio/locks.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Condition.__dict__.__contains__('wait_for') == True. Condition defines wait_for as a coroutine method directly in asyncio/locks.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.TaskGroup.__dict__.__class__.__name__ == 'mappingproxy'. TaskGroup is a Python class in asyncio/taskgroups.py; its __dict__ is a read-only mappingproxy. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.TaskGroup.__dict__.__contains__('create_task') == True. TaskGroup defines create_task directly in asyncio/taskgroups.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.TaskGroup.__dict__.__contains__('__aenter__') == True. TaskGroup is an async context manager and defines __aenter__ directly in its __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.TaskGroup.__dict__.__contains__('__aexit__') == True. TaskGroup defines __aexit__ directly in its __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Condition.__dict__ class name and wait/notify methods — extra77
#
# Wave 243 theme: asyncio Condition.__dict__ content + TaskGroup.__dict__ content.
#
# Condition.__dict__.__class__.__name__ == 'mappingproxy'
# Condition.__dict__.__contains__('wait') == True
# Condition.__dict__.__contains__('notify') == True
# Condition.__dict__.__contains__('notify_all') == True
# ---------------------------------------------------------------------------

table asyncio_extra77.Condition_dict_class_and_notify_methods:
  description: "asyncio Condition.__dict__ class name and wait/notify method content checks in asynciomore77 namespace — wave 243 theme: Condition.__dict__ content; Condition.__dict__.__class__.__name__=='mappingproxy' (class __dict__ is read-only mappingproxy in CPython); Condition.__dict__.__contains__('wait')==True; Condition.__dict__.__contains__('notify')==True; Condition.__dict__.__contains__('notify_all')==True; NOTE: acquire/release are NOT in Condition.__dict__ (inherited from underlying lock); verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: asynciomore77

  columns: [id, function, args, expected, description]
  rows:
    - [cond_dict_class_name,    Condition.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true, "Condition.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy in CPython; verified with Python 3.14.3"]
    - [cond_dict_has_wait,      Condition.__dict__.__contains__,              ["wait"],          true, "Condition.__dict__.__contains__('wait') == True — Condition defines wait coroutine in asyncio/locks.py; verified with Python 3.14.3"]
    - [cond_dict_has_notify,    Condition.__dict__.__contains__,              ["notify"],        true, "Condition.__dict__.__contains__('notify') == True — Condition defines notify in asyncio/locks.py; verified with Python 3.14.3"]
    - [cond_dict_has_notify_all, Condition.__dict__.__contains__,             ["notify_all"],    true, "Condition.__dict__.__contains__('notify_all') == True — Condition defines notify_all in asyncio/locks.py; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio Condition.__dict__ wait_for content — extra77
#
# Condition.__dict__.__contains__('wait_for') == True
# ---------------------------------------------------------------------------

table asyncio_extra77.Condition_dict_wait_for:
  description: "asyncio Condition.__dict__ wait_for method content check in asynciomore77 namespace — wave 243 theme: Condition.__dict__ content; Condition.__dict__.__contains__('wait_for')==True (Condition defines wait_for as a coroutine method in asyncio/locks.py); Condition.__dict__.__class__.__name__=='mappingproxy' (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: asynciomore77a

  columns: [id, function, args, expected, description]
  rows:
    - [cond_dict_has_wait_for,   Condition.__dict__.__contains__,              ["wait_for"],     true, "Condition.__dict__.__contains__('wait_for') == True — Condition defines wait_for coroutine in asyncio/locks.py; verified with Python 3.14.3"]
    - [cond_dict_cls_cross_check, Condition.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true, "Condition.__dict__.__class__.__name__ == 'mappingproxy' — cross-check; verified with Python 3.14.3"]

