table asyncio_extra77.Condition_and_TaskGroup_dict_cross_check:
  description: "asyncio Condition and TaskGroup __dict__ class name cross-check in asynciomore77 namespace — wave 243 theme: both Condition and TaskGroup __dict__ are mappingproxy; Condition.__dict__.__class__.__name__=='mappingproxy'; TaskGroup.__dict__.__class__.__name__=='mappingproxy'; Condition.__dict__.__contains__('notify')==True; TaskGroup.__dict__.__contains__('create_task')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: asynciomore77c

  columns: [id, function, args, expected, description]
  rows:
    - [cond_dict_cls_check,        Condition.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true, "Condition.__dict__.__class__.__name__ == 'mappingproxy' — cross-check; verified with Python 3.14.3"]
    - [tg_dict_cls_check,          TaskGroup.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true, "TaskGroup.__dict__.__class__.__name__ == 'mappingproxy' — cross-check; verified with Python 3.14.3"]
    - [cond_dict_notify_check,     Condition.__dict__.__contains__,              ["notify"],        true, "Condition.__dict__.__contains__('notify') == True — cross-check; verified with Python 3.14.3"]
    - [tg_dict_create_task_check,  TaskGroup.__dict__.__contains__,              ["create_task"],   true, "TaskGroup.__dict__.__contains__('create_task') == True — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra77
# ---------------------------------------------------------------------------

invariant asyncio_extra77.Condition_dict_class_name:
  description: "asyncio.Condition.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — Condition is a Python class in asyncio/locks.py; class __dict__ objects are always mappingproxy in CPython; NEW in extra77: first standalone __dict__.__class__.__name__ invariant for Condition in asynciomore77 namespace; wave 243; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: Condition.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant asyncio_extra77.Condition_dict_has_wait:
  description: "asyncio.Condition.__dict__.__contains__('wait') returns True — Condition defines the wait() coroutine method directly in asyncio/locks.py; NEW in extra77: first standalone __contains__('wait') invariant for Condition.__dict__ in asynciomore77 namespace; wave 243; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: Condition.__dict__.__contains__
  args: ["wait"]
  expected: true

invariant asyncio_extra77.Condition_dict_has_notify_all:
  description: "asyncio.Condition.__dict__.__contains__('notify_all') returns True — Condition defines the notify_all() method directly in asyncio/locks.py; NEW in extra77: first standalone __contains__('notify_all') invariant for Condition.__dict__ in asynciomore77 namespace; wave 243; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: Condition.__dict__.__contains__
  args: ["notify_all"]
  expected: true

invariant asyncio_extra77.TaskGroup_dict_class_name:
  description: "asyncio.TaskGroup.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — TaskGroup is a Python class in asyncio/taskgroups.py; class __dict__ objects are always mappingproxy in CPython; NEW in extra77: first standalone __dict__.__class__.__name__ invariant for TaskGroup in asynciomore77 namespace; wave 243; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: TaskGroup.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant asyncio_extra77.TaskGroup_dict_has_aenter:
  description: "asyncio.TaskGroup.__dict__.__contains__('__aenter__') returns True — TaskGroup is an async context manager and defines __aenter__ directly in its __dict__ in asyncio/taskgroups.py; NEW in extra77: first standalone __contains__('__aenter__') invariant for TaskGroup.__dict__ in asynciomore77 namespace; wave 243; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: TaskGroup.__dict__.__contains__
  args: ["__aenter__"]
  expected: true
