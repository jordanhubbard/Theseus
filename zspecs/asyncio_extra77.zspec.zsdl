table asyncio_extra77.TaskGroup_dict_class_and_methods:
  description: "asyncio TaskGroup.__dict__ class name and async context manager method content checks in asynciomore77 namespace — wave 243 theme: TaskGroup.__dict__ content; TaskGroup.__dict__.__class__.__name__=='mappingproxy' (class __dict__ is read-only mappingproxy); TaskGroup.__dict__.__contains__('create_task')==True; TaskGroup.__dict__.__contains__('__aenter__')==True (TaskGroup is an async context manager); TaskGroup.__dict__.__contains__('__aexit__')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: asynciomore77b

  columns: [id, function, args, expected, description]
  rows:
    - [tg_dict_class_name,     TaskGroup.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true, "TaskGroup.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy in CPython; verified with Python 3.14.3"]
    - [tg_dict_has_create_task, TaskGroup.__dict__.__contains__,             ["create_task"],  true, "TaskGroup.__dict__.__contains__('create_task') == True — TaskGroup defines create_task in asyncio/taskgroups.py; verified with Python 3.14.3"]
    - [tg_dict_has_aenter,     TaskGroup.__dict__.__contains__,              ["__aenter__"],   true, "TaskGroup.__dict__.__contains__('__aenter__') == True — TaskGroup defines __aenter__ as async context manager entry; verified with Python 3.14.3"]
    - [tg_dict_has_aexit,      TaskGroup.__dict__.__contains__,              ["__aexit__"],    true, "TaskGroup.__dict__.__contains__('__aexit__') == True — TaskGroup defines __aexit__ as async context manager exit; verified with Python 3.14.3"]

