spec: dynaconf_rust
version: ">=3.9"
backend: rust_module(dynaconf_rust)

docs: https://www.dynaconf.com/

provenance:
  derived_from:
    - "https://www.dynaconf.com/ — Dynaconf documentation"
  not_derived_from:
    - "dynaconf source: dynaconf/__init__.py"
  notes:
    - "Dynaconf provides settings management for Python."
    - "from dynaconf import Dynaconf; settings = Dynaconf()."
    - "Dynaconf(FOO='bar').FOO == 'bar'."
    - "Dynaconf(NUM=42).NUM == 42."
    - "settings = Dynaconf(); settings.get('MISSING', default='x') == 'x'."
    - "Expose dynaconf_get(key, value, default) -> any: Dynaconf(**{key: value}).get(key)."
    - "Expose dynaconf_missing_default(key, default) -> any: Dynaconf().get(key, default=default)."
    - "All test vectors verified against dynaconf 3.2.6."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# dynaconf_get — get configured value
table dynaconf_rust.settings.get:
  kind: python_call_eq
  category: get
  id_prefix: dyn_g
  function: dynaconf_get

  columns: [id, args, expected]
  rows:
    - [str_val,  ["MYKEY", "bar",  "MYKEY"],  "bar"]
    - [int_val,  ["MYNUM", 42,     "MYNUM"],  42]

# dynaconf_missing_default — default for missing key
table dynaconf_rust.settings.missing:
  kind: python_call_eq
  category: missing_default
  id_prefix: dyn_m
  function: dynaconf_missing_default

  columns: [id, args, expected]
  rows:
    - [str_def, ["NOTEXIST_XYZ", "fallback"], "fallback"]
    - [int_def, ["NOTEXIST_XYZ", 99],          99]

