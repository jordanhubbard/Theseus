spec: itertools_extra59
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra58.zspec.zsdl."
    - "Wave 225 theme: __loader__ identity checks + __spec__ attribute chains + module __file__ checks (None for C extensions, path strings for Python files) + __cached__ attribute presence."
    - "itertools is a C builtin module (Modules/itertoolsmodule.c). Its __loader__ is the BuiltinImporter class itself (not an instance of it) — this is because Python's import system for built-in modules assigns the loader class directly as __loader__, not an instance. Therefore itertools.__loader__.__class__.__name__ == 'type' (since __loader__ IS a class, and classes are instances of 'type'). The loader's own name is accessible via itertools.__loader__.__name__ == 'BuiltinImporter'. No prior itertools spec has table rows checking __loader__.__class__.__name__.__eq__('type') or __loader__.__name__.__eq__('BuiltinImporter')."
    - "itertools.__spec__ is a ModuleSpec instance (same as all importable modules, including C builtins). itertools.__spec__.__class__.__name__ == 'ModuleSpec'. itertools.__spec__.origin == 'built-in' (not a file path). No prior itertools spec has a table row checking __spec__.__class__.__name__.__eq__('ModuleSpec')."
    - "itertools has NO __file__ attribute — hasattr(itertools, '__file__') is False and '__file__' not in itertools.__dict__. C builtin modules have no disk location so the import system does not set __file__. The check itertools.__dict__.__contains__('__file__') == False confirms absence. No prior itertools spec has a table row checking __dict__.__contains__('__file__')."
    - "itertools has NO __cached__ attribute — hasattr(itertools, '__cached__') is False and '__cached__' not in itertools.__dict__. C builtin modules have no source file and therefore no bytecode cache. The check itertools.__dict__.__contains__('__cached__') == False confirms absence. No prior itertools spec has a table row checking __dict__.__contains__('__cached__')."
    - "This spec covers: itertools.__loader__.__class__.__name__.__eq__('type')==true; itertools.__loader__.__name__.__eq__('BuiltinImporter')==true; itertools.__spec__.__class__.__name__.__eq__('ModuleSpec')==true; itertools.__dict__.__contains__('__file__')==false; itertools.__dict__.__contains__('__cached__')==false."
    - "Key findings: itertools.__loader__ is the BuiltinImporter class itself (not an instance), so __loader__.__class__.__name__ == 'type'. The loader's name is 'BuiltinImporter' accessible via __loader__.__name__. itertools.__spec__ is a ModuleSpec with origin 'built-in' (not a file path). itertools has no __file__ and no __cached__ — both attributes are entirely absent from its __dict__. This contrasts sharply with pure-Python modules (functools, inspect, threading) which have __file__ and __cached__ as str paths. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools.__loader__ identity — extra59
#
# Wave 225 theme: __loader__ identity checks.
#
# itertools.__loader__ is the BuiltinImporter class itself (from
# _frozen_importlib). Unlike pure-Python modules where __loader__ is an
# *instance* of a loader class (e.g., a SourceFileLoader instance), builtin
# C extension modules have __loader__ set to the BuiltinImporter *class* directly.
#
# Because __loader__ is a class (not an instance), its __class__ is 'type'
# (the metaclass of all classes in Python). So:
#   itertools.__loader__.__class__.__name__ == 'type'
#
# The loader's own name (as a class attribute) is 'BuiltinImporter':
#   itertools.__loader__.__name__ == 'BuiltinImporter'
#
# Both checks confirm that itertools uses the BuiltinImporter, which loads
# modules that are compiled into the CPython interpreter binary.
#
# No prior itertools spec has table rows checking __loader__.__class__.__name__
# or __loader__.__name__. Both rows are new to extra59.
# ---------------------------------------------------------------------------

table itertools_extra59.loader_identity:
  description: "itertools.__loader__.__class__.__name__.__eq__('type')==true and __loader__.__name__.__eq__('BuiltinImporter')==true — itertools is C builtin; __loader__ IS the BuiltinImporter class (not an instance), so its __class__ is 'type'; wave 225 __loader__ identity check; no prior itertools spec has table rows for __loader__; new to extra59"
  kind: python_call_eq
  category: class_identity
  id_prefix: itertload59

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_name_eq_type,
       __loader__.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.__loader__.__class__.__name__.__eq__('type') == True — itertools.__loader__ is the _frozen_importlib.BuiltinImporter class itself (not an instance of it); Python's import system for C builtin modules assigns the BuiltinImporter class directly as __loader__; because __loader__ is a class, its __class__ is 'type' (the metaclass of all Python classes); this contrasts with pure-Python modules (functools, inspect, threading) where __loader__ is a SourceFileLoader *instance* and __loader__.__class__.__name__ == 'SourceFileLoader'; no prior itertools spec has a table row checking __loader__.__class__.__name__.__eq__('type'); new to extra59"]
    - [loader_name_eq_BuiltinImporter,
       __loader__.__name__.__eq__,
       ["BuiltinImporter"],
       true,
       "itertools.__loader__.__name__.__eq__('BuiltinImporter') == True — itertools.__loader__ is the _frozen_importlib.BuiltinImporter class; as a class, it has a __name__ attribute equal to 'BuiltinImporter' (15 chars); BuiltinImporter is the CPython importlib loader responsible for importing modules that are compiled into the interpreter binary (built-in modules); itertools is one such module, compiled from Modules/itertoolsmodule.c and linked directly into the interpreter; __loader__.__name__ == 'BuiltinImporter' confirms which loader class handles itertools; no prior itertools spec has a table row checking __loader__.__name__.__eq__('BuiltinImporter'); new to extra59"]

# ---------------------------------------------------------------------------
# itertools.__spec__ class identity — extra59
#
# Wave 225 theme: __spec__ attribute chains.
#
# itertools.__spec__ is a ModuleSpec instance from _frozen_importlib, just like
# all importable Python modules (pure-Python or C extension). The ModuleSpec
# class is universal across all importable modules (PEP 451). What differs for
# C builtins is the ModuleSpec's origin field: for itertools, origin == 'built-in'
# rather than a filesystem path.
#
# The check: itertools.__spec__.__class__.__name__.__eq__('ModuleSpec')
# — __spec__ is a ModuleSpec object, and 'ModuleSpec'.__name__ == 'ModuleSpec'.
#
# No prior itertools spec has a table row checking __spec__.__class__.__name__.__eq__('ModuleSpec').
# New to extra59.
# ---------------------------------------------------------------------------

table itertools_extra59.spec_class_identity:
  description: "itertools.__spec__.__class__.__name__.__eq__('ModuleSpec')==true — even C builtin modules have a ModuleSpec __spec__ (PEP 451); origin is 'built-in' not a file path; wave 225 __spec__ chain; no prior itertools spec has table rows for __spec__.__class__.__name__; new to extra59"
  kind: python_call_eq
  category: class_identity
  id_prefix: itertload59

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_name_eq_ModuleSpec,
       __spec__.__class__.__name__.__eq__,
       ["ModuleSpec"],
       true,
       "itertools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — itertools.__spec__ is an instance of _frozen_importlib.ModuleSpec; the ModuleSpec class (introduced in PEP 451, Python 3.4) is used universally for all importable modules including C built-in modules; for itertools, __spec__.origin == 'built-in' and __spec__.has_location is False (no disk location); for pure-Python modules like functools, __spec__.origin is a filesystem path; despite this difference in origin, the __spec__.__class__.__name__ is 'ModuleSpec' for both builtin and pure-Python modules; no prior itertools spec has a table row checking __spec__.__class__.__name__.__eq__('ModuleSpec'); new to extra59"]

# ---------------------------------------------------------------------------
# itertools __file__ and __cached__ absence — extra59
#
# Wave 225 theme: __file__ checks (None for C extensions) + __cached__ presence.
#
# itertools is a C builtin module and has NO __file__ attribute.
# hasattr(itertools, '__file__') is False.
# '__file__' not in itertools.__dict__ — confirmed: itertools.__dict__.__contains__('__file__') == False.
#
# Similarly, itertools has NO __cached__ attribute.
# hasattr(itertools, '__cached__') is False.
# '__cached__' not in itertools.__dict__ — confirmed: itertools.__dict__.__contains__('__cached__') == False.
#
# This is fundamentally different from pure-Python modules (functools, inspect,
# threading) which have both __file__ and __cached__ as str paths.
# C builtin modules are compiled into the interpreter binary and have no disk
# location, so the import system does not set __file__ or __cached__.
#
# The __dict__.__contains__ checks use the module's __dict__ attribute (which
# is the module's namespace dictionary) to confirm that the keys '__file__' and
# '__cached__' are not present at all.
#
# No prior itertools spec has table rows checking __dict__.__contains__('__file__')
# or __dict__.__contains__('__cached__'). Both are new to extra59.
# ---------------------------------------------------------------------------

table itertools_extra59.file_cached_absence:
  description: "itertools.__dict__.__contains__('__file__')==false and __dict__.__contains__('__cached__')==false — C builtin modules have no __file__ or __cached__ (no disk location); wave 225 __file__/__cached__ checks; no prior itertools spec has table rows confirming __file__/__cached__ absence via __dict__.__contains__; new to extra59"
  kind: python_call_eq
  category: membership
  id_prefix: itertload59

  columns: [id, function, args, expected, description]
  rows:
    - [dict_not_contains_file,
       __dict__.__contains__,
       ["__file__"],
       false,
       "itertools.__dict__.__contains__('__file__') == False — itertools has no __file__ attribute; C builtin modules are compiled into the CPython interpreter binary (from Modules/itertoolsmodule.c) and have no disk location, so the import system (BuiltinImporter) does not set __file__; hasattr(itertools, '__file__') is False; '__file__' is not in itertools.__dict__; this contrasts with pure-Python modules (functools, inspect, threading) where __file__ is a str path to the .py source file; checking via __dict__.__contains__ directly queries the module namespace dictionary rather than going through attribute lookup which could trigger descriptors; no prior itertools spec has a table row checking __dict__.__contains__('__file__')==false; new to extra59"]
    - [dict_not_contains_cached,
       __dict__.__contains__,
       ["__cached__"],
       false,
       "itertools.__dict__.__contains__('__cached__') == False — itertools has no __cached__ attribute; C builtin modules have no source file and therefore no bytecode cache (.pyc file); the import system (BuiltinImporter) does not set __cached__ for built-in modules; hasattr(itertools, '__cached__') is False; '__cached__' is not in itertools.__dict__; this contrasts with pure-Python modules (functools, inspect, threading) where __cached__ is a str path to the .pyc file in __pycache__/; no prior itertools spec has a table row checking __dict__.__contains__('__cached__')==false; new to extra59"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra59
# ---------------------------------------------------------------------------

invariant itertools_extra59.loader_class_is_type:
  description: "itertools.__loader__.__class__.__name__.__eq__('type') == True — itertools __loader__ IS the BuiltinImporter class (not an instance), so __class__ is 'type'; wave 225 __loader__ identity check; new to extra59"
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra59.loader_name_is_BuiltinImporter:
  description: "itertools.__loader__.__name__.__eq__('BuiltinImporter') == True — the loader class for builtin C modules is BuiltinImporter; wave 225 __loader__ check; new to extra59"
  kind: python_call_eq
  function: __loader__.__name__.__eq__
  args: ["BuiltinImporter"]
  expected: true

invariant itertools_extra59.spec_is_ModuleSpec:
  description: "itertools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — all importable modules including C builtins have a ModuleSpec __spec__ (PEP 451); wave 225 __spec__ chain; new to extra59"
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant itertools_extra59.no_file_in_dict:
  description: "itertools.__dict__.__contains__('__file__') == False — C builtin module has no __file__ attribute (no disk location); wave 225 __file__ absence check; new to extra59"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["__file__"]
  expected: false
