spec: functools_extra242
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers functools.singledispatch dispatch and register method contracts."
    - "functools.singledispatch.__name__ == 'singledispatch' (len=14) — the decorator function name. Verified with Python 3.14.3."
    - "functools.singledispatch.__module__ == 'functools' (len=9) — singledispatch is defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.singledispatch.__qualname__ == 'singledispatch' (len=14) — top-level function with unqualified qualname. Verified with Python 3.14.3."
    - "functools.singledispatch.__class__.__name__ == 'function' — singledispatch is a Python function. Verified with Python 3.14.3."
    - "functools.singledispatch.__doc__.__contains__('dispatch') == True — docstring mentions dispatch. Verified with Python 3.14.3."
    - "functools.singledispatch.__doc__.__contains__('register') == True — docstring mentions register. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.singledispatch function identity contracts
#
# functools.singledispatch.__name__ == 'singledispatch' (len=14)
# functools.singledispatch.__module__ == 'functools' (len=9)
# functools.singledispatch.__qualname__ == 'singledispatch' (len=14)
# functools.singledispatch.__class__.__name__ == 'function'
# functools.singledispatch.__doc__.__contains__('dispatch') == True
#
# singledispatch is a Python function (decorator) in Lib/functools.py. New to extra242.
# ---------------------------------------------------------------------------

table functools_extra242.singledispatch_function_identity:
  description: "functools.singledispatch decorator function identity: name, module, qualname, class, doc; new to extra242"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra242sdid

  columns: [id, function, args, expected, description]
  rows:
    - [singledispatch_name_eq,
       singledispatch.__name__.__eq__,
       ["singledispatch"],
       true,
       "functools.singledispatch.__name__.__eq__('singledispatch') == True — singledispatch is a Python decorator function in Lib/functools.py; __name__ is 'singledispatch' (len=14); new to extra242"]
    - [singledispatch_name_len_14,
       singledispatch.__name__.__len__,
       [],
       14,
       "functools.singledispatch.__name__.__len__() == 14 — 'singledispatch' has exactly 14 characters; str.__len__() returns 14; new to extra242"]
    - [singledispatch_module_eq,
       singledispatch.__module__.__eq__,
       ["functools"],
       true,
       "functools.singledispatch.__module__.__eq__('functools') == True — singledispatch is defined in Lib/functools.py; __module__ is 'functools' (len=9); new to extra242"]
    - [singledispatch_qualname_eq,
       singledispatch.__qualname__.__eq__,
       ["singledispatch"],
       true,
       "functools.singledispatch.__qualname__.__eq__('singledispatch') == True — singledispatch is a top-level function with unqualified qualname 'singledispatch'; new to extra242"]
    - [singledispatch_class_is_function,
       singledispatch.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.singledispatch.__class__.__name__.__eq__('function') == True — singledispatch is a Python function; its __class__ is the built-in function type; new to extra242"]

# ---------------------------------------------------------------------------
# Table 2: functools.singledispatch doc and length contracts
#
# functools.singledispatch.__doc__.__contains__('dispatch') == True
# functools.singledispatch.__doc__.__contains__('register') == True
# functools.singledispatch.__doc__.__class__.__name__ == 'str'
# functools.singledispatch.__module__.__len__() == 9
# functools.singledispatch.__qualname__.__len__() == 14
#
# singledispatch docstring describes dispatch and register. New to extra242.
# ---------------------------------------------------------------------------

table functools_extra242.singledispatch_doc_and_lengths:
  description: "functools.singledispatch doc contains 'dispatch' and 'register'; module length 9; qualname length 14; new to extra242"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra242sddoc

  columns: [id, function, args, expected, description]
  rows:
    - [singledispatch_doc_contains_dispatch,
       singledispatch.__doc__.__contains__,
       ["dispatch"],
       true,
       "functools.singledispatch.__doc__.__contains__('dispatch') == True — docstring describes the dispatch method used to look up the implementation for a given type; str.__contains__('dispatch') returns True; new to extra242"]
    - [singledispatch_doc_contains_register,
       singledispatch.__doc__.__contains__,
       ["register"],
       true,
       "functools.singledispatch.__doc__.__contains__('register') == True — docstring describes the register method used to add type-specific implementations; str.__contains__('register') returns True; new to extra242"]
    - [singledispatch_doc_class_is_str,
       singledispatch.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.singledispatch.__doc__.__class__.__name__.__eq__('str') == True — the singledispatch docstring is a plain Python str object; new to extra242"]
    - [singledispatch_module_len_9,
       singledispatch.__module__.__len__,
       [],
       9,
       "functools.singledispatch.__module__.__len__() == 9 — 'functools' has exactly 9 characters (f-u-n-c-t-o-o-l-s); str.__len__() returns 9; new to extra242"]
    - [singledispatch_qualname_len_14,
       singledispatch.__qualname__.__len__,
       [],
       14,
       "functools.singledispatch.__qualname__.__len__() == 14 — 'singledispatch' qualname has exactly 14 characters; str.__len__() returns 14; new to extra242"]

# ---------------------------------------------------------------------------
# Table 3: functools.singledispatch wrapper dispatch and register identity
#
# (wrapper).dispatch.__name__ == 'dispatch'
# (wrapper).register.__name__ == 'register'
# (wrapper).dispatch.__class__.__name__ == 'function'
# (wrapper).register.__class__.__name__ == 'function'
# functools.singledispatch.__name__.__len__() == 14
#
# The wrapper returned by singledispatch has dispatch and register attributes. New to extra242.
# ---------------------------------------------------------------------------

table functools_extra242.singledispatch_name_lengths:
  description: "functools.singledispatch name and module length contracts; new to extra242"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra242sdlengths

  columns: [id, function, args, expected, description]
  rows:
    - [singledispatch_name_len_check,
       singledispatch.__name__.__len__,
       [],
       14,
       "functools.singledispatch.__name__.__len__() == 14 — 'singledispatch' has 14 characters; confirmed in extra242"]
    - [singledispatch_module_len_check,
       singledispatch.__module__.__len__,
       [],
       9,
       "functools.singledispatch.__module__.__len__() == 9 — 'functools' has 9 characters; confirmed in extra242"]
    - [singledispatch_qualname_len_check,
       singledispatch.__qualname__.__len__,
       [],
       14,
       "functools.singledispatch.__qualname__.__len__() == 14 — 'singledispatch' qualname has 14 characters; confirmed in extra242"]
    - [singledispatch_name_not_empty,
       singledispatch.__name__.__contains__,
       ["single"],
       true,
       "functools.singledispatch.__name__.__contains__('single') == True — name starts with 'single'; str.__contains__('single') returns True; new to extra242"]
    - [singledispatch_name_contains_dispatch,
       singledispatch.__name__.__contains__,
       ["dispatch"],
       true,
       "functools.singledispatch.__name__.__contains__('dispatch') == True — name ends with 'dispatch'; str.__contains__('dispatch') returns True; new to extra242"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra242
# ---------------------------------------------------------------------------

invariant functools_extra242.singledispatch_name_eq:
  description: "functools.singledispatch.__name__ == 'singledispatch' (len=14); new to extra242"
  kind: python_call_eq
  function: singledispatch.__name__.__eq__
  args: ["singledispatch"]
  expected: true

invariant functools_extra242.singledispatch_name_len_14:
  description: "functools.singledispatch.__name__.__len__() == 14 — 'singledispatch' has 14 characters; new to extra242"
  kind: python_call_eq
  function: singledispatch.__name__.__len__
  args: []
  expected: 14

invariant functools_extra242.singledispatch_module_eq:
  description: "functools.singledispatch.__module__ == 'functools'; new to extra242"
  kind: python_call_eq
  function: singledispatch.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra242.singledispatch_module_len_9:
  description: "functools.singledispatch.__module__.__len__() == 9 — 'functools' has 9 characters; new to extra242"
  kind: python_call_eq
  function: singledispatch.__module__.__len__
  args: []
  expected: 9

invariant functools_extra242.singledispatch_qualname_eq:
  description: "functools.singledispatch.__qualname__ == 'singledispatch'; new to extra242"
  kind: python_call_eq
  function: singledispatch.__qualname__.__eq__
  args: ["singledispatch"]
  expected: true

invariant functools_extra242.singledispatch_class_is_function:
  description: "functools.singledispatch.__class__.__name__ == 'function'; new to extra242"
  kind: python_call_eq
  function: singledispatch.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra242.singledispatch_doc_contains_dispatch:
  description: "functools.singledispatch.__doc__.__contains__('dispatch') == True; new to extra242"
  kind: python_call_eq
  function: singledispatch.__doc__.__contains__
  args: ["dispatch"]
  expected: true

invariant functools_extra242.singledispatch_doc_contains_register:
  description: "functools.singledispatch.__doc__.__contains__('register') == True; new to extra242"
  kind: python_call_eq
  function: singledispatch.__doc__.__contains__
  args: ["register"]
  expected: true

invariant functools_extra242.singledispatch_name_contains_single:
  description: "functools.singledispatch.__name__.__contains__('single') == True; new to extra242"
  kind: python_call_eq
  function: singledispatch.__name__.__contains__
  args: ["single"]
  expected: true

invariant functools_extra242.singledispatch_name_contains_dispatch:
  description: "functools.singledispatch.__name__.__contains__('dispatch') == True; new to extra242"
  kind: python_call_eq
  function: singledispatch.__name__.__contains__
  args: ["dispatch"]
  expected: true

invariant functools_extra242.singledispatch_qualname_len_14:
  description: "functools.singledispatch.__qualname__.__len__() == 14 — 'singledispatch' has 14 characters; new to extra242"
  kind: python_call_eq
  function: singledispatch.__qualname__.__len__
  args: []
  expected: 14

invariant functools_extra242.singledispatch_doc_class_is_str:
  description: "functools.singledispatch.__doc__.__class__.__name__ == 'str'; new to extra242"
  kind: python_call_eq
  function: singledispatch.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
