spec: abc_extra1516
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Wave 548 theme: arithmetic/numeric operator protocol dict-presence checks — __add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__, __pow__ in class __dict__."
    - "The abc module defines abstract base class machinery — ABCMeta (metaclass), ABC (helper class), abstractmethod (decorator). None of these are numeric types."
    - "abc.ABCMeta does NOT define any arithmetic operator protocol methods in its own __dict__. ABCMeta is a metaclass that processes @abstractmethod decorators and manages virtual subclass registration — no arithmetic."
    - "abc.ABC does NOT define any arithmetic operator protocol methods in its own __dict__. ABC is a helper class whose only role is to set ABCMeta as the metaclass — its __dict__ contains only __abstractmethods__ (frozenset()), __slots__, __doc__, _abc_impl, and __static_attributes__."
    - "abc.ABCMeta.__dict__ does contain register(), __instancecheck__(), __subclasscheck__() — all metaclass interface methods for virtual subclass management, none arithmetic."
    - "abc.ABC.__dict__ contains __abstractmethods__ == True — this is established across many prior wave specs."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc.ABCMeta arithmetic operator __dict__ absence
#
# abc.ABCMeta.__dict__.__contains__('__add__')      == False
# abc.ABCMeta.__dict__.__contains__('__mul__')      == False
# abc.ABCMeta.__dict__.__contains__('__sub__')      == False
# abc.ABCMeta.__dict__.__contains__('__truediv__')  == False
# abc.ABCMeta.__dict__.__contains__('__floordiv__') == False
# abc.ABCMeta.__dict__.__contains__('__mod__')      == False
# abc.ABCMeta.__dict__.__contains__('register')     == True  (metaclass method)
# ---------------------------------------------------------------------------

table abc_extra1516.abcmeta_no_arithmetic_ops:
  description: "abc.ABCMeta has no arithmetic operator methods in its own __dict__ — ab1516am namespace. abc.ABCMeta.__dict__.__contains__('__add__')==False (ABCMeta is a metaclass — a subclass of type; it provides abstract base class machinery: @abstractmethod tracking, __abstractmethods__ computation, virtual subclass registration via register(); its semantic domain is class creation and interface enforcement, not arithmetic; no __add__ in ABCMeta.__dict__); abc.ABCMeta.__dict__.__contains__('__mul__')==False (no multiplication on ABCMeta — the metaclass is not a numeric type; the only 'multiplication' in Python metaclass context is class creation, which is handled by __new__ and __init__ inherited from type); abc.ABCMeta.__dict__.__contains__('__sub__')==False (no subtraction on ABCMeta); abc.ABCMeta.__dict__.__contains__('__truediv__')==False (no true division on ABCMeta); abc.ABCMeta.__dict__.__contains__('__floordiv__')==False (no floor division on ABCMeta); abc.ABCMeta.__dict__.__contains__('__mod__')==False (no modulo on ABCMeta; note: __mod__ is unrelated to the string % formatting operator which uses __mod__ on str, not on metaclasses); abc.ABCMeta.__dict__.__contains__('register')==True (ABCMeta.register() IS defined directly in ABCMeta.__dict__ — it is the method used to register virtual subclasses: 'MyABC.register(ConcreteClass)'; this is the core mechanism for structural subtyping with ABCMeta); verified with Python 3.14.4"
  kind: python_call_eq
  category: arithmetic_protocol
  id_prefix: ab1516am

  columns: [id, function, args, expected, description]
  rows:
    - [ab1516am001, abc.ABCMeta.__dict__.__contains__, ["__add__"],      false, "abc.ABCMeta.__dict__.__contains__('__add__')==False — metaclass for abstract base classes, not numeric; no __add__; verified with Python 3.14.4"]
    - [ab1516am002, abc.ABCMeta.__dict__.__contains__, ["__mul__"],      false, "abc.ABCMeta.__dict__.__contains__('__mul__')==False — no multiplication on ABCMeta; verified with Python 3.14.4"]
    - [ab1516am003, abc.ABCMeta.__dict__.__contains__, ["__sub__"],      false, "abc.ABCMeta.__dict__.__contains__('__sub__')==False — no subtraction on ABCMeta; verified with Python 3.14.4"]
    - [ab1516am004, abc.ABCMeta.__dict__.__contains__, ["__truediv__"],  false, "abc.ABCMeta.__dict__.__contains__('__truediv__')==False — no true division on ABCMeta; verified with Python 3.14.4"]
    - [ab1516am005, abc.ABCMeta.__dict__.__contains__, ["__floordiv__"], false, "abc.ABCMeta.__dict__.__contains__('__floordiv__')==False — no floor division on ABCMeta; verified with Python 3.14.4"]
    - [ab1516am006, abc.ABCMeta.__dict__.__contains__, ["__mod__"],      false, "abc.ABCMeta.__dict__.__contains__('__mod__')==False — no modulo on ABCMeta; verified with Python 3.14.4"]
    - [ab1516am007, abc.ABCMeta.__dict__.__contains__, ["register"],     true,  "abc.ABCMeta.__dict__.__contains__('register')==True — ABCMeta.register() defined directly in ABCMeta.__dict__; virtual subclass registration; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Table 2: abc.ABC arithmetic operator __dict__ absence
#
# abc.ABC.__dict__.__contains__('__add__')              == False
# abc.ABC.__dict__.__contains__('__mul__')              == False
# abc.ABC.__dict__.__contains__('__sub__')              == False
# abc.ABC.__dict__.__contains__('__truediv__')          == False
# abc.ABC.__dict__.__contains__('__floordiv__')         == False
# abc.ABC.__dict__.__contains__('__mod__')              == False
# abc.ABC.__dict__.__contains__('__abstractmethods__')  == True  (established)
# ---------------------------------------------------------------------------

table abc_extra1516.abc_ABC_no_arithmetic_ops:
  description: "abc.ABC has no arithmetic operator methods in its own __dict__ — ab1516ac namespace. abc.ABC.__dict__.__contains__('__add__')==False (ABC is a helper class defined as 'class ABC(metaclass=ABCMeta): pass'; its entire purpose is to provide ABCMeta as the metaclass without requiring the user to specify 'metaclass=ABCMeta'; ABC.__dict__ is minimal: __abstractmethods__ (frozenset()), __slots__, __doc__, _abc_impl, __static_attributes__ — no arithmetic operators whatsoever); abc.ABC.__dict__.__contains__('__mul__')==False (no multiplication on ABC — ABC is an interface definition aid, not a numeric value; you cannot multiply abstract base class helper objects); abc.ABC.__dict__.__contains__('__sub__')==False (no subtraction on ABC); abc.ABC.__dict__.__contains__('__truediv__')==False (no true division on ABC); abc.ABC.__dict__.__contains__('__floordiv__')==False (no floor division on ABC); abc.ABC.__dict__.__contains__('__mod__')==False (no modulo on ABC); abc.ABC.__dict__.__contains__('__abstractmethods__')==True (__abstractmethods__ IS defined directly in abc.ABC.__dict__ as frozenset() — the empty frozen set indicating ABC itself has no abstract methods; this is the core ABCMeta invariant that prevents instantiation of classes with unimplemented abstract methods; established across many prior specs); verified with Python 3.14.4"
  kind: python_call_eq
  category: arithmetic_protocol
  id_prefix: ab1516ac

  columns: [id, function, args, expected, description]
  rows:
    - [ab1516ac001, abc.ABC.__dict__.__contains__, ["__add__"],             false, "abc.ABC.__dict__.__contains__('__add__')==False — helper class for abstract base classes, not numeric; no __add__; verified with Python 3.14.4"]
    - [ab1516ac002, abc.ABC.__dict__.__contains__, ["__mul__"],             false, "abc.ABC.__dict__.__contains__('__mul__')==False — no multiplication on ABC; verified with Python 3.14.4"]
    - [ab1516ac003, abc.ABC.__dict__.__contains__, ["__sub__"],             false, "abc.ABC.__dict__.__contains__('__sub__')==False — no subtraction on ABC; verified with Python 3.14.4"]
    - [ab1516ac004, abc.ABC.__dict__.__contains__, ["__truediv__"],         false, "abc.ABC.__dict__.__contains__('__truediv__')==False — no true division on ABC; verified with Python 3.14.4"]
    - [ab1516ac005, abc.ABC.__dict__.__contains__, ["__floordiv__"],        false, "abc.ABC.__dict__.__contains__('__floordiv__')==False — no floor division on ABC; verified with Python 3.14.4"]
    - [ab1516ac006, abc.ABC.__dict__.__contains__, ["__mod__"],             false, "abc.ABC.__dict__.__contains__('__mod__')==False — no modulo on ABC; verified with Python 3.14.4"]
    - [ab1516ac007, abc.ABC.__dict__.__contains__, ["__abstractmethods__"], true,  "abc.ABC.__dict__.__contains__('__abstractmethods__')==True — frozenset() in ABC.__dict__; ABCMeta invariant for abstract method tracking; established across prior specs; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Table 3: abc full arithmetic sweep — both ABCMeta and ABC, all 7 operators
#
# Comprehensive sweep confirming all 7 arithmetic operators absent from both
# abc.ABCMeta.__dict__ and abc.ABC.__dict__
# abc.ABCMeta.__dict__.__contains__('__instancecheck__') == True  (metaclass method)
# ---------------------------------------------------------------------------

table abc_extra1516.abc_full_arith_sweep:
  description: "abc module full arithmetic operator sweep — all 7 operators absent from both ABCMeta.__dict__ and ABC.__dict__ — ab1516fs namespace. Comprehensive confirmation that neither abc.ABCMeta nor abc.ABC define any of the standard Python arithmetic operator protocol methods (__add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__, __pow__) in their own __dict__. abc is an interface-definition module — ABCMeta controls class creation and enforces abstract method contracts; ABC provides a convenient base class; neither has any numeric semantics. abc.ABCMeta.__dict__.__contains__('__add__')==False (complete absence of addition); abc.ABC.__dict__.__contains__('__mul__')==False (complete absence of multiplication); abc.ABCMeta.__dict__.__contains__('__pow__')==False (complete absence of exponentiation); abc.ABC.__dict__.__contains__('__pow__')==False (same for ABC); abc.ABCMeta.__dict__.__contains__('__sub__')==False; abc.ABC.__dict__.__contains__('__floordiv__')==False; abc.ABCMeta.__dict__.__contains__('__instancecheck__')==True (ABCMeta.__instancecheck__() IS defined directly in ABCMeta.__dict__ — it overrides isinstance() checks so that 'isinstance(obj, MyABC)' works for virtual subclasses registered via register()); verified with Python 3.14.4"
  kind: python_call_eq
  category: arithmetic_protocol
  id_prefix: ab1516fs

  columns: [id, function, args, expected, description]
  rows:
    - [ab1516fs001, abc.ABCMeta.__dict__.__contains__, ["__add__"],           false, "abc.ABCMeta.__dict__.__contains__('__add__')==False — metaclass, not numeric; full sweep row 1; verified with Python 3.14.4"]
    - [ab1516fs002, abc.ABC.__dict__.__contains__,     ["__mul__"],           false, "abc.ABC.__dict__.__contains__('__mul__')==False — ABC helper class, not numeric; full sweep row 2; verified with Python 3.14.4"]
    - [ab1516fs003, abc.ABCMeta.__dict__.__contains__, ["__pow__"],           false, "abc.ABCMeta.__dict__.__contains__('__pow__')==False — no exponentiation on ABCMeta; full sweep row 3; verified with Python 3.14.4"]
    - [ab1516fs004, abc.ABC.__dict__.__contains__,     ["__pow__"],           false, "abc.ABC.__dict__.__contains__('__pow__')==False — no exponentiation on ABC; full sweep row 4; verified with Python 3.14.4"]
    - [ab1516fs005, abc.ABCMeta.__dict__.__contains__, ["__sub__"],           false, "abc.ABCMeta.__dict__.__contains__('__sub__')==False — no subtraction on ABCMeta; full sweep row 5; verified with Python 3.14.4"]
    - [ab1516fs006, abc.ABC.__dict__.__contains__,     ["__floordiv__"],      false, "abc.ABC.__dict__.__contains__('__floordiv__')==False — no floor division on ABC; full sweep row 6; verified with Python 3.14.4"]
    - [ab1516fs007, abc.ABCMeta.__dict__.__contains__, ["__instancecheck__"], true,  "abc.ABCMeta.__dict__.__contains__('__instancecheck__')==True — ABCMeta.__instancecheck__() defined in ABCMeta.__dict__; overrides isinstance() for virtual subclasses; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1516
# ---------------------------------------------------------------------------

invariant abc_extra1516.abcmeta_no_add:
  description: "abc.ABCMeta.__dict__.__contains__('__add__') returns False — abc.ABCMeta does not define __add__ in its own __dict__; ABCMeta is a metaclass (subclass of type) that provides the abstract base class machinery; ABCMeta.__dict__ contains register(), __instancecheck__(), __subclasscheck__(), _dump_registry(), _abc_registry_clear(), _abc_caches_clear() — all metaclass interface methods for abstract class management; no arithmetic operators of any kind are defined; ABCMeta's role is to enforce interface contracts at class instantiation time, which is entirely orthogonal to numeric arithmetic; wave 548 theme: arithmetic operator __dict__ presence checks; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: arithmetic_protocol
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__contains__
  args: ["__add__"]
  expected: false

invariant abc_extra1516.abcmeta_no_pow:
  description: "abc.ABCMeta.__dict__.__contains__('__pow__') returns False — abc.ABCMeta does not define __pow__ in its own __dict__; exponentiation on a metaclass object is undefined and unsupported; ABCMeta is a metaclass whose instances are abstract base classes — it controls how abstract classes are created (via __new__) and enforces that all @abstractmethod-decorated methods are implemented before a class can be instantiated; no arithmetic operator protocol method (__add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__, __pow__) exists in ABCMeta.__dict__; wave 548 theme; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: arithmetic_protocol
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__contains__
  args: ["__pow__"]
  expected: false

invariant abc_extra1516.abc_ABC_no_add:
  description: "abc.ABC.__dict__.__contains__('__add__') returns False — abc.ABC does not define __add__ in its own __dict__; ABC is a helper class defined as 'class ABC(metaclass=ABCMeta): pass'; its __dict__ is intentionally minimal, containing only: __abstractmethods__ (frozenset()), __slots__, __doc__, _abc_impl (the C-level ABC implementation object), and __static_attributes__; no arithmetic operators are present; ABC's sole purpose is to make it convenient to create abstract base classes without spelling out 'metaclass=ABCMeta'; wave 548 theme: arithmetic operator __dict__ presence; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: arithmetic_protocol
  kind: python_call_eq
  function: abc.ABC.__dict__.__contains__
  args: ["__add__"]
  expected: false

invariant abc_extra1516.abc_ABC_no_mul:
  description: "abc.ABC.__dict__.__contains__('__mul__') returns False — abc.ABC does not define __mul__ in its own __dict__; multiplying abstract base class helper objects is semantically meaningless; ABC.__dict__ contains only class-metadata entries needed for the ABCMeta abstract method enforcement mechanism; the wave 548 theme focuses on verifying that none of the 7 arithmetic operator protocol methods (__add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__, __pow__) appear in the __dict__ of abc module classes — and abc.ABC is the clearest case since its __dict__ is the most minimal of all abc module classes; wave 548 theme; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: arithmetic_protocol
  kind: python_call_eq
  function: abc.ABC.__dict__.__contains__
  args: ["__mul__"]
  expected: false
