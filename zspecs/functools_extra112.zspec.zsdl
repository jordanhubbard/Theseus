error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.cache and functools.lru_cache function identity
#
# Wave 260 theme: functools.cache and functools.lru_cache are pure-Python
# decorator functions defined in Lib/functools.py. Both have
# __class__.__name__ == 'function' and __module__ == 'functools'.
# cache wraps lru_cache(maxsize=None) and takes 1 argument (the function).
# lru_cache takes 2 arguments (maxsize and typed). Both __name__ and
# __qualname__ equal their simple lowercase name.
#
# functools.cache.__class__.__name__ == 'function'
# functools.cache.__module__ == 'functools'
# functools.cache.__name__ == 'cache'
# functools.cache.__qualname__ == 'cache'
# functools.cache.__code__.co_name == 'cache'
# functools.cache.__code__.co_argcount == 1
# functools.lru_cache.__class__.__name__ == 'function'
# functools.lru_cache.__module__ == 'functools'
# functools.lru_cache.__name__ == 'lru_cache'
# functools.lru_cache.__code__.co_name == 'lru_cache'
# functools.lru_cache.__code__.co_argcount == 2
#
# New to extra112.
# ---------------------------------------------------------------------------

table functools_extra112.cache_lru_cache_identity:
  description: "functools.cache and functools.lru_cache function identity: __class__.__name__ == 'function', __module__ == 'functools', __name__ and __qualname__ equal lowercase name, co_name and co_argcount; wave 260; new to extra112"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolscache112

  columns: [id, function, args, expected, description]
  rows:
    - [cache_class_name_function,
       "cache.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.cache.__class__.__name__.__eq__('function') == True — functools.cache is a pure-Python decorator function defined in Lib/functools.py; it wraps lru_cache(maxsize=None); accessed as a module attribute it is a plain Python function object; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra112"]
    - [cache_module_eq,
       "cache.__module__.__eq__",
       ["functools"],
       true,
       "functools.cache.__module__.__eq__('functools') == True — functools.cache is defined in Lib/functools.py; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra112"]
    - [cache_name_eq,
       "cache.__name__.__eq__",
       ["cache"],
       true,
       "functools.cache.__name__.__eq__('cache') == True — functools.cache is a top-level function; its __name__ is 'cache'; __name__ equals __qualname__ for top-level functions; str.__eq__('cache') returns True; new to extra112"]
    - [cache_qualname_eq,
       "cache.__qualname__.__eq__",
       ["cache"],
       true,
       "functools.cache.__qualname__.__eq__('cache') == True — functools.cache is a top-level function so __qualname__ equals __name__ equals 'cache'; str.__eq__('cache') returns True; new to extra112"]
    - [cache_code_co_name_eq,
       "cache.__code__.co_name.__eq__",
       ["cache"],
       true,
       "functools.cache.__code__.co_name.__eq__('cache') == True — the code object's co_name is the function name at definition; for functools.cache it is 'cache'; str.__eq__('cache') returns True; new to extra112"]
    - [cache_code_co_argcount_1,
       "cache.__code__.co_argcount.__eq__",
       [1],
       true,
       "functools.cache.__code__.co_argcount.__eq__(1) == True — functools.cache takes 1 positional argument (the user function to wrap); co_argcount counts positional arguments only; int.__eq__(1) returns True; new to extra112"]
    - [lru_cache_class_name_function,
       "lru_cache.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.lru_cache.__class__.__name__.__eq__('function') == True — functools.lru_cache is a pure-Python decorator factory defined in Lib/functools.py; accessed as a module attribute it is a plain Python function object; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra112"]
    - [lru_cache_module_eq,
       "lru_cache.__module__.__eq__",
       ["functools"],
       true,
       "functools.lru_cache.__module__.__eq__('functools') == True — functools.lru_cache is defined in Lib/functools.py; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra112"]
    - [lru_cache_name_eq,
       "lru_cache.__name__.__eq__",
       ["lru_cache"],
       true,
       "functools.lru_cache.__name__.__eq__('lru_cache') == True — functools.lru_cache is a top-level function; its __name__ is 'lru_cache'; str.__eq__('lru_cache') returns True; new to extra112"]
    - [lru_cache_code_co_name_eq,
       "lru_cache.__code__.co_name.__eq__",
       ["lru_cache"],
       true,
       "functools.lru_cache.__code__.co_name.__eq__('lru_cache') == True — the code object co_name for functools.lru_cache is 'lru_cache'; str.__eq__('lru_cache') returns True; new to extra112"]
    - [lru_cache_code_co_argcount_2,
       "lru_cache.__code__.co_argcount.__eq__",
       [2],
       true,
       "functools.lru_cache.__code__.co_argcount.__eq__(2) == True — functools.lru_cache takes 2 positional arguments (maxsize and typed); co_argcount counts positional arguments only; int.__eq__(2) returns True; new to extra112"]

# ---------------------------------------------------------------------------
# Table 2: functools.total_ordering and functools.singledispatch code identity
#
# Wave 260 theme: functools.total_ordering and functools.singledispatch are
# pure-Python class decorators / dispatch registrars defined in
# Lib/functools.py. Both have __class__.__name__ == 'function',
# __module__ == 'functools', and co_argcount == 1 (each takes a single
# class or function argument). Their co_name equals __name__.
#
# functools.total_ordering.__class__.__name__ == 'function'
# functools.total_ordering.__module__ == 'functools'
# functools.total_ordering.__name__ == 'total_ordering'
# functools.total_ordering.__code__.co_name == 'total_ordering'
# functools.total_ordering.__code__.co_argcount == 1
# functools.singledispatch.__class__.__name__ == 'function'
# functools.singledispatch.__module__ == 'functools'
# functools.singledispatch.__name__ == 'singledispatch'
# functools.singledispatch.__code__.co_name == 'singledispatch'
# functools.singledispatch.__code__.co_argcount == 1
#
# New to extra112.
# ---------------------------------------------------------------------------

table functools_extra112.total_ordering_singledispatch_identity:
  description: "functools.total_ordering and functools.singledispatch function identity: __class__.__name__ == 'function', __module__ == 'functools', __name__ and co_name equal lowercase name, co_argcount == 1; wave 260; new to extra112"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsordering112

  columns: [id, function, args, expected, description]
  rows:
    - [total_ordering_class_name_function,
       "total_ordering.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.total_ordering.__class__.__name__.__eq__('function') == True — functools.total_ordering is a pure-Python class decorator defined in Lib/functools.py; it fills in missing comparison methods given __eq__ and one of __lt__/__le__/__gt__/__ge__; accessed as a module attribute it is a plain Python function object; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra112"]
    - [total_ordering_module_eq,
       "total_ordering.__module__.__eq__",
       ["functools"],
       true,
       "functools.total_ordering.__module__.__eq__('functools') == True — functools.total_ordering is defined in Lib/functools.py; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra112"]
    - [total_ordering_name_eq,
       "total_ordering.__name__.__eq__",
       ["total_ordering"],
       true,
       "functools.total_ordering.__name__.__eq__('total_ordering') == True — functools.total_ordering is a top-level function; its __name__ is 'total_ordering'; str.__eq__('total_ordering') returns True; new to extra112"]
    - [total_ordering_code_co_name_eq,
       "total_ordering.__code__.co_name.__eq__",
       ["total_ordering"],
       true,
       "functools.total_ordering.__code__.co_name.__eq__('total_ordering') == True — the code object co_name for functools.total_ordering is 'total_ordering'; str.__eq__('total_ordering') returns True; new to extra112"]
    - [total_ordering_code_co_argcount_1,
       "total_ordering.__code__.co_argcount.__eq__",
       [1],
       true,
       "functools.total_ordering.__code__.co_argcount.__eq__(1) == True — functools.total_ordering takes 1 positional argument (the class to decorate); co_argcount counts positional arguments only; int.__eq__(1) returns True; new to extra112"]
    - [singledispatch_class_name_function,
       "singledispatch.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.singledispatch.__class__.__name__.__eq__('function') == True — functools.singledispatch is a pure-Python single-dispatch generic function decorator defined in Lib/functools.py; accessed as a module attribute it is a plain Python function object; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra112"]
    - [singledispatch_module_eq,
       "singledispatch.__module__.__eq__",
       ["functools"],
       true,
       "functools.singledispatch.__module__.__eq__('functools') == True — functools.singledispatch is defined in Lib/functools.py; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra112"]
    - [singledispatch_name_eq,
       "singledispatch.__name__.__eq__",
       ["singledispatch"],
       true,
       "functools.singledispatch.__name__.__eq__('singledispatch') == True — functools.singledispatch is a top-level function; its __name__ is 'singledispatch'; str.__eq__('singledispatch') returns True; new to extra112"]
    - [singledispatch_code_co_name_eq,
       "singledispatch.__code__.co_name.__eq__",
       ["singledispatch"],
       true,
       "functools.singledispatch.__code__.co_name.__eq__('singledispatch') == True — the code object co_name for functools.singledispatch is 'singledispatch'; str.__eq__('singledispatch') returns True; new to extra112"]
    - [singledispatch_code_co_argcount_1,
       "singledispatch.__code__.co_argcount.__eq__",
       [1],
       true,
       "functools.singledispatch.__code__.co_argcount.__eq__(1) == True — functools.singledispatch takes 1 positional argument (the function to transform into a single-dispatch generic function); co_argcount counts positional arguments only; int.__eq__(1) returns True; new to extra112"]

# ---------------------------------------------------------------------------
# Table 3: functools.singledispatchmethod and functools.cached_property class
# identity
#
# Wave 260 theme: functools.singledispatchmethod and functools.cached_property
# are pure-Python classes (not functions) defined in Lib/functools.py.
# Their __class__.__name__ is 'type' (they are type objects, not function
# objects). Both inherit directly from object with MRO depth 2.
# Their __module__ is 'functools'.
#
# functools.singledispatchmethod.__class__.__name__ == 'type'
# functools.singledispatchmethod.__module__ == 'functools'
# functools.singledispatchmethod.__name__ == 'singledispatchmethod'
# functools.singledispatchmethod.__qualname__ == 'singledispatchmethod'
# functools.singledispatchmethod.__bases__[0].__name__ == 'object'
# functools.singledispatchmethod.__mro__.__len__() == 2
# functools.cached_property.__class__.__name__ == 'type'
# functools.cached_property.__module__ == 'functools'
# functools.cached_property.__name__ == 'cached_property'
# functools.cached_property.__qualname__ == 'cached_property'
# functools.cached_property.__bases__[0].__name__ == 'object'
# functools.cached_property.__mro__.__len__() == 2
#
# New to extra112.
# ---------------------------------------------------------------------------

table functools_extra112.singledispatchmethod_cached_property_identity:
  description: "functools.singledispatchmethod and functools.cached_property class identity: __class__.__name__ == 'type', __module__ == 'functools', __name__ and __qualname__ equal class name, MRO depth 2; wave 260; new to extra112"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolssdm112

  columns: [id, function, args, expected, description]
  rows:
    - [singledispatchmethod_class_name_type,
       "singledispatchmethod.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.singledispatchmethod.__class__.__name__.__eq__('type') == True — functools.singledispatchmethod is a pure-Python class (not a function) defined in Lib/functools.py; as a class its __class__ is 'type' (the metaclass); __class__.__name__ is 'type'; contrasts with singledispatch which is a function; str.__eq__('type') returns True; new to extra112"]
    - [singledispatchmethod_module_eq,
       "singledispatchmethod.__module__.__eq__",
       ["functools"],
       true,
       "functools.singledispatchmethod.__module__.__eq__('functools') == True — functools.singledispatchmethod is defined in Lib/functools.py; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra112"]
    - [singledispatchmethod_name_eq,
       "singledispatchmethod.__name__.__eq__",
       ["singledispatchmethod"],
       true,
       "functools.singledispatchmethod.__name__.__eq__('singledispatchmethod') == True — functools.singledispatchmethod is a top-level class; its __name__ is 'singledispatchmethod'; str.__eq__('singledispatchmethod') returns True; new to extra112"]
    - [singledispatchmethod_qualname_eq,
       "singledispatchmethod.__qualname__.__eq__",
       ["singledispatchmethod"],
       true,
       "functools.singledispatchmethod.__qualname__.__eq__('singledispatchmethod') == True — functools.singledispatchmethod is a top-level class so __qualname__ equals __name__ equals 'singledispatchmethod'; str.__eq__('singledispatchmethod') returns True; new to extra112"]
    - ["singledispatchmethod_bases_0_object",
       "singledispatchmethod.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.singledispatchmethod.__bases__[0].__name__.__eq__('object') == True — functools.singledispatchmethod inherits directly from object; __bases__[0] is object; object.__name__ is 'object'; str.__eq__('object') returns True; new to extra112"]
    - [singledispatchmethod_mro_len_2,
       "singledispatchmethod.__mro__.__len__",
       [],
       2,
       "functools.singledispatchmethod.__mro__.__len__() == 2 — functools.singledispatchmethod inherits directly from object; its MRO is [singledispatchmethod, object] with length 2; new to extra112"]
    - [cached_property_class_name_type,
       "cached_property.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.cached_property.__class__.__name__.__eq__('type') == True — functools.cached_property is a pure-Python descriptor class defined in Lib/functools.py; as a class its __class__ is 'type' (the metaclass); __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra112"]
    - [cached_property_module_eq,
       "cached_property.__module__.__eq__",
       ["functools"],
       true,
       "functools.cached_property.__module__.__eq__('functools') == True — functools.cached_property is defined in Lib/functools.py; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra112"]
    - [cached_property_name_eq,
       "cached_property.__name__.__eq__",
       ["cached_property"],
       true,
       "functools.cached_property.__name__.__eq__('cached_property') == True — functools.cached_property is a top-level class; its __name__ is 'cached_property'; str.__eq__('cached_property') returns True; new to extra112"]
    - [cached_property_qualname_eq,
       "cached_property.__qualname__.__eq__",
       ["cached_property"],
       true,
       "functools.cached_property.__qualname__.__eq__('cached_property') == True — functools.cached_property is a top-level class so __qualname__ equals __name__ equals 'cached_property'; str.__eq__('cached_property') returns True; new to extra112"]
    - ["cached_property_bases_0_object",
       "cached_property.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.cached_property.__bases__[0].__name__.__eq__('object') == True — functools.cached_property inherits directly from object; __bases__[0] is object; object.__name__ is 'object'; str.__eq__('object') returns True; new to extra112"]
    - [cached_property_mro_len_2,
       "cached_property.__mro__.__len__",
       [],
       2,
       "functools.cached_property.__mro__.__len__() == 2 — functools.cached_property inherits directly from object; its MRO is [cached_property, object] with length 2; new to extra112"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra112
# ---------------------------------------------------------------------------

invariant functools_extra112.cache_code_co_argcount:
  description: "functools.cache.__code__.co_argcount == 1 — cache is a decorator taking 1 argument (the user function); wave 260; new to extra112"
  kind: python_call_eq
  function: cache.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant functools_extra112.lru_cache_code_co_argcount:
  description: "functools.lru_cache.__code__.co_argcount == 2 — lru_cache takes maxsize and typed as positional args; wave 260; new to extra112"
  kind: python_call_eq
  function: lru_cache.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant functools_extra112.singledispatch_class_function:
  description: "functools.singledispatch.__class__.__name__ == 'function' — singledispatch is a function, not a class; contrasts with singledispatchmethod which is a class; wave 260; new to extra112"
  kind: python_call_eq
  function: singledispatch.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra112.singledispatchmethod_class_type:
  description: "functools.singledispatchmethod.__class__.__name__ == 'type' — singledispatchmethod is a class (type), not a function; contrasts with singledispatch; wave 260; new to extra112"
  kind: python_call_eq
  function: singledispatchmethod.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra112.cached_property_mro_len:
  description: "functools.cached_property.__mro__.__len__() == 2 — pure-Python class inheriting directly from object; MRO is [cached_property, object]; wave 260; new to extra112"
  kind: python_call_eq
  function: cached_property.__mro__.__len__
  args: []
  expected: 2
