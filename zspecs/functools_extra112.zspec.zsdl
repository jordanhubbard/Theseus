spec: functools_extra112
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra111.zspec.zsdl."
    - "This spec covers: functools.cache, functools.lru_cache, functools.total_ordering, functools.singledispatch class/function identity (__name__, __module__, __class__.__name__, __qualname__); functools.singledispatchmethod and functools.cached_property class identity (__bases__[0].__name__, __mro__.__len__); functools.total_ordering and functools.singledispatch code attributes (co_name, co_argcount); wave 260."
    - "functools.cache.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "functools.cache.__module__ == 'functools'. Verified with Python 3.14.3."
    - "functools.cache.__name__ == 'cache'. Verified with Python 3.14.3."
    - "functools.cache.__qualname__ == 'cache'. Verified with Python 3.14.3."
    - "functools.cache.__code__.co_name == 'cache'. Verified with Python 3.14.3."
    - "functools.cache.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "functools.lru_cache.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "functools.lru_cache.__module__ == 'functools'. Verified with Python 3.14.3."
    - "functools.lru_cache.__name__ == 'lru_cache'. Verified with Python 3.14.3."
    - "functools.lru_cache.__qualname__ == 'lru_cache'. Verified with Python 3.14.3."
    - "functools.lru_cache.__code__.co_name == 'lru_cache'. Verified with Python 3.14.3."
    - "functools.lru_cache.__code__.co_argcount == 2. Verified with Python 3.14.3."
    - "functools.total_ordering.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "functools.total_ordering.__module__ == 'functools'. Verified with Python 3.14.3."
    - "functools.total_ordering.__name__ == 'total_ordering'. Verified with Python 3.14.3."
    - "functools.total_ordering.__code__.co_name == 'total_ordering'. Verified with Python 3.14.3."
    - "functools.total_ordering.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "functools.singledispatch.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "functools.singledispatch.__module__ == 'functools'. Verified with Python 3.14.3."
    - "functools.singledispatch.__name__ == 'singledispatch'. Verified with Python 3.14.3."
    - "functools.singledispatch.__code__.co_name == 'singledispatch'. Verified with Python 3.14.3."
    - "functools.singledispatch.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__module__ == 'functools'. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__name__ == 'singledispatchmethod'. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
