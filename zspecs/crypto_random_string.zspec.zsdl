spec: crypto_random_string
version: ">=5.0.0"
backend: node(crypto-random-string)

docs: https://github.com/sindresorhus/crypto-random-string#readme

provenance:
  derived_from:
    - "crypto-random-string README — https://github.com/sindresorhus/crypto-random-string#readme"
    - "Test vectors verified with crypto-random-string via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "crypto-random-string source"
  notes:
    - "Generates cryptographically secure random strings — wraps Node's crypto.randomBytes."
    - "Install: npm install crypto-random-string"
    - "v5 ESM only; default export takes {length, type, characters} options."
    - "Types: hex (default), base64, url-safe, numeric, distinguishable, ascii-printable, alphanumeric."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws TypeError on missing/invalid length."
  stderr: "null"
  stickiness: "N/A — each call independent and random."
  codes: {}

invariant crypto_random_string.default_length:
  description: "default {length: 10} returns a 10-char string"
  category: length
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [{length: 10}]
  chain:
    - {get: length}
  expected: 10

invariant crypto_random_string.length_64:
  description: "{length: 64} returns 64 chars"
  category: length
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [{length: 64}]
  chain:
    - {get: length}
  expected: 64

invariant crypto_random_string.url_safe_length:
  description: "{type: 'url-safe', length: 10} produces 10 chars"
  category: type
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [{length: 10, type: "url-safe"}]
  chain:
    - {get: length}
  expected: 10

invariant crypto_random_string.numeric_length:
  description: "{type: 'numeric', length: 10} produces 10 chars"
  category: type
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [{length: 10, type: "numeric"}]
  chain:
    - {get: length}
  expected: 10

invariant crypto_random_string.distinguishable_length:
  description: "{type: 'distinguishable', length: 10} produces 10 chars"
  category: type
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [{length: 10, type: "distinguishable"}]
  chain:
    - {get: length}
  expected: 10

invariant crypto_random_string.is_string:
  description: "Default output is a String (constructor.name)"
  category: type
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [{length: 8}]
  chain:
    - {get: "constructor.name"}
  expected: "String"

invariant crypto_random_string.zero_length_returns_empty:
  description: "{length: 0} returns an empty string"
  category: edge
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [{length: 0}]
  chain:
    - {get: length}
  expected: 0
