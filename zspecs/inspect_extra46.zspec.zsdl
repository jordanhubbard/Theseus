spec: inspect_extra46
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra45.zspec.zsdl."
    - "Prior specs covered: ismodule/isclass/isfunction/ismethod/isbuiltin/isroutine/iscode/isframe/istraceback __name__/__qualname__.__len__(); iscoroutinefunction/isgeneratorfunction/isasyncgenfunction __name__/__qualname__.__len__(); getmembers/getfile/getsource/getmodule/signature/stack/currentframe/getfullargspec __qualname__.__len__(); Parameter/__mro__.__len__()==2; Signature/__mro__.__len__()==2; BoundArguments/__mro__.__len__()==2; FullArgSpec/__mro__.__len__()==3; FrameInfo/__mro__.__len__()==4; Parameter.empty/kind constants; inspect.__all__.__len__()==107; CO_OPTIMIZED==1; cleandoc/formatannotation/getattr_static/classify_class_attrs __name__ lengths; Signature/Parameter/BoundArguments method qualnames; getmembers/__module__.__len__(7); parameter kind integer values; Parameter/__name__/__module__/__qualname__; Signature/__name__/__module__/__qualname__; BoundArguments/__name__/__qualname__/__module__; FullArgSpec/__name__/__qualname__/__module__; FrameInfo/__name__/__qualname__; class __bases__[0].__name__ for Parameter/Signature/BoundArguments; FullArgSpec/__bases__[0].__name__=='tuple'; FrameInfo/__bases__[0].__name__=='_FrameInfo'; Parameter/__qualname__.__len__()==9; Signature/__qualname__.__len__()==9; BoundArguments/__qualname__.__len__()==14; FullArgSpec/__qualname__.__len__()==11; FrameInfo/__qualname__.__len__()==9; Parameter/__bases__[0].__qualname__=='object'; Signature/__bases__[0].__qualname__=='object'; BoundArguments/__bases__[0].__qualname__=='object'; FullArgSpec/__bases__[0].__qualname__=='tuple'; FrameInfo/__bases__[0].__qualname__=='_FrameInfo'."
    - "This spec covers: inspect.getouterframes.__name__ == 'getouterframes'; inspect.getouterframes.__module__ == 'inspect'; inspect.getinnerframes.__name__ == 'getinnerframes'; inspect.getinnerframes.__module__ == 'inspect'; inspect.formatargvalues.__name__ == 'formatargvalues'; inspect.formatargvalues.__module__ == 'inspect'; inspect.walktree.__name__ == 'walktree'; inspect.walktree.__module__ == 'inspect'; inspect.classify_class_attrs.__name__ == 'classify_class_attrs'; inspect.classify_class_attrs.__module__ == 'inspect'; inspect.getattr_static.__name__ == 'getattr_static'; inspect.getattr_static.__module__ == 'inspect'."
    - "Key findings: getouterframes and getinnerframes are pure-Python functions in Lib/inspect.py for walking call stacks; both have __name__ == __qualname__ (14 chars each) and __module__ == 'inspect'. formatargvalues is a legacy function for formatting argument value lists; __name__ == 'formatargvalues' (15 chars), __qualname__ == __name__, __module__ == 'inspect'. walktree is an older helper for walking class inheritance trees; __name__ == 'walktree' (8 chars), __qualname__ == __name__, __module__ == 'inspect'. classify_class_attrs is a pure-Python function that categorizes the attributes of a class into a list of Attribute named tuples; __name__ == 'classify_class_attrs' (20 chars) — the longest name in this set. getattr_static is a function that retrieves an attribute without triggering descriptor protocol (added in Python 3.2); __name__ == 'getattr_static' (14 chars), __module__ == 'inspect'. All six functions are pure-Python (def-statements in Lib/inspect.py). No prior spec recorded __name__ or __module__ string equality for any of these six functions; prior specs only recorded __name__.__len__() via length survey tables (e.g. 'cleandoc/formatannotation/getattr_static/classify_class_attrs __name__ lengths' per extra45 notes). The string equality invariants for __name__ and __module__ are all new to extra46."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.getouterframes and getinnerframes identity — extra46 namespace
#
# inspect.getouterframes.__name__ is 'getouterframes' (14 chars) and
# inspect.getinnerframes.__name__ is 'getinnerframes' (14 chars). Both are
# pure-Python functions defined at module level in Lib/inspect.py that walk
# the call stack outward and inward respectively. As top-level functions
# __qualname__ == __name__, and __module__ == 'inspect'. Prior specs recorded
# __name__.__len__() via length survey tables but not the string equality
# invariants for __name__ or __module__ for either function. Both name and
# module equality invariants are new to extra46 for both functions.
# ---------------------------------------------------------------------------

table inspect_extra46.getouterframes_getinnerframes_identity:
  description: "inspect.getouterframes and getinnerframes __name__ and __module__ string equality — pure-Python stack-walking functions; __name__ == __qualname__; __module__ == 'inspect'"
  kind: python_call_eq
  category: identity
  id_prefix: gogiid46

  columns: [id, function, args, expected, description]
  rows:
    - [getouterframes_name,
       getouterframes.__name__.__eq__,
       ["getouterframes"],
       true,
       "inspect.getouterframes.__name__ == 'getouterframes' — pure-Python function in Lib/inspect.py; returns a list of FrameInfo records for the caller's stack up to the outermost frame; 14-char name; __qualname__ == __name__"]
    - [getouterframes_module,
       getouterframes.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getouterframes.__module__ == 'inspect' — pure-Python function defined in Lib/inspect.py; module name is 'inspect' (7 chars); same module as all inspect functions"]
    - [getinnerframes_name,
       getinnerframes.__name__.__eq__,
       ["getinnerframes"],
       true,
       "inspect.getinnerframes.__name__ == 'getinnerframes' — pure-Python function in Lib/inspect.py; returns a list of FrameInfo records starting from a given traceback or frame; 14-char name; same length as getouterframes.__name__"]
    - [getinnerframes_module,
       getinnerframes.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getinnerframes.__module__ == 'inspect' — pure-Python function defined in Lib/inspect.py; module name is 'inspect' (7 chars); same module as getouterframes"]

# ---------------------------------------------------------------------------
# inspect.formatargvalues identity — extra46 namespace
#
# inspect.formatargvalues.__name__ is 'formatargvalues' (15 chars) and
# __module__ is 'inspect'. formatargvalues is a legacy pure-Python function in
# Lib/inspect.py that formats a function's argument names and values as a
# human-readable string; it is complementary to formatargspec (both were part
# of the pre-signature API). As a top-level function __qualname__ == __name__.
# Prior specs recorded __name__.__len__() in a length survey but not the string
# equality invariants. Both are new to extra46.
# ---------------------------------------------------------------------------

table inspect_extra46.formatargvalues_identity:
  description: "inspect.formatargvalues __name__ and __module__ string equality — pure-Python legacy function; 15-char name; __qualname__ == __name__; __module__ == 'inspect'"
  kind: python_call_eq
  category: identity
  id_prefix: favid46

  columns: [id, function, args, expected, description]
  rows:
    - [formatargvalues_name,
       formatargvalues.__name__.__eq__,
       ["formatargvalues"],
       true,
       "inspect.formatargvalues.__name__ == 'formatargvalues' — pure-Python function in Lib/inspect.py; formats argument names and values as a human-readable string; legacy pre-signature API; 15 chars; longest name in this spec"]
    - [formatargvalues_module,
       formatargvalues.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.formatargvalues.__module__ == 'inspect' — pure-Python function defined in Lib/inspect.py; module name is 'inspect' (7 chars); same module as all inspect functions"]

# ---------------------------------------------------------------------------
# inspect.walktree identity — extra46 namespace
#
# inspect.walktree.__name__ is 'walktree' (8 chars) and __module__ is 'inspect'.
# walktree is a pure-Python function in Lib/inspect.py that recursively walks
# a class's __bases__ to produce a tree of ancestor classes. As a top-level
# function __qualname__ == __name__. No prior spec recorded walktree.__name__
# string equality or __module__. Both are new to extra46.
# ---------------------------------------------------------------------------

table inspect_extra46.walktree_identity:
  description: "inspect.walktree __name__ and __module__ string equality — pure-Python class-tree walking function; 8-char name; __qualname__ == __name__; __module__ == 'inspect'"
  kind: python_call_eq
  category: identity
  id_prefix: wtid46

  columns: [id, function, args, expected, description]
  rows:
    - [walktree_name,
       walktree.__name__.__eq__,
       ["walktree"],
       true,
       "inspect.walktree.__name__ == 'walktree' — pure-Python function in Lib/inspect.py; recursively walks a class's __bases__ to build a class hierarchy tree; 8-char name; __qualname__ == __name__"]
    - [walktree_module,
       walktree.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.walktree.__module__ == 'inspect' — pure-Python function defined in Lib/inspect.py; module name is 'inspect' (7 chars); same module as all inspect functions"]

# ---------------------------------------------------------------------------
# inspect.classify_class_attrs and getattr_static identity — extra46 namespace
#
# inspect.classify_class_attrs.__name__ is 'classify_class_attrs' (20 chars)
# and inspect.getattr_static.__name__ is 'getattr_static' (14 chars). Both are
# pure-Python functions in Lib/inspect.py. classify_class_attrs categorizes
# class attributes into a list of Attribute named tuples (name, kind, defining
# class, object). getattr_static retrieves an attribute without triggering the
# descriptor protocol (added in Python 3.2 for static introspection). Both have
# __module__ == 'inspect'. Prior specs recorded __name__.__len__() for both in
# length survey tables (noted as 'cleandoc/formatannotation/getattr_static/
# classify_class_attrs __name__ lengths'), but not the string equality invariants
# for __name__ or __module__ for either. All four invariants are new to extra46.
# ---------------------------------------------------------------------------

table inspect_extra46.classify_class_attrs_getattr_static_identity:
  description: "inspect.classify_class_attrs and getattr_static __name__ and __module__ string equality — pure-Python introspection functions; __qualname__ == __name__ in each case; __module__ == 'inspect'"
  kind: python_call_eq
  category: identity
  id_prefix: ccagaid46

  columns: [id, function, args, expected, description]
  rows:
    - [classify_class_attrs_name,
       classify_class_attrs.__name__.__eq__,
       ["classify_class_attrs"],
       true,
       "inspect.classify_class_attrs.__name__ == 'classify_class_attrs' — pure-Python function in Lib/inspect.py; categorizes class attributes into Attribute named tuples by kind (method, class method, static method, data, or other); 20-char name; longest in this spec"]
    - [classify_class_attrs_module,
       classify_class_attrs.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.classify_class_attrs.__module__ == 'inspect' — pure-Python function defined in Lib/inspect.py; module name is 'inspect' (7 chars); same module as all inspect functions"]
    - [getattr_static_name,
       getattr_static.__name__.__eq__,
       ["getattr_static"],
       true,
       "inspect.getattr_static.__name__ == 'getattr_static' — pure-Python function in Lib/inspect.py added in Python 3.2; retrieves attributes without triggering descriptors (no __get__/__set__ calls); 14-char name; same length as getouterframes and getinnerframes"]
    - [getattr_static_module,
       getattr_static.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getattr_static.__module__ == 'inspect' — pure-Python function defined in Lib/inspect.py; module name is 'inspect' (7 chars); same module as classify_class_attrs and all other inspect functions"]
