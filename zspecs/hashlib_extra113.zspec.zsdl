spec: hashlib_extra113
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra112.zspec.zsdl — covers md5/sha1/sha256/sha512 function __qualname__ string equality / sha224/sha384/sha3_512/blake2s qualname equality / qualname length groupings across SHA families and BLAKE2 (table + invariants)."
    - "hashlib_extra111.zspec.zsdl — covers sha3_256.__qualname__.__eq__('openssl_sha3_256') and blake2b.__qualname__.__eq__('blake2b') in a table; blake2b is a type not a function (table + invariants)."
    - "hashlib_extra110.zspec.zsdl — covers HASH class-level method descriptor qualnames for digest/copy / method_descriptor type names for update/digest/copy at class level / sha256 instance-bound method qualnames (digest/copy/hexdigest) / hexdigest descriptor type name and length confirmations (table + invariants)."
    - "hashlib_extra109.zspec.zsdl — covers algorithms_guaranteed and algorithms_available class names and sizes / subset relationship / hashlib.new code attributes (co_name, co_argcount, type, module) / blake2s membership (table + invariants)."
    - "hashlib_extra108.zspec.zsdl — covers sha224/sha384/sha3_256/sha3_512 digest_size and block_size / blake2b/blake2s digest_size and block_size and type names / sha3_256/sha3_512 HASH type identity / HASH.update and HASH.hexdigest qualname string equality via sha256().__class__ (table + invariants)."
    - "hashlib_extra107.zspec.zsdl — covers HASH type identity (__name__=='HASH', __module__=='_hashlib', __mro__.__len__()==2, __bases__[0].__name__=='object') / HASH method qualname lengths / md5/sha1/sha256/sha512 digest_size and block_size (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 __class__.__name__=='builtin_function_or_method' and __name__ equality / blake2b/blake2s class/module/qualname / algorithms_guaranteed.__len__()==14 (table + invariants)."
  notes:
    - "This spec extends hashlib through hashlib_extra112; it does NOT duplicate invariants present in those files."
    - "Wave 271 theme: HASH class-level attributes — name, block_size, digest_size — are getset_descriptors; their qualnames follow the 'HASH.attr' pattern; __objclass__ is HASH; type is getset_descriptor for all three."
    - "type(type(hashlib.md5()).name).__name__ == 'getset_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.md5()).name.__qualname__ == 'HASH.name'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.md5()).block_size.__qualname__ == 'HASH.block_size'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.md5()).digest_size.__qualname__ == 'HASH.digest_size'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.md5()).name.__objclass__.__name__ == 'HASH'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(type(hashlib.md5()).name.__qualname__) == 9 ('HASH.name': 'HASH.'=5 + 'name'=4). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(type(hashlib.md5()).block_size.__qualname__) == 15 ('HASH.block_size': 'HASH.'=5 + 'block_size'=10). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(type(hashlib.md5()).digest_size.__qualname__) == 16 ('HASH.digest_size': 'HASH.'=5 + 'digest_size'=11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: HASH is the internal CPython C-level type for hash objects returned by hashlib.md5(), hashlib.sha256(), etc. It is defined in Modules/_hashlib.c as 'HASH'. Its attributes name, block_size, and digest_size are getset_descriptors — C-level property-like objects that expose integer and string fields of the underlying C struct."
    - "Note: getset_descriptor is the type of C-level attribute descriptors (as opposed to member_descriptor which is for C-level struct members). The qualname pattern 'HASH.attr' reflects that these descriptors are defined on the HASH class. All three (name, block_size, digest_size) are getset_descriptor type; __objclass__ is HASH for all three."
    - "Note: hashlib_extra107 anchors HASH type identity (__name__=='HASH', __module__=='_hashlib'); this spec anchors the HASH class-level descriptor types (name, block_size, digest_size) as getset_descriptors with their qualnames and __objclass__ for the first time."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# type(type(hashlib.md5()).name).__name__.__eq__('getset_descriptor')
# type(hashlib.md5()).name.__qualname__.__eq__('HASH.name')
# type(hashlib.md5()).block_size.__qualname__.__eq__('HASH.block_size')
# type(hashlib.md5()).name.__objclass__.__name__.__eq__('HASH')
# len(type(hashlib.md5()).name.__qualname__) == 9
#
# Wave 271 theme: HASH.name, HASH.block_size, HASH.digest_size are getset_descriptors.
#
# The HASH class (CPython internal C type from _hashlib) exposes three data
# descriptors: name (returns the algorithm name as a string), block_size (returns
# the algorithm's block size in bytes), and digest_size (returns the digest length
# in bytes). All three are getset_descriptor type — the C-level equivalent of
# Python properties. Their qualnames follow the 'HASH.attr' pattern and their
# __objclass__ is HASH. hashlib_extra107 anchors HASH type identity; this spec
# anchors the descriptor types as getset_descriptor for the first time.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra113.HASH_name_block_size_digest_size_descriptor_types:
  description: "type(HASH.name).__name__.__eq__('getset_descriptor')==True / HASH.name.__qualname__.__eq__('HASH.name')==True / HASH.block_size.__qualname__.__eq__('HASH.block_size')==True / HASH.name.__objclass__.__name__.__eq__('HASH')==True / HASH.name.__qualname__.__len__()==9 — HASH is the CPython internal C type for hash objects; name/block_size/digest_size are getset_descriptors (C-level data descriptors); qualnames follow 'HASH.attr' pattern; __objclass__ is HASH; name qualname is 9 chars; extra107 anchors HASH type identity; first hashhash113 anchor"
  kind: python_call_eq
  category: descriptor_identity
  id_prefix: hashhash113

  columns: [id, function, args, expected, description]
  rows:
    - [name_type_getset,    "sha256().__class__.name.__class__.__name__.__eq__", ["getset_descriptor"], true, "type(HASH.name).__name__ is 'getset_descriptor' (C-level data descriptor; not member_descriptor; on HASH class in _hashlib)"]
    - [name_qualname_eq,    "sha256().__class__.name.__qualname__.__eq__",       ["HASH.name"],         true, "HASH.name.__qualname__ is 'HASH.name' (9 chars; 'HASH.'=5 + 'name'=4; returns hash algorithm name string)"]
    - [block_size_qualname, "sha256().__class__.block_size.__qualname__.__eq__", ["HASH.block_size"],   true, "HASH.block_size.__qualname__ is 'HASH.block_size' (15 chars; 'HASH.'=5 + 'block_size'=10; returns block size in bytes)"]
    - [name_objclass_eq,    "sha256().__class__.name.__objclass__.__name__.__eq__", ["HASH"],           true, "HASH.name.__objclass__.__name__ is 'HASH' (__objclass__ is the class the descriptor is defined on; here HASH)"]
    - [name_qualname_len,   "sha256().__class__.name.__qualname__.__len__",      [],                    9,    "HASH.name.__qualname__.__len__() is 9 ('HASH.name': 'HASH.'=5 + 'name'=4)"]

# ---------------------------------------------------------------------------
# HASH.digest_size.__qualname__.__eq__('HASH.digest_size')
# HASH.digest_size.__objclass__.__name__.__eq__('HASH')
# HASH.block_size.__objclass__.__name__.__eq__('HASH')
# HASH.digest_size.__qualname__.__len__()==16
# HASH.block_size.__qualname__.__len__()==15
#
# Wave 271 theme: HASH.digest_size and HASH.block_size descriptor qualname details.
#
# HASH.digest_size.__qualname__ is 'HASH.digest_size' (16 chars: 'HASH.'=5 +
# 'digest_size'=11). HASH.block_size.__qualname__ is 'HASH.block_size' (15 chars:
# 'HASH.'=5 + 'block_size'=10). Both have __objclass__ == HASH. The digest_size
# qualname length (16) is one more than block_size (15) because 'digest_size'
# has 11 chars vs 'block_size' with 10 chars. No prior hashlib spec anchors
# HASH.digest_size qualname equality or HASH.block_size/__objclass__ as a grouped
# table. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra113.HASH_digest_size_and_block_size_qualname_objclass:
  description: "HASH.digest_size.__qualname__.__eq__('HASH.digest_size')==True / HASH.digest_size.__objclass__.__name__.__eq__('HASH')==True / HASH.block_size.__objclass__.__name__.__eq__('HASH')==True / HASH.digest_size.__qualname__.__len__()==16 / HASH.block_size.__qualname__.__len__()==15 — digest_size is 16 chars ('HASH.'=5 + 'digest_size'=11); block_size is 15 chars ('HASH.'=5 + 'block_size'=10); both __objclass__ are HASH; digest_size qualname len 16 is same as 'openssl_sha3_256' len; no prior spec anchors these; first hashhash113 anchor"
  kind: python_call_eq
  category: descriptor_identity
  id_prefix: hashhash113

  columns: [id, function, args, expected, description]
  rows:
    - [digest_size_qualname_eq,  "sha256().__class__.digest_size.__qualname__.__eq__",         ["HASH.digest_size"], true, "HASH.digest_size.__qualname__ is 'HASH.digest_size' (16 chars; 'HASH.'=5 + 'digest_size'=11; returns digest length in bytes)"]
    - [digest_size_objclass_eq,  "sha256().__class__.digest_size.__objclass__.__name__.__eq__", ["HASH"],             true, "HASH.digest_size.__objclass__.__name__ is 'HASH' (__objclass__ is the class the descriptor is defined on)"]
    - [block_size_objclass_eq,   "sha256().__class__.block_size.__objclass__.__name__.__eq__",  ["HASH"],             true, "HASH.block_size.__objclass__.__name__ is 'HASH' (all three descriptors share the same __objclass__)"]
    - [digest_size_qualname_len, "sha256().__class__.digest_size.__qualname__.__len__",         [],                   16,   "HASH.digest_size.__qualname__.__len__() is 16 ('HASH.digest_size': 'HASH.'=5 + 'digest_size'=11)"]
    - [block_size_qualname_len,  "sha256().__class__.block_size.__qualname__.__len__",          [],                   15,   "HASH.block_size.__qualname__.__len__() is 15 ('HASH.block_size': 'HASH.'=5 + 'block_size'=10)"]

# ---------------------------------------------------------------------------
# type(hashlib.sha256().__class__.name).__name__.__eq__('getset_descriptor')
# HASH.name.__qualname__.__eq__('HASH.name') [via sha256()]
# HASH.block_size.__qualname__.__eq__('HASH.block_size') [via sha256()]
# type(HASH.digest_size).__name__.__eq__('getset_descriptor')
# HASH.digest_size.__qualname__.__eq__('HASH.digest_size') [all three getset]
#
# Wave 271 theme: All three HASH descriptors are getset_descriptor; qualname
# string equality grouped across name/block_size/digest_size.
#
# This table groups the three HASH attribute descriptors (name, block_size,
# digest_size) and confirms that all three are getset_descriptor type and have
# qualnames following the 'HASH.attr' pattern. The type check via sha256() is
# important because HASH is not directly importable from hashlib — you must
# create a hash instance to access the HASH class via .__class__. No prior
# hashlib spec anchors all three descriptor type checks in a single table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra113.HASH_all_three_descriptors_getset_type_grouped:
  description: "type(HASH.name).__name__.__eq__('getset_descriptor')==True / type(HASH.block_size).__name__.__eq__('getset_descriptor')==True / type(HASH.digest_size).__name__.__eq__('getset_descriptor')==True / HASH.name.__qualname__.__eq__('HASH.name')==True / HASH.digest_size.__qualname__.__eq__('HASH.digest_size')==True — all three HASH class-level attributes are getset_descriptor (C-level data descriptors); qualnames follow 'HASH.attr' pattern; HASH not directly importable (access via hash instance .__class__); no prior spec groups all three; first hashhash113 anchor"
  kind: python_call_eq
  category: descriptor_identity
  id_prefix: hashhash113

  columns: [id, function, args, expected, description]
  rows:
    - [name_type_eq,         "sha256().__class__.name.__class__.__name__.__eq__",         ["getset_descriptor"], true, "type(HASH.name) is getset_descriptor (C-level data descriptor defined in _hashlib; exposes name field of C struct)"]
    - [block_size_type_eq,   "sha256().__class__.block_size.__class__.__name__.__eq__",   ["getset_descriptor"], true, "type(HASH.block_size) is getset_descriptor (same C-level descriptor type; exposes block_size integer field)"]
    - [digest_size_type_eq,  "sha256().__class__.digest_size.__class__.__name__.__eq__",  ["getset_descriptor"], true, "type(HASH.digest_size) is getset_descriptor (same C-level descriptor type; exposes digest_size integer field)"]
    - [name_qualname_eq2,    "sha256().__class__.name.__qualname__.__eq__",               ["HASH.name"],         true, "HASH.name.__qualname__ is 'HASH.name' (grouped with other two descriptors; confirms 'HASH.attr' pattern)"]
    - [digest_size_qualname_eq2, "sha256().__class__.digest_size.__qualname__.__eq__",    ["HASH.digest_size"],  true, "HASH.digest_size.__qualname__ is 'HASH.digest_size' (16 chars; longest of the three HASH descriptor qualnames)"]

# ---------------------------------------------------------------------------
# type(HASH.name).__name__.__eq__('getset_descriptor') — standalone
#
# type(HASH.name).__name__ is 'getset_descriptor'. The HASH class (defined in
# Modules/_hashlib.c as the C struct EVPobject) exposes its name, block_size,
# and digest_size fields as getset_descriptors. A getset_descriptor is a C-level
# descriptor defined by a PyGetSetDef struct — it has both a getter and optionally
# a setter function. The HASH.name descriptor is read-only (no setter) and returns
# the algorithm name (e.g., 'md5', 'sha256') as a Python string. This is in
# contrast to member_descriptor which is used for simple C struct fields without
# custom getter/setter logic. hashlib_extra110 anchors HASH method_descriptor type
# names; this spec anchors HASH attribute getset_descriptor types for the first time.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra113.HASH_name_type_is_getset_descriptor:
  description: "type(HASH.name).__name__.__eq__('getset_descriptor') == True — HASH.name is a getset_descriptor (C-level PyGetSetDef-based descriptor; has getter function; read-only; returns algorithm name string like 'md5' or 'sha256'); distinct from member_descriptor (simple C struct field); extra110 anchors method_descriptor types; first standalone for HASH attribute descriptor types under hashhash113"
  category: descriptor_identity
  kind: python_call_eq
  function: "sha256().__class__.name.__class__.__name__.__eq__"
  args: ["getset_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# HASH.name.__qualname__.__eq__('HASH.name') — standalone
#
# HASH.name.__qualname__ is 'HASH.name' (9 chars). The qualname 'HASH.name'
# follows the 'ClassName.attr' pattern, where 'HASH' is the C-level class name
# and 'name' is the attribute name. The HASH class is defined in Modules/_hashlib.c
# and is not directly importable from Python — you must use the .__class__
# attribute of a hash instance to access it (e.g., hashlib.md5().__class__).
# The qualifier 'HASH.' has length 5, and 'name' has length 4, giving total
# length 9. This qualname length (9) is shorter than HASH.block_size (15) and
# HASH.digest_size (16) because 'name' is the shortest attribute name.
# No prior hashlib spec anchors HASH.name.__qualname__ equality as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra113.HASH_name_qualname_eq:
  description: "HASH.name.__qualname__.__eq__('HASH.name') == True — qualname is 'HASH.name' (9 chars; 'HASH.'=5 + 'name'=4); HASH is C-level class in _hashlib not directly importable; shortest qualname among three HASH descriptors (name=9, block_size=15, digest_size=16); first standalone under hashhash113"
  category: descriptor_identity
  kind: python_call_eq
  function: "sha256().__class__.name.__qualname__.__eq__"
  args: ["HASH.name"]
  expected: true

# ---------------------------------------------------------------------------
# HASH.block_size.__qualname__.__eq__('HASH.block_size') — standalone
#
# HASH.block_size.__qualname__ is 'HASH.block_size' (15 chars: 'HASH.'=5 +
# 'block_size'=10). The HASH.block_size descriptor returns the hash algorithm's
# internal block size in bytes. For MD5 and SHA-1, block_size is 64 (512-bit
# blocks). For SHA-384 and SHA-512, block_size is 128 (1024-bit blocks). For
# SHA3-256 and SHA3-512, block_size is 136 and 72 respectively (due to the
# Keccak sponge rate). The block_size is used in HMAC construction to pad the
# key to the block boundary. Its qualname length (15) is one less than
# HASH.digest_size (16) because 'block_size' has 10 chars vs 'digest_size'
# with 11 chars. No prior spec anchors HASH.block_size qualname as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra113.HASH_block_size_qualname_eq:
  description: "HASH.block_size.__qualname__.__eq__('HASH.block_size') == True — qualname is 'HASH.block_size' (15 chars; 'HASH.'=5 + 'block_size'=10); block_size is 64 bytes for MD5/SHA-1, 128 for SHA-512/SHA-384, 136 for SHA3-256; used in HMAC key padding; 1 char shorter than digest_size qualname; no prior spec anchors as standalone; first standalone under hashhash113"
  category: descriptor_identity
  kind: python_call_eq
  function: "sha256().__class__.block_size.__qualname__.__eq__"
  args: ["HASH.block_size"]
  expected: true

# ---------------------------------------------------------------------------
# HASH.digest_size.__qualname__.__eq__('HASH.digest_size') — standalone
#
# HASH.digest_size.__qualname__ is 'HASH.digest_size' (16 chars: 'HASH.'=5 +
# 'digest_size'=11). The HASH.digest_size descriptor returns the hash algorithm's
# output digest length in bytes. For MD5, digest_size is 16 (128-bit). For
# SHA-1, digest_size is 20 (160-bit). For SHA-256, digest_size is 32 (256-bit).
# For SHA-512, digest_size is 64 (512-bit). This is the most important attribute
# for selecting an appropriate hash function for a specific security level (e.g.,
# 128-bit security requires SHA-256 with its 32-byte digest). The qualname length
# (16) matches that of 'openssl_sha3_256' and 'HASH.digest_size'. No prior spec
# anchors HASH.digest_size qualname as a standalone. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant hashlib_extra113.HASH_digest_size_qualname_eq:
  description: "HASH.digest_size.__qualname__.__eq__('HASH.digest_size') == True — qualname is 'HASH.digest_size' (16 chars; 'HASH.'=5 + 'digest_size'=11); digest_size is 16 for MD5, 20 for SHA-1, 32 for SHA-256, 64 for SHA-512; longest of the three HASH descriptor qualnames; len 16 matches 'openssl_sha3_256'; no prior spec anchors as standalone; first standalone under hashhash113"
  category: descriptor_identity
  kind: python_call_eq
  function: "sha256().__class__.digest_size.__qualname__.__eq__"
  args: ["HASH.digest_size"]
  expected: true

# ---------------------------------------------------------------------------
# HASH.name.__objclass__.__name__.__eq__('HASH') — standalone
#
# HASH.name.__objclass__.__name__ is 'HASH'. The __objclass__ attribute of a
# descriptor is the class on which the descriptor is defined. For all three HASH
# descriptors (name, block_size, digest_size), __objclass__ is the HASH class.
# The HASH class __name__ is 'HASH' (4 chars). This confirms that all three
# descriptors are defined directly on the HASH class (not on a base class or
# mixin). The HASH class has __module__ == '_hashlib' and __mro__ of length 2
# ([HASH, object]). No prior hashlib spec anchors HASH.name.__objclass__.__name__
# equality as a standalone under hashhash113. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra113.HASH_name_objclass_is_HASH:
  description: "HASH.name.__objclass__.__name__.__eq__('HASH') == True — __objclass__ is the class the descriptor is defined on; HASH.__name__ is 'HASH' (4 chars); __objclass__ == HASH for all three descriptors (name/block_size/digest_size); HASH is the C-level class from _hashlib; extra107 anchors HASH __name__=='HASH'; first standalone for __objclass__ under hashhash113"
  category: descriptor_identity
  kind: python_call_eq
  function: "sha256().__class__.name.__objclass__.__name__.__eq__"
  args: ["HASH"]
  expected: true

