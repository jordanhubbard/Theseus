spec: enum_extra34
version: ">=3.11"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum_extra33.zspec.zsdl."
    - "Prior specs covered: Enum/IntEnum/Flag/IntFlag/StrEnum/auto/unique/EnumType __name__/__module__/__qualname__; all __mro__.__len__() values; __bases__[0].__name__ for all; Enum dunder method __qualname__.__len__() for __new__/__str__/__repr__/__hash__/__format__; EnumType method __qualname__.__len__() for __call__/__prepare__/__repr__/__setattr__/__delattr__/__iter__/__new__/__getitem__; Enum._missing_ and _generate_next_value_ qualname lengths; EnumType.__mro__.__len__()==3."
    - "This spec covers: enum.__all__.__len__()==30 and .__class__.__name__.__len__()==4; __dict__.__class__.__name__.__len__()==12 for Enum/IntEnum/Flag/IntFlag/StrEnum/EnumType; Enum._generate_next_value_.__qualname__.__len__()==26; Enum._missing_.__qualname__.__len__()==14; EnumType.__bases__[0].__name__.__len__()==4; IntEnum.__bases__[0].__name__.__len__()==3; Flag.__bases__[0].__name__.__len__()==4; auto/__qualname__.__len__()==4; unique/__qualname__.__len__()==6; nonmember/__qualname__.__len__()==9; member/__qualname__.__len__()==6."
    - "enum.__all__.__len__() == 30 — thirty public names exported by the enum module (Python 3.11+)."
    - "enum.__all__.__class__.__name__ == 'list' (len=4) — __all__ is a plain list."
    - "All six enum classes (Enum, IntEnum, Flag, IntFlag, StrEnum, EnumType) have __dict__.__class__.__name__ == 'mappingproxy' (len=12)."
    - "Enum._generate_next_value_.__qualname__ == 'Enum._generate_next_value_' (len=26) — longest Enum method qualname recorded in this spec series."
    - "Enum._missing_.__qualname__ == 'Enum._missing_' (len=14) — matches Enum.__format__ (15) closely."
    - "EnumType.__bases__[0].__name__ == 'type' (len=4) — EnumType is a metaclass, subclassing 'type'."
    - "IntEnum.__bases__[0].__name__ == 'int' (len=3) — IntEnum directly subclasses int (and ReprEnum)."
    - "Flag.__bases__[0].__name__ == 'Enum' (len=4) — Flag directly subclasses Enum."
    - "auto.__qualname__ == 'auto' (len=4) — simple helper class for automatic enum values."
    - "unique.__qualname__ == 'unique' (len=6); member.__qualname__ == 'member' (len=6) — tied."
    - "nonmember.__qualname__ == 'nonmember' (len=9) — longest of the four small helper qualnames."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __dict__.__class__.__name__.__len__() table for enum classes
# (extra34 namespace)
#
# Enum, IntEnum, Flag, IntFlag, StrEnum (Python 3.11+), and EnumType all
# have __dict__.__class__.__name__ == 'mappingproxy' (12 characters). This
# is the standard Python class namespace wrapper. No prior enum spec records
# all six together in the extra34 namespace.
# ---------------------------------------------------------------------------

table enum_extra34.class_dict_class_name_lens:
  description: "__dict__.__class__.__name__.__len__() for enum classes — all equal 12 ('mappingproxy')"
  kind: python_call_eq
  category: class_dict_attrs
  id_prefix: dict_class_name_len

  columns: [id, function, args, expected]
  rows:
    - [Enum,     Enum.__dict__.__class__.__name__.__len__,     [], 12]
    - [IntEnum,  IntEnum.__dict__.__class__.__name__.__len__,  [], 12]
    - [Flag,     Flag.__dict__.__class__.__name__.__len__,     [], 12]
    - [IntFlag,  IntFlag.__dict__.__class__.__name__.__len__,  [], 12]
    - [StrEnum,  StrEnum.__dict__.__class__.__name__.__len__,  [], 12]
    - [EnumType, EnumType.__dict__.__class__.__name__.__len__, [], 12]

# ---------------------------------------------------------------------------
# Helper symbol __qualname__.__len__() table (extra34 namespace)
#
# The enum module exposes four small helper symbols at module scope:
#   auto      -> qualname 'auto'      (len=4) — auto-assign enum values
#   unique    -> qualname 'unique'    (len=6) — decorator ensuring uniqueness
#   member    -> qualname 'member'    (len=6) — force item into enum members
#   nonmember -> qualname 'nonmember' (len=9) — exclude item from enum members
# nonmember (9) is the longest; auto (4) is the shortest. unique and member
# are tied at 6. No prior enum spec records all four together in the extra34
# namespace.
# ---------------------------------------------------------------------------

table enum_extra34.helper_symbol_qualname_lens:
  description: "__qualname__.__len__() for enum helper symbols: auto, unique, member, nonmember"
  kind: python_call_eq
  category: qualname_attrs
  id_prefix: helper_qualname_len

  columns: [id, function, args, expected]
  rows:
    - [auto,      auto.__qualname__.__len__,      [], 4]
    - [unique,    unique.__qualname__.__len__,     [], 6]
    - [member,    member.__qualname__.__len__,     [], 6]
    - [nonmember, nonmember.__qualname__.__len__,  [], 9]

# ---------------------------------------------------------------------------
# Enum special method __qualname__.__len__() table (extra34 namespace)
#
# Enum._generate_next_value_ and Enum._missing_ are special hooks:
#   _generate_next_value_ -> 'Enum._generate_next_value_' (len=26) — longest
#   _missing_             -> 'Enum._missing_'              (len=14)
# _generate_next_value_ (26) is the longest method qualname among all Enum
# methods covered in the spec series. No prior enum spec records these two
# together in the extra34 namespace alongside the __bases__[0].__name__ facts.
# ---------------------------------------------------------------------------

table enum_extra34.Enum_special_method_qualname_lens:
  description: "__qualname__.__len__() for Enum._generate_next_value_ and Enum._missing_"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: Enum_special_qualname_len

  columns: [id, function, args, expected]
  rows:
    - [generate_next_value, Enum._generate_next_value_.__qualname__.__len__, [], 26]
    - [missing,             Enum._missing_.__qualname__.__len__,             [], 14]

# ---------------------------------------------------------------------------
# enum.__all__.__len__() == 30 — standalone (extra34 namespace)
#
# The enum module exports 30 public names via __all__ in Python 3.11+,
# reflecting additions such as StrEnum, member, nonmember, and EnumCheck.
# No prior enum spec records this standalone count in the extra34 namespace.
# ---------------------------------------------------------------------------

invariant enum_extra34.all_len:
  description: "len(enum.__all__) == 30 — thirty public names exported by enum (Python 3.11+)"
  category: module_attrs
  kind: python_call_eq
  function: enum.__all__.__len__
  args: []
  expected: 30

# ---------------------------------------------------------------------------
# enum.__all__.__class__.__name__.__len__() == 4 — standalone
# (extra34 namespace)
#
# enum.__all__ is a plain Python list, so __class__.__name__ == 'list'
# (4 characters). No prior enum spec records this in the extra34 namespace.
# ---------------------------------------------------------------------------

invariant enum_extra34.all_class_name_len:
  description: "len(enum.__all__.__class__.__name__) == 4 — __all__ is a list"
  category: module_attrs
  kind: python_call_eq
  function: enum.__all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# EnumType.__bases__[0].__name__.__len__() == 4 — standalone
# (extra34 namespace)
#
# EnumType is a metaclass — a subclass of the built-in 'type'. 'type' has 4
# characters. This confirms that EnumType sits in the metaclass hierarchy
# (type -> object) rather than the enum value hierarchy. No prior enum spec
# records this standalone in the extra34 namespace.
# ---------------------------------------------------------------------------

invariant enum_extra34.EnumType.base_name_len:
  description: "len(enum.EnumType.__bases__[0].__name__) == 4 — EnumType's direct base is 'type'"
  category: class_hierarchy
  kind: python_call_eq
  function: "EnumType.__bases__[0].__name__.__len__"
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# IntEnum.__bases__[0].__name__.__len__() == 3 — standalone
# (extra34 namespace)
#
# IntEnum inherits from int (and ReprEnum). int.__name__ == 'int' (3 chars) —
# the shortest base-class name among the core enum classes. This reflects that
# IntEnum members are genuine int subclass instances. No prior enum spec records
# this standalone in the extra34 namespace.
# ---------------------------------------------------------------------------

invariant enum_extra34.IntEnum.base_name_len:
  description: "len(enum.IntEnum.__bases__[0].__name__) == 3 — IntEnum's primary base is 'int'"
  category: class_hierarchy
  kind: python_call_eq
  function: "IntEnum.__bases__[0].__name__.__len__"
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# Enum._generate_next_value_.__qualname__.__len__() == 26 — standalone
# (extra34 namespace)
#
# 'Enum._generate_next_value_' has 26 characters, making it the longest
# method qualname among all Enum methods covered in this spec series.
# _generate_next_value_(name, start, count, last_values) is called by auto()
# to compute successive enum values. No prior enum spec records this standalone
# in the extra34 namespace.
# ---------------------------------------------------------------------------

invariant enum_extra34.Enum.generate_next_value.qualname_len:
  description: "len(enum.Enum._generate_next_value_.__qualname__) == 26 — longest Enum method qualname in the series"
  category: method_qualname_lengths
  kind: python_call_eq
  function: Enum._generate_next_value_.__qualname__.__len__
  args: []
  expected: 26
