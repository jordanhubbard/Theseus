spec: dataclasses_extra29
version: ">=3.9"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "This spec extends dataclasses_extra28.zspec.zsdl."
    - "Prior specs covered: dataclass decorator, field(), fields(), asdict(), astuple(), make_dataclass(), replace(), is_dataclass(), dataclasses.__name__/__package__, dataclasses.Field.__name__/__module__/__qualname__, FrozenInstanceError/__name__, InitVar/__name__, KW_ONLY, MISSING.__class__.__name__, dataclasses.__all__ type/length, dataclasses.field.__name__, various function __module__ and __qualname__ attributes."
    - "This spec covers: dataclasses.dataclass.__name__, dataclasses.fields.__name__, dataclasses.asdict.__name__, dataclasses.astuple.__name__, dataclasses.make_dataclass.__name__, dataclasses.replace.__name__, dataclasses.is_dataclass.__name__, dataclasses.Field.__bases__[0].__name__, dataclasses.FrozenInstanceError.__bases__[0].__name__, dataclasses.FrozenInstanceError.__module__."
    - "All module-level function __name__ values equal their identifier: dataclass/fields/asdict/astuple/make_dataclass/replace/is_dataclass."
    - "Field.__bases__[0].__name__ == 'object' — Field is a plain class inheriting from object."
    - "FrozenInstanceError.__bases__[0].__name__ == 'AttributeError' — FrozenInstanceError subclasses AttributeError."
    - "FrozenInstanceError.__module__ == 'dataclasses' — defined at module level in dataclasses."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# dataclasses module-level function __name__ values — combined table
#
# Each module-level function in dataclasses has a __name__ equal to its
# identifier string. No prior dataclasses spec collects all seven of
# dataclass/fields/asdict/astuple/make_dataclass/replace/is_dataclass together
# in a single combined __name__.__eq__ table in the extra29 namespace.
# ---------------------------------------------------------------------------

table dataclasses_extra29.function_names:
  description: "__name__.__eq__ for dataclasses module-level functions"
  kind: python_call_eq
  category: function_attrs
  id_prefix: name

  columns: [id, function, args, expected]
  rows:
    - [dataclass,      dataclass.__name__.__eq__,      ["dataclass"],      true]
    - [fields,         fields.__name__.__eq__,         ["fields"],         true]
    - [asdict,         asdict.__name__.__eq__,         ["asdict"],         true]
    - [astuple,        astuple.__name__.__eq__,        ["astuple"],        true]
    - [make_dataclass, make_dataclass.__name__.__eq__, ["make_dataclass"], true]
    - [replace,        replace.__name__.__eq__,        ["replace"],        true]
    - [is_dataclass,   is_dataclass.__name__.__eq__,   ["is_dataclass"],   true]

# ---------------------------------------------------------------------------
# dataclasses module-level function __name__.__len__() — combined table
#
# String lengths of each function __name__:
#   dataclass -> 9, fields -> 6, asdict -> 6, astuple -> 7,
#   make_dataclass -> 14, replace -> 7, is_dataclass -> 12.
# No prior dataclasses spec records these seven name lengths together in a
# single combined table in the extra29 namespace.
# ---------------------------------------------------------------------------

table dataclasses_extra29.function_name_lens:
  description: "__name__.__len__() for dataclasses module-level functions"
  kind: python_call_eq
  category: function_attr_lengths
  id_prefix: name_len

  columns: [id, function, args, expected]
  rows:
    - [dataclass,      dataclass.__name__.__len__,       [],  9]
    - [fields,         fields.__name__.__len__,          [],  6]
    - [asdict,         asdict.__name__.__len__,          [],  6]
    - [astuple,        astuple.__name__.__len__,         [],  7]
    - [make_dataclass, make_dataclass.__name__.__len__,  [], 14]
    - [replace,        replace.__name__.__len__,         [],  7]
    - [is_dataclass,   is_dataclass.__name__.__len__,    [], 12]

# ---------------------------------------------------------------------------
# dataclasses.Field.__bases__[0].__name__ == 'object' — standalone invariant
#
# dataclasses.Field is defined as a plain class with no explicit base other
# than object. No prior dataclasses spec records Field.__bases__[0].__name__
# in any invariant or table in the extra29 namespace.
# ---------------------------------------------------------------------------

invariant dataclasses_extra29.Field.base_name:
  description: "dataclasses.Field.__bases__[0].__name__ == 'object' — Field inherits directly from object"
  category: class_attrs
  kind: python_call_eq
  function: "Field.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# dataclasses.FrozenInstanceError.__bases__[0].__name__ == 'AttributeError'
#
# FrozenInstanceError is raised when a frozen dataclass is mutated; it
# subclasses AttributeError. No prior dataclasses spec records
# FrozenInstanceError.__bases__[0].__name__ in the extra29 namespace.
# (dataclasses_extra27 records FrozenInstanceError base name in its namespace.)
# ---------------------------------------------------------------------------

invariant dataclasses_extra29.FrozenInstanceError.base_name:
  description: "dataclasses.FrozenInstanceError.__bases__[0].__name__ == 'AttributeError' — subclasses AttributeError"
  category: class_attrs
  kind: python_call_eq
  function: "FrozenInstanceError.__bases__[0].__name__.__eq__"
  args: ["AttributeError"]
  expected: true

# ---------------------------------------------------------------------------
# dataclasses.FrozenInstanceError.__module__ == 'dataclasses' — standalone invariant
#
# FrozenInstanceError is defined at module level in dataclasses.
# No prior dataclasses spec records FrozenInstanceError.__module__ in the
# extra29 namespace.
# ---------------------------------------------------------------------------

invariant dataclasses_extra29.FrozenInstanceError.module:
  description: "dataclasses.FrozenInstanceError.__module__ == 'dataclasses' — defined in the dataclasses module"
  category: module_attrs
  kind: python_call_eq
  function: FrozenInstanceError.__module__.__eq__
  args: ["dataclasses"]
  expected: true
