  rows:
    - [re931y001, re.finditer.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [re931y002, re.sub.__doc__.__class__.__name__.__eq__,        ["str"], true]
    - [re931y003, re.subn.__doc__.__class__.__name__.__eq__,       ["str"], true]
    - [re931y004, re.split.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [re931y005, re.escape.__doc__.__class__.__name__.__eq__,     ["str"], true]
    - [re931y006, re.purge.__doc__.__class__.__name__.__eq__,      ["str"], true]

table re_extra931.error_and_pattern_doc_type:
  description: "re.error and re.Pattern __doc__ type identity"
