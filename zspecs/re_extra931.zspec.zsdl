spec: re_extra931
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module function documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __doc__.__class__.__name__ for re module public functions and compile"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra931.compile_and_match_doc_type:
  description: "re.compile and re.match __doc__ type identity"
  kind: python_call_eq
  category: compile_and_match_doc_type
  id_prefix: re931x
  columns: [id, function, args, expected]
  rows:
    - [re931x001, re.compile.__doc__.__class__.__name__.__eq__,    ["str"], true]
    - [re931x002, re.match.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [re931x003, re.search.__doc__.__class__.__name__.__eq__,     ["str"], true]
    - [re931x004, re.fullmatch.__doc__.__class__.__name__.__eq__,  ["str"], true]
    - [re931x005, re.findall.__doc__.__class__.__name__.__eq__,    ["str"], true]

table re_extra931.iter_and_sub_doc_type:
