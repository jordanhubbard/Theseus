spec: itertools_extra195
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "itertools.__name__ == 'itertools' (len=9); the module name as registered in sys.modules; verified with Python 3.14.3."
    - "itertools.__package__ == '' (len=0); itertools is a top-level C extension module with no package prefix; verified with Python 3.14.3."
    - "itertools.__doc__.__class__.__name__ == 'str' (len=3); the module docstring is a Python str object; verified with Python 3.14.3."
    - "itertools.__loader__.__class__.__name__ == 'type' (len=4); the loader for a built-in module is BuiltinImporter, which is itself a class (type); verified with Python 3.14.3."
    - "itertools.__spec__.name == 'itertools' (len=9); the ModuleSpec .name attribute holds the module name; __spec__.__name__ does not exist — use __spec__.name (the attribute, not dunder); verified with Python 3.14.3."
    - "itertools.count.__doc__.__class__.__name__ == 'str' (len=3); count is a C-level type whose docstring is a Python str; verified with Python 3.14.3."
    - "itertools.chain.__doc__.__class__.__name__ == 'str' (len=3); chain is a C-level type whose docstring is a Python str; verified with Python 3.14.3."
    - "itertools.repeat.__doc__.__class__.__name__ == 'str' (len=3); repeat is a C-level type whose docstring is a Python str; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools module-level name, package, and doc class
#
# itertools.__name__                  == 'itertools' (len=9)
# itertools.__package__               == '' (len=0)
# itertools.__doc__.__class__.__name__ == 'str' (len=3)
#
# itertools is a built-in C extension with an empty __package__. New to extra195.
# ---------------------------------------------------------------------------

table itertools_extra195.module_name_package_doc:
  description: "itertools module identity: __name__=='itertools'(len=9); __package__==''(len=0); __doc__.__class__.__name__=='str'(len=3); new to extra195"
  kind: python_call_eq
  category: module_attrs
  id_prefix: itermoduleattrs195

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name_eq,
       __name__.__eq__,
       ["itertools"],
       true,
       "itertools.__name__.__eq__('itertools') == True — the module name as registered in sys.modules; __name__ is 'itertools' (len=9); str.__eq__('itertools') returns True; verified with Python 3.14.3; new to extra195"]
    - [mod_name_len,
       __name__.__len__,
       [],
       9,
       "itertools.__name__.__len__() == 9 — 'itertools' has 9 characters: i-t-e-r-t-o-o-l-s; str.__len__() returns 9; verified with Python 3.14.3; new to extra195"]
    - [mod_package_eq,
       __package__.__eq__,
       [""],
       true,
       "itertools.__package__.__eq__('') == True — itertools is a top-level C extension module with no package prefix; __package__ is '' (len=0); str.__eq__('') returns True; verified with Python 3.14.3; new to extra195"]
    - [mod_package_len,
       __package__.__len__,
       [],
       0,
       "itertools.__package__.__len__() == 0 — itertools has an empty __package__ string; str.__len__() returns 0; verified with Python 3.14.3; new to extra195"]
    - [mod_doc_class_eq,
       __doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.__doc__.__class__.__name__.__eq__('str') == True — the module docstring is a Python str object; __doc__.__class__.__name__ is 'str' (len=3); str.__eq__('str') returns True; verified with Python 3.14.3; new to extra195"]

# ---------------------------------------------------------------------------
# Table 2: itertools loader class and spec name
#
# itertools.__loader__.__class__.__name__ == 'type' (len=4)
# itertools.__spec__.name                 == 'itertools' (len=9)
# itertools.__spec__.__class__.__name__   == 'ModuleSpec' (len=10)
#
# The BuiltinImporter loader is itself a class (type). The ModuleSpec .name
# attribute stores the module name. New to extra195.
# ---------------------------------------------------------------------------

table itertools_extra195.loader_and_spec:
  description: "itertools loader and spec: __loader__.__class__.__name__=='type'(len=4); __spec__.name=='itertools'(len=9); __spec__.__class__.__name__=='ModuleSpec'(len=10); new to extra195"
  kind: python_call_eq
  category: module_attrs
  id_prefix: itermoduleattrs195

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_eq,
       __loader__.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.__loader__.__class__.__name__.__eq__('type') == True — the loader for a built-in module is BuiltinImporter, which is itself a class (metaclass is type); __loader__.__class__.__name__ is 'type' (len=4); str.__eq__('type') returns True; verified with Python 3.14.3; new to extra195"]
    - [loader_class_len,
       __loader__.__class__.__name__.__len__,
       [],
       4,
       "itertools.__loader__.__class__.__name__.__len__() == 4 — 'type' has 4 characters: t-y-p-e; str.__len__() returns 4; verified with Python 3.14.3; new to extra195"]
    - [spec_name_eq,
       __spec__.name.__eq__,
       ["itertools"],
       true,
       "itertools.__spec__.name.__eq__('itertools') == True — the ModuleSpec .name attribute holds the module name; note __spec__.__name__ does not exist on ModuleSpec; __spec__.name is 'itertools' (len=9); str.__eq__('itertools') returns True; verified with Python 3.14.3; new to extra195"]
    - [spec_name_len,
       __spec__.name.__len__,
       [],
       9,
       "itertools.__spec__.name.__len__() == 9 — 'itertools' has 9 characters: i-t-e-r-t-o-o-l-s; str.__len__() returns 9; verified with Python 3.14.3; new to extra195"]
    - [spec_class_eq,
       __spec__.__class__.__name__.__eq__,
       ["ModuleSpec"],
       true,
       "itertools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — itertools.__spec__ is an instance of ModuleSpec from importlib._bootstrap; __spec__.__class__.__name__ is 'ModuleSpec' (len=10); str.__eq__('ModuleSpec') returns True; verified with Python 3.14.3; new to extra195"]

