spec: abc_extra32
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra31.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__.__len__() and __name__.__len__() and __qualname__.__len__() for ABC/ABCMeta/abstractmethod/get_cache_token, abstractproperty lengths, ABCMeta.register/__name__/__qualname__ lengths, ABCMeta.__new__/__instancecheck__ __qualname__.__len__(), __mro__.__len__() for ABCMeta(3)/ABC(2), ABC/__ABCMeta __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__() for ABC/ABCMeta (both 12), ABCMeta.__subclasscheck__/__qualname__.__len__()==25, update_abstractmethods/__qualname__.__len__()==22, ABC.__abstractmethods__.__class__.__name__.__len__()==9, ABC.__name__.__len__()==3, ABCMeta.register.__qualname__.__len__()==16, abstractmethod.__name__.__len__()==14, get_cache_token.__name__.__len__()==15, abc.__name__.__len__()==3, ABCMeta mro entry name lengths, ABC mro entry name lengths, ABCMeta.__subclasshook__/__qualname__.__len__()==24, issubclass/isinstance behavioral invariants, abstractmethod.__class__.__name__.__len__()==8, ABC.__doc__.__class__.__name__.__len__()==3, update_abstractmethods/__name__.__len__()==22, ABC.__module__.__len__()==3, ABCMeta.__prepare__.__qualname__.__len__()==19, ABCMeta.__prepare__.__name__.__len__()==11, ABCMeta.__init__.__qualname__.__len__()==13, ABCMeta.__getattribute__.__qualname__.__len__()==21, ABCMeta.__call__/__repr__.__qualname__.__len__()==13, ABCMeta.__setattr__/__delattr__.__qualname__.__len__()==16, abstractmethod.__code__.__class__.__name__.__len__()==4, ABC.__subclasshook__.__qualname__.__len__()==20."
    - "This spec covers: ABCMeta.__instancecheck__.__name__.__len__()==17 ('__instancecheck__'); ABCMeta.__subclasscheck__.__name__.__len__()==17 ('__subclasscheck__'); ABC.__init_subclass__.__name__.__len__()==17 ('__init_subclass__'); ABC.__init_subclass__.__qualname__.__len__()==21 ('ABC.__init_subclass__'); abstractmethod.__annotations__.__class__.__name__.__len__()==4 ('dict'); ABC.__class__.__name__.__len__()==7 ('ABCMeta'); ABCMeta.__class__.__name__.__len__()==4 ('type'); get_cache_token.__class__.__name__.__len__()==26 ('builtin_function_or_method')."
    - "ABCMeta.__instancecheck__.__name__, ABCMeta.__subclasscheck__.__name__, and ABC.__init_subclass__.__name__ all share length 17. '__instancecheck__' is 17 chars (2 leading underscores + 15 body + trailing is part of body); '__subclasscheck__' is 17 chars; '__init_subclass__' is 17 chars. Prior specs measured __qualname__.__len__() for __instancecheck__ (25) and __subclasscheck__ (25), but not their __name__.__len__() as integers."
    - "ABC.__init_subclass__.__qualname__ == 'ABC.__init_subclass__' (21 chars): 'ABC' (3) + '.' (1) + '__init_subclass__' (17) = 21. This is a classmethod inherited from the ABC class hierarchy; its __qualname__ carries the 'ABC.' prefix."
    - "ABC.__class__ is ABCMeta — the metaclass of ABC. ABC.__class__.__name__ == 'ABCMeta' (7 chars). ABCMeta.__class__ is type — the metaclass of ABCMeta. ABCMeta.__class__.__name__ == 'type' (4 chars). These reveal the metaclass chain: ABC -> ABCMeta -> type."
    - "abstractmethod.__annotations__ == {} (empty dict). Its __class__ is dict. __class__.__name__ == 'dict' (4 chars). This traversal is novel: it goes through the annotations attribute of a class to reach the class name of the annotations container."
    - "get_cache_token is a C-level builtin. Its __class__.__name__ == 'builtin_function_or_method' (26 chars). This contrasts with abstractmethod.__class__.__name__ == 'function' (8 chars, covered in extra29): both are callable but have different implementation origins."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ABCMeta protocol method __name__.__len__() — extra32 namespace
#
# ABCMeta defines two key protocol methods for isinstance/issubclass checks:
#   ABCMeta.__instancecheck__.__name__  == '__instancecheck__'  (17 chars)
#   ABCMeta.__subclasscheck__.__name__  == '__subclasscheck__'  (17 chars)
# Both share __name__.__len__() == 17. Prior specs measured their
# __qualname__.__len__() (25 each: 'ABCMeta.' (8) + 17 = 25), but NOT
# their short __name__.__len__() as integer invariants.
# Additionally, ABC defines __init_subclass__ as a classmethod:
#   ABC.__init_subclass__.__name__  == '__init_subclass__'  (17 chars)
# All three share the same __name__.__len__() == 17, forming a natural group.
# ---------------------------------------------------------------------------

table abc_extra32.protocol_method_name_lengths:
  description: "abc ABCMeta protocol method and ABC.__init_subclass__ __name__.__len__() in extra32 namespace — all share length 17"
  kind: python_call_eq
  category: method_names
  id_prefix: abcprotomethodnamelen32

  columns: [id, function, args, expected, description]
  rows:
    - [instancecheck,   ABCMeta.__instancecheck__.__name__.__len__,  [], 17, "'__instancecheck__' is 17 characters; prior spec measured __qualname__.__len__()==25 but not __name__.__len__()"]
    - [subclasscheck,   ABCMeta.__subclasscheck__.__name__.__len__,  [], 17, "'__subclasscheck__' is 17 characters; same length as __instancecheck__"]
    - [init_subclass,   ABC.__init_subclass__.__name__.__len__,      [], 17, "'__init_subclass__' is 17 characters; same length as the ABCMeta protocol methods"]

# ---------------------------------------------------------------------------
# ABC.__init_subclass__.__qualname__.__len__() — extra32 namespace
#
# ABC.__init_subclass__.__qualname__ == 'ABC.__init_subclass__' (21 chars):
#   'ABC' (3) + '.' (1) + '__init_subclass__' (17) = 21
# This classmethod is inherited by all classes created with ABC as base.
# Its __qualname__ is shorter than ABCMeta method qualnames because 'ABC' (3)
# is much shorter than 'ABCMeta' (7). No prior abc spec has measured
# ABC.__init_subclass__.__qualname__.__len__() as an integer invariant.
# ---------------------------------------------------------------------------

invariant abc_extra32.ABC_init_subclass_qualname_len:
  description: "abc.ABC.__init_subclass__.__qualname__.__len__() == 21 — 'ABC.__init_subclass__' has 21 characters: 'ABC' (3) + '.' (1) + '__init_subclass__' (17)"
  category: method_names
  kind: python_call_eq
  function: ABC.__init_subclass__.__qualname__.__len__
  args: []
  expected: 21

# ---------------------------------------------------------------------------
# abc metaclass chain __class__.__name__.__len__() — extra32 namespace
#
# Python's metaclass chain for abc is:
#   ABC.__class__       is ABCMeta  → ABCMeta.__name__  == 'ABCMeta' (7 chars)
#   ABCMeta.__class__   is type     → type.__name__     == 'type'    (4 chars)
# Measuring ABC.__class__.__name__.__len__() and ABCMeta.__class__.__name__.__len__()
# reveals the metaclass hierarchy through name length arithmetic. No prior
# abc spec has captured these __class__.__name__.__len__() values.
# ---------------------------------------------------------------------------

table abc_extra32.metaclass_chain_name_lengths:
  description: "abc metaclass chain __class__.__name__.__len__() — ABC's metaclass is ABCMeta (7); ABCMeta's metaclass is type (4)"
  kind: python_call_eq
  category: class_names
  id_prefix: abcmetachainlen32

  columns: [id, function, args, expected, description]
  rows:
    - [abc_class,     ABC.__class__.__name__.__len__,    [], 7, "ABC.__class__ is ABCMeta; 'ABCMeta' is 7 characters"]
    - [abcmeta_class, ABCMeta.__class__.__name__.__len__, [], 4, "ABCMeta.__class__ is type; 'type' is 4 characters"]

# ---------------------------------------------------------------------------
# abstractmethod.__annotations__ and get_cache_token class name lengths — extra32
#
# abstractmethod.__annotations__ returns {} (empty dict). The container's
# class is dict: abstractmethod.__annotations__.__class__.__name__ == 'dict' (4).
# get_cache_token is a C builtin: its __class__.__name__ == 'builtin_function_or_method' (26).
# These two facts together reveal the contrast between Python-level classes
# (abstractmethod is 'function', 8 chars; covered in extra29) and C-level
# builtins (get_cache_token is 'builtin_function_or_method', 26 chars).
# ---------------------------------------------------------------------------

invariant abc_extra32.abstractmethod_annotations_class_name_len:
  description: "abc.abstractmethod.__annotations__.__class__.__name__.__len__() == 4 — annotations is an empty dict; dict's class name is 'dict' (4 chars)"
  category: class_names
  kind: python_call_eq
  function: abstractmethod.__annotations__.__class__.__name__.__len__
  args: []
  expected: 4

invariant abc_extra32.get_cache_token_class_name_len:
  description: "abc.get_cache_token.__class__.__name__.__len__() == 26 — get_cache_token is a C builtin; 'builtin_function_or_method' has 26 characters"
  category: class_names
  kind: python_call_eq
  function: get_cache_token.__class__.__name__.__len__
  args: []
  expected: 26

# ---------------------------------------------------------------------------
# Standalone invariants — extra32
# ---------------------------------------------------------------------------

invariant abc_extra32.ABCMeta_instancecheck_name_len:
  description: "abc.ABCMeta.__instancecheck__.__name__.__len__() == 17 — '__instancecheck__' has 17 characters; prior specs measured __qualname__.__len__()==25 but not __name__.__len__()"
  category: method_names
  kind: python_call_eq
  function: ABCMeta.__instancecheck__.__name__.__len__
  args: []
  expected: 17

invariant abc_extra32.ABC_class_name_len:
  description: "abc.ABC.__class__.__name__.__len__() == 7 — ABC's metaclass is ABCMeta; 'ABCMeta' has 7 characters"
  category: class_names
  kind: python_call_eq
  function: ABC.__class__.__name__.__len__
  args: []
  expected: 7
