spec: struct_extra1396
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "Wave 540 (_extra1396): focuses on __class_getitem__ and __init_subclass__ method checks."
    - "struct.Struct is a C extension type implementing the compiled struct API. It does not define __class_getitem__ in its own __dict__, so struct.Struct.__dict__.__contains__('__class_getitem__') returns False."
    - "struct.error is a concrete exception class inheriting from Exception. It also does not define __class_getitem__ in its own __dict__, so struct.error.__dict__.__contains__('__class_getitem__') returns False."
    - "Neither struct.Struct nor struct.error defines __init_subclass__ in their own __dict__; both inherit it from object."
    - "When accessed as struct.Struct.__init_subclass__, the classmethod_descriptor in object.__dict__ is bound through the descriptor protocol, yielding a 'builtin_function_or_method'."
    - "object.__dict__.__contains__('__class_getitem__') returns False on Python 3.14 — there is no global __class_getitem__ on object."
    - "object.__dict__.__contains__('__init_subclass__') returns True — object owns __init_subclass__ as a classmethod_descriptor."
    - "struct.Struct.__class__.__name__ == 'type' and struct.error.__class__.__name__ == 'type' — both have the plain type metaclass."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table struct_extra1396.struct_class_getitem_absent:
  description: "struct.Struct and struct.error class dicts do not contain __class_getitem__ — neither class defines generic-alias support; __dict__.__contains__ returns False for both"
  kind: python_call_eq
  category: class_getitem_checks
  id_prefix: st1396cg
  columns: [id, function, args, expected]
  rows:
    - [st1396cg001, struct.Struct.__dict__.__contains__,                          ["__class_getitem__"], false]
    - [st1396cg002, struct.error.__dict__.__contains__,                           ["__class_getitem__"], false]
    - [st1396cg003, struct.Struct.__dict__.__contains__,                          ["__init_subclass__"], false]
    - [st1396cg004, struct.error.__dict__.__contains__,                           ["__init_subclass__"], false]
    - [st1396cg005, struct.Struct.__dict__.__class__.__name__.__eq__,             ["mappingproxy"],      true]
    - [st1396cg006, struct.error.__dict__.__class__.__name__.__eq__,              ["mappingproxy"],      true]

table struct_extra1396.struct_init_subclass_bound_checks:
  description: "struct.Struct and struct.error inherit __init_subclass__ from object; when accessed as an attribute the descriptor protocol yields a builtin_function_or_method; object.__dict__ owns the classmethod_descriptor"
  kind: python_call_eq
  category: init_subclass_checks
  id_prefix: st1396is
  columns: [id, function, args, expected]
  rows:
    - [st1396is001, struct.Struct.__init_subclass__.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [st1396is002, struct.error.__init_subclass__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [st1396is003, object.__dict__.__contains__,                                ["__init_subclass__"],          true]
    - [st1396is004, object.__dict__.__contains__,                                ["__class_getitem__"],          false]
    - [st1396is005, struct.Struct.__class__.__name__.__eq__,                     ["type"],                       true]
    - [st1396is006, struct.error.__class__.__name__.__eq__,                      ["type"],                       true]

table struct_extra1396.struct_bases_and_name_checks:
  description: "struct.Struct and struct.error __bases__, __mro__, and __name__ consistency checks; confirms both are plain-type classes with tuple MROs and string names"
  kind: python_call_eq
  category: class_getitem_checks
  id_prefix: st1396bn
  columns: [id, function, args, expected]
  rows:
    - [st1396bn001, struct.Struct.__bases__.__class__.__name__.__eq__,   ["tuple"], true]
    - [st1396bn002, struct.error.__bases__.__class__.__name__.__eq__,    ["tuple"], true]
    - [st1396bn003, struct.Struct.__mro__.__class__.__name__.__eq__,     ["tuple"], true]
    - [st1396bn004, struct.error.__mro__.__class__.__name__.__eq__,      ["tuple"], true]
    - [st1396bn005, struct.Struct.__name__.__class__.__name__.__eq__,    ["str"],   true]
    - [st1396bn006, struct.error.__name__.__class__.__name__.__eq__,     ["str"],   true]
