spec: hashlib_extra1336
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c and Modules/sha2module.c"
  notes:
    - "Wave 536 (_extra1336): focuses on __hash__ and __eq__ method class checks for hashlib types."
    - "hashlib.algorithms_guaranteed is a plain Python set; sets are unhashable — __hash__ is None."
    - "algorithms_guaranteed.__hash__ is None confirms that set deliberately defines __hash__ = None."
    - "algorithms_guaranteed.__eq__.__class__.__name__ == 'method-wrapper' — bound to the set instance."
    - "algorithms_guaranteed.__eq__.__qualname__ == 'set.__eq__' — the set's __eq__ method."
    - "The HASH C extension type inherits __hash__ and __eq__ from object as wrapper_descriptors."
    - "hashlib.new('md5').__class__.__hash__.__qualname__ == 'object.__hash__' — inherited from object."
    - "hashlib.new('md5').__class__.__eq__.__qualname__ == 'object.__eq__' — inherited from object."
    - "hashlib.md5 is a builtin_function_or_method; its __hash__ is a method-wrapper bound to the function object."
    - "hashlib.md5.__hash__.__qualname__ == 'builtin_function_or_method.__hash__' (method-wrapper)."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table hashlib_extra1336.HASH_hash_eq_descriptors:
  description: "HASH C extension type __hash__ and __eq__ inherited from object as wrapper_descriptors: class name and qualname checks"
  kind: python_call_eq
  category: hash_eq_class_checks
  id_prefix: hl1336hh
  columns: [id, function, args, expected]
  rows:
    - [hl1336hh001, hashlib.new("md5").__class__.__hash__.__class__.__name__.__eq__, ["wrapper_descriptor"],  true]
    - [hl1336hh002, hashlib.new("md5").__class__.__hash__.__qualname__.__eq__,       ["object.__hash__"],     true]
    - [hl1336hh003, hashlib.new("md5").__class__.__eq__.__class__.__name__.__eq__,   ["wrapper_descriptor"],  true]
    - [hl1336hh004, hashlib.new("md5").__class__.__eq__.__qualname__.__eq__,         ["object.__eq__"],       true]
    - [hl1336hh005, hashlib.new("sha256").__class__.__hash__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [hl1336hh006, hashlib.new("sha256").__class__.__eq__.__qualname__.__eq__,        ["object.__eq__"],      true]
    - [hl1336hh007, hashlib.new("sha512").__class__.__hash__.__qualname__.__eq__,      ["object.__hash__"],    true]
    - [hl1336hh008, hashlib.new("sha512").__class__.__eq__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]

table hashlib_extra1336.algorithms_set_hash_eq_checks:
  description: "hashlib set attributes are unhashable (__hash__ is None) and have method-wrapper __eq__; confirms set hashability semantics"
  kind: python_call_eq
  category: hash_eq_class_checks
  id_prefix: hl1336sh
  columns: [id, function, args, expected]
  rows:
    - [hl1336sh001, (hashlib.algorithms_guaranteed.__hash__ is None).__class__.__name__.__eq__,  ["bool"],           true]
    - [hl1336sh002, (hashlib.algorithms_available.__hash__ is None).__class__.__name__.__eq__,   ["bool"],           true]
    - [hl1336sh003, hashlib.algorithms_guaranteed.__eq__.__class__.__name__.__eq__,              ["method-wrapper"], true]
    - [hl1336sh004, hashlib.algorithms_guaranteed.__eq__.__qualname__.__eq__,                    ["set.__eq__"],     true]
    - [hl1336sh005, hashlib.algorithms_available.__eq__.__class__.__name__.__eq__,               ["method-wrapper"], true]
    - [hl1336sh006, hashlib.algorithms_available.__eq__.__qualname__.__eq__,                     ["set.__eq__"],     true]

table hashlib_extra1336.md5_builtin_hash_eq_checks:
  description: "hashlib.md5 is a builtin_function_or_method; its __hash__ and __eq__ are method-wrappers bound to the function object"
  kind: python_call_eq
  category: hash_eq_class_checks
  id_prefix: hl1336bh
  columns: [id, function, args, expected]
  rows:
    - [hl1336bh001, hashlib.md5.__hash__.__class__.__name__.__eq__,   ["method-wrapper"],                  true]
    - [hl1336bh002, hashlib.md5.__hash__.__qualname__.__eq__,         ["builtin_function_or_method.__hash__"], true]
    - [hl1336bh003, hashlib.md5.__eq__.__class__.__name__.__eq__,     ["method-wrapper"],                  true]
    - [hl1336bh004, hashlib.md5.__eq__.__qualname__.__eq__,           ["builtin_function_or_method.__eq__"], true]
    - [hl1336bh005, hashlib.sha256.__hash__.__class__.__name__.__eq__, ["method-wrapper"],                  true]
    - [hl1336bh006, hashlib.sha256.__eq__.__qualname__.__eq__,         ["builtin_function_or_method.__eq__"], true]
