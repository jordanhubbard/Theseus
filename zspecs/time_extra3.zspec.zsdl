spec: time_extra3
version: ">=3.9"
backend: python_module(time)

docs: https://docs.python.org/3/library/time.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/time.html — Python time module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/timemodule.c"
  notes:
    - "This spec extends time.zspec.zsdl, time_extra.zspec.zsdl, and time_extra2.zspec.zsdl."
    - "Focus: time.struct_time class attributes, module-level timezone globals, and function name verification."
    - "time.struct_time._fields is a tuple of 9 field name strings: tm_year, tm_mon, tm_mday, tm_hour, tm_min, tm_sec, tm_wday, tm_yday, tm_isdst."
    - "time.altzone, time.daylight, time.timezone are int module-level constants; time.tzname is a 2-tuple of strings."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# time.struct_time — class identity and _fields tuple
# ---------------------------------------------------------------------------

invariant time_extra3.struct_time.class_name:
  description: "time.struct_time.__name__ == 'struct_time'"
  category: struct_time
  kind: python_call_eq
  function: struct_time.__name__.__eq__
  args: ["struct_time"]
  expected: true

invariant time_extra3.struct_time.module:
  description: "time.struct_time.__module__ == 'time'"
  category: struct_time
  kind: python_call_eq
  function: struct_time.__module__.__eq__
  args: ["time"]
  expected: true

invariant time_extra3.struct_time.fields_class_name:
  description: "time.struct_time._fields.__class__.__name__ == 'tuple'"
  category: struct_time
  kind: python_call_eq
  function: struct_time._fields.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant time_extra3.struct_time.fields_len:
  description: "time.struct_time._fields.__len__() == 9 (tm_year through tm_isdst)"
  category: struct_time
  kind: python_call_eq
  function: struct_time._fields.__len__
  args: []
  expected: 9

invariant time_extra3.struct_time.fields_contains_tm_year:
  description: "time.struct_time._fields.__contains__('tm_year') == True"
  category: struct_time
  kind: python_call_eq
  function: struct_time._fields.__contains__
  args: ["tm_year"]
  expected: true

invariant time_extra3.struct_time.fields_contains_tm_sec:
  description: "time.struct_time._fields.__contains__('tm_sec') == True"
  category: struct_time
  kind: python_call_eq
  function: struct_time._fields.__contains__
  args: ["tm_sec"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level timezone globals — altzone, daylight, timezone, tzname
# ---------------------------------------------------------------------------

invariant time_extra3.altzone.class_name:
  description: "time.altzone.__class__.__name__ == 'int'"
  category: globals
  kind: python_call_eq
  function: altzone.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant time_extra3.daylight.class_name:
  description: "time.daylight.__class__.__name__ == 'int'"
  category: globals
  kind: python_call_eq
  function: daylight.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant time_extra3.timezone.class_name:
  description: "time.timezone.__class__.__name__ == 'int'"
  category: globals
  kind: python_call_eq
  function: timezone.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant time_extra3.tzname.class_name:
  description: "time.tzname.__class__.__name__ == 'tuple'"
  category: globals
  kind: python_call_eq
  function: tzname.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant time_extra3.tzname.len:
  description: "time.tzname.__len__() == 2 — (standard_name, dst_name)"
  category: globals
  kind: python_call_eq
  function: tzname.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# function_names table — gmtime, localtime, mktime, strftime, strptime
# ---------------------------------------------------------------------------

table time_extra3.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: function_name

  columns: [id, function, args, expected]
  rows:
    - [gmtime,    gmtime.__name__.__eq__,    ["gmtime"],    true]
    - [localtime, localtime.__name__.__eq__, ["localtime"], true]
    - [mktime,    mktime.__name__.__eq__,    ["mktime"],    true]
    - [strftime,  strftime.__name__.__eq__,  ["strftime"],  true]
    - [strptime,  strptime.__name__.__eq__,  ["strptime"],  true]
