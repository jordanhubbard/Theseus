spec: concurrent_futures_extra32
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra31.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values, class __module__/__name__/__len__() tables, submit/shutdown qualname lens for ThreadPoolExecutor/ProcessPoolExecutor/Executor, Future method qualname lens for result/add_done_callback/cancel/done/exception/running/set_result/set_exception/set_running_or_notify_cancel, class __dict__.__class__.__name__.__len__() for Future/ThreadPoolExecutor/ProcessPoolExecutor/Executor/BrokenExecutor/CancelledError, as_completed/wait __module__.__len__(), __all__.__len__() == 14, __mro__.__len__() for ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor, __bases__[0].__name__.__len__() for all four, Executor context manager __enter__/__exit__ qualname lens, InvalidStateError hierarchy, wait sentinel string lengths, class qualname lengths."
    - "This spec covers: ThreadPoolExecutor.__init__.__qualname__.__len__()==27 ('ThreadPoolExecutor.__init__'); ProcessPoolExecutor.__init__.__qualname__.__len__()==28 ('ProcessPoolExecutor.__init__'); Future.__init__.__qualname__.__len__()==15 ('Future.__init__'); Executor.__init__.__qualname__.__len__()==15 ('object.__init__'); BrokenExecutor.__init__.__qualname__.__len__()==22 ('BaseException.__init__')."
    - "ThreadPoolExecutor.__init__.__qualname__ == 'ThreadPoolExecutor.__init__' (27 chars) — defined directly on ThreadPoolExecutor."
    - "ProcessPoolExecutor.__init__.__qualname__ == 'ProcessPoolExecutor.__init__' (28 chars) — one char longer than ThreadPoolExecutor.__init__ qualname (27)."
    - "Future.__init__.__qualname__ == 'Future.__init__' (15 chars) — defined directly on Future."
    - "Executor.__init__.__qualname__ == 'object.__init__' (15 chars) — Executor does not define __init__; resolves to object.__init__."
    - "BrokenExecutor.__init__.__qualname__ == 'BaseException.__init__' (22 chars) — BrokenExecutor (RuntimeError subclass) inherits __init__ from BaseException."
    - "Future.__init__ and Executor.__init__ share the same __qualname__ length (15) despite resolving to different actual methods ('Future.__init__' vs 'object.__init__')."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures executor __init__ __qualname__ lengths — extra32 namespace
#
# The __init__ qualname reveals whether a class defines its own __init__ or
# inherits it. For ThreadPoolExecutor and ProcessPoolExecutor, __init__ is
# defined on the class itself:
#   ThreadPoolExecutor.__init__.__qualname__  == 'ThreadPoolExecutor.__init__'  (27 chars)
#   ProcessPoolExecutor.__init__.__qualname__ == 'ProcessPoolExecutor.__init__' (28 chars)
# ProcessPoolExecutor.__init__ qualname is one char longer than
# ThreadPoolExecutor.__init__ qualname — matching the class name length diff.
# No prior concurrent.futures spec has measured __init__.__qualname__.__len__()
# for either executor class.
# ---------------------------------------------------------------------------

table concurrent_futures_extra32.executor_init_qualname_lengths:
  description: "concurrent.futures executor __init__.__qualname__.__len__() in extra32 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: execinitqlen32

  columns: [id, function, args, expected]
  rows:
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__init__.__qualname__.__len__,  [], 27]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__init__.__qualname__.__len__, [], 28]

# ---------------------------------------------------------------------------
# concurrent.futures Future and Executor __init__ qualname lengths — extra32
#
# Future defines its own __init__:
#   Future.__init__.__qualname__ == 'Future.__init__' (15 chars)
# Executor does NOT define __init__ — it resolves to object.__init__:
#   Executor.__init__.__qualname__ == 'object.__init__' (15 chars)
# Both resolve to length 15, but the qualname strings differ: 'Future.__init__'
# vs 'object.__init__'. The identical length despite different strings makes
# this a useful cross-class comparison.
# BrokenExecutor inherits __init__ from BaseException (not RuntimeError.__init__
# or BrokenExecutor.__init__):
#   BrokenExecutor.__init__.__qualname__ == 'BaseException.__init__' (22 chars)
# ---------------------------------------------------------------------------

table concurrent_futures_extra32.future_executor_init_qualname_lengths:
  description: "concurrent.futures Future/Executor/BrokenExecutor __init__.__qualname__.__len__() in extra32 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: futexinitqlen32

  columns: [id, function, args, expected, description]
  rows:
    - [Future,         Future.__init__.__qualname__.__len__,         [], 15, "'Future.__init__' — defined on Future (15 chars)"]
    - [Executor,       Executor.__init__.__qualname__.__len__,       [], 15, "'object.__init__' — Executor inherits from object (15 chars)"]
    - [BrokenExecutor, BrokenExecutor.__init__.__qualname__.__len__, [], 22, "'BaseException.__init__' — BrokenExecutor inherits from BaseException (22 chars)"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra32
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra32.ThreadPoolExecutor_init_qualname_len:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__len__() == 27 — 'ThreadPoolExecutor.__init__' has 27 characters"
  category: method_names
  kind: python_call_eq
  function: ThreadPoolExecutor.__init__.__qualname__.__len__
  args: []
  expected: 27

invariant concurrent_futures_extra32.ProcessPoolExecutor_init_qualname_len:
  description: "concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__len__() == 28 — 'ProcessPoolExecutor.__init__' is one char longer than ThreadPoolExecutor's (27)"
  category: method_names
  kind: python_call_eq
  function: ProcessPoolExecutor.__init__.__qualname__.__len__
  args: []
  expected: 28

invariant concurrent_futures_extra32.BrokenExecutor_init_qualname_len:
  description: "concurrent.futures.BrokenExecutor.__init__.__qualname__.__len__() == 22 — resolves to 'BaseException.__init__' (22 chars), not BrokenExecutor or RuntimeError"
  category: method_names
  kind: python_call_eq
  function: BrokenExecutor.__init__.__qualname__.__len__
  args: []
  expected: 22
