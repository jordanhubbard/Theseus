spec: calendar_extra18
version: ">=3.9"
backend: python_module(calendar)

docs: https://docs.python.org/3/library/calendar.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/calendar.html — Python calendar module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/calendar.py"
    - "calendar_extra3.zspec.zsdl — covers __qualname__ for Calendar/TextCalendar/HTMLCalendar/isleap/monthrange/weekday; isleap/__module__"
    - "calendar_extra7.zspec.zsdl — covers Calendar/__qualname__; isleap; leapdays; monthrange; firstweekday/__module__"
    - "calendar_extra13.zspec.zsdl — covers isleap/__qualname__; month/__qualname__; calendar/__qualname__"
    - "calendar_extra14.zspec.zsdl — covers leapdays/__qualname__; monthcalendar/__qualname__; setfirstweekday/__qualname__; firstweekday/__qualname__"
    - "calendar_extra17.zspec.zsdl — covers Calendar.__init__.__qualname__/__module__; TextCalendar/__init__.__qualname__; HTMLCalendar/__init__.__qualname__; monthrange/__module__; isleap/__module__; leapdays/__module__; weekday/__module__"
  notes:
    - "This spec extends calendar_extra17.zspec.zsdl."
    - "NEW in extra18 — Axis 1: Calendar.__init__.__name__, TextCalendar.__init__.__name__, HTMLCalendar.__init__.__name__ — the __name__ attribute for the inherited __init__ method on each class."
    - "NEW in extra18 — Axis 2: isleap/__qualname__, leapdays/__qualname__, weekday/__qualname__, monthrange/__qualname__ as extra18-namespace standalone invariants (prior coverage was in table rows in extra3/extra7/extra13/extra14, or in earlier namespace invariants)."
    - "NEW in extra18 — Axis 3: isleap/__module__, leapdays/__module__, weekday/__module__, monthrange/__module__ as extra18-namespace standalone invariants (prior coverage was in table rows in extra17)."
    - "NEW in extra18 — Axis 4: calendar.monthcalendar.__qualname__ — the module-level monthcalendar is a bound method of the module-level TextCalendar instance; its __qualname__ is 'Calendar.monthdayscalendar'."
    - "calendar.Calendar.__init__.__name__ == '__init__' — verified Python 3.12."
    - "calendar.TextCalendar.__init__.__name__ == '__init__' — TextCalendar inherits __init__ from Calendar; __name__ is still '__init__'."
    - "calendar.HTMLCalendar.__init__.__name__ == '__init__' — HTMLCalendar inherits __init__ from Calendar; __name__ is still '__init__'."
    - "calendar.isleap.__qualname__ == 'isleap' — flat qualname; pure-Python function in calendar.py."
    - "calendar.leapdays.__qualname__ == 'leapdays' — flat qualname; pure-Python function in calendar.py."
    - "calendar.weekday.__qualname__ == 'weekday' — flat qualname; pure-Python function in calendar.py."
    - "calendar.monthrange.__qualname__ == 'monthrange' — flat qualname; pure-Python function in calendar.py."
    - "calendar.monthcalendar.__qualname__ == 'Calendar.monthdayscalendar' — the module-level name 'monthcalendar' is a bound method of the module-level c (TextCalendar instance); its underlying function is Calendar.monthdayscalendar."
    - "calendar.isleap.__module__ == 'calendar' — pure-Python, defined in calendar.py."
    - "calendar.leapdays.__module__ == 'calendar' — pure-Python, defined in calendar.py."
    - "calendar.weekday.__module__ == 'calendar' — pure-Python, defined in calendar.py."
    - "calendar.monthrange.__module__ == 'calendar' — pure-Python, defined in calendar.py."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Calendar.__init__, TextCalendar.__init__, HTMLCalendar.__init__ — __name__
#
# All three classes share the same __init__ implementation (TextCalendar and
# HTMLCalendar inherit it from Calendar without override). The __name__
# attribute of any method is always the bare name 'init' with double underscores
# regardless of inheritance. calendar_extra17 covers the __qualname__ for these
# (which is 'Calendar.__init__' for all three). This axis anchors the
# corresponding __name__ values as extra18-namespace invariants.
# ---------------------------------------------------------------------------

table calendar_extra18.init_method_names:
  description: "__init__.__name__ for Calendar, TextCalendar, HTMLCalendar — all resolve to '__init__'"
  kind: python_call_eq
  category: method_identity
  id_prefix: imn18

  columns: [id, function, args, expected]
  rows:
    - [Calendar,     Calendar.__init__.__name__.__eq__,     ["__init__"], true]
    - [TextCalendar, TextCalendar.__init__.__name__.__eq__, ["__init__"], true]
    - [HTMLCalendar, HTMLCalendar.__init__.__name__.__eq__, ["__init__"], true]

# ---------------------------------------------------------------------------
# isleap, leapdays, weekday, monthrange — __qualname__ standalone invariants
#
# These four are pure-Python functions defined in calendar.py. Their __qualname__
# values are flat strings (equal to __name__). Prior specs cover some of these
# in table rows (extra3, extra7) or in earlier namespace standalone invariants
# (extra13 for isleap, extra14 for leapdays/monthcalendar). These invariants
# establish the same facts under the extra18 namespace.
# ---------------------------------------------------------------------------

table calendar_extra18.utility_function_qualnames:
  description: "__qualname__ for isleap, leapdays, weekday, monthrange — all flat (equal to __name__)"
  kind: python_call_eq
  category: function_identity
  id_prefix: ufq18

  columns: [id, function, args, expected]
  rows:
    - [isleap,      isleap.__qualname__.__eq__,      ["isleap"],      true]
    - [leapdays,    leapdays.__qualname__.__eq__,     ["leapdays"],    true]
    - [weekday,     weekday.__qualname__.__eq__,      ["weekday"],     true]
    - [monthrange,  monthrange.__qualname__.__eq__,   ["monthrange"],  true]

# ---------------------------------------------------------------------------
# isleap, leapdays, weekday, monthrange — __module__ standalone invariants
#
# calendar_extra17 covers these four functions' __module__ values in a table
# (id_prefix ufm17). These invariants establish the same facts as standalone
# extra18-namespace invariants, complementing the __qualname__ table above.
# All four are pure-Python functions registered under module 'calendar'.
# ---------------------------------------------------------------------------

table calendar_extra18.utility_function_modules:
  description: "__module__ for isleap, leapdays, weekday, monthrange — all 'calendar'"
  kind: python_call_eq
  category: function_identity
  id_prefix: ufm18

  columns: [id, function, args, expected]
  rows:
    - [isleap,     isleap.__module__.__eq__,     ["calendar"], true]
    - [leapdays,   leapdays.__module__.__eq__,   ["calendar"], true]
    - [weekday,    weekday.__module__.__eq__,    ["calendar"], true]
    - [monthrange, monthrange.__module__.__eq__, ["calendar"], true]

# ---------------------------------------------------------------------------
# calendar.monthcalendar.__qualname__ — bound-method identity
#
# The module-level name 'monthcalendar' in calendar.py is not a plain function
# but a bound method: it is the monthdayscalendar method of the module-level
# TextCalendar instance 'c'. As a result, its __qualname__ is
# 'Calendar.monthdayscalendar' (the dotted qualname of the underlying function
# as defined on the Calendar base class). No prior calendar spec records this
# surprising discrepancy as a standalone invariant.
# ---------------------------------------------------------------------------

invariant calendar_extra18.monthcalendar.qualname:
  description: "calendar.monthcalendar.__qualname__ == 'Calendar.monthdayscalendar' — module-level alias is a bound method of the module-level TextCalendar instance; underlying function is Calendar.monthdayscalendar"
  category: function_identity
  kind: python_call_eq
  function: monthcalendar.__qualname__.__eq__
  args: ["Calendar.monthdayscalendar"]
  expected: true
