spec: multiprocessing_extra253
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "multiprocessing.context.__name__ == 'multiprocessing.context' (full dotted name)."
    - "multiprocessing.context.__package__ == 'multiprocessing'."
    - "multiprocessing.context.BaseContext is a pure Python class inheriting from object."
    - "multiprocessing.context.SpawnContext inherits from BaseContext."
    - "multiprocessing.context.ForkContext inherits from BaseContext (Unix only)."
    - "ForkContext is available on macOS/Darwin 25.4.0 (Unix platform)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.context module identity
#
# multiprocessing.context is the submodule defining all context classes.
# Its __name__ is the full dotted name; __package__ is 'multiprocessing'.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra253.context_module.name:
  description: "multiprocessing.context.__name__ == 'multiprocessing.context'"
  category: identity
  kind: python_call_eq
  function: context.__name__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra253.context_module.package:
  description: "multiprocessing.context.__package__ == 'multiprocessing'"
  category: identity
  kind: python_call_eq
  function: context.__package__.__eq__
  args: ["multiprocessing"]
  expected: true

# ---------------------------------------------------------------------------
# multiprocessing.context.BaseContext — class identity
#
# BaseContext is defined in multiprocessing.context and inherits from object.
# It is the abstract base for all context implementations.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra253.base_context.name:
  description: "multiprocessing.context.BaseContext.__name__ == 'BaseContext'"
  category: identity
  kind: python_call_eq
  function: context.BaseContext.__name__.__eq__
  args: ["BaseContext"]
  expected: true

invariant multiprocessing_extra253.base_context.module:
  description: "multiprocessing.context.BaseContext.__module__ == 'multiprocessing.context'"
  category: identity
  kind: python_call_eq
  function: context.BaseContext.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra253.base_context.base:
  description: "multiprocessing.context.BaseContext.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: context.BaseContext.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# multiprocessing.context.SpawnContext — class identity
#
# SpawnContext is defined in multiprocessing.context and inherits from
# BaseContext. It is available on all platforms.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra253.spawn_context.name:
  description: "multiprocessing.context.SpawnContext.__name__ == 'SpawnContext'"
  category: identity
  kind: python_call_eq
  function: context.SpawnContext.__name__.__eq__
  args: ["SpawnContext"]
  expected: true

invariant multiprocessing_extra253.spawn_context.module:
  description: "multiprocessing.context.SpawnContext.__module__ == 'multiprocessing.context'"
  category: identity
  kind: python_call_eq
  function: context.SpawnContext.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra253.spawn_context.base:
  description: "multiprocessing.context.SpawnContext.__bases__[0].__name__ == 'BaseContext'"
  category: identity
  kind: python_call_eq
  function: context.SpawnContext.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BaseContext"

# ---------------------------------------------------------------------------
# multiprocessing.context.ForkContext — class identity (Unix only)
#
# ForkContext is defined in multiprocessing.context and inherits from
# BaseContext. It is present on Unix/macOS but not on Windows.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra253.fork_context.name:
  description: "multiprocessing.context.ForkContext.__name__ == 'ForkContext'"
  category: identity
  kind: python_call_eq
  function: context.ForkContext.__name__.__eq__
  args: ["ForkContext"]
  expected: true

invariant multiprocessing_extra253.fork_context.module:
  description: "multiprocessing.context.ForkContext.__module__ == 'multiprocessing.context'"
  category: identity
  kind: python_call_eq
  function: context.ForkContext.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra253.fork_context.base:
  description: "multiprocessing.context.ForkContext.__bases__[0].__name__ == 'BaseContext'"
  category: identity
  kind: python_call_eq
  function: context.ForkContext.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BaseContext"
