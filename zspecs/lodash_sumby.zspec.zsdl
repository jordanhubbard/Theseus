spec: lodash_sumby
version: ">=4.0.0"
backend: node(lodash.sumby)

docs: https://lodash.com/docs/#sumBy

provenance:
  derived_from:
    - "lodash.sumby README — https://www.npmjs.com/package/lodash.sumby"
    - "Test vectors verified with lodash.sumby@4.6.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.sumby exports the _.sumBy function directly as module.exports."
    - "sumBy(array, iteratee) computes the sum of iteratee results."
    - "String iteratee plucks the named property."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the sum as a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_sumby.sumby:
  kind: node_module_call_eq
  function: ~
  category: sumby
  id_prefix: lsumb

  columns: [id, args, expected]
  rows:
    - [by_n,  [[{"n": 1}, {"n": 2}, {"n": 3}], "n"],  6]
    - [by_v,  [[{"v": 10}, {"v": 20}, {"v": 30}], "v"], 60]

