spec: environs_rust
version: ">=3.9"
backend: rust_module(environs_rust)

docs: https://github.com/sloria/environs

provenance:
  derived_from:
    - "https://github.com/sloria/environs — environs documentation"
  not_derived_from:
    - "environs source: environs/__init__.py"
  notes:
    - "environs provides environment variable parsing."
    - "from environs import Env; env = Env()."
    - "env.int('NUM', default=5) == 5 when NUM not set."
    - "env.str('KEY', default='hello') == 'hello' when KEY not set."
    - "env.bool('FLAG', default=True) == True when FLAG not set."
    - "Expose environs_int_default(key, val) -> int: Env().int(key, default=val)."
    - "Expose environs_str_default(key, val) -> str: Env().str(key, default=val)."
    - "Expose environs_bool_default(key, val) -> bool: Env().bool(key, default=val)."
    - "All test vectors verified against environs 11.2.1."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# environs_int_default — int default when env var absent
table environs_rust.env.int_default:
  kind: python_call_eq
  category: int_default
  id_prefix: env_i
  function: environs_int_default

  columns: [id, args, expected]
  rows:
    - [five,   ["MISSING_ENV_VAR_XYZ", 5],  5]
    - [forty2, ["MISSING_ENV_VAR_XYZ", 42], 42]

# environs_str_default — str default when env var absent
table environs_rust.env.str_default:
  kind: python_call_eq
  category: str_default
  id_prefix: env_s
  function: environs_str_default

  columns: [id, args, expected]
  rows:
    - [hello, ["MISSING_ENV_VAR_XYZ", "hello"], "hello"]
    - [world, ["MISSING_ENV_VAR_XYZ", "world"], "world"]

# environs_bool_default — bool default when env var absent
invariant environs_rust.env.bool_default_true:
  description: "Env().bool(key, default=True) == True when unset"
  category: bool_default
  kind: python_call_eq
  function: environs_bool_default
  args: ["MISSING_ENV_VAR_XYZ", true]
  expected: true

