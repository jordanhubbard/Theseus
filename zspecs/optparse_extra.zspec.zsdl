invariant optparse_extra.AmbiguousOptionError.name:
  description: "optparse.AmbiguousOptionError.__name__ == 'AmbiguousOptionError'"
  category: class_names
  kind: python_call_eq
  function: AmbiguousOptionError.__name__.__eq__
  args: ["AmbiguousOptionError"]
  expected: true

invariant optparse_extra.AmbiguousOptionError.base_class:
  description: "optparse.AmbiguousOptionError.__bases__[0].__name__ == 'BadOptionError' — AmbiguousOptionError inherits directly from BadOptionError"
  category: class_hierarchy
  kind: python_call_eq
  function: AmbiguousOptionError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
