invariant optparse_extra.BadOptionError.name:
  description: "optparse.BadOptionError.__name__ == 'BadOptionError'"
  category: class_names
  kind: python_call_eq
  function: BadOptionError.__name__.__eq__
  args: ["BadOptionError"]
  expected: true

invariant optparse_extra.BadOptionError.base_class:
  description: "optparse.BadOptionError.__bases__[0].__name__ == 'OptParseError' — BadOptionError inherits directly from OptParseError"
  category: class_hierarchy
  kind: python_call_eq
  function: BadOptionError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
