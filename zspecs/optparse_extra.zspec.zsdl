spec: optparse_extra
version: ">=3.2"
backend: python_module(optparse)

docs: https://docs.python.org/3/library/optparse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/optparse.html — Python optparse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/optparse.py"
  notes:
    - "Extends optparse.zspec.zsdl with additional class name, module, and exception hierarchy invariants."
    - "optparse.OptionParser.__name__ == 'OptionParser' — the main option-processing class."
    - "optparse.OptionParser.__module__ == 'optparse' — defined in the optparse module."
    - "optparse.Option.__name__ == 'Option' — represents a single command-line option."
    - "optparse.Option.__module__ == 'optparse' — defined in the optparse module."
    - "optparse.OptionGroup.__name__ == 'OptionGroup' — groups related options under a heading."
    - "optparse.OptionGroup.__module__ == 'optparse' — defined in the optparse module."
    - "optparse.OptParseError.__name__ == 'OptParseError' — root base class for all optparse exceptions."
    - "optparse.OptParseError.__bases__[0].__name__ == 'Exception' — OptParseError inherits from Exception."
    - "optparse.OptionError.__name__ == 'OptionError' — raised for invalid option definitions; inherits from OptParseError."
    - "optparse.OptionValueError.__name__ == 'OptionValueError' — raised for invalid option values; inherits from OptParseError."
    - "optparse.BadOptionError.__name__ == 'BadOptionError' — raised for unknown options on command line; inherits from OptParseError."
    - "optparse.AmbiguousOptionError.__name__ == 'AmbiguousOptionError' — raised when option prefix is ambiguous; inherits from BadOptionError."
    - "optparse.OptionConflictError.__name__ == 'OptionConflictError' — raised when conflicting options are added; inherits from OptionError."
    - "All expected values verified by running Python 3.12 optparse module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# OptionParser — class name and module
# ---------------------------------------------------------------------------

invariant optparse_extra.OptionParser.name:
  description: "optparse.OptionParser.__name__ == 'OptionParser'"
  category: class_names
  kind: python_call_eq
  function: OptionParser.__name__.__eq__
  args: ["OptionParser"]
  expected: true

invariant optparse_extra.OptionParser.module:
  description: "optparse.OptionParser.__module__ == 'optparse'"
  category: class_modules
  kind: python_call_eq
  function: OptionParser.__module__.__eq__
  args: ["optparse"]
  expected: true

# ---------------------------------------------------------------------------
# Option — class name and module
# ---------------------------------------------------------------------------

invariant optparse_extra.Option.name:
  description: "optparse.Option.__name__ == 'Option'"
  category: class_names
  kind: python_call_eq
  function: Option.__name__.__eq__
  args: ["Option"]
  expected: true

invariant optparse_extra.Option.module:
  description: "optparse.Option.__module__ == 'optparse'"
  category: class_modules
  kind: python_call_eq
  function: Option.__module__.__eq__
  args: ["optparse"]
  expected: true

# ---------------------------------------------------------------------------
# OptionGroup — class name and module
# ---------------------------------------------------------------------------

invariant optparse_extra.OptionGroup.name:
  description: "optparse.OptionGroup.__name__ == 'OptionGroup'"
  category: class_names
  kind: python_call_eq
  function: OptionGroup.__name__.__eq__
  args: ["OptionGroup"]
  expected: true

invariant optparse_extra.OptionGroup.module:
  description: "optparse.OptionGroup.__module__ == 'optparse'"
  category: class_modules
  kind: python_call_eq
  function: OptionGroup.__module__.__eq__
  args: ["optparse"]
  expected: true

# ---------------------------------------------------------------------------
# OptParseError — root exception name and base class
# ---------------------------------------------------------------------------

invariant optparse_extra.OptParseError.name:
  description: "optparse.OptParseError.__name__ == 'OptParseError'"
  category: class_names
  kind: python_call_eq
  function: OptParseError.__name__.__eq__
  args: ["OptParseError"]
  expected: true

invariant optparse_extra.OptParseError.base_class:
  description: "optparse.OptParseError.__bases__[0].__name__ == 'Exception' — root optparse exception inherits from Exception"
  category: class_hierarchy
  kind: python_call_eq
  function: OptParseError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

# ---------------------------------------------------------------------------
# OptionError — name and hierarchy
# ---------------------------------------------------------------------------

invariant optparse_extra.OptionError.name:
  description: "optparse.OptionError.__name__ == 'OptionError'"
  category: class_names
  kind: python_call_eq
  function: OptionError.__name__.__eq__
  args: ["OptionError"]
  expected: true

invariant optparse_extra.OptionError.base_class:
  description: "optparse.OptionError.__bases__[0].__name__ == 'OptParseError'"
  category: class_hierarchy
  kind: python_call_eq
  function: OptionError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "OptParseError"

# ---------------------------------------------------------------------------
# OptionValueError — name and hierarchy
# ---------------------------------------------------------------------------

invariant optparse_extra.OptionValueError.name:
  description: "optparse.OptionValueError.__name__ == 'OptionValueError'"
  category: class_names
  kind: python_call_eq
  function: OptionValueError.__name__.__eq__
  args: ["OptionValueError"]
  expected: true

invariant optparse_extra.OptionValueError.base_class:
  description: "optparse.OptionValueError.__bases__[0].__name__ == 'OptParseError' — OptionValueError inherits directly from OptParseError"
  category: class_hierarchy
  kind: python_call_eq
  function: OptionValueError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "OptParseError"

