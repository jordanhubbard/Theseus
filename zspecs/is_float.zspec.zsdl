spec: is_float
version: ">=1.0.0"
backend: node(is-float)

docs: https://www.npmjs.com/package/is-float

provenance:
  derived_from:
    - "is-float README — https://www.npmjs.com/package/is-float"
    - "Test vectors verified with is-float via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-float source"
  notes:
    - "is-float is an npm package. Install: npm install is-float"
    - "Returns true if the number has a non-zero fractional component."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_float.check:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: isfloat

  columns: [id, args, expected]
  rows:
    - [float,    [1.5],  true]
    - [integer,  [1],    false]
    - [float2,   [3.14], true]
