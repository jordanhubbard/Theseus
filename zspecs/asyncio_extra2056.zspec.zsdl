    - ["as2056009", "asyncio.Event.__dict__.__contains__", ["__delitem__"], false]
    - ["as2056010", "asyncio.Lock.__dict__.__contains__", ["__getitem__"], false]
    - ["as2056011", "asyncio.Lock.__dict__.__contains__", ["__setitem__"], false]
    - ["as2056012", "asyncio.Lock.__dict__.__contains__", ["__delitem__"], false]
    - ["as2056013", "asyncio.Queue.__dict__.__contains__", ["__getitem__"], false]
    - ["as2056014", "asyncio.Queue.__dict__.__contains__", ["__setitem__"], false]
    - ["as2056015", "asyncio.Queue.__dict__.__contains__", ["__delitem__"], false]
    - ["as2056016", "asyncio.Semaphore.__dict__.__contains__", ["__getitem__"], false]
