spec: asyncio_extra2056
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/asyncio.html"
    - "https://docs.python.org/3/library/asyncio-task.html"
    - "https://docs.python.org/3/library/asyncio-sync.html"
    - "https://docs.python.org/3/library/asyncio-queue.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 584 (_extra2056): __getitem__/__setitem__/__delitem__, __len__, __getattr__/__setattr__/__delattr__ dict-presence checks."
    - "asyncio types (Task, Future, Event, Lock, Queue, Semaphore) are concurrency primitives, not sequence/mapping/attribute-override types."
    - "asyncio.Queue defines qsize() but NOT __len__; none of these types define __len__ in their own __dict__."
    - "None of these types define __getitem__, __setitem__, __delitem__, __getattr__, __setattr__, or __delattr__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table asyncio_extra2056.getitem_protocol:
  description: "asyncio types __getitem__/__setitem__/__delitem__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2056

  columns: [id, function, args, expected]
  rows:
    - ["as2056001", "asyncio.Task.__dict__.__contains__", ["__getitem__"], false]
    - ["as2056002", "asyncio.Task.__dict__.__contains__", ["__setitem__"], false]
    - ["as2056003", "asyncio.Task.__dict__.__contains__", ["__delitem__"], false]
