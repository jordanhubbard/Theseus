spec: functools_extra1501
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "Wave 547 theme: __await__, __aiter__, __anext__ async protocol checks and __aenter__/__aexit__ async context manager checks for functools classes."
    - "functools.partial: no async protocol methods in __dict__. Verified with Python 3.12."
    - "functools.cached_property: no async protocol methods in __dict__. Verified with Python 3.12."
    - "functools.singledispatchmethod: no async protocol methods in __dict__. Verified with Python 3.12."
    - "functools.partialmethod: no async protocol methods in __dict__. Verified with Python 3.12."
    - "None of the functools wrapper/descriptor classes implement any async protocol; they are synchronous callable wrappers and descriptors only."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial — async protocol absence checks
#
# Wave 547 theme: functools.partial — partial application of a callable.
#
# functools.partial.__dict__.__contains__("__await__") == False
# functools.partial.__dict__.__contains__("__aiter__") == False
# functools.partial.__dict__.__contains__("__anext__") == False
# functools.partial.__dict__.__contains__("__aenter__") == False
# functools.partial.__dict__.__contains__("__aexit__") == False
#
# partial is a synchronous callable wrapper. It does not implement any
# async protocol. Positive anchors: __call__ and __get__ are present.
# New to extra1501.
# ---------------------------------------------------------------------------

table functools_extra1501.partial_async_protocol_absence:
  description: "functools.partial has no async protocol methods in __dict__; partial is a synchronous callable wrapper only; wave 547; new to extra1501"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1501pa

  columns: [id, function, args, expected, description]
  rows:
    - [fu1501pa001,
       "partial.__dict__.__contains__",
       ["__await__"],
       false,
       "functools.partial.__dict__.__contains__('__await__') == False — partial is a synchronous callable wrapper that partially applies arguments to another callable; it does not implement the awaitable protocol; __await__ is not defined in partial.__dict__; verified with Python 3.12; new to extra1501"]
    - [fu1501pa002,
       "partial.__dict__.__contains__",
       ["__aiter__"],
       false,
       "functools.partial.__dict__.__contains__('__aiter__') == False — partial does not implement the async iterator protocol; __aiter__ is not in partial.__dict__; verified with Python 3.12; new to extra1501"]
    - [fu1501pa003,
       "partial.__dict__.__contains__",
       ["__anext__"],
       false,
       "functools.partial.__dict__.__contains__('__anext__') == False — partial does not implement the async iterator protocol; __anext__ is not in partial.__dict__; verified with Python 3.12; new to extra1501"]
    - [fu1501pa004,
       "partial.__dict__.__contains__",
       ["__aenter__"],
       false,
       "functools.partial.__dict__.__contains__('__aenter__') == False — partial does not implement the async context manager protocol; __aenter__ is not in partial.__dict__; verified with Python 3.12; new to extra1501"]
    - [fu1501pa005,
       "partial.__dict__.__contains__",
       ["__aexit__"],
       false,
       "functools.partial.__dict__.__contains__('__aexit__') == False — partial does not implement the async context manager protocol; __aexit__ is not in partial.__dict__; verified with Python 3.12; new to extra1501"]
    - [fu1501pa006,
       "partial.__dict__.__contains__",
       ["__call__"],
       true,
       "functools.partial.__dict__.__contains__('__call__') == True — partial IS callable and defines __call__ in its __dict__; this is its primary synchronous interface; verified with Python 3.12; new to extra1501"]
    - [fu1501pa007,
       "partial.__dict__.__contains__",
       ["__get__"],
       true,
       "functools.partial.__dict__.__contains__('__get__') == True — partial defines __get__ making it a non-data descriptor; this allows partial objects to behave as bound methods when used as class attributes; verified with Python 3.12; new to extra1501"]

# ---------------------------------------------------------------------------
# Table 2: functools.cached_property — async protocol absence checks
#
# Wave 547 theme: functools.cached_property — descriptor that caches the
# result of a method as a per-instance attribute.
#
# functools.cached_property.__dict__.__contains__("__await__") == False
# functools.cached_property.__dict__.__contains__("__aiter__") == False
# functools.cached_property.__dict__.__contains__("__anext__") == False
# functools.cached_property.__dict__.__contains__("__aenter__") == False
# functools.cached_property.__dict__.__contains__("__aexit__") == False
#
# cached_property is a synchronous data descriptor. It has __get__ and
# __set_name__ but no async protocol methods. New to extra1501.
# ---------------------------------------------------------------------------

table functools_extra1501.cached_property_async_protocol_absence:
  description: "functools.cached_property has no async protocol methods in __dict__; cached_property is a synchronous descriptor only; wave 547; new to extra1501"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1501cp

  columns: [id, function, args, expected, description]
  rows:
    - [fu1501cp001,
       "cached_property.__dict__.__contains__",
       ["__await__"],
       false,
       "functools.cached_property.__dict__.__contains__('__await__') == False — cached_property is a synchronous descriptor that caches computed property values in the instance __dict__; it does not implement the awaitable protocol; __await__ is not in cached_property.__dict__; verified with Python 3.12; new to extra1501"]
    - [fu1501cp002,
       "cached_property.__dict__.__contains__",
       ["__aiter__"],
       false,
       "functools.cached_property.__dict__.__contains__('__aiter__') == False — cached_property does not implement the async iterator protocol; __aiter__ is not in cached_property.__dict__; verified with Python 3.12; new to extra1501"]
    - [fu1501cp003,
       "cached_property.__dict__.__contains__",
       ["__anext__"],
       false,
       "functools.cached_property.__dict__.__contains__('__anext__') == False — cached_property does not implement the async iterator protocol; __anext__ is not in cached_property.__dict__; verified with Python 3.12; new to extra1501"]
    - [fu1501cp004,
       "cached_property.__dict__.__contains__",
       ["__aenter__"],
       false,
       "functools.cached_property.__dict__.__contains__('__aenter__') == False — cached_property does not implement the async context manager protocol; __aenter__ is not in cached_property.__dict__; verified with Python 3.12; new to extra1501"]
    - [fu1501cp005,
       "cached_property.__dict__.__contains__",
       ["__aexit__"],
       false,
       "functools.cached_property.__dict__.__contains__('__aexit__') == False — cached_property does not implement the async context manager protocol; __aexit__ is not in cached_property.__dict__; verified with Python 3.12; new to extra1501"]
    - [fu1501cp006,
       "cached_property.__dict__.__contains__",
       ["__get__"],
       true,
       "functools.cached_property.__dict__.__contains__('__get__') == True — cached_property IS a descriptor and defines __get__ in its __dict__; this is its primary synchronous interface, distinct from any async protocol; verified with Python 3.12; new to extra1501"]
    - [fu1501cp007,
       "cached_property.__dict__.__contains__",
       ["__set_name__"],
       true,
       "functools.cached_property.__dict__.__contains__('__set_name__') == True — cached_property defines __set_name__ to record the attribute name at class creation time; __set_name__ IS in cached_property.__dict__; verified with Python 3.12; new to extra1501"]

# ---------------------------------------------------------------------------
# Table 3: functools.singledispatchmethod and partialmethod — async protocol
# absence checks
#
# Wave 547 theme: descriptor-based decorator classes.
#
# functools.singledispatchmethod.__dict__.__contains__("__await__") == False
# functools.singledispatchmethod.__dict__.__contains__("__aiter__") == False
# functools.partialmethod.__dict__.__contains__("__aenter__") == False
# functools.partialmethod.__dict__.__contains__("__aexit__") == False
#
# Both are synchronous descriptor decorators. Neither implements any async
# protocol. Positive anchor: __get__ is present in both. New to extra1501.
# ---------------------------------------------------------------------------

table functools_extra1501.singledispatchmethod_partialmethod_async_protocol_absence:
  description: "functools.singledispatchmethod and partialmethod have no async protocol methods in __dict__; both are synchronous descriptor decorators; wave 547; new to extra1501"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1501sd

  columns: [id, function, args, expected, description]
  rows:
    - [fu1501sd001,
       "singledispatchmethod.__dict__.__contains__",
       ["__await__"],
       false,
       "functools.singledispatchmethod.__dict__.__contains__('__await__') == False — singledispatchmethod is a descriptor for single-dispatch generic methods; it dispatches based on the type of the first non-self argument but does not implement the awaitable protocol; __await__ is not in singledispatchmethod.__dict__; verified with Python 3.12; new to extra1501"]
    - [fu1501sd002,
       "singledispatchmethod.__dict__.__contains__",
       ["__aiter__"],
       false,
       "functools.singledispatchmethod.__dict__.__contains__('__aiter__') == False — singledispatchmethod does not implement the async iterator protocol; __aiter__ is not in singledispatchmethod.__dict__; verified with Python 3.12; new to extra1501"]
    - [fu1501sd003,
       "singledispatchmethod.__dict__.__contains__",
       ["__anext__"],
       false,
       "functools.singledispatchmethod.__dict__.__contains__('__anext__') == False — singledispatchmethod does not implement the async iterator protocol; __anext__ is not in singledispatchmethod.__dict__; verified with Python 3.12; new to extra1501"]
    - [fu1501sd004,
       "partialmethod.__dict__.__contains__",
       ["__aenter__"],
       false,
       "functools.partialmethod.__dict__.__contains__('__aenter__') == False — partialmethod is a descriptor that creates partial methods for use inside class bodies; it does not implement the async context manager protocol; __aenter__ is not in partialmethod.__dict__; verified with Python 3.12; new to extra1501"]
    - [fu1501sd005,
       "partialmethod.__dict__.__contains__",
       ["__aexit__"],
       false,
       "functools.partialmethod.__dict__.__contains__('__aexit__') == False — partialmethod cannot be used as an async context manager; __aexit__ is not defined in partialmethod.__dict__; verified with Python 3.12; new to extra1501"]
    - [fu1501sd006,
       "singledispatchmethod.__dict__.__contains__",
       ["__get__"],
       true,
       "functools.singledispatchmethod.__dict__.__contains__('__get__') == True — singledispatchmethod IS a descriptor and defines __get__ in its __dict__; the descriptor protocol is its primary interface, not any async protocol; verified with Python 3.12; new to extra1501"]
    - [fu1501sd007,
       "partialmethod.__dict__.__contains__",
       ["__get__"],
       true,
       "functools.partialmethod.__dict__.__contains__('__get__') == True — partialmethod IS a descriptor and defines __get__ in its __dict__; descriptor protocol is its primary interface, not any async protocol; verified with Python 3.12; new to extra1501"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1501
# ---------------------------------------------------------------------------

invariant functools_extra1501.partial_no_await:
  description: "functools.partial.__dict__ does not contain '__await__' — partial is a synchronous callable wrapper, not an awaitable; wave 547; new to extra1501"
  kind: python_call_eq
  function: partial.__dict__.__contains__
  args: ["__await__"]
  expected: false

invariant functools_extra1501.partial_no_aiter:
  description: "functools.partial.__dict__ does not contain '__aiter__' — partial does not implement the async iterator protocol; wave 547; new to extra1501"
  kind: python_call_eq
  function: partial.__dict__.__contains__
  args: ["__aiter__"]
  expected: false

invariant functools_extra1501.partial_no_aenter:
  description: "functools.partial.__dict__ does not contain '__aenter__' — partial does not implement the async context manager protocol; wave 547; new to extra1501"
  kind: python_call_eq
  function: partial.__dict__.__contains__
  args: ["__aenter__"]
  expected: false

invariant functools_extra1501.cached_property_no_await:
  description: "functools.cached_property.__dict__ does not contain '__await__' — cached_property is a synchronous descriptor, not an awaitable; wave 547; new to extra1501"
  kind: python_call_eq
  function: cached_property.__dict__.__contains__
  args: ["__await__"]
  expected: false

invariant functools_extra1501.cached_property_no_aenter:
  description: "functools.cached_property.__dict__ does not contain '__aenter__' — cached_property does not implement the async context manager protocol; wave 547; new to extra1501"
  kind: python_call_eq
  function: cached_property.__dict__.__contains__
  args: ["__aenter__"]
  expected: false

invariant functools_extra1501.singledispatchmethod_no_await:
  description: "functools.singledispatchmethod.__dict__ does not contain '__await__' — singledispatchmethod is a synchronous dispatch descriptor, not an awaitable; wave 547; new to extra1501"
  kind: python_call_eq
  function: singledispatchmethod.__dict__.__contains__
  args: ["__await__"]
  expected: false

invariant functools_extra1501.partialmethod_no_aenter:
  description: "functools.partialmethod.__dict__ does not contain '__aenter__' — partialmethod is a synchronous method-wrapping descriptor, not an async context manager; wave 547; new to extra1501"
  kind: python_call_eq
  function: partialmethod.__dict__.__contains__
  args: ["__aenter__"]
  expected: false
