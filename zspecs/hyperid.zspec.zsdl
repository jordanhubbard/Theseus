spec: hyperid
version: ">=4.0.0"
backend: node(hyperid)

docs: https://github.com/mcollina/hyperid#readme

provenance:
  derived_from:
    - "hyperid README — https://github.com/mcollina/hyperid#readme"
    - "Test vectors verified with hyperid via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "hyperid source"
  notes:
    - "Very fast unique-ID generator — 22-char base64 prefix + slash + numeric counter."
    - "Install: npm install hyperid"
    - "v4 CJS; require('hyperid') is itself the factory; calling it returns a generator function."
    - "Options: {fixedLength, urlSafe} — fixedLength pads counter to 10 digits (33 char total); urlSafe replaces + with _ and / with -."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "N/A — each generator independent."
  codes: {}

invariant hyperid.factory_arity:
  description: "hyperid factory takes one (optional) options arg"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 1

invariant hyperid.generator_is_function:
  description: "hyperid() returns a function (the id generator)"
  category: shape
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant hyperid.fixed_length_is_33:
  description: "Generator with {fixedLength:true} returns 33-char IDs"
  category: format
  kind: node_chain_eq
  entry: module
  entry_args: [{fixedLength: true}]
  chain:
    - {call: []}
    - {get: length}
  expected: 33

invariant hyperid.fixed_length_separator_char:
  description: "Fixed-length ID has '/' at index 22 (uuid-like prefix + slash + counter)"
  category: format
  kind: node_chain_eq
  entry: module
  entry_args: [{fixedLength: true}]
  chain:
    - {call: []}
    - {method: charAt, args: [22]}
  expected: "/"

invariant hyperid.url_safe_no_slash:
  description: "{urlSafe:true} IDs contain no '/' character"
  category: format
  kind: node_chain_eq
  entry: module
  entry_args: [{fixedLength: true, urlSafe: true}]
  chain:
    - {call: []}
    - {method: indexOf, args: ["/"]}
  expected: -1

invariant hyperid.url_safe_uses_dash:
  description: "{urlSafe:true, fixedLength:true} IDs use '-' as separator at index 22"
  category: format
  kind: node_chain_eq
  entry: module
  entry_args: [{fixedLength: true, urlSafe: true}]
  chain:
    - {call: []}
    - {method: charAt, args: [22]}
  expected: "-"

invariant hyperid.id_is_string:
  description: "Generated IDs are strings (constructor.name === 'String')"
  category: shape
  kind: node_chain_eq
  entry: module
  entry_args: [{fixedLength: true}]
  chain:
    - {call: []}
    - {get: "constructor.name"}
  expected: "String"
