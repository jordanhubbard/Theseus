spec: abc_extra239
version: ">=3.4"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers abc.ABC __module__ and abc.ABCMeta MRO analysis."
    - "abc.ABC.__module__ == 'abc' (ABC is defined in Lib/abc.py)."
    - "abc.ABC.__qualname__ == 'ABC' (module-level class, qualname equals name)."
    - "abc.ABC.__module__.__eq__('abc') returns True."
    - "abc.ABC.__qualname__.__eq__('ABC') returns True."
    - "abc.ABCMeta.__mro__.__len__() == 3 (MRO is [ABCMeta, type, object])."
    - "abc.ABCMeta.__mro__.__getitem__(0).__name__ == 'ABCMeta'."
    - "abc.ABCMeta.__mro__.__getitem__(1).__name__ == 'type'."
    - "abc.ABCMeta.__mro__.__getitem__(2).__name__ == 'object'."
    - "abc.ABCMeta.__module__ == 'abc' (ABCMeta is also defined in Lib/abc.py)."
    - "abc.ABCMeta.__name__.__len__() == 7; abc.ABC.__name__.__len__() == 3."
    - "abc.ABCMeta.__class__.__name__ == 'type' (ABCMeta's metaclass is type)."
    - "abc.ABC.__class__.__name__ == 'ABCMeta' (ABC's metaclass is ABCMeta)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABC module and qualname checks
#
# abc.ABC.__module__.__eq__('abc') == True
# abc.ABC.__qualname__.__eq__('ABC') == True
# abc.ABC.__name__.__len__() == 3
# abc.ABC.__module__.__len__() == 3
# abc.ABC.__class__.__name__ == 'ABCMeta'
# ---------------------------------------------------------------------------

table abc_extra239.abc_ABC_identity:
  description: "abc.ABC module and qualname identity checks — ABC.__module__.__eq__('abc')==True (ABC is defined in Lib/abc.py, module='abc'); ABC.__qualname__.__eq__('ABC')==True (module-level class so qualname equals name 'ABC'); ABC.__module__.__len__()==3 ('abc' is 3 chars); ABC.__name__.__len__()==3 ('ABC' is 3 chars, both module and name have same length 3); ABC.__class__.__name__.__eq__('ABCMeta')==True (ABC is an instance of ABCMeta since ABCMeta is the metaclass used to create ABC); ABC.__qualname__.__len__()==3; verified with Python 3.14.3"
  kind: python_call_eq
  category: abc_ABC_identity
  id_prefix: abc239mro

  columns: [id, function, args, expected, description]
  rows:
    - [abc_mod_eq,   ABC.__module__.__eq__,           ["abc"],     true, "abc.ABC.__module__ == 'abc'; verified with Python 3.14.3"]
    - [abc_mod_len,  ABC.__module__.__len__,           [],          3,    "abc.ABC.__module__.__len__() == 3 ('abc' is 3 chars); verified with Python 3.14.3"]
    - [abc_qn_eq,    ABC.__qualname__.__eq__,          ["ABC"],     true, "abc.ABC.__qualname__ == 'ABC' (module-level class, qualname equals name); verified with Python 3.14.3"]
    - [abc_qn_len,   ABC.__qualname__.__len__,         [],          3,    "abc.ABC.__qualname__.__len__() == 3; verified with Python 3.14.3"]
    - [abc_cls_nm,   ABC.__class__.__name__.__eq__,    ["ABCMeta"], true, "abc.ABC.__class__.__name__ == 'ABCMeta' (ABC's metaclass is ABCMeta); verified with Python 3.14.3"]
    - [abc_nm_len,   ABC.__name__.__len__,             [],          3,    "abc.ABC.__name__.__len__() == 3 ('ABC' is 3 chars); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta MRO analysis
#
# abc.ABCMeta.__mro__.__len__() == 3
# abc.ABCMeta.__mro__.__getitem__(0).__name__.__eq__('ABCMeta') == True
# abc.ABCMeta.__mro__.__getitem__(1).__name__.__eq__('type') == True
# abc.ABCMeta.__mro__.__getitem__(2).__name__.__eq__('object') == True
# abc.ABCMeta.__module__ == 'abc'
# abc.ABCMeta.__class__.__name__ == 'type'
# abc.ABCMeta.__name__.__len__() == 7
# ---------------------------------------------------------------------------

table abc_extra239.abcmeta_mro_analysis:
  description: "abc.ABCMeta MRO analysis checks — ABCMeta.__mro__.__len__()==3 (MRO is [ABCMeta, type, object], a 3-element chain: ABCMeta inherits from type which inherits from object); ABCMeta.__mro__.__getitem__(0).__name__.__eq__('ABCMeta')==True (first MRO element is ABCMeta itself); ABCMeta.__mro__.__getitem__(1).__name__.__eq__('type')==True (second MRO element is type, the built-in metaclass); ABCMeta.__mro__.__getitem__(2).__name__.__eq__('object')==True (third and final MRO element is object); ABCMeta.__module__.__eq__('abc')==True (ABCMeta is defined in Lib/abc.py); ABCMeta.__class__.__name__.__eq__('type')==True (ABCMeta's own metaclass is type); ABCMeta.__name__.__len__()==7 ('ABCMeta' is 7 chars); verified with Python 3.14.3"
  kind: python_call_eq
  category: abcmeta_mro_analysis
  id_prefix: abc239mrob

  columns: [id, function, args, expected, description]
  rows:
    - [meta_mro_len,   ABCMeta.__mro__.__len__,                                       [],          3,    "abc.ABCMeta.__mro__.__len__() == 3 ([ABCMeta, type, object]); verified with Python 3.14.3"]
    - [meta_mro_0,     "ABCMeta.__mro__.__getitem__(0).__name__.__eq__",               ["ABCMeta"], true, "abc.ABCMeta.__mro__.__getitem__(0).__name__ == 'ABCMeta'; verified with Python 3.14.3"]
    - [meta_mro_1,     "ABCMeta.__mro__.__getitem__(1).__name__.__eq__",               ["type"],    true, "abc.ABCMeta.__mro__.__getitem__(1).__name__ == 'type'; verified with Python 3.14.3"]
    - [meta_mro_2,     "ABCMeta.__mro__.__getitem__(2).__name__.__eq__",               ["object"],  true, "abc.ABCMeta.__mro__.__getitem__(2).__name__ == 'object'; verified with Python 3.14.3"]
    - [meta_mod_eq,    ABCMeta.__module__.__eq__,                                      ["abc"],     true, "abc.ABCMeta.__module__ == 'abc'; verified with Python 3.14.3"]
    - [meta_cls_nm,    ABCMeta.__class__.__name__.__eq__,                              ["type"],    true, "abc.ABCMeta.__class__.__name__ == 'type' (ABCMeta's metaclass is type); verified with Python 3.14.3"]
    - [meta_nm_len,    ABCMeta.__name__.__len__,                                       [],          7,    "abc.ABCMeta.__name__.__len__() == 7 ('ABCMeta' is 7 chars); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra239
# ---------------------------------------------------------------------------

invariant abc_extra239.ABC_module_eq_abc:
  description: "abc.ABC.__module__.__eq__('abc') returns True — abc.ABC is defined directly in Lib/abc.py; __module__ is 'abc' (the top-level module name, len=3); both ABC and ABCMeta share the same __module__ ('abc'); ABC.__class__.__name__ is 'ABCMeta' (ABC's metaclass); ABC.__name__.__len__()==3 and ABC.__module__.__len__()==3 (both 3 chars); NEW in extra239: first standalone ABC module invariant in abc239mro namespace; verified with Python 3.14.3"
  category: abc_ABC_identity
  kind: python_call_eq
  function: ABC.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra239.ABC_qualname_eq_ABC:
  description: "abc.ABC.__qualname__.__eq__('ABC') returns True — abc.ABC is a module-level class (not nested in another class or function), so its __qualname__ is simply 'ABC', identical to its __name__; ABC.__qualname__.__len__()==3 (same as __name__.__len__()==3); compare: a nested class would have qualname 'Outer.Inner'; ABC.__module__ is 'abc' (len=3); NEW in extra239: first standalone ABC qualname invariant in abc239mro namespace; verified with Python 3.14.3"
  category: abc_ABC_identity
  kind: python_call_eq
  function: ABC.__qualname__.__eq__
  args: ["ABC"]
  expected: true

invariant abc_extra239.ABCMeta_mro_len_3:
  description: "abc.ABCMeta.__mro__.__len__() == 3 — ABCMeta's MRO is [ABCMeta, type, object]; a 3-element chain: ABCMeta (the metaclass itself) -> type (the built-in metaclass ABCMeta inherits from) -> object (ultimate base); compare: abc.ABC's MRO would be [ABC, object] (length=2) since ABC is a regular class whose metaclass is ABCMeta; ABCMeta.__module__ is 'abc'; ABCMeta.__name__.__len__()==7; NEW in extra239: first standalone ABCMeta MRO length invariant in abc239mro namespace; verified with Python 3.14.3"
  category: abcmeta_mro_analysis
  kind: python_call_eq
  function: ABCMeta.__mro__.__len__
  args: []
  expected: 3

invariant abc_extra239.ABCMeta_mro_item0_is_ABCMeta:
  description: "abc.ABCMeta.__mro__.__getitem__(0).__name__.__eq__('ABCMeta') returns True — the first element of ABCMeta's MRO (index 0) is ABCMeta itself; in Python's MRO, the first element is always the class itself; ABCMeta.__mro__.__getitem__(0).__name__ is 'ABCMeta' (len=7); compare index 1 is 'type' (len=4) and index 2 is 'object' (len=6); the function path contains [0] so it must be double-quoted; NEW in extra239: first standalone ABCMeta MRO item 0 invariant in abc239mro namespace; verified with Python 3.14.3"
  category: abcmeta_mro_analysis
  kind: python_call_eq
  function: "ABCMeta.__mro__.__getitem__(0).__name__.__eq__"
  args: ["ABCMeta"]
  expected: true

invariant abc_extra239.ABCMeta_mro_item1_is_type:
  description: "abc.ABCMeta.__mro__.__getitem__(1).__name__.__eq__('type') returns True — the second element of ABCMeta's MRO (index 1) is type; ABCMeta inherits from type (the built-in metaclass), so type appears at MRO index 1; ABCMeta.__mro__.__getitem__(1).__name__ is 'type' (len=4); this confirms ABCMeta is a subclass of type (all metaclasses must be); ABCMeta.__class__.__name__ is also 'type' (the metaclass of ABCMeta is type); the function path contains [1] so it must be double-quoted; NEW in extra239: first standalone ABCMeta MRO item 1 invariant in abc239mro namespace; verified with Python 3.14.3"
  category: abcmeta_mro_analysis
  kind: python_call_eq
  function: "ABCMeta.__mro__.__getitem__(1).__name__.__eq__"
  args: ["type"]
  expected: true

invariant abc_extra239.ABCMeta_module_eq_abc:
  description: "abc.ABCMeta.__module__.__eq__('abc') returns True — ABCMeta is defined in Lib/abc.py alongside ABC; both ABC and ABCMeta have __module__ == 'abc' (len=3); ABCMeta.__name__ is 'ABCMeta' (len=7); ABCMeta.__qualname__ is 'ABCMeta' (len=7, module-level class so qualname equals name); ABCMeta.__class__.__name__ is 'type'; NEW in extra239: first standalone ABCMeta module invariant in abc239mrob namespace; verified with Python 3.14.3"
  category: abcmeta_mro_analysis
  kind: python_call_eq
  function: ABCMeta.__module__.__eq__
  args: ["abc"]
  expected: true
