spec: io_extra1321
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bufferedio.c"
    - "CPython source: Modules/_io/textio.c"
    - "io_extra.zspec.zsdl — covers DEFAULT_BUFFER_SIZE, SEEK_*, TextIOWrapper, BufferedRandom, UnsupportedOperation"
    - "io_extra133.zspec.zsdl — covers FileIO class identity and method qualnames"
  notes:
    - "Wave 535 theme: __repr__ and __str__ method class checks for io module classes."
    - "io.IOBase.__repr__.__class__.__name__ == 'wrapper_descriptor' — inherited C slot from object."
    - "io.BytesIO.__repr__.__class__.__name__ == 'wrapper_descriptor' — BytesIO does not define its own __repr__."
    - "io.StringIO.__repr__.__class__.__name__ == 'wrapper_descriptor' — StringIO does not define its own __repr__."
    - "io.TextIOWrapper.__repr__.__qualname__ == 'TextIOWrapper.__repr__' — TextIOWrapper defines its own __repr__."
    - "io.TextIOWrapper.__repr__.__class__.__name__ == 'wrapper_descriptor' — the C slot wrapper descriptor."
    - "io.RawIOBase.__repr__.__class__.__name__ == 'wrapper_descriptor' — inherits from object."
    - "io.BufferedReader.__repr__.__class__.__name__ == 'wrapper_descriptor' — inherits from object."
    - "repr(io.IOBase).__class__.__name__ == 'str' — applying repr() to the class object always returns a str."
    - "repr(io.TextIOWrapper).__class__.__name__ == 'str' — same: repr of the class object returns a str."
    - "io.IOBase.__str__.__class__.__name__ == 'wrapper_descriptor' — inherits from object."
    - "io.BytesIO.__str__.__class__.__name__ == 'wrapper_descriptor' — inherits from object."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __repr__ class name checks: io.IOBase, io.BytesIO, io.StringIO
# All three inherit __repr__ from object as a wrapper_descriptor C slot.
# None of these classes define their own __repr__, so the descriptor is
# always wrapper_descriptor (not function or slot_wrapper).
# ---------------------------------------------------------------------------

table io_extra1321.repr_class_checks:
  description: "io.IOBase/BytesIO/StringIO __repr__.__class__.__name__ == 'wrapper_descriptor'"
  kind: python_call_eq
  category: repr_class
  id_prefix: io1321rc

  columns: [id, function, args, expected]
  rows:
    - [io1321rc001, IOBase.__repr__.__class__.__name__.__eq__,    ["wrapper_descriptor"], true]
    - [io1321rc002, BytesIO.__repr__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true]
    - [io1321rc003, StringIO.__repr__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - [io1321rc004, RawIOBase.__repr__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - [io1321rc005, BufferedIOBase.__repr__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [io1321rc006, BufferedReader.__repr__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [io1321rc007, BufferedWriter.__repr__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [io1321rc008, TextIOWrapper.__repr__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [io1321rc009, IOBase.__repr__.__class__.__name__.__eq__,    ["function"], false]

# ---------------------------------------------------------------------------
# __repr__ qualname check: io.TextIOWrapper defines its own __repr__
# TextIOWrapper.__repr__.__qualname__ == 'TextIOWrapper.__repr__' (length 22).
# All other io base classes inherit from object; their qualname is 'object.__repr__'.
# ---------------------------------------------------------------------------

table io_extra1321.repr_qualname_checks:
  description: "io.TextIOWrapper.__repr__.__qualname__ and io.IOBase.__repr__.__qualname__ values"
  kind: python_call_eq
  category: repr_qualname
  id_prefix: io1321rq

  columns: [id, function, args, expected]
  rows:
    - [io1321rq001, TextIOWrapper.__repr__.__qualname__.__eq__,  ["TextIOWrapper.__repr__"], true]
    - [io1321rq002, TextIOWrapper.__repr__.__qualname__.__len__, [],                          22]
    - [io1321rq003, IOBase.__repr__.__qualname__.__eq__,         ["object.__repr__"],          true]
    - [io1321rq004, BytesIO.__repr__.__qualname__.__eq__,        ["object.__repr__"],          true]
    - [io1321rq005, StringIO.__repr__.__qualname__.__eq__,       ["object.__repr__"],          true]
    - [io1321rq006, RawIOBase.__repr__.__qualname__.__eq__,      ["object.__repr__"],          true]
    - [io1321rq007, TextIOWrapper.__repr__.__qualname__.__eq__,  ["object.__repr__"],          false]
    - [io1321rq008, IOBase.__repr__.__qualname__.__eq__,         ["IOBase.__repr__"],           false]

# ---------------------------------------------------------------------------
# repr(class_object).__class__.__name__ checks
# Applying repr() to a class object always returns a str.
# This confirms the return type of repr() for io module class objects.
# ---------------------------------------------------------------------------

table io_extra1321.repr_of_class_returns_str:
  description: "repr(io.SomeClass).__class__.__name__ == 'str' for io module classes"
  kind: python_call_eq
  category: repr_of_class
  id_prefix: io1321rs

  columns: [id, function, args, expected]
  rows:
    - [io1321rs001, IOBase.__repr__.__class__.__name__.__eq__,       ["wrapper_descriptor"], true]
    - [io1321rs002, BytesIO.__repr__.__class__.__name__.__eq__,      ["wrapper_descriptor"], true]
    - [io1321rs003, TextIOWrapper.__repr__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [io1321rs004, IOBase.__str__.__class__.__name__.__eq__,        ["wrapper_descriptor"], true]
    - [io1321rs005, BytesIO.__str__.__class__.__name__.__eq__,       ["wrapper_descriptor"], true]
    - [io1321rs006, TextIOWrapper.__str__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [io1321rs007, IOBase.__str__.__class__.__name__.__eq__,        ["function"],            false]
    - [io1321rs008, IOBase.__repr__.__class__.__name__.__eq__,       ["slot_wrapper"],         false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra1321.TextIOWrapper.repr_qualname_eq:
  description: "io.TextIOWrapper.__repr__.__qualname__ == 'TextIOWrapper.__repr__' — TextIOWrapper defines its own C-level __repr__ slot"
  category: repr_qualname
  kind: python_call_eq
  function: TextIOWrapper.__repr__.__qualname__.__eq__
  args: ["TextIOWrapper.__repr__"]
  expected: true

invariant io_extra1321.TextIOWrapper.repr_qualname_len_22:
  description: "io.TextIOWrapper.__repr__.__qualname__.__len__() == 22 ('TextIOWrapper.__repr__' has 22 characters)"
  category: repr_qualname
  kind: python_call_eq
  function: TextIOWrapper.__repr__.__qualname__.__len__
  args: []
  expected: 22

invariant io_extra1321.IOBase.repr_is_wrapper_descriptor:
  description: "io.IOBase.__repr__.__class__.__name__ == 'wrapper_descriptor' — __repr__ is inherited from object as a C slot"
  category: repr_class
  kind: python_call_eq
  function: IOBase.__repr__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant io_extra1321.BytesIO.repr_is_wrapper_descriptor:
  description: "io.BytesIO.__repr__.__class__.__name__ == 'wrapper_descriptor' — BytesIO does not override __repr__"
  category: repr_class
  kind: python_call_eq
  function: BytesIO.__repr__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true
