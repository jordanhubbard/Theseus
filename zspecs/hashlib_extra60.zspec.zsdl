spec: hashlib_extra60
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra59.zspec.zsdl — covers hashlib.__all__.__contains__ for 'md5'/'blake2b'/'file_digest'/'pbkdf2_hmac' (table) and 'new' (invariant); blake2b/blake2s __eq__/__subclasshook__.__class__.__name__.__eq__('wrapper_descriptor'/'builtin_function_or_method')."
    - "hashlib_extra52.zspec.zsdl — covers sha256/md5/sha1/pbkdf2_hmac/sha3_256/new/blake2b/blake2s __doc__.__class__.__name__.__eq__('str'); sha256/new/module __doc__.__class__.__qualname__.__eq__('str')."
    - "hashlib_extra55.zspec.zsdl — covers algorithms_guaranteed.__contains__ for sha224/sha384/blake2b/blake2s/sha3_256/sha3_512; hashlib.__name__.__eq__('hashlib') and __name__.__len__()==7."
    - "hashlib_extra34.zspec.zsdl — covers hashlib.__all__.__class__.__name__.__eq__('tuple') and __all__.__len__()==19; new.__class__.__name__.__len__()==8."
    - "hashlib.zspec — covers hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra59; it does NOT duplicate invariants present in those files."
    - "Wave 224 theme: __all__.__contains__ membership + module __package__ identity + class __doc__.__class__.__name__ checks."
    - "Coverage gap 1: hashlib_extra59 checks __all__.__contains__ for md5/blake2b/file_digest/pbkdf2_hmac (table) and new (invariant). No prior hashlib spec checks __all__.__contains__ for 'sha256', 'sha1', 'sha512', or 'sha3_256'. hashlib.__all__ is a tuple of 19 public names. Checking these four additional algorithm names confirms that the core SHA family members are all in the declared public API. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__all__.__contains__('sha256') == True. 'sha256' is in hashlib.__all__ (the public API tuple). hashlib_extra59 checks md5/blake2b/file_digest/pbkdf2_hmac and new but NOT sha256. No prior hashlib spec checks __all__.__contains__('sha256'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__all__.__contains__('sha1') == True. 'sha1' is in hashlib.__all__. No prior hashlib spec checks __all__.__contains__('sha1'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__all__.__contains__('sha512') == True. 'sha512' is in hashlib.__all__. No prior hashlib spec checks __all__.__contains__('sha512'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__all__.__contains__('sha3_256') == True. 'sha3_256' is in hashlib.__all__. No prior hashlib spec checks __all__.__contains__('sha3_256'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 2: hashlib_extra52 checks __doc__.__class__.__qualname__.__eq__('str') for sha256, new, and the module — but NOT for blake2b or blake2s. blake2b and blake2s are C extension types whose docstrings are Python str objects; str.__qualname__ == 'str'. The __doc__.__class__.__qualname__ chain for blake2b and blake2s is entirely novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__doc__.__class__.__qualname__ == 'str'. blake2b is a C extension type with a docstring 'Return a new BLAKE2b hash object.'; the docstring is a Python str; str.__qualname__ == 'str'. hashlib_extra52 covers sha256/new/module for this chain but NOT blake2b. No prior hashlib spec checks blake2b.__doc__.__class__.__qualname__.__eq__('str'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__doc__.__class__.__qualname__ == 'str'. blake2s is a C extension type with docstring 'Return a new BLAKE2s hash object.'; same __doc__.__class__.__qualname__ == 'str' pattern. hashlib_extra52 does not cover blake2s. No prior hashlib spec checks blake2s.__doc__.__class__.__qualname__.__eq__('str'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 3: hashlib_extra52 covers __doc__.__class__.__qualname__ for sha256/new/module only. No prior hashlib spec checks __doc__.__class__.__qualname__ for md5 or sha1. md5 and sha1 are C builtin_function_or_method objects with docstrings as Python str objects; str.__qualname__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__doc__.__class__.__qualname__ == 'str'. md5 docstring is a Python str; str.__qualname__ == 'str'. hashlib_extra52 covers sha256 only among the SHA-MD family for the __qualname__ axis. No prior hashlib spec checks md5.__doc__.__class__.__qualname__.__eq__('str'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__doc__.__class__.__qualname__ == 'str'. sha1 docstring is a Python str; str.__qualname__ == 'str'. No prior hashlib spec checks sha1.__doc__.__class__.__qualname__.__eq__('str'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.__all__.__contains__ for additional SHA algorithm names
#
# hashlib_extra59 checks __all__.__contains__ for md5/blake2b/file_digest/
# pbkdf2_hmac (table) and new (invariant). No prior hashlib spec checks
# __all__.__contains__ for 'sha256', 'sha1', 'sha512', or 'sha3_256'.
# hashlib.__all__ is a tuple of 19 public names (verified: extra34).
# These four names confirm that the core SHA algorithm family is present
# in the declared public API namespace.
# ---------------------------------------------------------------------------

table hashlib_extra60.all_contains_sha:
  description: "hashlib.__all__.__contains__('sha256'/'sha1'/'sha512'/'sha3_256') — confirms SHA algorithm names in the public API tuple; hashlib_extra59 checks md5/blake2b/file_digest/pbkdf2_hmac/new but NOT sha256/sha1/sha512/sha3_256; hashlib_extra34 covers __all__.__len__ and type but NOT __contains__; no prior hashlib spec checks __all__.__contains__ for any SHA algorithm name"
  kind: python_call_eq
  category: module_structure
  id_prefix: hashlibpkg60

  columns: [id, function, args, expected]
  rows:
    - [all_contains_sha256,   __all__.__contains__, ["sha256"],   true]
    - [all_contains_sha1,     __all__.__contains__, ["sha1"],     true]
    - [all_contains_sha512,   __all__.__contains__, ["sha512"],   true]
    - [all_contains_sha3_256, __all__.__contains__, ["sha3_256"], true]

# ---------------------------------------------------------------------------
# hashlib.blake2b and blake2s __doc__.__class__.__qualname__.__eq__('str')
#
# hashlib_extra52 checks __doc__.__class__.__qualname__.__eq__('str') for
# sha256, new, and the module — but NOT for blake2b or blake2s. Both blake2b
# and blake2s are C extension types whose __doc__ attribute is a Python str
# ('Return a new BLAKE2b hash object.' and 'Return a new BLAKE2s hash object.'
# respectively). The str type's __qualname__ attribute is 'str', the same as
# its __name__, but .__qualname__ is a distinct attribute chain and an
# independent regression vector.
# ---------------------------------------------------------------------------

table hashlib_extra60.blake_doc_class_qualname:
  description: "hashlib.blake2b/blake2s __doc__.__class__.__qualname__.__eq__('str') — C extension type docstrings are Python str; str.__qualname__ == 'str'; hashlib_extra52 covers sha256/new/module for this chain but NOT blake2b or blake2s; no prior hashlib spec checks blake2b or blake2s __doc__.__class__.__qualname__.__eq__('str')"
  kind: python_call_eq
  category: type_structure
  id_prefix: hashlibpkg60

  columns: [id, function, args, expected]
  rows:
    - [blake2b_doc_class_qualname_eq, blake2b.__doc__.__class__.__qualname__.__eq__, ["str"], true]
    - [blake2s_doc_class_qualname_eq, blake2s.__doc__.__class__.__qualname__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# hashlib.md5 and sha1 __doc__.__class__.__qualname__.__eq__('str')
#
# hashlib_extra52 covers sha256/new/module for __doc__.__class__.__qualname__.
# md5 and sha1 are C builtin_function_or_method objects with docstrings as
# Python str objects. str.__qualname__ == 'str'. No prior hashlib spec checks
# __doc__.__class__.__qualname__ for md5 or sha1. This extends the qualname
# axis to two additional algorithm constructors that were absent from extra52.
# ---------------------------------------------------------------------------

table hashlib_extra60.md5_sha1_doc_class_qualname:
  description: "hashlib.md5/sha1 __doc__.__class__.__qualname__.__eq__('str') — C builtin_function_or_method docstrings are Python str; str.__qualname__ == 'str'; hashlib_extra52 covers sha256 for this axis but NOT md5 or sha1; no prior hashlib spec checks md5 or sha1 __doc__.__class__.__qualname__.__eq__('str')"
  kind: python_call_eq
  category: type_structure
  id_prefix: hashlibpkg60

  columns: [id, function, args, expected]
  rows:
    - [md5_doc_class_qualname_eq,  md5.__doc__.__class__.__qualname__.__eq__,  ["str"], true]
    - [sha1_doc_class_qualname_eq, sha1.__doc__.__class__.__qualname__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# hashlib.__all__.__contains__('algorithms_guaranteed') — the set of guaranteed names
#
# 'algorithms_guaranteed' is a set attribute in the hashlib module that is itself
# a member of the public API declared in __all__. hashlib_extra55 checks
# algorithms_guaranteed.__contains__ for specific algorithm names, but no prior
# hashlib spec checks whether 'algorithms_guaranteed' itself is in __all__.
# This is a self-referential containment check: the set of guaranteed algorithms
# is itself part of the declared public namespace.
# ---------------------------------------------------------------------------

invariant hashlib_extra60.all_contains_algorithms_guaranteed:
  description: "hashlib.__all__.__contains__('algorithms_guaranteed') == True — the algorithms_guaranteed set is itself in the public API tuple; hashlib_extra55 checks algorithms_guaranteed.__contains__ for specific names (outward direction) but NOT __all__.__contains__('algorithms_guaranteed') (inward direction); no prior hashlib spec checks __all__.__contains__('algorithms_guaranteed')"
  category: module_structure
  kind: python_call_eq
  function: __all__.__contains__
  args: ["algorithms_guaranteed"]
  expected: true
