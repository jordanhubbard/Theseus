spec: profile_extra6
version: ">=3.3"
backend: python_module(profile)

docs: https://docs.python.org/3/library/profile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/profile.html — Python profile documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/profile.py"
  notes:
    - "This spec extends profile.zspec.zsdl through profile_extra5.zspec.zsdl."
    - "profile.zspec.zsdl covers: Profile/__name__/__module__/__bases__[0]/__name__, Profile methods __name__ (run/runcall/runctx/print_stats/dump_stats), Profile instantiation, profile.__name__."
    - "profile_extra covers: Profile/__name__/__module__, run/__name__, runctx/__name__."
    - "profile_extra2 covers: pstats backend; SortKey values, Stats.dump_stats/__name__, Stats.add/__name__."
    - "profile_extra3 covers: Profile/__qualname__, run/__module__, runctx/__module__, run/__name__/runctx/__name__ table, Profile/__qualname__/__class__/__name__."
    - "profile_extra4 covers: Profile method __qualname__ and __module__ (run/runcall/runctx/print_stats/dump_stats), Profile/__bases__.__len__, Profile method type checks, run/__qualname__, runctx/__qualname__."
    - "profile_extra5 covers: Profile.calibrate/__name__/__qualname__/__class__.__name__, Profile.simulate_call/__name__/__qualname__/__class__.__name__, Profile.__bases__[0].__qualname__, Profile.__dict__ membership (run/runcall/calibrate/simulate_call)."
    - "NEW in this spec: profile.Profile.__name__=='Profile' and profile.Profile.__module__=='profile' via __eq__ predicate; profile.run.__name__=='run' and profile.runctx.__name__=='runctx' via __eq__ predicate; profile.Profile.__bases__[0].__name__=='object' via __eq__ predicate; profile.Profile.__bases__.__len__()==1; profile.Profile.__dict__.__class__.__name__=='mappingproxy'; profile.Profile.__dict__ membership for runctx/print_stats/dump_stats/runcall; run/__class__.__name__ and runctx/__class__.__name__."
    - "profile.Profile.__name__ == 'Profile' — verified runtime."
    - "profile.Profile.__module__ == 'profile' — verified runtime."
    - "profile.run.__name__ == 'run' — verified runtime."
    - "profile.runctx.__name__ == 'runctx' — verified runtime."
    - "profile.Profile.__bases__[0].__name__ == 'object' — single direct base is object (verified runtime)."
    - "profile.Profile.__bases__.__len__() == 1 — exactly one direct base class (verified runtime)."
    - "profile.Profile.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy (verified runtime)."
    - "profile.run.__class__.__name__ == 'function' — run is a plain Python function (verified runtime)."
    - "profile.runctx.__class__.__name__ == 'function' — runctx is a plain Python function (verified runtime)."
    - "profile.Profile.__dict__ contains runctx, print_stats, dump_stats, runcall — membership not previously covered for these keys (profile_extra5 only covers run/runcall/calibrate/simulate_call)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# profile.Profile identity — __eq__ predicate form
# profile.zspec.zsdl checks Profile/__name__ and /__module__ as direct string
# expected values.  These invariants use the __eq__ predicate (expected: true),
# which is a structurally distinct form not covered by any prior profile spec.
# ---------------------------------------------------------------------------

invariant profile_extra6.Profile.name_eq:
  description: "profile.Profile.__name__.__eq__('Profile') == True"
  category: classes
  kind: python_call_eq
  function: Profile.__name__.__eq__
  args: ["Profile"]
  expected: true

invariant profile_extra6.Profile.module_eq:
  description: "profile.Profile.__module__.__eq__('profile') == True"
  category: classes
  kind: python_call_eq
  function: Profile.__module__.__eq__
  args: ["profile"]
  expected: true

# ---------------------------------------------------------------------------
# profile.Profile base class — __eq__ predicate form and __len__
# profile.zspec.zsdl checks __bases__[0].__name__ as a direct string value.
# profile_extra4 checks __bases__.__len__ as a standalone invariant.
# The __eq__ predicate form for __bases__[0].__name__ is new here.
# ---------------------------------------------------------------------------

invariant profile_extra6.Profile.base0_name_eq:
  description: "profile.Profile.__bases__[0].__name__.__eq__('object') == True — Profile inherits directly from object"
  category: hierarchy
  kind: python_call_eq
  function: Profile.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

invariant profile_extra6.Profile.bases_len:
  description: "len(profile.Profile.__bases__) == 1 — Profile has exactly one direct base class"
  category: hierarchy
  kind: python_call_eq
  function: Profile.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# profile module-level function names — __eq__ predicate form
# profile_extra checks run/__name__ and runctx/__name__ as direct string values.
# The __eq__ predicate form (expected: true) is new for both.
# ---------------------------------------------------------------------------

invariant profile_extra6.run.name_eq:
  description: "profile.run.__name__.__eq__('run') == True"
  category: functions
  kind: python_call_eq
  function: run.__name__.__eq__
  args: ["run"]
  expected: true

invariant profile_extra6.runctx.name_eq:
  description: "profile.runctx.__name__.__eq__('runctx') == True"
  category: functions
  kind: python_call_eq
  function: runctx.__name__.__eq__
  args: ["runctx"]
  expected: true

# ---------------------------------------------------------------------------
# run and runctx __class__.__name__ — type verification
# profile_extra4 checks Profile method __class__.__name__ for instance methods.
# run and runctx are module-level functions; their __class__.__name__ is new.
# ---------------------------------------------------------------------------

invariant profile_extra6.run.class_name:
  description: "profile.run.__class__.__name__ == 'function' — run is a plain Python function"
  category: function_types
  kind: python_call_eq
  function: run.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant profile_extra6.runctx.class_name:
  description: "profile.runctx.__class__.__name__ == 'function' — runctx is a plain Python function"
  category: function_types
  kind: python_call_eq
  function: runctx.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# Profile.__dict__.__class__.__name__ — mappingproxy type check
# profile_extra5 checks Profile.__dict__ membership for run/runcall/calibrate/simulate_call.
# No prior profile spec checks the type of __dict__ itself.
# ---------------------------------------------------------------------------

invariant profile_extra6.Profile.dict_type:
  description: "profile.Profile.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is a read-only mappingproxy"
  category: dict_membership
  kind: python_call_eq
  function: Profile.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# Profile.__dict__ membership — additional method keys
# profile_extra5 covers run/runcall/calibrate/simulate_call.
# runctx/print_stats/dump_stats membership is not covered in any prior spec.
# ---------------------------------------------------------------------------

table profile_extra6.Profile_dict_additional:
  description: "profile.Profile.__dict__ contains runctx, print_stats, dump_stats — not covered by profile_extra5"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pdict

  columns: [id, function, args, expected]
  rows:
    - [runctx,      Profile.__dict__.__contains__, ["runctx"],      true]
    - [print_stats, Profile.__dict__.__contains__, ["print_stats"], true]
    - [dump_stats,  Profile.__dict__.__contains__, ["dump_stats"],  true]
