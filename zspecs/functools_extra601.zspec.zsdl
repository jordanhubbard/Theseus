spec: functools_extra601
version: ">=3.9"
backend: python_module(functools)
docs: "Identity checks for functools.lru_cache, singledispatch, wraps, total_ordering, and cached_property"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module reference"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __qualname__, __module__, and __doc__ class identity for key functools objects"
  created_at: "2026-04-12T00:00:00Z"

table functools_extra601.ft601lc:
  id_prefix: ft601lc

  columns: [id, function, args, expected]
  rows:
