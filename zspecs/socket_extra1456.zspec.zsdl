spec: socket_extra1456
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "_socket_extra.zspec.zsdl — covers _socket C extension type and method presence checks"
    - "_socket.zspec.zsdl — covers low-level _socket constants and type names"
  notes:
    - "Wave 544 theme: __contains__ and __iter__ method presence and type checks."
    - "socket.socket is the high-level Python socket class; it wraps _socket.socket (C-level)."
    - "socket.error is an alias for OSError; socket.timeout is a subclass of socket.error."
    - "socket.herror and socket.gaierror are also socket.error subclasses for host/address errors."
    - "socket.socket.__dict__ does not contain '__iter__' or '__contains__' — sockets are not containers."
    - "socket.error.__dict__ does not contain '__iter__' or '__contains__' — OSError is not a container."
    - "socket.timeout.__dict__ does not contain '__iter__' or '__contains__' — timeout is not a container."
    - "socket.herror.__dict__ does not contain '__iter__' or '__contains__' — herror is not a container."
    - "socket.gaierror.__dict__ does not contain '__iter__' or '__contains__' — gaierror is not a container."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket — __contains__ and __iter__ absence checks
#
# socket.socket is a bidirectional communication endpoint. It provides methods
# like send(), recv(), connect(), bind(), accept() — but it is not a sequence
# or mapping. Neither __iter__ nor __contains__ is defined in socket.socket.__dict__
# or anywhere in its MRO (socket.socket > _socket.socket > object).
# ---------------------------------------------------------------------------

table socket_extra1456.socket_contains_iter:
  description: "socket.socket has no __contains__ or __iter__ — socket.socket is a communication endpoint, not a container; neither method in socket.__dict__; wave 544 __contains__/__iter__ absence theme; sk1456ci anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sk1456ci

  columns: [id, function, args, expected, description]
  rows:
    - [sk1456ci001, "socket.socket.__dict__.__contains__", ["__contains__"], false, "socket.socket.__dict__ does not contain '__contains__' — socket is not a membership-test container"]
    - [sk1456ci002, "socket.socket.__dict__.__contains__", ["__iter__"],     false, "socket.socket.__dict__ does not contain '__iter__' — socket objects are not iterable"]
    - [sk1456ci003, "socket.socket.__dict__.__contains__", ["send"],         true,  "socket.socket.__dict__ contains 'send' — confirms __dict__ lookup works correctly on socket.socket"]
    - [sk1456ci004, "socket.socket.__dict__.__contains__", ["recv"],         true,  "socket.socket.__dict__ contains 'recv' — confirms __dict__ lookup works correctly on socket.socket"]
    - [sk1456ci005, "socket.socket.__dict__.__contains__", ["connect"],      true,  "socket.socket.__dict__ contains 'connect' — confirms __dict__ lookup works correctly on socket.socket"]
    - [sk1456ci006, "socket.socket.__dict__.__contains__", ["close"],        true,  "socket.socket.__dict__ contains 'close' — confirms __dict__ lookup works correctly on socket.socket"]

# ---------------------------------------------------------------------------
# socket.error and socket.timeout — __contains__ and __iter__ absence checks
#
# socket.error is an alias for OSError; socket.timeout is TimeoutError (a
# subclass of OSError). Neither is a container. Their exception nature means
# no container protocol methods appear in their own __dict__.
# ---------------------------------------------------------------------------

table socket_extra1456.error_timeout_contains_iter:
  description: "socket.error and socket.timeout have no __contains__ or __iter__ — both are OSError subclasses, not containers; neither method in their __dict__; wave 544 theme; sk1456et anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sk1456et

  columns: [id, function, args, expected, description]
  rows:
    - [sk1456et001, "socket.error.__dict__.__contains__",   ["__contains__"], false, "socket.error.__dict__ does not contain '__contains__' — socket.error (OSError) is not a container"]
    - [sk1456et002, "socket.error.__dict__.__contains__",   ["__iter__"],     false, "socket.error.__dict__ does not contain '__iter__' — socket.error is not iterable"]
    - [sk1456et003, "socket.timeout.__dict__.__contains__", ["__contains__"], false, "socket.timeout.__dict__ does not contain '__contains__' — socket.timeout is not a container"]
    - [sk1456et004, "socket.timeout.__dict__.__contains__", ["__iter__"],     false, "socket.timeout.__dict__ does not contain '__iter__' — socket.timeout is not iterable"]
    - [sk1456et005, "socket.herror.__dict__.__contains__",  ["__contains__"], false, "socket.herror.__dict__ does not contain '__contains__' — socket.herror is not a container"]
    - [sk1456et006, "socket.gaierror.__dict__.__contains__", ["__contains__"], false, "socket.gaierror.__dict__ does not contain '__contains__' — socket.gaierror is not a container"]

# ---------------------------------------------------------------------------
# socket.socket vs set symmetry — socket lacks container protocol that set has
#
# set defines __iter__ (wrapper_descriptor) and __contains__ (method_descriptor).
# socket.socket has neither. This table anchors the contrast and also verifies
# the socket class identity as a non-container communication primitive.
# ---------------------------------------------------------------------------

table socket_extra1456.socket_vs_set_protocol:
  description: "socket.socket lacks __contains__/__iter__ that set provides — set.__iter__ is 'wrapper_descriptor', set.__contains__ is 'method_descriptor'; socket has neither; contrast confirms socket is not a collection; wave 544 sk1456vs anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sk1456vs

  columns: [id, function, args, expected, description]
  rows:
    - [sk1456vs001, "socket.socket.__dict__.__contains__",    ["__iter__"],           false,              "socket.socket.__dict__ does not contain '__iter__' — contrast with set which defines __iter__"]
    - [sk1456vs002, "socket.socket.__dict__.__contains__",    ["__contains__"],       false,              "socket.socket.__dict__ does not contain '__contains__' — contrast with set which defines __contains__"]
    - [sk1456vs003, "set.__iter__.__class__.__name__.__eq__", ["wrapper_descriptor"], true,               "set.__iter__.__class__.__name__ == 'wrapper_descriptor' — reference value that socket does NOT have"]
    - [sk1456vs004, "set.__contains__.__class__.__name__.__eq__", ["method_descriptor"], true,            "set.__contains__.__class__.__name__ == 'method_descriptor' — reference value that socket does NOT have"]
    - [sk1456vs005, "socket.socket.__name__.__eq__",          ["socket"],             true,               "socket.socket.__name__ == 'socket' — confirms the class is named socket"]
    - [sk1456vs006, "socket.socket.__module__.__eq__",        ["socket"],             true,               "socket.socket.__module__ == 'socket' — confirms socket.socket is defined in the socket module"]
