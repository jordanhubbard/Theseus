spec: hashlib_extra362
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "'shake_128' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'shake_256' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'blake2b' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'blake2s' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: SHAKE-128 and SHAKE-256 are XOF (extendable-output functions) from NIST FIPS 202 (SHA-3 standard). They are guaranteed on all Python platforms."
    - "Note: BLAKE2b and BLAKE2s are BLAKE2 cryptographic hash functions (RFC 7693) added to Python 3.6 hashlib. Both are in algorithms_guaranteed."
    - "Note: algorithms_guaranteed is a set (not frozenset) — its __class__.__name__ is 'set'. This is confirmed by Python 3.14 runtime."
    - "Note: algorithms_available is also a set — __class__.__name__ is 'set'. It is a superset of algorithms_guaranteed on any given platform."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# 'shake_128' in hashlib.algorithms_guaranteed
# 'shake_256' in hashlib.algorithms_guaranteed
# 'blake2b' in hashlib.algorithms_guaranteed
# 'blake2s' in hashlib.algorithms_guaranteed
#
# Wave 362 theme: SHAKE and BLAKE2 algorithm membership in algorithms_guaranteed.
#
# SHAKE-128 and SHAKE-256 are extendable-output functions (XOF) from NIST
# FIPS 202 (the SHA-3 standard). BLAKE2b and BLAKE2s are cryptographic hash
# functions defined in RFC 7693, added to hashlib in Python 3.6. All four
# are in algorithms_guaranteed — the set of hash algorithm names guaranteed
# to be available on every Python platform, regardless of OpenSSL configuration.
# Membership is tested via __contains__ to avoid YAML set syntax.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra362.shake_blake2_in_guaranteed:
  description: "algorithms_guaranteed.__contains__('shake_128')==True / ...('shake_256')==True / ...('blake2b')==True / ...('blake2s')==True — SHAKE-128, SHAKE-256 (NIST FIPS 202 XOFs) and BLAKE2b, BLAKE2s (RFC 7693) are all guaranteed on every Python platform; __contains__ avoids YAML set syntax; first hashlibshakeid362 anchor for SHAKE/BLAKE2 guaranteed membership"
  kind: python_call_eq
  category: algorithm_membership
  id_prefix: hashlibshakeid362

  columns: [id, function, args, expected]
  rows:
    - [shake_128_guaranteed, algorithms_guaranteed.__contains__, ["shake_128"], true]
    - [shake_256_guaranteed, algorithms_guaranteed.__contains__, ["shake_256"], true]
    - [blake2b_guaranteed,   algorithms_guaranteed.__contains__, ["blake2b"],   true]
    - [blake2s_guaranteed,   algorithms_guaranteed.__contains__, ["blake2s"],   true]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__class__.__name__ == 'set'
# hashlib.algorithms_available.__class__.__name__ == 'set'
#
# Wave 362 theme: algorithms_guaranteed and algorithms_available are sets.
#
# Both algorithms_guaranteed and algorithms_available are plain Python sets
# (not frozensets). Their __class__.__name__ is 'set'. This is confirmed
# by Python 3.14 runtime. algorithms_guaranteed is the set of names that
# must be available on all Python implementations; algorithms_available is
# a (typically larger) set that includes platform/OpenSSL-specific algorithms.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra362.algorithm_set_class_names:
  description: "algorithms_guaranteed.__class__.__name__.__eq__('set')==True / algorithms_available.__class__.__name__.__eq__('set')==True — both algorithm collections are plain Python sets (not frozensets); __class__.__name__ is 'set' on both; algorithms_guaranteed is platform-universal, algorithms_available is platform-specific superset; first hashlibshakeid362 anchor for set class identity"
  kind: python_call_eq
  category: collection_type
  id_prefix: hashlibshakeid362

  columns: [id, function, args, expected, description]
  rows:
    - [guaranteed_is_set, "algorithms_guaranteed.__class__.__name__.__eq__", ["set"], true, "hashlib.algorithms_guaranteed.__class__.__name__ is 'set' — plain Python set (not frozenset); contains algorithm names guaranteed on all Python platforms"]
    - [available_is_set,  "algorithms_available.__class__.__name__.__eq__",  ["set"], true, "hashlib.algorithms_available.__class__.__name__ is 'set' — plain Python set; platform-specific superset of algorithms_guaranteed"]

# ---------------------------------------------------------------------------
# 'shake_128' in hashlib.algorithms_guaranteed — standalone
#
# 'shake_128' in hashlib.algorithms_guaranteed is True. SHAKE-128 is an
# extendable-output function (XOF) defined in NIST FIPS 202 as part of the
# SHA-3 standard. Unlike fixed-output hash functions (SHA-256, SHA-512),
# SHAKE-128 produces variable-length output: the caller specifies the desired
# digest length. The '128' refers to the security strength in bits (not output
# length). SHAKE-128 has been in algorithms_guaranteed since Python 3.6.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra362.shake_128_in_guaranteed:
  description: "hashlib.algorithms_guaranteed.__contains__('shake_128') == True — SHAKE-128 is a NIST FIPS 202 XOF (extendable-output function); security strength is 128 bits; variable-length output (caller specifies digest size); guaranteed on all Python platforms since Python 3.6; first standalone for shake_128 guaranteed membership under hashlibshakeid362"
  category: algorithm_membership
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["shake_128"]
  expected: true

# ---------------------------------------------------------------------------
# 'blake2b' in hashlib.algorithms_guaranteed — standalone
#
# 'blake2b' in hashlib.algorithms_guaranteed is True. BLAKE2b is a
# cryptographic hash function defined in RFC 7693. It is optimized for
# 64-bit platforms and produces digests up to 64 bytes (512 bits). BLAKE2b
# is faster than SHA-256 and SHA-3 on most 64-bit platforms. It was added
# to Python hashlib in Python 3.6 as hashlib.blake2b and is guaranteed
# to be available on all Python platforms.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra362.blake2b_in_guaranteed:
  description: "hashlib.algorithms_guaranteed.__contains__('blake2b') == True — BLAKE2b is an RFC 7693 cryptographic hash function optimized for 64-bit platforms; produces digests up to 64 bytes (512 bits); faster than SHA-256 on most 64-bit systems; guaranteed on all Python platforms since Python 3.6; first standalone for blake2b guaranteed membership under hashlibshakeid362"
  category: algorithm_membership
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["blake2b"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__class__.__name__ == 'set' — standalone
#
# hashlib.algorithms_guaranteed.__class__.__name__ is 'set'. Despite its name
# suggesting immutability ('guaranteed'), algorithms_guaranteed is a plain
# Python mutable set, not a frozenset. Its __class__.__name__ is 'set'. This
# is a Python implementation detail — the attribute is documented as a set
# of names but the Python docs do not specify whether it is mutable or
# immutable. At runtime in CPython 3.14, it is a plain set object.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra362.algorithms_guaranteed_class_is_set:
  description: "hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set') == True — algorithms_guaranteed is a plain Python set (not frozenset) despite implying immutability; __class__.__name__ is 'set'; CPython implementation detail (docs say 'set', not 'frozenset'); first standalone for algorithms_guaranteed class identity under hashlibshakeid362"
  category: collection_type
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__eq__
  args: ["set"]
  expected: true
