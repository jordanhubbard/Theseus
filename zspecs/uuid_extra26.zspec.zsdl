spec: uuid_extra26
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra25.zspec.zsdl — covers UUID.__init_subclass__/__subclasshook__ __qualname__.__len__(); uuid.__spec__.__name__/__loader__.__class__.__name__.__len__(); UUID.__new__.__qualname__.__len__()==14; uuid4().__class__.__qualname__.__len__()==4."
    - "uuid_extra23.zspec.zsdl — covers UUID.hex/bytes/bytes_le.fget.__qualname__.__len__()==8; UUID.__dict__.__class__.__name__.__len__()==12; RFC_4122.__class__.__name__.__len__()==3; uuid1/3/4/5 __qualname__.__len__()==5."
    - "uuid_extra22.zspec.zsdl — covers UUID.hex.__class__.__name__.__eq__('property') and UUID.__slots__.__class__.__name__.__eq__('tuple') and UUID.__slots__.__len__()==3."
    - "uuid_extra18.zspec.zsdl — covers UUID property fget __qualname__ values and lengths for hex/bytes/urn/version/bytes_le/fields/variant; notes that UUID.int is a member_descriptor (slot) with no fget."
  notes:
    - "This spec extends uuid through uuid_extra25; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: UUID.hex.__class__.__name__.__eq__('property') (extra22 via __eq__); UUID.int.__class__.__name__.__eq__('int') on instances (extra/extra4 — checks INSTANCE .int.__class__.__name__, not the DESCRIPTOR type); UUID property fget qualname lengths (extra18/extra23); UUID.__slots__.__class__.__name__ and __len__()==3 (extra22)."
    - "This spec covers: UUID.int.__class__.__name__.__len__() (NOVEL — UUID.int is a member_descriptor slot; 'member_descriptor' has 17 chars; extra22 only checks UUID.hex.__class__.__name__.__eq__('property') via __eq__; no prior spec checks __len__() for any UUID attribute descriptor class name); UUID.is_safe.__class__.__name__.__len__() (NOVEL — UUID.is_safe is also a member_descriptor slot; same 17-char class name; no prior spec checks UUID.is_safe descriptor type length); UUID.hex.__class__.__name__.__len__() (NOVEL — extra22 checks __eq__ only, not __len__()); UUID.urn.__class__.__name__.__len__() (NOVEL — 'property' has 8 chars; extra22 does not include UUID.urn); UUID.variant.__class__.__name__.__len__() (NOVEL — 'property' has 8 chars; no prior spec checks UUID.variant descriptor class name length); UUID.version.__class__.__name__.__len__() (NOVEL — 'property' has 8 chars; no prior spec checks UUID.version descriptor class name length)."
    - "UUID.int is a C-level member_descriptor (slot) in the UUID class, not a Python property. Its descriptor object's __class__.__name__ is 'member_descriptor' (len 17). Prior specs check uuid4_instance.int.__class__.__name__=='int' on the integer VALUE, not the descriptor. No prior spec checks the descriptor class name length for UUID.int. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "UUID.is_safe is also a member_descriptor slot in the UUID class. Its descriptor __class__.__name__ is 'member_descriptor' (len 17). No prior spec checks UUID.is_safe at all (no __qualname__, no class name, no descriptor type). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "UUID.hex.__class__.__name__ == 'property' (len 8). extra22 checks __eq__('property') but not __len__(). Novel len check. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "UUID.urn.__class__.__name__ == 'property' (len 8). No prior spec checks UUID.urn descriptor class name at all. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "UUID.variant.__class__.__name__ == 'property' (len 8). No prior spec checks UUID.variant descriptor class name. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "UUID.version.__class__.__name__ == 'property' (len 8). No prior spec checks UUID.version descriptor class name. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UUID.int and UUID.is_safe descriptor class name lengths
#
# UUID uses __slots__ to store integer representation and safe-UUID flag as
# C-level member_descriptor objects. When accessed on the class (not an
# instance), UUID.int and UUID.is_safe are both member_descriptor objects.
# Their __class__.__name__ == 'member_descriptor' (len 17).
#
# Note: prior specs check uuid_instance.int.__class__.__name__ == 'int'
# on the integer VALUE; this checks the class-level DESCRIPTOR object type.
# UUID.int.__class__.__name__.__len__() == 17
# UUID.is_safe.__class__.__name__.__len__() == 17
# ---------------------------------------------------------------------------

table uuid_extra26.uuid_slot_descriptor_class_name_lens:
  description: "UUID.int and UUID.is_safe are member_descriptor slots (len 17) — novel; extra22 checks hex property via __eq__ only; no prior spec checks member_descriptor type name length for UUID slots"
  kind: python_call_eq
  category: class_introspection
  id_prefix: usdcnl26

  columns: [id, function, args, expected]
  rows:
    - [int_desc_len,    "UUID.int.__class__.__name__.__len__",    [], 17]
    - [is_safe_desc_len, "UUID.is_safe.__class__.__name__.__len__", [], 17]

# ---------------------------------------------------------------------------
# UUID property descriptor class name lengths
#
# UUID.hex, UUID.urn, UUID.variant, UUID.version are all Python property
# descriptors. When accessed on the class, they yield property objects whose
# __class__.__name__ == 'property' (len 8).
#
# extra22 checks UUID.hex.__class__.__name__.__eq__('property') via __eq__
# but does NOT check __len__(). UUID.urn, UUID.variant, UUID.version are
# not checked in any prior spec at the descriptor-class-name level.
#
# UUID.hex.__class__.__name__.__len__() == 8
# UUID.urn.__class__.__name__.__len__() == 8
# UUID.variant.__class__.__name__.__len__() == 8
# UUID.version.__class__.__name__.__len__() == 8
# ---------------------------------------------------------------------------

table uuid_extra26.uuid_property_descriptor_class_name_lens:
  description: "UUID.hex/urn/variant/version are property descriptors (class name len 8) — novel __len__() checks; extra22 covers hex via __eq__ only; urn/variant/version not covered by any prior spec at descriptor level"
  kind: python_call_eq
  category: class_introspection
  id_prefix: updcnl26

  columns: [id, function, args, expected]
  rows:
    - [hex_desc_len,     "UUID.hex.__class__.__name__.__len__",     [], 8]
    - [urn_desc_len,     "UUID.urn.__class__.__name__.__len__",     [], 8]
    - [variant_desc_len, "UUID.variant.__class__.__name__.__len__", [], 8]
    - [version_desc_len, "UUID.version.__class__.__name__.__len__", [], 8]
