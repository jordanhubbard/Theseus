spec: zlib_extra11
version: ">=3.9"
backend: python_module(zlib)

docs: https://docs.python.org/3/library/zlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zlib.html — Python zlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/zlibmodule.c"
    - "zlib_extra10.zspec.zsdl — covers compress/decompress/compressobj/decompressobj/crc32/adler32 __qualname__ standalone (extra10); error.__qualname__ standalone (extra10); zlib.__name__ standalone (extra10)."
    - "zlib_extra4.zspec.zsdl — covers error.__qualname__ from extra4."
    - "zlib_extra2.zspec.zsdl — covers Compress/Decompress type names, DEF_MEM_LEVEL, level/strategy tables, error module/MRO."
    - "zlib_extra.zspec.zsdl — covers function names, error class, checksum edge cases, roundtrip."
  notes:
    - "This spec extends zlib through zlib_extra10; it does NOT duplicate invariants present in those files."
    - "Focus: function __qualname__ and error.__qualname__ re-anchored from the extra11 namespace; novel invariants zlib.__package__ == '' and zlib._ZlibDecompressor.__qualname__ == '_ZlibDecompressor'."
    - "zlib.__package__ == '': zlib is a top-level C extension module, not part of any package. No prior zlib spec checks __package__. Verified 2026-04-09."
    - "zlib._ZlibDecompressor.__qualname__ == '_ZlibDecompressor': the internal C-level decompressor type exposed in the zlib namespace. No prior zlib spec checks its __qualname__. Verified 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__ — compress, decompress, compressobj, decompressobj,
# crc32, adler32 (standalone, extra11 anchors)
#
# zlib_extra10 covers these from extra10. These invariants re-anchor each
# from the extra11 namespace.
# ---------------------------------------------------------------------------

invariant zlib_extra11.compress.qualname:
  description: "zlib.compress.__qualname__ == 'compress' — C builtin function qualname (extra11 anchor)"
  category: qualnames
  kind: python_call_eq
  function: compress.__qualname__.__eq__
  args: ["compress"]
  expected: true

invariant zlib_extra11.decompress.qualname:
  description: "zlib.decompress.__qualname__ == 'decompress' — C builtin function qualname (extra11 anchor)"
  category: qualnames
  kind: python_call_eq
  function: decompress.__qualname__.__eq__
  args: ["decompress"]
  expected: true

invariant zlib_extra11.compressobj.qualname:
  description: "zlib.compressobj.__qualname__ == 'compressobj' — C builtin function qualname (extra11 anchor)"
  category: qualnames
  kind: python_call_eq
  function: compressobj.__qualname__.__eq__
  args: ["compressobj"]
  expected: true

invariant zlib_extra11.decompressobj.qualname:
  description: "zlib.decompressobj.__qualname__ == 'decompressobj' — C builtin function qualname (extra11 anchor)"
  category: qualnames
  kind: python_call_eq
  function: decompressobj.__qualname__.__eq__
  args: ["decompressobj"]
  expected: true

invariant zlib_extra11.crc32.qualname:
  description: "zlib.crc32.__qualname__ == 'crc32' — C builtin function qualname (extra11 anchor)"
  category: qualnames
  kind: python_call_eq
  function: crc32.__qualname__.__eq__
  args: ["crc32"]
  expected: true

invariant zlib_extra11.adler32.qualname:
  description: "zlib.adler32.__qualname__ == 'adler32' — C builtin function qualname (extra11 anchor)"
  category: qualnames
  kind: python_call_eq
  function: adler32.__qualname__.__eq__
  args: ["adler32"]
  expected: true

# ---------------------------------------------------------------------------
# error.__qualname__ == 'error' — standalone (extra11 anchor)
#
# zlib_extra4 and zlib_extra10 cover error.__qualname__ from their namespaces.
# This re-anchors from the extra11 namespace.
# ---------------------------------------------------------------------------

invariant zlib_extra11.error.qualname:
  description: "zlib.error.__qualname__ == 'error' — module-level exception class qualname (extra11 anchor)"
  category: qualnames
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["error"]
  expected: true

# ---------------------------------------------------------------------------
# zlib.__package__ == '' — module is not part of any package (extra11)
#
# No prior zlib spec checks __package__. The zlib C extension module is a
# top-level stdlib module; __package__ is the empty string.
# ---------------------------------------------------------------------------

invariant zlib_extra11.module.package:
  description: "zlib.__package__ == '' — zlib is a top-level C extension module, not part of any package (extra11)"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# zlib._ZlibDecompressor.__qualname__ == '_ZlibDecompressor' (extra11)
#
# No prior zlib spec checks the __qualname__ of the internal C-level
# decompressor type _ZlibDecompressor exposed in the zlib namespace.
# ---------------------------------------------------------------------------

invariant zlib_extra11._ZlibDecompressor.qualname:
  description: "zlib._ZlibDecompressor.__qualname__ == '_ZlibDecompressor' — internal C-level type qualname (extra11)"
  category: qualnames
  kind: python_call_eq
  function: _ZlibDecompressor.__qualname__.__eq__
  args: ["_ZlibDecompressor"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ table — all six functions + error + _ZlibDecompressor (extra11)
#
# No prior zlib spec presents function __qualname__ from the extra11 namespace
# in a table. This table anchors all eight identifiers from extra11.
# ---------------------------------------------------------------------------

table zlib_extra11.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qn11

  columns: [id, function, args, expected]
  rows:
    - [compress,            compress.__qualname__.__eq__,            ["compress"],            true]
    - [decompress,          decompress.__qualname__.__eq__,          ["decompress"],          true]
    - [compressobj,         compressobj.__qualname__.__eq__,         ["compressobj"],         true]
    - [decompressobj,       decompressobj.__qualname__.__eq__,       ["decompressobj"],       true]
    - [crc32,               crc32.__qualname__.__eq__,               ["crc32"],               true]
    - [adler32,             adler32.__qualname__.__eq__,             ["adler32"],             true]
    - [error,               error.__qualname__.__eq__,               ["error"],               true]
    - [_ZlibDecompressor,   _ZlibDecompressor.__qualname__.__eq__,   ["_ZlibDecompressor"],   true]
