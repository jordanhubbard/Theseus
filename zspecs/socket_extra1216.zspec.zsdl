spec: socket_extra1216
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module socket class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks socket.socket.__dict__.__contains__ for bind/listen/accept/connect/send/recv/close/shutdown keys; socket.socket.__dict__ class identity; and socket.socket.__mro__.__len__ count"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra1216.socket_dict_contains_server:
  description: "socket.socket.__dict__.__contains__ checks for server-side method keys"
  kind: python_call_eq
  category: socket_dict_contains_server
  id_prefix: sk1216sv
  columns: [id, function, args, expected]
  rows:
    - [sk1216sv001, socket.socket.__dict__.__contains__,                  ["bind"],        true]
    - [sk1216sv002, socket.socket.__dict__.__contains__,                  ["listen"],      true]
    - [sk1216sv003, socket.socket.__dict__.__contains__,                  ["accept"],      true]
    - [sk1216sv004, socket.socket.__dict__.__contains__,                  ["close"],       true]
    - [sk1216sv005, socket.socket.__dict__.__contains__,                  ["shutdown"],    true]
    - [sk1216sv006, socket.socket.__dict__.__contains__,                  ["fileno"],      true]
    - [sk1216sv007, socket.socket.__dict__.__contains__,                  ["getsockname"], true]
    - [sk1216sv008, socket.socket.__dict__.__class__.__name__.__eq__,     ["mappingproxy"], true]
    - [sk1216sv009, socket.socket.__dict__.__class__.__qualname__.__eq__, ["mappingproxy"], true]

table socket_extra1216.socket_dict_contains_io:
  description: "socket.socket.__dict__.__contains__ checks for I/O and client-side method keys"
  kind: python_call_eq
  category: socket_dict_contains_io
  id_prefix: sk1216io
  columns: [id, function, args, expected]
  rows:
    - [sk1216io001, socket.socket.__dict__.__contains__,                  ["connect"],     true]
    - [sk1216io002, socket.socket.__dict__.__contains__,                  ["send"],        true]
    - [sk1216io003, socket.socket.__dict__.__contains__,                  ["recv"],        true]
    - [sk1216io004, socket.socket.__dict__.__contains__,                  ["sendall"],     true]
    - [sk1216io005, socket.socket.__dict__.__contains__,                  ["sendto"],      true]
    - [sk1216io006, socket.socket.__dict__.__contains__,                  ["recvfrom"],    true]
    - [sk1216io007, socket.socket.__dict__.__contains__,                  ["makefile"],    true]
    - [sk1216io008, socket.socket.__dict__.__class__.__module__.__eq__,   ["builtins"],    true]
    - [sk1216io009, socket.socket.__dict__.__class__.__name__.__class__.__name__.__eq__, ["str"], true]

table socket_extra1216.socket_mro_len:
  description: "socket.socket.__mro__.__len__ and __mro__ class identity"
  kind: python_call_eq
  category: socket_mro_len
  id_prefix: sk1216ml
  columns: [id, function, args, expected]
  rows:
    - [sk1216ml001, socket.socket.__mro__.__len__,                        [],              2]
    - [sk1216ml002, socket.socket.__mro__.__class__.__name__.__eq__,      ["tuple"],       true]
    - [sk1216ml003, socket.socket.__mro__.__class__.__qualname__.__eq__,  ["tuple"],       true]
    - [sk1216ml004, socket.socket.__mro__.__class__.__module__.__eq__,    ["builtins"],    true]
    - [sk1216ml005, socket.socket.__name__.__eq__,                        ["socket"],      true]
    - [sk1216ml006, socket.socket.__module__.__eq__,                      ["socket"],      true]
    - [sk1216ml007, socket.socket.__mro__.__class__.__name__.__class__.__name__.__eq__, ["str"], true]
