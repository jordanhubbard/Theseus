spec: pathlib_extra2386
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
  notes:
    - "Wave 2386 (pathlib_extra2386): __str__ and __repr__ implementation type classification for pathlib path classes."
    - "pathlib.PurePath, PurePosixPath, Path, and PosixPath are all pure-Python classes defined in Lib/pathlib.py."
    - "Because these are Python classes with custom __repr__ and __str__ defined as Python functions, .__repr__.__class__.__name__ == 'function' and .__str__.__class__.__name__ == 'function'."
    - "This contrasts with C extension types (e.g., io.StringIO) where these attributes are 'wrapper_descriptor'."
    - "pathlib.PurePath.__repr__ is defined directly in PurePath as a Python function: def __repr__(self): return \"{}({!r})\".format(self.__class__.__name__, self.as_posix())."
    - "pathlib.PurePath.__str__ is defined directly in PurePath as a Python function: def __str__(self): return self._str."
    - "PurePosixPath, Path, and PosixPath all inherit __repr__ and __str__ from PurePath (they are still 'function' — Python does not change the class of an inherited function)."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# pathlib.PurePath — __repr__ and __str__ implementation type
# ---------------------------------------------------------------------------

table pathlib_extra2386.purepath_str_repr:
  description: "pathlib.PurePath.__repr__.__class__.__name__ and pathlib.PurePath.__str__.__class__.__name__ — both are 'function' because PurePath is a pure-Python class with __repr__ and __str__ defined as ordinary Python functions in Lib/pathlib.py, not as C slot wrappers"
  kind: python_call_eq
  category: classnames
  id_prefix: pp2386

  columns: [id, function, args, expected]
  rows:
    - ["pp2386001", "pathlib.PurePath.__repr__.__class__.__name__.__eq__", ["function"], true]
    - ["pp2386002", "pathlib.PurePath.__str__.__class__.__name__.__eq__",  ["function"], true]

