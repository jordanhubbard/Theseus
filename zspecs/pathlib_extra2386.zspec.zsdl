    - ["pp2386008", "pathlib.PosixPath.__str__.__class__.__name__.__eq__",  ["function"], true]

# ---------------------------------------------------------------------------
# Cross-check: pathlib 'function' vs io 'wrapper_descriptor' contrast
#
# Confirms that pathlib path classes (Python) differ from C types in their
# __repr__/__str__ implementation class — 'function' not 'wrapper_descriptor'.
# The following invariants confirm that pathlib types do NOT return
# 'wrapper_descriptor' for either slot, distinguishing them from io C types.
# ---------------------------------------------------------------------------

table pathlib_extra2386.not_wrapper_descriptor:
  description: "Negative cross-checks: pathlib path classes do NOT have 'wrapper_descriptor' for __repr__ or __str__ — they are pure-Python classes whose __repr__/__str__ are plain functions, unlike C-extension io types; these invariants confirm the classification boundary"
  kind: python_call_eq
  category: classnames
  id_prefix: pp2386

  columns: [id, function, args, expected]
  rows:
    - ["pp2386009", "pathlib.PurePath.__repr__.__class__.__name__.__eq__",     ["wrapper_descriptor"], false]
    - ["pp2386010", "pathlib.PurePath.__str__.__class__.__name__.__eq__",      ["wrapper_descriptor"], false]
    - ["pp2386011", "pathlib.PurePosixPath.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], false]
    - ["pp2386012", "pathlib.PurePosixPath.__str__.__class__.__name__.__eq__",  ["wrapper_descriptor"], false]
    - ["pp2386013", "pathlib.Path.__repr__.__class__.__name__.__eq__",          ["wrapper_descriptor"], false]
    - ["pp2386014", "pathlib.Path.__str__.__class__.__name__.__eq__",           ["wrapper_descriptor"], false]
    - ["pp2386015", "pathlib.PosixPath.__repr__.__class__.__name__.__eq__",     ["wrapper_descriptor"], false]
    - ["pp2386016", "pathlib.PosixPath.__str__.__class__.__name__.__eq__",      ["wrapper_descriptor"], false]

