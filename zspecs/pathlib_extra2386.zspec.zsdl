  description: "pathlib.PurePosixPath.__repr__.__class__.__name__ and pathlib.PurePosixPath.__str__.__class__.__name__ — both are 'function'; PurePosixPath inherits __repr__ and __str__ from PurePath; inherited Python functions retain their class 'function'"
  kind: python_call_eq
  category: classnames
  id_prefix: pp2386

  columns: [id, function, args, expected]
  rows:
    - ["pp2386003", "pathlib.PurePosixPath.__repr__.__class__.__name__.__eq__", ["function"], true]
    - ["pp2386004", "pathlib.PurePosixPath.__str__.__class__.__name__.__eq__",  ["function"], true]

