  description: "pathlib.Path.__repr__.__class__.__name__ and pathlib.Path.__str__.__class__.__name__ — both are 'function'; Path is a concrete Python class that inherits __repr__ and __str__ from PurePath; the implementation type remains 'function'"
  kind: python_call_eq
  category: classnames
  id_prefix: pp2386

  columns: [id, function, args, expected]
  rows:
    - ["pp2386005", "pathlib.Path.__repr__.__class__.__name__.__eq__", ["function"], true]
    - ["pp2386006", "pathlib.Path.__str__.__class__.__name__.__eq__",  ["function"], true]

