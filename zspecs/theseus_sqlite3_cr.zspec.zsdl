spec: theseus_sqlite3_cr
version: ">=3.0"
backend: python_cleanroom(theseus_sqlite3_cr)
blocks: sqlite3

docs: https://docs.python.org/3/library/sqlite3.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/sqlite3.html"
  not_derived_from:
    - "CPython source: Modules/_sqlite/"
  notes:
    - "Clean-room sqlite3 module. Do NOT import sqlite3."

error_model: python_exceptions

invariant theseus_sqlite3_cr.sqlite3_connect:
  description: "connect(':memory:') returns a Connection"
  category: behavior
  kind: python_call_eq
  function: sqlite3_2connect
  args: []
  expected: true

invariant theseus_sqlite3_cr.sqlite3_execute:
  description: "execute() and fetchall() work"
  category: behavior
  kind: python_call_eq
  function: sqlite3_2execute
  args: []
  expected: true

invariant theseus_sqlite3_cr.sqlite3_version:
  description: "sqlite_version string is non-empty"
  category: behavior
  kind: python_call_eq
  function: sqlite3_2version
  args: []
  expected: true
