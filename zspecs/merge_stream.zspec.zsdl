spec: merge_stream
version: ">=2.0.0"
backend: node(merge-stream)

docs: https://github.com/grncdr/merge-stream#readme

provenance:
  derived_from:
    - "merge-stream README — https://github.com/grncdr/merge-stream#readme"
    - "Test vectors verified with merge-stream via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "merge-stream source"
  notes:
    - "Merge multiple streams into one PassThrough — used by gulp-style pipelines."
    - "Install: npm install merge-stream"
    - "v2 CJS; module export IS the factory function."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure factory; never throws."
  stderr: "null"
  stickiness: "N/A — each merged stream independent."
  codes: {}

invariant merge_stream.module_is_function:
  description: "Module export is a function (the merge factory)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant merge_stream.factory_returns_PassThrough:
  description: "merge() (no args) returns a PassThrough stream"
  category: stream
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain:
    - {get: "constructor.name"}
  expected: "PassThrough"

invariant merge_stream.stream_is_readable:
  description: "Returned stream has readable=true"
  category: stream
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain:
    - {get: readable}
  expected: true

invariant merge_stream.stream_is_writable:
  description: "Returned stream has writable=true"
  category: stream
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain:
    - {get: writable}
  expected: true

invariant merge_stream.factory_arity:
  description: "merge takes 0 declared args (uses arguments)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 0

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T21:13:04Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
