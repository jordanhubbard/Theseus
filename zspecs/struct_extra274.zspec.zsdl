spec: struct_extra274
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html
rfcs:
  - "IEEE 754 — Standard for Floating-Point Arithmetic"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "IEEE 754 — Standard for Floating-Point Arithmetic"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "This spec extends struct.zspec.zsdl through struct_extra273.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "struct.zspec.zsdl covers: pack/unpack for B/b/H/h/I/i/Q/q/f/d/?/e/x with big/little-endian and network byte order; calcsize; roundtrip; error cases."
    - "struct_extra273.zspec.zsdl covers: network byte order ('!') signed integer pack/unpack vectors for b/h/i; calcsize !b/!h/!i; out-of-range signed byte error."
    - "This spec focuses on: IEEE 754 float/double network byte order ('!f'/'!d') pack/unpack vectors — zero, 1.0, -1.0, infinity; calcsize for !f (4) and !d (8); unpack size mismatch error."
    - "struct.pack('!f', 0.0) == b'\\x00\\x00\\x00\\x00' — IEEE 754 positive zero is all-zero bits. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.pack('!d', 0.0) == b'\\x00\\x00\\x00\\x00\\x00\\x00\\x00\\x00' — IEEE 754 double positive zero is 8 zero bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.pack('!f', 1.0) == b'\\x3f\\x80\\x00\\x00' — IEEE 754 single-precision 1.0: sign=0, exp=127 (0x7f), mantissa=0. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.pack('!d', 1.0) == b'\\x3f\\xf0\\x00\\x00\\x00\\x00\\x00\\x00' — IEEE 754 double-precision 1.0: sign=0, exp=1023 (0x3ff), mantissa=0. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.pack('!f', float('inf')) == b'\\x7f\\x80\\x00\\x00' — IEEE 754 single-precision positive infinity: exp=255, mantissa=0. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.pack('!f', float('-inf')) == b'\\xff\\x80\\x00\\x00' — IEEE 754 single-precision negative infinity: sign=1, exp=255, mantissa=0. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('!f') == 4 — single-precision float is always 4 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('!d') == 8 — double-precision float is always 8 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('!fd') == 12 — combined float+double format is 4+8=12 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.unpack('!f', b'\\x00\\x00\\x00\\x00') == (0.0,) — all-zero bytes decode as positive zero. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.unpack('!f', b'\\x7f\\x80\\x00\\x00') == (float('inf'),) — IEEE 754 inf bit pattern decodes as infinity. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.unpack('!f', <3 bytes>) raises struct.error — buffer must be exactly 4 bytes for '!f'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model:
  semantics: "struct.error is raised for buffer size mismatches on unpack. pack raises struct.error for non-float arguments to 'f'/'d' format."
  stderr: "null"
  stickiness: "N/A — struct functions are pure; no shared state."
  codes: {}

# ---------------------------------------------------------------------------
# struct.pack — IEEE 754 network byte order float ('!f') vectors
# struct.zspec.zsdl covers '>f' (big-endian). These '!' variants are novel
# and encode the IEEE 754 bit patterns explicitly.
# 1.0 in IEEE 754 single: 0 01111111 00000000000000000000000 = 0x3f800000
# -1.0 in IEEE 754 single: 1 01111111 00000000000000000000000 = 0xbf800000
# +inf single: 0 11111111 00000000000000000000000 = 0x7f800000
# -inf single: 1 11111111 00000000000000000000000 = 0xff800000
# ---------------------------------------------------------------------------

table struct_extra274.pack_float32_vectors:
  description: "struct.pack('!f', ...) IEEE 754 single-precision vectors in network byte order — zero/1.0/-1.0/+inf/-inf; verified with Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: pack_vector
  function: pack
  id_prefix: pf274

  columns: [id, args, expected, description]
  rows:
    - [zero,     ["!f", 0.0],           !hex 00000000, "IEEE 754 positive zero: all-zero bit pattern"]
    - [one,      ["!f", 1.0],           !hex 3f800000, "IEEE 754 1.0: exponent=127 (0x7f), mantissa=0"]
    - [neg_one,  ["!f", -1.0],          !hex bf800000, "IEEE 754 -1.0: sign=1, exponent=127, mantissa=0"]
    - [pos_inf,  ["!f", "float('inf')"], !hex 7f800000, "IEEE 754 +infinity: exponent=255, mantissa=0"]
    - [neg_inf,  ["!f", "float('-inf')"], !hex ff800000, "IEEE 754 -infinity: sign=1, exponent=255, mantissa=0"]

# ---------------------------------------------------------------------------
# struct.pack — IEEE 754 network byte order double ('!d') vectors
# 1.0 in IEEE 754 double: 0 01111111111 0000...0 = 0x3ff0000000000000
# -1.0 in IEEE 754 double: 1 01111111111 0000...0 = 0xbff0000000000000
# ---------------------------------------------------------------------------

table struct_extra274.pack_float64_vectors:
  description: "struct.pack('!d', ...) IEEE 754 double-precision vectors in network byte order — zero/1.0/-1.0; verified with Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: pack_vector
  function: pack
  id_prefix: pd274

  columns: [id, args, expected, description]
  rows:
    - [zero,    ["!d", 0.0],  !hex 0000000000000000, "IEEE 754 double positive zero: all-zero 8 bytes"]
    - [one,     ["!d", 1.0],  !hex 3ff0000000000000, "IEEE 754 double 1.0: exponent=1023 (0x3ff), mantissa=0"]
    - [neg_one, ["!d", -1.0], !hex bff0000000000000, "IEEE 754 double -1.0: sign=1, exponent=1023, mantissa=0"]

# ---------------------------------------------------------------------------
# struct.calcsize — float format sizes
# '!f' is always 4 bytes (IEEE 754 single); '!d' always 8 bytes (double).
# Combined '!fd' is 4+8=12. These are platform-independent.
# ---------------------------------------------------------------------------

invariant struct_extra274.calcsize.bang_f:
  description: "struct.calcsize('!f') == 4 — IEEE 754 single-precision float is always 4 bytes in network byte order; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["!f"]
  expected: 4

invariant struct_extra274.calcsize.bang_d:
  description: "struct.calcsize('!d') == 8 — IEEE 754 double-precision float is always 8 bytes in network byte order; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["!d"]
  expected: 8

invariant struct_extra274.calcsize.bang_fd:
  description: "struct.calcsize('!fd') == 12 — combined single+double format is 4+8=12 bytes; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["!fd"]
  expected: 12

# ---------------------------------------------------------------------------
# struct.unpack — IEEE 754 float round-trip decode
# Decoding all-zero bytes as '!f' yields 0.0; decoding 0x7f800000 yields inf.
# ---------------------------------------------------------------------------

invariant struct_extra274.unpack.float32_zero:
  description: "struct.unpack('!f', b'\\x00\\x00\\x00\\x00') == (0.0,) — all-zero IEEE 754 single-precision bytes decode as positive zero; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: unpack_vector
  kind: python_call_eq
  function: unpack
  args: ["!f", !hex 00000000]
  expected: [0.0]

invariant struct_extra274.unpack.float64_zero:
  description: "struct.unpack('!d', b'\\x00..\\x00') == (0.0,) — all-zero IEEE 754 double-precision bytes decode as positive zero; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: unpack_vector
  kind: python_call_eq
  function: unpack
  args: ["!d", !hex 0000000000000000]
  expected: [0.0]

invariant struct_extra274.unpack.float32_inf:
  description: "struct.unpack('!f', b'\\x7f\\x80\\x00\\x00') == (float('inf'),) — 0x7f800000 decodes as IEEE 754 single positive infinity; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: unpack_vector
  kind: python_call_eq
  function: unpack
  args: ["!f", !hex 7f800000]
  expected: ["float('inf')"]

# ---------------------------------------------------------------------------
# struct.unpack — wrong buffer size raises struct.error
# '!f' requires exactly 4 bytes; 3 bytes triggers struct.error.
# ---------------------------------------------------------------------------

invariant struct_extra274.unpack.float32_short_buffer_raises:
  description: "struct.unpack('!f', b'\\x00\\x00\\x00') raises struct.error — buffer must be exactly 4 bytes for '!f' format; 3 bytes is rejected; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: error
  kind: python_call_raises
  function: unpack
  args: ["!f", !hex 000000]
  raises: struct.error
