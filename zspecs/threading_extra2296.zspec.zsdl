spec: threading_extra2296
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/threading.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 600 (_extra2296): __module__ and __qualname__ attribute value checks."
    - "Subjects: threading.Thread, threading.Event, threading.Condition, threading.Semaphore, threading.BoundedSemaphore, threading.Barrier, threading.Timer, threading.local."
    - "threading.local is implemented in _thread (C extension); __module__ == '_thread', __qualname__ == '_local', __name__ == '_local'."
    - "All other subjects are pure Python; __module__ == 'threading'."
    - "All pure-Python subjects have __qualname__ matching their unqualified public class name."
    - "threading.BrokenBarrierError.__module__ == 'threading', __qualname__ == 'BrokenBarrierError'."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table threading_extra2296.thread_module:
  description: "threading.Thread __module__ and __qualname__"
  kind: python_call_eq
  category: module_identity
  id_prefix: th2296

  columns: [id, function, args, expected]
  rows:
    - ["th2296001", "threading.Thread.__module__", [], "threading"]
    - ["th2296002", "threading.Thread.__qualname__", [], "Thread"]

