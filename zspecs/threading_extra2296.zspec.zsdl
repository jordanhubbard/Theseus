table threading_extra2296.pure_python_vs_c:
  description: "Cross-check: pure-Python types report 'threading'; C-backed local reports '_thread'"
  kind: python_call_eq
  category: module_identity
  id_prefix: th2296

  columns: [id, function, args, expected]
  rows:
    - ["th2296019", "threading.Thread.__module__", [], "threading"]
    - ["th2296020", "threading.Event.__module__", [], "threading"]
    - ["th2296021", "threading.Condition.__module__", [], "threading"]
    - ["th2296022", "threading.Semaphore.__module__", [], "threading"]
    - ["th2296023", "threading.BoundedSemaphore.__module__", [], "threading"]
    - ["th2296024", "threading.Barrier.__module__", [], "threading"]
    - ["th2296025", "threading.Timer.__module__", [], "threading"]
    - ["th2296026", "threading.local.__module__", [], "_thread"]
