spec: socket_extra150
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra149.zspec.zsdl — covers socket.__dict__.__len__()==267 / socket.socket.__dict__.__len__()==28 / socket.AddressFamily.__dict__.__len__()==25 / socket.SocketKind.__dict__.__len__()==20 / all three class dicts are mappingproxy / socket.__dict__.__class__.__name__.__eq__('dict') (table + invariants)."
    - "socket_extra148.zspec.zsdl — covers socket.__dict__.__contains__('socket'/'AF_INET'/'gethostname'/'error'/'timeout'/'getaddrinfo'/'AF_INET6'/'SOCK_STREAM') / socket.socket.__dict__.__contains__('family'/'type'/'__enter__'/'__exit__') (table + invariants)."
    - "socket_extra147.zspec.zsdl — covers socket.socket.__dict__.__contains__('accept'/'makefile'/'close'/'__init__'/'__slots__'/'sendfile'/'detach'/'dup'/'__repr__') / socket.__dict__.__len__()==28 / socket.__package__.__eq__('') / socket.__loader__.__class__.__name__.__eq__('SourceFileLoader') (table + invariants)."
    - "socket_extra146.zspec.zsdl — covers socket.__all__.__contains__('socket'/'AF_INET'/'SOCK_STREAM'/'gethostname'/'error'/'AF_INET6') / __all__.__len__()==238 / socket.socket.__init__.__qualname__.__eq__('socket.__init__') / __init__.__class__.__name__.__eq__('function') (table + invariants)."
    - "socket_extra145.zspec.zsdl — covers socket.AF_UNSPEC/__class__.__name__.__eq__('AddressFamily') / AF_UNIX.name.__eq__('AF_UNIX') / IPPROTO_TCP/__class__.__name__.__eq__('int') / __spec__.name.__eq__('socket') / __doc__.__len__()==2021 (table + invariants)."
    - "socket_extra144.zspec.zsdl — covers socket.socket.__module__/__qualname__/__eq__('socket') / socket.socket.__dict__.__class__.__name__.__eq__('mappingproxy') / __mro__.__len__()==3 (table + invariants)."
    - "socket_extra142.zspec.zsdl — covers socket.AF_INET/AF_INET6 enum member .name values / SOCK_STREAM/SOCK_DGRAM .name values / AddressFamily/SocketKind class __name__ values (table + invariants)."
    - "socket_extra99.zspec.zsdl — covers socket.gethostname/gethostbyname/getaddrinfo/setdefaulttimeout/getdefaulttimeout __qualname__.__len__() / SocketIO class identity."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra93 through socket_extra149."
    - "Wave 332 theme: _socket C extension module namespace — _socket.__dict__.__len__()==235 / _socket.__dict__.__class__.__name__.__eq__('dict') / _socket.__dict__.__contains__('socket') / _socket.__dict__.__contains__('AF_INET') / _socket.__dict__.__contains__('IPPROTO_TCP') / _socket.__dict__.__contains__('SO_REUSEADDR') / _socket.__dict__.__contains__('gethostname'). Also _socket.socket.__dict__.__len__()==37 and size comparison: socket(267) vs _socket(235) — the public wrapper has 32 more entries than the C extension."
    - "_socket.__dict__.__len__() == 235. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "_socket.__dict__.__class__.__name__ == 'dict'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "_socket.__dict__.__contains__('socket') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "_socket.__dict__.__contains__('AF_INET') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "_socket.__dict__.__contains__('IPPROTO_TCP') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "_socket.__dict__.__contains__('SO_REUSEADDR') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "_socket.__dict__.__contains__('gethostname') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "_socket.socket.__dict__.__len__() == 37. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "_socket.socket.__dict__.__class__.__name__ == 'mappingproxy'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: _socket.__dict__.__len__() == 235. The 235 C extension entries include: the socket C type, error/gaierror/herror/timeout exception types (4), all AF_*/SOCK_*/IPPROTO_*/SO_*/TCP_*/SHUT_*/SOL_*/MSG_* raw integer constants (~200), builtin_function_or_method functions (gethostname, gethostbyname, getaddrinfo, inet_aton, inet_ntoa, etc., ~25), and standard C extension metadata (__doc__, __file__, __loader__, __name__, __package__, __spec__). The public socket module (267) has 32 more entries because socket.py adds: the AddressFamily/SocketKind IntEnum wrappers, the SocketIO class, Python-level function wrappers, aliases (error/timeout/gaierror/herror pointing to new exception types), and module infrastructure (__all__, __cached__, __builtins__, etc.)."
    - "Note: _socket.socket.__dict__.__len__() == 37. The C-level _socket.socket class dict (37 entries) is larger than the Python-level socket.socket class dict (28 entries, anchored in extra147/extra149). This is because _socket.socket is a fully-formed C extension type with all socket operations as C-level methods, while the Python-level socket.socket wraps _socket.socket and selectively overrides/adds methods at the Python level. The Python socket.socket inherits the C methods from _socket.socket, so they do not appear in socket.socket.__dict__."
    - "Note: _socket.__dict__.__class__.__name__ == 'dict' (4 chars). Consistent with the pattern for all module __dict__ objects (struct, hashlib, uuid, socket and their C extension counterparts _struct, _hashlib, _socket). Class __dict__ objects (_socket.socket.__dict__) remain 'mappingproxy' (12 chars)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# _socket.__dict__.__len__()==235
# _socket.__dict__.__class__.__name__.__eq__('dict')
# socket.__dict__.__len__()==267
#
# Wave 332 theme: _socket C extension namespace size vs public socket size.
#
# The _socket C extension dict (235 entries) is 32 entries smaller than the public
# socket module dict (267 entries). The 32-entry difference arises from AddressFamily/
# SocketKind IntEnum wrappers, SocketIO class, Python-level aliases, and module
# infrastructure added by socket.py. Both are plain 'dict' (4 chars).
# extra149 anchors socket.__dict__.__len__()==267 as a table; no prior socket spec
# anchors _socket.__dict__.__len__()==235 as a table under sockc150.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra150.socket_vs_socket_c_dict_sizes:
  description: "_socket.__dict__.__len__()==235 / _socket.__dict__.__class__.__name__.__eq__('dict')==True / socket.__dict__.__len__()==267 — _socket C extension dict (235) is 32 entries smaller than public socket dict (267); the 32-entry difference: AddressFamily/SocketKind IntEnum wrappers + SocketIO + Python-level aliases + module infrastructure (__all__/__cached__/__builtins__ + exception aliases); both are plain 'dict' (4 chars); extra149 anchors socket dict len; first sockc150 anchor for _socket dict len and comparison"
  kind: python_call_eq
  category: identity
  id_prefix: sockc150

  columns: [id, function, args, expected, description]
  rows:
    - [socket_c_dict_len_235,  "_socket.__dict__.__len__",                    [],        235,  "_socket.__dict__.__len__() is 235 (C extension dict; 32 fewer than socket's 267 entries)"]
    - [socket_c_dict_class,    "_socket.__dict__.__class__.__name__.__eq__",  ["dict"],  true, "_socket.__dict__.__class__.__name__ == 'dict' (4 chars; plain mutable module dict, same as socket)"]
    - [socket_dict_len_267,    "__dict__.__len__",                            [],        267,  "socket.__dict__.__len__() is 267 (public wrapper; 32 more than _socket: IntEnum wrappers + SocketIO + aliases)"]

# ---------------------------------------------------------------------------
# _socket.__dict__.__contains__('socket')
# _socket.__dict__.__contains__('AF_INET')
# _socket.__dict__.__contains__('IPPROTO_TCP')
# _socket.__dict__.__contains__('SO_REUSEADDR')
#
# Wave 332 theme: _socket C extension dict contains the core socket class and constants.
#
# The C extension _socket dict contains: the socket C type (as 'socket'), the AF_INET
# address family constant (raw int), IPPROTO_TCP (raw int), and SO_REUSEADDR (raw int).
# These are C-level integer constants — not IntEnum members like in the public socket
# module. extra148 anchors socket.__dict__.__contains__ for 'socket'/'AF_INET'; no prior
# socket spec anchors _socket.__dict__.__contains__ for any name as a table under sockc150.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra150.socket_c_dict_contains_core_names:
  description: "_socket.__dict__.__contains__('socket')==True / __dict__.__contains__('AF_INET')==True / __dict__.__contains__('IPPROTO_TCP')==True / __dict__.__contains__('SO_REUSEADDR')==True — 'socket' is the C-level socket type; AF_INET/IPPROTO_TCP/SO_REUSEADDR are raw C integers (not IntEnum); public socket module wraps AF_INET in AddressFamily IntEnum; extra148 anchors socket.__dict__.__contains__ for 'socket'/'AF_INET'; first sockc150 anchor for _socket.__dict__.__contains__ membership checks"
  kind: python_call_eq
  category: identity
  id_prefix: sockc150

  columns: [id, function, args, expected, description]
  rows:
    - [socket_c_socket,       "_socket.__dict__.__contains__",  ["socket"],      true, "_socket.__dict__.__contains__('socket') == True (the C-level socket type; base of socket.socket)"]
    - [socket_c_AF_INET,      "_socket.__dict__.__contains__",  ["AF_INET"],     true, "_socket.__dict__.__contains__('AF_INET') == True (IPv4 address family; raw C int, not AddressFamily IntEnum)"]
    - [socket_c_IPPROTO_TCP,  "_socket.__dict__.__contains__",  ["IPPROTO_TCP"], true, "_socket.__dict__.__contains__('IPPROTO_TCP') == True (TCP protocol number as raw C int)"]
    - [socket_c_SO_REUSEADDR, "_socket.__dict__.__contains__",  ["SO_REUSEADDR"], true, "_socket.__dict__.__contains__('SO_REUSEADDR') == True (socket option for address reuse; raw C int)"]

# ---------------------------------------------------------------------------
# _socket.__dict__.__contains__('gethostname')
# _socket.__dict__.__contains__('getaddrinfo')
# _socket.__dict__.__contains__('gethostbyname')
# _socket.__dict__.__contains__('inet_aton')
#
# Wave 332 theme: _socket C extension dict contains key network functions.
#
# gethostname, getaddrinfo, gethostbyname, and inet_aton are four C-level network
# functions in _socket.__dict__. These are the same objects imported into the public
# socket namespace. extra148 anchors socket.__dict__.__contains__('gethostname') and
# ('getaddrinfo') for the public module; no prior socket spec anchors _socket.__dict__
# .__contains__ for these function names as a table under sockc150.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra150.socket_c_dict_contains_network_functions:
  description: "_socket.__dict__.__contains__('gethostname')==True / __dict__.__contains__('getaddrinfo')==True / __dict__.__contains__('gethostbyname')==True / __dict__.__contains__('inet_aton')==True — all four are builtin_function_or_method from the C extension; same objects imported into public socket namespace; extra148 anchors socket.__dict__.__contains__('gethostname') and ('getaddrinfo'); first sockc150 anchor for _socket.__dict__.__contains__ for these function names"
  kind: python_call_eq
  category: identity
  id_prefix: sockc150

  columns: [id, function, args, expected, description]
  rows:
    - [socket_c_gethostname,   "_socket.__dict__.__contains__",  ["gethostname"],  true, "_socket.__dict__.__contains__('gethostname') == True (returns machine hostname; same as socket.gethostname)"]
    - [socket_c_getaddrinfo,   "_socket.__dict__.__contains__",  ["getaddrinfo"],  true, "_socket.__dict__.__contains__('getaddrinfo') == True (main name resolution; same as socket.getaddrinfo)"]
    - [socket_c_gethostbyname, "_socket.__dict__.__contains__",  ["gethostbyname"], true, "_socket.__dict__.__contains__('gethostbyname') == True (resolves hostname to IPv4 address string)"]
    - [socket_c_inet_aton,     "_socket.__dict__.__contains__",  ["inet_aton"],    true, "_socket.__dict__.__contains__('inet_aton') == True (converts IPv4 dotted-decimal to 4-byte packed binary)"]

# ---------------------------------------------------------------------------
# _socket.socket.__dict__.__len__()==37
# _socket.socket.__dict__.__class__.__name__.__eq__('mappingproxy')
#
# Wave 332 theme: _socket.socket C extension class dict size and type.
#
# The C-level _socket.socket class dict has 37 entries — larger than the Python-level
# socket.socket class dict (28 entries, anchored in extra149). This is because
# _socket.socket is a C extension type exposing all socket operations as direct
# C-level methods, while socket.socket overrides some in Python and inherits the rest,
# so the Python-level class dict only contains the Python overrides/additions.
# No prior socket spec anchors _socket.socket.__dict__.__len__()==37 or
# __class__.__name__=='mappingproxy' as a table under sockc150.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra150.socket_c_socket_dict_size_and_type:
  description: "_socket.socket.__dict__.__len__()==37 / _socket.socket.__dict__.__class__.__name__.__eq__('mappingproxy')==True — C-level _socket.socket class dict (37) is larger than Python-level socket.socket class dict (28, extra149); Python socket.socket inherits C methods from _socket.socket, so only Python overrides appear in socket.socket.__dict__; both are mappingproxy (12 chars); first sockc150 anchor for _socket.socket dict len and class name"
  kind: python_call_eq
  category: identity
  id_prefix: sockc150

  columns: [id, function, args, expected, description]
  rows:
    - [socket_c_socket_dict_len_37,       "_socket.socket.__dict__.__len__",                    [],              37,   "_socket.socket.__dict__.__len__() is 37 (C extension class dict; 9 more than Python socket.socket at 28)"]
    - [socket_c_socket_dict_mappingproxy, "_socket.socket.__dict__.__class__.__name__.__eq__",  ["mappingproxy"], true, "_socket.socket.__dict__.__class__.__name__ == 'mappingproxy' (12 chars; C extension class dict is also mappingproxy)"]

# ---------------------------------------------------------------------------
# _socket.__dict__.__len__()==235 — standalone
#
# _socket.__dict__.__len__() is 235. The 235 C extension entries include: the socket
# C type (1), exception types (4: error/gaierror/herror/timeout), raw integer constants
# for address families (AF_UNSPEC/AF_UNIX/AF_INET/AF_INET6/AF_APPLETALK/etc., ~30),
# socket types (SOCK_STREAM/SOCK_DGRAM/SOCK_RAW/etc., ~10), IP protocol constants
# (IPPROTO_TCP/IPPROTO_UDP/IPPROTO_ICMP/etc., ~40), socket options (SO_REUSEADDR/
# SO_KEEPALIVE/SO_SNDBUF/etc., ~50), and many more platform constants, plus ~25
# C-level network functions, and 6 standard metadata entries. The public socket module
# (267) = _socket (235) + 32 Python-level additions. Comparing C extension dict sizes:
# _struct(15) < _hashlib(32) << _socket(235) < socket(267). No prior socket spec anchors
# _socket.__dict__.__len__()==235 as a standalone under sockc150.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra150.socket_c_dict_len_235:
  description: "_socket.__dict__.__len__() == 235 — 235 C extension entries: socket type + 4 exception types + ~30 AF_* constants + ~10 SOCK_* constants + ~40 IPPROTO_* constants + ~50 SO_*/TCP_*/SHUT_* options + ~25 network functions + 6 metadata; socket(267) = _socket(235) + 32 Python additions; C extension dict sizes: _struct(15) < _hashlib(32) << _socket(235); no prior socket spec anchors this as a standalone; first standalone under sockc150"
  category: identity
  kind: python_call_eq
  function: "_socket.__dict__.__len__"
  args: []
  expected: 235

# ---------------------------------------------------------------------------
# _socket.__dict__.__class__.__name__.__eq__('dict') — standalone
#
# _socket.__dict__.__class__.__name__ is 'dict' (4 chars). The _socket C extension
# module dict is a plain mutable dict, consistent with the universal pattern that all
# module-level __dict__ objects are plain 'dict' — regardless of whether the module
# is implemented in pure Python or as a C extension. The pattern holds for all six
# module dicts surveyed in this series: struct(dict), _struct(dict), hashlib(dict),
# _hashlib(dict), uuid(dict), socket(dict), _socket(dict). The contrast is with class
# __dict__ objects which are always 'mappingproxy' (12 chars). No prior socket spec
# anchors _socket.__dict__.__class__.__name__.__eq__('dict') as a standalone under
# sockc150. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra150.socket_c_dict_class_dict:
  description: "_socket.__dict__.__class__.__name__.__eq__('dict') == True — 'dict' (4 chars); C extension module dicts are plain mutable dicts, same as pure-Python module dicts; universal pattern: struct/_struct/hashlib/_hashlib/uuid/socket/_socket all are 'dict'; class dicts (_socket.socket/socket.socket/AddressFamily/SocketKind) are 'mappingproxy' (12 chars); no prior socket spec anchors this as a standalone; first standalone under sockc150"
  category: identity
  kind: python_call_eq
  function: "_socket.__dict__.__class__.__name__.__eq__"
  args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# _socket.__dict__.__contains__('IPPROTO_TCP') — standalone
#
# _socket.__dict__.__contains__('IPPROTO_TCP') is True. In _socket, IPPROTO_TCP is
# a raw C integer constant (the TCP protocol number, value 6). This is distinct from
# the public socket module where IPPROTO_TCP is still a plain int (not wrapped in an
# IntEnum like AF_INET is wrapped in AddressFamily). extra145 anchors
# socket.IPPROTO_TCP.__class__.__name__.__eq__('int') in the public socket namespace;
# this spec anchors its presence in the C extension namespace. No prior socket spec
# anchors _socket.__dict__.__contains__('IPPROTO_TCP') as a standalone under sockc150.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra150.socket_c_dict_contains_IPPROTO_TCP:
  description: "_socket.__dict__.__contains__('IPPROTO_TCP') == True — raw C integer constant (TCP protocol number = 6); present as plain int in both _socket and socket (not wrapped in IntEnum unlike AF_INET); extra145 anchors socket.IPPROTO_TCP.__class__.__name__.__eq__('int'); no prior socket spec anchors this as a standalone; first standalone under sockc150"
  category: identity
  kind: python_call_eq
  function: "_socket.__dict__.__contains__"
  args: ["IPPROTO_TCP"]
  expected: true

# ---------------------------------------------------------------------------
# _socket.socket.__dict__.__len__()==37 — standalone
#
# _socket.socket.__dict__.__len__() is 37. The C-level socket class dict (37 entries)
# is larger than the Python-level socket.socket class dict (28 entries, anchored in
# extra147 and extra149). The C type _socket.socket holds all socket operations as
# direct C-level method_descriptor and slot_wrapper objects, plus type metadata.
# The Python-level socket.socket inherits from _socket.socket but overrides/adds only
# a subset of methods in Python (accept, makefile, sendfile, detach, dup, close, etc.),
# so socket.socket.__dict__ (28) contains only the Python-level additions while
# _socket.socket.__dict__ (37) contains the full C-level implementation.
# No prior socket spec anchors _socket.socket.__dict__.__len__()==37 as a standalone
# under sockc150. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra150.socket_c_socket_dict_len_37:
  description: "_socket.socket.__dict__.__len__() == 37 — C-level class dict (37 entries) > Python-level socket.socket.__dict__ (28 entries, extra149); _socket.socket holds all C-level method_descriptor/slot_wrapper objects; socket.socket inherits C methods and adds Python overrides only (accept/makefile/sendfile/detach/dup/close/etc.); no prior socket spec anchors this as a standalone; first standalone under sockc150"
  category: identity
  kind: python_call_eq
  function: "_socket.socket.__dict__.__len__"
  args: []
  expected: 37

