spec: pathlib_extra1681
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython pathlib source: Lib/pathlib/"
    - "pathlib_extra1666.zspec.zsdl — covers __new__ and __init__ construction protocol"
    - "pathlib_extra1651.zspec.zsdl — covers __init_subclass__, __class_getitem__, module attr presence"
  notes:
    - "Wave 559 (_extra1681): __call__ callable protocol — which pathlib types define __call__ in their own __dict__."
    - "No pathlib type defines __call__ in its own __dict__. Path objects are filesystem handles, not callables."
    - "pathlib.Path defines __truediv__ (/) for path joining in its own __dict__."
    - "pathlib.Path defines __fspath__ in its own __dict__ (os.fspath() protocol)."
    - "pathlib.Path defines __enter__ in its own __dict__ (context manager for open())."
    - "PurePath defines __truediv__ and __rtruediv__ for pure-path joining."
    - "PurePath defines __str__, __fspath__, __bytes__ — string/bytes conversion protocols."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table pathlib_extra1681.callable_protocol
# __call__ is absent from every pathlib type's own __dict__.
# Path objects are filesystem handles; they are not callable.
# ---------------------------------------------------------------------------

table pathlib_extra1681.callable_protocol:
  description: "pathlib types __call__ dict-presence checks — no pathlib type defines __call__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1681

  columns: [id, function, args, expected]
  rows:
    - ["pl1681001", PurePath.__dict__.__contains__,        ["__call__"], false]
    - ["pl1681002", PurePosixPath.__dict__.__contains__,   ["__call__"], false]
    - ["pl1681003", PureWindowsPath.__dict__.__contains__, ["__call__"], false]
    - ["pl1681004", Path.__dict__.__contains__,            ["__call__"], false]
    - ["pl1681005", PosixPath.__dict__.__contains__,       ["__call__"], false]
    - ["pl1681006", WindowsPath.__dict__.__contains__,     ["__call__"], false]

# ---------------------------------------------------------------------------
# Table pathlib_extra1681.division_operator_protocol
# PurePath defines __truediv__ and __rtruediv__ for path joining via /.
# Path inherits these from PurePath and does not re-define them.
# ---------------------------------------------------------------------------

table pathlib_extra1681.division_operator_protocol:
  description: "Path division operator (__truediv__/__rtruediv__) dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1681

  columns: [id, function, args, expected]
  rows:
    - ["pl1681007", PurePath.__dict__.__contains__,        ["__truediv__"],  true]
    - ["pl1681008", PurePath.__dict__.__contains__,        ["__rtruediv__"], true]
    - ["pl1681009", Path.__dict__.__contains__,            ["__truediv__"],  true]
    - ["pl1681010", Path.__dict__.__contains__,            ["__rtruediv__"], false]
    - ["pl1681011", PurePosixPath.__dict__.__contains__,   ["__truediv__"],  false]
    - ["pl1681012", PurePosixPath.__dict__.__contains__,   ["__rtruediv__"], false]
    - ["pl1681013", PosixPath.__dict__.__contains__,       ["__truediv__"],  false]
    - ["pl1681014", PosixPath.__dict__.__contains__,       ["__rtruediv__"], false]

# ---------------------------------------------------------------------------
# Table pathlib_extra1681.fspath_context_manager_protocol
# Path defines __fspath__ (os.fspath() protocol) and __enter__ (context manager).
# PurePath defines __fspath__ for pure-path use.
# ---------------------------------------------------------------------------

table pathlib_extra1681.fspath_context_manager_protocol:
  description: "os.fspath() and context manager protocol dict-presence checks for pathlib types"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1681

  columns: [id, function, args, expected]
  rows:
    - ["pl1681015", PurePath.__dict__.__contains__,        ["__fspath__"], true]
    - ["pl1681016", Path.__dict__.__contains__,            ["__fspath__"], true]
    - ["pl1681017", PurePosixPath.__dict__.__contains__,   ["__fspath__"], false]
    - ["pl1681018", PosixPath.__dict__.__contains__,       ["__fspath__"], false]
    - ["pl1681019", Path.__dict__.__contains__,            ["__enter__"],  true]
    - ["pl1681020", Path.__dict__.__contains__,            ["__exit__"],   true]
    - ["pl1681021", PurePath.__dict__.__contains__,        ["__enter__"],  false]
    - ["pl1681022", PurePath.__dict__.__contains__,        ["__exit__"],   false]
    - ["pl1681023", PurePosixPath.__dict__.__contains__,   ["__enter__"],  false]
    - ["pl1681024", PosixPath.__dict__.__contains__,       ["__enter__"],  false]
    - ["pl1681025", PurePath.__dict__.__contains__,        ["__str__"],    true]
    - ["pl1681026", PurePath.__dict__.__contains__,        ["__bytes__"],  true]
    - ["pl1681027", Path.__dict__.__contains__,            ["__str__"],    false]
    - ["pl1681028", Path.__dict__.__contains__,            ["__bytes__"],  false]
