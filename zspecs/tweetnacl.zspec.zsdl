spec: tweetnacl
version: ">=1.0.0"
backend: node(tweetnacl)

docs: https://github.com/dchest/tweetnacl-js#readme

provenance:
  derived_from:
    - "tweetnacl-js README — https://github.com/dchest/tweetnacl-js#readme"
    - "TweetNaCl reference (Bernstein et al.) — https://tweetnacl.cr.yp.to"
    - "RFC 8032 (EdDSA), Curve25519 / X25519, XSalsa20-Poly1305"
    - "Test vectors verified with tweetnacl via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "tweetnacl source"
  notes:
    - "Port of TweetNaCl — Curve25519, Ed25519, XSalsa20-Poly1305, SHA-512."
    - "Install: npm install tweetnacl"
    - "v1 CJS; namespaces secretbox / box / sign / hash / scalarMult, plus randomBytes / verify."
    - "Constants verified here are derived from the underlying primitives (Curve25519 = 32B keys, Ed25519 = 32B pub / 64B sec / 64B sig, XSalsa20-Poly1305 = 32B key / 24B nonce / 16B MAC, SHA-512 = 64B digest)."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "All primitives operate on Uint8Array; throw on type mismatch."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# secretbox (XSalsa20-Poly1305) constants
invariant tweetnacl.secretbox_keyLength:
  description: "secretbox.keyLength is 32 bytes"
  category: secretbox
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "secretbox.keyLength"}
  expected: 32

invariant tweetnacl.secretbox_nonceLength:
  description: "secretbox.nonceLength is 24 bytes"
  category: secretbox
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "secretbox.nonceLength"}
  expected: 24

invariant tweetnacl.secretbox_overheadLength:
  description: "secretbox.overheadLength is 16 bytes (Poly1305 MAC)"
  category: secretbox
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "secretbox.overheadLength"}
  expected: 16

# box (Curve25519 + XSalsa20-Poly1305) constants
invariant tweetnacl.box_publicKeyLength:
  description: "box.publicKeyLength is 32 bytes (Curve25519)"
  category: box
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "box.publicKeyLength"}
  expected: 32

invariant tweetnacl.box_secretKeyLength:
  description: "box.secretKeyLength is 32 bytes (Curve25519)"
  category: box
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "box.secretKeyLength"}
  expected: 32

invariant tweetnacl.box_nonceLength:
  description: "box.nonceLength is 24 bytes"
  category: box
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "box.nonceLength"}
  expected: 24

# sign (Ed25519) constants
invariant tweetnacl.sign_publicKeyLength:
  description: "sign.publicKeyLength is 32 bytes (Ed25519)"
  category: sign
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "sign.publicKeyLength"}
  expected: 32

invariant tweetnacl.sign_secretKeyLength:
  description: "sign.secretKeyLength is 64 bytes (Ed25519 expanded secret)"
  category: sign
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "sign.secretKeyLength"}
  expected: 64

invariant tweetnacl.sign_signatureLength:
  description: "sign.signatureLength is 64 bytes"
  category: sign
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "sign.signatureLength"}
  expected: 64

# hash (SHA-512)
invariant tweetnacl.hash_hashLength:
  description: "hash.hashLength is 64 bytes (SHA-512)"
  category: hash
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "hash.hashLength"}
  expected: 64
