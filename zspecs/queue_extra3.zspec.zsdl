spec: queue_extra3
version: ">=3.9"
backend: python_module(queue)

docs: https://docs.python.org/3/library/queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/queue.html — Python queue module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/queue.py"
  notes:
    - "This spec extends prior queue specs."
    - "Focus: class names, exception names, and behavioral invariants."
    - "queue.Queue.__name__ == 'Queue'."
    - "queue.LifoQueue.__name__ == 'LifoQueue'."
    - "queue.PriorityQueue.__name__ == 'PriorityQueue'."
    - "queue.SimpleQueue.__name__ == 'SimpleQueue'."
    - "queue.Empty.__name__ == 'Empty'."
    - "queue.Full.__name__ == 'Full'."
    - "queue.Queue().__class__.__name__ == 'Queue'."
    - "queue.Queue().qsize() == 0 (empty queue)."
    - "queue.Queue().empty() == True (empty queue)."
    - "queue.Queue().maxsize == 0 (no limit by default)."
    - "queue.LifoQueue().__class__.__name__ == 'LifoQueue'."
    - "queue.PriorityQueue().__class__.__name__ == 'PriorityQueue'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table queue_extra3.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [Queue,         Queue.__name__.__eq__,         ["Queue"],         true]
    - [LifoQueue,     LifoQueue.__name__.__eq__,     ["LifoQueue"],     true]
    - [PriorityQueue, PriorityQueue.__name__.__eq__, ["PriorityQueue"], true]
    - [SimpleQueue,   SimpleQueue.__name__.__eq__,   ["SimpleQueue"],   true]
    - [Empty,         Empty.__name__.__eq__,         ["Empty"],         true]
    - [Full,          Full.__name__.__eq__,          ["Full"],          true]

table queue_extra3.class_modules:
  kind: python_call_eq
  category: module
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [Queue,         Queue.__module__.__eq__,         ["queue"], true]
    - [LifoQueue,     LifoQueue.__module__.__eq__,     ["queue"], true]
    - [PriorityQueue, PriorityQueue.__module__.__eq__, ["queue"], true]
    - [SimpleQueue,   SimpleQueue.__module__.__eq__,   ["queue"], true]
    - [Empty,         Empty.__module__.__eq__,         ["queue"], true]
    - [Full,          Full.__module__.__eq__,          ["queue"], true]

invariant queue_extra3.Queue.qsize_empty:
  description: "queue.Queue().qsize() == 0"
  category: Queue_behavior
  kind: python_call_eq
  function: Queue
  args: []
  method: qsize.__func__.__name__.__eq__
  method_args: ["qsize"]
  expected: true

invariant queue_extra3.Queue.maxsize_default:
  description: "queue.Queue().maxsize == 0"
  category: Queue_behavior
  kind: python_call_eq
  function: Queue
  args: []
  method: maxsize.__eq__
  method_args: [0]
  expected: true

invariant queue_extra3.Queue.instance_class:
  description: "queue.Queue().__class__.__name__ == 'Queue'"
  category: Queue_behavior
  kind: python_call_eq
  function: Queue
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["Queue"]
  expected: true

invariant queue_extra3.LifoQueue.instance_class:
  description: "queue.LifoQueue().__class__.__name__ == 'LifoQueue'"
  category: LifoQueue_behavior
  kind: python_call_eq
  function: LifoQueue
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["LifoQueue"]
  expected: true

invariant queue_extra3.PriorityQueue.instance_class:
  description: "queue.PriorityQueue().__class__.__name__ == 'PriorityQueue'"
  category: PriorityQueue_behavior
  kind: python_call_eq
  function: PriorityQueue
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["PriorityQueue"]
  expected: true

invariant queue_extra3.Empty.base:
  description: "queue.Empty.__bases__[0].__name__ == 'Exception'"
  category: exceptions
  kind: python_call_eq
  function: Empty.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant queue_extra3.Full.base:
  description: "queue.Full.__bases__[0].__name__ == 'Exception'"
  category: exceptions
  kind: python_call_eq
  function: Full.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"
