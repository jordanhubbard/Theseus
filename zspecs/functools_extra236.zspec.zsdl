spec: functools_extra236
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers functools.wraps and functools.update_wrapper behavioral contracts: __name__, __qualname__, __module__, and name length."
    - "functools.wraps.__name__ == 'wraps' — wraps is a Python-level decorator in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.wraps.__module__ == 'functools' — defined in the functools module. Verified with Python 3.14.3."
    - "functools.wraps.__qualname__ == 'wraps' — top-level function with unqualified qualname. Verified with Python 3.14.3."
    - "functools.wraps.__name__.__len__() == 5 — 'wraps' has 5 characters. Verified with Python 3.14.3."
    - "functools.update_wrapper.__name__ == 'update_wrapper' — update_wrapper is a Python-level function in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.update_wrapper.__module__ == 'functools' — defined in the functools module. Verified with Python 3.14.3."
    - "functools.update_wrapper.__qualname__ == 'update_wrapper' — top-level function with unqualified qualname. Verified with Python 3.14.3."
    - "functools.update_wrapper.__name__.__len__() == 14 — 'update_wrapper' has 14 characters. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS is a tuple of length 6: ('__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.wraps identity contracts
#
# functools.wraps.__name__ == 'wraps'
# functools.wraps.__qualname__ == 'wraps'
# functools.wraps.__module__ == 'functools'
# functools.wraps.__name__.__len__() == 5
# functools.wraps.__qualname__.__len__() == 5
#
# New to extra236.
# ---------------------------------------------------------------------------

table functools_extra236.wraps_identity:
  description: "functools.wraps identity contracts: __name__, __qualname__, __module__, name length; new to extra236"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra236wrapsid

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_name_eq,
       wraps.__name__.__eq__,
       ["wraps"],
       true,
       "functools.wraps.__name__ == 'wraps' — wraps is a convenience decorator in Lib/functools.py that calls update_wrapper; __name__.__eq__('wraps') returns True; new to extra236"]
    - [wraps_qualname_eq,
       wraps.__qualname__.__eq__,
       ["wraps"],
       true,
       "functools.wraps.__qualname__ == 'wraps' — wraps is a top-level function with unqualified qualname 'wraps'; __qualname__.__eq__('wraps') returns True; new to extra236"]
    - [wraps_module_eq,
       wraps.__module__.__eq__,
       ["functools"],
       true,
       "functools.wraps.__module__ == 'functools' — wraps is defined in the Python functools module (Lib/functools.py); __module__.__eq__('functools') returns True; new to extra236"]
    - [wraps_name_len_5,
       wraps.__name__.__len__,
       [],
       5,
       "functools.wraps.__name__.__len__() == 5 — 'wraps' has exactly 5 characters (w-r-a-p-s); __len__() returns 5; new to extra236"]
    - [wraps_qualname_len_5,
       wraps.__qualname__.__len__,
       [],
       5,
       "functools.wraps.__qualname__.__len__() == 5 — qualname 'wraps' has exactly 5 characters; __len__() returns 5; new to extra236"]

# ---------------------------------------------------------------------------
# Table 2: functools.update_wrapper identity contracts
#
# functools.update_wrapper.__name__ == 'update_wrapper'
# functools.update_wrapper.__qualname__ == 'update_wrapper'
# functools.update_wrapper.__module__ == 'functools'
# functools.update_wrapper.__name__.__len__() == 14
# functools.update_wrapper.__qualname__.__len__() == 14
#
# New to extra236.
# ---------------------------------------------------------------------------

table functools_extra236.update_wrapper_identity:
  description: "functools.update_wrapper identity contracts: __name__, __qualname__, __module__, name length; new to extra236"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra236updatewrapid

  columns: [id, function, args, expected, description]
  rows:
    - [update_wrapper_name_eq,
       update_wrapper.__name__.__eq__,
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__name__ == 'update_wrapper' — update_wrapper is a top-level function in Lib/functools.py that copies wrapper attributes; __name__.__eq__('update_wrapper') returns True; new to extra236"]
    - [update_wrapper_qualname_eq,
       update_wrapper.__qualname__.__eq__,
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__qualname__ == 'update_wrapper' — update_wrapper is a top-level function with unqualified qualname 'update_wrapper'; __qualname__.__eq__('update_wrapper') returns True; new to extra236"]
    - [update_wrapper_module_eq,
       update_wrapper.__module__.__eq__,
       ["functools"],
       true,
       "functools.update_wrapper.__module__ == 'functools' — update_wrapper is defined in the Python functools module (Lib/functools.py); __module__.__eq__('functools') returns True; new to extra236"]
    - [update_wrapper_name_len_14,
       update_wrapper.__name__.__len__,
       [],
       14,
       "functools.update_wrapper.__name__.__len__() == 14 — 'update_wrapper' has exactly 14 characters (u-p-d-a-t-e-_-w-r-a-p-p-e-r); __len__() returns 14; new to extra236"]
    - [update_wrapper_qualname_len_14,
       update_wrapper.__qualname__.__len__,
       [],
       14,
       "functools.update_wrapper.__qualname__.__len__() == 14 — qualname 'update_wrapper' has exactly 14 characters; __len__() returns 14; new to extra236"]

# ---------------------------------------------------------------------------
# Table 3: functools.WRAPPER_ASSIGNMENTS contracts
#
# functools.WRAPPER_ASSIGNMENTS is a tuple
# functools.WRAPPER_ASSIGNMENTS.__len__() == 6
# '__name__' in functools.WRAPPER_ASSIGNMENTS
# '__module__' in functools.WRAPPER_ASSIGNMENTS
# '__qualname__' in functools.WRAPPER_ASSIGNMENTS
#
# New to extra236.
# ---------------------------------------------------------------------------

table functools_extra236.wrapper_assignments_contracts:
  description: "functools.WRAPPER_ASSIGNMENTS tuple membership and length contracts; new to extra236"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra236wrapassnid

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_assignments_len_6,
       WRAPPER_ASSIGNMENTS.__len__,
       [],
       6,
       "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — the tuple lists 6 attributes copied by update_wrapper: __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__; __len__() returns 6; new to extra236"]
    - [wrapper_assignments_has_name,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__name__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True — '__name__' is one of the attributes copied by update_wrapper; __contains__('__name__') returns True; new to extra236"]
    - [wrapper_assignments_has_module,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__module__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True — '__module__' is one of the attributes copied by update_wrapper; __contains__('__module__') returns True; new to extra236"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra236
# ---------------------------------------------------------------------------

invariant functools_extra236.wraps_name_eq:
  description: "functools.wraps.__name__ == 'wraps'; new to extra236"
  kind: python_call_eq
  function: wraps.__name__.__eq__
  args: ["wraps"]
  expected: true

invariant functools_extra236.wraps_qualname_eq:
  description: "functools.wraps.__qualname__ == 'wraps'; new to extra236"
  kind: python_call_eq
  function: wraps.__qualname__.__eq__
  args: ["wraps"]
  expected: true

invariant functools_extra236.wraps_module_eq:
  description: "functools.wraps.__module__ == 'functools'; new to extra236"
  kind: python_call_eq
  function: wraps.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra236.wraps_name_len_5:
  description: "functools.wraps.__name__.__len__() == 5 — 'wraps' has 5 characters; new to extra236"
  kind: python_call_eq
  function: wraps.__name__.__len__
  args: []
  expected: 5

invariant functools_extra236.update_wrapper_name_eq:
  description: "functools.update_wrapper.__name__ == 'update_wrapper'; new to extra236"
  kind: python_call_eq
  function: update_wrapper.__name__.__eq__
  args: ["update_wrapper"]
  expected: true

invariant functools_extra236.update_wrapper_qualname_eq:
  description: "functools.update_wrapper.__qualname__ == 'update_wrapper'; new to extra236"
  kind: python_call_eq
  function: update_wrapper.__qualname__.__eq__
  args: ["update_wrapper"]
  expected: true

invariant functools_extra236.update_wrapper_module_eq:
  description: "functools.update_wrapper.__module__ == 'functools'; new to extra236"
  kind: python_call_eq
  function: update_wrapper.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra236.update_wrapper_name_len_14:
  description: "functools.update_wrapper.__name__.__len__() == 14 — 'update_wrapper' has 14 characters; new to extra236"
  kind: python_call_eq
  function: update_wrapper.__name__.__len__
  args: []
  expected: 14

invariant functools_extra236.wrapper_assignments_len_6:
  description: "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — tuple of 6 attributes copied by update_wrapper; new to extra236"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

invariant functools_extra236.wrapper_assignments_has_name:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True; new to extra236"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__name__"]
  expected: true

invariant functools_extra236.wrapper_assignments_has_module:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True; new to extra236"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__module__"]
  expected: true
