spec: attrs_rust
version: ">=3.9"
backend: rust_module(attrs_rust)

docs: https://www.attrs.org/en/stable/

provenance:
  derived_from:
    - "https://www.attrs.org/en/stable/ — attrs documentation"
  not_derived_from:
    - "attrs source: src/attr/__init__.py"
  notes:
    - "attrs provides class decorators for boilerplate reduction."
    - "@attr.s class Point: x = attr.ib(); y = attr.ib(); Point(1, 2).x == 1."
    - "@attr.s class Point: x = attr.ib(); Point(x=5).x == 5."
    - "attr.fields(Point) gives the field descriptors."
    - "Expose attrs_point_x(x, y) -> int: Point(x=x, y=y).x using attrs."
    - "Expose attrs_point_y(x, y) -> int: Point(x=x, y=y).y using attrs."
    - "Expose attrs_field_count() -> int: len(attr.fields(Point))."
    - "All test vectors verified against attrs 24.3.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# attrs_point_x — x field of attrs class
table attrs_rust.point.x_field:
  kind: python_call_eq
  category: x_field
  id_prefix: at_x
  function: attrs_point_x

  columns: [id, args, expected]
  rows:
    - [one,  [1, 2], 1]
    - [five, [5, 0], 5]

# attrs_point_y — y field of attrs class
table attrs_rust.point.y_field:
  kind: python_call_eq
  category: y_field
  id_prefix: at_y
  function: attrs_point_y

  columns: [id, args, expected]
  rows:
    - [two,  [1, 2], 2]
    - [zero, [5, 0], 0]

# attrs_field_count — Point has 2 fields
invariant attrs_rust.fields.count:
  description: "Point has 2 fields (x and y)"
  category: fields
  kind: python_call_eq
  function: attrs_field_count
  args: []
  expected: 2

