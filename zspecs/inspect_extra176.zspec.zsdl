spec: inspect_extra176
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect module function identity — inspect.getmembers.__name__=='getmembers' (len=10); inspect.getmembers.__module__=='inspect'; inspect.isfunction.__name__=='isfunction' (len=10; same as getmembers); inspect.isclass.__name__=='isclass' (len=7); inspect.ismethod.__name__=='ismethod' (len=8); inspect.ismodule.__name__=='ismodule' (len=8; same as ismethod); inspect.getdoc.__name__=='getdoc' (len=6); inspect.getsource.__name__=='getsource' (len=9)."
    - "inspect.getmembers.__name__ == 'getmembers' — getmembers is a Python function in Lib/inspect.py that returns all the members of an object in a list of (name, value) pairs; its __name__ is 'getmembers', 10 characters. Verified with Python 3.14.3."
    - "inspect.getmembers.__module__ == 'inspect' — getmembers is defined in Lib/inspect.py; its __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.isfunction.__name__ == 'isfunction' — isfunction is a Python function in Lib/inspect.py; its __name__ is 'isfunction', 10 characters, same length as 'getmembers'. Verified with Python 3.14.3."
    - "inspect.isclass.__name__ == 'isclass' — isclass is a Python function in Lib/inspect.py; its __name__ is 'isclass', 7 characters. Verified with Python 3.14.3."
    - "inspect.ismethod.__name__ == 'ismethod' — ismethod is a Python function in Lib/inspect.py; its __name__ is 'ismethod', 8 characters. Verified with Python 3.14.3."
    - "inspect.ismodule.__name__ == 'ismodule' — ismodule is a Python function in Lib/inspect.py; its __name__ is 'ismodule', 8 characters, same length as 'ismethod'. Verified with Python 3.14.3."
    - "inspect.getdoc.__name__ == 'getdoc' — getdoc is a Python function in Lib/inspect.py that retrieves the docstring for an object; its __name__ is 'getdoc', 6 characters. Verified with Python 3.14.3."
    - "inspect.getsource.__name__ == 'getsource' — getsource is a Python function in Lib/inspect.py that returns the source code for an object; its __name__ is 'getsource', 9 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.getmembers and inspect.isfunction __name__
#
# inspect.getmembers.__name__ == 'getmembers'
# inspect.getmembers.__name__.__len__() == 10
# inspect.getmembers.__module__ == 'inspect'
# inspect.isfunction.__name__ == 'isfunction'
#
# inspect.getmembers is a Python function in Lib/inspect.py that returns all
# members of an object as (name, value) pairs. Its __name__ is 'getmembers'
# (10 chars) and its __module__ is 'inspect'. inspect.isfunction has the same
# name length. New to extra176.
# ---------------------------------------------------------------------------

table inspect_extra176.getmembers_and_isfunction_name:
  description: "inspect.getmembers.__name__ 'getmembers' len 10; __module__ 'inspect'; isfunction.__name__ 'isfunction' len 10; new to extra176"
  kind: python_call_eq
  category: identity
  id_prefix: inspectfns176

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_name_eq,
       "getmembers.__name__.__eq__",
       ["getmembers"],
       true,
       "inspect.getmembers.__name__.__eq__('getmembers') == True — inspect.getmembers is a Python function in Lib/inspect.py that returns all members of an object as a sorted list of (name, value) pairs; its __name__ is 'getmembers'; str.__eq__('getmembers') returns True; new to extra176"]
    - [getmembers_name_len_10,
       "getmembers.__name__.__len__",
       [],
       10,
       "inspect.getmembers.__name__.__len__() == 10 — the name 'getmembers' has exactly 10 characters: g-e-t-m-e-m-b-e-r-s; str.__len__() returns 10; new to extra176"]
    - [getmembers_module_inspect,
       "getmembers.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getmembers.__module__.__eq__('inspect') == True — inspect.getmembers is a Python function defined in Lib/inspect.py; its __module__ is the string 'inspect'; str.__eq__('inspect') returns True; new to extra176"]
    - [isfunction_name_eq,
       "isfunction.__name__.__eq__",
       ["isfunction"],
       true,
       "inspect.isfunction.__name__.__eq__('isfunction') == True — inspect.isfunction is a Python function in Lib/inspect.py returning True if the object is a Python function; its __name__ is 'isfunction'; the name length (10) is the same as 'getmembers'; str.__eq__('isfunction') returns True; new to extra176"]

# ---------------------------------------------------------------------------
# Table 2: inspect.isfunction name length and inspect.isclass, ismethod names
#
# inspect.isfunction.__name__.__len__() == 10
# inspect.isclass.__name__ == 'isclass'
# inspect.isclass.__name__.__len__() == 7
# inspect.ismethod.__name__ == 'ismethod'
#
# isfunction has __name__ 'isfunction' (10 chars). isclass has __name__
# 'isclass' (7 chars). ismethod has __name__ 'ismethod' (8 chars). New to
# extra176.
# ---------------------------------------------------------------------------

table inspect_extra176.isfunction_len_and_isclass_ismethod_name:
  description: "inspect.isfunction.__name__ len 10; isclass.__name__ 'isclass' len 7; ismethod.__name__ 'ismethod' len 8; new to extra176"
  kind: python_call_eq
  category: identity
  id_prefix: inspectfns176

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_name_len_10,
       "isfunction.__name__.__len__",
       [],
       10,
       "inspect.isfunction.__name__.__len__() == 10 — the name 'isfunction' has exactly 10 characters: i-s-f-u-n-c-t-i-o-n; same length as 'getmembers' (10); str.__len__() returns 10; new to extra176"]
    - [isclass_name_eq,
       "isclass.__name__.__eq__",
       ["isclass"],
       true,
       "inspect.isclass.__name__.__eq__('isclass') == True — inspect.isclass is a Python function in Lib/inspect.py returning True if the object is a class; its __name__ is 'isclass'; str.__eq__('isclass') returns True; new to extra176"]
    - [isclass_name_len_7,
       "isclass.__name__.__len__",
       [],
       7,
       "inspect.isclass.__name__.__len__() == 7 — the name 'isclass' has exactly 7 characters: i-s-c-l-a-s-s; str.__len__() returns 7; new to extra176"]
    - [ismethod_name_eq,
       "ismethod.__name__.__eq__",
       ["ismethod"],
       true,
       "inspect.ismethod.__name__.__eq__('ismethod') == True — inspect.ismethod is a Python function in Lib/inspect.py returning True if the object is a bound method written in Python; its __name__ is 'ismethod'; str.__eq__('ismethod') returns True; new to extra176"]

# ---------------------------------------------------------------------------
# Table 3: inspect.ismethod, ismodule, getdoc name lengths
#
# inspect.ismethod.__name__.__len__() == 8
# inspect.ismodule.__name__ == 'ismodule'
# inspect.ismodule.__name__.__len__() == 8
# inspect.getdoc.__name__ == 'getdoc'
#
# ismethod and ismodule both have 8-character names. getdoc has __name__
# 'getdoc' (6 chars). New to extra176.
# ---------------------------------------------------------------------------

table inspect_extra176.ismethod_len_ismodule_getdoc_name:
  description: "inspect.ismethod.__name__ len 8; ismodule.__name__ 'ismodule' len 8 (same); getdoc.__name__ 'getdoc' len 6; new to extra176"
  kind: python_call_eq
  category: identity
  id_prefix: inspectfns176

  columns: [id, function, args, expected, description]
  rows:
    - [ismethod_name_len_8,
       "ismethod.__name__.__len__",
       [],
       8,
       "inspect.ismethod.__name__.__len__() == 8 — the name 'ismethod' has exactly 8 characters: i-s-m-e-t-h-o-d; str.__len__() returns 8; new to extra176"]
    - [ismodule_name_eq,
       "ismodule.__name__.__eq__",
       ["ismodule"],
       true,
       "inspect.ismodule.__name__.__eq__('ismodule') == True — inspect.ismodule is a Python function in Lib/inspect.py returning True if the object is a module; its __name__ is 'ismodule'; str.__eq__('ismodule') returns True; new to extra176"]
    - [ismodule_name_len_8,
       "ismodule.__name__.__len__",
       [],
       8,
       "inspect.ismodule.__name__.__len__() == 8 — the name 'ismodule' has exactly 8 characters: i-s-m-o-d-u-l-e; same length as 'ismethod' (8); str.__len__() returns 8; new to extra176"]
    - [getdoc_name_eq,
       "getdoc.__name__.__eq__",
       ["getdoc"],
       true,
       "inspect.getdoc.__name__.__eq__('getdoc') == True — inspect.getdoc is a Python function in Lib/inspect.py that returns the docstring for an object, cleaning it up with cleandoc; its __name__ is 'getdoc'; str.__eq__('getdoc') returns True; new to extra176"]

# ---------------------------------------------------------------------------
# Table 4: inspect.getdoc name length and inspect.getsource __name__
#
# inspect.getdoc.__name__.__len__() == 6
# inspect.getsource.__name__ == 'getsource'
# inspect.getsource.__name__.__len__() == 9
# inspect.getsource.__module__ == 'inspect'
#
# getdoc has __name__ 'getdoc' (6 chars). getsource has __name__ 'getsource'
# (9 chars) and __module__ 'inspect'. New to extra176.
# ---------------------------------------------------------------------------

table inspect_extra176.getdoc_len_and_getsource_name_module:
  description: "inspect.getdoc.__name__ len 6; getsource.__name__ 'getsource' len 9; getsource.__module__ 'inspect'; new to extra176"
  kind: python_call_eq
  category: identity
  id_prefix: inspectfns176

  columns: [id, function, args, expected, description]
  rows:
    - [getdoc_name_len_6,
       "getdoc.__name__.__len__",
       [],
       6,
       "inspect.getdoc.__name__.__len__() == 6 — the name 'getdoc' has exactly 6 characters: g-e-t-d-o-c; str.__len__() returns 6; new to extra176"]
    - [getsource_name_eq,
       "getsource.__name__.__eq__",
       ["getsource"],
       true,
       "inspect.getsource.__name__.__eq__('getsource') == True — inspect.getsource is a Python function in Lib/inspect.py that returns the text of the source code for an object (function, method, class, or module); its __name__ is 'getsource'; str.__eq__('getsource') returns True; new to extra176"]
    - [getsource_name_len_9,
       "getsource.__name__.__len__",
       [],
       9,
       "inspect.getsource.__name__.__len__() == 9 — the name 'getsource' has exactly 9 characters: g-e-t-s-o-u-r-c-e; str.__len__() returns 9; new to extra176"]
    - [getsource_module_inspect,
       "getsource.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getsource.__module__.__eq__('inspect') == True — inspect.getsource is a Python function defined in Lib/inspect.py; its __module__ is the string 'inspect'; str.__eq__('inspect') returns True; new to extra176"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra176
# ---------------------------------------------------------------------------

invariant inspect_extra176.getmembers_name_getmembers:
  description: "inspect.getmembers.__name__ == 'getmembers' — Python function in Lib/inspect.py with __name__ 'getmembers' (10 chars); new to extra176"
  kind: python_call_eq
  function: getmembers.__name__.__eq__
  args: ["getmembers"]
  expected: true

invariant inspect_extra176.getmembers_name_len_10:
  description: "inspect.getmembers.__name__.__len__() == 10 — 'getmembers' is 10 characters long; new to extra176"
  kind: python_call_eq
  function: getmembers.__name__.__len__
  args: []
  expected: 10

invariant inspect_extra176.getmembers_module_inspect:
  description: "inspect.getmembers.__module__ == 'inspect' — getmembers is defined in Lib/inspect.py; new to extra176"
  kind: python_call_eq
  function: getmembers.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra176.isfunction_name_isfunction:
  description: "inspect.isfunction.__name__ == 'isfunction' — Python function in Lib/inspect.py with __name__ 'isfunction' (10 chars, same length as getmembers); new to extra176"
  kind: python_call_eq
  function: isfunction.__name__.__eq__
  args: ["isfunction"]
  expected: true

invariant inspect_extra176.isclass_name_isclass:
  description: "inspect.isclass.__name__ == 'isclass' — Python function in Lib/inspect.py with __name__ 'isclass' (7 chars); new to extra176"
  kind: python_call_eq
  function: isclass.__name__.__eq__
  args: ["isclass"]
  expected: true

invariant inspect_extra176.isclass_name_len_7:
  description: "inspect.isclass.__name__.__len__() == 7 — 'isclass' is 7 characters long; new to extra176"
  kind: python_call_eq
  function: isclass.__name__.__len__
  args: []
  expected: 7

invariant inspect_extra176.ismethod_name_ismethod:
  description: "inspect.ismethod.__name__ == 'ismethod' — Python function in Lib/inspect.py with __name__ 'ismethod' (8 chars); new to extra176"
  kind: python_call_eq
  function: ismethod.__name__.__eq__
  args: ["ismethod"]
  expected: true

invariant inspect_extra176.ismodule_name_ismodule:
  description: "inspect.ismodule.__name__ == 'ismodule' — Python function in Lib/inspect.py with __name__ 'ismodule' (8 chars, same length as ismethod); new to extra176"
  kind: python_call_eq
  function: ismodule.__name__.__eq__
  args: ["ismodule"]
  expected: true

invariant inspect_extra176.ismodule_name_len_8:
  description: "inspect.ismodule.__name__.__len__() == 8 — 'ismodule' is 8 characters long, same length as 'ismethod'; new to extra176"
  kind: python_call_eq
  function: ismodule.__name__.__len__
  args: []
  expected: 8

invariant inspect_extra176.getdoc_name_getdoc:
  description: "inspect.getdoc.__name__ == 'getdoc' — Python function in Lib/inspect.py with __name__ 'getdoc' (6 chars); new to extra176"
  kind: python_call_eq
  function: getdoc.__name__.__eq__
  args: ["getdoc"]
  expected: true

invariant inspect_extra176.getsource_name_getsource:
  description: "inspect.getsource.__name__ == 'getsource' — Python function in Lib/inspect.py with __name__ 'getsource' (9 chars); new to extra176"
  kind: python_call_eq
  function: getsource.__name__.__eq__
  args: ["getsource"]
  expected: true

invariant inspect_extra176.getsource_module_inspect:
  description: "inspect.getsource.__module__ == 'inspect' — getsource is defined in Lib/inspect.py; new to extra176"
  kind: python_call_eq
  function: getsource.__module__.__eq__
  args: ["inspect"]
  expected: true
