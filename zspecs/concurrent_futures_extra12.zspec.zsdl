spec: concurrent_futures_extra12
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
  notes:
    - "This spec extends concurrent_futures.zspec.zsdl and prior extras through concurrent_futures_extra11.zspec.zsdl."
    - "extra3 covers: Executor.map/__name__, Executor.shutdown/__name__, Executor/__module__."
    - "extra9 covers: ThreadPoolExecutor/__class__.__name__, ProcessPoolExecutor/__class__.__name__, ThreadPoolExecutor/__mro__[1].__name__, ProcessPoolExecutor/__mro__[1].__name__, ThreadPoolExecutor/__mro__[2].__name__, ProcessPoolExecutor/__mro__[2].__name__."
    - "extra11 covers: Future.add_done_callback/__qualname__, Future.set_result/__qualname__, Future.set_exception/__qualname__; Executor.map/__qualname__, Executor.shutdown/__qualname__, ProcessPoolExecutor.map/__qualname__, ProcessPoolExecutor.shutdown/__qualname__; BrokenExecutor/__mro__[2].__name__; BrokenExecutor/CancelledError/TimeoutError __class__.__name__."
    - "NOT yet covered in any prior spec: Executor.__class__.__name__ == 'type' — metaclass check for Executor itself."
    - "NOT yet covered: Future.__class__.__name__ == 'type' — metaclass check for Future."
    - "NOT yet covered: Executor.__mro__[1].__name__ == 'object' — MRO access path for Executor."
    - "NOT yet covered: Future.__mro__[1].__name__ == 'object' — MRO access path for Future."
    - "NOT yet covered: Future.set_result.__name__ == 'set_result' — method __name__ for set_result."
    - "NOT yet covered: Future.set_exception.__name__ == 'set_exception' — method __name__ for set_exception."
    - "NOT yet covered: Future.add_done_callback.__name__ == 'add_done_callback' — method __name__."
    - "NOT yet covered: InvalidStateError.__mro__[2].__name__ == 'Exception' — MRO depth check at index 2."
    - "NOT yet covered: ThreadPoolExecutor.map.__qualname__ == 'Executor.map' — inherits without override."
    - "concurrent.futures.Executor.__class__.__name__ == 'type' — Executor is a plain Python class."
    - "concurrent.futures.Future.__class__.__name__ == 'type' — Future is a plain Python class."
    - "concurrent.futures.Executor.__mro__[1].__name__ == 'object' — Executor inherits directly from object."
    - "concurrent.futures.Future.__mro__[1].__name__ == 'object' — Future inherits directly from object."
    - "concurrent.futures.Future.set_result.__name__ == 'set_result'."
    - "concurrent.futures.Future.set_exception.__name__ == 'set_exception'."
    - "concurrent.futures.Future.add_done_callback.__name__ == 'add_done_callback' — already in base spec, but __name__ not yet checked via this spec chain."
    - "concurrent.futures.InvalidStateError.__mro__[2].__name__ == 'Exception' — MRO is [InvalidStateError, Error, Exception, BaseException, object]."
    - "concurrent.futures.ThreadPoolExecutor.map.__qualname__ == 'Executor.map' — not overridden in ThreadPoolExecutor."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Executor and Future metaclass type checks
#
# extra9 covers ThreadPoolExecutor/__class__.__name__ and
# ProcessPoolExecutor/__class__.__name__. extra11 covers BrokenExecutor/
# CancelledError/TimeoutError __class__.__name__. No prior spec checks the
# metaclass for Executor itself or for Future.
# ---------------------------------------------------------------------------

table concurrent_futures_extra12.class_metaclass_names:
  description: "Executor and Future have __class__.__name__ == 'type'"
  kind: python_call_eq
  category: class_types
  id_prefix: cfcmeta12

  columns: [id, function, args, expected]
  rows:
    - [Executor, Executor.__class__.__name__.__eq__, ["type"], true]
    - [Future,   Future.__class__.__name__.__eq__,   ["type"], true]

# ---------------------------------------------------------------------------
# Executor and Future MRO index-based access
#
# extra4 covers ThreadPoolExecutor/__mro__[1] and ProcessPoolExecutor/__mro__[1].
# extra8 covers Future/__mro__[1].__name__. No wait — check extra8 again.
# extra9 covers ThreadPoolExecutor/__mro__[1] and /__mro__[2]. No prior spec
# checks Executor.__mro__[1] or Future.__mro__[1] directly.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra12.Executor.mro_index1:
  description: "concurrent.futures.Executor.__mro__[1].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: Executor.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "object"

invariant concurrent_futures_extra12.Future.mro_index1:
  description: "concurrent.futures.Future.__mro__[1].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: Future.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Future additional method __name__ checks
#
# The base spec covers Future.cancel/__name__, Future.result/__name__, and
# Future.add_done_callback/__name__. extra9 covers additional method __name__
# values (cancelled/running/done/exception/set_result). No prior spec checks
# __name__ for Future.set_exception. Future.add_done_callback.__name__ was
# covered in the base spec; this spec adds set_exception as a new axis.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra12.Future.set_exception.name:
  description: "concurrent.futures.Future.set_exception.__name__ == 'set_exception'"
  category: method_names
  kind: python_call_eq
  function: Future.set_exception.__name__.__eq__
  args: ["set_exception"]
  expected: true

# ---------------------------------------------------------------------------
# InvalidStateError MRO depth check
#
# extra9 covers InvalidStateError/__qualname__/__module__/__bases__[0].__name__.
# No prior spec checks InvalidStateError.__mro__[2]. InvalidStateError's MRO
# is [InvalidStateError, Error, Exception, BaseException, object], so index 2
# is Exception.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra12.InvalidStateError.mro_index2:
  description: "concurrent.futures.InvalidStateError.__mro__[2].__name__ == 'Exception'"
  category: class_hierarchy
  kind: python_call_eq
  function: InvalidStateError.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# ThreadPoolExecutor.map __qualname__ — inheritance without override
#
# ThreadPoolExecutor does not override Executor.map, so accessing
# ThreadPoolExecutor.map gives the same function object as Executor.map.
# Its __qualname__ is 'Executor.map' (not 'ThreadPoolExecutor.map').
# extra11 covers Executor.map/__qualname__ and ProcessPoolExecutor.map/__qualname__.
# No prior spec checks ThreadPoolExecutor.map/__qualname__.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra12.ThreadPoolExecutor.map.qualname:
  description: "concurrent.futures.ThreadPoolExecutor.map.__qualname__ == 'Executor.map' — not overridden"
  category: method_qualnames
  kind: python_call_eq
  function: ThreadPoolExecutor.map.__qualname__.__eq__
  args: ["Executor.map"]
  expected: true
