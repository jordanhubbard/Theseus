spec: socket_extra4
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
    - "socket.zspec.zsdl — covers AF_INET/AF_INET6/AF_UNIX values; SOCK_STREAM/DGRAM/RAW; IPPROTO_IP/TCP/UDP; SOL_SOCKET; SHUT_RD/WR/RDWR values; socket/herror/gaierror __name__; gethostname/getdefaulttimeout/inet_aton/inet_ntoa/htonl/ntohl function names"
    - "socket_extra.zspec.zsdl — covers create_connection/create_server/setdefaulttimeout/htons/ntohs function names; inet_aton/inet_ntoa/htonl/ntohl computation"
    - "socket_extra2.zspec.zsdl — covers AddressFamily class names for AF_INET/AF_INET6/AF_UNIX; SocketKind class names; AF_INET==2/SOCK_STREAM==1/SOCK_DGRAM==2; getfqdn/gethostname return type; socket.error/__name__; socket.timeout name and base"
    - "socket_extra3.zspec.zsdl — covers AddressFamily/__name__; SocketKind/__name__; herror/gaierror base hierarchy; IPPROTO_TCP/UDP class name; socket.socket.__module__"
    - "_socket.zspec.zsdl — covers _socket.getaddrinfo.__name__ == 'getaddrinfo'"
    - "_socket_extra.zspec.zsdl — covers additional _socket module invariants"
  notes:
    - "This spec extends the socket chain; it does NOT duplicate invariants present in any prior spec."
    - "socket.getaddrinfo.__name__ — the socket-namespace name check (not the _socket C-extension check already in _socket.zspec.zsdl)."
    - "socket.getnameinfo and socket.gethostbyname are module-level functions not checked in any prior spec."
    - "socket.SHUT_RD/SHUT_WR/SHUT_RDWR are plain int constants; their __class__.__name__ == 'int' on all platforms."
    - "socket.getfqdn.__name__ == 'getfqdn' — the function name check (socket_extra2 only tested return type)."
    - "socket.gethostbyaddr.__name__ == 'gethostbyaddr' — host-by-address lookup function identity."
    - "socket.getservbyname.__name__ == 'getservbyname' — service-by-name lookup function identity."
    - "socket.getprotobyname.__name__ == 'getprotobyname' — protocol-by-name lookup function identity."
    - "socket.SOL_SOCKET is a plain int (not an enum member) on all platforms; socket_extra3 only tested IPPROTO_TCP/UDP."
    - "socket.IPPROTO_IP is a plain int; socket_extra3 covers IPPROTO_TCP/UDP class names, this spec adds IPPROTO_IP."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "socket raises OSError (and subclasses herror, gaierror, timeout) for I/O and DNS failures. All invariants in this spec are pure attribute reads and do not perform network I/O."
  stderr: "null"
  stickiness: "N/A — all tested invariants are stateless function name or constant type checks."
  codes: {}

# ---------------------------------------------------------------------------
# Function name checks — getaddrinfo, getnameinfo, gethostbyname
# _socket.zspec.zsdl checks _socket.getaddrinfo.__name__; this spec checks
# the same function name through the socket namespace wrapper.
# getnameinfo and gethostbyname are not checked in any prior spec.
# ---------------------------------------------------------------------------

invariant socket_extra4.getaddrinfo.name:
  description: "socket.getaddrinfo.__name__ == 'getaddrinfo'"
  category: function_names
  kind: python_call_eq
  function: getaddrinfo.__name__.__eq__
  args: ["getaddrinfo"]
  expected: true

invariant socket_extra4.getnameinfo.name:
  description: "socket.getnameinfo.__name__ == 'getnameinfo'"
  category: function_names
  kind: python_call_eq
  function: getnameinfo.__name__.__eq__
  args: ["getnameinfo"]
  expected: true

invariant socket_extra4.gethostbyname.name:
  description: "socket.gethostbyname.__name__ == 'gethostbyname'"
  category: function_names
  kind: python_call_eq
  function: gethostbyname.__name__.__eq__
  args: ["gethostbyname"]
  expected: true

invariant socket_extra4.gethostbyaddr.name:
  description: "socket.gethostbyaddr.__name__ == 'gethostbyaddr'"
  category: function_names
  kind: python_call_eq
  function: gethostbyaddr.__name__.__eq__
  args: ["gethostbyaddr"]
  expected: true

invariant socket_extra4.getservbyname.name:
  description: "socket.getservbyname.__name__ == 'getservbyname'"
  category: function_names
  kind: python_call_eq
  function: getservbyname.__name__.__eq__
  args: ["getservbyname"]
  expected: true

invariant socket_extra4.getprotobyname.name:
  description: "socket.getprotobyname.__name__ == 'getprotobyname'"
  category: function_names
  kind: python_call_eq
  function: getprotobyname.__name__.__eq__
  args: ["getprotobyname"]
  expected: true

invariant socket_extra4.getfqdn.name:
  description: "socket.getfqdn.__name__ == 'getfqdn'"
  category: function_names
  kind: python_call_eq
  function: getfqdn.__name__.__eq__
  args: ["getfqdn"]
  expected: true

# ---------------------------------------------------------------------------
# SHUT_* constants — __class__.__name__ check
# socket.zspec.zsdl tests the integer values (0, 1, 2); this spec verifies
# that all three SHUT_* constants are plain int instances, not enum members.
# ---------------------------------------------------------------------------

table socket_extra4.shut_class_names:
  kind: python_call_eq
  category: constants
  id_prefix: shut_class

  columns: [id, function, args, expected, description]
  rows:
    - [SHUT_RD,   SHUT_RD.__class__.__name__.__eq__,   ["int"], true, "socket.SHUT_RD.__class__.__name__ == 'int'"]
    - [SHUT_WR,   SHUT_WR.__class__.__name__.__eq__,   ["int"], true, "socket.SHUT_WR.__class__.__name__ == 'int'"]
    - [SHUT_RDWR, SHUT_RDWR.__class__.__name__.__eq__,  ["int"], true, "socket.SHUT_RDWR.__class__.__name__ == 'int'"]

# ---------------------------------------------------------------------------
# SOL_SOCKET class name check
# socket.zspec.zsdl checks the integer value (65535 on macOS); this spec
# checks that SOL_SOCKET is a plain int instance, not an enum member.
# ---------------------------------------------------------------------------

invariant socket_extra4.SOL_SOCKET.class_name:
  description: "socket.SOL_SOCKET.__class__.__name__ == 'int' — SOL_SOCKET is a plain int constant"
  category: constants
  kind: python_call_eq
  function: SOL_SOCKET.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# IPPROTO_IP class name check
# socket.zspec.zsdl checks IPPROTO_IP == 0 (integer value); socket_extra3
# checks IPPROTO_TCP and IPPROTO_UDP class names. This spec adds IPPROTO_IP.
# ---------------------------------------------------------------------------

invariant socket_extra4.IPPROTO_IP.class_name:
  description: "socket.IPPROTO_IP.__class__.__name__ == 'int' — IPPROTO_IP is a plain int constant"
  category: constants
  kind: python_call_eq
  function: IPPROTO_IP.__class__.__name__.__eq__
  args: ["int"]
  expected: true
