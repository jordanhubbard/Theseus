spec: hashlib_extra1831
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "hashlib stdlib documentation"
    - "CPython source: Lib/hashlib.py"
  not_derived_from:
    - "third-party cryptography libraries"
  notes:
    - "hashlib hash constructors (sha256, md5, etc.) are builtin_function_or_method objects"
    - "builtin_function_or_method defines __call__ in its class __dict__"
    - "hashlib module itself is not callable — no __call__ in module __dict__"
    - "hash constructors do not define __get__, __set__, or __delete__ in their class __dict__"
    - "hashlib.new is a Python function (not builtin), but still callable"
    - "algorithms_guaranteed and algorithms_available are set objects in the module __dict__"
  created_at: "2026-04-12"

table hashlib_extra1831.descriptor_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["hl1831-dp-001", "hashlib.sha256.__class__.__dict__.__contains__", ["__get__"], false]
    - ["hl1831-dp-002", "hashlib.sha256.__class__.__dict__.__contains__", ["__set__"], false]
    - ["hl1831-dp-003", "hashlib.sha256.__class__.__dict__.__contains__", ["__delete__"], false]
    - ["hl1831-dp-004", "hashlib.md5.__class__.__dict__.__contains__", ["__get__"], false]
    - ["hl1831-dp-005", "hashlib.sha512.__class__.__dict__.__contains__", ["__get__"], false]
    - ["hl1831-dp-006", "hashlib.__dict__.__contains__", ["__get__"], false]
    - ["hl1831-dp-007", "hashlib.__dict__.__contains__", ["__set__"], false]
    - ["hl1831-dp-008", "hashlib.__dict__.__contains__", ["__delete__"], false]

table hashlib_extra1831.callable_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["hl1831-cp-001", "hashlib.sha256.__class__.__dict__.__contains__", ["__call__"], true]
    - ["hl1831-cp-002", "hashlib.md5.__class__.__dict__.__contains__", ["__call__"], true]
    - ["hl1831-cp-003", "hashlib.sha512.__class__.__dict__.__contains__", ["__call__"], true]
    - ["hl1831-cp-004", "hashlib.__dict__.__contains__", ["__call__"], false]
    - ["hl1831-cp-005", "hashlib.sha256.__class__.__dict__.__contains__", ["__get__"], false]
    - ["hl1831-cp-006", "hashlib.pbkdf2_hmac.__class__.__dict__.__contains__", ["__call__"], true]
    - ["hl1831-cp-007", "hashlib.new.__class__.__dict__.__contains__", ["__call__"], true]
    - ["hl1831-cp-008", "hashlib.__dict__.__contains__", ["__iter__"], false]
    - ["hl1831-cp-009", "hashlib.__dict__.__contains__", ["__contains__"], false]

table hashlib_extra1831.hashlib_class_attrs:
  columns: [id, function, args, expected]
  rows:
    - ["hl1831-ca-001", "hashlib.__dict__.__contains__", ["sha256"], true]
