spec: just_union
version: ">=3.2.0"
backend: node(just-union)

docs: https://www.npmjs.com/package/just-union

provenance:
  derived_from:
    - "just-union README — https://www.npmjs.com/package/just-union"
    - "Test vectors verified with just-union via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "just-union source"
  notes:
    - "just-union is an npm package. Install: npm install just-union"
    - "The module exports a single function that returns the union of two arrays (no duplicates)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a new array containing all unique values from both inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_union.union:
  kind: node_module_call_eq
  function: ~
  category: set
  id_prefix: junion

  columns: [id, args, expected]
  rows:
    - [overlap,    [[1, 2, 3], [2, 3, 4]], [1, 2, 3, 4]]
    - [disjoint,   [[1, 2], [3, 4]],       [1, 2, 3, 4]]
