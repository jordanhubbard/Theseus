spec: re_extra59
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra58.zspec.zsdl — covers Pattern/Match/error __repr__.__class__.__name__.__eq__('wrapper_descriptor'); Pattern/Match __hash__.__class__.__name__.__eq__('wrapper_descriptor')."
    - "re_extra57.zspec.zsdl — covers Pattern/Match/error __class__.__module__.__eq__('builtins'); search/compile/sub/findall __class__.__module__.__eq__('builtins'); RegexFlag.__class__.__module__.__eq__('enum')."
    - "re_extra56.zspec.zsdl — covers Pattern/Match/error/RegexFlag __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy'); re module __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy')."
    - "re_extra55.zspec.zsdl — covers subn __module__.__len__()==2; Pattern/Match/RegexFlag __module__ equality/length namespace anchors."
    - "re_extra54.zspec.zsdl — covers re function __module__.__eq__('re') for all 9 functions + error."
    - "re_extra51.zspec.zsdl — covers RegexFlag member __class__.__module__.__eq__('re') for MULTILINE/DOTALL/VERBOSE/ASCII/UNICODE."
    - "re_extra43.zspec.zsdl — covers search/__module__=='re'; findall/__module__=='re'; IGNORECASE/__class__.__module__=='re'."
    - "re_extra33.zspec.zsdl — covers error/Pattern/Match/RegexFlag __dict__.__class__.__name__.__len__()==12."
  notes:
    - "This spec extends re_extra58.zspec.zsdl."
    - "Prior specs collectively covered: re_extra58 covers __repr__.__class__.__name__ and __hash__.__class__.__name__ for Pattern/Match/error; re_extra57 covers __class__.__module__ for Pattern/Match/error/RegexFlag; re_extra54 covers __module__ for re functions. NOT YET COVERED: re.__all__.__class__.__name__.__eq__('list') — no prior re spec checks __all__.__class__.__name__; novel; re.__all__.__len__()==31 — no prior re spec checks the length of re.__all__; novel; Pattern/Match __eq__.__class__.__name__.__eq__('wrapper_descriptor') — no prior re spec checks __eq__.__class__.__name__ for Pattern or Match; novel; error.__eq__.__class__.__name__.__eq__('wrapper_descriptor') — re.error (PatternError) inherits from Exception/BaseException; __eq__ is from object; wrapper_descriptor; novel; RegexFlag.__eq__.__class__.__name__.__eq__('wrapper_descriptor') — RegexFlag is an IntFlag (subclass of int); __eq__ resolves to int.__eq__ which is a wrapper_descriptor; novel."
    - "re has __all__ defined as a list. Verified: hasattr(re, '__all__') == True. re.__all__ is a plain Python list with 31 entries covering module functions, types, flag shorthand letters, and full flag names. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.__all__.__class__.__name__ == 'list'. No prior re spec checks __all__.__class__.__name__. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.__all__.__len__() == 31. The re module's __all__ list has 31 entries in Python 3.14.3. No prior re spec checks __all__.__len__(). Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.Pattern.__eq__.__class__.__name__ == 'wrapper_descriptor'. Pattern is a C-extension type that defines __eq__ in its own __dict__ (confirmed: '__eq__' in Pattern.__dict__ == True). The __eq__ is a wrapper_descriptor (C-level slot wrapper). No prior re spec checks __eq__.__class__.__name__ for Pattern. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.Match.__eq__.__class__.__name__ == 'wrapper_descriptor'. Match is a C-extension type that does NOT define __eq__ in its own __dict__ (confirmed: '__eq__' in Match.__dict__ == False). It inherits object.__eq__, which is a wrapper_descriptor. No prior re spec checks __eq__.__class__.__name__ for Match. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.error.__eq__.__class__.__name__ == 'wrapper_descriptor'. re.error (PatternError in Python 3.14) is a pure-Python Exception subclass. It does NOT define __eq__ in its own __dict__ (confirmed: '__eq__' in re.error.__dict__ == False). It inherits object.__eq__, which is a wrapper_descriptor. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.RegexFlag.__eq__.__class__.__name__ == 'wrapper_descriptor'. RegexFlag is an IntFlag (subclass of int, as confirmed by RegexFlag.__bases__ == (IntFlag,) and RegexFlag.__mro__ containing int). RegexFlag does NOT define __eq__ in its own __dict__ ('__eq__' in RegexFlag.__dict__ == False). __eq__ resolves to int.__eq__ (confirmed: RegexFlag.__eq__ is int.__eq__ == True and RegexFlag.__eq__.__qualname__ == 'int.__eq__'). int.__eq__ is a C-level slot wrapper — a wrapper_descriptor. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note on re.error: In Python 3.14.3, re.error is an alias for re.PatternError. The 'error' symbol still resolves to the same class."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module __all__ identity
#
# The re module defines __all__ as a plain Python list with 31 entries covering
# module functions (match, fullmatch, search, sub, subn, split, findall,
# finditer, compile, purge, escape), types (error, Pattern, Match), flag
# single-letter shortcuts (A, I, L, M, S, X, U), full flag names
# (ASCII, IGNORECASE, LOCALE, MULTILINE, DOTALL, VERBOSE, UNICODE, NOFLAG),
# and (RegexFlag, PatternError).
#
#   re.__all__.__class__.__name__ == 'list'
#   re.__all__.__len__()          == 31
#
# No prior re spec checks re.__all__.__class__.__name__ or its length.
# Both anchors are novel in the reall59 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra59.all_identity:
  description: "re module __all__.__class__.__name__.__eq__('list') and __all__.__len__()==31 — re defines __all__ as a plain Python list with 31 public names including functions, types (Pattern, Match, error), flag shortcuts, and full flag names; no prior re spec checks __all__.__class__.__name__ or its length; both novel anchors in reall59 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: reall59all

  columns: [id, function, args, expected]
  rows:
    - [all_class_name, "__all__.__class__.__name__.__eq__", ["list"], true]
    - [all_len,        "__all__.__len__",                   [],        31  ]

# ---------------------------------------------------------------------------
# re Pattern/Match __eq__.__class__.__name__ == 'wrapper_descriptor'
#
# Pattern is a C-extension type that defines __eq__ in its own __dict__ as a
# wrapper_descriptor for 're.Pattern' objects. Match is also a C-extension type
# but does NOT define __eq__ in its own __dict__ (confirmed: '__eq__' in
# Match.__dict__ == False); it inherits object.__eq__, which is a
# wrapper_descriptor. Both are wrapper_descriptor.
#
#   Pattern.__eq__.__class__.__name__ == 'wrapper_descriptor'
#   Match.__eq__.__class__.__name__   == 'wrapper_descriptor'
#
# No prior re spec checks __eq__.__class__.__name__ for Pattern or Match.
# Both anchors are novel in the reall59 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra59.cext_eq_class_name:
  description: "re Pattern/Match __eq__.__class__.__name__.__eq__('wrapper_descriptor') — Pattern defines __eq__ in its own __dict__ as a wrapper_descriptor; Match inherits object.__eq__ which is also a wrapper_descriptor; no prior re spec checks __eq__.__class__.__name__ for Pattern or Match; both novel anchors in reall59 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: reall59ceq

  columns: [id, function, args, expected]
  rows:
    - [Pattern_eq_class_name, "Pattern.__eq__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - [Match_eq_class_name,   "Match.__eq__.__class__.__name__.__eq__",   ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# re error __eq__.__class__.__name__ == 'wrapper_descriptor'
#
# re.error (PatternError in Python 3.14) is a pure-Python Exception subclass.
# It does NOT define __eq__ in its own __dict__ (confirmed: '__eq__' in
# re.error.__dict__ == False). It inherits object.__eq__, which is a
# wrapper_descriptor. Exception and BaseException do not define their own
# __eq__; the chain terminates at object.__eq__.
#
#   error.__eq__.__class__.__name__ == 'wrapper_descriptor'
#
# No prior re spec checks __eq__.__class__.__name__ for error.
# This anchor is novel in the reall59 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra59.error_eq_class_name:
  description: "re error __eq__.__class__.__name__.__eq__('wrapper_descriptor') — re.error (PatternError) is an Exception subclass that does not define __eq__ in its own __dict__; it inherits object.__eq__ which is a wrapper_descriptor; no prior re spec checks __eq__.__class__.__name__ for error; novel anchor in reall59 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: reall59erq

  columns: [id, function, args, expected]
  rows:
    - [error_eq_class_name, "error.__eq__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# re RegexFlag __eq__.__class__.__name__ == 'wrapper_descriptor'
#
# RegexFlag is an IntFlag (confirmed: RegexFlag.__bases__ == (IntFlag,) and
# RegexFlag.__mro__ contains int). RegexFlag does NOT define __eq__ in its own
# __dict__ (confirmed: '__eq__' in RegexFlag.__dict__ == False). The __eq__
# attribute resolves to int.__eq__ through the MRO (confirmed: RegexFlag.__eq__
# is int.__eq__ == True; RegexFlag.__eq__.__qualname__ == 'int.__eq__').
# int.__eq__ is a C-level slot wrapper — a wrapper_descriptor.
#
#   RegexFlag.__eq__.__class__.__name__ == 'wrapper_descriptor'
#
# No prior re spec checks __eq__.__class__.__name__ for RegexFlag.
# This anchor is novel in the reall59 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra59.regexflag_eq_class_name:
  description: "re RegexFlag __eq__.__class__.__name__.__eq__('wrapper_descriptor') — RegexFlag is an IntFlag subclass of int; it does not define __eq__ in its own __dict__; __eq__ resolves to int.__eq__ via MRO (confirmed: RegexFlag.__eq__ is int.__eq__; __eq__.__qualname__=='int.__eq__'); int.__eq__ is a C-level wrapper_descriptor; no prior re spec checks __eq__.__class__.__name__ for RegexFlag; novel anchor in reall59 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: reall59fleq

  columns: [id, function, args, expected]
  rows:
    - [RegexFlag_eq_class_name, "RegexFlag.__eq__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]

invariant re_extra59.all_class_name_list:
  description: "re.__all__.__class__.__name__ == 'list' — the re module defines __all__ as a plain Python list; no prior re spec checks __all__.__class__.__name__; novel anchor in reall59 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant re_extra59.all_len_31:
  description: "re.__all__.__len__() == 31 — the re module's __all__ list contains 31 public names in Python 3.14.3; no prior re spec checks the length of __all__; novel anchor in reall59 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 31

invariant re_extra59.Pattern_eq_class_name_wrapper_descriptor:
  description: "re.Pattern.__eq__.__class__.__name__ == 'wrapper_descriptor' — Pattern is a C-extension type that defines __eq__ in its own __dict__ as a wrapper_descriptor (confirmed: '__eq__' in Pattern.__dict__ == True); no prior re spec checks __eq__.__class__.__name__ for Pattern; novel anchor in reall59 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__eq__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant re_extra59.RegexFlag_eq_class_name_wrapper_descriptor:
  description: "re.RegexFlag.__eq__.__class__.__name__ == 'wrapper_descriptor' — RegexFlag is an IntFlag subclass of int; __eq__ resolves to int.__eq__ via MRO (RegexFlag.__eq__ is int.__eq__); int.__eq__ is a C-level wrapper_descriptor; no prior re spec checks __eq__.__class__.__name__ for RegexFlag; novel anchor in reall59 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: RegexFlag.__eq__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true
