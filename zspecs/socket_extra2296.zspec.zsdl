spec: socket_extra2296
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/socket.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 600 (_extra2296): __module__ and __qualname__ attribute value checks."
    - "socket.socket is a pure-Python subclass of _socket.socket; __module__ == 'socket'."
    - "socket.error is an alias for the built-in OSError; __module__ == 'builtins', __name__ == 'OSError'."
    - "socket.timeout is an alias for the built-in TimeoutError; __module__ == 'builtins', __name__ == 'TimeoutError'."
    - "socket.herror and socket.gaierror are pure-Python exception subclasses; __module__ == 'socket'."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses; __module__ == 'socket'."
    - "socket module itself: __name__ == 'socket', __package__ == ''."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table socket_extra2296.socket_class_module:
