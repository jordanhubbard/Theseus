spec: threading_extra22
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading.zspec.zsdl and prior extras through threading_extra21.zspec.zsdl."
    - "threading_extra18 covers: Condition/Barrier/BoundedSemaphore/Timer __name__ and __module__ tables; get_ident/__name__; get_native_id/__name__."
    - "threading_extra19 covers: Thread/Event/Condition/Semaphore/Timer/Barrier __qualname__ table; Lock/__qualname__; RLock/__qualname__; current_thread/__name__; active_count/__name__."
    - "threading_extra20 covers: class __name__ length table; Lock/__name__ == 'lock' standalone; RLock/__name__; BoundedSemaphore/__name__."
    - "threading_extra21 covers: class base name __getitem__ table; class __module__ table; Timer/BoundedSemaphore base class standalone invariants; Thread/Timer __module__ standalone."
    - "NOT yet covered in any prior spec: threading function __module__ table (current_thread/main_thread/active_count/enumerate/settrace/setprofile) in extra22 namespace."
    - "NOT yet covered: threading.current_thread.__qualname__ == 'current_thread' as standalone extra22-namespace invariant."
    - "NOT yet covered: threading.main_thread.__qualname__ == 'main_thread' as standalone extra22-namespace invariant."
    - "NOT yet covered: threading function __name__ table (current_thread/main_thread/active_count/enumerate/settrace/setprofile) in extra22 namespace."
    - "threading.current_thread.__module__ == 'threading' — defined in Lib/threading.py."
    - "threading.main_thread.__module__ == 'threading' — defined in Lib/threading.py."
    - "threading.active_count.__module__ == 'threading' — defined in Lib/threading.py."
    - "threading.enumerate.__module__ == 'threading' — defined in Lib/threading.py."
    - "threading.settrace.__module__ == 'threading' — defined in Lib/threading.py."
    - "threading.setprofile.__module__ == 'threading' — defined in Lib/threading.py."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __module__ table — threading utility functions in extra22 namespace
#
# Prior specs check __module__ for threading class types. No prior spec
# provides a unified table of threading utility function __module__ values.
# All six functions (current_thread, main_thread, active_count, enumerate,
# settrace, setprofile) are defined directly in Lib/threading.py and
# report __module__ == 'threading'. This contrasts with stack_size and
# excepthook which are imported from the lower-level _thread C extension.
# ---------------------------------------------------------------------------

table threading_extra22.function_modules:
  description: "threading utility functions all report __module__ == 'threading'"
  kind: python_call_eq
  category: function_modules
  id_prefix: fnmod22

  columns: [id, function, args, expected]
  rows:
    - [current_thread, current_thread.__module__.__eq__, ["threading"], true]
    - [main_thread,    main_thread.__module__.__eq__,    ["threading"], true]
    - [active_count,   active_count.__module__.__eq__,   ["threading"], true]
    - [enumerate,      enumerate.__module__.__eq__,      ["threading"], true]
    - [settrace,       settrace.__module__.__eq__,       ["threading"], true]
    - [setprofile,     setprofile.__module__.__eq__,     ["threading"], true]

# ---------------------------------------------------------------------------
# Function __name__ table — threading utility functions in extra22 namespace
#
# No prior spec provides a unified table of threading utility function __name__
# values. Each function's __name__ attribute matches its definition-site name
# exactly, confirming no aliasing or renaming occurs on import.
# ---------------------------------------------------------------------------

table threading_extra22.function_names:
  description: "threading utility functions report __name__ matching their definition-site names"
  kind: python_call_eq
  category: function_names
  id_prefix: fnname22

  columns: [id, function, args, expected]
  rows:
    - [current_thread, current_thread.__name__.__eq__, ["current_thread"], true]
    - [main_thread,    main_thread.__name__.__eq__,    ["main_thread"],    true]
    - [active_count,   active_count.__name__.__eq__,   ["active_count"],   true]
    - [enumerate,      enumerate.__name__.__eq__,       ["enumerate"],      true]
    - [settrace,       settrace.__name__.__eq__,        ["settrace"],       true]
    - [setprofile,     setprofile.__name__.__eq__,      ["setprofile"],     true]

# ---------------------------------------------------------------------------
# current_thread.__qualname__ == 'current_thread' — standalone invariant
#
# No prior spec checks current_thread's __qualname__ as a standalone invariant.
# The __qualname__ matches the simple function name (no class nesting), which
# confirms current_thread is a module-level function, not a method.
# ---------------------------------------------------------------------------

invariant threading_extra22.current_thread.qualname_eq:
  description: "threading.current_thread.__qualname__ == 'current_thread' — module-level function"
  category: function_names
  kind: python_call_eq
  function: current_thread.__qualname__.__eq__
  args: ["current_thread"]
  expected: true

# ---------------------------------------------------------------------------
# main_thread.__qualname__ == 'main_thread' — standalone invariant
#
# No prior spec checks main_thread's __qualname__ as a standalone invariant.
# Confirms main_thread is a module-level function in threading.
# ---------------------------------------------------------------------------

invariant threading_extra22.main_thread.qualname_eq:
  description: "threading.main_thread.__qualname__ == 'main_thread' — module-level function"
  category: function_names
  kind: python_call_eq
  function: main_thread.__qualname__.__eq__
  args: ["main_thread"]
  expected: true

# ---------------------------------------------------------------------------
# settrace.__module__ == 'threading' — standalone extra22-namespace invariant
#
# threading.settrace installs a trace function for all future threads started
# from the threading module. The function table above covers this value; this
# standalone invariant provides an independent extra22-namespace anchor
# confirming settrace is defined in threading, not in the _thread C extension.
# ---------------------------------------------------------------------------

invariant threading_extra22.settrace.module_eq:
  description: "threading.settrace.__module__ == 'threading' — defined in pure-Python threading module"
  category: function_modules
  kind: python_call_eq
  function: settrace.__module__.__eq__
  args: ["threading"]
  expected: true

# ---------------------------------------------------------------------------
# setprofile.__module__ == 'threading' — standalone extra22-namespace invariant
#
# threading.setprofile installs a profile function for all future threads.
# Like settrace, it is defined in the pure-Python threading module rather than
# the _thread C extension. This standalone invariant provides an independent
# extra22-namespace anchor for that placement.
# ---------------------------------------------------------------------------

invariant threading_extra22.setprofile.module_eq:
  description: "threading.setprofile.__module__ == 'threading' — defined in pure-Python threading module"
  category: function_modules
  kind: python_call_eq
  function: setprofile.__module__.__eq__
  args: ["threading"]
  expected: true
