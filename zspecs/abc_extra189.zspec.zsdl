spec: abc_extra189
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "abc.__name__ == 'abc' (len=3); the module name is the package name."
    - "abc.__package__ == '' (empty string, len=0); abc is a top-level module with no parent package."
    - "abc.__loader__.__name__ == 'FrozenImporter' (len=14); abc is a frozen module in Python 3.14 — loaded by _frozen_importlib.FrozenImporter."
    - "abc.__loader__.__class__.__name__ == 'type' (len=4); FrozenImporter is a class (a type), so its metaclass __class__ is 'type'."
    - "abc.ABCMeta.__module__ == 'abc' (len=3); ABCMeta is defined in the abc module."
    - "abc.ABC.__module__ == 'abc' (len=3); ABC is defined in the abc module."
    - "abc.abstractmethod.__module__ == 'abc' (len=3); abstractmethod is defined in the abc module."
    - "abc.get_cache_token.__module__ == '_abc' (len=4); get_cache_token is implemented in the C extension _abc, not the pure-Python abc."
    - "The len() tests use .__len__() on the string value to produce an integer for comparison."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc module-level identity — __name__, __package__, loader name
#
# abc.__name__ == 'abc' (len=3)
# abc.__package__ == '' (len=0, empty string)
# abc.__loader__.__name__ == 'FrozenImporter' (len=14)
# abc.__loader__.__class__.__name__ == 'type' (len=4)
# ---------------------------------------------------------------------------

table abc_extra189.abc_module_identity:
  description: "abc module-level identity checks in abcmodule189 namespace — abc.__name__=='abc' (len=3: a(1)b(2)c(3); the Abstract Base Classes module, providing ABCMeta, ABC, and abstractmethod); abc.__package__=='' (len=0; abc is a top-level module, not inside any package, so __package__ is the empty string); abc.__loader__.__name__=='FrozenImporter' (len=14: 'Frozen'=6+'Importer'=8=14; abc is a frozen module in CPython 3.14, embedded directly in the interpreter binary); abc.__loader__.__class__.__name__=='type' (len=4; FrozenImporter is itself a class, so its own class is the metaclass 'type'); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmodule189

  columns: [id, function, args, expected, description]
  rows:
    - [abc_name_eq,          abc.__name__.__eq__,                   ["abc"],             true, "abc.__name__ == 'abc' (len=3; the Abstract Base Classes module); verified Python 3.14.3"]
    - [abc_name_len,         abc.__name__.__len__,                  [],                  3,    "abc.__name__.__len__() == 3 ('abc'=3: a(1)b(2)c(3)); verified Python 3.14.3"]
    - [abc_package_len,      abc.__package__.__len__,               [],                  0,    "abc.__package__.__len__() == 0 (empty string; abc is a top-level module with no parent package); verified Python 3.14.3"]
    - [abc_loader_name_eq,   abc.__loader__.__name__.__eq__,        ["FrozenImporter"],  true, "abc.__loader__.__name__ == 'FrozenImporter' (len=14; abc is frozen in the CPython 3.14 binary); verified Python 3.14.3"]
    - [abc_loader_class_eq,  abc.__loader__.__class__.__name__.__eq__, ["type"],         true, "abc.__loader__.__class__.__name__ == 'type' (FrozenImporter is a class, its class is the metaclass 'type'); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: abc symbol module lengths — ABCMeta, ABC, abstractmethod
#
# abc.ABCMeta.__module__.__len__() == 3 (module 'abc', len=3)
# abc.ABC.__module__.__len__() == 3
# abc.abstractmethod.__module__.__len__() == 3
# ---------------------------------------------------------------------------

table abc_extra189.abc_symbol_module_lengths:
  description: "abc symbol __module__ length checks in abcmodule189 namespace — abc.ABCMeta.__module__.__len__()==3 (ABCMeta.__module__=='abc', len=3; ABCMeta is the metaclass for registering abstract base classes); abc.ABC.__module__.__len__()==3 (ABC.__module__=='abc', len=3; ABC is the convenience class that uses ABCMeta as its metaclass); abc.abstractmethod.__module__.__len__()==3 (abstractmethod.__module__=='abc', len=3; abstractmethod is a decorator for marking methods as abstract); all three are defined in the pure-Python abc module; abc.get_cache_token.__module__.__len__()==4 ('_abc', len=4) — get_cache_token is implemented in the C extension _abc; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmodule189

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_module_eq,    abc.ABCMeta.__module__.__eq__,               ["abc"],  true, "abc.ABCMeta.__module__ == 'abc' (len=3; ABCMeta defined in the pure-Python abc module); verified Python 3.14.3"]
    - [abcmeta_module_len,   abc.ABCMeta.__module__.__len__,              [],       3,    "abc.ABCMeta.__module__.__len__() == 3 ('abc'=3; ABCMeta is the metaclass for abstract base classes); verified Python 3.14.3"]
    - [abc_ABC_module_eq,    abc.ABC.__module__.__eq__,                   ["abc"],  true, "abc.ABC.__module__ == 'abc' (len=3; ABC is the convenience class using ABCMeta); verified Python 3.14.3"]
    - [abc_ABC_module_len,   abc.ABC.__module__.__len__,                  [],       3,    "abc.ABC.__module__.__len__() == 3 ('abc'=3; ABC inherits from object with ABCMeta as metaclass); verified Python 3.14.3"]
    - [abstractmethod_mod_len, abc.abstractmethod.__module__.__len__,     [],       3,    "abc.abstractmethod.__module__.__len__() == 3 ('abc'=3; abstractmethod decorator defined in pure-Python abc module); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: abc.get_cache_token module — lives in _abc C extension
#
# abc.get_cache_token.__module__ == '_abc' (len=4)
# abc.__loader__.__name__ length == 14 ('FrozenImporter')
# ---------------------------------------------------------------------------

table abc_extra189.abc_get_cache_token_module:
  description: "abc.get_cache_token __module__ identity in abcmodule189 namespace — get_cache_token.__module__=='_abc' (len=4: '_'=1+'abc'=3=4; get_cache_token is implemented in the C extension _abc, not the pure-Python abc wrapper); get_cache_token.__module__ (4) > abc.__name__ (3) by 1 — the C module name '_abc' has a leading underscore making it one character longer; abc.abstractmethod.__module__ (3) vs abc.get_cache_token.__module__ (4) — same-looking symbols but different implementation layers; abc.__loader__.__name__ (14) confirms the module is loaded by FrozenImporter; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmodule189

  columns: [id, function, args, expected, description]
  rows:
    - [get_cache_module_eq,    abc.get_cache_token.__module__.__eq__,    ["_abc"],  true, "abc.get_cache_token.__module__ == '_abc' (len=4; implemented in C extension _abc, not pure-Python abc); verified Python 3.14.3"]
    - [get_cache_module_len,   abc.get_cache_token.__module__.__len__,   [],        4,    "abc.get_cache_token.__module__.__len__() == 4 ('_abc'=4: '_'=1+'abc'=3=4); verified Python 3.14.3"]
    - [loader_name_len,        abc.__loader__.__name__.__len__,          [],        14,   "abc.__loader__.__name__.__len__() == 14 ('FrozenImporter'=14: 'Frozen'=6+'Importer'=8=14); verified Python 3.14.3"]
    - [abstractmethod_mod_eq,  abc.abstractmethod.__module__.__eq__,     ["abc"],   true, "abc.abstractmethod.__module__ == 'abc' (len=3; pure-Python abc vs C extension _abc for get_cache_token); verified Python 3.14.3"]
    - [abc_name_eq2,           abc.__name__.__eq__,                      ["abc"],   true, "abc.__name__ == 'abc' (len=3) confirms module identity; abc.__name__ (3) < get_cache_token.__module__ (4) by 1; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra189
# ---------------------------------------------------------------------------

invariant abc_extra189.abc_module_name_eq:
  description: "abc.__name__.__eq__('abc') returns True — abc.__name__=='abc' (len=3: a(1)b(2)c(3)); the abc module provides the infrastructure for defining Abstract Base Classes in Python; it supplies ABCMeta (the metaclass), ABC (a convenience class), abstractmethod (decorator), and get_cache_token() (C-level token for cache invalidation); abc.__name__ (3) is one of the shortest Python stdlib module names; abc.__name__ (3) < abc.get_cache_token.__module__ (4: '_abc') by 1 — the C implementation adds a leading underscore; NEW in abcmodule189: first standalone abc.__name__.__eq__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__name__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra189.abc_package_len_zero:
  description: "abc.__package__.__len__() == 0 — abc.__package__ is the empty string (len=0); abc is a top-level stdlib module with no parent package; for a top-level module, __package__ is set to '' (empty string) by the import system; this is distinct from submodules like 'concurrent.futures' where __package__=='concurrent.futures' (len=18); abc.__package__ (0) confirms abc has no enclosing package namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__package__.__len__
  args: []
  expected: 0

invariant abc_extra189.abc_loader_name_eq:
  description: "abc.__loader__.__name__.__eq__('FrozenImporter') returns True — abc.__loader__.__name__=='FrozenImporter' (len=14: 'Frozen'=6+'Importer'=8=14); the abc module is frozen into the CPython binary in Python 3.14 — the FrozenImporter loads it directly from the bytecode embedded in the interpreter without reading the filesystem; abc.__loader__.__name__ (14) >> abc.__name__ (3) — the loader name is much longer than the module name; FrozenImporter is defined in _frozen_importlib, which is itself the very first module bootstrapped during interpreter startup; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__loader__.__name__.__eq__
  args: ["FrozenImporter"]
  expected: true

invariant abc_extra189.abc_loader_class_is_type:
  description: "abc.__loader__.__class__.__name__.__eq__('type') returns True — abc.__loader__.__class__.__name__=='type' (len=4); abc.__loader__ is the FrozenImporter class itself (not an instance) — it is a class object, so its own class is the metaclass 'type'; in Python, type(SomeClass).__name__ == 'type' for any regular class; abc.__loader__.__class__.__name__ (4) == len('type') (4); this distinguishes abc.__loader__ (a class) from a loader instance (which would have __class__.__name__=='FrozenImporter'); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__loader__.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant abc_extra189.abc_ABCMeta_module_len:
  description: "abc.ABCMeta.__module__.__len__() == 3 — abc.ABCMeta.__module__=='abc' (len=3); ABCMeta is the metaclass for abstract base classes; it is defined in the pure-Python abc module (not the C extension _abc); ABCMeta.__module__ (3) == abc.__name__ (3) — ABCMeta is defined in the same module the user imports; ABCMeta.__module__ (3) < get_cache_token.__module__ (4) by 1 — ABCMeta is pure Python while get_cache_token is in the C extension _abc; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__module__.__len__
  args: []
  expected: 3

invariant abc_extra189.abc_ABC_module_len:
  description: "abc.ABC.__module__.__len__() == 3 — abc.ABC.__module__=='abc' (len=3); ABC is a convenience class with ABCMeta as its metaclass; users subclass ABC instead of using ABCMeta directly as a metaclass; ABC.__module__ (3) == ABCMeta.__module__ (3) == abstractmethod.__module__ (3) — all three pure-Python symbols share the same module name length; ABC.__module__ (3) < get_cache_token.__module__ (4) — ABC is pure-Python while get_cache_token is C; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__module__.__len__
  args: []
  expected: 3

invariant abc_extra189.abc_abstractmethod_module_len:
  description: "abc.abstractmethod.__module__.__len__() == 3 — abc.abstractmethod.__module__=='abc' (len=3); abstractmethod is a decorator function defined in the pure-Python abc module; decorating a method with @abstractmethod marks it as abstract, requiring concrete subclasses to provide an implementation; abstractmethod.__module__ (3) == ABCMeta.__module__ (3) == ABC.__module__ (3) — all three pure-Python abc symbols have module name 'abc' with length 3; abstractmethod.__module__ (3) < get_cache_token.__module__ (4) — the boundary between pure-Python and C implementation; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__module__.__len__
  args: []
  expected: 3

invariant abc_extra189.abc_get_cache_token_module_len:
  description: "abc.get_cache_token.__module__.__len__() == 4 — abc.get_cache_token.__module__=='_abc' (len=4: '_'=1+'abc'=3=4); get_cache_token() is implemented in the C extension _abc (not the pure-Python abc wrapper); it returns an opaque token that changes whenever the set of known virtual subclasses changes, enabling cache invalidation for isinstance() checks; get_cache_token.__module__ (4) > abstractmethod.__module__ (3) by 1 — the C extension module '_abc' has a leading underscore making it one character longer than 'abc'; NEW in abcmodule189: completing 8-invariant coverage for abc module structure; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__module__.__len__
  args: []
  expected: 4
