spec: multiprocessing_extra97
version: ">=3.9"
backend: python_module(multiprocessing)
extends: multiprocessing_extra96

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec extends multiprocessing_extra96.zspec.zsdl."
    - "This spec covers: wave 254 theme — multiprocessing.Process class identity and method class names. NEW in extra97: Process.__class__.__name__=='type'; Process.__module__=='multiprocessing.context' (defined in the context module, not process.py); Process.__bases__[0].__name__=='BaseProcess' (an intermediate base class); Process.__mro__.__len__()==3 (MRO is [Process, BaseProcess, object]); Process.__init__.__class__.__name__=='function'; Process.start.__class__.__name__=='function'; Process.run.__class__.__name__=='function'; Process.join.__class__.__name__=='function'; Process.terminate.__class__.__name__=='function'; Process.is_alive.__class__.__name__=='function'; Process.__init__.__qualname__=='BaseProcess.__init__' (len=20, inherited from BaseProcess); Process.start.__qualname__=='BaseProcess.start' (len=17); Process.run.__qualname__=='BaseProcess.run' (len=15); Process.join.__qualname__=='BaseProcess.join' (len=16); Process.terminate.__qualname__=='BaseProcess.terminate' (len=21); Process.is_alive.__qualname__=='BaseProcess.is_alive' (len=20); all method __module__=='multiprocessing.process'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Process.__module__ == 'multiprocessing.context'. The Process class visible in multiprocessing is defined in Lib/multiprocessing/context.py (the context-specific Process subclass), NOT in Lib/multiprocessing/process.py (where BaseProcess lives). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Process.__bases__[0].__name__ == 'BaseProcess'. multiprocessing.Process inherits from BaseProcess (in Lib/multiprocessing/process.py), not directly from object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Process.__init__.__qualname__ == 'BaseProcess.__init__' (len=20). Process methods are inherited from BaseProcess and their qualnames reflect the defining class 'BaseProcess'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Process class identity — extra97
#
# Wave 254 theme: multiprocessing.Process class identity and method class names.
#
# Process.__class__.__name__ == 'type'
# Process.__module__ == 'multiprocessing.context'
# Process.__bases__[0].__name__ == 'BaseProcess'
# Process.__mro__.__len__() == 3   [Process, BaseProcess, object]
# Process.__name__ == 'Process'    (len=7)
# Process.__qualname__ == 'Process' (len=7)
# ---------------------------------------------------------------------------

table multiprocessing_extra97.mp_process_class_identity:
  description: "multiprocessing.Process class identity checks in mpprocessident97 namespace — wave 254 theme: multiprocessing.Process class hierarchy; multiprocessing.Process is a Python class (not a bound context method like Queue/Pipe/Lock); Process.__class__.__name__.__eq__('type')==True (it is a genuine class, metaclass is type); Process.__module__.__eq__('multiprocessing.context')==True (the Process class seen in the public API is the context-specific subclass defined in Lib/multiprocessing/context.py, NOT the BaseProcess in process.py); Process.__bases__[0].__name__.__eq__('BaseProcess')==True (Process inherits from BaseProcess which lives in Lib/multiprocessing/process.py); Process.__mro__.__len__()==3 (MRO is [Process, BaseProcess, object]); Process.__name__.__eq__('Process')==True (len=7); Process.__qualname__.__eq__('Process')==True (len=7, module-level class so qualname equals name); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpprocessident97

  columns: [id, function, args, expected, description]
  rows:
    - [proc_class_nm,  "multiprocessing.Process.__class__.__name__.__eq__",      ["type"],                       true, "multiprocessing.Process.__class__.__name__ == 'type' — genuine Python class; verified with Python 3.14.3"]
    - [proc_module,    "multiprocessing.Process.__module__.__eq__",               ["multiprocessing.context"],    true, "multiprocessing.Process.__module__ == 'multiprocessing.context' — context-specific subclass; verified with Python 3.14.3"]
    - [proc_base0,     "multiprocessing.Process.__bases__[0].__name__.__eq__",    ["BaseProcess"],                true, "multiprocessing.Process.__bases__[0].__name__ == 'BaseProcess' — inherits from BaseProcess; verified with Python 3.14.3"]
    - [proc_mro_len,   "multiprocessing.Process.__mro__.__len__",                 [],                             3,    "multiprocessing.Process.__mro__.__len__() == 3 — MRO is [Process, BaseProcess, object]; verified with Python 3.14.3"]
    - [proc_name,      "multiprocessing.Process.__name__.__eq__",                 ["Process"],                    true, "multiprocessing.Process.__name__ == 'Process' (len=7); verified with Python 3.14.3"]
    - [proc_qualname,  "multiprocessing.Process.__qualname__.__eq__",             ["Process"],                    true, "multiprocessing.Process.__qualname__ == 'Process' (len=7); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.Process method class names — extra97
#
# All Process methods are inherited from BaseProcess and are Python functions.
#
# Process.__init__.__class__.__name__ == 'function'
# Process.start.__class__.__name__ == 'function'
# Process.run.__class__.__name__ == 'function'
# Process.join.__class__.__name__ == 'function'
# Process.terminate.__class__.__name__ == 'function'
# Process.is_alive.__class__.__name__ == 'function'
# ---------------------------------------------------------------------------

table multiprocessing_extra97.mp_process_method_class_names:
  description: "multiprocessing.Process method class name checks in mpprocessident97 namespace — wave 254 theme: Process methods are Python functions (not C-level method_descriptors); all Process methods are defined in BaseProcess (Lib/multiprocessing/process.py) and inherited by the context-specific Process; Process.__init__.__class__.__name__.__eq__('function')==True; Process.start.__class__.__name__.__eq__('function')==True; Process.run.__class__.__name__.__eq__('function')==True; Process.join.__class__.__name__.__eq__('function')==True; Process.terminate.__class__.__name__.__eq__('function')==True; Process.is_alive.__class__.__name__.__eq__('function')==True; these Python functions contrast with asyncio.Task methods which are C-level method_descriptors; all Process methods have __module__=='multiprocessing.process' (the process submodule where BaseProcess is defined); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpprocessident97a

  columns: [id, function, args, expected, description]
  rows:
    - [init_cls,       "multiprocessing.Process.__init__.__class__.__name__.__eq__",      ["function"], true, "multiprocessing.Process.__init__.__class__.__name__ == 'function' — Python function; verified with Python 3.14.3"]
    - [start_cls,      "multiprocessing.Process.start.__class__.__name__.__eq__",         ["function"], true, "multiprocessing.Process.start.__class__.__name__ == 'function' — Python function; verified with Python 3.14.3"]
    - [run_cls,        "multiprocessing.Process.run.__class__.__name__.__eq__",           ["function"], true, "multiprocessing.Process.run.__class__.__name__ == 'function' — Python function; verified with Python 3.14.3"]
    - [join_cls,       "multiprocessing.Process.join.__class__.__name__.__eq__",          ["function"], true, "multiprocessing.Process.join.__class__.__name__ == 'function' — Python function; verified with Python 3.14.3"]
    - [terminate_cls,  "multiprocessing.Process.terminate.__class__.__name__.__eq__",     ["function"], true, "multiprocessing.Process.terminate.__class__.__name__ == 'function' — Python function; verified with Python 3.14.3"]
    - [is_alive_cls,   "multiprocessing.Process.is_alive.__class__.__name__.__eq__",      ["function"], true, "multiprocessing.Process.is_alive.__class__.__name__ == 'function' — Python function; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.Process method __qualname__ values — extra97
#
# All qualnames have 'BaseProcess.' prefix because methods are inherited.
#
# Process.__init__.__qualname__ == 'BaseProcess.__init__'   (len=20)
# Process.start.__qualname__ == 'BaseProcess.start'          (len=17)
# Process.run.__qualname__ == 'BaseProcess.run'              (len=15)
# Process.join.__qualname__ == 'BaseProcess.join'            (len=16)
# Process.terminate.__qualname__ == 'BaseProcess.terminate'  (len=21)
# Process.is_alive.__qualname__ == 'BaseProcess.is_alive'    (len=20)
# ---------------------------------------------------------------------------

table multiprocessing_extra97.mp_process_method_qualnames:
  description: "multiprocessing.Process method __qualname__ checks in mpprocessident97 namespace — wave 254 theme: Process method qualnames all use 'BaseProcess.' prefix; all Process methods are inherited from BaseProcess; because they are defined in BaseProcess (not Process itself), their __qualname__ uses 'BaseProcess.' as the prefix rather than 'Process.'; Process.__init__.__qualname__.__eq__('BaseProcess.__init__')==True (len=20: 'BaseProcess.'=12 + '__init__'=8); Process.start.__qualname__.__eq__('BaseProcess.start')==True (len=17: 'BaseProcess.'=12 + 'start'=5); Process.run.__qualname__.__eq__('BaseProcess.run')==True (len=15: 'BaseProcess.'=12 + 'run'=3, the shortest); Process.join.__qualname__.__eq__('BaseProcess.join')==True (len=16: 'BaseProcess.'=12 + 'join'=4); Process.terminate.__qualname__.__eq__('BaseProcess.terminate')==True (len=21: 'BaseProcess.'=12 + 'terminate'=9, the longest); Process.is_alive.__qualname__.__eq__('BaseProcess.is_alive')==True (len=20: 'BaseProcess.'=12 + 'is_alive'=8); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpprocessident97b

  columns: [id, function, args, expected, description]
  rows:
    - [init_qeq,      "multiprocessing.Process.__init__.__qualname__.__eq__",     ["BaseProcess.__init__"],     true, "Process.__init__.__qualname__ == 'BaseProcess.__init__' (len=20); verified with Python 3.14.3"]
    - [init_qlen,     "multiprocessing.Process.__init__.__qualname__.__len__",    [],                           20,   "Process.__init__.__qualname__.__len__() == 20; verified with Python 3.14.3"]
    - [start_qeq,     "multiprocessing.Process.start.__qualname__.__eq__",        ["BaseProcess.start"],        true, "Process.start.__qualname__ == 'BaseProcess.start' (len=17); verified with Python 3.14.3"]
    - [start_qlen,    "multiprocessing.Process.start.__qualname__.__len__",       [],                           17,   "Process.start.__qualname__.__len__() == 17; verified with Python 3.14.3"]
    - [run_qeq,       "multiprocessing.Process.run.__qualname__.__eq__",          ["BaseProcess.run"],          true, "Process.run.__qualname__ == 'BaseProcess.run' (len=15, shortest); verified with Python 3.14.3"]
    - [run_qlen,      "multiprocessing.Process.run.__qualname__.__len__",         [],                           15,   "Process.run.__qualname__.__len__() == 15 (shortest among the six); verified with Python 3.14.3"]
    - [join_qeq,      "multiprocessing.Process.join.__qualname__.__eq__",         ["BaseProcess.join"],         true, "Process.join.__qualname__ == 'BaseProcess.join' (len=16); verified with Python 3.14.3"]
    - [terminate_qeq, "multiprocessing.Process.terminate.__qualname__.__eq__",    ["BaseProcess.terminate"],    true, "Process.terminate.__qualname__ == 'BaseProcess.terminate' (len=21, longest); verified with Python 3.14.3"]
    - [is_alive_qeq,  "multiprocessing.Process.is_alive.__qualname__.__eq__",     ["BaseProcess.is_alive"],     true, "Process.is_alive.__qualname__ == 'BaseProcess.is_alive' (len=20); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra97
# ---------------------------------------------------------------------------

invariant multiprocessing_extra97.Process_base_is_BaseProcess:
  description: "multiprocessing.Process.__bases__[0].__name__.__eq__('BaseProcess') returns True — multiprocessing.Process inherits from BaseProcess (Lib/multiprocessing/process.py), making BaseProcess the platform-independent abstract base that defines the core process lifecycle methods; the context-specific Process (Lib/multiprocessing/context.py) is a minimal subclass that sets the start method; all the key methods (start, run, join, terminate, is_alive, __init__) are defined in BaseProcess; Process.__mro__ is [Process, BaseProcess, object] (length=3); this contrasts with the multiprocessing bound-method factories (Queue, Pipe, Lock, etc.) which are bound methods (class='method') with qualnames like 'BaseContext.Queue'; NEW in extra97: first standalone Process base class invariant in mpprocessident97 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.Process.__bases__[0].__name__.__eq__"
  args: ["BaseProcess"]
  expected: true

invariant multiprocessing_extra97.Process_module_is_context:
  description: "multiprocessing.Process.__module__.__eq__('multiprocessing.context') returns True — the Process class accessible as multiprocessing.Process is the context-specific subclass defined in Lib/multiprocessing/context.py, NOT the BaseProcess class in Lib/multiprocessing/process.py; this is an important distinction: Process.__module__ is 'multiprocessing.context' (the context module) even though all the methods are inherited from BaseProcess whose __module__ is 'multiprocessing.process'; Process is a minimal context-specific wrapper around BaseProcess that sets the default start method (fork, spawn, or forkserver depending on platform); NEW in extra97: first standalone Process module invariant in mpprocessident97 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.Process.__module__.__eq__"
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra97.Process_init_qualname_baseprocess:
  description: "multiprocessing.Process.__init__.__qualname__.__eq__('BaseProcess.__init__') returns True — Process.__init__ is inherited from BaseProcess; the __qualname__ attribute always reflects the class where the method was originally defined, so Process.__init__.__qualname__ is 'BaseProcess.__init__' (len=20) rather than 'Process.__init__'; this pattern applies to all Process methods: they are defined in BaseProcess and their qualnames use the 'BaseProcess.' prefix (len=12); Process.__init__.__qualname__ length (20) matches Process.is_alive.__qualname__ length (also 20); Process.terminate.__qualname__ (len=21) is the longest because 'terminate' (9 chars) is the longest method name; NEW in extra97: first standalone Process.__init__ qualname invariant in mpprocessident97 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.Process.__init__.__qualname__.__eq__"
  args: ["BaseProcess.__init__"]
  expected: true

invariant multiprocessing_extra97.Process_start_is_function:
  description: "multiprocessing.Process.start.__class__.__name__.__eq__('function') returns True — multiprocessing.Process.start is a Python function (class='function') defined in BaseProcess in Lib/multiprocessing/process.py; this confirms that Process methods are pure-Python (unlike asyncio.Task methods which are C-level method_descriptors); start.__qualname__ is 'BaseProcess.start' (len=17); start.__module__ is 'multiprocessing.process' (the process submodule where BaseProcess lives, distinct from Process.__module__ which is 'multiprocessing.context'); run, join, terminate, is_alive, and __init__ all share the same 'function' class; NEW in extra97: first standalone Process.start class name invariant in mpprocessident97 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.Process.start.__class__.__name__.__eq__"
  args: ["function"]
  expected: true

invariant multiprocessing_extra97.Process_terminate_qualname_longest:
  description: "multiprocessing.Process.terminate.__qualname__.__eq__('BaseProcess.terminate') returns True — Process.terminate.__qualname__ is 'BaseProcess.terminate' (len=21), the longest qualname among the six core Process methods (run=15, join=16, start=17, __init__=20, is_alive=20, terminate=21); the length difference comes from the method name lengths after the 'BaseProcess.' prefix (12 chars): run=3, join=4, start=5, __init__=8, is_alive=8, terminate=9; terminate sends SIGTERM to the child process on Unix; kill (SIGKILL) and close are also available; terminate.__class__.__name__ is 'function' (Python-defined in BaseProcess); NEW in extra97: first standalone Process.terminate qualname invariant in mpprocessident97 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.Process.terminate.__qualname__.__eq__"
  args: ["BaseProcess.terminate"]
  expected: true
