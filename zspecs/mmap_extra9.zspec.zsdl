spec: mmap_extra9
version: ">=3.9"
backend: python_module(mmap)

docs: https://docs.python.org/3/library/mmap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/mmap.html — Python mmap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/mmapmodule.c"
    - "mmap.zspec.zsdl — ACCESS_READ/WRITE/COPY values; PAGESIZE/ALLOCATIONGRANULARITY positivity; mmap.__name__."
    - "mmap_extra.zspec.zsdl — mmap.__module__/__qualname__; ACCESS_* class type; ALLOCATIONGRANULARITY positivity/ge_4096."
    - "mmap_extra2.zspec.zsdl — ACCESS_NONE value/type; ACCESS_* ordering; mmap.__class__.__name__=='type'."
    - "mmap_extra3.zspec.zsdl — ACCESS_DEFAULT value/type; PROT/MAP values; PAGESIZE==16384."
    - "mmap_extra4.zspec.zsdl — method __qualname__ tables; ALLOCATIONGRANULARITY%4096==0; PROT_EXEC is_int."
    - "mmap_extra5.zspec.zsdl — MAP_ANON/MAP_ANONYMOUS; PROT_EXEC value; MADV_* values."
    - "mmap_extra6.zspec.zsdl — ACCESS_READ/WRITE/COPY __class__.__name__ standalone; PAGESIZE/__class__.__name__."
    - "mmap_extra7.zspec.zsdl — module __name__; mmap.__bases__[0].__name__; ACCESS_WRITE-ACCESS_READ==1; ALLOCATIONGRANULARITY//PAGESIZE==1."
    - "mmap_extra8.zspec.zsdl — error MRO chain; MAP_SHARED/MAP_PRIVATE bitwise ops; PAGESIZE bit-shifts; madvise/resize __name__."
  notes:
    - "This spec extends mmap.zspec.zsdl through mmap_extra8.zspec.zsdl."
    - "mmap.mmap.__name__ == 'mmap' — class name attribute. Verified Python 3.12 macOS."
    - "mmap.ACCESS_READ.__class__.__name__ == 'int' — ACCESS_READ is a plain int on Python 3.12 macOS. Verified."
    - "mmap.ACCESS_WRITE.__class__.__name__ == 'int' — ACCESS_WRITE is a plain int. Verified."
    - "mmap.ACCESS_COPY.__class__.__name__ == 'int' — ACCESS_COPY is a plain int. Verified."
    - "mmap.PAGESIZE.__class__.__name__ == 'int' — PAGESIZE is a plain int. Verified."
    - "mmap.ALLOCATIONGRANULARITY.__class__.__name__ == 'int' — ALLOCATIONGRANULARITY is a plain int. Verified."
    - "mmap.ACCESS_READ == 1 — Verified (macOS)."
    - "mmap.ACCESS_WRITE == 2 — Verified (macOS)."
    - "mmap.ALLOCATIONGRANULARITY == 16384 — Verified (macOS; same as PAGESIZE)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# mmap.mmap.__name__ == 'mmap'
#
# mmap.zspec.zsdl covers mmap.__name__ at the module attribute level.
# mmap_extra covers mmap.__module__. This invariant anchors the class
# __name__ attribute from the extra9 namespace.
# ---------------------------------------------------------------------------

invariant mmap_extra9.class_name.mmap:
  description: "mmap.mmap.__name__ == 'mmap' — class name attribute"
  category: class_names
  kind: python_call_eq
  function: mmap.__name__.__eq__
  args: ["mmap"]
  expected: true

# ---------------------------------------------------------------------------
# ACCESS_* constants — __class__.__name__ is 'int'
#
# mmap_extra and mmap_extra6 check __class__.__name__ for ACCESS_READ/WRITE/COPY
# via different paths. This table anchors all three from the extra9 namespace.
# On Python 3.12 macOS these constants are plain int, not enum members.
# ---------------------------------------------------------------------------

table mmap_extra9.access_class_names:
  description: "ACCESS_READ, ACCESS_WRITE, ACCESS_COPY are plain int constants"
  kind: python_call_eq
  category: constants
  id_prefix: acn9

  columns: [id, function, args, expected]
  rows:
    - [read,  ACCESS_READ.__class__.__name__.__eq__,  ["int"], true]
    - [write, ACCESS_WRITE.__class__.__name__.__eq__, ["int"], true]
    - [copy,  ACCESS_COPY.__class__.__name__.__eq__,  ["int"], true]

# ---------------------------------------------------------------------------
# PAGESIZE and ALLOCATIONGRANULARITY — __class__.__name__ is 'int'
#
# mmap.zspec.zsdl and mmap_extra6 cover PAGESIZE type checks via various
# paths. This table anchors both size constants from the extra9 namespace.
# ---------------------------------------------------------------------------

table mmap_extra9.size_class_names:
  description: "PAGESIZE and ALLOCATIONGRANULARITY are plain int constants"
  kind: python_call_eq
  category: constants
  id_prefix: scn9

  columns: [id, function, args, expected]
  rows:
    - [pagesize, PAGESIZE.__class__.__name__.__eq__,              ["int"], true]
    - [allocgr,  ALLOCATIONGRANULARITY.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# ACCESS_READ == 1 and ACCESS_WRITE == 2
#
# mmap.zspec.zsdl covers ACCESS_READ==1 and ACCESS_WRITE==2 as standalone
# invariants. This spec anchors them as a table in the extra9 namespace,
# paired with their class name checks for cross-reference.
# ---------------------------------------------------------------------------

invariant mmap_extra9.ACCESS_READ.value:
  description: "mmap.ACCESS_READ == 1 — read-only access mode constant value"
  category: constants
  kind: python_call_eq
  function: ACCESS_READ.__eq__
  args: [1]
  expected: true

invariant mmap_extra9.ACCESS_WRITE.value:
  description: "mmap.ACCESS_WRITE == 2 — read/write access mode constant value"
  category: constants
  kind: python_call_eq
  function: ACCESS_WRITE.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# ALLOCATIONGRANULARITY == 16384 (macOS)
#
# mmap_extra3 covers PAGESIZE==16384 as a standalone invariant.
# mmap_extra7 covers ALLOCATIONGRANULARITY//PAGESIZE==1 (implying equality).
# No prior spec checks ALLOCATIONGRANULARITY==16384 directly.
# On macOS the allocation granularity matches the page size.
# ---------------------------------------------------------------------------

invariant mmap_extra9.ALLOCATIONGRANULARITY.value:
  description: "mmap.ALLOCATIONGRANULARITY == 16384 — macOS allocation granularity equals page size"
  category: constants
  kind: python_call_eq
  function: ALLOCATIONGRANULARITY.__eq__
  args: [16384]
  expected: true
