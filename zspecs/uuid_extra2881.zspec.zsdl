spec: uu2881
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 639 (_extra2881): __iadd__, __isub__, __imul__ dict-presence checks for uuid types."
    - "uuid.UUID is the primary type; uuid.SafeUUID is an Enum (not IntEnum) subclass."
    - "uuid.RFC_4122, uuid.RESERVED_NCS, uuid.RESERVED_MICROSOFT, uuid.RESERVED_FUTURE are plain str constants, not types."
    - "None of uuid.UUID, uuid.SafeUUID define in-place augmented assignment operators (__iadd__, __isub__, __imul__) in their own __dict__."
    - "uuid.SafeUUID inherits from Enum (not int), so it does not pick up numeric in-place operators."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table uu2881.iadd:
  description: "uuid types __iadd__ dict-presence checks; wave 639"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2881
  columns: [id, function, args, expected]
  rows:
    - ["uu2881001", "uuid.UUID.__dict__.__contains__",     ["__iadd__"], false]
    - ["uu2881002", "uuid.SafeUUID.__dict__.__contains__", ["__iadd__"], false]
    - ["uu2881003", "type(uuid.uuid4()).__dict__.__contains__", ["__iadd__"], false]
    - ["uu2881004", "type(uuid.uuid1()).__dict__.__contains__", ["__iadd__"], false]
    - ["uu2881005", "type(uuid.uuid3(uuid.NAMESPACE_DNS, 'python.org')).__dict__.__contains__", ["__iadd__"], false]
    - ["uu2881006", "type(uuid.uuid5(uuid.NAMESPACE_DNS, 'python.org')).__dict__.__contains__", ["__iadd__"], false]

