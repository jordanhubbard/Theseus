spec: builtins_extra14
version: ">=3.9"
backend: python_module(builtins)

docs: https://docs.python.org/3/library/functions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functions.html — Python built-in functions documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/bltinmodule.c"
    - "builtins_extra.zspec.zsdl — covers abs(-5)==5; abs(3.14) return type; divmod(10,3) quotient/remainder; pow(2,10)==1024; round(3.14159,2)==3.14; sum([1,2,3,4])==10; max([1,2,3])==3; min([1,2,3])==1"
    - "builtins_extra13.zspec.zsdl — covers str/list/dict/tuple/set __name__; len/__name__/__class__.__name__; print/__class__.__name__; bool/__bases__.__len__(); int/__bases__.__len__(); bool.__bases__[0].__name__; str/__bases__.__len__()"
  notes:
    - "This spec extends builtins.zspec.zsdl and prior extras through builtins_extra13.zspec.zsdl."
    - "builtins_extra covers abs(-5)==5 (negative int) but NOT abs(5)==5 (positive int)."
    - "builtins_extra covers abs(3.14).__class__.__name__ but NOT the value abs(-3.14)==3.14."
    - "builtins_extra covers divmod(10,3) quotient==3 and remainder==1 but NOT divmod(7,2)."
    - "builtins_extra covers sum([1,2,3,4])==10 but NOT sum([])==0 or sum([1,2,3])==6."
    - "builtins_extra covers max([1,2,3])==3 and min([1,2,3])==1 but NOT other lists."
    - "builtins_extra covers round(3.14159,2)==3.14 (two-arg form) but NOT round(3.7)==4 or round(3.2)==3 (one-arg form)."
    - "builtins_extra covers pow(2,10)==1024 but NOT pow(2,3)==8 or pow(3,3)==27."
    - "abs(5) == 5 — abs of a positive integer is the integer itself."
    - "abs(-3.14) == 3.14 — abs of a negative float returns the float magnitude."
    - "divmod(7, 2) returns (3, 1) — 7 // 2 == 3, 7 % 2 == 1."
    - "sum([]) == 0 — sum of an empty iterable is the start value 0."
    - "sum([1, 2, 3]) == 6 — sum of three-element list."
    - "round(3.7) == 4 — one-arg round rounds to nearest integer."
    - "round(3.2) == 3 — one-arg round rounds to nearest integer."
    - "pow(2, 3) == 8 — 2 raised to the power 3."
    - "pow(3, 3) == 27 — 3 raised to the power 3."
    - "max([5, 3, 8]) == 8 — maximum of a list."
    - "min([5, 3, 8]) == 3 — minimum of a list."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abs() — additional test vectors
#
# builtins_extra covers abs(-5)==5 and abs(3.14) type check.
# No prior spec covers abs(5)==5 (positive input) or abs(-3.14)==3.14 (float value).
# ---------------------------------------------------------------------------

table builtins_extra14.abs_values:
  description: "abs() on positive int and negative float — value checks not yet covered"
  kind: python_call_eq
  category: function_calls

  columns: [id, function, args, expected]
  rows:
    - [positive_int,   abs, [5],     5]
    - [negative_float, abs, [-3.14], 3.14]

# ---------------------------------------------------------------------------
# divmod() — additional inputs
#
# builtins_extra covers divmod(10, 3) quotient==3 and remainder==1.
# No prior spec covers divmod(7, 2). divmod(7, 2) returns (3, 1):
# 7 // 2 == 3, 7 % 2 == 1.
# ---------------------------------------------------------------------------

invariant builtins_extra14.divmod.7_2_quotient:
  description: "builtins.divmod(7, 2)[0] == 3 — 7 // 2 == 3"
  category: function_calls
  kind: python_call_eq
  function: divmod
  args: [7, 2]
  method: __getitem__
  method_args: [0]
  expected: 3

invariant builtins_extra14.divmod.7_2_remainder:
  description: "builtins.divmod(7, 2)[1] == 1 — 7 % 2 == 1"
  category: function_calls
  kind: python_call_eq
  function: divmod
  args: [7, 2]
  method: __getitem__
  method_args: [1]
  expected: 1

# ---------------------------------------------------------------------------
# sum() — empty list and three-element list
#
# builtins_extra covers sum([1,2,3,4]) == 10.
# No prior spec covers sum([]) == 0 or sum([1,2,3]) == 6.
# sum() with an empty iterable returns the default start value 0.
# ---------------------------------------------------------------------------

invariant builtins_extra14.sum.empty:
  description: "builtins.sum([]) == 0 — sum of empty iterable is the start value 0"
  category: function_calls
  kind: python_call_eq
  function: sum
  args: [[]]
  expected: 0

invariant builtins_extra14.sum.three_elements:
  description: "builtins.sum([1, 2, 3]) == 6 — sum of [1, 2, 3]"
  category: function_calls
  kind: python_call_eq
  function: sum
  args: [[1, 2, 3]]
  expected: 6

# ---------------------------------------------------------------------------
# round() — one-argument form
#
# builtins_extra covers round(3.14159, 2) == 3.14 (two-argument form).
# No prior spec covers the one-argument form round(x) which rounds to an int.
# round(3.7) == 4 and round(3.2) == 3 (round half to even / banker's rounding).
# ---------------------------------------------------------------------------

invariant builtins_extra14.round.3_7:
  description: "builtins.round(3.7) == 4 — one-arg round rounds 3.7 up to nearest integer"
  category: function_calls
  kind: python_call_eq
  function: round
  args: [3.7]
  expected: 4

invariant builtins_extra14.round.3_2:
  description: "builtins.round(3.2) == 3 — one-arg round rounds 3.2 down to nearest integer"
  category: function_calls
  kind: python_call_eq
  function: round
  args: [3.2]
  expected: 3

# ---------------------------------------------------------------------------
# pow() — additional exponents
#
# builtins_extra covers pow(2, 10) == 1024.
# No prior spec covers pow(2, 3) == 8 or pow(3, 3) == 27.
# ---------------------------------------------------------------------------

table builtins_extra14.pow_values:
  description: "pow() with small exponents — test vectors not yet covered"
  kind: python_call_eq
  category: function_calls

  columns: [id, function, args, expected]
  rows:
    - [2_pow_3, pow, [2, 3], 8]
    - [3_pow_3, pow, [3, 3], 27]

# ---------------------------------------------------------------------------
# max() and min() — different list inputs
#
# builtins_extra covers max([1,2,3])==3 and min([1,2,3])==1.
# No prior spec covers max([5,3,8]) or min([5,3,8]).
# ---------------------------------------------------------------------------

invariant builtins_extra14.max.unordered_list:
  description: "builtins.max([5, 3, 8]) == 8 — maximum of an unordered list"
  category: function_calls
  kind: python_call_eq
  function: max
  args: [[5, 3, 8]]
  expected: 8

invariant builtins_extra14.min.unordered_list:
  description: "builtins.min([5, 3, 8]) == 3 — minimum of an unordered list"
  category: function_calls
  kind: python_call_eq
  function: min
  args: [[5, 3, 8]]
  expected: 3
