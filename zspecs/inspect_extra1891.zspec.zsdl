spec: inspect_extra1891
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "inspect module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any third-party inspect extensions"
  notes:
    - "Tests unary arithmetic protocol and async iteration protocol membership in inspect types"
    - "None of the inspect types implement unary arithmetic dunder methods"
    - "None of the inspect types implement async iteration protocol methods"
    - "classify_class_attrs, getattr_static, getmro are longstanding public API"
    - "getmembers_static added in Python 3.11; ismethodwrapper added in Python 3.11"
    - "indentsize removed in Python 3.11"
    - "isabstract, isroutine, ismethoddescriptor, isdatadescriptor are stable public API"
  created_at: "2026-04-12"

table inspect_extra1891.unary_arithmetic:
  columns: [id, function, args, expected]
  rows:
    - ["in1891-ua-001", "inspect.Parameter.__dict__.__contains__", ["__abs__"], false]
    - ["in1891-ua-002", "inspect.Parameter.__dict__.__contains__", ["__neg__"], false]
    - ["in1891-ua-003", "inspect.Parameter.__dict__.__contains__", ["__pos__"], false]
    - ["in1891-ua-004", "inspect.Signature.__dict__.__contains__", ["__abs__"], false]
    - ["in1891-ua-005", "inspect.Signature.__dict__.__contains__", ["__neg__"], false]
    - ["in1891-ua-006", "inspect.BoundArguments.__dict__.__contains__", ["__abs__"], false]
    - ["in1891-ua-007", "inspect.BoundArguments.__dict__.__contains__", ["__neg__"], false]
    - ["in1891-ua-008", "inspect.BoundArguments.__dict__.__contains__", ["__round__"], false]

table inspect_extra1891.async_iteration_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["in1891-ai-001", "inspect.Parameter.__dict__.__contains__", ["__aiter__"], false]
    - ["in1891-ai-002", "inspect.Parameter.__dict__.__contains__", ["__anext__"], false]
    - ["in1891-ai-003", "inspect.Signature.__dict__.__contains__", ["__aiter__"], false]
    - ["in1891-ai-004", "inspect.Signature.__dict__.__contains__", ["__anext__"], false]
    - ["in1891-ai-005", "inspect.BoundArguments.__dict__.__contains__", ["__aiter__"], false]
    - ["in1891-ai-006", "inspect.BoundArguments.__dict__.__contains__", ["__anext__"], false]
    - ["in1891-ai-007", "inspect.BoundArguments.__dict__.__contains__", ["__length_hint__"], false]
    - ["in1891-ai-008", "inspect.Signature.__dict__.__contains__", ["__length_hint__"], false]

table inspect_extra1891.inspect_classify_attrs:
  columns: [id, function, args, expected]
  rows:
    - ["in1891-ca-001", "inspect.__dict__.__contains__", ["classify_class_attrs"], true]
    - ["in1891-ca-002", "inspect.__dict__.__contains__", ["getmembers_static"], true]
    - ["in1891-ca-003", "inspect.__dict__.__contains__", ["getattr_static"], true]
    - ["in1891-ca-004", "inspect.__dict__.__contains__", ["getmro"], true]
    - ["in1891-ca-005", "inspect.__dict__.__contains__", ["indentsize"], false]
    - ["in1891-ca-006", "inspect.__dict__.__contains__", ["isabstract"], true]
    - ["in1891-ca-007", "inspect.__dict__.__contains__", ["ismethodwrapper"], true]
    - ["in1891-ca-008", "inspect.__dict__.__contains__", ["isroutine"], true]
    - ["in1891-ca-009", "inspect.__dict__.__contains__", ["ismethoddescriptor"], true]
    - ["in1891-ca-010", "inspect.__dict__.__contains__", ["isdatadescriptor"], true]
