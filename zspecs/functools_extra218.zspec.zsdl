spec: functools_extra218
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "functools_extra217.zspec.zsdl — covers functools __qualname__ equality and length checks"
    - "functools.zspec.zsdl — covers WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES and callable type checks"
  notes:
    - "functools.reduce.__doc__.__contains__('reduce') == True — the reduce docstring mentions 'reduce' in its example. Verified with Python 3.14.3."
    - "functools.reduce.__doc__.__contains__('iterable') == True — the reduce docstring describes applying a function cumulatively to items of an iterable. Verified with Python 3.14.3."
    - "functools.lru_cache.__doc__.__contains__('cache') == True — the lru_cache docstring describes a Least-recently-used cache decorator. Verified with Python 3.14.3."
    - "functools.lru_cache.__doc__.__contains__('maxsize') == True — the lru_cache docstring mentions the *maxsize* parameter explicitly. Verified with Python 3.14.3."
    - "functools.partial.__doc__.__contains__('partial') == True — the partial docstring says 'Create a new function with partial application'. Verified with Python 3.14.3."
    - "functools.wraps.__doc__.__contains__('wrapper') == True — the wraps docstring says 'Decorator factory to apply update_wrapper() to a wrapper function'. Verified with Python 3.14.3."
    - "functools.total_ordering.__doc__.__contains__('ordering') == True — the total_ordering docstring says 'Class decorator that fills in missing ordering methods'. Verified with Python 3.14.3."
    - "functools.singledispatch.__doc__.__contains__('generic') == True — the singledispatch docstring says 'Single-dispatch generic function decorator'. Verified with Python 3.14.3."
    - "functools.update_wrapper.__doc__.__contains__('wrapper') == True — the update_wrapper docstring says 'Update a wrapper function to look like the wrapped function'. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__doc__.__contains__('key') == True — the cmp_to_key docstring says 'Convert a cmp= function into a key= function'. Verified with Python 3.14.3."
    - "functools.reduce.__doc__.__len__() == 389 — the reduce docstring has exactly 389 characters. Verified with Python 3.14.3."
    - "functools.lru_cache.__doc__.__len__() == 743 — the lru_cache docstring has exactly 743 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools __doc__.__contains__ checks — reduce, lru_cache, partial
#
# reduce.__doc__.__contains__('reduce')     == True
# reduce.__doc__.__contains__('iterable')   == True
# lru_cache.__doc__.__contains__('cache')   == True
# lru_cache.__doc__.__contains__('maxsize') == True
# ---------------------------------------------------------------------------

table functools_extra218.doc_contains_group1:
  description: "functools __doc__.__contains__ checks for reduce and lru_cache in functdoccontains218g1 namespace — reduce.__doc__ contains 'reduce' (True) and 'iterable' (True); lru_cache.__doc__ contains 'cache' (True) and 'maxsize' (True); all four rows verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: functdoccontains218g1

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_doc_contains_reduce,
       reduce.__doc__.__contains__,
       ["reduce"],
       true,
       "functools.reduce.__doc__.__contains__('reduce') == True — the reduce docstring includes 'reduce' in its example expression; __contains__('reduce') returns True; verified with Python 3.14.3"]
    - [reduce_doc_contains_iterable,
       reduce.__doc__.__contains__,
       ["iterable"],
       true,
       "functools.reduce.__doc__.__contains__('iterable') == True — the reduce docstring describes applying a function to items of an iterable; __contains__('iterable') returns True; verified with Python 3.14.3"]
    - [lru_cache_doc_contains_cache,
       lru_cache.__doc__.__contains__,
       ["cache"],
       true,
       "functools.lru_cache.__doc__.__contains__('cache') == True — the lru_cache docstring opens with 'Least-recently-used cache decorator'; __contains__('cache') returns True; verified with Python 3.14.3"]
    - [lru_cache_doc_contains_maxsize,
       lru_cache.__doc__.__contains__,
       ["maxsize"],
       true,
       "functools.lru_cache.__doc__.__contains__('maxsize') == True — the lru_cache docstring mentions the *maxsize* parameter explicitly; __contains__('maxsize') returns True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: functools __doc__.__contains__ checks — partial, wraps, total_ordering, singledispatch
#
# partial.__doc__.__contains__('partial')               == True
# wraps.__doc__.__contains__('wrapper')                 == True
# total_ordering.__doc__.__contains__('ordering')       == True
# singledispatch.__doc__.__contains__('generic')        == True
# ---------------------------------------------------------------------------

table functools_extra218.doc_contains_group2:
  description: "functools __doc__.__contains__ checks for partial, wraps, total_ordering, and singledispatch in functdoccontains218g2 namespace — partial.__doc__ contains 'partial' (True), wraps.__doc__ contains 'wrapper' (True), total_ordering.__doc__ contains 'ordering' (True), singledispatch.__doc__ contains 'generic' (True); all four rows verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: functdoccontains218g2

  columns: [id, function, args, expected, description]
  rows:
    - [partial_doc_contains_partial,
       partial.__doc__.__contains__,
       ["partial"],
       true,
       "functools.partial.__doc__.__contains__('partial') == True — the partial docstring says 'Create a new function with partial application'; __contains__('partial') returns True; verified with Python 3.14.3"]
    - [wraps_doc_contains_wrapper,
       wraps.__doc__.__contains__,
       ["wrapper"],
       true,
       "functools.wraps.__doc__.__contains__('wrapper') == True — the wraps docstring says 'Decorator factory to apply update_wrapper() to a wrapper function'; __contains__('wrapper') returns True; verified with Python 3.14.3"]
    - [total_ordering_doc_contains_ordering,
       total_ordering.__doc__.__contains__,
       ["ordering"],
       true,
       "functools.total_ordering.__doc__.__contains__('ordering') == True — the total_ordering docstring says 'Class decorator that fills in missing ordering methods'; __contains__('ordering') returns True; verified with Python 3.14.3"]
    - [singledispatch_doc_contains_generic,
       singledispatch.__doc__.__contains__,
       ["generic"],
       true,
       "functools.singledispatch.__doc__.__contains__('generic') == True — the singledispatch docstring says 'Single-dispatch generic function decorator'; __contains__('generic') returns True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: functools __doc__.__len__ checks
#
# reduce.__doc__.__len__()         == 389
# lru_cache.__doc__.__len__()      == 743
# partial.__doc__.__len__()        == 83
# update_wrapper.__doc__.__len__() == 458
# ---------------------------------------------------------------------------

table functools_extra218.doc_len:
  description: "functools __doc__.__len__ checks in functdoclen218 namespace — reduce.__doc__ has len 389, lru_cache.__doc__ has len 743, partial.__doc__ has len 83, update_wrapper.__doc__ has len 458; all four rows verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: functdoclen218

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_doc_len,
       reduce.__doc__.__len__,
       [],
       389,
       "functools.reduce.__doc__.__len__() == 389 — the reduce docstring has exactly 389 characters; verified with Python 3.14.3"]
    - [lru_cache_doc_len,
       lru_cache.__doc__.__len__,
       [],
       743,
       "functools.lru_cache.__doc__.__len__() == 743 — the lru_cache docstring has exactly 743 characters; verified with Python 3.14.3"]
    - [partial_doc_len,
       partial.__doc__.__len__,
       [],
       83,
       "functools.partial.__doc__.__len__() == 83 — the partial docstring has exactly 83 characters; verified with Python 3.14.3"]
    - [update_wrapper_doc_len,
       update_wrapper.__doc__.__len__,
       [],
       458,
       "functools.update_wrapper.__doc__.__len__() == 458 — the update_wrapper docstring has exactly 458 characters; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — functools_extra218
# ---------------------------------------------------------------------------

invariant functools_extra218.reduce_doc_contains_reduce:
  description: "functools.reduce.__doc__.__contains__('reduce') == True — the reduce docstring includes 'reduce' in its example; new to extra218; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: reduce.__doc__.__contains__
  args: ["reduce"]
  expected: true

invariant functools_extra218.reduce_doc_contains_iterable:
  description: "functools.reduce.__doc__.__contains__('iterable') == True — the reduce docstring describes an iterable argument; new to extra218; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: reduce.__doc__.__contains__
  args: ["iterable"]
  expected: true

invariant functools_extra218.lru_cache_doc_contains_cache:
