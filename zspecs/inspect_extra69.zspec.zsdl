spec: inspect_extra69
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra68.zspec.zsdl."
    - "Wave 235 theme: getattr_static, isabstract, ismethod, iscoroutinefunction identity and code object attributes."
    - "getattr_static.__class__.__name__ == 'function' — getattr_static is a pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "getattr_static.__module__ == 'inspect' — defined in and exported from Lib/inspect.py. Verified with Python 3.14.3."
    - "getattr_static.__qualname__ == 'getattr_static' — top-level function so qualname equals simple name. Verified with Python 3.14.3."
    - "getattr_static.__code__.co_name == 'getattr_static' — code object name matches the function's def name. Verified with Python 3.14.3."
    - "getattr_static.__code__.co_argcount == 3 — signature is getattr_static(obj, name, default); three positional parameters. Verified with Python 3.14.3."
    - "getattr_static.__defaults__.__len__() == 1 — 'default' has one default argument (_sentinel); __defaults__ is a 1-element tuple. Verified with Python 3.14.3."
    - "isabstract.__class__.__name__ == 'function' — isabstract is a pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "isabstract.__module__ == 'inspect' — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "isabstract.__qualname__ == 'isabstract' — top-level function so qualname equals simple name. Verified with Python 3.14.3."
    - "isabstract.__code__.co_argcount == 1 — signature is isabstract(object); one positional parameter. Verified with Python 3.14.3."
    - "ismethod.__class__.__name__ == 'function' — ismethod is a pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "ismethod.__module__ == 'inspect' — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "ismethod.__code__.co_argcount == 1 — signature is ismethod(object); one positional parameter. Verified with Python 3.14.3."
    - "iscoroutinefunction.__class__.__name__ == 'function' — iscoroutinefunction is a pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "iscoroutinefunction.__module__ == 'inspect' — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "iscoroutinefunction.__code__.co_argcount == 1 — signature is iscoroutinefunction(object); one positional parameter. Verified with Python 3.14.3."
    - "No prior inspect spec checks getattr_static.__code__.co_argcount, isabstract identity, ismethod identity, or iscoroutinefunction identity in the inspid69 namespace. All checks in this spec are new to extra69."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# getattr_static identity — extra69
#
# Wave 235 theme: getattr_static is a pure-Python function in Lib/inspect.py.
#
# inspect.getattr_static retrieves attributes without triggering dynamic
# lookup (no descriptors, __getattr__, __getattribute__). Its signature is:
#   def getattr_static(obj, name, default=_sentinel)
#
# getattr_static.__class__.__name__ == 'function'
# getattr_static.__module__         == 'inspect'
# getattr_static.__qualname__       == 'getattr_static'
# getattr_static.__code__.co_name   == 'getattr_static'
#
# No prior inspect spec checks these getattr_static attributes. New to extra69.
# ---------------------------------------------------------------------------

table inspect_extra69.getattr_static_identity:
  description: "getattr_static identity: __class__.__name__=='function', __module__=='inspect', __qualname__=='getattr_static', co_name=='getattr_static'; wave 235 getattr_static identity; new to extra69"
  kind: python_call_eq
  category: function_identity
  id_prefix: inspid69

  columns: [id, function, args, expected, description]
  rows:
    - [getattr_static_class_name_eq_function,
       getattr_static.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.getattr_static.__class__.__name__.__eq__('function') == True — getattr_static is a pure-Python function defined in Lib/inspect.py; it retrieves attributes statically without triggering descriptor protocols or __getattr__; its __class__ is the built-in function type; function.__name__ == 'function' (8 chars); __eq__ returns True; no prior inspect spec checks getattr_static.__class__.__name__; new to extra69"]
    - [getattr_static_module_eq_inspect,
       getattr_static.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getattr_static.__module__.__eq__('inspect') == True — getattr_static is defined in Lib/inspect.py and belongs to the inspect module; its __module__ attribute is set to 'inspect' at import time; __eq__ on the str 'inspect' (7 chars) returns True; no prior inspect spec checks getattr_static.__module__; new to extra69"]
    - [getattr_static_qualname_eq_getattr_static,
       getattr_static.__qualname__.__eq__,
       ["getattr_static"],
       true,
       "inspect.getattr_static.__qualname__.__eq__('getattr_static') == True — getattr_static is a top-level function in the inspect module (no enclosing class or function scope); its __qualname__ is therefore equal to its simple name 'getattr_static' (14 chars); __eq__ returns True; no prior inspect spec checks getattr_static.__qualname__; new to extra69"]
    - [getattr_static_code_co_name_eq_getattr_static,
       getattr_static.__code__.co_name.__eq__,
       ["getattr_static"],
       true,
       "inspect.getattr_static.__code__.co_name.__eq__('getattr_static') == True — getattr_static is a pure-Python function; its code object (a types.CodeType instance) has a co_name attribute equal to the function name as it appears in the def statement; the function is defined as 'def getattr_static(obj, name, default=_sentinel):' so co_name == 'getattr_static' (14 chars); __eq__ returns True; no prior inspect spec checks getattr_static.__code__.co_name; new to extra69"]

# ---------------------------------------------------------------------------
# getattr_static code object attributes — extra69
#
# Wave 235 theme: getattr_static code object details.
#
# getattr_static(obj, name, default=_sentinel) has three parameters:
#   - obj: required positional
#   - name: required positional
#   - default: optional positional with default _sentinel
#
# getattr_static.__code__.co_argcount == 3   (three positional parameters)
# getattr_static.__defaults__.__len__() == 1 (one default: for 'default')
#
# No prior inspect spec checks getattr_static.__code__.co_argcount or
# __defaults__.__len__(). New to extra69.
# ---------------------------------------------------------------------------

table inspect_extra69.getattr_static_code:
  description: "getattr_static code object: co_argcount==3, __defaults__.__len__()==1; wave 235 getattr_static code attributes; new to extra69"
  kind: python_call_eq
  category: function_code
  id_prefix: inspid69

  columns: [id, function, args, expected, description]
  rows:
    - [getattr_static_co_argcount_eq_3,
       getattr_static.__code__.co_argcount.__eq__,
       [3],
       true,
       "inspect.getattr_static.__code__.co_argcount.__eq__(3) == True — getattr_static is defined as 'def getattr_static(obj, name, default=_sentinel):' with three positional parameters: 'obj' (the object to inspect), 'name' (the attribute name), and 'default' (the value to return if the attribute is not found); co_argcount counts positional parameters excluding *args and **kwargs; for getattr_static co_argcount == 3; int.__eq__(3) returns True; no prior inspect spec checks getattr_static.__code__.co_argcount; new to extra69"]
    - [getattr_static_defaults_len_eq_1,
       getattr_static.__defaults__.__len__,
       [],
       1,
       "inspect.getattr_static.__defaults__.__len__() == 1 — getattr_static(obj, name, default=_sentinel) has one positional parameter with a default: 'default' is optional and defaults to the internal _sentinel object; __defaults__ is a tuple containing that one default value; tuple.__len__() returns 1; no prior inspect spec checks getattr_static.__defaults__.__len__(); new to extra69"]

# ---------------------------------------------------------------------------
# inspect predicate functions identity — extra69
#
# Wave 235 theme: isabstract, ismethod, iscoroutinefunction are all Python
# functions in the inspect module.
#
# All three are defined in Lib/inspect.py:
#   isabstract(object)          — checks if object is abstract
#   ismethod(object)            — checks if object is a bound method
#   iscoroutinefunction(object) — checks if object is a coroutine function
#
# isabstract.__class__.__name__         == 'function'
# isabstract.__module__                 == 'inspect'
# ismethod.__class__.__name__           == 'function'
# iscoroutinefunction.__class__.__name__ == 'function'
#
# No prior inspect spec checks any of these in the inspid69 namespace.
# New to extra69.
# ---------------------------------------------------------------------------

table inspect_extra69.inspect_predicate_functions:
  description: "isabstract/ismethod/iscoroutinefunction are Python functions in inspect module; __class__.__name__=='function' and __module__=='inspect'; wave 235 predicate function identity; new to extra69"
  kind: python_call_eq
  category: function_identity
  id_prefix: inspid69

  columns: [id, function, args, expected, description]
  rows:
    - [isabstract_class_name_eq_function,
       isabstract.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.isabstract.__class__.__name__.__eq__('function') == True — isabstract is a pure-Python function defined in Lib/inspect.py that returns True if an object is an abstract base class with unimplemented abstract methods; its __class__ is the built-in function type; function.__name__ == 'function' (8 chars); __eq__ returns True; no prior inspect spec checks isabstract.__class__.__name__; new to extra69"]
    - [isabstract_module_eq_inspect,
       isabstract.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.isabstract.__module__.__eq__('inspect') == True — isabstract is defined in Lib/inspect.py; its __module__ attribute is 'inspect' (7 chars); __eq__ returns True; no prior inspect spec checks isabstract.__module__; new to extra69"]
    - [ismethod_class_name_eq_function,
       ismethod.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.ismethod.__class__.__name__.__eq__('function') == True — ismethod is a pure-Python function defined in Lib/inspect.py that returns True if the object is a bound method (a function bound to a class instance or class); its __class__ is the built-in function type; function.__name__ == 'function' (8 chars); __eq__ returns True; no prior inspect spec checks ismethod.__class__.__name__; new to extra69"]
    - [iscoroutinefunction_class_name_eq_function,
       iscoroutinefunction.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.iscoroutinefunction.__class__.__name__.__eq__('function') == True — iscoroutinefunction is a pure-Python function defined in Lib/inspect.py that returns True if the object is a coroutine function (defined with 'async def'); its __class__ is the built-in function type; function.__name__ == 'function' (8 chars); __eq__ returns True; no prior inspect spec checks iscoroutinefunction.__class__.__name__; new to extra69"]

# ---------------------------------------------------------------------------
# inspect predicate functions co_argcount — extra69
#
# Wave 235 theme: isabstract, ismethod, iscoroutinefunction each take exactly
# one positional argument named 'object'.
#
# isabstract(object)          — co_argcount == 1
# ismethod(object)            — co_argcount == 1
# iscoroutinefunction(object) — co_argcount == 1
#
# No prior inspect spec checks co_argcount for these three functions.
# New to extra69.
# ---------------------------------------------------------------------------

table inspect_extra69.inspect_predicate_code:
  description: "isabstract/ismethod/iscoroutinefunction __code__.co_argcount==1 — each takes a single positional argument; wave 235 predicate code attributes; new to extra69"
  kind: python_call_eq
  category: function_code
  id_prefix: inspid69

  columns: [id, function, args, expected, description]
  rows:
    - [isabstract_co_argcount_eq_1,
       isabstract.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.isabstract.__code__.co_argcount.__eq__(1) == True — isabstract is defined as 'def isabstract(object):' with a single positional parameter 'object'; co_argcount counts positional parameters excluding *args and **kwargs; for isabstract co_argcount == 1; int.__eq__(1) returns True; no prior inspect spec checks isabstract.__code__.co_argcount; new to extra69"]
    - [ismethod_co_argcount_eq_1,
       ismethod.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.ismethod.__code__.co_argcount.__eq__(1) == True — ismethod is defined as 'def ismethod(object):' with a single positional parameter 'object'; co_argcount counts positional parameters excluding *args and **kwargs; for ismethod co_argcount == 1; int.__eq__(1) returns True; no prior inspect spec checks ismethod.__code__.co_argcount; new to extra69"]
    - [iscoroutinefunction_co_argcount_eq_1,
       iscoroutinefunction.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.iscoroutinefunction.__code__.co_argcount.__eq__(1) == True — iscoroutinefunction is defined as 'def iscoroutinefunction(object):' with a single positional parameter 'object'; co_argcount counts positional parameters excluding *args and **kwargs; for iscoroutinefunction co_argcount == 1; int.__eq__(1) returns True; no prior inspect spec checks iscoroutinefunction.__code__.co_argcount; new to extra69"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra69
# ---------------------------------------------------------------------------

invariant inspect_extra69.getattr_static_class_function:
  description: "inspect.getattr_static.__class__.__name__.__eq__('function') == True — getattr_static is a pure-Python function in Lib/inspect.py; wave 235 getattr_static identity; new to extra69"
  kind: python_call_eq
  function: getattr_static.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra69.getattr_static_module_inspect:
  description: "inspect.getattr_static.__module__.__eq__('inspect') == True — getattr_static is defined in Lib/inspect.py; wave 235 getattr_static module; new to extra69"
  kind: python_call_eq
  function: getattr_static.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra69.getattr_static_co_argcount_3:
  description: "inspect.getattr_static.__code__.co_argcount.__eq__(3) == True — getattr_static(obj, name, default) has 3 positional parameters; wave 235 getattr_static code; new to extra69"
  kind: python_call_eq
  function: getattr_static.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant inspect_extra69.isabstract_class_function:
  description: "inspect.isabstract.__class__.__name__.__eq__('function') == True — isabstract is a pure-Python predicate function in Lib/inspect.py; wave 235 predicate identity; new to extra69"
  kind: python_call_eq
  function: isabstract.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra69.iscoroutinefunction_module_inspect:
  description: "inspect.iscoroutinefunction.__module__.__eq__('inspect') == True — iscoroutinefunction is defined in Lib/inspect.py; wave 235 predicate module; new to extra69"
  kind: python_call_eq
  function: iscoroutinefunction.__module__.__eq__
  args: ["inspect"]
  expected: true
