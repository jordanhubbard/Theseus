spec: vary
version: ">=1.1.0"
backend: node(vary)

docs: https://github.com/jshttp/vary#readme

provenance:
  derived_from:
    - "vary README — https://github.com/jshttp/vary#readme"
    - "RFC 7231 §7.1.4 — Vary header"
    - "Test vectors verified with vary via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "vary source"
  notes:
    - "Manage the HTTP Vary header — append, dedupe, set on a response."
    - "Install: npm install vary"
    - "v1 CJS; module export is the response-mutating vary(res, field) helper. Has .append(header, field) returning a new string."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws TypeError on invalid field input."
  stderr: "null"
  stickiness: "vary(res, field) mutates res; .append() is pure."
  codes: {}

invariant vary.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant vary.has_append:
  description: ".append() helper exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "append.constructor.name"}
  expected: "Function"

invariant vary.append_to_empty:
  description: "append('', 'Accept-Encoding') returns 'Accept-Encoding'"
  category: append
  kind: node_chain_eq
  entry: named
  function: append
  entry_args: ["", "Accept-Encoding"]
  chain: []
  expected: "Accept-Encoding"

invariant vary.append_combines_fields:
  description: "Distinct fields are combined with ', '"
  category: append
  kind: node_chain_eq
  entry: named
  function: append
  entry_args: ["Origin", "Accept-Encoding"]
  chain: []
  expected: "Origin, Accept-Encoding"

invariant vary.append_dedupes_case_insensitive:
  description: "Duplicate field (case-insensitive) is dropped"
  category: append
  kind: node_chain_eq
  entry: named
  function: append
  entry_args: ["Origin", "origin"]
  chain: []
  expected: "Origin"

invariant vary.append_wildcard_collapses:
  description: "'*' alone collapses any existing field list"
  category: append
  kind: node_chain_eq
  entry: named
  function: append
  entry_args: ["Origin, Accept-Encoding", "*"]
  chain: []
  expected: "*"
