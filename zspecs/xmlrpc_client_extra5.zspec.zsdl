spec: xmlrpc_client_extra5
version: ">=3.9"
backend: python_module(xmlrpc.client)

docs: https://docs.python.org/3/library/xmlrpc.client.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/xmlrpc.client.html — Python xmlrpc.client module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/xmlrpc/client.py"
  notes:
    - "This spec extends xmlrpc_client.zspec.zsdl through xmlrpc_client_extra4.zspec.zsdl."
    - "xmlrpc_client.zspec.zsdl covers: __name__ table (ServerProxy/Fault/ProtocolError/MultiCall/Binary/DateTime/ResponseError/Unmarshaller/Marshaller); Fault/ProtocolError base hierarchy; loads/dumps __name__; type checks; Binary.data roundtrip; Fault.faultCode/faultString; dumps returns str."
    - "xmlrpc_client_extra.zspec.zsdl covers: individual __name__ invariants for ServerProxy/Fault/ProtocolError/Binary/DateTime/Error; ServerProxy.__module__ and Error.__module__; Error.__bases__[0].__name__=='Exception'; is_type checks for ServerProxy/Fault/Error/Binary/DateTime."
    - "xmlrpc_client_extra2.zspec.zsdl covers: Fault/ProtocolError/Binary/DateTime/ResponseError __module__; Unmarshaller/Marshaller/MultiCall __name__; __qualname__ table for ServerProxy/Fault/ProtocolError/ResponseError/Error/Binary/DateTime; loads/dumps __module__."
    - "xmlrpc_client_extra3.zspec.zsdl covers: MultiCall/dumps/loads __qualname__."
    - "xmlrpc_client_extra4.zspec.zsdl covers: Unmarshaller/Marshaller __qualname__; is_type checks for Unmarshaller/Marshaller/MultiCall/ResponseError; __name__ length checks for ServerProxy/ProtocolError/Unmarshaller/Marshaller; Unmarshaller/Marshaller base checks."
    - "This spec adds: xmlrpc.client module __name__ attribute; Fault.__name__ length check; metaclass checks for Fault, ProtocolError, and ServerProxy (none covered in any prior spec)."
    - "xmlrpc.client.__name__ == 'xmlrpc.client' — the module's own __name__ dunder when imported."
    - "xmlrpc.client.Fault.__name__ has 5 characters; xmlrpc.client.ProtocolError.__name__ has 13 characters (same as ServerProxy which was already verified in extra4)."
    - "Fault, ProtocolError, and ServerProxy are all regular Python classes: metaclass is 'type'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# xmlrpc.client module __name__
# The module's own __name__ dunder equals 'xmlrpc.client' when imported.
# No prior xmlrpc_client spec has checked the module-level __name__ attribute.
# ---------------------------------------------------------------------------

invariant xmlrpc_client_extra5.module.__name__:
  description: "xmlrpc.client.__name__ == 'xmlrpc.client' — module __name__ dunder"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["xmlrpc.client"]
  expected: true

# ---------------------------------------------------------------------------
# Fault.__name__ length check
# xmlrpc_client_extra4 checks lengths for ServerProxy (11), ProtocolError (13),
# Unmarshaller (12), and Marshaller (10). Fault (5 characters) is not covered.
# ---------------------------------------------------------------------------

invariant xmlrpc_client_extra5.Fault.name_len:
  description: "xmlrpc.client.Fault.__name__.__len__() == 5 — 'Fault' has 5 characters"
  category: class_identity
  kind: python_call_eq
  function: Fault.__name__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# Metaclass checks — Fault, ProtocolError, ServerProxy
# xmlrpc_client_extra covers is_type checks via isinstance-style checks for
# ServerProxy/Fault/Error/Binary/DateTime, but does NOT check
# __class__.__name__ == 'type' for Fault, ProtocolError, or ServerProxy.
# xmlrpc_client_extra4 adds metaclass checks only for Unmarshaller/Marshaller/
# MultiCall/ResponseError. Fault, ProtocolError, and ServerProxy remain unchecked
# via the __class__.__name__ == 'type' pattern.
# ---------------------------------------------------------------------------

table xmlrpc_client_extra5.metaclass_checks:
  kind: python_call_eq
  category: class_types
  id_prefix: metaclass

  columns: [id, function, args, expected]
  rows:
    - [Fault,         Fault.__class__.__name__.__eq__,         ["type"], true]
    - [ProtocolError, ProtocolError.__class__.__name__.__eq__, ["type"], true]
    - [ServerProxy,   ServerProxy.__class__.__name__.__eq__,   ["type"], true]
