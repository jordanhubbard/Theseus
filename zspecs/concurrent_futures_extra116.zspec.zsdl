spec: concurrent_futures_extra116
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec extends concurrent_futures_extra115.zspec.zsdl."
    - "This spec covers: wave 259 theme — concurrent.futures.BrokenThreadPool and BrokenProcessPool exception class attributes not previously covered. Prior specs covered: extra66 covered BrokenProcessPool.__name__ and __module__; extra67 covered BrokenProcessPool.__bases__[0].__name__ and __mro__.__len__()==6; extra103 noted BrokenThreadPool and BrokenProcessPool MRO depth=6 in notes but did not write BrokenThreadPool-specific table rows. NOT previously covered: BrokenThreadPool.__name__.__eq__/.__len__(), BrokenThreadPool.__module__.__eq__/.__len__(), BrokenThreadPool.__qualname__.__eq__/.__len__(), BrokenThreadPool.__mro__.__len__(), BrokenThreadPool.__bases__[0].__name__; BrokenProcessPool.__qualname__.__eq__/.__len__(), BrokenProcessPool.__name__.__len__(), BrokenProcessPool.__module__.__len__(). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.thread.BrokenThreadPool.__name__ == 'BrokenThreadPool' (len=16). __module__ == 'concurrent.futures.thread' (len=25). __qualname__ == 'BrokenThreadPool' (len=16, __qualname__==__name__ for top-level class). __mro__.__len__() == 6 ([BrokenThreadPool, BrokenExecutor, RuntimeError, Exception, BaseException, object]). __bases__[0].__name__ == 'BrokenExecutor'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.process.BrokenProcessPool.__name__ == 'BrokenProcessPool' (len=17). __module__ == 'concurrent.futures.process' (len=26). __qualname__ == 'BrokenProcessPool' (len=17). __mro__.__len__() == 6 (same depth as BrokenThreadPool). __bases__[0].__name__ == 'BrokenExecutor'. Compare: BrokenThreadPool name len=16 < BrokenProcessPool name len=17 (1 more: 'Thread'=6 vs 'Process'=7); BrokenThreadPool module len=25 < BrokenProcessPool module len=26 (1 more: 'thread'=6 vs 'process'=7). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.thread.BrokenThreadPool class identity — extra116
#
# Wave 259 theme: BrokenThreadPool class-level identity attributes (first coverage).
#
# BrokenThreadPool.__name__.__len__()              == 16  ('BrokenThreadPool')
# BrokenThreadPool.__module__.__len__()            == 25  ('concurrent.futures.thread')
# BrokenThreadPool.__qualname__.__len__()          == 16  (tied with __name__)
# BrokenThreadPool.__mro__.__len__()               == 6   ([BTP, BE, RuntimeError, Exception, BaseException, object])
# BrokenThreadPool.__bases__[0].__name__           == 'BrokenExecutor'
# ---------------------------------------------------------------------------

table concurrent_futures_extra116.cf_btp_class_identity:
  description: "concurrent.futures.thread.BrokenThreadPool class identity checks in cfbtp116 namespace — wave 259 theme: first explicit coverage of BrokenThreadPool class attributes; BrokenThreadPool.__name__.__eq__('BrokenThreadPool')==True (len=16: 'Broken'=6+'Thread'=6+'Pool'=4=16; BrokenThreadPool is raised when a ThreadPoolExecutor worker thread fails catastrophically and the pool must be shut down); BrokenThreadPool.__name__.__len__()==16; BrokenThreadPool.__qualname__.__eq__('BrokenThreadPool')==True (__qualname__==__name__ for top-level exception class; len=16); BrokenThreadPool.__qualname__.__len__()==16; BrokenThreadPool.__module__.__eq__('concurrent.futures.thread')==True (len=25: 'concurrent.'=11+'futures.'=8+'thread'=6=25; defined in Lib/concurrent/futures/thread.py); BrokenThreadPool.__module__.__len__()==25; BrokenThreadPool.__mro__.__len__()==6 (the deepest exception MRO in this module: [BrokenThreadPool, BrokenExecutor, RuntimeError, Exception, BaseException, object]; 6 levels; same depth as BrokenProcessPool=6); BrokenThreadPool.__bases__[0].__name__.__eq__('BrokenExecutor')==True (BrokenThreadPool inherits directly from BrokenExecutor, not from RuntimeError or Exception directly; BrokenExecutor.__mro__.__len__()==5); compare: BrokenThreadPool.__name__.__len__()==16 vs BrokenProcessPool.__name__.__len__()==17 (1 less: 'Thread'=6 vs 'Process'=7); BrokenThreadPool.__module__.__len__()==25 vs BrokenProcessPool.__module__.__len__()==26 (1 less: 'thread'=6 vs 'process'=7); both have __mro__.__len__()==6 (same depth); verified with Python 3.14.3"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: cfbtp116

  columns: [id, function, args, expected, description]
  rows:
    - [btp_name_eq,   concurrent.futures.thread.BrokenThreadPool.__name__.__eq__,              ["BrokenThreadPool"],            true, "BrokenThreadPool.__name__ == 'BrokenThreadPool' (len=16); verified with Python 3.14.3"]
    - [btp_name_len,  concurrent.futures.thread.BrokenThreadPool.__name__.__len__,             [],                              16,   "BrokenThreadPool.__name__.__len__() == 16 ('BrokenThreadPool'=16); verified with Python 3.14.3"]
    - [btp_qn_eq,     concurrent.futures.thread.BrokenThreadPool.__qualname__.__eq__,          ["BrokenThreadPool"],            true, "BrokenThreadPool.__qualname__ == 'BrokenThreadPool' (__qualname__==__name__ for top-level class); verified with Python 3.14.3"]
    - [btp_qn_len,    concurrent.futures.thread.BrokenThreadPool.__qualname__.__len__,         [],                              16,   "BrokenThreadPool.__qualname__.__len__() == 16 (tied with __name__ len=16); verified with Python 3.14.3"]
    - [btp_mod_eq,    concurrent.futures.thread.BrokenThreadPool.__module__.__eq__,            ["concurrent.futures.thread"],   true, "BrokenThreadPool.__module__ == 'concurrent.futures.thread' (len=25); verified with Python 3.14.3"]
    - [btp_mod_len,   concurrent.futures.thread.BrokenThreadPool.__module__.__len__,           [],                              25,   "BrokenThreadPool.__module__.__len__() == 25 ('concurrent.futures.thread'=25); verified with Python 3.14.3"]
    - [btp_mro_len,   concurrent.futures.thread.BrokenThreadPool.__mro__.__len__,              [],                              6,    "BrokenThreadPool.__mro__.__len__() == 6 ([BTP, BrokenExecutor, RuntimeError, Exception, BaseException, object]); verified with Python 3.14.3"]
    - [btp_base_eq,   "concurrent.futures.thread.BrokenThreadPool.__bases__[0].__name__.__eq__", ["BrokenExecutor"],            true, "BrokenThreadPool.__bases__[0].__name__ == 'BrokenExecutor' (direct parent); verified with Python 3.14.3"]
    - [btp_base_len,  "concurrent.futures.thread.BrokenThreadPool.__bases__[0].__name__.__len__", [],                           14,   "BrokenThreadPool.__bases__[0].__name__.__len__() == 14 ('BrokenExecutor'=14); verified with Python 3.14.3"]

