# BrokenProcessPool.__mro__.__len__()       == 6   (cross-check: covered in extra67 for comparison)
# ---------------------------------------------------------------------------

table concurrent_futures_extra116.cf_bpp_new_attrs:
  description: "concurrent.futures.process.BrokenProcessPool new attribute checks in cfbtp116 namespace — wave 259 theme: BrokenProcessPool attributes not previously covered as explicit table rows; BrokenProcessPool.__qualname__.__eq__('BrokenProcessPool')==True (len=17: __qualname__==__name__ for top-level exception; NOT previously covered as equality check); BrokenProcessPool.__qualname__.__len__()==17; BrokenProcessPool.__name__.__len__()==17 (NOT previously covered as length check — only equality 'BrokenProcessPool' was covered in extra66; len=17: 'Broken'=6+'Process'=7+'Pool'=4=17); BrokenProcessPool.__module__.__len__()==26 (NOT previously covered as length — only equality was covered in extra66; 'concurrent.futures.process'=26: 'concurrent.'=11+'futures.'=8+'process'=7=26); compare with BrokenThreadPool: BrokenProcessPool.__name__.__len__()==17 > BrokenThreadPool.__name__.__len__()==16 (1 more: 'Process'=7 vs 'Thread'=6, diff=1); BrokenProcessPool.__module__.__len__()==26 > BrokenThreadPool.__module__.__len__()==25 (1 more: 'process'=7 vs 'thread'=6, diff=1); both BrokenThreadPool and BrokenProcessPool have __mro__.__len__()==6 (same depth, consistent hierarchy); BrokenProcessPool.__bases__[0].__name__=='BrokenExecutor' (covered in extra67; included here as cross-check); 'BrokenProcessPool'=17 chars vs 'BrokenThreadPool'=16 chars — the difference is 'Process'=7 vs 'Thread'=6; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: cfbtp116a

  columns: [id, function, args, expected, description]
  rows:
    - [bpp_qn_eq,    concurrent.futures.process.BrokenProcessPool.__qualname__.__eq__,  ["BrokenProcessPool"],           true, "BrokenProcessPool.__qualname__ == 'BrokenProcessPool' (first qualname equality check; len=17); verified with Python 3.14.3"]
    - [bpp_qn_len,   concurrent.futures.process.BrokenProcessPool.__qualname__.__len__, [],                              17,   "BrokenProcessPool.__qualname__.__len__() == 17 (1 more than BrokenThreadPool=16); verified with Python 3.14.3"]
    - [bpp_name_len, concurrent.futures.process.BrokenProcessPool.__name__.__len__,     [],                              17,   "BrokenProcessPool.__name__.__len__() == 17 (first name length check; 'BrokenProcessPool'=17); verified with Python 3.14.3"]
    - [bpp_mod_len,  concurrent.futures.process.BrokenProcessPool.__module__.__len__,   [],                              26,   "BrokenProcessPool.__module__.__len__() == 26 ('concurrent.futures.process'=26, 1 more than BrokenThreadPool module len=25); verified with Python 3.14.3"]
    - [bpp_mro_len,  concurrent.futures.process.BrokenProcessPool.__mro__.__len__,      [],                              6,    "BrokenProcessPool.__mro__.__len__() == 6 (same depth as BrokenThreadPool=6; cross-check); verified with Python 3.14.3"]
    - [bpp_base_len, "concurrent.futures.process.BrokenProcessPool.__bases__[0].__name__.__len__", [],                   14,   "BrokenProcessPool.__bases__[0].__name__.__len__() == 14 ('BrokenExecutor'=14; same base as BrokenThreadPool); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# BrokenThreadPool vs BrokenProcessPool comparison cross-checks — extra116
#
# Wave 259 theme: compare the two broken-pool exception classes.
#
# BrokenThreadPool name len=16 < BrokenProcessPool name len=17 (diff=1: 'Thread' vs 'Process')
# BrokenThreadPool module len=25 < BrokenProcessPool module len=26 (diff=1: 'thread' vs 'process')
# BrokenThreadPool.__mro__.__len__() == BrokenProcessPool.__mro__.__len__() == 6 (tied)
# Both share __bases__[0].__name__=='BrokenExecutor' (same direct parent)
# ---------------------------------------------------------------------------

table concurrent_futures_extra116.cf_btp_bpp_comparison:
  description: "BrokenThreadPool vs BrokenProcessPool comparison cross-checks in cfbtp116 namespace — wave 259 theme: comparing the two broken-pool exception classes side by side; BrokenThreadPool.__name__.__len__()==16 (1 less than BrokenProcessPool=17: 'Thread'=6 vs 'Process'=7, diff=1; the single-char asymmetry in the middle word propagates exactly to the class name and module name lengths); BrokenProcessPool.__name__.__len__()==17; BrokenThreadPool.__module__.__len__()==25 vs BrokenProcessPool.__module__.__len__()==26 (same 1-char difference: 'thread'=6 vs 'process'=7); both have __mro__.__len__()==6 (same depth: [BrokenXxxPool, BrokenExecutor, RuntimeError, Exception, BaseException, object]); both have __bases__[0].__name__=='BrokenExecutor' (same direct parent); the difference between 'Thread' and 'Process' (1 char) propagates consistently to: class name diff=1, qualname diff=1, module name diff=1; BrokenExecutor.__module__=='concurrent.futures._base' (len=24; 1 shorter than BrokenThreadPool module=25, 2 shorter than BrokenProcessPool module=26); BrokenExecutor.__mro__.__len__()==5 (1 less than both broken-pool classes at 6); verified with Python 3.14.3"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: cfbtp116b

  columns: [id, function, args, expected, description]
  rows:
    - [btp_name_16, concurrent.futures.thread.BrokenThreadPool.__name__.__len__,   [], 16, "BrokenThreadPool.__name__.__len__() == 16 (1 less than BrokenProcessPool=17); verified with Python 3.14.3"]
    - [bpp_name_17, concurrent.futures.process.BrokenProcessPool.__name__.__len__, [], 17, "BrokenProcessPool.__name__.__len__() == 17 (1 more than BrokenThreadPool=16); verified with Python 3.14.3"]
    - [btp_mod_25,  concurrent.futures.thread.BrokenThreadPool.__module__.__len__,   [], 25, "BrokenThreadPool.__module__.__len__() == 25 (1 less than BrokenProcessPool module=26); verified with Python 3.14.3"]
    - [bpp_mod_26,  concurrent.futures.process.BrokenProcessPool.__module__.__len__, [], 26, "BrokenProcessPool.__module__.__len__() == 26 (1 more than BrokenThreadPool module=25); verified with Python 3.14.3"]
    - [btp_mro_6,   concurrent.futures.thread.BrokenThreadPool.__mro__.__len__,     [], 6,  "BrokenThreadPool.__mro__.__len__() == 6 (tied with BrokenProcessPool=6); verified with Python 3.14.3"]
    - [bpp_mro_6,   concurrent.futures.process.BrokenProcessPool.__mro__.__len__,   [], 6,  "BrokenProcessPool.__mro__.__len__() == 6 (tied with BrokenThreadPool=6); verified with Python 3.14.3"]
    - [be_mro_5,    concurrent.futures.BrokenExecutor.__mro__.__len__,              [], 5,  "BrokenExecutor.__mro__.__len__() == 5 (1 less than both broken-pool classes at 6); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra116
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra116.BrokenThreadPool_name_len_16:
  description: "concurrent.futures.thread.BrokenThreadPool.__name__.__len__() == 16 — 'BrokenThreadPool' = 'Broken'=6+'Thread'=6+'Pool'=4=16; BrokenThreadPool.__name__.__eq__('BrokenThreadPool')==True; BrokenThreadPool.__qualname__.__len__()==16 (tied: __qualname__==__name__ for top-level class); BrokenThreadPool is raised when a ThreadPoolExecutor worker thread terminates abruptly (e.g., due to a segfault or forced termination); once raised the entire pool is considered broken and subsequent calls to Future.result() or Future.exception() on futures submitted to that pool will also raise BrokenThreadPool; BrokenThreadPool.__module__=='concurrent.futures.thread' (len=25); BrokenThreadPool.__mro__.__len__()==6; BrokenThreadPool.__bases__[0].__name__=='BrokenExecutor'; compare: BrokenProcessPool.__name__.__len__()==17 (1 more: 'Process'=7 vs 'Thread'=6); BrokenExecutor.__name__.__len__()==14 (2 less than BrokenThreadPool: 'Executor'=8 < 'ThreadPool'=10); first standalone BrokenThreadPool name length invariant in cfbtp116 namespace; wave 259; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_hierarchy
  kind: python_call_eq
  function: concurrent.futures.thread.BrokenThreadPool.__name__.__len__
  args: []
  expected: 16

invariant concurrent_futures_extra116.BrokenThreadPool_module_len_25:
  description: "concurrent.futures.thread.BrokenThreadPool.__module__.__len__() == 25 — 'concurrent.futures.thread' = 'concurrent.'=11+'futures.'=8+'thread'=6=25; BrokenThreadPool.__module__.__eq__('concurrent.futures.thread')==True; BrokenThreadPool is defined in Lib/concurrent/futures/thread.py and its __module__ reflects the submodule path; compare: BrokenProcessPool.__module__.__len__()==26 ('concurrent.futures.process'=26; 1 more than thread=25 because 'process'=7 vs 'thread'=6); BrokenExecutor.__module__.__len__()==24 ('concurrent.futures._base'=24; 1 less than BrokenThreadPool=25); module length ordering: BrokenExecutor=24 < BrokenThreadPool=25 < BrokenProcessPool=26 (each 1 apart); BrokenThreadPool.__name__.__len__()==16; BrokenThreadPool.__mro__.__len__()==6; first standalone BrokenThreadPool module length invariant in cfbtp116 namespace; wave 259; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_hierarchy
  kind: python_call_eq
  function: concurrent.futures.thread.BrokenThreadPool.__module__.__len__
  args: []
  expected: 25

invariant concurrent_futures_extra116.BrokenThreadPool_mro_len_6:
  description: "concurrent.futures.thread.BrokenThreadPool.__mro__.__len__() == 6 — the MRO is [BrokenThreadPool, BrokenExecutor, RuntimeError, Exception, BaseException, object]: 6 entries; this is the deepest exception MRO in the concurrent.futures module; compare: BrokenExecutor.__mro__.__len__()==5 (one shorter; BrokenThreadPool adds 1 level by inheriting BrokenExecutor); Executor.__mro__.__len__()==2 (shortest; inherits directly from object); BrokenThreadPool.__mro__.__len__()==6 tied with BrokenProcessPool.__mro__.__len__()==6; the MRO path: BrokenThreadPool -> BrokenExecutor -> RuntimeError -> Exception -> BaseException -> object explains why catching any of RuntimeError, Exception, or BaseException also catches BrokenThreadPool; BrokenThreadPool.__bases__[0].__name__=='BrokenExecutor'; BrokenThreadPool.__name__.__len__()==16; BrokenThreadPool.__module__.__len__()==25; first standalone BrokenThreadPool MRO length invariant in cfbtp116 namespace; wave 259; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_hierarchy
  kind: python_call_eq
  function: concurrent.futures.thread.BrokenThreadPool.__mro__.__len__
  args: []
  expected: 6

invariant concurrent_futures_extra116.BrokenThreadPool_base_BrokenExecutor:
  description: "concurrent.futures.thread.BrokenThreadPool.__bases__[0].__name__.__eq__('BrokenExecutor') returns True — BrokenThreadPool inherits directly from BrokenExecutor (not from RuntimeError directly); __bases__[0].__name__=='BrokenExecutor' (len=14); BrokenExecutor.__mro__.__len__()==5 (1 less than BrokenThreadPool=6; adding BrokenThreadPool as the top adds 1 level); BrokenThreadPool.__mro__.__len__()==6; BrokenExecutor.__module__=='concurrent.futures._base' (len=24); both BrokenThreadPool and BrokenProcessPool share the same direct parent BrokenExecutor — the single-hierarchy design means code that catches BrokenExecutor catches both pool types; BrokenThreadPool.__name__.__len__()==16; BrokenThreadPool.__module__.__len__()==25; first standalone BrokenThreadPool __bases__[0].__name__ equality invariant in cfbtp116 namespace; wave 259; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_hierarchy
  kind: python_call_eq
  function: "concurrent.futures.thread.BrokenThreadPool.__bases__[0].__name__.__eq__"
  args: ["BrokenExecutor"]
  expected: true

invariant concurrent_futures_extra116.BrokenProcessPool_qualname_len_17:
  description: "concurrent.futures.process.BrokenProcessPool.__qualname__.__len__() == 17 — 'BrokenProcessPool' = 'Broken'=6+'Process'=7+'Pool'=4=17; BrokenProcessPool.__qualname__.__eq__('BrokenProcessPool')==True (first qualname equality check for BrokenProcessPool; prior specs only covered __name__/__module__/__bases__[0]/__mro__); __qualname__==__name__ for top-level exception classes; BrokenProcessPool.__name__.__len__()==17 (tied with __qualname__); BrokenProcessPool.__module__.__len__()==26 ('concurrent.futures.process'=26); BrokenProcessPool is raised when a ProcessPoolExecutor worker process terminates abruptly; subsequent calls on futures submitted to that pool will also raise BrokenProcessPool; compare: BrokenProcessPool.__qualname__.__len__()==17 > BrokenThreadPool.__qualname__.__len__()==16 (1 more: 'Process'=7 vs 'Thread'=6); BrokenExecutor.__qualname__.__len__()==14 (covered in extra103; 3 less than BrokenProcessPool); first standalone BrokenProcessPool __qualname__ length invariant in cfbtp116 namespace; wave 259; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_hierarchy
  kind: python_call_eq
  function: concurrent.futures.process.BrokenProcessPool.__qualname__.__len__
  args: []
  expected: 17

