spec: hashlib_extra117
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra116.zspec.zsdl — covers HASH instance method type identity (update/digest/hexdigest/copy are builtin_function_or_method) / HASH instance method qualname equality ('HASH.update', 'HASH.digest', etc.) / sha256().__class__.__module__ equality (table + invariants)."
    - "hashlib_extra115.zspec.zsdl — covers hash object .name attribute equality and lengths / hashlib.new function identity / pbkdf2_hmac module and type (table + invariants)."
    - "hashlib_extra113.zspec.zsdl — covers HASH class-level descriptor types / HASH descriptor qualnames and __objclass__ (table + invariants)."
    - "hashlib_extra112.zspec.zsdl — covers md5/sha1/sha256/sha512 function __qualname__ string equality / sha224/sha384/sha3_512/blake2s qualname equality / qualname length groupings (table + invariants)."
    - "hashlib_extra108.zspec.zsdl — covers sha224/sha384/sha3_256/sha3_512 digest_size and block_size / blake2b/blake2s digest_size and block_size (table + invariants)."
    - "hashlib_extra107.zspec.zsdl — covers HASH type identity (__name__=='HASH', __module__=='_hashlib', __mro__.__len__()==2) (table + invariants)."
  notes:
    - "This spec extends hashlib through hashlib_extra116; it does NOT duplicate invariants present in those files."
    - "Wave 274 theme: shake_128 and shake_256 XOF (extensible output function) attributes not yet covered — HASHXOF class name, shake block_size values (168 and 136 bytes), shake().name equality, shake function __name__ identity ('openssl_shake_128'/'openssl_shake_256'), HASHXOF instance method qualnames."
    - "hashlib.shake_128().name == 'shake_128'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_256().name == 'shake_256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_128().block_size == 168. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_256().block_size == 136. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_128().digest_size == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_256().digest_size == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_128().__class__.__name__ == 'HASHXOF'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_256().__class__.__name__ == 'HASHXOF'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_128.__name__ == 'openssl_shake_128'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_256.__name__ == 'openssl_shake_256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_128.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_128().digest.__qualname__ == 'HASHXOF.digest'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_128().update.__qualname__ == 'HASHXOF.update'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: shake_128 and shake_256 are XOF (eXtensible Output Functions) from the SHAKE family (NIST). Unlike fixed-output hash functions (sha256 returns 32 bytes, etc.), XOFs can produce output of any length via digest(length). Their digest_size == 0 signals this variable-length nature. Instances are HASHXOF objects (not HASH), a distinct C class in _hashlib. hashlib_extra116 anchors HASH instance method qualnames (HASH.update, HASH.digest, etc.); this spec anchors the analogous HASHXOF method qualnames (HASHXOF.digest, HASHXOF.update) for the first time."
    - "Note: shake_128().block_size == 168 bytes corresponds to the SHAKE-128 rate (r = 1344 bits = 168 bytes; the Keccak sponge rate). shake_256().block_size == 136 bytes corresponds to the SHAKE-256 rate (r = 1088 bits = 136 bytes). The capacity is 2 * security_level bits: 256 bits for SHAKE-128, 512 bits for SHAKE-256. shake_128 has a larger block_size (faster) but lower security level than shake_256."
    - "Note: hashlib.shake_128.__name__ == 'openssl_shake_128' (17 chars) reveals that the Python-level 'shake_128' name is a public alias; the underlying OpenSSL-backed C function is named 'openssl_shake_128'. Similarly for shake_256. This parallels how hashlib.sha256.__name__ == 'openssl_sha256'. The shake functions are builtin_function_or_method with __module__ == '_hashlib'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.shake_128().name.__eq__('shake_128')
# hashlib.shake_256().name.__eq__('shake_256')
# hashlib.shake_128().name.__len__() == 9
# hashlib.shake_256().name.__len__() == 9
# hashlib.shake_128().__class__.__name__.__eq__('HASHXOF')
#
# Wave 274 theme: shake XOF instance .name equality and HASHXOF class identity.
#
# shake_128() and shake_256() instances have .name attributes 'shake_128' and
# 'shake_256' (both 9 chars: 'shake_' prefix + 3-digit variant number). The
# instance class is HASHXOF, not HASH — a distinct C type in _hashlib for XOF
# algorithms. hashlib_extra115 anchors .name for md5/sha1/sha256/sha512; this
# spec anchors the XOF variant .name values for the first time.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra117.shake_instance_name_and_class:
  description: "shake_128().name.__eq__('shake_128')==True / shake_256().name.__eq__('shake_256')==True / shake_128().name.__len__()==9 / shake_256().name.__len__()==9 / shake_128().__class__.__name__.__eq__('HASHXOF')==True — both XOF .name attributes are 9 chars ('shake_'=6+'128'=3 or '256'=3); class is HASHXOF (not HASH; a distinct C type for XOF algorithms); extra115 anchors .name for standard hashes; first shakexof117 anchor for XOF .name"
  kind: python_call_eq
  category: type_identity
  id_prefix: shakexof117

  columns: [id, function, args, expected, description]
  rows:
    - [shake128_name_eq,       "shake_128().name.__eq__",              ["shake_128"], true, "hashlib.shake_128().name is 'shake_128' (9 chars; 'shake_'=6 + '128'=3; XOF name matches public hashlib alias)"]
    - [shake256_name_eq,       "shake_256().name.__eq__",              ["shake_256"], true, "hashlib.shake_256().name is 'shake_256' (9 chars; 'shake_'=6 + '256'=3; same length as shake_128)"]
    - [shake128_name_len,      "shake_128().name.__len__",             [],            9,    "hashlib.shake_128().name.__len__() is 9 ('shake_128': 6-char prefix + 3-char variant)"]
    - [shake256_name_len,      "shake_256().name.__len__",             [],            9,    "hashlib.shake_256().name.__len__() is 9 (same length as shake_128; both use 3-char numeric suffix)"]
    - [shake128_class_name_eq, "shake_128().__class__.__name__.__eq__",["HASHXOF"],   true, "hashlib.shake_128().__class__.__name__ is 'HASHXOF' (distinct from HASH; XOF = eXtensible Output Function)"]

# ---------------------------------------------------------------------------
# hashlib.shake_128().block_size == 168
# hashlib.shake_256().block_size == 136
# hashlib.shake_128().digest_size == 0
# hashlib.shake_256().digest_size == 0
# hashlib.shake_256().__class__.__name__.__eq__('HASHXOF')
#
# Wave 274 theme: shake XOF block_size and digest_size distinguishing properties.
#
# shake_128().block_size == 168 bytes (SHAKE-128 Keccak sponge rate: 1344 bits).
# shake_256().block_size == 136 bytes (SHAKE-256 rate: 1088 bits). XOFs have
# digest_size == 0 (variable-length output; not fixed like sha256's 32 bytes).
# hashlib_extra108 anchors block_size for sha224/sha384/sha3_256/blake2b; no prior
# spec anchors shake_128 or shake_256 block_size or digest_size.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra117.shake_block_size_and_digest_size:
  description: "shake_128().block_size==168 / shake_256().block_size==136 / shake_128().digest_size==0 / shake_256().digest_size==0 / shake_256().__class__.__name__.__eq__('HASHXOF')==True — block_size 168=SHAKE-128 rate (1344 bits); block_size 136=SHAKE-256 rate (1088 bits); digest_size==0 indicates XOF variable-length output (no fixed digest); extra108 anchors block_size for other algorithms; first shakexof117 anchor for XOF block_size and digest_size"
  kind: python_call_eq
  category: type_identity
  id_prefix: shakexof117

  columns: [id, function, args, expected, description]
  rows:
    - [shake128_block_size,    "shake_128().block_size.__eq__",         [168],     true, "hashlib.shake_128().block_size is 168 (SHAKE-128 Keccak rate: 1344 bits = 168 bytes; larger rate = faster throughput)"]
    - [shake256_block_size,    "shake_256().block_size.__eq__",         [136],     true, "hashlib.shake_256().block_size is 136 (SHAKE-256 rate: 1088 bits = 136 bytes; smaller rate = higher security)"]
    - [shake128_digest_size,   "shake_128().digest_size.__eq__",        [0],       true, "hashlib.shake_128().digest_size is 0 (XOF: variable-length output; digest(length) returns any number of bytes)"]
    - [shake256_digest_size,   "shake_256().digest_size.__eq__",        [0],       true, "hashlib.shake_256().digest_size is 0 (same as shake_128; XOF with no fixed output length)"]
    - [shake256_class_name_eq, "shake_256().__class__.__name__.__eq__", ["HASHXOF"],true, "hashlib.shake_256().__class__.__name__ is 'HASHXOF' (same C class as shake_128; shared across both XOFs)"]

# ---------------------------------------------------------------------------
# hashlib.shake_128.__name__.__eq__('openssl_shake_128')
# hashlib.shake_256.__name__.__eq__('openssl_shake_256')
# hashlib.shake_128.__module__.__eq__('_hashlib')
# hashlib.shake_128().digest.__qualname__.__eq__('HASHXOF.digest')
# hashlib.shake_128().update.__qualname__.__eq__('HASHXOF.update')
#
# Wave 274 theme: shake function __name__ identity and HASHXOF method qualnames.
#
# hashlib.shake_128.__name__ is 'openssl_shake_128' (17 chars: 'openssl_shake_'=14 +
# '128'=3). The public 'shake_128' is an alias; the underlying C function is named
# 'openssl_shake_128'. Similarly shake_256.__name__ == 'openssl_shake_256'. Both
# have __module__ == '_hashlib'. HASHXOF instance method qualnames use the 'HASHXOF.'
# prefix: digest -> 'HASHXOF.digest' (14 chars), update -> 'HASHXOF.update' (14 chars).
# hashlib_extra116 anchors HASH method qualnames ('HASH.update', etc.); this spec
# anchors the analogous HASHXOF method qualnames for the first time.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra117.shake_function_name_and_method_qualnames:
  description: "shake_128.__name__.__eq__('openssl_shake_128')==True / shake_256.__name__.__eq__('openssl_shake_256')==True / shake_128.__module__.__eq__('_hashlib')==True / shake_128().digest.__qualname__.__eq__('HASHXOF.digest')==True / shake_128().update.__qualname__.__eq__('HASHXOF.update')==True — shake function __name__ reveals OpenSSL backend ('openssl_shake_*'; 17 chars); __module__=='_hashlib'; HASHXOF method qualnames: digest=14 chars, update=14 chars; extra116 anchors HASH method qualnames; first shakexof117 anchor for shake __name__ and HASHXOF qualnames"
  kind: python_call_eq
  category: function_identity
  id_prefix: shakexof117

  columns: [id, function, args, expected, description]
  rows:
    - [shake128_func_name_eq,       "shake_128.__name__.__eq__",              ["openssl_shake_128"], true, "hashlib.shake_128.__name__ is 'openssl_shake_128' (17 chars; 'openssl_shake_'=14 + '128'=3; reveals OpenSSL backend; 'shake_128' is a public alias)"]
    - [shake256_func_name_eq,       "shake_256.__name__.__eq__",              ["openssl_shake_256"], true, "hashlib.shake_256.__name__ is 'openssl_shake_256' (17 chars; same pattern as shake_128; both are OpenSSL-backed C functions)"]
    - [shake128_func_module_eq,     "shake_128.__module__.__eq__",            ["_hashlib"],          true, "hashlib.shake_128.__module__ is '_hashlib' (C extension module; same module as sha256, md5, and other OpenSSL-backed functions)"]
    - [shake128_digest_qualname_eq, "shake_128().digest.__qualname__.__eq__", ["HASHXOF.digest"],    true, "hashlib.shake_128().digest.__qualname__ is 'HASHXOF.digest' (14 chars; 'HASHXOF.'=8 + 'digest'=6; uses HASHXOF prefix not HASH)"]
    - [shake128_update_qualname_eq, "shake_128().update.__qualname__.__eq__", ["HASHXOF.update"],    true, "hashlib.shake_128().update.__qualname__ is 'HASHXOF.update' (14 chars; same length as HASHXOF.digest; HASHXOF prefix not HASH)"]

# ---------------------------------------------------------------------------
# hashlib.shake_128().name.__eq__('shake_128') — standalone
#
# hashlib.shake_128().name is 'shake_128' (9 chars). The .name attribute on a
# HASHXOF instance reflects the canonical algorithm name used by hashlib and
# OpenSSL. For shake_128, the name is 'shake_128' — matching the public Python
# API name. This parallels how hashlib.sha256().name == 'sha256' (6 chars).
# hashlib_extra115 anchors .name for sha256/md5/sha512/sha1; no prior hashlib spec
# anchors shake_128().name or shake_256().name as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra117.shake128_name_eq:
  description: "hashlib.shake_128().name.__eq__('shake_128') == True — XOF instance .name is 'shake_128' (9 chars; 'shake_'=6 + '128'=3); matches public Python alias; parallels sha256().name=='sha256' from extra115; HASHXOF class not HASH; no prior spec anchors shake .name as standalone; first standalone under shakexof117"
  category: type_identity
  kind: python_call_eq
  function: "shake_128().name.__eq__"
  args: ["shake_128"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.shake_128().block_size == 168 — standalone
#
# hashlib.shake_128().block_size is 168. This is the Keccak sponge rate for
# SHAKE-128: r = 1600 - 2*128 = 1344 bits = 168 bytes. A larger rate means more
# throughput (absorbing more bytes per permutation round) but a smaller capacity
# (lower security). shake_256().block_size == 136 (rate = 1600 - 2*256 = 1088 bits).
# hashlib_extra108 anchors block_size for sha224/sha384/sha3_256/sha3_512/blake2b;
# no prior hashlib spec anchors shake_128 block_size as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra117.shake128_block_size:
  description: "hashlib.shake_128().block_size.__eq__(168) == True — SHAKE-128 Keccak sponge rate is 1344 bits = 168 bytes (rate = 1600 - 2*128 bits; larger rate = more throughput; shake_256 has smaller rate of 136 bytes); extra108 anchors block_size for other algorithms; first standalone for shake block_size under shakexof117"
  category: type_identity
  kind: python_call_eq
  function: "shake_128().block_size.__eq__"
  args: [168]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.shake_128().digest_size == 0 — standalone
#
# hashlib.shake_128().digest_size is 0. For XOF (eXtensible Output Functions),
# digest_size == 0 indicates that the output length is variable — the caller
# specifies the desired number of output bytes via digest(length). This is
# distinct from fixed-output hash functions: sha256().digest_size == 32,
# sha512().digest_size == 64. The digest_size == 0 sentinel is how hashlib
# signals XOF capability. hashlib_extra108 anchors digest_size for fixed-output
# hashes; no prior hashlib spec anchors shake digest_size == 0 as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra117.shake128_digest_size_zero:
  description: "hashlib.shake_128().digest_size.__eq__(0) == True — XOF digest_size==0 is sentinel for variable-length output (caller specifies length via digest(n)); contrasts with sha256().digest_size==32, sha512().digest_size==64; extra108 anchors digest_size for fixed-output hashes; first standalone for XOF digest_size==0 under shakexof117"
  category: type_identity
  kind: python_call_eq
  function: "shake_128().digest_size.__eq__"
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.shake_128.__name__.__eq__('openssl_shake_128') — standalone
#
# hashlib.shake_128.__name__ is 'openssl_shake_128' (17 chars). The callable
# exposed at hashlib.shake_128 is a C-level builtin_function_or_method whose
# internal name is 'openssl_shake_128'. The 'openssl_' prefix signals it is
# implemented via OpenSSL's EVP interface. The public Python name 'shake_128'
# is an alias in the hashlib namespace. This pattern parallels hashlib.sha256
# (whose __name__ == 'openssl_sha256'). No prior hashlib spec anchors
# shake_128.__name__ equality as a standalone under shakexof117.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra117.shake128_func_name_eq:
  description: "hashlib.shake_128.__name__.__eq__('openssl_shake_128') == True — __name__ is 'openssl_shake_128' (17 chars; 'openssl_shake_'=14 + '128'=3); 'openssl_' prefix indicates OpenSSL EVP backend; 'shake_128' public name is a hashlib alias; parallels sha256.__name__=='openssl_sha256'; first standalone under shakexof117"
  category: function_identity
  kind: python_call_eq
  function: "shake_128.__name__.__eq__"
  args: ["openssl_shake_128"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.shake_128().digest.__qualname__.__eq__('HASHXOF.digest') — standalone
#
# hashlib.shake_128().digest.__qualname__ is 'HASHXOF.digest' (14 chars:
# 'HASHXOF.'=8 + 'digest'=6). The 'HASHXOF.' prefix is the C class name for
# XOF hash objects. hashlib_extra116 anchors HASH instance method qualnames
# ('HASH.update'=11 chars, 'HASH.digest'=11 chars); the HASHXOF equivalents
# are 3 chars longer ('HASHXOF.'=8 vs 'HASH.'=5). No prior hashlib spec anchors
# HASHXOF instance method qualnames as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra117.shake128_digest_qualname_eq:
  description: "hashlib.shake_128().digest.__qualname__.__eq__('HASHXOF.digest') == True — qualname is 'HASHXOF.digest' (14 chars; 'HASHXOF.'=8 + 'digest'=6); 3 chars longer than 'HASH.digest' (11 chars) because 'HASHXOF'=7 vs 'HASH'=4; extra116 anchors HASH method qualnames; first standalone for HASHXOF method qualname under shakexof117"
  category: method_identity
  kind: python_call_eq
  function: "shake_128().digest.__qualname__.__eq__"
  args: ["HASHXOF.digest"]
  expected: true
