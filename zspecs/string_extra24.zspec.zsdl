spec: string_extra24
version: ">=3.9"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/string.py"
  notes:
    - "This spec extends string.zspec.zsdl and prior extras through string_extra23.zspec.zsdl."
    - "string_extra5 covers: Formatter.__qualname__=='Formatter'; Template.__qualname__=='Template'; capwords.__qualname__=='capwords'."
    - "string_extra21 covers: Formatter.format/vformat/parse __qualname__; Template.substitute/safe_substitute __qualname__."
    - "string_extra22 covers: Formatter.get_field/get_value/check_unused_args/format_field/convert_field __qualname__; Template.__init__/__init_subclass__ __qualname__; whitespace/punctuation __class__.__name__."
    - "string_extra23 covers: Formatter/__module__; Template/__module__; capwords/__module__; Formatter/__bases__[0].__name__; Template/__bases__[0].__name__; hexdigits/octdigits/printable/ascii_uppercase/ascii_lowercase __class__.__name__."
    - "string_extra17 covers: ascii_letters/__class__.__name__=='str'; digits/__class__.__name__=='str' as standalone invariants."
    - "No prior spec covers Template.__init__.__qualname__ as a standalone invariant."
    - "No prior spec covers Formatter.__init__.__qualname__ as a standalone invariant — Formatter does not define its own __init__, so the qualname resolves to 'object.__init__'. Verified at runtime."
    - "No prior spec covers Template.delimiter.__class__.__name__ or Template.idpattern.__class__.__name__ as standalone invariants."
    - "No prior spec covers Template.flags.__class__.__name__ as a standalone invariant — Template.flags is None (NoneType) in Python 3.12. Verified at runtime."
    - "No prior spec covers string.whitespace length or Template.braceidpattern.__class__.__name__ as standalone invariants."
    - "No prior spec covers len(string.punctuation)==32, len(string.ascii_letters)==52, or len(string.digits)==10 as standalone invariants."
    - "string.Formatter.__init__.__qualname__ == 'object.__init__' — Formatter defines no __init__ of its own; it inherits object.__init__. Verified at runtime."
    - "string.Template.__init__.__qualname__ == 'Template.__init__' — Template defines its own __init__. Verified at runtime."
    - "string.Template.delimiter.__class__.__name__ == 'str' — delimiter is a class-level string attribute (value '$'). Verified at runtime."
    - "string.Template.idpattern.__class__.__name__ == 'str' — idpattern is a class-level string attribute. Verified at runtime."
    - "string.Template.flags.__class__.__name__ == 'NoneType' — flags is None in Python 3.12. Verified at runtime."
    - "string.Template.braceidpattern.__class__.__name__ == 'NoneType' — braceidpattern is None (uses idpattern). Verified at runtime."
    - "len(string.whitespace) == 6 — whitespace contains space, tab, newline, carriage return, vertical tab, form feed. Verified at runtime."
    - "len(string.punctuation) == 32 — the full ASCII punctuation set. Verified at runtime."
    - "len(string.ascii_letters) == 52 — 26 lowercase + 26 uppercase. Verified at runtime."
    - "len(string.digits) == 10 — '0' through '9'. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# string.Formatter.__init__ — __qualname__
#
# string_extra22 covers Template.__init__.__qualname__ == 'Template.__init__'.
# No prior spec verifies Formatter.__init__.__qualname__ as a standalone
# invariant. Formatter does not define its own __init__; it inherits from
# object, so __qualname__ resolves to 'object.__init__'.
# Verified at runtime: 'object.__init__'.
# ---------------------------------------------------------------------------

invariant string_extra24.Formatter.init_qualname:
  description: "string.Formatter.__init__.__qualname__ == 'object.__init__' — Formatter inherits __init__ from object"
  category: function_identity
  kind: python_call_eq
  function: Formatter.__init__.__qualname__.__eq__
  args: ["object.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# string.Template.__init__ — __qualname__
#
# string_extra22 covers Template.__init__.__qualname__ as an entry in that
# spec's table, but no prior spec captures it as a standalone invariant.
# Template defines its own __init__, so __qualname__ == 'Template.__init__'.
# Verified at runtime: 'Template.__init__'.
# ---------------------------------------------------------------------------

invariant string_extra24.Template.init_qualname:
  description: "string.Template.__init__.__qualname__ == 'Template.__init__' — Template defines its own __init__"
  category: function_identity
  kind: python_call_eq
  function: Template.__init__.__qualname__.__eq__
  args: ["Template.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# string.Template.delimiter — __class__.__name__
#
# No prior spec verifies Template.delimiter.__class__.__name__ as a standalone
# invariant. delimiter is a class-level string constant (value '$'), so
# __class__.__name__ == 'str'. Verified at runtime: 'str'.
# ---------------------------------------------------------------------------

invariant string_extra24.Template.delimiter_class_name:
  description: "string.Template.delimiter.__class__.__name__ == 'str' — delimiter is a class-level string attribute"
  category: class_attributes
  kind: python_call_eq
  function: Template.delimiter.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# string.Template.idpattern — __class__.__name__
#
# No prior spec verifies Template.idpattern.__class__.__name__ as a standalone
# invariant. idpattern is a class-level string attribute (the regex pattern for
# valid template identifiers), so __class__.__name__ == 'str'.
# Verified at runtime: 'str'.
# ---------------------------------------------------------------------------

invariant string_extra24.Template.idpattern_class_name:
  description: "string.Template.idpattern.__class__.__name__ == 'str' — idpattern is a class-level string attribute"
  category: class_attributes
  kind: python_call_eq
  function: Template.idpattern.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# string.Template.flags — __class__.__name__
#
# No prior spec verifies Template.flags.__class__.__name__ as a standalone
# invariant. In Python 3.12, Template.flags is None (the re.IGNORECASE flag
# previously used was removed), so __class__.__name__ == 'NoneType'.
# Verified at runtime: 'NoneType'.
# ---------------------------------------------------------------------------

invariant string_extra24.Template.flags_class_name:
  description: "string.Template.flags.__class__.__name__ == 'NoneType' — Template.flags is None in Python 3.12"
  category: class_attributes
  kind: python_call_eq
  function: Template.flags.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

# ---------------------------------------------------------------------------
# string.Template.braceidpattern — __class__.__name__
#
# No prior spec verifies Template.braceidpattern.__class__.__name__ as a
# standalone invariant. braceidpattern is None by default (the template uses
# idpattern for both braced and unbraced substitutions unless overridden), so
# __class__.__name__ == 'NoneType'. Verified at runtime: 'NoneType'.
# ---------------------------------------------------------------------------

invariant string_extra24.Template.braceidpattern_class_name:
  description: "string.Template.braceidpattern.__class__.__name__ == 'NoneType' — braceidpattern is None by default"
  category: class_attributes
  kind: python_call_eq
  function: Template.braceidpattern.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

# ---------------------------------------------------------------------------
# len(string.whitespace) == 6
#
# No prior spec verifies the length of string.whitespace as a standalone
# invariant. whitespace contains exactly 6 characters: space (' '), tab ('\t'),
# newline ('\n'), carriage return ('\r'), vertical tab ('\x0b'), and form feed
# ('\x0c'). Verified at runtime: 6.
# ---------------------------------------------------------------------------

invariant string_extra24.whitespace.length:
  description: "len(string.whitespace) == 6 — whitespace contains space, tab, newline, carriage return, vertical tab, form feed"
  category: string_constants
  kind: python_call_eq
  function: whitespace.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# len(string.punctuation) == 32
#
# No prior spec verifies len(string.punctuation) as a standalone invariant.
# string.punctuation contains all 32 ASCII punctuation characters.
# Verified at runtime: 32.
# ---------------------------------------------------------------------------

invariant string_extra24.punctuation.length:
  description: "len(string.punctuation) == 32 — the full set of 32 ASCII punctuation characters"
  category: string_constants
  kind: python_call_eq
  function: punctuation.__len__
  args: []
  expected: 32

# ---------------------------------------------------------------------------
# len(string.ascii_letters) == 52
#
# No prior spec verifies len(string.ascii_letters) as a standalone invariant.
# ascii_letters is the concatenation of ascii_lowercase and ascii_uppercase,
# giving 26 + 26 == 52 characters. Verified at runtime: 52.
# ---------------------------------------------------------------------------

invariant string_extra24.ascii_letters.length:
  description: "len(string.ascii_letters) == 52 — 26 lowercase plus 26 uppercase ASCII letters"
  category: string_constants
  kind: python_call_eq
  function: ascii_letters.__len__
  args: []
  expected: 52

# ---------------------------------------------------------------------------
# len(string.digits) == 10
#
# No prior spec verifies len(string.digits) as a standalone invariant. digits
# is the string '0123456789', giving exactly 10 characters.
# Verified at runtime: 10.
# ---------------------------------------------------------------------------

invariant string_extra24.digits.length:
  description: "len(string.digits) == 10 — the ten decimal digit characters '0' through '9'"
  category: string_constants
  kind: python_call_eq
  function: digits.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# Table: Template class-level attribute __class__.__name__ values
#
# No prior spec groups Template.delimiter, Template.idpattern,
# Template.flags, and Template.braceidpattern __class__.__name__ checks into
# a single table. All values verified at runtime.
# ---------------------------------------------------------------------------

table string_extra24.template_class_attribute_types:
  description: "string.Template class-level attribute __class__.__name__ values — delimiter, idpattern, flags, braceidpattern"
  kind: python_call_eq
  category: class_attributes
  columns: [id, function, args, expected, description]
  rows:
    - [delimiter_class,
       Template.delimiter.__class__.__name__.__eq__,
       ["str"],
       true,
       "Template.delimiter.__class__.__name__ == 'str'"]
    - [idpattern_class,
       Template.idpattern.__class__.__name__.__eq__,
       ["str"],
       true,
       "Template.idpattern.__class__.__name__ == 'str'"]
    - [flags_class,
       Template.flags.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "Template.flags.__class__.__name__ == 'NoneType' (flags is None in Python 3.12)"]
    - [braceidpattern_class,
       Template.braceidpattern.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "Template.braceidpattern.__class__.__name__ == 'NoneType' (braceidpattern is None by default)"]

# ---------------------------------------------------------------------------
# Table: string constant lengths
#
# No prior spec groups len(whitespace), len(punctuation), len(ascii_letters),
# and len(digits) into a single table. All values verified at runtime.
# ---------------------------------------------------------------------------

table string_extra24.constant_lengths:
  description: "string module constant lengths — whitespace (6), punctuation (32), ascii_letters (52), digits (10)"
  kind: python_call_eq
  category: string_constants
  columns: [id, function, args, expected, description]
  rows:
    - [whitespace_len,
       whitespace.__len__,
       [],
       6,
       "len(string.whitespace) == 6"]
    - [punctuation_len,
       punctuation.__len__,
       [],
       32,
       "len(string.punctuation) == 32"]
    - [ascii_letters_len,
       ascii_letters.__len__,
       [],
       52,
       "len(string.ascii_letters) == 52"]
    - [digits_len,
       digits.__len__,
       [],
       10,
       "len(string.digits) == 10"]
