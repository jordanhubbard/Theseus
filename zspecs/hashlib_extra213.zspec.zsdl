spec: hashlib_extra213
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "RFC 1321 — The MD5 Message-Digest Algorithm"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "FIPS 180-4 — Secure Hash Standard (SHS), NIST, August 2015"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Lib/hashlib.py"
  notes:
    - "This spec extends hashlib_extra2.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "hashlib.new is exposed as a module-level attribute; its __code__.co_name is '__hash_new' (internal name)."
    - "hashlib.new.__code__.co_varnames == ('name', 'args', 'kwargs') — 3 local variable names."
    - "hashlib.new.__code__.co_argcount == 1 (only 'name' is a positional parameter; args and kwargs are *args/**kwargs)."
    - "hashlib.file_digest.__code__.co_varnames == ('fileobj', 'digest', '_bufsize', 'digestobj', 'buf', 'view', 'size') — 7 local variable names."
    - "hashlib.file_digest.__code__.co_argcount == 2 ('fileobj' and 'digest' are the two positional parameters)."
    - "hashlib.file_digest.__qualname__ == 'file_digest'; hashlib.new.__qualname__ == '__hash_new' (internal alias)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model:
  semantics: "hashlib raises ValueError for unknown algorithm names passed to hashlib.new(). Code attribute accesses do not raise."
  stderr: "null"
  stickiness: "N/A — code object attributes are read-only and immutable."
  codes: {}

# ---------------------------------------------------------------------------
# hashlib.new.__code__.co_varnames — local variable name membership
#
# hashlib.new.__code__.co_varnames == ('name', 'args', 'kwargs')
# co_argcount == 1 (only 'name' is positional; *args/**kwargs are not counted)
# ---------------------------------------------------------------------------

table hashlib_extra213.new_co_varnames_contains:
  description: "hashlib.new.__code__.co_varnames membership checks in hashlibnew213 namespace — wave 257 theme: hashlib.new.__code__.co_varnames is ('name', 'args', 'kwargs') — three local variable slots; co_argcount==1 (only 'name' is positional); 'args' and 'kwargs' appear as *args/**kwargs in the signature; __contains__('name')==True; __contains__('args')==True; __contains__('kwargs')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: hashlibnew213

  columns: [id, function, args, expected, description]
  rows:
    - [new_has_name,   hashlib.new.__code__.co_varnames.__contains__,   ["name"],   true, "hashlib.new.__code__.co_varnames.__contains__('name') == True; 'name' is the first positional parameter; verified with Python 3.14.3"]
    - [new_has_args,   hashlib.new.__code__.co_varnames.__contains__,   ["args"],   true, "hashlib.new.__code__.co_varnames.__contains__('args') == True; *args captured as 'args' local; verified with Python 3.14.3"]
    - [new_has_kwargs, hashlib.new.__code__.co_varnames.__contains__,   ["kwargs"], true, "hashlib.new.__code__.co_varnames.__contains__('kwargs') == True; **kwargs captured as 'kwargs' local; verified with Python 3.14.3"]
    - [new_varnames_len, hashlib.new.__code__.co_varnames.__len__,      [],         3,    "hashlib.new.__code__.co_varnames.__len__() == 3 — exactly three local variable names: name, args, kwargs; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# hashlib.new.__code__ — argcount and qualname
# ---------------------------------------------------------------------------

table hashlib_extra213.new_code_attrs:
  description: "hashlib.new.__code__ argcount and qualname checks in hashlibnew213 namespace — wave 257 theme: hashlib.new.__code__.co_argcount==1 (only 'name' is positional; *args and **kwargs are not counted in co_argcount); hashlib.new.__qualname__=='__hash_new' (internal CPython name); hashlib.new.__module__=='hashlib'; hashlib.new.__code__.co_name=='__hash_new' (matches qualname); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: hashlibnew213a

  columns: [id, function, args, expected, description]
  rows:
    - [new_co_argc,    hashlib.new.__code__.co_argcount.__eq__,       [1],           true, "hashlib.new.__code__.co_argcount == 1; only 'name' counts as positional; verified with Python 3.14.3"]
    - [new_co_name,    hashlib.new.__code__.co_name.__eq__,           ["__hash_new"], true, "hashlib.new.__code__.co_name == '__hash_new' (internal CPython alias name); verified with Python 3.14.3"]
    - [new_qualname,   hashlib.new.__qualname__.__eq__,               ["__hash_new"], true, "hashlib.new.__qualname__ == '__hash_new'; the function is internally named __hash_new; verified with Python 3.14.3"]
    - [new_module,     hashlib.new.__module__.__eq__,                 ["hashlib"],   true, "hashlib.new.__module__ == 'hashlib'; defined in Lib/hashlib.py; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# hashlib.file_digest.__code__.co_varnames — local variable name membership
#
# hashlib.file_digest.__code__.co_varnames ==
#   ('fileobj', 'digest', '_bufsize', 'digestobj', 'buf', 'view', 'size')
# co_argcount == 2 ('fileobj' and 'digest')
# ---------------------------------------------------------------------------

table hashlib_extra213.file_digest_co_varnames_contains:
  description: "hashlib.file_digest.__code__.co_varnames membership checks in hashlibnew213 namespace — wave 257 theme: file_digest co_varnames is ('fileobj', 'digest', '_bufsize', 'digestobj', 'buf', 'view', 'size') — 7 local variable names; co_argcount==2 ('fileobj' and 'digest' are positional); internal locals include '_bufsize' (read buffer size), 'digestobj' (the constructed digest object), 'buf' (read buffer bytes), 'view' (memoryview of buf), 'size' (bytes read count); __contains__('digest')==True; __contains__('buf')==True; __contains__('fileobj')==True; __len__()==7; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: hashlibnew213b

  columns: [id, function, args, expected, description]
  rows:
    - [fd_has_fileobj,  hashlib.file_digest.__code__.co_varnames.__contains__, ["fileobj"],  true, "hashlib.file_digest.__code__.co_varnames.__contains__('fileobj') == True; first positional param; verified with Python 3.14.3"]
    - [fd_has_digest,   hashlib.file_digest.__code__.co_varnames.__contains__, ["digest"],   true, "hashlib.file_digest.__code__.co_varnames.__contains__('digest') == True; second positional param; verified with Python 3.14.3"]
    - [fd_has_buf,      hashlib.file_digest.__code__.co_varnames.__contains__, ["buf"],      true, "hashlib.file_digest.__code__.co_varnames.__contains__('buf') == True; internal read buffer local; verified with Python 3.14.3"]
    - [fd_varnames_len, hashlib.file_digest.__code__.co_varnames.__len__,      [],           7,    "hashlib.file_digest.__code__.co_varnames.__len__() == 7 — fileobj, digest, _bufsize, digestobj, buf, view, size; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — hashlib_extra213
# ---------------------------------------------------------------------------

invariant hashlib_extra213.new_co_argcount_eq_1:
  description: "hashlib.new.__code__.co_argcount.__eq__(1) returns True — hashlib.new is defined as 'def __hash_new(name, *args, **kwargs)'; co_argcount counts only explicit positional parameters (not *args or **kwargs), so co_argcount==1 (just 'name'); the function is exposed as hashlib.new but internally named __hash_new; co_varnames is ('name', 'args', 'kwargs') with len==3; *args and **kwargs each occupy a co_varnames slot but do not increment co_argcount; compare: hashlib.file_digest co_argcount==2 (fileobj and digest both positional); NEW in hashlib_extra213: first standalone new co_argcount invariant in hashlibnew213 namespace; wave 257; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: hashlib.new.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant hashlib_extra213.new_co_varnames_len_3:
  description: "hashlib.new.__code__.co_varnames.__len__() == 3 — co_varnames stores all local variable names in function scope; for hashlib.new the locals are exactly ('name', 'args', 'kwargs'); name is the positional parameter, args is *args, kwargs is **kwargs; no additional local variables are defined within the function body (it is a thin dispatcher); compare: hashlib.file_digest has 7 co_varnames (more complex implementation reading from a file); NEW in hashlib_extra213: first standalone new co_varnames length invariant; wave 257; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: hashlib.new.__code__.co_varnames.__len__
  args: []
  expected: 3

invariant hashlib_extra213.file_digest_co_argcount_eq_2:
  description: "hashlib.file_digest.__code__.co_argcount.__eq__(2) returns True — file_digest is defined as 'def file_digest(fileobj, digest, /, *, usedforsecurity=True)'; co_argcount==2 counts 'fileobj' and 'digest' as positional-only parameters (PEP 570); the function reads from a file object in chunks using a buffer and feeds each chunk to the digest; co_varnames len==7 showing the 5 additional internal locals; compare: hashlib.new co_argcount==1 (single 'name' positional param); NEW in hashlib_extra213: first standalone file_digest co_argcount invariant; wave 257; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: hashlib.file_digest.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant hashlib_extra213.file_digest_co_varnames_len_7:
  description: "hashlib.file_digest.__code__.co_varnames.__len__() == 7 — the 7 locals are: 'fileobj' (file object param), 'digest' (hash constructor or name param), '_bufsize' (internal buffer size constant, typically 2**18=262144), 'digestobj' (the constructed hash object), 'buf' (bytes read from file each iteration), 'view' (memoryview wrapping buf for efficient passing), 'size' (number of bytes actually read); this is a complete accounting of all local variable slots in file_digest; compare: hashlib.new has only 3 co_varnames; NEW in hashlib_extra213: first standalone file_digest co_varnames length invariant; wave 257; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: hashlib.file_digest.__code__.co_varnames.__len__
  args: []
  expected: 7

invariant hashlib_extra213.file_digest_has_view_local:
  description: "hashlib.file_digest.__code__.co_varnames.__contains__('view') returns True — 'view' is a memoryview local variable in file_digest that wraps the read buffer for zero-copy passing to the digest update method; using a memoryview avoids creating a slice copy on each chunk read; this is an internal CPython optimization detail captured in co_varnames; the full co_varnames tuple is ('fileobj', 'digest', '_bufsize', 'digestobj', 'buf', 'view', 'size'); NEW in hashlib_extra213: first standalone file_digest 'view' local invariant; wave 257; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: hashlib.file_digest.__code__.co_varnames.__contains__
  args: ["view"]
  expected: true

invariant hashlib_extra213.file_digest_has_size_local:
  description: "hashlib.file_digest.__code__.co_varnames.__contains__('size') returns True — 'size' is a local variable in file_digest that tracks how many bytes were read by each call to fileobj.readinto(buf); after readinto, size==0 signals end-of-file; the loop continues while size>0, feeding buf[:size] (via memoryview 'view') to digestobj.update(); the full co_varnames includes all 7 locals: fileobj, digest, _bufsize, digestobj, buf, view, size; NEW in hashlib_extra213: first standalone file_digest 'size' local invariant; wave 257; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: hashlib.file_digest.__code__.co_varnames.__contains__
  args: ["size"]
  expected: true

invariant hashlib_extra213.file_digest_qualname_eq:
  description: "hashlib.file_digest.__qualname__.__eq__('file_digest') returns True — file_digest is a module-level function in Lib/hashlib.py; its qualname equals its simple name 'file_digest' (not nested in any class); compare: hashlib.new.__qualname__=='__hash_new' (the internal alias name differs from the public attribute name); hashlib.file_digest was added in Python 3.11 to provide a standardized way to compute a hash of a file object; __module__ is 'hashlib'; NEW in hashlib_extra213: first standalone file_digest qualname invariant; wave 257; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: hashlib.file_digest.__qualname__.__eq__
  args: ["file_digest"]
  expected: true

invariant hashlib_extra213.new_qualname_is_hash_new:
  description: "hashlib.new.__qualname__.__eq__('__hash_new') returns True — hashlib.new is a module-level attribute bound to the internal function __hash_new defined in Lib/hashlib.py; the public API name is 'new' (accessed as hashlib.new) but the function's internal qualname is '__hash_new'; this means new.__code__.co_name=='__hash_new' and new.__qualname__=='__hash_new'; the dunder prefix suggests it is an implementation detail not intended for subclassing; compare: hashlib.file_digest.__qualname__=='file_digest' (public name matches qualname); NEW in hashlib_extra213: first standalone new.__qualname__ invariant in hashlibnew213 namespace; wave 257; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: hashlib.new.__qualname__.__eq__
  args: ["__hash_new"]
  expected: true
