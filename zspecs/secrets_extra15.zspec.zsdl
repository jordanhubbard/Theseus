spec: secrets_extra15
version: ">=3.9"
backend: python_module(secrets)

docs: https://docs.python.org/3/library/secrets.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/secrets.html — Python secrets module documentation"
    - "PEP 506 — Adding A Secrets Module To The Standard Library"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/secrets.py"
    - "secrets_extra14.zspec.zsdl — covers SystemRandom.random.__qualname__; SystemRandom.getrandbits.__qualname__; SystemRandom.__qualname__; token_bytes/hex/urlsafe __module__; DEFAULT_ENTROPY == 32."
    - "secrets_extra13.zspec.zsdl — covers callable __class__.__name__.__eq__ table; DEFAULT_ENTROPY.__class__.__qualname__.__eq__."
    - "secrets_extra12.zspec.zsdl — covers __qualname__.__len__() for token_bytes/hex/urlsafe/choice/randbelow/randbits/SystemRandom."
    - "secrets_extra4.zspec.zsdl — covers __qualname__.__eq__ for all callables including SystemRandom; DEFAULT_ENTROPY == 32; randbits.__qualname__ == 'SystemRandom.getrandbits'."
    - "secrets_extra3.zspec.zsdl — covers token_hex/__module__, token_urlsafe/__module__, choice/__module__, randbelow/__module__, randbits/__module__."
    - "secrets_extra2.zspec.zsdl — covers token_bytes/__module__, token_hex/__module__, token_urlsafe/__module__."
    - "secrets_extra.zspec.zsdl — covers token_bytes/__module__."
  notes:
    - "This spec extends secrets through secrets_extra14; it does NOT duplicate invariants present in those files."
    - "Focus: token_bytes/token_hex/token_urlsafe __name__; choice/__name__ and randbelow/__name__; SystemRandom.seed/__qualname__; SystemRandom.uniform/__qualname__; SystemRandom.randint/__qualname__; SystemRandom.__module__ and __bases__[0].__name__."
    - "secrets.token_bytes.__name__ == 'token_bytes': No prior spec checks __name__ (as opposed to __qualname__ or __module__) for token_bytes. secrets_extra4 covers __qualname__; secrets_extra2 covers __module__. __name__ is new coverage. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.token_hex.__name__ == 'token_hex': Same reasoning. secrets_extra4 covers __qualname__; extras 2/3 cover __module__. __name__ is new coverage. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.token_urlsafe.__name__ == 'token_urlsafe': Same reasoning. New coverage. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.choice.__name__ == 'choice' and secrets.randbelow.__name__ == 'randbelow': secrets_extra3 covers their __module__; secrets_extra4 covers __qualname__. __name__ is new coverage. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.SystemRandom.seed.__qualname__ == 'SystemRandom.seed': secrets_extra14 covers SystemRandom.random.__qualname__ and SystemRandom.getrandbits.__qualname__ via class attribute path. seed.__qualname__ is not covered by any prior spec. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.SystemRandom.uniform.__qualname__ == 'Random.uniform': Inherited from Random; qualname reflects defining class. Not covered in any prior spec. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.SystemRandom.randint.__qualname__ == 'Random.randint': Inherited from Random. Not covered in any prior spec. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.SystemRandom.__module__ == 'random': SystemRandom is defined in the random module and re-exported by secrets. No prior spec covers SystemRandom.__module__.__eq__('random') — extra14 notes cover this but do not write an invariant for it. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "secrets.SystemRandom.__bases__[0].__name__ == 'Random': SystemRandom inherits from Random. No prior spec checks __bases__[0].__name__ for SystemRandom. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# token_bytes, token_hex, token_urlsafe __name__
#
# secrets_extra4 covers __qualname__.__eq__; secrets_extra2/3 cover __module__.
# No prior spec covers __name__ for any of the three token functions.
# On CPython, these are plain Python functions so __name__ == __qualname__.
# ---------------------------------------------------------------------------

table secrets_extra15.token_function_names:
  description: "secrets token function __name__ values"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: sectfn15

  columns: [id, function, args, expected]
  rows:
    - [token_bytes,   token_bytes.__name__.__eq__,   ["token_bytes"],   true]
    - [token_hex,     token_hex.__name__.__eq__,     ["token_hex"],     true]
    - [token_urlsafe, token_urlsafe.__name__.__eq__, ["token_urlsafe"], true]

# ---------------------------------------------------------------------------
# choice and randbelow __name__
#
# secrets_extra3 covers choice/__module__ and randbelow/__module__.
# secrets_extra4 covers choice/__qualname__ and randbelow/__qualname__.
# No prior spec covers __name__ for choice or randbelow.
# choice.__name__ == 'choice'; randbelow.__name__ == 'randbelow'.
# ---------------------------------------------------------------------------

invariant secrets_extra15.choice.name:
  description: "secrets.choice.__name__ == 'choice' — bound method name attribute"
  category: function_qualnames
  kind: python_call_eq
  function: choice.__name__.__eq__
  args: ["choice"]
  expected: true

invariant secrets_extra15.randbelow.name:
  description: "secrets.randbelow.__name__ == 'randbelow' — bound method name attribute"
  category: function_qualnames
  kind: python_call_eq
  function: randbelow.__name__.__eq__
  args: ["randbelow"]
  expected: true

# ---------------------------------------------------------------------------
# SystemRandom class method __qualname__ — seed, uniform, randint
#
# secrets_extra14 covers SystemRandom.random.__qualname__ and
# SystemRandom.getrandbits.__qualname__ via the class attribute path.
# No prior spec covers seed, uniform, or randint __qualname__.
# seed is defined on SystemRandom itself; uniform and randint are inherited
# from Random, so their qualnames use the 'Random.' prefix.
# ---------------------------------------------------------------------------

invariant secrets_extra15.SystemRandom.seed.qualname:
  description: "secrets.SystemRandom.seed.__qualname__ == 'SystemRandom.seed' — defined on SystemRandom"
  category: function_qualnames
  kind: python_call_eq
  function: SystemRandom.seed.__qualname__.__eq__
  args: ["SystemRandom.seed"]
  expected: true

invariant secrets_extra15.SystemRandom.uniform.qualname:
  description: "secrets.SystemRandom.uniform.__qualname__ == 'Random.uniform' — inherited from Random"
  category: function_qualnames
  kind: python_call_eq
  function: SystemRandom.uniform.__qualname__.__eq__
  args: ["Random.uniform"]
  expected: true

invariant secrets_extra15.SystemRandom.randint.qualname:
  description: "secrets.SystemRandom.randint.__qualname__ == 'Random.randint' — inherited from Random"
  category: function_qualnames
  kind: python_call_eq
  function: SystemRandom.randint.__qualname__.__eq__
  args: ["Random.randint"]
  expected: true

# ---------------------------------------------------------------------------
# SystemRandom.__module__ and __bases__[0].__name__
#
# secrets.SystemRandom is defined in the random module and re-exported.
# No prior spec covers SystemRandom.__module__.__eq__('random') as a standalone
# invariant (extra14 notes mention it but write no invariant for it).
# SystemRandom.__bases__[0].__name__ == 'Random': inherits from random.Random.
# No prior spec covers this base class name.
# ---------------------------------------------------------------------------

invariant secrets_extra15.SystemRandom.module:
  description: "secrets.SystemRandom.__module__ == 'random' — defined in random module, re-exported by secrets"
  category: module_metadata
  kind: python_call_eq
  function: SystemRandom.__module__.__eq__
  args: ["random"]
  expected: true

invariant secrets_extra15.SystemRandom.base_name:
  description: "secrets.SystemRandom.__bases__[0].__name__ == 'Random' — inherits from random.Random"
  category: type_metadata
  kind: python_call_eq
  function: "SystemRandom.__bases__.__getitem__"
  args: [0]
  method: __name__.__eq__
  method_args: ["Random"]
  expected: true
