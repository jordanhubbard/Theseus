spec: urllib_parse_extra14
version: ">=3.9"
backend: python_module(urllib.parse)

docs: https://docs.python.org/3/library/urllib.parse.html
rfcs:
  - "RFC 3986 — Uniform Resource Identifier (URI): Generic Syntax"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.parse.html — Python urllib.parse module documentation"
    - "RFC 3986 — Uniform Resource Identifier (URI): Generic Syntax"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/parse.py"
    - "urllib_parse_extra4.zspec.zsdl — covers __qualname__.__eq__ for urlparse/urlsplit/urljoin/urlencode/quote/unquote and ParseResult/SplitResult/DefragResult."
    - "urllib_parse_extra5.zspec.zsdl — covers __qualname__.__eq__ for quote_plus/unquote_plus/parse_qs/parse_qsl."
    - "urllib_parse_extra7.zspec.zsdl — covers ParseResult/SplitResult/DefragResult __qualname__.__eq__ and _fields/__len__()."
    - "urllib_parse_extra13.zspec.zsdl — covers ParseResult/SplitResult/DefragResult __module__.__len__()==12; urlparse/__module__.__len__()==12; result class __bases__[0].__name__."
  notes:
    - "This spec extends the urllib_parse chain through extra13; it does NOT duplicate invariants in any prior spec."
    - "Focus: __qualname__.__len__() for key urllib.parse functions and result classes — no prior spec checks __qualname__.__len__() for any urllib.parse symbol."
    - "urllib.parse.urlparse.__qualname__.__len__() == 8 — len('urlparse') == 8. extra4 checks __qualname__.__eq__; extra13 checks __module__.__len__(). No prior spec checks __qualname__.__len__(). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.urlencode.__qualname__.__len__() == 9 — len('urlencode') == 9. No prior spec checks this length. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.quote.__qualname__.__len__() == 5 — len('quote') == 5. No prior spec checks this length. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.unquote.__qualname__.__len__() == 7 — len('unquote') == 7. No prior spec checks this length. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.urljoin.__qualname__.__len__() == 7 — len('urljoin') == 7. No prior spec checks this length. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.urlsplit.__qualname__.__len__() == 8 — len('urlsplit') == 8. No prior spec checks this length. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.ParseResult.__qualname__.__len__() == 11 — len('ParseResult') == 11. No prior spec checks this length. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.SplitResult.__qualname__.__len__() == 11 — len('SplitResult') == 11. No prior spec checks this length. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__.__len__() for key urllib.parse functions
#
# urllib_parse_extra4 covers __qualname__.__eq__ for urlparse/urlsplit/urljoin/
# urlencode/quote/unquote. No prior spec checks __qualname__.__len__() for any
# of these functions.
# len('urlparse') == 8; len('urlencode') == 9; len('quote') == 5;
# len('unquote') == 7; len('urljoin') == 7; len('urlsplit') == 8.
# ---------------------------------------------------------------------------

table urllib_parse_extra14.function_qualname_lengths:
  description: "Length of __qualname__ strings for key urllib.parse functions"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqlen14

  columns: [id, function, args, expected]
  rows:
    - [urlparse,  urlparse.__qualname__.__len__,  [], 8]
    - [urlencode, urlencode.__qualname__.__len__, [], 9]
    - [quote,     quote.__qualname__.__len__,     [], 5]
    - [unquote,   unquote.__qualname__.__len__,   [], 7]
    - [urljoin,   urljoin.__qualname__.__len__,   [], 7]
    - [urlsplit,  urlsplit.__qualname__.__len__,  [], 8]

# ---------------------------------------------------------------------------
# Result class __qualname__.__len__() for ParseResult and SplitResult
#
# urllib_parse_extra4 covers ParseResult/SplitResult/DefragResult __qualname__.__eq__.
# urllib_parse_extra7 covers __qualname__.__eq__ for the same classes (different namespace).
# urllib_parse_extra13 covers __module__.__len__()==12 for the result classes.
# No prior spec checks __qualname__.__len__() for any result class.
# len('ParseResult') == 11; len('SplitResult') == 11.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra14.ParseResult.qualname_len:
  description: "urllib.parse.ParseResult.__qualname__.__len__() == 11 — len('ParseResult') == 11"
  category: class_qualnames
  kind: python_call_eq
  function: ParseResult.__qualname__.__len__
  args: []
  expected: 11

invariant urllib_parse_extra14.SplitResult.qualname_len:
  description: "urllib.parse.SplitResult.__qualname__.__len__() == 11 — len('SplitResult') == 11"
  category: class_qualnames
  kind: python_call_eq
  function: SplitResult.__qualname__.__len__
  args: []
  expected: 11
