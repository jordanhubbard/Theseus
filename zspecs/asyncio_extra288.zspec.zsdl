spec: asyncio_extra288
version: ">=3.9"
backend: python_module(asyncio)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-stream.html — asyncio streams API (StreamReader, StreamWriter, open_connection, start_server)"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/streams.py"
  notes:
    - "asyncio.StreamReader.__module__ is 'asyncio.streams', not 'asyncio'"
    - "asyncio.StreamWriter.__module__ is 'asyncio.streams', not 'asyncio'"
    - "asyncio.open_connection.__module__ is 'asyncio.streams'"
    - "asyncio.start_server.__module__ is 'asyncio.streams'"
    - "StreamReader.__bases__[0].__name__ is 'object' (no intermediate base class)"
    - "StreamWriter.__bases__[0].__name__ is 'object' (no intermediate base class)"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table asyncio_extra288.class_identity:
  description: "StreamReader and StreamWriter class __name__ and __module__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: asy288

  columns: [id, function, args, expected, description]
  rows:
    - [asy288_001, asyncio.StreamReader.__name__.__eq__, ["StreamReader"], true, "StreamReader class name is 'StreamReader'"]
    - [asy288_002, asyncio.StreamReader.__module__.__eq__, ["asyncio.streams"], true, "StreamReader module is 'asyncio.streams'"]
    - [asy288_003, "asyncio.StreamReader.__bases__[0].__name__.__eq__", ["object"], true, "StreamReader bases[0] is object"]
    - [asy288_004, asyncio.StreamWriter.__name__.__eq__, ["StreamWriter"], true, "StreamWriter class name is 'StreamWriter'"]
    - [asy288_005, asyncio.StreamWriter.__module__.__eq__, ["asyncio.streams"], true, "StreamWriter module is 'asyncio.streams'"]
    - [asy288_006, "asyncio.StreamWriter.__bases__[0].__name__.__eq__", ["object"], true, "StreamWriter bases[0] is object"]

table asyncio_extra288.method_qualnames:
  description: "StreamReader and StreamWriter method __qualname__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: asy288m

  columns: [id, function, args, expected, description]
  rows:
    - [asy288m_001, asyncio.StreamReader.read.__qualname__.__eq__, ["StreamReader.read"], true, "StreamReader.read qualname"]
    - [asy288m_002, asyncio.StreamReader.readline.__qualname__.__eq__, ["StreamReader.readline"], true, "StreamReader.readline qualname"]
    - [asy288m_003, asyncio.StreamReader.readexactly.__qualname__.__eq__, ["StreamReader.readexactly"], true, "StreamReader.readexactly qualname"]
    - [asy288m_004, asyncio.StreamReader.readuntil.__qualname__.__eq__, ["StreamReader.readuntil"], true, "StreamReader.readuntil qualname"]
    - [asy288m_005, asyncio.StreamWriter.write.__qualname__.__eq__, ["StreamWriter.write"], true, "StreamWriter.write qualname"]
    - [asy288m_006, asyncio.StreamWriter.drain.__qualname__.__eq__, ["StreamWriter.drain"], true, "StreamWriter.drain qualname"]
    - [asy288m_007, asyncio.StreamWriter.close.__qualname__.__eq__, ["StreamWriter.close"], true, "StreamWriter.close qualname"]

invariant asyncio_extra288.open_connection_name:
  description: "asyncio.open_connection __name__ is 'open_connection'"
  category: identity
  kind: python_call_eq
  function: asyncio.open_connection.__name__.__eq__
  args: ["open_connection"]
  expected: true

invariant asyncio_extra288.open_connection_module:
  description: "asyncio.open_connection __module__ is 'asyncio.streams'"
  category: identity
  kind: python_call_eq
  function: asyncio.open_connection.__module__.__eq__
  args: ["asyncio.streams"]
  expected: true

invariant asyncio_extra288.start_server_name:
  description: "asyncio.start_server __name__ is 'start_server'"
  category: identity
  kind: python_call_eq
  function: asyncio.start_server.__name__.__eq__
  args: ["start_server"]
  expected: true

invariant asyncio_extra288.start_server_module:
  description: "asyncio.start_server __module__ is 'asyncio.streams'"
  category: identity
  kind: python_call_eq
  function: asyncio.start_server.__module__.__eq__
  args: ["asyncio.streams"]
  expected: true

invariant asyncio_extra288.streamreader_base_is_object:
  description: "asyncio.StreamReader first base class __name__ is 'object'"
  category: identity
  kind: python_call_eq
  function: "asyncio.StreamReader.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant asyncio_extra288.streamwriter_base_is_object:
  description: "asyncio.StreamWriter first base class __name__ is 'object'"
  category: identity
  kind: python_call_eq
  function: "asyncio.StreamWriter.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
