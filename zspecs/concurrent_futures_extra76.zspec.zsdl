table concurrent_futures_extra76.Future_init_result_and_cross_check:
  description: "concurrent.futures Future.__init__ and result code attributes plus cross-check in cfmore76 namespace — wave 244 theme: Future.__init__/result code attributes + cross-checks; Future.__init__.__code__.co_argcount==1 (self only); Future.result.__code__.co_name=='result'; Future.result.__code__.co_argcount==2 (self + timeout); Executor.__enter__.__code__.co_name=='__enter__'; ThreadPoolExecutor.__init__.__code__.co_name=='__init__'; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: cfmore76c

  columns: [id, function, args, expected, description]
  rows:
    - [future_init_co_argcount,  Future.__init__.__code__.co_argcount.__eq__,  [1],        true, "Future.__init__.__code__.co_argcount == 1 — only self is a positional parameter; verified with Python 3.14.3"]
    - [future_result_co_name,    Future.result.__code__.co_name.__eq__,        ["result"], true, "Future.result.__code__.co_name == 'result' — code object co_name matches the method name; verified with Python 3.14.3"]
    - [future_result_co_argcount, Future.result.__code__.co_argcount.__eq__,    [2],        true, "Future.result.__code__.co_argcount == 2 — self and timeout are positional parameters; verified with Python 3.14.3"]
    - [executor_enter_cross,     Executor.__enter__.__code__.co_name.__eq__,   ["__enter__"], true, "Executor.__enter__.__code__.co_name == '__enter__' — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra76
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra76.TPE_init_co_name:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_name.__eq__('__init__') returns True — ThreadPoolExecutor is a Python class in concurrent/futures/thread.py; code object co_name matches the method name; NEW in extra76: first standalone co_name invariant for ThreadPoolExecutor.__init__ in cfmore76 namespace; wave 244; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: ThreadPoolExecutor.__init__.__code__.co_name.__eq__
  args: ["__init__"]
  expected: true

invariant concurrent_futures_extra76.TPE_init_co_argcount:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount.__eq__(5) returns True — self, max_workers, thread_name_prefix, initializer, initargs are positional; ctxkwargs uses **kwargs; NEW in extra76: first standalone co_argcount invariant for ThreadPoolExecutor.__init__ in cfmore76 namespace; wave 244; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: ThreadPoolExecutor.__init__.__code__.co_argcount.__eq__
  args: [5]
  expected: true

invariant concurrent_futures_extra76.PPE_init_co_argcount:
  description: "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_argcount.__eq__(5) returns True — self, max_workers, mp_context, initializer, initargs are positional; max_tasks_per_child is keyword-only (co_kwonlyargcount==1); NEW in extra76: first standalone co_argcount invariant for ProcessPoolExecutor.__init__ in cfmore76 namespace; wave 244; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: ProcessPoolExecutor.__init__.__code__.co_argcount.__eq__
  args: [5]
  expected: true

invariant concurrent_futures_extra76.Executor_exit_co_argcount:
  description: "concurrent.futures.Executor.__exit__.__code__.co_argcount.__eq__(4) returns True — self, exc_type, exc_val, exc_tb are all positional parameters; NEW in extra76: first standalone co_argcount invariant for Executor.__exit__ in cfmore76 namespace; wave 244; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Executor.__exit__.__code__.co_argcount.__eq__
  args: [4]
  expected: true

invariant concurrent_futures_extra76.Future_result_co_argcount:
  description: "concurrent.futures.Future.result.__code__.co_argcount.__eq__(2) returns True — self and timeout are positional parameters; NEW in extra76: first standalone co_argcount invariant for Future.result in cfmore76 namespace; wave 244; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Future.result.__code__.co_argcount.__eq__
  args: [2]
  expected: true
