table concurrent_futures_extra76.Executor_enter_and_exit_code_attrs:
  description: "concurrent.futures Executor.__enter__ and __exit__ code attribute checks in cfmore76 namespace — wave 244 theme: Executor context manager code attributes; Executor.__enter__.__code__.co_name=='__enter__'; Executor.__enter__.__code__.co_argcount==1 (self only; returns self); Executor.__exit__.__code__.co_name=='__exit__'; Executor.__exit__.__code__.co_argcount==4 (self + exc_type + exc_val + exc_tb); verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: cfmore76b

  columns: [id, function, args, expected, description]
  rows:
    - [executor_enter_co_name,     Executor.__enter__.__code__.co_name.__eq__,     ["__enter__"], true, "Executor.__enter__.__code__.co_name == '__enter__' — code object co_name matches the method name; verified with Python 3.14.3"]
    - [executor_enter_co_argcount, Executor.__enter__.__code__.co_argcount.__eq__,  [1],           true, "Executor.__enter__.__code__.co_argcount == 1 — only self; __enter__ returns self; verified with Python 3.14.3"]
    - [executor_exit_co_name,      Executor.__exit__.__code__.co_name.__eq__,      ["__exit__"],  true, "Executor.__exit__.__code__.co_name == '__exit__' — code object co_name matches the method name; verified with Python 3.14.3"]
    - [executor_exit_co_argcount,  Executor.__exit__.__code__.co_argcount.__eq__,   [4],           true, "Executor.__exit__.__code__.co_argcount == 4 — self + exc_type + exc_val + exc_tb; verified with Python 3.14.3"]

