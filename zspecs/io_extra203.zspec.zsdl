# ---------------------------------------------------------------------------
# Standalone invariants — ioiobase203
# ---------------------------------------------------------------------------

invariant io_extra203.IOBase.name_eq:
  description: "io.IOBase.__name__.__eq__('IOBase') returns True — IOBase is the public name of the abstract base class for all I/O classes; the C implementation lives in _IOBase but is exposed as io.IOBase in the io module; io.IOBase.__module__ is 'io'; io.IOBase.__class__.__name__ is 'ABCMeta' (IOBase uses ABCMeta as its metaclass); compare: io.RawIOBase.__name__=='RawIOBase', io.BufferedIOBase.__name__=='BufferedIOBase'; NEW in io_extra203: first standalone IOBase.__name__ identity invariant in ioiobase203 namespace; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: IOBase.__name__.__eq__
  args: ["IOBase"]
  expected: true

invariant io_extra203.IOBase.module_eq:
  description: "io.IOBase.__module__.__eq__('io') returns True — IOBase is exposed through the 'io' module (Lib/io.py re-exports from _io); compare: io.TextIOWrapper.__module__=='_io' (C-level class, not re-exported with module fix); io.UnsupportedOperation.__module__=='io' (re-exported); verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: IOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra203.IOBase.bases0_name:
  description: "io.IOBase.__bases__.__getitem__(0).__name__ == '_IOBase' — io.IOBase inherits from the C-level _IOBase class (Modules/_io/_iomodule.c); _IOBase provides the core close/flush/readable/writable/seekable/__iter__/__next__ protocol; io.IOBase adds ABCMeta registration; compare: io.RawIOBase.__bases__[0].__name__=='IOBase'; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: IOBase.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "_IOBase"

invariant io_extra203.IOBase.metaclass_name:
  description: "io.IOBase.__class__.__name__.__eq__('ABCMeta') returns True — IOBase uses ABCMeta as its metaclass, enabling abstract method registration and virtual subclass checking via register(); compare: io.TextIOWrapper.__class__.__name__=='type' (no ABCMeta); ABCMeta is defined in abc module; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: IOBase.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant io_extra203.IOBase.close_qualname_len:
  description: "io.IOBase.close.__qualname__.__len__() == 13 — '_IOBase.close' has 13 chars ('_IOBase.'=8 + 'close'=5 = 13); close() flushes and closes the stream; calling close() on an already-closed stream has no effect; compare: flush qualname='_IOBase.flush' also len=13; readable='_IOBase.readable' len=16; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: IOBase.close.__qualname__.__len__
  args: []
  expected: 13

invariant io_extra203.IOBase.flush_qualname_len:
  description: "io.IOBase.flush.__qualname__.__len__() == 13 — '_IOBase.flush' has 13 chars ('_IOBase.'=8 + 'flush'=5 = 13); flush() flushes the write buffers of the stream if applicable; for read-only and non-blocking streams it is a no-op; compare: close qualname='_IOBase.close' also len=13; readable='_IOBase.readable' len=16; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: IOBase.flush.__qualname__.__len__
  args: []
  expected: 13

invariant io_extra203.IOBase.readable_qualname_eq:
  description: "io.IOBase.readable.__qualname__.__eq__('_IOBase.readable') returns True — readable() returns False by default; subclasses that support read() should override to return True; qualname has '_IOBase.' prefix because the method is defined on the C-level _IOBase class; compare: writable qualname='_IOBase.writable' (same length=16); verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: IOBase.readable.__qualname__.__eq__
  args: ["_IOBase.readable"]
  expected: true

invariant io_extra203.IOBase.writable_qualname_eq:
  description: "io.IOBase.writable.__qualname__.__eq__('_IOBase.writable') returns True — writable() returns False by default; subclasses that support write() should override to return True; qualname has '_IOBase.' prefix because the method is defined on the C-level _IOBase class; qualname length is 16 ('_IOBase.'=8 + 'writable'=8 = 16); compare: readable qualname='_IOBase.readable' (same length=16); verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: IOBase.writable.__qualname__.__eq__
  args: ["_IOBase.writable"]
  expected: true

