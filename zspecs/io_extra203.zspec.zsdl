spec: io_extra203
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra.zspec.zsdl — covers TextIOWrapper, BufferedRandom, UnsupportedOperation, DEFAULT_BUFFER_SIZE, SEEK_* constants"
  notes:
    - "This spec covers io.IOBase abstract base class identity not already in io_extra.zspec.zsdl."
    - "io.IOBase.__name__ == 'IOBase' — the public class name."
    - "io.IOBase.__module__ == 'io' — defined in the io module (Python-visible name)."
    - "io.IOBase.__bases__[0].__name__ == '_IOBase' — the C-level base class from _io."
    - "io.IOBase.__class__.__name__ == 'ABCMeta' — IOBase uses ABCMeta as its metaclass."
    - "io.IOBase.close.__qualname__ == '_IOBase.close' — method defined on the C-level _IOBase class."
    - "io.IOBase.flush.__qualname__ == '_IOBase.flush' — method defined on the C-level _IOBase class."
    - "io.IOBase.readable.__qualname__ == '_IOBase.readable' — method defined on the C-level _IOBase class."
    - "io.IOBase.writable.__qualname__ == '_IOBase.writable' — method defined on the C-level _IOBase class."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

