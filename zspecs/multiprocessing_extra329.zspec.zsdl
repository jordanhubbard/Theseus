spec: multiprocessing_extra329
version: ">=3.0"
backend: python_module(multiprocessing.queues)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "multiprocessing.queues.Queue and SimpleQueue both inherit directly from object on Python 3.14."
    - "multiprocessing.queues.JoinableQueue inherits from Queue (not object)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.queues module identity
# ---------------------------------------------------------------------------

invariant multiprocessing_extra329.module.name:
  description: "multiprocessing.queues.__name__ == 'multiprocessing.queues'"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["multiprocessing.queues"]
  expected: true

invariant multiprocessing_extra329.module.package:
  description: "multiprocessing.queues.__package__ == 'multiprocessing'"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["multiprocessing"]
  expected: true

# ---------------------------------------------------------------------------
# Queue class introspection
# ---------------------------------------------------------------------------

invariant multiprocessing_extra329.queue.class_name:
  description: "Queue.__name__ == 'Queue'"
  category: queue
  kind: python_call_eq
  function: Queue.__name__.__eq__
  args: ["Queue"]
  expected: true

invariant multiprocessing_extra329.queue.module:
  description: "Queue.__module__ == 'multiprocessing.queues'"
  category: queue
  kind: python_call_eq
  function: Queue.__module__.__eq__
  args: ["multiprocessing.queues"]
  expected: true

invariant multiprocessing_extra329.queue.base_class:
  description: "Queue.__bases__[0].__name__ == 'object'"
  category: queue
  kind: python_call_eq
  function: Queue.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# SimpleQueue class introspection
# ---------------------------------------------------------------------------

invariant multiprocessing_extra329.simple_queue.class_name:
  description: "SimpleQueue.__name__ == 'SimpleQueue'"
  category: simple_queue
  kind: python_call_eq
  function: SimpleQueue.__name__.__eq__
  args: ["SimpleQueue"]
  expected: true

invariant multiprocessing_extra329.simple_queue.module:
  description: "SimpleQueue.__module__ == 'multiprocessing.queues'"
  category: simple_queue
  kind: python_call_eq
  function: SimpleQueue.__module__.__eq__
  args: ["multiprocessing.queues"]
  expected: true

invariant multiprocessing_extra329.simple_queue.base_class:
  description: "SimpleQueue.__bases__[0].__name__ == 'object'"
  category: simple_queue
  kind: python_call_eq
  function: SimpleQueue.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# JoinableQueue class introspection
# ---------------------------------------------------------------------------

invariant multiprocessing_extra329.joinable_queue.class_name:
  description: "JoinableQueue.__name__ == 'JoinableQueue'"
  category: joinable_queue
  kind: python_call_eq
  function: JoinableQueue.__name__.__eq__
  args: ["JoinableQueue"]
  expected: true

invariant multiprocessing_extra329.joinable_queue.module:
  description: "JoinableQueue.__module__ == 'multiprocessing.queues'"
  category: joinable_queue
  kind: python_call_eq
  function: JoinableQueue.__module__.__eq__
  args: ["multiprocessing.queues"]
  expected: true

invariant multiprocessing_extra329.joinable_queue.base_class:
  description: "JoinableQueue.__bases__[0].__name__ == 'Queue'"
  category: joinable_queue
  kind: python_call_eq
  function: JoinableQueue.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Queue"]
  expected: true
