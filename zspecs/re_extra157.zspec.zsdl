spec: re_extra157
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re module __spec__ attributes and re.__all__ contents."
    - "re.__spec__.__class__.__name__ == 'ModuleSpec' — the re module's __spec__ attribute is a ModuleSpec object (from importlib.machinery) describing how the module was loaded."
    - "re.__spec__.name == 're' — the ModuleSpec's name attribute is the fully-qualified module name 're'."
    - "re.__all__ is a list (re.__all__.__class__.__name__ == 'list') with 31 elements (len(re.__all__) == 31)."
    - "re.__all__ contains 'match', 'search', 'compile', 'Pattern', 'Match' among its 31 items. Full list: ['match', 'fullmatch', 'search', 'sub', 'subn', 'split', 'findall', 'finditer', 'compile', 'purge', 'escape', 'error', 'Pattern', 'Match', 'A', 'I', 'L', 'M', 'S', 'X', 'U', 'ASCII', 'IGNORECASE', 'LOCALE', 'MULTILINE', 'DOTALL', 'VERBOSE', 'UNICODE', 'NOFLAG', 'RegexFlag', 'PatternError']."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module __spec__ attributes
# re.__spec__.__class__.__name__ == 'ModuleSpec'
# re.__spec__.name == 're'
# The ModuleSpec object describes the module's import origin and loader.
# ---------------------------------------------------------------------------

table re_extra157.re_spec_attributes:
  description: "re module __spec__ attributes: __spec__.__class__.__name__=='ModuleSpec'; __spec__.name=='re'; re.__all__.__class__.__name__=='list'"
  kind: python_call_eq
  category: identity
  id_prefix: respec157

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_name_eq,  __spec__.__class__.__name__.__eq__,  ["ModuleSpec"], true, "re.__spec__.__class__.__name__ == 'ModuleSpec' (the re module's __spec__ attribute is an instance of importlib.machinery.ModuleSpec; ModuleSpec objects are created by the import system to describe how a module is found and loaded; __spec__ was introduced in Python 3.4 as part of PEP 451 (importlib.machinery); all modules loaded by the standard import system have a __spec__)"]
    - [spec_name_eq,        __spec__.name.__eq__,                ["re"],         true, "re.__spec__.name == 're' (the ModuleSpec's name attribute holds the fully-qualified module name; for the top-level re module, this is just 're' without any package prefix; for a submodule like re._compiler it would be 're._compiler'; the name attribute is used by the import system to identify the module)"]
    - [all_class_name_eq,   __all__.__class__.__name__.__eq__,   ["list"],       true, "re.__all__.__class__.__name__ == 'list' (re.__all__ is a plain Python list — not a tuple or set; __all__ controls what is exported when 'from re import *' is used; it is defined as a list literal in Lib/re/__init__.py; re.__all__ has 31 items including function names, class names, flag abbreviations, and the RegexFlag enum)"]
    - [all_len_eq,          __all__.__len__,                     [],             31,   "re.__all__.__len__() == 31 (re.__all__ has exactly 31 items in Python 3.14; the list includes 8 functions (match, fullmatch, search, sub, subn, split, findall, finditer), compile, purge, escape, error, Pattern, Match, 7 single-letter flag abbreviations (A, I, L, M, S, X, U), 7 full flag names, NOFLAG, RegexFlag, and PatternError)"]

# ---------------------------------------------------------------------------
# re.__all__ contents — which names are in the public API?
# match, search, compile, Pattern, Match, and many others confirmed present.
# re.__all__ has 31 items total.
# ---------------------------------------------------------------------------

table re_extra157.re_all_contents:
  description: "re.__all__ membership checks: match, search, compile, Pattern, Match all present (True); re.__all__.__len__()==31; re.__all__ is the public API export list"
  kind: python_call_eq
  category: identity
  id_prefix: respec157

  columns: [id, function, args, expected, description]
  rows:
    - [all_has_match,    __all__.__contains__,   ["match"],   true, "re.__all__.__contains__('match') == True ('match' is in re.__all__; re.match() is one of the eight primary pattern-application functions in the re module; it anchors the pattern at the start of the string; 'match' is the first item in re.__all__ as defined in Lib/re/__init__.py)"]
    - [all_has_search,   __all__.__contains__,   ["search"],  true, "re.__all__.__contains__('search') == True ('search' is in re.__all__; re.search() scans through the string to find the first match anywhere, unlike match() which anchors to the start; 'search' is the third item in re.__all__ (after 'match' and 'fullmatch'))"]
    - [all_has_compile,  __all__.__contains__,   ["compile"], true, "re.__all__.__contains__('compile') == True ('compile' is in re.__all__; re.compile() compiles a regular expression pattern into a Pattern object for repeated use; it is the ninth item in re.__all__ after the six string-matching functions and purge/escape — though actually in position 9 after match, fullmatch, search, sub, subn, split, findall, finditer)"]
    - [all_has_Pattern,  __all__.__contains__,   ["Pattern"], true, "re.__all__.__contains__('Pattern') == True ('Pattern' is in re.__all__; re.Pattern is the compiled pattern class, made public in Python 3.7 (PEP 3155); Pattern.__name__=='Pattern' and Pattern.__module__=='re' as established in re_extra155; Pattern is listed in __all__ so that 'from re import Pattern' works and type annotations referencing re.Pattern resolve correctly)"]
    - [all_has_Match,    __all__.__contains__,   ["Match"],   true, "re.__all__.__contains__('Match') == True ('Match' is in re.__all__; re.Match is the match result class, made public in Python 3.7; Match.__name__=='Match' (len=5) and Match.__module__=='re' as established in re_extra155; 'Match' appears in __all__ right after 'Pattern' — both are class names added as public API in Python 3.7)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra157.spec_class_name_is_ModuleSpec:
  description: "re.__spec__.__class__.__name__ == 'ModuleSpec' — the re module's __spec__ is an instance of importlib.machinery.ModuleSpec; ModuleSpec was introduced in Python 3.4 (PEP 451) to replace the fragmented module metadata previously scattered across __file__, __loader__, __package__, __name__; a ModuleSpec consolidates all this into one object; re.__spec__.__class__.__name__ == 'ModuleSpec' confirms that re is loaded via the standard import machinery, not some custom loader that bypasses __spec__"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant re_extra157.spec_name_is_re:
  description: "re.__spec__.name == 're' — the name attribute of the re module's ModuleSpec is the fully-qualified module name 're'; for top-level modules this is just the module name without any package qualifier; re.__spec__.name == 're' confirms the re module is a top-level module (not a subpackage like 'xml.etree'); this also equals re.__name__ for top-level modules"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["re"]
  expected: true

invariant re_extra157.all_len_is_31:
  description: "re.__all__.__len__() == 31 — the re module's public API exports exactly 31 names in Python 3.14; this includes: 8 matching functions (match, fullmatch, search, sub, subn, split, findall, finditer), compile, purge, escape, error (4 utility names), Pattern, Match (2 class names), 7 single-letter flag abbreviations (A, I, L, M, S, X, U), 7 full flag names (ASCII, IGNORECASE, LOCALE, MULTILINE, DOTALL, VERBOSE, UNICODE), NOFLAG, RegexFlag, and PatternError — totaling 31 exported names"
  category: identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 31

invariant re_extra157.all_is_list:
  description: "re.__all__.__class__.__name__ == 'list' — re.__all__ is a plain Python list; the choice of list (rather than tuple or frozenset) is conventional for __all__ across the standard library; the import system does not require any specific sequence type for __all__ — it only needs to be iterable; re.__all__ being a list means it could theoretically be modified at runtime (though this is not recommended); len(re.__all__) == 31 confirmed by re_extra157.all_len_is_31"
  category: identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant re_extra157.all_contains_Pattern:
  description: "re.__all__.__contains__('Pattern') == True — 'Pattern' is in re.__all__, making re.Pattern part of the official public API; Pattern was added to __all__ in Python 3.7 when re.Pattern became the public type alias for compiled regular expression objects; prior to 3.7, the only way to reference the Pattern type was type(re.compile('')) or re.Pattern (via a private alias); its inclusion in __all__ enables 'from re import Pattern' and proper type annotation support"
  category: identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Pattern"]
  expected: true
