spec: concurrent_futures_extra21
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures.zspec.zsdl and prior extras through concurrent_futures_extra20.zspec.zsdl."
    - "concurrent_futures_extra20 covers: Future.result/exception/done/cancel/cancelled method qualnames; Executor.submit/map/shutdown."
    - "NOT yet covered in any prior spec: Future.add_done_callback.__qualname__ in extra21 namespace."
    - "NOT yet covered: ThreadPoolExecutor method __qualname__ table (submit/shutdown) in extra21 namespace."
    - "NOT yet covered: ProcessPoolExecutor method __qualname__ table (submit/map/shutdown) in extra21 namespace."
    - "Future.add_done_callback.__qualname__ == 'Future.add_done_callback' — method on Future class."
    - "ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit' — overrides Executor.submit."
    - "ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown' — overrides Executor.shutdown."
    - "ProcessPoolExecutor.submit.__qualname__ == 'ProcessPoolExecutor.submit' — overrides Executor.submit."
    - "ProcessPoolExecutor.map.__qualname__ == 'ProcessPoolExecutor.map' — overrides Executor.map."
    - "ProcessPoolExecutor.shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown' — overrides Executor.shutdown."
    - "ThreadPoolExecutor.map inherits from Executor — its __qualname__ is 'Executor.map', NOT 'ThreadPoolExecutor.map'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ThreadPoolExecutor method __qualname__ table — extra21 namespace
#
# concurrent_futures_extra20 covers Executor.submit/map/shutdown qualnames.
# ThreadPoolExecutor overrides submit and shutdown (so their qualnames use
# 'ThreadPoolExecutor.' prefix), but inherits map (qualname stays 'Executor.map').
# No prior spec covers ThreadPoolExecutor method __qualname__ values.
# Lengths: ThreadPoolExecutor.submit(25), ThreadPoolExecutor.shutdown(27),
#          Executor.map(12).
# ---------------------------------------------------------------------------

table concurrent_futures_extra21.threadpoolexecutor_method_qualnames:
  description: "concurrent.futures.ThreadPoolExecutor method __qualname__ values in extra21 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: tpemqn21

  columns: [id, function, args, expected]
  rows:
    - [submit,   ThreadPoolExecutor.submit.__qualname__.__eq__,   ["ThreadPoolExecutor.submit"],   true]
    - [shutdown, ThreadPoolExecutor.shutdown.__qualname__.__eq__, ["ThreadPoolExecutor.shutdown"], true]
    - [map,      ThreadPoolExecutor.map.__qualname__.__eq__,      ["Executor.map"],                true]

# ---------------------------------------------------------------------------
# ThreadPoolExecutor method __qualname__ length table — extra21 namespace
#
# Lengths: ThreadPoolExecutor.submit(25), ThreadPoolExecutor.shutdown(27),
#          Executor.map(12).
# ---------------------------------------------------------------------------

table concurrent_futures_extra21.threadpoolexecutor_method_qualname_lengths:
  description: "concurrent.futures.ThreadPoolExecutor method __qualname__ lengths in extra21 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: tpemqnlen21

  columns: [id, function, args, expected]
  rows:
    - [submit,   ThreadPoolExecutor.submit.__qualname__.__len__,   [], 25]
    - [shutdown, ThreadPoolExecutor.shutdown.__qualname__.__len__, [], 27]
    - [map,      ThreadPoolExecutor.map.__qualname__.__len__,      [], 12]

# ---------------------------------------------------------------------------
# ProcessPoolExecutor method __qualname__ table — extra21 namespace
#
# ProcessPoolExecutor overrides submit, map, and shutdown. No prior spec
# covers ProcessPoolExecutor method __qualname__ values.
# Lengths: ProcessPoolExecutor.submit(26), ProcessPoolExecutor.map(23),
#          ProcessPoolExecutor.shutdown(28).
# ---------------------------------------------------------------------------

table concurrent_futures_extra21.processpoolexecutor_method_qualnames:
  description: "concurrent.futures.ProcessPoolExecutor method __qualname__ values in extra21 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: ppemqn21

  columns: [id, function, args, expected]
  rows:
    - [submit,   ProcessPoolExecutor.submit.__qualname__.__eq__,   ["ProcessPoolExecutor.submit"],   true]
    - [map,      ProcessPoolExecutor.map.__qualname__.__eq__,      ["ProcessPoolExecutor.map"],      true]
    - [shutdown, ProcessPoolExecutor.shutdown.__qualname__.__eq__, ["ProcessPoolExecutor.shutdown"], true]

# ---------------------------------------------------------------------------
# ProcessPoolExecutor method __qualname__ length table — extra21 namespace
#
# Lengths: ProcessPoolExecutor.submit(26), ProcessPoolExecutor.map(23),
#          ProcessPoolExecutor.shutdown(28).
# ---------------------------------------------------------------------------

table concurrent_futures_extra21.processpoolexecutor_method_qualname_lengths:
  description: "concurrent.futures.ProcessPoolExecutor method __qualname__ lengths in extra21 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: ppemqnlen21

  columns: [id, function, args, expected]
  rows:
    - [submit,   ProcessPoolExecutor.submit.__qualname__.__len__,   [], 26]
    - [map,      ProcessPoolExecutor.map.__qualname__.__len__,      [], 23]
    - [shutdown, ProcessPoolExecutor.shutdown.__qualname__.__len__, [], 28]

# ---------------------------------------------------------------------------
# Future.add_done_callback.__qualname__ — standalone extra21 invariant
#
# concurrent_futures_extra20 covers Future.result/exception/done/cancel/
# cancelled method qualnames. No prior spec covers Future.add_done_callback.
# Its __qualname__ is 'Future.add_done_callback'. Length: 24.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra21.Future.add_done_callback.qualname_eq:
  description: "concurrent.futures.Future.add_done_callback.__qualname__ == 'Future.add_done_callback'"
  category: method_names
  kind: python_call_eq
  function: Future.add_done_callback.__qualname__.__eq__
  args: ["Future.add_done_callback"]
  expected: true
