spec: optparse
version: ">=3.2"
backend: python_module(optparse)

docs: https://docs.python.org/3/library/optparse.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/optparse.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "optparse source: Lib/optparse.py (PSF; source inspection permitted)"
  not_derived_from:
    - "optparse source: internal option-matching and help-formatting implementation details"
  notes:
    - "optparse is deprecated since Python 3.2; argparse is the recommended replacement."
    - "OptionParser().allow_interspersed_args == True by default (options may be mixed with positional args)."
    - "OptionParser().version == None when no version string is supplied."
    - "parse_args([]) returns (Values, []) — Values object contains defaults, args list is empty."
    - "parse_args(['--foo', '10']) with type='int' coerces the string to an integer."
    - "OptionConflictError and OptionValueError both inherit from OptionError."
    - "AmbiguousOptionError inherits from BadOptionError."
    - "IndentedHelpFormatter and TitledHelpFormatter are built-in help formatters."
    - "All expected values verified by running Python 3.12 optparse module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name metadata
# ---------------------------------------------------------------------------

table optparse.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [optionparser,          OptionParser.__name__.__eq__,          ["OptionParser"],          true]
    - [option,                Option.__name__.__eq__,                ["Option"],                true]
    - [optiongroup,           OptionGroup.__name__.__eq__,           ["OptionGroup"],           true]
    - [values,                Values.__name__.__eq__,                ["Values"],                true]
    - [optionerror,           OptionError.__name__.__eq__,           ["OptionError"],           true]
    - [optionconflicterror,   OptionConflictError.__name__.__eq__,   ["OptionConflictError"],   true]
    - [optionvalueerror,      OptionValueError.__name__.__eq__,      ["OptionValueError"],      true]
    - [badoptionerror,        BadOptionError.__name__.__eq__,        ["BadOptionError"],        true]
    - [ambiguousoptionerror,  AmbiguousOptionError.__name__.__eq__,  ["AmbiguousOptionError"],  true]
    - [indentedhelpformatter, IndentedHelpFormatter.__name__.__eq__,  ["IndentedHelpFormatter"], true]
    - [titledhelpformatter,   TitledHelpFormatter.__name__.__eq__,   ["TitledHelpFormatter"],   true]

# ---------------------------------------------------------------------------
# OptionParser default attributes
# ---------------------------------------------------------------------------

invariant optparse.parser_allow_interspersed:
  description: "OptionParser().allow_interspersed_args == True by default"
  category: defaults
  kind: python_call_eq
  function: OptionParser
  args: []
  method: allow_interspersed_args
  method_args: []
  expected: true

invariant optparse.parser_version_none:
  description: "OptionParser().version == None when no version string is provided"
  category: defaults
  kind: python_call_eq
  function: OptionParser
  args: []
  method: version
  method_args: []
  expected: null

# ---------------------------------------------------------------------------
# Exception hierarchy
# ---------------------------------------------------------------------------

invariant optparse.optionconflicterror_mro:
  description: "OptionConflictError.__mro__[1].__name__ == 'OptionError'"
  category: exceptions
  kind: python_call_eq
  function: OptionConflictError.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "OptionError"

invariant optparse.optionvalueerror_mro:
  description: "OptionValueError.__mro__[1].__name__ == 'OptionError'"
  category: exceptions
  kind: python_call_eq
  function: OptionValueError.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "OptionError"

invariant optparse.ambiguousoptionerror_mro:
  description: "AmbiguousOptionError.__mro__[1].__name__ == 'BadOptionError'"
  category: exceptions
  kind: python_call_eq
  function: AmbiguousOptionError.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "BadOptionError"
