spec: uuid_extra274
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "This spec extends uuid.zspec.zsdl through uuid_extra273.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "uuid_extra273.zspec.zsdl covers: UUID boundary values (UUID(int=0) and UUID(int=2**128-1)); __str__, __repr__, .hex, .int, .version, .fields attributes for boundary UUIDs."
    - "This spec focuses on: uuid3 vs uuid5 for different names — both are deterministic/reproducible; uuid3(NAMESPACE_DNS, 'www.example.com').hex; uuid5(NAMESPACE_DNS, 'www.example.com').hex; uuid3/uuid5 version attributes; uuid3/uuid5 for 'python.org'."
    - "uuid.uuid3(NAMESPACE_DNS, 'www.example.com').hex == '5df418813aed351588a72f4a814cf09e'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.uuid5(NAMESPACE_DNS, 'www.example.com').hex == '2ed6657de927568b95e12665a8aea6a2'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.uuid3(NAMESPACE_DNS, 'python.org').hex == '6fa459eaee8a3ca4894edb77e160355e'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.uuid5(NAMESPACE_DNS, 'python.org').hex == '886313e13b8a53729b900c9aee199e5d'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid3 uses MD5; uuid5 uses SHA-1; both are deterministic given the same namespace and name. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.uuid3(NAMESPACE_DNS, 'www.example.com').version == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.uuid5(NAMESPACE_DNS, 'www.example.com').version == 5. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.uuid3 and uuid.uuid5 — deterministic hex vectors for NAMESPACE_DNS
# uuid3 uses MD5; uuid5 uses SHA-1.  Both produce a fixed output for a given
# (namespace, name) pair, making them suitable as stable identifiers.
# NAMESPACE_DNS == UUID('6ba7b810-9dad-11d1-80b4-00c04fd430c8').
# ---------------------------------------------------------------------------

table uuid_extra274.uuid3_uuid5_hex_vectors:
  description: "uuid.uuid3/uuid5 hex vectors for NAMESPACE_DNS with 'www.example.com' and 'python.org'; verified with Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: known_vector
  id_prefix: u3u5274

  columns: [id, function, args, expected, description]
  rows:
    - [uuid3_example_com_hex, "uuid3.__call__.hex.__eq__", [{namespace: NAMESPACE_DNS}, "www.example.com", "5df418813aed351588a72f4a814cf09e"], true, "uuid3(NAMESPACE_DNS, 'www.example.com').hex — MD5-based deterministic UUID hex"]
    - [uuid5_example_com_hex, "uuid5.__call__.hex.__eq__", [{namespace: NAMESPACE_DNS}, "www.example.com", "2ed6657de927568b95e12665a8aea6a2"], true, "uuid5(NAMESPACE_DNS, 'www.example.com').hex — SHA-1-based deterministic UUID hex"]
    - [uuid3_python_org_hex,  "uuid3.__call__.hex.__eq__", [{namespace: NAMESPACE_DNS}, "python.org", "6fa459eaee8a3ca4894edb77e160355e"], true, "uuid3(NAMESPACE_DNS, 'python.org').hex — MD5-based deterministic UUID hex"]
    - [uuid5_python_org_hex,  "uuid5.__call__.hex.__eq__", [{namespace: NAMESPACE_DNS}, "python.org", "886313e13b8a53729b900c9aee199e5d"], true, "uuid5(NAMESPACE_DNS, 'python.org').hex — SHA-1-based deterministic UUID hex"]

# ---------------------------------------------------------------------------
# uuid.uuid3 and uuid.uuid5 — version attribute
# uuid3 always produces a version-3 UUID; uuid5 always produces version-5.
# The version is encoded in bits 12–15 of the time_hi_and_version field.
# ---------------------------------------------------------------------------

table uuid_extra274.uuid3_uuid5_version:
  description: "uuid3().version == 3 and uuid5().version == 5 — RFC 4122 version field; verified with Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: version_attribute
  id_prefix: uv274

  columns: [id, function, args, expected, description]
  rows:
    - [uuid3_version, "uuid3.__call__.version.__eq__", [{namespace: NAMESPACE_DNS}, "www.example.com", 3], true, "uuid3(NAMESPACE_DNS, name).version == 3 — RFC 4122 version 3 (MD5)"]
    - [uuid5_version, "uuid5.__call__.version.__eq__", [{namespace: NAMESPACE_DNS}, "www.example.com", 5], true, "uuid5(NAMESPACE_DNS, name).version == 5 — RFC 4122 version 5 (SHA-1)"]

# ---------------------------------------------------------------------------
# uuid.uuid3 and uuid.uuid5 — determinism: same inputs always same output
# Calling uuid3/uuid5 twice with the same (namespace, name) must return equal
# UUID objects.  This verifies the core contract of name-based UUIDs.
# ---------------------------------------------------------------------------

invariant uuid_extra274.uuid3.deterministic_example_com:
  description: "uuid.uuid3(NAMESPACE_DNS, 'www.example.com') called twice returns equal UUIDs — uuid3 is deterministic; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: determinism
  kind: python_call_eq
  function: "uuid3.__call__.__eq__"
  args: [{namespace: NAMESPACE_DNS}, "www.example.com", {call: uuid3, args: [{namespace: NAMESPACE_DNS}, "www.example.com"]}]
  expected: true

invariant uuid_extra274.uuid5.deterministic_example_com:
  description: "uuid.uuid5(NAMESPACE_DNS, 'www.example.com') called twice returns equal UUIDs — uuid5 is deterministic; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: determinism
  kind: python_call_eq
  function: "uuid5.__call__.__eq__"
  args: [{namespace: NAMESPACE_DNS}, "www.example.com", {call: uuid5, args: [{namespace: NAMESPACE_DNS}, "www.example.com"]}]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid3 vs uuid.uuid5 — same inputs produce DIFFERENT outputs
# uuid3 uses MD5; uuid5 uses SHA-1.  The same (namespace, name) pair
# produces distinct UUIDs depending on the hashing algorithm.
# ---------------------------------------------------------------------------

invariant uuid_extra274.uuid3_vs_uuid5.example_com_differ:
  description: "uuid3(NAMESPACE_DNS, 'www.example.com') != uuid5(NAMESPACE_DNS, 'www.example.com') — different algorithms produce different UUIDs; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: algorithm_contrast
  kind: python_call_eq
  function: "uuid3.__call__.__ne__"
  args: [{namespace: NAMESPACE_DNS}, "www.example.com", {call: uuid5, args: [{namespace: NAMESPACE_DNS}, "www.example.com"]}]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid3 and uuid.uuid5 — str() canonical hyphenated form
# str() returns the standard 8-4-4-4-12 hyphenated form.
# ---------------------------------------------------------------------------

invariant uuid_extra274.uuid3.str_example_com:
  description: "str(uuid.uuid3(NAMESPACE_DNS, 'www.example.com')) == '5df41881-3aed-3515-88a7-2f4a814cf09e' — canonical hyphenated string form; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: known_vector
  kind: python_call_eq
  function: uuid3.__call__.__str__
  args: [{namespace: NAMESPACE_DNS}, "www.example.com"]
  expected: "5df41881-3aed-3515-88a7-2f4a814cf09e"

invariant uuid_extra274.uuid5.str_example_com:
  description: "str(uuid.uuid5(NAMESPACE_DNS, 'www.example.com')) == '2ed6657d-e927-568b-95e1-2665a8aea6a2' — canonical hyphenated string form; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: known_vector
  kind: python_call_eq
  function: uuid5.__call__.__str__
  args: [{namespace: NAMESPACE_DNS}, "www.example.com"]
  expected: "2ed6657d-e927-568b-95e1-2665a8aea6a2"

# ---------------------------------------------------------------------------
# uuid.uuid3 and uuid.uuid5 — variant attribute
# Both uuid3 and uuid5 produce RFC 4122 variant UUIDs.
# .variant returns the string 'specified in RFC 4122'.
# ---------------------------------------------------------------------------

invariant uuid_extra274.uuid3.variant_rfc4122:
  description: "uuid.uuid3(NAMESPACE_DNS, 'www.example.com').variant == 'specified in RFC 4122' — uuid3 always produces RFC 4122 variant UUIDs; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: variant_attribute
  kind: python_call_eq
  function: uuid3.__call__.variant.__eq__
  args: [{namespace: NAMESPACE_DNS}, "www.example.com", "specified in RFC 4122"]
  expected: true

invariant uuid_extra274.uuid5.variant_rfc4122:
  description: "uuid.uuid5(NAMESPACE_DNS, 'www.example.com').variant == 'specified in RFC 4122' — uuid5 always produces RFC 4122 variant UUIDs; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: variant_attribute
  kind: python_call_eq
  function: uuid5.__call__.variant.__eq__
  args: [{namespace: NAMESPACE_DNS}, "www.example.com", "specified in RFC 4122"]
  expected: true
