spec: theseus_json
version: ">=3.9"
backend: python_cleanroom(theseus_json)

docs: https://www.json.org/json-en.html

provenance:
  derived_from:
    - "https://www.json.org/json-en.html — JSON specification"
  notes:
    - "Clean-room JSON codec. Do NOT import json, simplejson, or any JSON library."
    - "Implement a recursive descent parser from scratch using only Python stdlib string/bytes ops."
    - "json_loads_int: parse '{\"a\": 1}' and return obj['a'] which equals 1."
    - "json_dumps_has_key: serialize {'a': 1} to a JSON string; return True if 'a' appears in output."
    - "json_round_trip: loads(dumps({'x': [1,2,3]}))['x'] should equal [1,2,3]; return True."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_json.loads_int:
  description: "parse '{\"a\": 1}' and return obj['a'] == 1"
  category: loads
  kind: python_call_eq
  function: json_loads_int
  args: []
  expected: 1

invariant theseus_json.dumps_has_key:
  description: "dumps({'a': 1}) produces JSON string containing 'a'"
  category: dumps
  kind: python_call_eq
  function: json_dumps_has_key
  args: []
  expected: true

invariant theseus_json.round_trip:
  description: "loads(dumps({'x': [1,2,3]}))['x'] == [1,2,3]"
  category: round_trip
  kind: python_call_eq
  function: json_round_trip
  args: []
  expected: true
