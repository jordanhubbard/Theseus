spec: concurrent_futures_extra1621
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __weakref__ and weak reference protocol"
    - "concurrent.futures.Future is a pure Python class that directly subclasses object; Python automatically adds __weakref__ getset_descriptor to the class __dict__ for classes without __slots__ whose base does not already supply it — Future.__dict__.__contains__('__weakref__') is True"
    - "concurrent.futures.Executor is also a pure Python base class with no __slots__ and no parent other than object; __weakref__ is in its own __dict__"
    - "ThreadPoolExecutor and ProcessPoolExecutor inherit from Executor which already owns __weakref__; subclasses do not re-define it, so __dict__.__contains__('__weakref__') is False for both"
    - "concurrent.futures.BrokenExecutor is a pure Python exception class (direct subclass of RuntimeError, itself a C type without Python __weakref__ descriptor); BrokenExecutor is the first pure-Python link in the chain and owns __weakref__"
    - "CancelledError, TimeoutError, and InvalidStateError in concurrent.futures are re-exports of builtins or existing exception classes from the C hierarchy; their own __dict__ does not contain __weakref__"
    - "thread.BrokenThreadPool and process.BrokenProcessPool inherit from BrokenExecutor which already owns __weakref__; they do not re-define it"
    - "Internal work-item classes (_WorkItem in thread and process, _CallItem, _ResultItem in process) are pure Python classes directly inheriting from object; they own __weakref__ in their own __dict__"
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12"
error_model: python_exceptions

table concurrent_futures_extra1621.executor_weakref:
  description: "concurrent.futures executor and future classes: base classes own __weakref__; concrete subclasses that inherit from those bases do not re-define it; internal work-item classes own __weakref__ as they are direct object subclasses"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1621ex

  columns: [id, function, args, expected]
  rows:
    - ["cf1621ex001", "concurrent.futures.Future.__dict__.__contains__",                    ["__weakref__"], true]
    - ["cf1621ex002", "concurrent.futures.Executor.__dict__.__contains__",                  ["__weakref__"], true]
    - ["cf1621ex003", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",        ["__weakref__"], false]
    - ["cf1621ex004", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__",       ["__weakref__"], false]
    - ["cf1621ex005", "concurrent.futures.Future.__dict__.__contains__",                    ["__dict__"],    false]
    - ["cf1621ex006", "concurrent.futures.Executor.__dict__.__contains__",                  ["__dict__"],    false]
    - ["cf1621ex007", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",        ["__dict__"],    false]
    - ["cf1621ex008", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__",       ["__dict__"],    false]
    - ["cf1621ex009", "concurrent.futures.Future.__dict__.__class__.__name__.__eq__",       ["mappingproxy"], true]
    - ["cf1621ex010", "concurrent.futures.Executor.__dict__.__class__.__name__.__eq__",     ["mappingproxy"], true]
    - ["cf1621ex011", "concurrent.futures.ThreadPoolExecutor.__name__.__eq__",              ["ThreadPoolExecutor"], true]
    - ["cf1621ex012", "concurrent.futures.ProcessPoolExecutor.__name__.__eq__",             ["ProcessPoolExecutor"], true]
    - ["cf1621ex013", "concurrent.futures.thread._WorkItem.__dict__.__contains__",          ["__weakref__"], true]
    - ["cf1621ex014", "concurrent.futures.process._WorkItem.__dict__.__contains__",         ["__weakref__"], true]
    - ["cf1621ex015", "concurrent.futures.process._CallItem.__dict__.__contains__",         ["__weakref__"], true]
    - ["cf1621ex016", "concurrent.futures.process._ResultItem.__dict__.__contains__",       ["__weakref__"], true]
    - ["cf1621ex017", "concurrent.futures.thread._WorkItem.__dict__.__contains__",          ["__dict__"],    false]
    - ["cf1621ex018", "concurrent.futures.process._CallItem.__dict__.__contains__",         ["__dict__"],    false]
    - ["cf1621ex019", "concurrent.futures.process._ResultItem.__dict__.__contains__",       ["__dict__"],    false]
    - ["cf1621ex020", "concurrent.futures.Future.__name__.__eq__",                          ["Future"],      true]
    - ["cf1621ex021", "concurrent.futures.Executor.__name__.__eq__",                        ["Executor"],    true]

table concurrent_futures_extra1621.exceptions_weakref:
  description: "concurrent.futures exception classes: BrokenExecutor is the first pure-Python node in the exception hierarchy and owns __weakref__; its subclasses (BrokenThreadPool, BrokenProcessPool) do not re-define it; CancelledError, TimeoutError, and InvalidStateError are re-exports of C-hierarchy exceptions and do not own __weakref__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1621ec

  columns: [id, function, args, expected]
  rows:
    - ["cf1621ec001", "concurrent.futures.BrokenExecutor.__dict__.__contains__",            ["__weakref__"], true]
    - ["cf1621ec002", "concurrent.futures.CancelledError.__dict__.__contains__",            ["__weakref__"], false]
    - ["cf1621ec003", "concurrent.futures.TimeoutError.__dict__.__contains__",              ["__weakref__"], false]
    - ["cf1621ec004", "concurrent.futures.InvalidStateError.__dict__.__contains__",         ["__weakref__"], false]
    - ["cf1621ec005", "concurrent.futures.thread.BrokenThreadPool.__dict__.__contains__",   ["__weakref__"], false]
    - ["cf1621ec006", "concurrent.futures.process.BrokenProcessPool.__dict__.__contains__", ["__weakref__"], false]
    - ["cf1621ec007", "concurrent.futures.BrokenExecutor.__dict__.__contains__",            ["__dict__"],    false]
    - ["cf1621ec008", "concurrent.futures.CancelledError.__dict__.__contains__",            ["__dict__"],    false]
    - ["cf1621ec009", "concurrent.futures.TimeoutError.__dict__.__contains__",              ["__dict__"],    false]
    - ["cf1621ec010", "concurrent.futures.InvalidStateError.__dict__.__contains__",         ["__dict__"],    false]
    - ["cf1621ec011", "concurrent.futures.thread.BrokenThreadPool.__dict__.__contains__",   ["__dict__"],    false]
    - ["cf1621ec012", "concurrent.futures.process.BrokenProcessPool.__dict__.__contains__", ["__dict__"],    false]
    - ["cf1621ec013", "concurrent.futures.BrokenExecutor.__name__.__eq__",                  ["BrokenExecutor"], true]
    - ["cf1621ec014", "concurrent.futures.thread.BrokenThreadPool.__name__.__eq__",         ["BrokenThreadPool"], true]
    - ["cf1621ec015", "concurrent.futures.process.BrokenProcessPool.__name__.__eq__",       ["BrokenProcessPool"], true]
    - ["cf1621ec016", "concurrent.futures.BrokenExecutor.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
