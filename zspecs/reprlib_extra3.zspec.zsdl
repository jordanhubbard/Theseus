spec: reprlib_extra3
version: ">=3.9"
backend: python_module(reprlib)

docs: https://docs.python.org/3/library/reprlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/reprlib.html — Python reprlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/reprlib.py"
  notes:
    - "This spec extends prior reprlib specs."
    - "Focus: __module__ and __name__ for reprlib classes and functions; Repr class attributes."
    - "reprlib.Repr.__name__ == 'Repr'."
    - "reprlib.Repr.__module__ == 'reprlib'."
    - "reprlib.repr.__name__ == 'repr' (the module-level repr function, not the built-in)."
    - "reprlib.aRepr.__class__.__name__ == 'Repr' (the module-level Repr instance)."
    - "reprlib.Repr().maxstring == 30 (default)."
    - "reprlib.Repr().maxlist == 6 (default)."
    - "reprlib.Repr().maxdict == 4 (default)."
    - "reprlib.Repr().maxother == 30 (default)."
    - "reprlib.recursive_repr.__name__ == 'recursive_repr'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table reprlib_extra3.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [Repr, Repr.__name__.__eq__, ["Repr"], true]

table reprlib_extra3.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [recursive_repr, recursive_repr.__name__.__eq__, ["recursive_repr"], true]

invariant reprlib_extra3.Repr.module:
  description: "reprlib.Repr.__module__ == 'reprlib'"
  category: module
  kind: python_call_eq
  function: Repr.__module__.__eq__
  args: ["reprlib"]
  expected: true

invariant reprlib_extra3.aRepr.class_name:
  description: "reprlib.aRepr.__class__.__name__ == 'Repr'"
  category: aRepr
  kind: python_call_eq
  function: aRepr.__class__.__name__.__eq__
  args: ["Repr"]
  expected: true

invariant reprlib_extra3.Repr.maxstring_default:
  description: "reprlib.Repr().maxstring == 30"
  category: Repr_defaults
  kind: python_call_eq
  function: Repr
  args: []
  method: maxstring.__eq__
  method_args: [30]
  expected: true

invariant reprlib_extra3.Repr.maxlist_default:
  description: "reprlib.Repr().maxlist == 6"
  category: Repr_defaults
  kind: python_call_eq
  function: Repr
  args: []
  method: maxlist.__eq__
  method_args: [6]
  expected: true

invariant reprlib_extra3.Repr.maxdict_default:
  description: "reprlib.Repr().maxdict == 4"
  category: Repr_defaults
  kind: python_call_eq
  function: Repr
  args: []
  method: maxdict.__eq__
  method_args: [4]
  expected: true

invariant reprlib_extra3.Repr.maxother_default:
  description: "reprlib.Repr().maxother == 30"
  category: Repr_defaults
  kind: python_call_eq
  function: Repr
  args: []
  method: maxother.__eq__
  method_args: [30]
  expected: true

invariant reprlib_extra3.Repr.maxlevel_default:
  description: "reprlib.Repr().maxlevel == 6"
  category: Repr_defaults
  kind: python_call_eq
  function: Repr
  args: []
  method: maxlevel.__eq__
  method_args: [6]
  expected: true

invariant reprlib_extra3.recursive_repr.module:
  description: "reprlib.recursive_repr.__module__ == 'reprlib'"
  category: module
  kind: python_call_eq
  function: recursive_repr.__module__.__eq__
  args: ["reprlib"]
  expected: true

invariant reprlib_extra3.Repr.repr_list_name:
  description: "reprlib.Repr().repr_list.__func__.__name__ == 'repr_list'"
  category: Repr_methods
  kind: python_call_eq
  function: Repr
  args: []
  method: repr_list.__func__.__name__.__eq__
  method_args: ["repr_list"]
  expected: true
