spec: invert_color
version: ">=2.0.0"
backend: node(invert-color)

docs: https://www.npmjs.com/package/invert-color

provenance:
  derived_from:
    - "invert-color README — https://www.npmjs.com/package/invert-color"
    - "Test vectors verified with invert-color via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "invert-color source"
  notes:
    - "invert-color is an npm package. Install: npm install invert-color"
    - "Returns the inverted hex color string for a given hex color."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a hex color string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table invert_color.invert:
  kind: node_module_call_eq
  function: ~
  category: color
  id_prefix: icolor

  columns: [id, args, expected]
  rows:
    - [red,    ["#ff0000"],  "#00ffff"]
    - [black,  ["#000000"],  "#ffffff"]
    - [blue,   ["#0000ff"],  "#ffff00"]
