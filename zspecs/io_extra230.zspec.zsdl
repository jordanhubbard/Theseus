spec: io_extra230
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bufferedio.c"
  notes:
    - "This spec covers: io method __class__.__name__ type contracts for BytesIO and StringIO methods, and io.open."
    - "io.BytesIO.read.__class__.__name__ == 'method_descriptor'; BytesIO methods are C extension method_descriptor; verified with Python 3.14.3."
    - "io.BytesIO.write.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.3."
    - "io.BytesIO.seek.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.3."
    - "io.BytesIO.getvalue.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.3."
    - "io.StringIO.read.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.3."
    - "io.StringIO.write.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.3."
    - "io.StringIO.getvalue.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.3."
    - "io.open.__class__.__name__ == 'builtin_function_or_method'; io.open is a C-level builtin; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io method __class__.__name__ values
# BytesIO and StringIO are C extension classes; their methods are method_descriptor.
# io.open is a C-level builtin_function_or_method.
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table io_extra230.bytesio_method_class_names:
  description: "io.BytesIO method __class__.__name__ contracts for read, write, seek, getvalue; all are method_descriptor (C extension); verified with Python 3.14.3"
  kind: python_call_eq
  category: method_metadata
  id_prefix: iomthdclsname230

  columns: [id, function, args, expected]
  rows:
    - [bytesio_read_classname,    BytesIO.read.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [bytesio_write_classname,   BytesIO.write.__class__.__name__.__eq__,   ["method_descriptor"], true]
    - [bytesio_seek_classname,    BytesIO.seek.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [bytesio_getvalue_classname, BytesIO.getvalue.__class__.__name__.__eq__, ["method_descriptor"], true]

table io_extra230.stringio_method_class_names:
  description: "io.StringIO method __class__.__name__ contracts for read, write, getvalue; all are method_descriptor (C extension); verified with Python 3.14.3"
  kind: python_call_eq
  category: method_metadata
  id_prefix: iomthdclsname230b

  columns: [id, function, args, expected]
  rows:
    - [stringio_read_classname,    StringIO.read.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [stringio_write_classname,   StringIO.write.__class__.__name__.__eq__,   ["method_descriptor"], true]
    - [stringio_getvalue_classname, StringIO.getvalue.__class__.__name__.__eq__, ["method_descriptor"], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

invariant io_extra230.BytesIO.read_class_name:
  description: "io.BytesIO.read.__class__.__name__ == 'method_descriptor' — BytesIO.read is a C extension method_descriptor, not a Python function; verified with Python 3.14.3"
  category: method_metadata
  kind: python_call_eq
  function: BytesIO.read.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra230.BytesIO.write_class_name:
  description: "io.BytesIO.write.__class__.__name__ == 'method_descriptor' — BytesIO.write is a C extension method_descriptor; verified with Python 3.14.3"
  category: method_metadata
  kind: python_call_eq
  function: BytesIO.write.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra230.BytesIO.seek_class_name:
  description: "io.BytesIO.seek.__class__.__name__ == 'method_descriptor' — BytesIO.seek is a C extension method_descriptor; verified with Python 3.14.3"
  category: method_metadata
  kind: python_call_eq
  function: BytesIO.seek.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra230.BytesIO.getvalue_class_name:
  description: "io.BytesIO.getvalue.__class__.__name__ == 'method_descriptor' — BytesIO.getvalue is a C extension method_descriptor; verified with Python 3.14.3"
  category: method_metadata
  kind: python_call_eq
  function: BytesIO.getvalue.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra230.StringIO.read_class_name:
  description: "io.StringIO.read.__class__.__name__ == 'method_descriptor' — StringIO.read is a C extension method_descriptor; verified with Python 3.14.3"
  category: method_metadata
  kind: python_call_eq
  function: StringIO.read.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra230.StringIO.write_class_name:
  description: "io.StringIO.write.__class__.__name__ == 'method_descriptor' — StringIO.write is a C extension method_descriptor; verified with Python 3.14.3"
  category: method_metadata
  kind: python_call_eq
  function: StringIO.write.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra230.StringIO.getvalue_class_name:
  description: "io.StringIO.getvalue.__class__.__name__ == 'method_descriptor' — StringIO.getvalue is a C extension method_descriptor; verified with Python 3.14.3"
  category: method_metadata
  kind: python_call_eq
  function: StringIO.getvalue.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra230.open_class_name:
  description: "io.open.__class__.__name__ == 'builtin_function_or_method' — io.open is a C-level builtin, not a Python function; verified with Python 3.14.3"
  category: method_metadata
  kind: python_call_eq
  function: open.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
