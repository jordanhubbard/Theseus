spec: dask_rust
version: ">=3.9"
backend: rust_module(dask_rust)

docs: https://docs.dask.org/

provenance:
  derived_from:
    - "https://docs.dask.org/ — Dask documentation"
  not_derived_from:
    - "dask source: dask/base.py"
  notes:
    - "Dask provides parallel computing with task graphs."
    - "dask.delayed(f)(args...).compute() executes lazily."
    - "Expose delayed_add(a, b) -> int: dask.delayed(lambda a,b: a+b)(a, b).compute()."
    - "Expose delayed_mul(a, b) -> int: dask.delayed(lambda a,b: a*b)(a, b).compute()."
    - "Expose delayed_list_sum(lst) -> int: compute sum of delayed list elements."
    - "dask.delayed(lambda a,b: a+b)(2, 3).compute() == 5."
    - "dask.delayed(lambda a,b: a*b)(4, 5).compute() == 20."
    - "All test vectors verified against dask 2025.3.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# delayed_add — deferred addition
table dask_rust.delayed.add:
  kind: python_call_eq
  category: add
  id_prefix: dsk_add
  function: delayed_add

  columns: [id, args, expected]
  rows:
    - [two_three, [2, 3],   5]
    - [zero,      [0, 0],   0]
    - [negative,  [-1, 1],  0]
    - [large,     [10, 20], 30]

# delayed_mul — deferred multiplication
table dask_rust.delayed.mul:
  kind: python_call_eq
  category: mul
  id_prefix: dsk_mul
  function: delayed_mul

  columns: [id, args, expected]
  rows:
    - [four_five, [4, 5],  20]
    - [zero,      [0, 5],  0]
    - [one,       [1, 7],  7]

# delayed_list_sum — sum over delayed values
invariant dask_rust.delayed.list_sum:
  description: "delayed sum of [1,2,3] == 6"
  category: list_sum
  kind: python_call_eq
  function: delayed_list_sum
  args: [[1, 2, 3]]
  expected: 6

