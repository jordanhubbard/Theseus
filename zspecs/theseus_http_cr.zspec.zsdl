spec: theseus_http_cr
version: ">=3.0"
backend: python_cleanroom(theseus_http_cr)
blocks: http

docs: https://docs.python.org/3/library/http.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/http.html"
  not_derived_from:
    - "CPython source: Lib/http/__init__.py"
  notes:
    - "Clean-room http module. Do NOT import http."

error_model: python_exceptions

invariant theseus_http_cr.http2_status:
  description: "HTTPStatus enum has correct values"
  category: behavior
  kind: python_call_eq
  function: http2_status
  args: []
  expected: true

invariant theseus_http_cr.http2_method:
  description: "HTTPMethod enum has standard methods"
  category: behavior
  kind: python_call_eq
  function: http2_method
  args: []
  expected: true

invariant theseus_http_cr.http2_categories:
  description: "HTTPStatus category properties work"
  category: behavior
  kind: python_call_eq
  function: http2_categories
  args: []
  expected: true
