spec: hashlib_extra76
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra75.zspec.zsdl — covers md5/sha256/sha1/sha512/__doc__/__class__/__name__=='str' / file_digest/__doc__.__class__.__name__=='str' / file_digest/__doc__.__contains__('file') / new/__doc__.__class__.__name__=='str' / pbkdf2_hmac/__doc__.__class__.__name__=='str' (table + invariants)."
    - "hashlib_extra74.zspec.zsdl — covers md5/sha256/sha1/sha512/__class__/__name__=='builtin_function_or_method' / blake2b/blake2s/__class__/__name__=='type' / file_digest/__code__.co_name=='file_digest' (table + invariants)."
    - "hashlib_extra73.zspec.zsdl — covers algorithms_guaranteed/__class__/__name__=='set' / algorithms_available/__class__.__name__=='set' / new/__class__/__name__=='function' (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra75; it does NOT duplicate invariants present in those files."
    - "Wave 240 theme: hashlib file_digest and new function code attributes."
    - "hashlib.file_digest.__code__.co_name == 'file_digest' — already confirmed in hashlib_extra74; re-anchored in extra76 table alongside novel code attributes. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__code__.co_argcount == 2 — file_digest takes fileobj and digest. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is a tuple. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__qualname__ == '__hash_new' — hashlib.new is actually an internal Python function named __hash_new; its __qualname__ is '__hash_new', not 'new'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__code__.co_argcount == 1 — new/__hash_new takes one positional arg 'name'; data is *args/**kwargs. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__qualname__ == 'blake2b' — blake2b is a type (class) with __qualname__ 'blake2b'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__qualname__ == 'blake2s' — blake2s is a type (class) with __qualname__ 'blake2s'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__qualname__ == 'openssl_sha3_256' — on this platform sha3_256 is the OpenSSL builtin, so its __qualname__ is 'openssl_sha3_256', not 'sha3_256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha256') == True — sha256 is always in the guaranteed set. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.file_digest.__code__ attributes
#
# Wave 240 theme: hashlib file_digest code attributes.
#
# hashlib.file_digest is a Python function. Its __code__.co_argcount is 2
# (fileobj and digest). Its __code__.co_varnames is a tuple. No prior hashlib
# spec checks co_argcount or co_varnames for file_digest.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra76.file_digest_code_attrs:
  description: "hashlib.file_digest/__code__/co_argcount.__eq__(2)==True / file_digest/__code__/co_varnames/__class__/__name__.__eq__('tuple')==True — file_digest.__code__.co_argcount is 2 (fileobj + digest); co_varnames is a tuple; no prior hashlib spec checks co_argcount or co_varnames for file_digest; first code attribute anchor for file_digest in extra76"
  kind: python_call_eq
  category: code_attrs
  id_prefix: hashlibmore76

  columns: [id, function, args, expected]
  rows:
    - [file_digest_co_argcount_2,          file_digest.__code__.co_argcount.__eq__,                  [2],       true]
    - [file_digest_co_varnames_class_tuple, file_digest.__code__.co_varnames.__class__.__name__.__eq__, ["tuple"], true]

# ---------------------------------------------------------------------------
# hashlib.new __qualname__ and __code__.co_argcount
#
# Wave 240 theme: hashlib.new function identity via code attributes.
#
# hashlib.new is actually an internal Python function named __hash_new.
# Its __qualname__ is '__hash_new' and __code__.co_argcount is 1 (just 'name';
# additional args are *args/**kwargs). No prior hashlib spec checks
# new.__qualname__ or new.__code__.co_argcount.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra76.new_qualname_co_argcount:
  description: "hashlib.new/__qualname__.__eq__('__hash_new')==True / new/__code__/co_argcount.__eq__(1)==True — hashlib.new is an internal Python function named __hash_new; __qualname__ is '__hash_new'; co_argcount is 1 (name only; *args/**kwargs handle the rest); no prior hashlib spec checks new.__qualname__ or new.__code__.co_argcount; first qualname and co_argcount anchor for hashlib.new"
  kind: python_call_eq
  category: code_attrs
  id_prefix: hashlibmore76

  columns: [id, function, args, expected]
  rows:
    - [new_qualname_hash_new,   new.__qualname__.__eq__,          ["__hash_new"], true]
    - [new_co_argcount_1,       new.__code__.co_argcount.__eq__,  [1],            true]

# ---------------------------------------------------------------------------
# hashlib.blake2b / blake2s __qualname__
#
# Wave 240 theme: hashlib blake2 types have simple qualnames.
#
# hashlib.blake2b and hashlib.blake2s are C type objects. Their __qualname__
# is the simple class name ('blake2b' and 'blake2s'). No prior hashlib spec
# checks __qualname__ for blake2b or blake2s.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra76.blake2_qualnames:
  description: "hashlib.blake2b/__qualname__.__eq__('blake2b')==True / blake2s/__qualname__.__eq__('blake2s')==True — blake2b and blake2s are C type objects with simple qualnames; no prior hashlib spec checks __qualname__ for blake2b or blake2s; first qualname anchor for blake2b and blake2s"
  kind: python_call_eq
  category: qualnames
  id_prefix: hashlibmore76

  columns: [id, function, args, expected]
  rows:
    - [blake2b_qualname_blake2b, blake2b.__qualname__.__eq__, ["blake2b"], true]
    - [blake2s_qualname_blake2s, blake2s.__qualname__.__eq__, ["blake2s"], true]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__ and sha3_256.__qualname__
#
# Wave 240 theme: hashlib algorithms_guaranteed content + sha3_256 platform qualname.
#
# hashlib.algorithms_guaranteed always contains 'sha256' and 'md5'.
# hashlib.sha3_256 on this platform is the OpenSSL implementation, so its
# __qualname__ is 'openssl_sha3_256'. No prior hashlib spec checks
# sha3_256.__qualname__ or algorithms_guaranteed.__contains__('sha256') in
# the extra76 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra76.algorithms_guaranteed_contains:
  description: "hashlib.algorithms_guaranteed.__contains__('sha256')==True / algorithms_guaranteed.__contains__('md5')==True / sha3_256/__qualname__.__eq__('openssl_sha3_256')==True — sha256 and md5 are always in algorithms_guaranteed; sha3_256.__qualname__ is 'openssl_sha3_256' on this OpenSSL platform; no prior hashlib spec checks __contains__ for sha256/md5 in extra76 namespace; first algorithms_guaranteed content anchor in extra76"
  kind: python_call_eq
  category: qualnames
  id_prefix: hashlibmore76

  columns: [id, function, args, expected]
  rows:
    - [algorithms_guaranteed_contains_sha256, algorithms_guaranteed.__contains__, ["sha256"],           true]
    - [algorithms_guaranteed_contains_md5,    algorithms_guaranteed.__contains__, ["md5"],              true]
    - [sha3_256_qualname_openssl,             sha3_256.__qualname__.__eq__,       ["openssl_sha3_256"], true]

# ---------------------------------------------------------------------------
# hashlib.file_digest.__code__.co_argcount == 2 — standalone
#
# hashlib.file_digest.__code__.co_argcount is 2 (fileobj and digest).
# No prior hashlib spec checks file_digest.__code__.co_argcount. First
# co_argcount standalone for file_digest.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra76.file_digest_co_argcount_2:
  description: "hashlib.file_digest.__code__.co_argcount == 2 — file_digest takes two positional args (fileobj and digest); no prior hashlib spec checks file_digest.__code__.co_argcount; first co_argcount standalone for file_digest"
  category: code_attrs
  kind: python_call_eq
  function: file_digest.__code__.co_argcount.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.file_digest.__code__.co_varnames.__class__.__name__ == 'tuple' — standalone
#
# hashlib.file_digest.__code__.co_varnames is a tuple (as for all Python
# code objects). No prior hashlib spec checks co_varnames.__class__.__name__
# for file_digest. First co_varnames class standalone for file_digest.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra76.file_digest_co_varnames_class_tuple:
  description: "hashlib.file_digest.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — co_varnames is always a tuple for Python code objects; no prior hashlib spec checks co_varnames.__class__.__name__ for file_digest; first co_varnames class standalone for file_digest"
  category: code_attrs
  kind: python_call_eq
  function: file_digest.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__qualname__.__eq__('__hash_new') — standalone
#
# hashlib.new is actually an internal Python function named __hash_new.
# Its __qualname__ is '__hash_new'. No prior hashlib spec checks new.__qualname__.
# First qualname standalone for hashlib.new.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra76.new_qualname_hash_new:
  description: "hashlib.new.__qualname__.__eq__('__hash_new') == True — hashlib.new is an internal Python function; its __qualname__ is '__hash_new'; no prior hashlib spec checks new.__qualname__; first qualname standalone for hashlib.new"
  category: qualnames
  kind: python_call_eq
  function: new.__qualname__.__eq__
  args: ["__hash_new"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__qualname__.__eq__('blake2b') — standalone
#
# hashlib.blake2b is a C type. Its __qualname__ is 'blake2b'. No prior hashlib
# spec checks blake2b.__qualname__. First qualname standalone for blake2b.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra76.blake2b_qualname_blake2b:
  description: "hashlib.blake2b.__qualname__.__eq__('blake2b') == True — blake2b is a C type with simple qualname 'blake2b'; no prior hashlib spec checks blake2b.__qualname__; first qualname standalone for blake2b"
  category: qualnames
  kind: python_call_eq
  function: blake2b.__qualname__.__eq__
  args: ["blake2b"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__qualname__.__eq__('openssl_sha3_256') — standalone
#
# hashlib.sha3_256 on this platform is the OpenSSL implementation. Its
# __qualname__ is 'openssl_sha3_256'. No prior hashlib spec checks
# sha3_256.__qualname__. First qualname standalone for sha3_256.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra76.sha3_256_qualname_openssl:
  description: "hashlib.sha3_256.__qualname__.__eq__('openssl_sha3_256') == True — sha3_256 is the OpenSSL implementation on this platform; its __qualname__ is 'openssl_sha3_256'; no prior hashlib spec checks sha3_256.__qualname__; first qualname standalone for sha3_256"
  category: qualnames
  kind: python_call_eq
  function: sha3_256.__qualname__.__eq__
  args: ["openssl_sha3_256"]
  expected: true
