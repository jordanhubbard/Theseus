spec: struct_extra195
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "struct.Struct.__doc__.__class__.__name__ == 'str' (len=3) — the Struct class carries a docstring."
    - "struct.error.__doc__.__class__.__name__ == 'NoneType' (len=8) — struct.error has no docstring; __doc__ is None."
    - "struct.pack.__doc__.__class__.__name__ == 'str' (len=3) — pack function carries a docstring."
    - "struct.unpack.__doc__.__class__.__name__ == 'str' (len=3) — unpack function carries a docstring."
    - "struct.calcsize.__doc__.__class__.__name__ == 'str' (len=3) — calcsize function carries a docstring."
    - "struct.pack_into.__doc__.__class__.__name__ == 'str' (len=3) — pack_into function carries a docstring."
    - "struct.unpack_from.__doc__.__class__.__name__ == 'str' (len=3) — unpack_from function carries a docstring."
    - "struct.iter_unpack.__doc__.__class__.__name__ == 'str' (len=3) — iter_unpack function carries a docstring."
    - "Only struct.error lacks a docstring among the covered names; all others have __doc__ of type str."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct class and function __doc__ class identity — group A
# struct.Struct, struct.error, struct.pack
# ---------------------------------------------------------------------------

table structdocs195.class_and_func_doc_class_a:
  kind: python_call_eq
  category: doc_identity
  id_prefix: structdocs195

  columns: [id, function, args, expected, description]
  rows:
    - [Struct_doc_class_len, Struct.__doc__.__class__.__name__.__len__, [], 3, "struct.Struct.__doc__.__class__.__name__.__len__() == 3 ('str' has 3 characters; Struct class carries a docstring)"]
    - [error_doc_class_len,  error.__doc__.__class__.__name__.__len__,  [], 8, "struct.error.__doc__.__class__.__name__.__len__() == 8 ('NoneType' has 8 characters; struct.error has no docstring)"]
    - [pack_doc_class_len,   pack.__doc__.__class__.__name__.__len__,   [], 3, "struct.pack.__doc__.__class__.__name__.__len__() == 3 ('str' has 3 characters; pack function carries a docstring)"]

# ---------------------------------------------------------------------------
# struct function __doc__ class identity — group B
# struct.unpack, struct.calcsize, struct.pack_into
# ---------------------------------------------------------------------------

table structdocs195.unpack_and_calcsize_doc_class_b:
  kind: python_call_eq
  category: doc_identity
  id_prefix: structdocs195

  columns: [id, function, args, expected, description]
  rows:
    - [unpack_doc_class_len,   unpack.__doc__.__class__.__name__.__len__,   [], 3, "struct.unpack.__doc__.__class__.__name__.__len__() == 3 ('str' has 3 characters; unpack function carries a docstring)"]
    - [calcsize_doc_class_len, calcsize.__doc__.__class__.__name__.__len__, [], 3, "struct.calcsize.__doc__.__class__.__name__.__len__() == 3 ('str' has 3 characters; calcsize function carries a docstring)"]
    - [pack_into_doc_class_len, pack_into.__doc__.__class__.__name__.__len__, [], 3, "struct.pack_into.__doc__.__class__.__name__.__len__() == 3 ('str' has 3 characters; pack_into function carries a docstring)"]

# ---------------------------------------------------------------------------
# struct function __doc__ class identity — group C
# struct.unpack_from, struct.iter_unpack (+ equality check)
# ---------------------------------------------------------------------------

table structdocs195.unpack_from_and_iter_doc_class_c:
  kind: python_call_eq
  category: doc_identity
  id_prefix: structdocs195

  columns: [id, function, args, expected, description]
  rows:
    - [unpack_from_doc_class_len,  unpack_from.__doc__.__class__.__name__.__len__,  [], 3, "struct.unpack_from.__doc__.__class__.__name__.__len__() == 3 ('str' has 3 characters; unpack_from function carries a docstring)"]
    - [iter_unpack_doc_class_len,  iter_unpack.__doc__.__class__.__name__.__len__,  [], 3, "struct.iter_unpack.__doc__.__class__.__name__.__len__() == 3 ('str' has 3 characters; iter_unpack function carries a docstring)"]
    - [Struct_doc_class_eq,        Struct.__doc__.__class__.__name__.__eq__,        ["str"], true, "struct.Struct.__doc__.__class__.__name__ == 'str' — Struct class docstring is a plain Python str"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant structdocs195.Struct_doc_class_name_len:
  description: "struct.Struct.__doc__.__class__.__name__.__len__() == 3 — 'str' has 3 characters; the Struct class carries a docstring"
  category: doc_identity
  kind: python_call_eq
  function: Struct.__doc__.__class__.__name__.__len__
  args: []
  expected: 3

invariant structdocs195.error_doc_class_name_len:
  description: "struct.error.__doc__.__class__.__name__.__len__() == 8 — 'NoneType' has 8 characters; struct.error has no docstring, __doc__ is None"
  category: doc_identity
  kind: python_call_eq
  function: error.__doc__.__class__.__name__.__len__
  args: []
  expected: 8

invariant structdocs195.pack_doc_class_name_len:
  description: "struct.pack.__doc__.__class__.__name__.__len__() == 3 — 'str' has 3 characters; pack function carries a docstring"
  category: doc_identity
  kind: python_call_eq
  function: pack.__doc__.__class__.__name__.__len__
  args: []
  expected: 3

invariant structdocs195.unpack_doc_class_name_len:
  description: "struct.unpack.__doc__.__class__.__name__.__len__() == 3 — 'str' has 3 characters; unpack function carries a docstring"
  category: doc_identity
  kind: python_call_eq
  function: unpack.__doc__.__class__.__name__.__len__
  args: []
  expected: 3

invariant structdocs195.calcsize_doc_class_name_len:
  description: "struct.calcsize.__doc__.__class__.__name__.__len__() == 3 — 'str' has 3 characters; calcsize function carries a docstring"
  category: doc_identity
  kind: python_call_eq
  function: calcsize.__doc__.__class__.__name__.__len__
  args: []
  expected: 3

invariant structdocs195.pack_into_doc_class_name_len:
  description: "struct.pack_into.__doc__.__class__.__name__.__len__() == 3 — 'str' has 3 characters; pack_into function carries a docstring"
  category: doc_identity
  kind: python_call_eq
  function: pack_into.__doc__.__class__.__name__.__len__
  args: []
  expected: 3

invariant structdocs195.unpack_from_doc_class_name_len:
  description: "struct.unpack_from.__doc__.__class__.__name__.__len__() == 3 — 'str' has 3 characters; unpack_from function carries a docstring"
  category: doc_identity
  kind: python_call_eq
  function: unpack_from.__doc__.__class__.__name__.__len__
  args: []
  expected: 3

invariant structdocs195.iter_unpack_doc_class_name_len:
  description: "struct.iter_unpack.__doc__.__class__.__name__.__len__() == 3 — 'str' has 3 characters; iter_unpack function carries a docstring"
  category: doc_identity
  kind: python_call_eq
  function: iter_unpack.__doc__.__class__.__name__.__len__
  args: []
