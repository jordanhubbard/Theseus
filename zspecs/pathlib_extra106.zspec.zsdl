spec: pathlib_extra106
version: ">=3.9"
backend: python_module(pathlib)
extends: pathlib_extra99

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends pathlib_extra99.zspec.zsdl."
    - "This spec covers: pathlib.PurePath method __qualname__ values and lengths for with_name, with_suffix, with_stem, relative_to, is_relative_to, joinpath, __truediv__, __str__, __repr__."
    - "All PurePath methods are Python functions (not C descriptors), so __class__.__name__ == 'function'."
    - "pathlib.PurePath.with_name.__qualname__ = 'PurePath.with_name' (length 18)."
    - "pathlib.PurePath.with_suffix.__qualname__ = 'PurePath.with_suffix' (length 20)."
    - "pathlib.PurePath.with_stem.__qualname__ = 'PurePath.with_stem' (length 18; same length as with_name)."
    - "pathlib.PurePath.relative_to.__qualname__ = 'PurePath.relative_to' (length 20)."
    - "pathlib.PurePath.is_relative_to.__qualname__ = 'PurePath.is_relative_to' (length 23)."
    - "pathlib.PurePath.joinpath.__qualname__ = 'PurePath.joinpath' (length 17)."
    - "pathlib.PurePath.__truediv__.__qualname__ = 'PurePath.__truediv__' (length 20)."
    - "pathlib.PurePath.__str__.__qualname__ = 'PurePath.__str__' (length 16)."
    - "pathlib.PurePath.__repr__.__qualname__ = 'PurePath.__repr__' (length 17)."
    - "All methods have __module__ == 'pathlib'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath method __qualname__ values for path manipulation methods
# with_name, with_suffix, with_stem, relative_to, is_relative_to are all
# Python functions defined in Lib/pathlib/_abc.py or Lib/pathlib/_local.py.
# Their __qualname__ follows the 'ClassName.method_name' pattern.
# ---------------------------------------------------------------------------

table pathlib_extra106.PurePath_path_manipulation_method_qualnames:
  description: "pathlib.PurePath path manipulation method __qualname__ values and lengths: with_name (18), with_suffix (20), with_stem (18), relative_to (20), is_relative_to (23)"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: pathlibppmeth106

  columns: [id, function, args, expected, description]
  rows:
    - [wn_qn,      PurePath.with_name.__qualname__.__eq__,         ["PurePath.with_name"],      true, "PurePath.with_name.__qualname__ == 'PurePath.with_name'"]
    - [wn_qn_len,  PurePath.with_name.__qualname__.__len__,        [],                          18,   "PurePath.with_name.__qualname__.__len__() == 18 ('PurePath.with_name' has 18 characters)"]
    - [ws_qn,      PurePath.with_suffix.__qualname__.__eq__,       ["PurePath.with_suffix"],    true, "PurePath.with_suffix.__qualname__ == 'PurePath.with_suffix'"]
    - [ws_qn_len,  PurePath.with_suffix.__qualname__.__len__,      [],                          20,   "PurePath.with_suffix.__qualname__.__len__() == 20 ('PurePath.with_suffix' has 20 characters)"]
    - [wstem_qn,   PurePath.with_stem.__qualname__.__eq__,         ["PurePath.with_stem"],      true, "PurePath.with_stem.__qualname__ == 'PurePath.with_stem'"]
    - [wstem_len,  PurePath.with_stem.__qualname__.__len__,        [],                          18,   "PurePath.with_stem.__qualname__.__len__() == 18 ('PurePath.with_stem' has 18 characters; same as with_name)"]
    - [rt_qn,      PurePath.relative_to.__qualname__.__eq__,       ["PurePath.relative_to"],    true, "PurePath.relative_to.__qualname__ == 'PurePath.relative_to'"]
    - [rt_qn_len,  PurePath.relative_to.__qualname__.__len__,      [],                          20,   "PurePath.relative_to.__qualname__.__len__() == 20 ('PurePath.relative_to' has 20 characters)"]
    - [irt_qn,     PurePath.is_relative_to.__qualname__.__eq__,    ["PurePath.is_relative_to"], true, "PurePath.is_relative_to.__qualname__ == 'PurePath.is_relative_to'"]
    - [irt_qn_len, PurePath.is_relative_to.__qualname__.__len__,   [],                          23,   "PurePath.is_relative_to.__qualname__.__len__() == 23 ('PurePath.is_relative_to' has 23 characters)"]

# ---------------------------------------------------------------------------
# pathlib.PurePath method __qualname__ values for navigation and dunder methods
# joinpath, __truediv__, __str__, __repr__ are all Python functions.
# __truediv__ implements the / operator for path joining.
# ---------------------------------------------------------------------------

table pathlib_extra106.PurePath_navigation_dunder_method_qualnames:
  description: "pathlib.PurePath joinpath, __truediv__, __str__, __repr__ method __qualname__ values and lengths"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: pathlibppmeth106

  columns: [id, function, args, expected, description]
  rows:
    - [jp_qn,       PurePath.joinpath.__qualname__.__eq__,     ["PurePath.joinpath"],     true, "PurePath.joinpath.__qualname__ == 'PurePath.joinpath'"]
    - [jp_qn_len,   PurePath.joinpath.__qualname__.__len__,    [],                        17,   "PurePath.joinpath.__qualname__.__len__() == 17 ('PurePath.joinpath' has 17 characters)"]
    - [td_qn,       PurePath.__truediv__.__qualname__.__eq__,  ["PurePath.__truediv__"],  true, "PurePath.__truediv__.__qualname__ == 'PurePath.__truediv__'"]
    - [td_qn_len,   PurePath.__truediv__.__qualname__.__len__, [],                        20,   "PurePath.__truediv__.__qualname__.__len__() == 20 ('PurePath.__truediv__' has 20 characters)"]
    - [str_qn,      PurePath.__str__.__qualname__.__eq__,      ["PurePath.__str__"],      true, "PurePath.__str__.__qualname__ == 'PurePath.__str__'"]
    - [str_qn_len,  PurePath.__str__.__qualname__.__len__,     [],                        16,   "PurePath.__str__.__qualname__.__len__() == 16 ('PurePath.__str__' has 16 characters)"]
    - [repr_qn,     PurePath.__repr__.__qualname__.__eq__,     ["PurePath.__repr__"],     true, "PurePath.__repr__.__qualname__ == 'PurePath.__repr__'"]
    - [repr_qn_len, PurePath.__repr__.__qualname__.__len__,    [],                        17,   "PurePath.__repr__.__qualname__.__len__() == 17 ('PurePath.__repr__' has 17 characters)"]

# ---------------------------------------------------------------------------
# pathlib.PurePath method class names
# All PurePath methods are Python functions; __class__.__name__ == 'function'.
# ---------------------------------------------------------------------------

table pathlib_extra106.PurePath_method_class_names:
  description: "pathlib.PurePath methods are Python functions (not C descriptors), so their __class__.__name__ == 'function'"
  kind: python_call_eq
  category: method_class_names
  id_prefix: pathlibppmeth106

  columns: [id, function, args, expected, description]
  rows:
    - [wn_cls,   PurePath.with_name.__class__.__name__.__eq__,      ["function"], true, "PurePath.with_name.__class__.__name__ == 'function' (Python-defined method)"]
    - [jp_cls,   PurePath.joinpath.__class__.__name__.__eq__,        ["function"], true, "PurePath.joinpath.__class__.__name__ == 'function'"]
    - [td_cls,   PurePath.__truediv__.__class__.__name__.__eq__,     ["function"], true, "PurePath.__truediv__.__class__.__name__ == 'function'"]
    - [str_cls,  PurePath.__str__.__class__.__name__.__eq__,         ["function"], true, "PurePath.__str__.__class__.__name__ == 'function'"]
    - [repr_cls, PurePath.__repr__.__class__.__name__.__eq__,        ["function"], true, "PurePath.__repr__.__class__.__name__ == 'function'"]
    - [wn_not_md, PurePath.with_name.__class__.__name__.__eq__,     ["method_descriptor"], false, "PurePath.with_name.__class__.__name__ is NOT 'method_descriptor' (it is a Python function, not a C extension descriptor)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra106.PurePath.with_name_qualname:
  description: "pathlib.PurePath.with_name.__qualname__ == 'PurePath.with_name' (qualname length is 18; the 'with_name' method creates a new path with the final component replaced)"
  category: method_qualnames
  kind: python_call_eq
  function: PurePath.with_name.__qualname__.__eq__
  args: ["PurePath.with_name"]
  expected: true

invariant pathlib_extra106.PurePath.is_relative_to_qualname_len:
  description: "pathlib.PurePath.is_relative_to.__qualname__.__len__() == 23 ('PurePath.is_relative_to' is the longest qualname among the path manipulation methods in this spec)"
  category: method_qualnames
  kind: python_call_eq
  function: PurePath.is_relative_to.__qualname__.__len__
  args: []
  expected: 23

invariant pathlib_extra106.PurePath.joinpath_is_function:
  description: "pathlib.PurePath.joinpath.__class__.__name__ == 'function' (PurePath methods are pure Python implementations; they are not C extension descriptors)"
  category: method_class_names
  kind: python_call_eq
  function: PurePath.joinpath.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pathlib_extra106.PurePath.truediv_qualname_len:
  description: "pathlib.PurePath.__truediv__.__qualname__.__len__() == 20 ('PurePath.__truediv__' has 20 characters; __truediv__ implements the / path-joining operator)"
  category: method_qualnames
  kind: python_call_eq
  function: PurePath.__truediv__.__qualname__.__len__
  args: []
  expected: 20

invariant pathlib_extra106.PurePath.with_suffix_qualname_len:
  description: "pathlib.PurePath.with_suffix.__qualname__.__len__() == 20 ('PurePath.with_suffix' has the same length as relative_to and __truediv__; all three are 20 characters)"
  category: method_qualnames
  kind: python_call_eq
  function: PurePath.with_suffix.__qualname__.__len__
  args: []
  expected: 20

