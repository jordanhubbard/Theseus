  category: identity
  id_prefix: cfwait180

  columns: [id, function, args, expected, description]
  rows:
    - [wait_name_eq,
       wait.__name__.__eq__,
       ["wait"],
       true,
       "concurrent.futures.wait.__name__.__eq__('wait') == True — wait is the blocking future-set completion function; __name__ is 'wait' (4 chars: w-a-i-t); str.__eq__('wait') returns True; new to concurrent_futures_extra180"]
    - [wait_name_len_4,
       wait.__name__.__len__,
       [],
       4,
       "concurrent.futures.wait.__name__.__len__() == 4 — 'wait' has 4 characters: w-a-i-t; NAME LENGTHS: wait=4 < as_completed=12; shorter of the two functions in this spec; str.__len__() returns 4; new to concurrent_futures_extra180"]
    - [wait_module_eq,
       wait.__module__.__eq__,
       ["concurrent.futures._base"],
       true,
       "concurrent.futures.wait.__module__.__eq__('concurrent.futures._base') == True — wait is defined in concurrent.futures._base and re-exported from concurrent.futures; str.__eq__('concurrent.futures._base') returns True; new to concurrent_futures_extra180"]
    - [wait_qualname_eq,
       wait.__qualname__.__eq__,
       ["wait"],
       true,
       "concurrent.futures.wait.__qualname__.__eq__('wait') == True — wait is a top-level function so __qualname__ equals __name__; str.__eq__('wait') returns True; new to concurrent_futures_extra180"]
    - [wait_module_len_24,
       wait.__module__.__len__,
       [],
       24,
       "concurrent.futures.wait.__module__.__len__() == 24 — 'concurrent.futures._base' has 24 characters: c-o-n-c-u-r-r-e-n-t-.-f-u-t-u-r-e-s-.-_-b-a-s-e; str.__len__() returns 24; new to concurrent_futures_extra180"]

