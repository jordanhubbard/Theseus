spec: struct_extra2101
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "Wave extra2101 (struct_extra2101): __class_getitem__, __init_subclass__, __subclasshook__, __mro_entries__ dict-presence checks."
    - "struct.Struct is a C extension type (from _struct); its __dict__ contains pack, unpack, iter_unpack, format, size — no dunder protocol hooks."
    - "struct.error is a pure-Python exception subclass of Exception; its __dict__ contains only __module__, __weakref__, __doc__."
    - "Neither struct.Struct nor struct.error define __class_getitem__ — generic alias subscripting is not supported."
    - "Neither class defines __init_subclass__ in their own __dict__ — hook is inherited from object."
    - "Neither class defines __subclasshook__ in their own __dict__ — ABC virtual subclass customization is absent."
    - "Neither class defines __mro_entries__ in their own __dict__ — MRO resolution protocol is not present."
    - "struct.Struct.__module__ is '_struct' (the C accelerator), not 'struct'."
    - "All expected values verified by running Python 3.14.4 struct module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table struct_extra2101.class_getitem_protocol:
  description: "struct classes __class_getitem__ dict-presence checks — generic alias protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2101

  columns: [id, function, args, expected]
  rows:
    - ["st2101001", "struct.Struct.__dict__.__contains__", ["__class_getitem__"], false]
    - ["st2101002", "struct.error.__dict__.__contains__", ["__class_getitem__"], false]
    - ["st2101003", "struct.Struct.__dict__.__contains__", ["__class_getitem__"], false]
    - ["st2101004", "struct.error.__dict__.__contains__", ["__class_getitem__"], false]
    - ["st2101005", "struct.Struct.__dict__.__contains__", ["__class_getitem__"], false]
    - ["st2101006", "struct.error.__dict__.__contains__", ["__class_getitem__"], false]
    - ["st2101007", "struct.Struct.__dict__.__contains__", ["__class_getitem__"], false]

