spec: abc_extra266
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "collections.abc.Generator.__bases__[0].__name__ == 'Iterator' — Generator inherits from Iterator."
    - "collections.abc.Generator.send, throw, close carry __qualname__ prefixed with 'Generator.'."
    - "collections.abc.Buffer is available in Python 3.12+; __module__ == 'collections.abc'."
    - "collections.abc.Reversible.__bases__[0].__name__ == 'Iterable'."
    - "collections.abc.Collection has three bases: Sized, Iterable, Container."
    - "All __module__ values == 'collections.abc'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Generator class identity — table
#
# collections.abc.Generator: class name, module, base class, and method names.
# Generator inherits from Iterator.
# ---------------------------------------------------------------------------

table abc_extra266.generator_abc_identity:
  description: "collections.abc.Generator class identity and method __name__ values"
  kind: python_call_eq
  category: identity
  id_prefix: genabc

  columns: [id, function, args, expected, description]
  rows:
    - [gen_name,       collections.abc.Generator.__name__.__eq__,              ["Generator"],       true, "collections.abc.Generator.__name__ == 'Generator'"]
    - [gen_module,     collections.abc.Generator.__module__.__eq__,            ["collections.abc"], true, "collections.abc.Generator.__module__ == 'collections.abc'"]
    - [gen_send_name,  collections.abc.Generator.send.__name__.__eq__,         ["send"],            true, "collections.abc.Generator.send.__name__ == 'send'"]
    - [gen_throw_name, collections.abc.Generator.throw.__name__.__eq__,        ["throw"],           true, "collections.abc.Generator.throw.__name__ == 'throw'"]
    - [gen_close_name, collections.abc.Generator.close.__name__.__eq__,        ["close"],           true, "collections.abc.Generator.close.__name__ == 'close'"]

# ---------------------------------------------------------------------------
# Reversible and Collection class identity — table
#
# collections.abc.Reversible inherits from Iterable.
# collections.abc.Collection has three bases: Sized, Iterable, Container.
# Buffer (Python 3.12+) inherits from object.
# ---------------------------------------------------------------------------

table abc_extra266.reversible_collection_identity:
  description: "collections.abc Reversible, Collection, and Buffer class identity"
  kind: python_call_eq
  category: identity
  id_prefix: revcol

  columns: [id, function, args, expected, description]
  rows:
    - [rev_name,       collections.abc.Reversible.__name__.__eq__,             ["Reversible"],      true, "collections.abc.Reversible.__name__ == 'Reversible'"]
    - [rev_module,     collections.abc.Reversible.__module__.__eq__,           ["collections.abc"], true, "collections.abc.Reversible.__module__ == 'collections.abc'"]
    - [col_name,       collections.abc.Collection.__name__.__eq__,             ["Collection"],      true, "collections.abc.Collection.__name__ == 'Collection'"]
    - [col_module,     collections.abc.Collection.__module__.__eq__,           ["collections.abc"], true, "collections.abc.Collection.__module__ == 'collections.abc'"]
    - [buf_name,       collections.abc.Buffer.__name__.__eq__,                 ["Buffer"],          true, "collections.abc.Buffer.__name__ == 'Buffer'"]

# ---------------------------------------------------------------------------
# Generator.__bases__[0] is Iterator — standalone invariant
# ---------------------------------------------------------------------------

invariant abc_extra266.Generator.bases0_name:
  description: "collections.abc.Generator.__bases__[0].__name__ == 'Iterator'"
  category: identity
  kind: python_call_eq
  function: "collections.abc.Generator.__bases__[0].__name__.__eq__"
  args: ["Iterator"]
  expected: true

# ---------------------------------------------------------------------------
# Reversible.__bases__[0] is Iterable — standalone invariant
# ---------------------------------------------------------------------------

invariant abc_extra266.Reversible.bases0_name:
  description: "collections.abc.Reversible.__bases__[0].__name__ == 'Iterable'"
  category: identity
  kind: python_call_eq
  function: "collections.abc.Reversible.__bases__[0].__name__.__eq__"
  args: ["Iterable"]
  expected: true

# ---------------------------------------------------------------------------
# Buffer.__bases__[0] is object — standalone invariant
# ---------------------------------------------------------------------------

invariant abc_extra266.Buffer.bases0_name:
  description: "collections.abc.Buffer.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: "collections.abc.Buffer.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# Buffer.__module__ is collections.abc — standalone invariant
# ---------------------------------------------------------------------------

invariant abc_extra266.Buffer.module:
  description: "collections.abc.Buffer.__module__ == 'collections.abc'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Buffer.__module__.__eq__
  args: ["collections.abc"]
  expected: true

# ---------------------------------------------------------------------------
# Generator method __qualname__ — standalone invariants
# ---------------------------------------------------------------------------

invariant abc_extra266.Generator.send_qualname:
  description: "collections.abc.Generator.send.__qualname__ == 'Generator.send'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Generator.send.__qualname__.__eq__
  args: ["Generator.send"]
  expected: true

invariant abc_extra266.Generator.throw_qualname:
  description: "collections.abc.Generator.throw.__qualname__ == 'Generator.throw'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Generator.throw.__qualname__.__eq__
  args: ["Generator.throw"]
  expected: true
