spec: hashlib_extra167
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra166.zspec.zsdl — covers hashlib.new.__name__/__qualname__/__module__/__class__.__name__ / new.__code__.co_argcount==1 / new.__code__.co_name / new.__code__.co_varnames.__len__()==3 / new.__name__.__len__()==10 / new.__module__.__len__()==7 (table + invariants)."
    - "hashlib_extra165.zspec.zsdl — covers hashlib.sha256.__class__.__name__.__eq__('builtin_function_or_method') / md5.__class__.__name__ / sha512.__class__.__name__ / sha256.__doc__.__len__()==66 / md5.__doc__.__len__()==63 / sha256.__doc__.__class__.__name__.__eq__('str') (table + invariants)."
    - "hashlib_extra164.zspec.zsdl — covers hashlib.algorithms_available and hashlib.algorithms_guaranteed set membership (table + invariants)."
    - "hashlib_extra160.zspec.zsdl — covers hashlib.__loader__.__class__.__name__ / new.__qualname__ / new.__class__.__name__ / algorithms_guaranteed.__class__.__name__ (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra166."
    - "Wave 346 theme: hashlib.__spec__ attribute identity — __spec__.name.__eq__('hashlib') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __spec__.origin.__class__.__name__.__eq__('str') / __spec__.origin.__contains__('hashlib')==True / __spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType'). The __spec__ attribute of hashlib is a ModuleSpec object from importlib describing the hashlib module's import metadata."
    - "hashlib.__spec__.name == 'hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.__class__.__name__ == 'ModuleSpec'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.origin.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.origin.__contains__('hashlib') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.submodule_search_locations is None (NoneType). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.name.__len__() == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.__class__.__name__.__len__() == 10. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.origin.__class__.__name__.__len__() == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.__spec__.name == 'hashlib' (7 chars). The ModuleSpec name is the canonical import name used to import the module (import hashlib). hashlib.__spec__.name == hashlib.__name__ == 'hashlib'. The 7-char name 'hashlib' is longer than 'struct' and 'socket' (both 6 chars) by 1 char."
    - "Note: hashlib.__spec__.origin.__class__.__name__ == 'str' (3 chars). The origin attribute is the filesystem path to hashlib.py (e.g. '.../lib/python3.14/hashlib.py'). The path is platform-specific, so we verify the type ('str') and that the path contains 'hashlib' as a substring. This avoids hardcoding machine-specific paths."
    - "Note: hashlib.__spec__.submodule_search_locations is None (NoneType). hashlib is a plain module (Lib/hashlib.py is a single Python file), not a package. Plain modules have submodule_search_locations==None. Packages (directories with __init__.py) have a non-None submodule_search_locations. 'NoneType' (8 chars = 'None'=4 + 'Type'=4) is how we check None in python_call_eq specs."
    - "Note: hashlib.__spec__.__class__.__name__ == 'ModuleSpec' (10 chars). ModuleSpec is the importlib.machinery.ModuleSpec class that describes all aspects of a module's import specification. All standard Python library modules share this same ModuleSpec class. 'ModuleSpec' = 'Module'=6 + 'Spec'=4 = 10 chars."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.__spec__.name.__eq__('hashlib')
# hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec')
# hashlib.__spec__.origin.__class__.__name__.__eq__('str')
# hashlib.__spec__.origin.__contains__('hashlib')
#
# Wave 346 theme: hashlib.__spec__ attribute identity.
#
# hashlib.__spec__.name == 'hashlib' (7 chars; canonical import name).
# hashlib.__spec__.__class__.__name__ == 'ModuleSpec' (10 chars).
# hashlib.__spec__.origin.__class__.__name__ == 'str' (3 chars; path is a string).
# hashlib.__spec__.origin.__contains__('hashlib') == True (path contains module name).
# No prior hashlib spec anchors these __spec__ attributes as a table under hashlibspec167.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra167.hashlib_spec_name_and_class:
  description: "hashlib.__spec__.name.__eq__('hashlib')==True / __spec__.__class__.__name__.__eq__('ModuleSpec')==True / __spec__.origin.__class__.__name__.__eq__('str')==True / __spec__.origin.__contains__('hashlib')==True — __spec__.name is 'hashlib' (7 chars; canonical import name; same as hashlib.__name__; 1 char longer than 'socket' and 'struct' which are 6 chars each); __spec__.__class__.__name__ is 'ModuleSpec' (10 chars; importlib.machinery.ModuleSpec; describes module import metadata; 'Module'=6 + 'Spec'=4 = 10 chars; same class for all Python stdlib modules); __spec__.origin.__class__.__name__ is 'str' (3 chars; origin is a filesystem path string to hashlib.py; platform-specific absolute path; cannot hardcode; verified via type check); __spec__.origin.__contains__('hashlib') is True (the path always contains 'hashlib' as a substring; e.g. '.../lib/python3.14/hashlib.py'; safe cross-platform check); first hashlibspec167 anchor for __spec__ name and class"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibspec167

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_hashlib,       "__spec__.name.__eq__",                      ["hashlib"],    true, "hashlib.__spec__.name == 'hashlib' (7 chars; canonical import name; 1 char longer than 'socket'/'struct' at 6 chars each)"]
    - [spec_class_ModuleSpec,   "__spec__.__class__.__name__.__eq__",        ["ModuleSpec"], true, "hashlib.__spec__.__class__.__name__ == 'ModuleSpec' (10 chars; importlib ModuleSpec; 'Module'=6 + 'Spec'=4; same for all Python stdlib modules)"]
    - [spec_origin_class_str,   "__spec__.origin.__class__.__name__.__eq__", ["str"],        true, "hashlib.__spec__.origin.__class__.__name__ == 'str' (3 chars; origin is a filesystem path string; platform-specific; verified via type check not value)"]
    - [spec_origin_has_hashlib, "__spec__.origin.__contains__",              ["hashlib"],    true, "hashlib.__spec__.origin.__contains__('hashlib') == True (path contains 'hashlib' as substring; e.g. '.../hashlib.py'; safe cross-platform check)"]

# ---------------------------------------------------------------------------
# hashlib.__spec__.submodule_search_locations — NoneType check
#
# Wave 346 theme: hashlib is not a package; submodule_search_locations is None.
#
# hashlib.__spec__.submodule_search_locations.__class__.__name__ == 'NoneType'.
# hashlib.__spec__.__class__.__name__ == 'ModuleSpec' (confirmed).
# hashlib.__spec__.name.__eq__('hashlib') (confirmed).
# hashlib.__spec__.name.__len__() == 7.
# No prior hashlib spec anchors submodule_search_locations as a table under hashlibspec167.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra167.hashlib_spec_submodule_and_lengths:
  description: "hashlib.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType')==True / __spec__.__class__.__name__.__eq__('ModuleSpec')==True / __spec__.name.__eq__('hashlib')==True / __spec__.name.__len__()==7 — submodule_search_locations.__class__.__name__ is 'NoneType' (8 chars = 'None'=4 + 'Type'=4; hashlib is NOT a package; plain modules have submodule_search_locations==None; packages have a non-None value listing subdirectory paths; 'NoneType' is the canonical way to check None in python_call_eq specs); __spec__.__class__.__name__ is 'ModuleSpec' (10 chars; confirmed; 'Module'=6 + 'Spec'=4); __spec__.name is 'hashlib' (7 chars; confirmed; same as hashlib.__name__); __spec__.name.__len__() is 7 ('hashlib' = 7 chars; 1 char longer than 'socket' and 'struct' both at 6 chars; 'hashlib'(7) < 'NoneType'(8) < 'ModuleSpec'(10) in length); first hashlibspec167 anchor for submodule_search_locations NoneType check"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibspec167

  columns: [id, function, args, expected, description]
  rows:
    - [submod_locs_nonetype,    "__spec__.submodule_search_locations.__class__.__name__.__eq__", ["NoneType"],   true, "hashlib.__spec__.submodule_search_locations.__class__.__name__ == 'NoneType' (8 chars; hashlib is not a package; plain module has None submodule_search_locations)"]
    - [spec_class_ModuleSpec_b, "__spec__.__class__.__name__.__eq__",                           ["ModuleSpec"], true, "hashlib.__spec__.__class__.__name__ == 'ModuleSpec' (10 chars; confirmed; importlib module spec class)"]
    - [spec_name_hashlib_b,     "__spec__.name.__eq__",                                         ["hashlib"],    true, "hashlib.__spec__.name == 'hashlib' (7 chars; confirmed; canonical import name; same as hashlib.__name__)"]
    - [spec_name_len_7,         "__spec__.name.__len__",                                        [], 7,           "hashlib.__spec__.name.__len__() is 7 ('hashlib' = 7 chars; 1 char longer than 'socket'/'struct' (6 chars each))"]

# ---------------------------------------------------------------------------
# hashlib.__spec__ attribute lengths
#
# Wave 346 theme: length ordering for hashlib spec attribute values.
#
# hashlib.__spec__.origin.__class__.__name__.__len__() == 3 ('str' = 3 chars).
# hashlib.__spec__.name.__len__() == 7 ('hashlib' = 7 chars).
# hashlib.__spec__.__class__.__name__.__len__() == 10 ('ModuleSpec' = 10 chars).
# hashlib.__spec__.origin.__contains__('hashlib') == True (confirmed).
# No prior hashlib spec anchors these spec attribute lengths as a table under hashlibspec167.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra167.hashlib_spec_attribute_lengths:
  description: "hashlib.__spec__.origin.__class__.__name__.__len__()==3 / __spec__.name.__len__()==7 / __spec__.__class__.__name__.__len__()==10 / __spec__.origin.__contains__('hashlib')==True — origin.__class__.__name__.__len__() is 3 ('str' = 3 chars; type name of the origin path; shortest attribute name here); __spec__.name.__len__() is 7 ('hashlib' = 7 chars; canonical import name; 1 char longer than 'socket'/'struct' at 6 chars; 7 > 6 by 1); __spec__.__class__.__name__.__len__() is 10 ('ModuleSpec' = 'Module'=6 + 'Spec'=4 = 10 chars; the importlib spec class name); origin.__contains__('hashlib') is True (confirmed; path always contains 'hashlib'); length ordering: 'str'(3) < 'hashlib'(7) < 'ModuleSpec'(10); first hashlibspec167 anchor for origin.__class__.__name__.__len__() and spec class name length"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibspec167

  columns: [id, function, args, expected, description]
  rows:
    - [origin_cls_name_len_3,    "__spec__.origin.__class__.__name__.__len__",  [], 3,  "hashlib.__spec__.origin.__class__.__name__.__len__() is 3 ('str' = 3 chars; shortest type name here; origin is a str path)"]
    - [spec_name_len_7_b,        "__spec__.name.__len__",                       [], 7,  "hashlib.__spec__.name.__len__() is 7 ('hashlib' = 7 chars; 1 char longer than 'socket'/'struct' (6 chars each); 'h'+'a'+'s'+'h'+'l'+'i'+'b'=7)"]
    - [spec_cls_name_len_10,     "__spec__.__class__.__name__.__len__",         [], 10, "hashlib.__spec__.__class__.__name__.__len__() is 10 ('ModuleSpec' = 'Module'=6 + 'Spec'=4 = 10 chars; importlib spec class name)"]
    - [origin_contains_hashlib_b,"__spec__.origin.__contains__",                ["hashlib"], true, "hashlib.__spec__.origin.__contains__('hashlib') == True (path contains module name; safe cross-platform check; confirmed)"]

# ---------------------------------------------------------------------------
# hashlib.__spec__.name.__eq__('hashlib') — standalone
#
# hashlib.__spec__.name is 'hashlib' (7 chars). The ModuleSpec.name attribute stores the
# canonical module name used in import statements (import hashlib). hashlib.__spec__.name
# equals hashlib.__name__ (both are 'hashlib'). 'hashlib' (7 chars) = 'h'+'a'+'s'+'h'+'l'+'i'+'b'.
# This is 1 char longer than the 'socket' and 'struct' module names (both 6 chars).
# The ModuleSpec is hashlib's importlib metadata descriptor; its name field identifies
# which module the spec describes. No prior hashlib spec anchors __spec__.name as a
# standalone under hashlibspec167. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra167.hashlib_spec_name_eq:
  description: "hashlib.__spec__.name.__eq__('hashlib') == True — 'hashlib' (7 chars; canonical import name; same as hashlib.__name__; 1 char longer than 'socket'/'struct' at 6 chars each); ModuleSpec.name is the import system's identifier for this module; 'hashlib'(7) < 'NoneType'(8) < 'ModuleSpec'(10) in length ordering; __spec__.submodule_search_locations is None (NoneType; hashlib is not a package); first hashlibspec167 standalone for __spec__.name"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec') — standalone
#
# hashlib.__spec__.__class__.__name__ is 'ModuleSpec' (10 chars = 'Module'=6 + 'Spec'=4).
# ModuleSpec (importlib.machinery.ModuleSpec) is the class that the Python import system uses
# to describe all aspects of a module: its name, origin, loader, and submodule_search_locations.
# All standard Python library modules have a __spec__ that is an instance of ModuleSpec.
# 'ModuleSpec' (10 chars) is 3 chars longer than hashlib.__spec__.name 'hashlib' (7 chars).
# No prior hashlib spec anchors __spec__.__class__.__name__ as a standalone under hashlibspec167.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra167.hashlib_spec_class_ModuleSpec:
  description: "hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — 'ModuleSpec' (10 chars = 'Module'=6 + 'Spec'=4); importlib.machinery.ModuleSpec; Python import system uses ModuleSpec to describe module import metadata; all stdlib modules share this class; __spec__.name=='hashlib' (7 chars; 3 chars shorter than 'ModuleSpec'=10); __spec__.submodule_search_locations.__class__.__name__=='NoneType' (hashlib is not a package); first hashlibspec167 standalone for __spec__.__class__.__name__"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__spec__.origin.__contains__('hashlib') — standalone
#
# hashlib.__spec__.origin.__contains__('hashlib') is True. The origin attribute is the
# filesystem path to hashlib.py (e.g. '/opt/.../lib/python3.14/hashlib.py'). The module
# name 'hashlib' always appears in the filename. This is a robust cross-platform check
# that avoids hardcoding an absolute path. origin.__class__.__name__ == 'str' (the path is
# a str). hashlib.__spec__.name == 'hashlib' (7 chars; same word appears in the origin path).
# No prior hashlib spec anchors __spec__.origin.__contains__ as a standalone under
# hashlibspec167. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra167.hashlib_spec_origin_contains_hashlib:
  description: "hashlib.__spec__.origin.__contains__('hashlib') == True — origin is the path to hashlib.py; 'hashlib' appears in the filename; cross-platform safe check (avoids hardcoding absolute path); origin.__class__.__name__=='str' (the path is a str); __spec__.name=='hashlib' (7 chars; the spec module name matches the filename); first hashlibspec167 standalone for origin.__contains__"
  category: identity
  kind: python_call_eq
  function: __spec__.origin.__contains__
  args: ["hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') — standalone
#
# hashlib.__spec__.submodule_search_locations.__class__.__name__ is 'NoneType' (8 chars).
# hashlib is a plain module (Lib/hashlib.py is a single Python file), not a package.
# Plain modules have submodule_search_locations == None because there are no subdirectory
# search paths to record. Packages (with __init__.py in a directory) have a non-None
# submodule_search_locations. 'NoneType' (8 chars = 'None'=4 + 'Type'=4) is the class name
# of Python's None singleton and is the standard way to check for None in python_call_eq specs.
# No prior hashlib spec anchors submodule_search_locations as a standalone under hashlibspec167.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra167.hashlib_spec_submod_locs_nonetype:
  description: "hashlib.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') == True — 'NoneType' (8 chars = 'None'=4 + 'Type'=4); hashlib is a plain module not a package (Lib/hashlib.py is a single Python file); submodule_search_locations==None for plain modules; packages have non-None value; 'NoneType' is the __class__.__name__ of Python's None singleton; this confirms hashlib is not a package without using 'is None'; first hashlibspec167 standalone for submodule_search_locations"
  category: identity
  kind: python_call_eq
  function: __spec__.submodule_search_locations.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true
