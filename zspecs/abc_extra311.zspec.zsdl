spec: abc_extra311
version: ">=3.3"
backend: python_module(collections.abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "This spec covers collections.abc Abstract Base Class identity: __name__, __module__, and __bases__[0].__name__ for the core ABCs."
    - "collections.abc.Mapping.__bases__[0].__name__ == 'Collection' — Mapping inherits from Collection, not directly from Sized/Iterable/Container."
    - "collections.abc.Sequence.__bases__[0].__name__ == 'Reversible' — Sequence inherits from Reversible (and Collection) but __bases__[0] is Reversible."
    - "collections.abc.MutableMapping.__bases__[0].__name__ == 'Mapping' — direct subclass of Mapping."
    - "collections.abc.MutableSequence.__bases__[0].__name__ == 'Sequence' — direct subclass of Sequence."
    - "collections.abc.Iterable.__bases__[0].__name__ == 'object' — Iterable is a root ABC with no ABC parent."
    - "collections.abc.Iterator.__bases__[0].__name__ == 'Iterable' — Iterator extends Iterable."
    - "collections.abc.Hashable.__bases__[0].__name__ == 'object' — Hashable is a root ABC."
    - "collections.abc.Callable.__bases__[0].__name__ == 'object' — Callable is a root ABC."
    - "All __module__ attributes are 'collections.abc' — the ABCs are defined directly in the collections.abc module."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ checks — all eight ABCs
#
# For top-level classes, __name__ is the unqualified class name.
# ---------------------------------------------------------------------------

table abc_extra311.class_names:
  description: "collections.abc ABCs have correct __name__ attributes"
  kind: python_call_eq
  category: class_names
  id_prefix: name

  columns: [id, function, args, expected]
  rows:
    - [Mapping,          Mapping.__name__.__eq__,          ["Mapping"],          true]
    - [Sequence,         Sequence.__name__.__eq__,         ["Sequence"],         true]
    - [MutableMapping,   MutableMapping.__name__.__eq__,   ["MutableMapping"],   true]
    - [MutableSequence,  MutableSequence.__name__.__eq__,  ["MutableSequence"],  true]
    - [Iterable,         Iterable.__name__.__eq__,         ["Iterable"],         true]
    - [Iterator,         Iterator.__name__.__eq__,         ["Iterator"],         true]
    - [Hashable,         Hashable.__name__.__eq__,         ["Hashable"],         true]
    - [Callable,         Callable.__name__.__eq__,         ["Callable"],         true]

# ---------------------------------------------------------------------------
# __module__ checks — all eight ABCs live in collections.abc
#
# All core ABCs are defined directly in the collections.abc module.
# ---------------------------------------------------------------------------

table abc_extra311.class_modules:
  description: "collections.abc ABCs all have __module__ == 'collections.abc'"
  kind: python_call_eq
  category: class_modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [Mapping,          Mapping.__module__.__eq__,          ["collections.abc"], true]
    - [Sequence,         Sequence.__module__.__eq__,         ["collections.abc"], true]
    - [MutableMapping,   MutableMapping.__module__.__eq__,   ["collections.abc"], true]
    - [MutableSequence,  MutableSequence.__module__.__eq__,  ["collections.abc"], true]
    - [Iterable,         Iterable.__module__.__eq__,         ["collections.abc"], true]
    - [Iterator,         Iterator.__module__.__eq__,         ["collections.abc"], true]
    - [Hashable,         Hashable.__module__.__eq__,         ["collections.abc"], true]
    - [Callable,         Callable.__module__.__eq__,         ["collections.abc"], true]

# ---------------------------------------------------------------------------
# __bases__[0].__name__ checks — inheritance hierarchy
#
# Each ABC's first base class is checked individually to document the
# intended hierarchy.
# ---------------------------------------------------------------------------

invariant abc_extra311.Mapping.base:
  description: "collections.abc.Mapping.__bases__[0].__name__ == 'Collection'"
  category: class_hierarchy
  kind: python_call_eq
  function: Mapping.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Collection"

invariant abc_extra311.Sequence.base:
  description: "collections.abc.Sequence.__bases__[0].__name__ == 'Reversible'"
  category: class_hierarchy
  kind: python_call_eq
  function: Sequence.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Reversible"

invariant abc_extra311.MutableMapping.base:
  description: "collections.abc.MutableMapping.__bases__[0].__name__ == 'Mapping'"
  category: class_hierarchy
  kind: python_call_eq
  function: MutableMapping.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Mapping"

invariant abc_extra311.MutableSequence.base:
  description: "collections.abc.MutableSequence.__bases__[0].__name__ == 'Sequence'"
  category: class_hierarchy
  kind: python_call_eq
  function: MutableSequence.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Sequence"

invariant abc_extra311.Iterable.base:
  description: "collections.abc.Iterable.__bases__[0].__name__ == 'object' — root ABC"
  category: class_hierarchy
  kind: python_call_eq
  function: Iterable.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant abc_extra311.Iterator.base:
  description: "collections.abc.Iterator.__bases__[0].__name__ == 'Iterable'"
  category: class_hierarchy
  kind: python_call_eq
  function: Iterator.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Iterable"

invariant abc_extra311.Hashable.base:
  description: "collections.abc.Hashable.__bases__[0].__name__ == 'object' — root ABC"
  category: class_hierarchy
  kind: python_call_eq
  function: Hashable.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant abc_extra311.Callable.base:
  description: "collections.abc.Callable.__bases__[0].__name__ == 'object' — root ABC"
  category: class_hierarchy
  kind: python_call_eq
  function: Callable.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"
