spec: socket_extra78
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra77.zspec.zsdl — covers gaierror/herror __dict__ key membership (__module__/__weakref__/__doc__) / AddressFamily/SocketKind __mro__[0]/__mro__[5] __name__ (table + invariants)."
    - "socket_extra76.zspec.zsdl — covers socket.socket/__dict__.__contains__('__enter__'/'__exit__'/'__repr__'/'family'/'type') / AddressFamily/SocketKind/__class__/__name__=='EnumType' / AddressFamily/SocketKind/__module__=='socket' (table + invariants)."
    - "socket_extra53.zspec.zsdl — covers socket.socket/herror/gaierror/timeout/__dict__/__class__/__qualname__.__eq__('mappingproxy') (table + invariants)."
    - "socket_extra35.zspec.zsdl — covers AddressFamily/SocketKind/__mro__.__len__()==6 (table + invariants)."
    - "socket_extra29.zspec.zsdl — covers socket.socket/__mro__.__len__()==3 / gaierror/__mro__.__len__()==5 (table + invariants)."
    - "socket_extra15.zspec.zsdl — covers AddressFamily/__mro__[1]/__name__=='IntEnum' / SocketKind/__mro__[1]/__name__=='IntEnum' (invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra77; it does NOT duplicate invariants present in those files."
    - "Wave 245 theme: socket.socket class identity + socket.error/timeout/gaierror/herror exception class names and hierarchy."
    - "socket.socket.__name__ == 'socket' — the socket class's __name__ is 'socket'. No prior socket spec checks socket.socket.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__module__ == 'socket' — the pure-Python socket wrapper class is defined in the socket module. No prior socket spec checks socket.socket.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__bases__[0].__name__ == 'socket' — socket.socket inherits from _socket.socket (the C extension type, also named 'socket'). socket_extra29 covers __mro__.__len__()==3 but NOT __bases__[0].__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__mro__.__len__() == 3 — already covered in socket_extra29. NOT duplicated here."
    - "socket.error.__name__ == 'OSError' — socket.error is an alias for the builtin OSError class. No prior socket spec checks socket.error.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error.__module__ == 'builtins' — OSError is a builtin exception. No prior socket spec checks socket.error.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__name__ == 'TimeoutError' — socket.timeout is an alias for the builtin TimeoutError since Python 3.11+. No prior socket spec checks socket.timeout.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__name__ == 'gaierror' — gaierror's own __name__ is 'gaierror'. No prior socket spec checks gaierror.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__module__ == 'socket' — gaierror is defined in the socket Python module. No prior socket spec checks gaierror.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__bases__[0].__name__ == 'OSError' — gaierror directly subclasses OSError. No prior socket spec checks gaierror.__bases__[0].__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__mro__.__len__() == 5 — already covered in socket_extra29. NOT duplicated here."
    - "socket.herror.__name__ == 'herror' — herror's own __name__ is 'herror'. No prior socket spec checks herror.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__module__ == 'socket' — herror is defined in the socket Python module. No prior socket spec checks herror.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__bases__[0].__name__ == 'OSError' — herror directly subclasses OSError. No prior socket spec checks herror.__bases__[0].__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__mro__.__len__() == 5 — herror MRO: (herror, OSError, Exception, BaseException, object) = 5 elements. No prior socket spec checks herror.__mro__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket class __name__ and __module__
#
# Wave 245 theme: socket.socket class identity.
#
# socket.socket is the pure-Python wrapper class; its __name__ is 'socket'
# and its __module__ is 'socket'. No prior socket spec checks socket.socket.__name__
# or socket.socket.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra78.socket_class_name_module:
  description: "socket.socket/__name__.__eq__('socket')==True / socket.socket/__module__.__eq__('socket')==True — socket.socket is the Python-level wrapper class; __name__=='socket' and __module__=='socket'; no prior socket spec checks socket.socket.__name__ or __module__; first __name__/__module__ anchor for socket.socket"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketextra78

  columns: [id, function, args, expected]
  rows:
    - [socket_class_name_socket,   socket.__name__.__eq__,   ["socket"], true]
    - [socket_class_module_socket, socket.__module__.__eq__,  ["socket"], true]

# ---------------------------------------------------------------------------
# socket.error and socket.timeout class name identity
#
# Wave 245 theme: socket exception alias class names.
#
# socket.error is an alias for the builtin OSError; its __name__ is 'OSError'
# and __module__ is 'builtins'. socket.timeout is an alias for TimeoutError
# since Python 3.11+; its __name__ is 'TimeoutError'. No prior socket spec
# checks socket.error.__name__, socket.error.__module__, or socket.timeout.__name__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra78.error_timeout_class_names:
  description: "socket.error/__name__.__eq__('OSError')==True / socket.error/__module__.__eq__('builtins')==True / socket.timeout/__name__.__eq__('TimeoutError')==True — socket.error is an alias for OSError; socket.timeout is an alias for TimeoutError; no prior socket spec checks error/__name__/__module__ or timeout/__name__; first alias class name anchor for socket.error and socket.timeout"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketextra78

  columns: [id, function, args, expected]
  rows:
    - [error_name_OSError,         error.__name__.__eq__,    ["OSError"],      true]
    - [error_module_builtins,      error.__module__.__eq__,  ["builtins"],     true]
    - [timeout_name_TimeoutError,  timeout.__name__.__eq__,  ["TimeoutError"], true]

# ---------------------------------------------------------------------------
# socket.gaierror class __name__, __module__, and __bases__[0].__name__
#
# Wave 245 theme: gaierror exception class hierarchy.
#
# socket.gaierror is a Python class defined in the socket module that directly
# subclasses OSError. Its __name__ is 'gaierror', __module__ is 'socket', and
# __bases__[0].__name__ is 'OSError'. No prior socket spec checks gaierror.__name__,
# gaierror.__module__, or gaierror.__bases__[0].__name__.
# socket_extra77 covers gaierror.__dict__ key membership but not these attributes.
# socket_extra29 covers gaierror.__mro__.__len__()==5 but not __bases__[0].__name__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra78.gaierror_class_attrs:
  description: "socket.gaierror/__name__.__eq__('gaierror')==True / gaierror/__module__.__eq__('socket')==True / gaierror/__bases__[0]/__name__.__eq__('OSError')==True — gaierror is defined in the socket module and directly subclasses OSError; socket_extra77 covers __dict__ membership; socket_extra29 covers __mro__.__len__()==5; no prior socket spec checks gaierror.__name__/__module__/__bases__[0].__name__; first class hierarchy anchor for gaierror"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketextra78

  columns: [id, function, args, expected]
  rows:
    - [gaierror_name_gaierror,          gaierror.__name__.__eq__,                    ["gaierror"], true]
    - [gaierror_module_socket,          gaierror.__module__.__eq__,                  ["socket"],   true]
    - [gaierror_bases0_name_OSError,    "gaierror.__bases__[0].__name__.__eq__",      ["OSError"],  true]

# ---------------------------------------------------------------------------
# socket.herror class __name__, __module__, __bases__[0].__name__, and __mro__.__len__
#
# Wave 245 theme: herror exception class hierarchy.
#
# socket.herror is a Python class defined in the socket module that directly
# subclasses OSError. Its __name__ is 'herror', __module__ is 'socket', and
# __bases__[0].__name__ is 'OSError'. herror.__mro__.__len__() == 5
# (herror, OSError, Exception, BaseException, object).
# socket_extra77 covers herror.__dict__ key membership but not these attributes.
# No prior socket spec checks herror.__name__, herror.__module__,
# herror.__bases__[0].__name__, or herror.__mro__.__len__().
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra78.herror_class_attrs:
  description: "socket.herror/__name__.__eq__('herror')==True / herror/__module__.__eq__('socket')==True / herror/__bases__[0]/__name__.__eq__('OSError')==True / herror/__mro__/__len__()==5 — herror is defined in socket module and subclasses OSError; MRO is (herror, OSError, Exception, BaseException, object); socket_extra77 covers herror.__dict__; no prior socket spec checks herror.__name__/__module__/__bases__[0]/__mro__.__len__(); first class hierarchy anchor for herror"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketextra78

  columns: [id, function, args, expected]
  rows:
    - [herror_name_herror,           herror.__name__.__eq__,                   ["herror"],  true]
    - [herror_module_socket,         herror.__module__.__eq__,                 ["socket"],  true]
    - [herror_bases0_name_OSError,   "herror.__bases__[0].__name__.__eq__",     ["OSError"], true]
    - [herror_mro_len_5,             herror.__mro__.__len__,                   [],          5]

# ---------------------------------------------------------------------------
# socket.socket.__name__.__eq__('socket') — standalone
#
# socket.socket's class __name__ is 'socket'. No prior socket spec checks
# socket.socket.__name__. First __name__ standalone for socket.socket.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra78.socket_class_name_socket:
  description: "socket.socket.__name__.__eq__('socket') == True — the socket class name is 'socket'; no prior socket spec checks socket.socket.__name__; first __name__ standalone for socket.socket"
  category: class_attrs
  kind: python_call_eq
  function: socket.__name__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.error.__name__.__eq__('OSError') — standalone
#
# socket.error is an alias for the builtin OSError; its __name__ is 'OSError'.
# No prior socket spec checks socket.error.__name__. First __name__ standalone
# for socket.error. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra78.error_name_OSError:
  description: "socket.error.__name__.__eq__('OSError') == True — socket.error is an alias for the builtin OSError; no prior socket spec checks socket.error.__name__; first __name__ standalone for socket.error"
  category: class_attrs
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# socket.gaierror.__name__.__eq__('gaierror') — standalone
#
# gaierror's own class __name__ is 'gaierror'. No prior socket spec checks
# gaierror.__name__. First __name__ standalone for gaierror.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra78.gaierror_name_gaierror:
  description: "socket.gaierror.__name__.__eq__('gaierror') == True — gaierror's class __name__ is 'gaierror'; no prior socket spec checks gaierror.__name__; first __name__ standalone for gaierror"
  category: class_attrs
  kind: python_call_eq
  function: gaierror.__name__.__eq__
  args: ["gaierror"]
  expected: true

# ---------------------------------------------------------------------------
# socket.herror.__bases__[0].__name__.__eq__('OSError') — standalone
#
# herror directly subclasses OSError. No prior socket spec checks
# herror.__bases__[0].__name__. First __bases__[0].__name__ standalone for herror.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra78.herror_bases0_name_OSError:
  description: "socket.herror.__bases__[0].__name__.__eq__('OSError') == True — herror directly subclasses OSError; no prior socket spec checks herror.__bases__[0].__name__; first __bases__[0].__name__ standalone for herror"
  category: class_attrs
  kind: python_call_eq
  function: "herror.__bases__[0].__name__.__eq__"
  args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# socket.herror.__mro__.__len__() == 5 — standalone
#
# herror's MRO is (herror, OSError, Exception, BaseException, object) = 5 entries.
# No prior socket spec checks herror.__mro__.__len__() (socket_extra29 covers
# gaierror.__mro__.__len__()==5 but NOT herror). First __mro__.__len__() standalone
# for herror. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra78.herror_mro_len_5:
  description: "socket.herror.__mro__.__len__() == 5 — herror MRO is (herror, OSError, Exception, BaseException, object); socket_extra29 covers gaierror.__mro__.__len__()==5 but NOT herror; no prior socket spec checks herror.__mro__.__len__(); first __mro__.__len__() standalone for herror"
  category: class_attrs
  kind: python_call_eq
  function: herror.__mro__.__len__
  args: []
  expected: 5
