spec: asyncio_extra1951
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/asyncio.html"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
  notes:
    - "Wave 577 (_extra1951): __contains__, __iter__, __next__, __aiter__, __anext__ dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "asyncio.Task and asyncio.Future define __iter__ for the yield-from protocol (PEP 492 / PEP 3156)."
    - "asyncio.Queue defines __aiter__ and __anext__ for async-for iteration."
    - "No asyncio class defines __contains__, __next__, or (except Queue) __aiter__/__anext__ in its own __dict__."
  created_at: "2026-04-12"
error_model: python_exceptions

table asyncio_extra1951.contains_protocol:
  description: "asyncio types __contains__ dict-presence checks — none define __contains__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1951

  columns: [id, function, args, expected]
  rows:
    - ["as1951001", "asyncio.Task.__dict__.__contains__",             ["__contains__"], false]
    - ["as1951002", "asyncio.Future.__dict__.__contains__",           ["__contains__"], false]
    - ["as1951003", "asyncio.Event.__dict__.__contains__",            ["__contains__"], false]
    - ["as1951004", "asyncio.Lock.__dict__.__contains__",             ["__contains__"], false]
    - ["as1951005", "asyncio.Queue.__dict__.__contains__",            ["__contains__"], false]
    - ["as1951006", "asyncio.Semaphore.__dict__.__contains__",        ["__contains__"], false]
    - ["as1951007", "asyncio.Condition.__dict__.__contains__",        ["__contains__"], false]
    - ["as1951008", "asyncio.BoundedSemaphore.__dict__.__contains__", ["__contains__"], false]

table asyncio_extra1951.iter_protocol:
