    - ["as1951010", "asyncio.Future.__dict__.__contains__",           ["__iter__"], true]
    - ["as1951011", "asyncio.Event.__dict__.__contains__",            ["__iter__"], false]
    - ["as1951012", "asyncio.Lock.__dict__.__contains__",             ["__iter__"], false]
    - ["as1951013", "asyncio.Queue.__dict__.__contains__",            ["__iter__"], false]
    - ["as1951014", "asyncio.Semaphore.__dict__.__contains__",        ["__iter__"], false]
    - ["as1951015", "asyncio.Condition.__dict__.__contains__",        ["__iter__"], false]
    - ["as1951016", "asyncio.BoundedSemaphore.__dict__.__contains__", ["__iter__"], false]

