spec: re_extra164
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.fullmatch, re.findall, re.finditer function code attributes (co_argcount, co_name), and re.purge and re.escape code attributes."
    - "re.fullmatch.__code__.co_argcount == 3 (takes pattern, string, flags=0)."
    - "re.fullmatch.__code__.co_name == 'fullmatch' (len=9)."
    - "re.findall.__code__.co_argcount == 3 (takes pattern, string, flags=0)."
    - "re.findall.__code__.co_name == 'findall' (len=7)."
    - "re.finditer.__code__.co_argcount == 3 (takes pattern, string, flags=0)."
    - "re.finditer.__code__.co_name == 'finditer' (len=8)."
    - "re.purge.__code__.co_argcount == 0 (takes no arguments)."
    - "re.purge.__code__.co_name == 'purge' (len=5)."
    - "re.escape.__code__.co_argcount == 1 (takes one argument: pattern)."
    - "re.escape.__code__.co_name == 'escape' (len=6)."
    - "fullmatch, findall, finditer all have co_argcount == 3: pattern, string, flags."
    - "purge is the only zero-argument function (co_argcount == 0) in this spec."
    - "escape has co_argcount == 1 — takes only the pattern string to escape."
    - "co_name length ranking: purge=5, escape=6, findall=7, finditer=8, fullmatch=9."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re function __code__.co_argcount and __code__.co_name (group 1)
# fullmatch, findall, finditer — all three have co_argcount == 3.
# co_name lengths: findall=7, finditer=8, fullmatch=9.
# ---------------------------------------------------------------------------

table re_extra164.func_code_attrs_group1:
  description: "re function code attributes: fullmatch=findall=finditer all have co_argcount=3; co_name lengths: findall=7, finditer=8, fullmatch=9; all three take pattern, string, flags=0"
  kind: python_call_eq
  category: identity
  id_prefix: req164

  columns: [id, function, args, expected, description]
  rows:
    - [fullmatch_argc,  re.fullmatch.__code__.co_argcount.__eq__,  [3],            true, "re.fullmatch.__code__.co_argcount == 3 (fullmatch() takes three arguments: pattern, string, flags=0; co_argcount counts all positional arguments including those with defaults, so the signature fullmatch(pattern, string, flags=0) yields co_argcount=3; re.fullmatch() matches the pattern against the entire string — unlike re.match() which matches only at the start and re.search() which matches anywhere; fullmatch is equivalent to re.match(pattern + '$', string) but cleaner; co_argcount=3 is shared by findall and finditer — all three scanning functions take the same three arguments)"]
    - [findall_argc,    re.findall.__code__.co_argcount.__eq__,    [3],            true, "re.findall.__code__.co_argcount == 3 (findall() takes three arguments: pattern, string, flags=0; co_argcount=3 is shared with fullmatch and finditer — all three functions follow the same (pattern, string, flags=0) signature; re.findall() returns all non-overlapping matches as a list of strings (or list of tuples if there are groups); findall() scans the entire string and returns all matches rather than stopping at the first; the 3-argument signature contrasts with re.purge() (co_argcount=0) and re.escape() (co_argcount=1))"]
    - [finditer_argc,   re.finditer.__code__.co_argcount.__eq__,   [3],            true, "re.finditer.__code__.co_argcount == 3 (finditer() takes three arguments: pattern, string, flags=0; co_argcount=3 is the same as fullmatch and findall; re.finditer() returns an iterator yielding Match objects for all non-overlapping matches; unlike findall() which returns strings, finditer() returns Match objects with span(), group(), groupdict() and other methods; finditer() is memory-efficient for large strings because it yields one match at a time rather than building the full list; all three scanning functions have identical co_argcount=3)"]
    - [fullmatch_cname, re.fullmatch.__code__.co_name.__eq__,      ["fullmatch"],  true, "re.fullmatch.__code__.co_name == 'fullmatch' (the co_name of the fullmatch function's code object is 'fullmatch' — the function's own name as written in the source; co_name is set at compile time from the 'def fullmatch(...)' definition; 'fullmatch' has 9 characters — the longest co_name in this spec; fullmatch (9) > finditer (8) > findall (7) > escape (6) > purge (5); the name 'fullmatch' reflects its purpose: a match that must cover the full string; compare with re.match.__qualname__ == 'match' (5 chars) from re_extra163 — module-level qualnames are much shorter than their co_name because match/search etc. had shorter names)"]

# ---------------------------------------------------------------------------
# re function __code__.co_argcount and __code__.co_name (group 2)
# purge, escape — purge has co_argcount=0, escape has co_argcount=1.
# co_name lengths: purge=5, escape=6.
# These differ from fullmatch/findall/finditer by argument count.
# ---------------------------------------------------------------------------

table re_extra164.func_code_attrs_group2:
  description: "re function code attributes: purge has co_argcount=0 (no args), escape has co_argcount=1 (one arg); co_name lengths: purge=5, escape=6; both differ from fullmatch/findall/finditer (co_argcount=3)"
  kind: python_call_eq
  category: identity
  id_prefix: req164

  columns: [id, function, args, expected, description]
  rows:
    - [purge_argc,   re.purge.__code__.co_argcount.__eq__,   [0],         true, "re.purge.__code__.co_argcount == 0 (purge() takes no arguments at all; co_argcount=0 is unique in this spec — purge is the only function with zero positional parameters; re.purge() clears the compiled regex pattern cache; the cache stores compiled Pattern objects to avoid recompiling frequently used patterns; purge() is rarely called explicitly in production code but is useful in testing and memory-constrained environments; co_argcount=0 contrasts sharply with fullmatch/findall/finditer (all co_argcount=3) and escape (co_argcount=1))"]
    - [escape_argc,  re.escape.__code__.co_argcount.__eq__,  [1],         true, "re.escape.__code__.co_argcount == 1 (escape() takes exactly one argument: pattern; co_argcount=1 places escape between purge (0) and the scanning functions (3) in argument count; re.escape() returns a string with all non-alphanumeric characters backslash-escaped, making it safe to use as a literal pattern in a regex; escape(pattern) is used when you want to match a literal string but construct the regex programmatically; escape takes one string argument and returns one string — no flags or string-to-search parameter needed)"]
    - [purge_cname,  re.purge.__code__.co_name.__eq__,       ["purge"],   true, "re.purge.__code__.co_name == 'purge' (the co_name of purge's code object is 'purge' — the function's name as defined in source; 'purge' has 5 characters — the shortest co_name in this spec; co_name length ranking: purge=5, escape=6, findall=7, finditer=8, fullmatch=9; 'purge' (5 chars) exactly matches re.match.__qualname__ length (5 chars, from re_extra163) and re.split.__qualname__ length (5 chars) — a coincidental equality between co_name length and qualname lengths; purge() clears the compiled pattern cache and its zero-argument signature means it is the simplest function in the re module)"]
    - [escape_cname, re.escape.__code__.co_name.__eq__,      ["escape"],  true, "re.escape.__code__.co_name == 'escape' (the co_name of escape's code object is 'escape' — the function's defined name; 'escape' has 6 characters; co_name length 6 for escape matches re.search.__qualname__.__len__() == 6 from re_extra163 — a coincidental tie between escape's co_name length and search's qualname length; 'escape' (6) sits between purge (5) and findall (7) in the co_name length ranking; re.escape() is useful when constructing patterns from user input to prevent regex injection vulnerabilities)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra164.fullmatch_findall_finditer_all_argc_3:
  description: "re.fullmatch.__code__.co_argcount == 3 — fullmatch, findall, and finditer all share co_argcount=3 because all three take the same (pattern, string, flags=0) argument signature; co_argcount counts all positional parameters including those with defaults; the three-way tie at co_argcount=3 reflects the design uniformity of the re module's main scanning functions; contrast with purge (co_argcount=0) and escape (co_argcount=1) which have different roles and fewer parameters; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.fullmatch.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant re_extra164.purge_is_zero_arg_unique:
  description: "re.purge.__code__.co_argcount == 0 — purge() is the only function in this spec with zero positional arguments; co_argcount=0 makes purge unique: it is a pure side-effect function that clears the compiled pattern cache with no input needed; the contrast: purge (0), escape (1), fullmatch=findall=finditer (3); re.purge() is the re module maintenance utility; its co_name 'purge' (5 chars) is the shortest co_name in this spec; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.purge.__code__.co_argcount.__eq__
  args: [0]
  expected: true

invariant re_extra164.fullmatch_co_name_len_9:
  description: "re.fullmatch.__code__.co_name.__len__() == 9 — 'fullmatch' has 9 characters and is the longest co_name in this spec; co_name length ranking from shortest: purge=5, escape=6, findall=7, finditer=8, fullmatch=9; 'fullmatch' (9) is the longest because it combines 'full' (4) + 'match' (5) = 9; this is notably longer than re.match.__qualname__ == 'match' (5 chars, from re_extra163) — fullmatch co_name (9) is 4 characters longer than match qualname (5); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.fullmatch.__code__.co_name.__len__
  args: []
  expected: 9

invariant re_extra164.finditer_co_name_len_8:
  description: "re.finditer.__code__.co_name.__len__() == 8 — 'finditer' has 8 characters; co_name length 8 places finditer between findall (7) and fullmatch (9) in the ranking; 'finditer' = 'find' (4) + 'iter' (4) = 8; finditer returns an iterator (hence the 'iter' suffix) while findall returns a list (no suffix); co_name length 8 for finditer is 1 less than fullmatch (9) and 1 more than findall (7); the co_name length ordering (findall=7, finditer=8, fullmatch=9) mirrors the alphabetical ordering of these three function names; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.finditer.__code__.co_name.__len__
  args: []
  expected: 8
