spec: theseus_wsgiref_cr
version: ">=3.0"
backend: python_cleanroom(theseus_wsgiref_cr)
blocks: wsgiref

docs: https://docs.python.org/3/library/wsgiref.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/wsgiref.html"
  not_derived_from:
    - "CPython source: Lib/wsgiref/__init__.py"
  notes:
    - "Clean-room wsgiref module. Do NOT import wsgiref."

error_model: python_exceptions

invariant theseus_wsgiref_cr.wsgiref2_headers:
  description: "Headers class can store and retrieve headers"
  category: behavior
  kind: python_call_eq
  function: wsgiref2_headers
  args: []
  expected: true

invariant theseus_wsgiref_cr.wsgiref2_environ:
  description: "make_environ() returns a valid WSGI environ dict"
  category: behavior
  kind: python_call_eq
  function: wsgiref2_environ
  args: []
  expected: true

invariant theseus_wsgiref_cr.wsgiref2_validate:
  description: "is_hop_by_hop() identifies hop-by-hop headers"
  category: behavior
  kind: python_call_eq
  function: wsgiref2_validate
  args: []
  expected: true
