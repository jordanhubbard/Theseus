table itertools_extra1591.iterator_protocol_present:
  description: "Core itertools classes all define __iter__ and __next__ in their own __dict__ (iterator protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1591ip

  columns: [id, function, args, expected]
  rows:
    - [it1591ip001, itertools.chain.__dict__.__contains__,        ["__iter__"],  true]
    - [it1591ip002, itertools.chain.__dict__.__contains__,        ["__next__"],  true]
    - [it1591ip003, itertools.islice.__dict__.__contains__,       ["__iter__"],  true]
    - [it1591ip004, itertools.islice.__dict__.__contains__,       ["__next__"],  true]
