spec: itertools_extra1591
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — descriptor protocol absence checks (__get__, __set__, __delete__ not in __dict__) and iterator protocol presence checks (__iter__, __next__ in __dict__) for all itertools C extension types"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Behavioral invariants: all itertools classes are C extension iterator types. None implement the descriptor protocol (__get__/__set__/__delete__ absent from their own __dict__). All implement the iterator protocol (__iter__/__next__ present in their own __dict__)."]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table itertools_extra1591.no_descriptor_protocol:
  description: "Core itertools classes define no descriptor protocol methods (__get__, __set__, __delete__ absent from __dict__)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1591nd

  columns: [id, function, args, expected]
  rows:
    - [it1591nd001, itertools.chain.__dict__.__contains__,        ["__get__"],    false]
    - [it1591nd002, itertools.chain.__dict__.__contains__,        ["__set__"],    false]
