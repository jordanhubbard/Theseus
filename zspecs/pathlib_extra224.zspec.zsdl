spec: pathlib_extra224
version: ">=3.4"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
  notes:
    - "This spec covers: class __module__ and __name__ attributes for Path, PurePath, PosixPath, PurePosixPath; PurePosixPath component attribute values for representative paths; relative path behavior."
    - "pathlib.Path.__module__ == 'pathlib' — all four pathlib classes are in the pathlib module."
    - "pathlib.PurePath.__bases__[0].__name__ == 'object' — PurePath is a direct subclass of object."
    - "pathlib.PosixPath.__bases__[0].__name__ == 'Path' — PosixPath directly subclasses Path."
    - "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' — PurePosixPath directly subclasses PurePath."
    - "PurePosixPath('/usr/local/bin').suffix == '' — directory component with no extension has empty suffix."
    - "PurePosixPath('/usr/local/bin').name == 'bin' — last path component."
    - "PurePosixPath('/home/user/doc.txt').suffix == '.txt' — file extension including dot."
    - "PurePosixPath('/home/user/doc.txt').stem == 'doc' — filename without extension."
    - "PurePosixPath('relative/path/file.py').is_absolute() == False — relative path is not absolute."
    - "All expected values use PurePosixPath — a platform-independent pure path requiring no filesystem access."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module attribute: __module__ == 'pathlib' for all four core classes
# Path, PurePath, PosixPath, PurePosixPath are all defined in the pathlib module.
# ---------------------------------------------------------------------------

table pathlib_extra224.class_modules:
  description: "Path, PurePath, PosixPath, PurePosixPath all report __module__ == 'pathlib'"
  kind: python_call_eq
  category: class_metadata
  id_prefix: plmodule224

  columns: [id, function, args, expected]
  rows:
    - [path_module,        Path.__module__.__eq__,          ["pathlib"], true]
    - [purepath_module,    PurePath.__module__.__eq__,       ["pathlib"], true]
    - [posixpath_module,   PosixPath.__module__.__eq__,      ["pathlib"], true]
    - [purepposix_module,  PurePosixPath.__module__.__eq__,  ["pathlib"], true]

# ---------------------------------------------------------------------------
# Class __name__ values
# The four core classes have the expected names.
# ---------------------------------------------------------------------------

table pathlib_extra224.class_names:
  description: "Class __name__ values for Path, PurePath, PosixPath, PurePosixPath"
  kind: python_call_eq
  category: class_metadata
  id_prefix: plcnames224

  columns: [id, function, args, expected]
  rows:
    - [path_name,       Path.__name__.__eq__,         ["Path"],          true]
    - [purepath_name,   PurePath.__name__.__eq__,      ["PurePath"],      true]
    - [posixpath_name,  PosixPath.__name__.__eq__,     ["PosixPath"],     true]
    - [purepposix_name, PurePosixPath.__name__.__eq__, ["PurePosixPath"], true]

# ---------------------------------------------------------------------------
# PurePosixPath component attributes — directory path with no extension
# PurePosixPath('/usr/local/bin'): name='bin', stem='bin', suffix='', root='/'
# ---------------------------------------------------------------------------

table pathlib_extra224.purepath_dir_components:
  description: "PurePosixPath('/usr/local/bin') component attribute values"
  kind: python_call_eq
  category: components
  id_prefix: pldir224
  function: PurePosixPath

  columns: [id, args, method, expected]
  rows:
    - [dir_name,   ["/usr/local/bin"], name,        "bin"]
    - [dir_stem,   ["/usr/local/bin"], stem,        "bin"]
    - [dir_suffix, ["/usr/local/bin"], suffix,      ""   ]
    - [dir_root,   ["/usr/local/bin"], root,        "/"  ]
    - [dir_anchor, ["/usr/local/bin"], anchor,      "/"  ]

# ---------------------------------------------------------------------------
# PurePosixPath component attributes — file path with extension
# PurePosixPath('/home/user/doc.txt'): suffix='.txt', stem='doc', name='doc.txt'
# ---------------------------------------------------------------------------

table pathlib_extra224.purepath_file_components:
  description: "PurePosixPath('/home/user/doc.txt') component attribute values"
  kind: python_call_eq
  category: components
  id_prefix: plfile224
  function: PurePosixPath

  columns: [id, args, method, expected]
  rows:
    - [file_name,   ["/home/user/doc.txt"], name,   "doc.txt"]
    - [file_stem,   ["/home/user/doc.txt"], stem,   "doc"    ]
    - [file_suffix, ["/home/user/doc.txt"], suffix, ".txt"   ]

# ---------------------------------------------------------------------------
# PurePosixPath predicates — is_absolute on relative vs. absolute paths
# ---------------------------------------------------------------------------

invariant pathlib_extra224.purepath.relative_is_not_absolute:
  description: "PurePosixPath('relative/path/file.py').is_absolute() == False — a path without leading slash is relative"
  category: predicates
  kind: python_call_eq
  function: PurePosixPath
  args: ["relative/path/file.py"]
  method: is_absolute
  expected: false

invariant pathlib_extra224.purepath.absolute_is_absolute:
  description: "PurePosixPath('/usr/local/bin').is_absolute() == True — a path with leading slash is absolute"
  category: predicates
  kind: python_call_eq
  function: PurePosixPath
  args: ["/usr/local/bin"]
  method: is_absolute
  expected: true

invariant pathlib_extra224.purepath.drive_is_empty_on_posix:
  description: "PurePosixPath('/usr/local/bin').drive == '' — POSIX paths have no drive component"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["/usr/local/bin"]
  method: drive
  expected: ""

invariant pathlib_extra224.PurePath.class_name:
  description: "pathlib.PurePath.__name__ == 'PurePath'"
  category: class_metadata
  kind: python_call_eq
  function: PurePath.__name__.__eq__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra224.PurePosixPath.module:
  description: "pathlib.PurePosixPath.__module__ == 'pathlib'"
  category: class_metadata
  kind: python_call_eq
  function: PurePosixPath.__module__.__eq__
  args: ["pathlib"]
  expected: true
