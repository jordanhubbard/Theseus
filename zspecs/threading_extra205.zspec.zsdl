spec: threading_extra205
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "threading_extra.zspec.zsdl — covers class __module__ checks for BoundedSemaphore/Condition/Semaphore/Event/RLock, local.__name__/__module__, current_thread class name, get_ident return type, TIMEOUT_MAX type, stack_size return type"
    - "threading_extra172.zspec.zsdl — earlier extra spec for threading"
  notes:
    - "threading.__all__ exists and is a list; confirmed with Python 3.14.3."
    - "threading.__all__.__class__.__name__ == 'list' — the __all__ export list is a plain Python list."
    - "threading.__all__.__len__() == 28 — there are exactly 28 public exports in Python 3.14.3."
    - "threading.__all__.__contains__('Thread') == True — Thread is a public export."
    - "threading.__all__.__contains__('Lock') == True — Lock is a public export."
    - "threading.__all__.__contains__('RLock') == True — RLock is a public export."
    - "threading.__all__.__contains__('Event') == True — Event is a public export."
    - "threading.__all__.__contains__('Condition') == True — Condition is a public export."
    - "threading.__all__.__contains__('Semaphore') == True — Semaphore is a public export."
    - "threading.__all__.__contains__('current_thread') == True — current_thread is a public export."
    - "threading.__all__.__contains__('main_thread') == True — main_thread is a public export."
    - "threading.__all__.__contains__('missing_xyz') == False — a nonexistent name is not in __all__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.__all__ class identity and length
#
# threading.__all__.__class__.__name__ == 'list'
# threading.__all__.__len__() == 28
#
# threading has a defined __all__ of 28 names in Python 3.14.3, covering
# synchronization primitives, thread functions, and utility constants.
# ---------------------------------------------------------------------------

table threading_extra205.all_identity:
  description: "threading.__all__ is a list with exactly 28 entries; class name and length checks; new to extra205"
  kind: python_call_eq
  category: all_list
  id_prefix: threadall205

  columns: [id, function, args, expected, description]
  rows:
    - [all_class_name_eq,
       "__all__.__class__.__name__.__eq__",
       ["list"],
       true,
       "threading.__all__.__class__.__name__.__eq__('list') == True — __all__ is a plain Python list; verified with Python 3.14.3; new to extra205"]
    - [all_len_28,
       "__all__.__len__",
       [],
       28,
       "threading.__all__.__len__() == 28 — there are exactly 28 public exports listed in threading.__all__ in Python 3.14.3; verified with Python 3.14.3; new to extra205"]
    - [all_contains_thread,
       "__all__.__contains__",
       ["Thread"],
       true,
       "threading.__all__.__contains__('Thread') == True — 'Thread' is listed as a public export in threading.__all__; verified with Python 3.14.3; new to extra205"]
    - [all_contains_lock,
       "__all__.__contains__",
       ["Lock"],
       true,
       "threading.__all__.__contains__('Lock') == True — 'Lock' is listed as a public export in threading.__all__; verified with Python 3.14.3; new to extra205"]

# ---------------------------------------------------------------------------
# Table 2: threading.__all__ membership — synchronization primitives
#
# Checks that RLock, Event, Condition, Semaphore are in __all__.
# These are the core synchronization primitives exposed by the threading module.
# ---------------------------------------------------------------------------

table threading_extra205.all_sync_primitives:
  description: "threading.__all__ contains RLock, Event, Condition, Semaphore; new to extra205"
  kind: python_call_eq
  category: all_list
  id_prefix: threadall205

  columns: [id, function, args, expected, description]
  rows:
    - [all_contains_rlock,
       "__all__.__contains__",
       ["RLock"],
       true,
       "threading.__all__.__contains__('RLock') == True — 'RLock' is a public export; verified with Python 3.14.3; new to extra205"]
    - [all_contains_event,
       "__all__.__contains__",
       ["Event"],
       true,
       "threading.__all__.__contains__('Event') == True — 'Event' is a public export; verified with Python 3.14.3; new to extra205"]
    - [all_contains_condition,
       "__all__.__contains__",
       ["Condition"],
       true,
       "threading.__all__.__contains__('Condition') == True — 'Condition' is a public export; verified with Python 3.14.3; new to extra205"]
    - [all_contains_semaphore,
       "__all__.__contains__",
       ["Semaphore"],
       true,
       "threading.__all__.__contains__('Semaphore') == True — 'Semaphore' is a public export; verified with Python 3.14.3; new to extra205"]

# ---------------------------------------------------------------------------
# Table 3: threading.__all__ — thread utility functions and negation check
#
# Checks that current_thread and main_thread are in __all__,
# and that 'missing_xyz' is not in __all__.
# ---------------------------------------------------------------------------

table threading_extra205.all_thread_functions:
  description: "threading.__all__ contains current_thread and main_thread; missing_xyz is absent; new to extra205"
  kind: python_call_eq
  category: all_list
  id_prefix: threadall205

  columns: [id, function, args, expected, description]
  rows:
    - [all_contains_current_thread,
       "__all__.__contains__",
       ["current_thread"],
       true,
       "threading.__all__.__contains__('current_thread') == True — 'current_thread' is a public export; verified with Python 3.14.3; new to extra205"]
    - [all_contains_main_thread,
       "__all__.__contains__",
       ["main_thread"],
       true,
       "threading.__all__.__contains__('main_thread') == True — 'main_thread' is a public export; verified with Python 3.14.3; new to extra205"]
    - [all_contains_barrier,
       "__all__.__contains__",
       ["Barrier"],
       true,
       "threading.__all__.__contains__('Barrier') == True — 'Barrier' is a public export; verified with Python 3.14.3; new to extra205"]
    - [all_not_contains_missing,
       "__all__.__contains__",
       ["missing_xyz"],
       false,
       "threading.__all__.__contains__('missing_xyz') == False — 'missing_xyz' does not exist in threading and is absent from __all__; verified with Python 3.14.3; new to extra205"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra205
# ---------------------------------------------------------------------------

invariant threading_extra205.all_is_list:
  description: "threading.__all__.__class__.__name__ == 'list' — the module's public export list is a plain Python list; verified with Python 3.14.3; new to extra205"
  category: all_list
  kind: python_call_eq
  function: "__all__.__class__.__name__.__eq__"
  args: ["list"]
  expected: true

invariant threading_extra205.all_len_28:
  description: "threading.__all__.__len__() == 28 — exactly 28 names are listed in threading.__all__ in Python 3.14.3; verified with Python 3.14.3; new to extra205"
  category: all_list
  kind: python_call_eq
  function: "__all__.__len__"
  args: []
  expected: 28

invariant threading_extra205.all_has_thread:
  description: "threading.__all__.__contains__('Thread') == True — 'Thread' is a public threading export; verified with Python 3.14.3; new to extra205"
  category: all_list
  kind: python_call_eq
  function: "__all__.__contains__"
  args: ["Thread"]
  expected: true

invariant threading_extra205.all_has_lock:
  description: "threading.__all__.__contains__('Lock') == True — 'Lock' is a public threading export; verified with Python 3.14.3; new to extra205"
  category: all_list
  kind: python_call_eq
  function: "__all__.__contains__"
  args: ["Lock"]
  expected: true

invariant threading_extra205.all_has_rlock:
  description: "threading.__all__.__contains__('RLock') == True — 'RLock' is a public threading export; verified with Python 3.14.3; new to extra205"
  category: all_list
  kind: python_call_eq
  function: "__all__.__contains__"
  args: ["RLock"]
  expected: true

invariant threading_extra205.all_has_current_thread:
  description: "threading.__all__.__contains__('current_thread') == True — 'current_thread' is a public threading export; verified with Python 3.14.3; new to extra205"
  category: all_list
  kind: python_call_eq
  function: "__all__.__contains__"
  args: ["current_thread"]
  expected: true

invariant threading_extra205.all_has_main_thread:
  description: "threading.__all__.__contains__('main_thread') == True — 'main_thread' is a public threading export; verified with Python 3.14.3; new to extra205"
  category: all_list
  kind: python_call_eq
  function: "__all__.__contains__"
  args: ["main_thread"]
  expected: true

invariant threading_extra205.all_missing_xyz_absent:
  description: "threading.__all__.__contains__('missing_xyz') == False — 'missing_xyz' does not exist in threading and is not in __all__; verified with Python 3.14.3; new to extra205"
  category: all_list
  kind: python_call_eq
  function: "__all__.__contains__"
  args: ["missing_xyz"]
  expected: false
