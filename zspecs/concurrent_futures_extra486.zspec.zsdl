spec: concurrent_futures_extra486
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures executor and future method identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers method name identity for Future, ThreadPoolExecutor, ProcessPoolExecutor, and Executor"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra486.future_method_identity:
  description: "concurrent.futures.Future method name identity"
  kind: python_call_eq
  category: identity
  id_prefix: FUT

  columns: [id, function, args, expected]
  rows:
    - [FUT001, concurrent.futures.Future.set_result.__name__.__eq__, ["set_result"], true]
    - [FUT002, concurrent.futures.Future.set_exception.__name__.__eq__, ["set_exception"], true]
    - [FUT003, concurrent.futures.Future.__repr__.__name__.__eq__, ["__repr__"], true]

table concurrent_futures_extra486.threadpool_method_identity:
  description: "concurrent.futures.ThreadPoolExecutor method name identity"
  kind: python_call_eq
  category: identity
  id_prefix: TPE

  columns: [id, function, args, expected]
  rows:
    - [TPE001, concurrent.futures.ThreadPoolExecutor.submit.__name__.__eq__, ["submit"], true]
    - [TPE002, concurrent.futures.ThreadPoolExecutor.map.__name__.__eq__, ["map"], true]
    - [TPE003, concurrent.futures.ThreadPoolExecutor.shutdown.__name__.__eq__, ["shutdown"], true]

