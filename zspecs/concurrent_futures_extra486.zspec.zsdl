    - [PPE002, concurrent.futures.ProcessPoolExecutor.map.__name__.__eq__, ["map"], true]
    - [PPE003, concurrent.futures.ProcessPoolExecutor.shutdown.__name__.__eq__, ["shutdown"], true]

table concurrent_futures_extra486.executor_method_identity:
