invariant abc_extra135.abstractmethod_co_cellvars_len_0:
  description: "abc.abstractmethod.__code__.co_cellvars.__len__() == 0 — abstractmethod.__code__.co_cellvars is () (empty tuple, len=0); abstractmethod does not create any closure cells because it does not contain any nested functions that reference its local variables; co_freevars is also () (len=0); abstractmethod is not itself a closure over any enclosing scope; NEW in extra135: first standalone abstractmethod co_cellvars length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__code__.co_cellvars.__len__
  args: []
  expected: 0

invariant abc_extra135.abstractmethod_co_consts_len_2:
  description: "abc.abstractmethod.__code__.co_consts.__len__() == 2 — abstractmethod.__code__.co_consts is a 2-tuple: index 0 is the docstring (a str describing the decorator), index 1 is True (the boolean value assigned to funcobj.__isabstractmethod__); co_consts does NOT contain None (unusual — abstractmethod's compiled body never pushes a None LOAD_CONST); co_consts.__class__.__name__=='tuple'; NEW in extra135: first standalone abstractmethod co_consts length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__code__.co_consts.__len__
  args: []
  expected: 2

invariant abc_extra135.abcmeta_instancecheck_qualname_len_25:
  description: "abc.ABCMeta.__instancecheck__.__qualname__.__len__() == 25 — ABCMeta.__instancecheck__.__qualname__ is 'ABCMeta.__instancecheck__' (25 chars: 'ABCMeta'=7+'.'=1+'__instancecheck__'=17=25); same length as ABCMeta.__subclasscheck__ qualname (also 25); both have co_argcount==2 and co_varnames.__len__()==2; qualname len (25) is one less than ABCMeta._abc_caches_clear qualname len (25 in extra134 — actually 25 — identical); NEW in extra135: first standalone ABCMeta.__instancecheck__ qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__instancecheck__.__qualname__.__len__
  args: []
  expected: 25

invariant abc_extra135.abstractproperty_name_len_16:
  description: "abc.abstractproperty.__name__.__len__() == 16 — abstractproperty.__name__ is 'abstractproperty' (16 chars: 'abstract'=8+'property'=8=16); abstractproperty.__bases__[0].__name__=='property' (len=8); abstractproperty.__module__=='abc' (len=3); name len (16) is 2 more than abstractmethod name len (14) and equal to ABCMeta.register qualname len (16, covered in extra134); NEW in extra135: first standalone abstractproperty name length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractproperty.__name__.__len__
  args: []
  expected: 16

invariant abc_extra135.abc_class_name_len_3:
  description: "abc.ABC.__name__.__len__() == 3 — abc.ABC.__name__ is 'ABC' (3 chars); coincidentally the same length as abc.ABC.__module__ ('abc', also 3 chars) and abc.ABCMeta.__module__ ('abc', len=3); ABC.__bases__[0].__name__=='object'; ABC is a convenience class for using the ABCMeta metaclass without explicit metaclass= syntax; NEW in extra135: first standalone ABC class name length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__name__.__len__
  args: []
  expected: 3

