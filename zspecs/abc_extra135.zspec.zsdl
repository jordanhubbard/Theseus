    - [ic_vlen,     abc.ABCMeta.__instancecheck__.__code__.co_varnames.__len__,   [],                           2,    "ABCMeta.__instancecheck__.__code__.co_varnames.__len__() == 2 ('cls','instance'); verified with Python 3.14.3"]
    - [ic_inst_in,  abc.ABCMeta.__instancecheck__.__code__.co_varnames.__contains__, ["instance"],              true, "ABCMeta.__instancecheck__.__code__.co_varnames contains 'instance'; verified with Python 3.14.3"]
    - [sc_qn_eq,    abc.ABCMeta.__subclasscheck__.__qualname__.__eq__,           ["ABCMeta.__subclasscheck__"], true, "ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' (len=25); verified with Python 3.14.3"]
