spec: abc_extra135
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "This spec covers: abc.abstractmethod.__code__ detailed properties — co_cellvars (len=0), co_freevars (len=0), co_consts (len=2, contains True but not None), co_flags.__class__.__name__=='int'. Also abc.ABCMeta.__instancecheck__ and __subclasscheck__ — both Python functions with co_argcount==2 and co_varnames.__len__()==2. Also abc.abstractproperty — __name__=='abstractproperty' (len=16), __bases__[0].__name__=='property'. Also abc.ABC class — __name__=='ABC' (len=3), __bases__[0].__name__=='object'. abstractmethod.__code__.co_cellvars.__len__()==0; co_freevars.__len__()==0; co_consts.__len__()==2; co_consts.__contains__(True)==True; co_consts.__contains__(None)==False; co_flags.__class__.__name__=='int'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.abstractmethod.__code__.co_consts is a 2-element tuple: index 0 is the docstring (a str), index 1 is True (the bool that __isabstractmethod__ is set to). There is no None in co_consts. co_cellvars==() (len=0) because abstractmethod does not create closures. co_freevars==() (len=0) because abstractmethod is not itself a closure. co_flags is an int (67108867). ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__' (len=25); co_argcount==2 ('cls','instance'); co_varnames.__len__()==2. ABCMeta.__subclasscheck__.__qualname__=='ABCMeta.__subclasscheck__' (len=25); co_argcount==2 ('cls','subclass'); co_varnames.__len__()==2. abstractproperty.__name__=='abstractproperty' (len=16); __bases__[0].__name__=='property'. abc.ABC.__name__=='ABC' (len=3); __bases__[0].__name__=='object'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.abstractmethod co_cellvars, co_freevars, co_consts, co_flags — extra135
#
# abc.abstractmethod.__code__.co_cellvars.__len__()    == 0
# abc.abstractmethod.__code__.co_freevars.__len__()    == 0
# abc.abstractmethod.__code__.co_consts.__len__()      == 2
# abc.abstractmethod.__code__.co_consts.__contains__(True)  == True
# abc.abstractmethod.__code__.co_consts.__contains__(None)  == False
# abc.abstractmethod.__code__.co_flags.__class__.__name__   == 'int'
# ---------------------------------------------------------------------------

table abc_extra135.abstractmethod_code_detail:
  description: "abc.abstractmethod.__code__ detailed property checks — co_cellvars.__len__()==0 (abstractmethod creates no closures; co_cellvars is an empty tuple); co_freevars.__len__()==0 (abstractmethod is not itself a closure; co_freevars is an empty tuple); co_consts.__len__()==2 (a 2-tuple: index 0 is the docstring str, index 1 is True — the value assigned to funcobj.__isabstractmethod__); co_consts.__contains__(True)==True (True is the second element); co_consts.__contains__(None)==False (None is NOT in co_consts — abstractmethod does not return None implicitly in its compiled form); co_flags.__class__.__name__.__eq__('int')==True (co_flags is an integer bitmask, value 67108867 in Python 3.14.3); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcamcode135

  columns: [id, function, args, expected, description]
  rows:
    - [cellvars_len,       abc.abstractmethod.__code__.co_cellvars.__len__,              [],      0,     "abstractmethod.__code__.co_cellvars.__len__() == 0 (no closures); verified with Python 3.14.3"]
    - [freevars_len,       abc.abstractmethod.__code__.co_freevars.__len__,              [],      0,     "abstractmethod.__code__.co_freevars.__len__() == 0 (not a closure); verified with Python 3.14.3"]
    - [consts_len,         abc.abstractmethod.__code__.co_consts.__len__,                [],      2,     "abstractmethod.__code__.co_consts.__len__() == 2 (docstring + True); verified with Python 3.14.3"]
    - [consts_has_true,    abc.abstractmethod.__code__.co_consts.__contains__,           [true],  true,  "abstractmethod.__code__.co_consts contains True; verified with Python 3.14.3"]
    - [consts_no_none,     abc.abstractmethod.__code__.co_consts.__contains__,           [null],  false, "abstractmethod.__code__.co_consts does NOT contain None; verified with Python 3.14.3"]
    - [consts_cls,         abc.abstractmethod.__code__.co_consts.__class__.__name__.__eq__, ["tuple"], true, "abstractmethod.__code__.co_consts.__class__.__name__ == 'tuple'; verified with Python 3.14.3"]
    - [flags_cls,          abc.abstractmethod.__code__.co_flags.__class__.__name__.__eq__, ["int"],   true, "abstractmethod.__code__.co_flags.__class__.__name__ == 'int'; verified with Python 3.14.3"]

