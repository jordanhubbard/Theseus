spec: struct_extra2551
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_structmodule.c"
  notes:
    - "Theme: __reduce__, __reduce_ex__, and __getnewargs__ dict-presence — checking whether struct.Struct defines its own pickling/serialization protocol in its class __dict__."
    - "struct.Struct is NOT picklable: pickle.dumps(struct.Struct('!I')) raises TypeError."
    - "struct.Struct does NOT define __reduce__, __reduce_ex__, __getnewargs__, __getnewargs_ex__, __getstate__, or __setstate__ in its own __dict__. Verified with Python 3.14 on macOS/Darwin 25.4.0."
    - "struct.Struct is a C extension type (_struct.Struct). It defines no custom pickle protocol; pickle dispatch falls to object.__reduce_ex__ which raises TypeError for C extension instances without pickle support."
    - "__reduce__ and __reduce_ex__ are inherited from object (appear in object.__dict__, not in struct.Struct.__dict__)."
    - "struct.Struct positive controls in __dict__: pack, unpack, __repr__, __sizeof__, format, size are present."
    - "All expected values verified by running Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: struct.Struct.__dict__ — __reduce__ and __getnewargs__ absent
#
# struct.Struct does not define __reduce__, __reduce_ex__, or __getnewargs__
# in its own class __dict__. These are inherited from object.
# struct.Struct instances are not picklable; the absence of these dunders
# from Struct.__dict__ is consistent with that unpicklability.
# ---------------------------------------------------------------------------

table struct_extra2551.Struct_reduce_getnewargs_absent:
  description: "__reduce__, __reduce_ex__, __getnewargs__ absent from struct.Struct.__dict__; Struct has no custom pickle protocol; verified Python 3.14"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st2551

  columns: [id, function, args, expected]
  rows:
    - ["st2551-001", struct.Struct.__dict__.__contains__, ["__reduce__"],    false]
    - ["st2551-002", struct.Struct.__dict__.__contains__, ["__reduce_ex__"], false]
    - ["st2551-003", struct.Struct.__dict__.__contains__, ["__getnewargs__"], false]

# ---------------------------------------------------------------------------
# Table 2: struct.Struct.__dict__ — full pickle-protocol dunder set absent
#
# All six pickle-protocol dunders are absent from struct.Struct.__dict__.
# Struct defines no serialization protocol at any level.
# ---------------------------------------------------------------------------

table struct_extra2551.Struct_all_pickle_dunders_absent:
  description: "__getnewargs_ex__, __getstate__, __setstate__ all absent from struct.Struct.__dict__; no pickle state protocol defined; verified Python 3.14"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st2551

  columns: [id, function, args, expected]
  rows:
    - ["st2551-004", struct.Struct.__dict__.__contains__, ["__getnewargs_ex__"], false]
    - ["st2551-005", struct.Struct.__dict__.__contains__, ["__getstate__"],      false]
    - ["st2551-006", struct.Struct.__dict__.__contains__, ["__setstate__"],      false]

# ---------------------------------------------------------------------------
# Table 3: struct.Struct.__dict__ — positive controls (members that ARE present)
#
# Confirms that __dict__.__contains__ operates correctly for struct.Struct.
# pack, unpack, __repr__, __sizeof__, format, size are all explicitly
# defined in the Struct C extension type's own __dict__.
# ---------------------------------------------------------------------------

table struct_extra2551.Struct_dict_positive_controls:
  description: "struct.Struct.__dict__ positive controls — pack, unpack, format, size, __repr__, __sizeof__ are present; verified Python 3.14"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st2551

  columns: [id, function, args, expected]
  rows:
    - ["st2551-007", struct.Struct.__dict__.__contains__, ["pack"],      true]
    - ["st2551-008", struct.Struct.__dict__.__contains__, ["unpack"],    true]
    - ["st2551-009", struct.Struct.__dict__.__contains__, ["__repr__"],  true]
    - ["st2551-010", struct.Struct.__dict__.__contains__, ["__sizeof__"], true]
    - ["st2551-011", struct.Struct.__dict__.__contains__, ["format"],    true]
    - ["st2551-012", struct.Struct.__dict__.__contains__, ["size"],      true]

# ---------------------------------------------------------------------------
# Table 4: struct.Struct vs struct.error — pickle dunder contrast
#
# struct.error is an Exception subclass; struct.Struct is a C extension type.
# Neither defines __reduce__, __reduce_ex__, or __getnewargs__ in its own
# __dict__. Both inherit pickle dispatch from their respective bases.
# This table documents the parallel absence across both public struct classes.
# ---------------------------------------------------------------------------

table struct_extra2551.Struct_error_pickle_dunder_parity:
  description: "Neither struct.Struct nor struct.error defines __reduce__, __reduce_ex__, or __getnewargs__ in its own __dict__; both inherit pickle dispatch from their bases; verified Python 3.14"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st2551

  columns: [id, function, args, expected]
  rows:
    - ["st2551-013", struct.Struct.__dict__.__contains__, ["__reduce__"],     false]
    - ["st2551-014", struct.Struct.__dict__.__contains__, ["__reduce_ex__"],  false]
    - ["st2551-015", struct.Struct.__dict__.__contains__, ["__getnewargs__"], false]
    - ["st2551-016", struct.error.__dict__.__contains__,  ["__reduce__"],     false]
    - ["st2551-017", struct.error.__dict__.__contains__,  ["__reduce_ex__"],  false]
    - ["st2551-018", struct.error.__dict__.__contains__,  ["__getnewargs__"], false]
