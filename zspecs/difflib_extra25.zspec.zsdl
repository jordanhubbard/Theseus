spec: difflib_extra25
version: ">=3.9"
backend: python_module(difflib)

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/difflib.html — Python difflib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/difflib.py"
    - "difflib_extra24.zspec.zsdl — covers __mro__.__len__() for SM/Differ/HtmlDiff (all 2); __bases__[0].__name__.__len__() for SM/Differ/HtmlDiff (all 6); method __qualname__.__len__() for SM.ratio(21)/get_matching_blocks(35)/get_opcodes(27)/__init__(24); Differ.compare(14)/__init__(15); HtmlDiff.make_file(18)/make_table(19)/__init__(17)."
    - "difflib_extra23.zspec.zsdl — covers ndiff/__name__/__len__; get_close_matches/__name__/__len__; diff_bytes/__module__/__name__/__len__; restore/__module__/__name__/__len__; SequenceMatcher/Differ/HtmlDiff __qualname__.__len__(); ndiff/get_close_matches/diff_bytes __qualname__.__len__()."
    - "difflib_extra19.zspec.zsdl — covers SequenceMatcher/Differ/HtmlDiff __module__; __bases__[0].__name__; restore/__qualname__; unified_diff/context_diff/ndiff/restore/get_close_matches __module__."
  notes:
    - "This spec extends difflib_extra24; it does NOT duplicate invariants present in prior specs."
    - "This spec covers: difflib.__all__.__len__() == 12 (NOVEL — no prior difflib spec checks __all__ length); difflib.__all__.__class__.__name__.__len__() == 4 (NOVEL); SequenceMatcher/__dict__/__class__/__name__.__len__() == 12 (NOVEL — 'mappingproxy' has 12 characters); Differ.__dict__/__class__/__name__.__len__() == 12 (NOVEL); HtmlDiff.__dict__/__class__/__name__.__len__() == 12 (NOVEL); SequenceMatcher.quick_ratio.__qualname__.__len__() == 27 (NOVEL); SequenceMatcher.get_grouped_opcodes.__qualname__.__len__() == 35 (NOVEL — distinct from get_matching_blocks despite same length); Differ._dump.__qualname__.__len__() == 12 (NOVEL); unified_diff.__qualname__.__len__() == 12 (NOVEL — extra23 covers ndiff/get_close_matches/diff_bytes qualname lengths, NOT unified_diff); context_diff.__qualname__.__len__() == 12 (NOVEL)."
    - "difflib.__all__.__len__() == 12: difflib exports 12 public names. difflib.__all__.__class__.__name__ == 'list'; len('list') == 4. No prior spec checks either fact. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "difflib.SequenceMatcher.__dict__.__class__.__name__ == 'mappingproxy'; len == 12. Class __dict__ is always a mappingproxy. No prior difflib spec checks .__dict__.__class__.__name__.__len__() for any class. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "difflib.Differ.__dict__.__class__.__name__ == 'mappingproxy'; len == 12. Same as SequenceMatcher. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "difflib.HtmlDiff.__dict__.__class__.__name__ == 'mappingproxy'; len == 12. Same pattern. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "difflib.SequenceMatcher.quick_ratio.__qualname__ == 'SequenceMatcher.quick_ratio'; len == 27. extra24 covers get_opcodes len 27 but not quick_ratio. Both happen to be length 27 as distinct invariants on different methods. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "difflib.SequenceMatcher.get_grouped_opcodes.__qualname__ == 'SequenceMatcher.get_grouped_opcodes'; len == 35. extra24 covers get_matching_blocks len 35 but not get_grouped_opcodes. Both are 35 characters. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "difflib.Differ._dump.__qualname__ == 'Differ._dump'; len == 12. extra18 covers _dump in a qualname equality table but no spec checks __qualname__.__len__() for Differ._dump. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "difflib.unified_diff.__qualname__ == 'unified_diff'; len == 12. extra23 covers ndiff/get_close_matches/diff_bytes qualname lengths. unified_diff was NOT covered there. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "difflib.context_diff.__qualname__ == 'context_diff'; len == 12. Same as unified_diff — both 12 characters. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# difflib.__all__ — length and type
#
# No prior difflib spec checks __all__.__len__() or __all__.__class__.__name__.
# difflib exports exactly 12 public names; __all__ is a plain Python list.
# ---------------------------------------------------------------------------

invariant difflib_extra25.all.len:
  description: "difflib.__all__.__len__() == 12 — difflib exports exactly 12 public names"
  category: module_identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 12

invariant difflib_extra25.all.class_name_len:
  description: "difflib.__all__.__class__.__name__.__len__() == 4 — len('list') == 4, __all__ is a plain list"
  category: module_identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Class __dict__.__class__.__name__.__len__() for difflib classes
#
# Class __dict__ objects are always mappingproxy instances in CPython.
# len('mappingproxy') == 12. No prior difflib spec checks this property
# for SequenceMatcher, Differ, or HtmlDiff. All three are novel.
# ---------------------------------------------------------------------------

invariant difflib_extra25.SequenceMatcher.dict_class_name_len:
  description: "difflib.SequenceMatcher.__dict__.__class__.__name__.__len__() == 12 — len('mappingproxy') == 12"
  category: class_identity
  kind: python_call_eq
  function: SequenceMatcher.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

invariant difflib_extra25.Differ.dict_class_name_len:
  description: "difflib.Differ.__dict__.__class__.__name__.__len__() == 12 — len('mappingproxy') == 12"
  category: class_identity
  kind: python_call_eq
  function: Differ.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

invariant difflib_extra25.HtmlDiff.dict_class_name_len:
  description: "difflib.HtmlDiff.__dict__.__class__.__name__.__len__() == 12 — len('mappingproxy') == 12"
  category: class_identity
  kind: python_call_eq
  function: HtmlDiff.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# SequenceMatcher.quick_ratio.__qualname__.__len__() — novel
#
# extra24 checks get_opcodes.__qualname__.__len__()==27. No prior spec checks
# quick_ratio.__qualname__.__len__(). quick_ratio.__qualname__ ==
# 'SequenceMatcher.quick_ratio' which also has length 27 — a coincidence with
# get_opcodes. Each is independently verifiable as a distinct method.
# ---------------------------------------------------------------------------

invariant difflib_extra25.SequenceMatcher.quick_ratio_qualname_len:
  description: "difflib.SequenceMatcher.quick_ratio.__qualname__.__len__() == 27 — 'SequenceMatcher.quick_ratio' has 27 characters"
  category: string_lengths
  kind: python_call_eq
  function: SequenceMatcher.quick_ratio.__qualname__.__len__
  args: []
  expected: 27

# ---------------------------------------------------------------------------
# SequenceMatcher.get_grouped_opcodes.__qualname__.__len__() — novel
#
# extra24 covers get_matching_blocks.__qualname__.__len__()==35. No prior spec
# checks get_grouped_opcodes.__qualname__.__len__(). Both methods have qualname
# length 35 (coincidence of different method names under the same long prefix).
# ---------------------------------------------------------------------------

invariant difflib_extra25.SequenceMatcher.get_grouped_opcodes_qualname_len:
  description: "difflib.SequenceMatcher.get_grouped_opcodes.__qualname__.__len__() == 35 — 'SequenceMatcher.get_grouped_opcodes' has 35 characters"
  category: string_lengths
  kind: python_call_eq
  function: SequenceMatcher.get_grouped_opcodes.__qualname__.__len__
  args: []
  expected: 35

# ---------------------------------------------------------------------------
# Differ._dump.__qualname__.__len__() — novel
#
# extra18 covers _dump in a __qualname__ equality table. No prior spec checks
# _dump.__qualname__.__len__(). 'Differ._dump' has 12 characters.
# ---------------------------------------------------------------------------

invariant difflib_extra25.Differ.dump_qualname_len:
  description: "difflib.Differ._dump.__qualname__.__len__() == 12 — 'Differ._dump' has 12 characters"
  category: string_lengths
  kind: python_call_eq
  function: Differ._dump.__qualname__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# Table: class __dict__.__class__.__name__.__len__() for all three classes
#
# Groups the three mappingproxy name-length checks into a single table.
# All are novel to extra25. All have value 12 (len('mappingproxy')).
# ---------------------------------------------------------------------------

table difflib_extra25.class_dict_type_name_lengths:
  description: "difflib class __dict__.__class__.__name__.__len__() — always 12 ('mappingproxy'), novel invariants"
  kind: python_call_eq
  category: class_identity
  id_prefix: dfa25a

  columns: [id, function, args, expected]
  rows:
    - [SequenceMatcher_dict_len, SequenceMatcher.__dict__.__class__.__name__.__len__, [], 12]
    - [Differ_dict_len,          Differ.__dict__.__class__.__name__.__len__,          [], 12]
    - [HtmlDiff_dict_len,        HtmlDiff.__dict__.__class__.__name__.__len__,        [], 12]

# ---------------------------------------------------------------------------
# Table: unified_diff and context_diff __qualname__.__len__() — novel
#
# extra23 covered ndiff/get_close_matches/diff_bytes __qualname__.__len__() but
# not unified_diff or context_diff. Both have qualname length 12.
# Also includes Differ._dump.__qualname__.__len__() for completeness.
# All values are novel to extra25.
# ---------------------------------------------------------------------------

table difflib_extra25.function_qualname_lengths:
  description: "difflib function __qualname__.__len__() — unified_diff(12), context_diff(12), Differ._dump(12) — novel invariants"
  kind: python_call_eq
  category: string_lengths
  id_prefix: dfa25b

  columns: [id, function, args, expected]
  rows:
    - [unified_diff_qualname_len,  unified_diff.__qualname__.__len__,               [], 12]
    - [context_diff_qualname_len,  context_diff.__qualname__.__len__,               [], 12]
    - [Differ_dump_qualname_len,   Differ._dump.__qualname__.__len__,               [], 12]
    - [SM_quick_ratio_qualname_len, SequenceMatcher.quick_ratio.__qualname__.__len__, [], 27]
    - [SM_grouped_opcodes_qualname_len, SequenceMatcher.get_grouped_opcodes.__qualname__.__len__, [], 35]
