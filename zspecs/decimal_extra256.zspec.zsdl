spec: decimal_extra256
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra255.zspec.zsdl — covers Decimal comparison dunder __name__/__qualname__ and __hash__"
    - "decimal_extra.zspec.zsdl — covers predicates, eng_string, Context/BasicContext/ExtendedContext, rounding modes"
  notes:
    - "Decimal.__int__.__name__ == '__int__', __qualname__ == 'Decimal.__int__', __class__.__name__ == 'method_descriptor'."
    - "Decimal.__float__.__name__ == '__float__', __qualname__ == 'Decimal.__float__', __class__.__name__ == 'wrapper_descriptor'."
    - "Decimal.__complex__.__name__ == '__complex__', __qualname__ == 'Decimal.__complex__', __class__.__name__ == 'method_descriptor'."
    - "Decimal.__bool__.__name__ == '__bool__', __qualname__ == 'Decimal.__bool__', __class__.__name__ == 'wrapper_descriptor'."
    - "Decimal.__str__.__name__ == '__str__', __qualname__ == 'Decimal.__str__', __class__.__name__ == 'wrapper_descriptor'."
    - "Decimal.__repr__.__name__ == '__repr__', __qualname__ == 'Decimal.__repr__', __class__.__name__ == 'wrapper_descriptor'."
    - "Decimal.__format__.__name__ == '__format__', __qualname__ == 'Decimal.__format__', __class__.__name__ == 'method_descriptor'."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal conversion methods — __name__ attributes
# ---------------------------------------------------------------------------

table decimal_extra256.Decimal.conversion_names:
  description: "Decimal conversion dunder methods report correct __name__ attributes"
  kind: python_call_eq
  category: method_identity
  id_prefix: name

  columns: [id, function, args, expected]
  rows:
    - [int_name,     Decimal.__int__.__name__.__eq__,     ["__int__"],     true]
    - [float_name,   Decimal.__float__.__name__.__eq__,   ["__float__"],   true]
    - [complex_name, Decimal.__complex__.__name__.__eq__, ["__complex__"], true]
    - [bool_name,    Decimal.__bool__.__name__.__eq__,    ["__bool__"],    true]
    - [str_name,     Decimal.__str__.__name__.__eq__,     ["__str__"],     true]
    - [repr_name,    Decimal.__repr__.__name__.__eq__,    ["__repr__"],    true]
    - [format_name,  Decimal.__format__.__name__.__eq__,  ["__format__"],  true]

# ---------------------------------------------------------------------------
# Decimal conversion methods — __qualname__ attributes
# ---------------------------------------------------------------------------

table decimal_extra256.Decimal.conversion_qualnames:
  description: "Decimal conversion dunder methods report correct __qualname__ attributes"
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [int_qualname,     Decimal.__int__.__qualname__.__eq__,     ["Decimal.__int__"],     true]
    - [float_qualname,   Decimal.__float__.__qualname__.__eq__,   ["Decimal.__float__"],   true]
    - [complex_qualname, Decimal.__complex__.__qualname__.__eq__, ["Decimal.__complex__"], true]
    - [bool_qualname,    Decimal.__bool__.__qualname__.__eq__,    ["Decimal.__bool__"],    true]
    - [str_qualname,     Decimal.__str__.__qualname__.__eq__,     ["Decimal.__str__"],     true]
    - [repr_qualname,    Decimal.__repr__.__qualname__.__eq__,    ["Decimal.__repr__"],    true]
    - [format_qualname,  Decimal.__format__.__qualname__.__eq__,  ["Decimal.__format__"],  true]

# ---------------------------------------------------------------------------
# Decimal conversion methods — descriptor class names
# __int__/__complex__/__format__ are method_descriptor; __float__/__bool__/__str__/__repr__ are wrapper_descriptor
# ---------------------------------------------------------------------------

invariant decimal_extra256.Decimal.int.class_name:
  description: "Decimal.__int__.__class__.__name__ == 'method_descriptor'"
  category: method_identity
  kind: python_call_eq
  function: Decimal.__int__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant decimal_extra256.Decimal.float.class_name:
  description: "Decimal.__float__.__class__.__name__ == 'wrapper_descriptor'"
  category: method_identity
  kind: python_call_eq
  function: Decimal.__float__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra256.Decimal.complex.class_name:
  description: "Decimal.__complex__.__class__.__name__ == 'method_descriptor'"
  category: method_identity
  kind: python_call_eq
  function: Decimal.__complex__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant decimal_extra256.Decimal.bool.class_name:
  description: "Decimal.__bool__.__class__.__name__ == 'wrapper_descriptor'"
  category: method_identity
  kind: python_call_eq
  function: Decimal.__bool__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra256.Decimal.str.class_name:
  description: "Decimal.__str__.__class__.__name__ == 'wrapper_descriptor'"
  category: method_identity
  kind: python_call_eq
  function: Decimal.__str__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra256.Decimal.repr.class_name:
  description: "Decimal.__repr__.__class__.__name__ == 'wrapper_descriptor'"
  category: method_identity
  kind: python_call_eq
  function: Decimal.__repr__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra256.Decimal.format.class_name:
  description: "Decimal.__format__.__class__.__name__ == 'method_descriptor'"
  category: method_identity
  kind: python_call_eq
  function: Decimal.__format__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true
