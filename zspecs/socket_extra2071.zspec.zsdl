spec: socket_extra2071
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/socket.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 585 (_extra2071): __pos__/__neg__, __getattribute__, __reduce__/__reduce_ex__, __copy__/__deepcopy__ dict-presence checks."
    - "socket.socket is a C type representing a network socket; it is not numeric so __pos__/__neg__ are absent. __reduce__/__reduce_ex__/__copy__/__deepcopy__/__getattribute__ are all absent from its own __dict__."
    - "socket.error is an alias for OSError. OSError defines __reduce__ in its own __dict__ (for exception pickling). __reduce_ex__/__pos__/__neg__/__copy__/__deepcopy__/__getattribute__ are absent."
    - "socket.timeout is an alias for TimeoutError; none of the target dunders appear in its own __dict__."
    - "socket.gaierror is a socket-specific exception subclass; none of the target dunders appear in its own __dict__."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses; __pos__/__neg__ are inherited from int and absent from their own __dict__. None of the pickle/copy dunders appear in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table socket_extra2071.unary_sign_protocol:
  description: "socket types __pos__/__neg__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2071

  columns: [id, function, args, expected]
  rows:
    - ["sk2071001", "socket.socket.__dict__.__contains__",        ["__pos__"], false]
    - ["sk2071002", "socket.socket.__dict__.__contains__",        ["__neg__"], false]
    - ["sk2071003", "socket.error.__dict__.__contains__",         ["__pos__"], false]
    - ["sk2071004", "socket.error.__dict__.__contains__",         ["__neg__"], false]
    - ["sk2071005", "socket.timeout.__dict__.__contains__",       ["__pos__"], false]
    - ["sk2071006", "socket.timeout.__dict__.__contains__",       ["__neg__"], false]
    - ["sk2071007", "socket.gaierror.__dict__.__contains__",      ["__pos__"], false]
    - ["sk2071008", "socket.gaierror.__dict__.__contains__",      ["__neg__"], false]
    - ["sk2071009", "socket.AddressFamily.__dict__.__contains__", ["__pos__"], false]
    - ["sk2071010", "socket.AddressFamily.__dict__.__contains__", ["__neg__"], false]
    - ["sk2071011", "socket.SocketKind.__dict__.__contains__",    ["__pos__"], false]
    - ["sk2071012", "socket.SocketKind.__dict__.__contains__",    ["__neg__"], false]

