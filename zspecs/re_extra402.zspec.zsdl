spec: re_extra402
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "re.Match.pos, re.Match.endpos, re.Match.re, and re.Match.string are member_descriptor objects"
    - "re.Match.lastindex and re.Match.lastgroup are getset_descriptor objects"
    - "The descriptor type reflects how CPython exposes each attribute at the C level: member_descriptor for fixed-offset struct members, getset_descriptor for computed get/set slots"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Match attribute descriptor types — member_descriptor attributes
# ---------------------------------------------------------------------------

table re_extra402.match_member_descriptors:
  description: "re.Match member_descriptor attributes — pos, endpos, re, string; these are fixed-offset struct members exposed via member_descriptor at the C level; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: rematchmem402

  columns: [id, function, args, expected]
  rows:
    - [pos_class,    re.Match.pos.__class__.__name__.__eq__,    ["member_descriptor"], true]
    - [endpos_class, re.Match.endpos.__class__.__name__.__eq__, ["member_descriptor"], true]
    - [re_class,     re.Match.re.__class__.__name__.__eq__,     ["member_descriptor"], true]
    - [string_class, re.Match.string.__class__.__name__.__eq__, ["member_descriptor"], true]

# ---------------------------------------------------------------------------
# re.Match attribute descriptor types — getset_descriptor attributes
# ---------------------------------------------------------------------------

table re_extra402.match_getset_descriptors:
  description: "re.Match getset_descriptor attributes — lastindex, lastgroup; these are computed get/set slots exposed via getset_descriptor at the C level; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: rematchgs402

  columns: [id, function, args, expected]
  rows:
    - [lastindex_class, re.Match.lastindex.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [lastgroup_class, re.Match.lastgroup.__class__.__name__.__eq__, ["getset_descriptor"], true]
