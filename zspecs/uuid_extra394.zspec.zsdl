  not_derived_from:
    - "CPython source code"
  notes:
    - "uuid.UUID.__repr__.__name__ == '__repr__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__name__ == '__str__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__int__.__name__ == '__int__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__name__ == '__hash__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__name__ == '__eq__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__lt__.__name__ == '__lt__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__qualname__ == 'UUID.__repr__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.UUID is a pure-Python class defined in Lib/uuid.py. Its special methods are ordinary Python function objects. Each method's __name__ is the bare dunder string (e.g. '__repr__') and its __qualname__ is qualified with the class name (e.g. 'UUID.__repr__'). This follows standard Python class method naming conventions."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID special method __name__ attributes
#
# Wave 394 theme: uuid.UUID special method identity.
#
# uuid.UUID is a pure-Python class defined in Lib/uuid.py. Its special
# methods (__repr__, __str__, __int__, __hash__, __eq__, __lt__) are
# ordinary Python function objects. Each method's __name__ is the bare
# dunder name (e.g., '__repr__') — identical to the attribute name used
# to look it up on the class. This is the standard naming convention for
# Python class methods defined with def inside a class body.
#
# __qualname__ is qualified with the class prefix: 'UUID.__repr__',
# 'UUID.__str__', etc.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra394.special_method_names:
  description: "uuid.UUID special method __name__ attributes — each dunder method's __name__ equals the bare dunder string; uuid.UUID is pure-Python so methods are function objects with standard naming; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuidmn394

  columns: [id, function, args, expected]
  rows:
    - [repr_name,  UUID.__repr__.__name__.__eq__,  ["__repr__"],  true]
    - [str_name,   UUID.__str__.__name__.__eq__,   ["__str__"],   true]
    - [int_name,   UUID.__int__.__name__.__eq__,   ["__int__"],   true]
    - [hash_name,  UUID.__hash__.__name__.__eq__,  ["__hash__"],  true]
    - [eq_name,    UUID.__eq__.__name__.__eq__,    ["__eq__"],    true]
    - [lt_name,    UUID.__lt__.__name__.__eq__,    ["__lt__"],    true]

# ---------------------------------------------------------------------------
# uuid.UUID.__repr__.__qualname__ — qualified with class name
#
# For methods defined inside a Python class body, __qualname__ takes the form
# 'ClassName.method_name'. uuid.UUID.__repr__.__qualname__ is 'UUID.__repr__',
# demonstrating that special methods on pure-Python classes carry the standard
# qualified name that includes the enclosing class.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra394.repr_qualname:
  description: "uuid.UUID.__repr__.__qualname__.__eq__('UUID.__repr__') == True — pure-Python class methods have __qualname__ qualified with the class name; 'UUID.__repr__' follows the ClassName.method_name pattern; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: UUID.__repr__.__qualname__.__eq__
  args: ["UUID.__repr__"]
  expected: true
