spec: re_extra260
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re.zspec.zsdl — covers sub, findall, split, escape, and compile error cases"
    - "re_extra.zspec.zsdl — covers Pattern/Match/error class names, flag constants, match/search/sub/split/findall vectors"
    - "re_extra259.zspec.zsdl — covers re.Match and re.Pattern class identity and method qualnames"
  notes:
    - "re.compile is a plain Python function; __name__ == 'compile', __qualname__ == 'compile', __module__ == 're'."
    - "re.fullmatch/search/findall/finditer/split are all plain Python functions defined in Lib/re/__init__.py."
    - "All module-level function qualnames equal their __name__ (no class prefix) — they are top-level functions."
    - "re.compile returns a re.Pattern object (the compiled regex)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.compile — function identity: name, qualname, module, class
# ---------------------------------------------------------------------------

invariant re_extra260.compile.name:
  description: "re.compile.__name__ == 'compile'"
  category: identity
  kind: python_call_eq
  function: compile.__name__.__eq__
  args: ["compile"]
  expected: true

invariant re_extra260.compile.qualname:
  description: "re.compile.__qualname__ == 'compile'"
  category: identity
  kind: python_call_eq
  function: compile.__qualname__.__eq__
  args: ["compile"]
  expected: true

invariant re_extra260.compile.module:
  description: "re.compile.__module__ == 're'"
  category: identity
  kind: python_call_eq
  function: compile.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra260.compile.class:
  description: "re.compile.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: compile.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# re.fullmatch — function identity: name, qualname
# ---------------------------------------------------------------------------

invariant re_extra260.fullmatch.name:
  description: "re.fullmatch.__name__ == 'fullmatch'"
  category: identity
  kind: python_call_eq
  function: fullmatch.__name__.__eq__
  args: ["fullmatch"]
  expected: true

invariant re_extra260.fullmatch.qualname:
  description: "re.fullmatch.__qualname__ == 'fullmatch'"
  category: identity
  kind: python_call_eq
  function: fullmatch.__qualname__.__eq__
  args: ["fullmatch"]
  expected: true

# ---------------------------------------------------------------------------
# re.search — function identity: name, qualname
# ---------------------------------------------------------------------------

invariant re_extra260.search.name:
  description: "re.search.__name__ == 'search'"
  category: identity
  kind: python_call_eq
  function: search.__name__.__eq__
  args: ["search"]
  expected: true

invariant re_extra260.search.qualname:
  description: "re.search.__qualname__ == 'search'"
  category: identity
  kind: python_call_eq
  function: search.__qualname__.__eq__
  args: ["search"]
  expected: true

# ---------------------------------------------------------------------------
# re.findall / re.finditer / re.split — function identity: name and qualname
# ---------------------------------------------------------------------------

table re_extra260.module_functions.names:
  description: "findall/finditer/split __name__ equals the bare function name"
  kind: python_call_eq
  category: identity
  id_prefix: func_name

  columns: [id, function, args, expected, description]
  rows:
    - [findall_name,  findall.__name__.__eq__,  ["findall"],  true, "findall __name__"]
    - [finditer_name, finditer.__name__.__eq__, ["finditer"], true, "finditer __name__"]
    - [split_name,    split.__name__.__eq__,    ["split"],    true, "split __name__"]

table re_extra260.module_functions.qualnames:
  description: "findall/finditer/split __qualname__ equals the bare function name (top-level)"
  kind: python_call_eq
  category: identity
  id_prefix: func_qualname

  columns: [id, function, args, expected, description]
  rows:
    - [findall_qualname,  findall.__qualname__.__eq__,  ["findall"],  true, "findall __qualname__"]
    - [finditer_qualname, finditer.__qualname__.__eq__, ["finditer"], true, "finditer __qualname__"]
    - [split_qualname,    split.__qualname__.__eq__,    ["split"],    true, "split __qualname__"]
