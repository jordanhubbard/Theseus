spec: re_extra1501
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module Pattern, Match, error documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "PCRE source code"
  notes:
    - "Wave 547 (_extra1501): async protocol method __dict__ presence checks for re module classes."
    - "All re classes are synchronous only. None define __await__, __aiter__, __anext__, __aenter__, or __aexit__ in their own __dict__."
    - "re.Pattern is the compiled regular expression type (type(re.compile('x'))); its __dict__ contains match, search, fullmatch, findall, sub, and other pattern-matching methods but no async protocol dunders."
    - "re.Match is the match object type (type(re.match('x','x'))); its __dict__ contains group, groups, start, end, span, and other result-extraction methods but no async protocol dunders."
    - "re.error is the exception class for invalid regex patterns; as an Exception subclass it has no context manager or async protocol support."
    - "Regular expression compilation and matching are purely synchronous CPU-bound operations; there is no async equivalent in the re module itself."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra1501.pattern_async_protocol:
  description: "re.Pattern async protocol absence — __await__, __aiter__, __anext__, __aenter__, __aexit__ are all absent from re.Pattern.__dict__; positive anchors show pattern-matching methods that ARE present; wave 547; new to extra1501"
  kind: python_call_eq
  category: async_protocol
  id_prefix: re1501pa
  columns: [id, function, args, expected, description]
  rows:
    - [re1501pa001,
       re.Pattern.__dict__.__contains__,
       ["__await__"],
       false,
       "re.Pattern.__dict__.__contains__('__await__') == False — re.Pattern is the compiled regular expression type; it does not implement the awaitable protocol; regex compilation and matching are synchronous CPU-bound operations; __await__ is absent from re.Pattern.__dict__; verified with Python 3.12"]
    - [re1501pa002,
       re.Pattern.__dict__.__contains__,
       ["__aiter__"],
       false,
       "re.Pattern.__dict__.__contains__('__aiter__') == False — re.Pattern does not implement the async iterator protocol; __aiter__ is absent; Pattern objects are not async-iterable; verified with Python 3.12"]
    - [re1501pa003,
       re.Pattern.__dict__.__contains__,
       ["__anext__"],
       false,
       "re.Pattern.__dict__.__contains__('__anext__') == False — re.Pattern does not implement __anext__; async next-item iteration is not part of the regex pattern design; verified with Python 3.12"]
    - [re1501pa004,
       re.Pattern.__dict__.__contains__,
       ["__aenter__"],
       false,
       "re.Pattern.__dict__.__contains__('__aenter__') == False — re.Pattern does not implement the async context manager protocol; __aenter__ is absent; Pattern objects cannot be used with 'async with'; verified with Python 3.12"]
    - [re1501pa005,
       re.Pattern.__dict__.__contains__,
       ["__aexit__"],
       false,
       "re.Pattern.__dict__.__contains__('__aexit__') == False — re.Pattern does not implement __aexit__; all five async protocol dunders are absent from re.Pattern.__dict__; verified with Python 3.12"]
    - [re1501pa006,
       re.Pattern.__dict__.__contains__,
       ["match"],
       true,
       "re.Pattern.__dict__.__contains__('match') == True — positive anchor: re.Pattern defines 'match' in its own __dict__; pattern-matching methods are defined at the class level while all five async protocol dunders are absent; verified with Python 3.12"]
    - [re1501pa007,
       re.Pattern.__dict__.__contains__,
       ["search"],
       true,
       "re.Pattern.__dict__.__contains__('search') == True — positive anchor: re.Pattern defines 'search' in its own __dict__; search scans through a string looking for any position where the pattern matches; sync methods are present, async methods are absent; verified with Python 3.12"]
    - [re1501pa008,
       re.Pattern.__dict__.__contains__,
       ["findall"],
       true,
       "re.Pattern.__dict__.__contains__('findall') == True — positive anchor: re.Pattern defines 'findall' in its own __dict__; findall returns all non-overlapping matches as a list; it is synchronous with no async equivalent on Pattern; verified with Python 3.12"]

table re_extra1501.match_async_protocol:
  description: "re.Match async protocol absence — __await__, __aiter__, __anext__, __aenter__, __aexit__ are all absent from re.Match.__dict__; positive anchors show result-extraction methods that ARE present; wave 547; new to extra1501"
  kind: python_call_eq
  category: async_protocol
  id_prefix: re1501ma
  columns: [id, function, args, expected, description]
  rows:
    - [re1501ma001,
       re.Match.__dict__.__contains__,
       ["__await__"],
       false,
       "re.Match.__dict__.__contains__('__await__') == False — re.Match is the match object type returned by pattern matching operations; it does not implement the awaitable protocol; match objects are simple result containers, not coroutines; __await__ is absent from re.Match.__dict__; verified with Python 3.12"]
    - [re1501ma002,
       re.Match.__dict__.__contains__,
       ["__aiter__"],
       false,
       "re.Match.__dict__.__contains__('__aiter__') == False — re.Match does not implement __aiter__; match objects are not async-iterable; they represent a single match result, not a sequence of async items; verified with Python 3.12"]
    - [re1501ma003,
       re.Match.__dict__.__contains__,
       ["__anext__"],
       false,
       "re.Match.__dict__.__contains__('__anext__') == False — re.Match does not implement __anext__; there is no async next-item protocol for match result objects; verified with Python 3.12"]
    - [re1501ma004,
       re.Match.__dict__.__contains__,
       ["__aenter__"],
       false,
       "re.Match.__dict__.__contains__('__aenter__') == False — re.Match does not implement the async context manager protocol; __aenter__ is absent; match objects cannot be used with 'async with'; verified with Python 3.12"]
    - [re1501ma005,
       re.Match.__dict__.__contains__,
       ["__aexit__"],
       false,
       "re.Match.__dict__.__contains__('__aexit__') == False — re.Match does not implement __aexit__; all five async protocol dunders are absent from re.Match.__dict__; verified with Python 3.12"]
    - [re1501ma006,
       re.Match.__dict__.__contains__,
       ["group"],
       true,
       "re.Match.__dict__.__contains__('group') == True — positive anchor: re.Match defines 'group' in its own __dict__; group() is the primary method for extracting matched substrings; sync result-extraction methods are present while all async protocol dunders are absent; verified with Python 3.12"]
    - [re1501ma007,
       re.Match.__dict__.__contains__,
       ["groups"],
       true,
       "re.Match.__dict__.__contains__('groups') == True — positive anchor: re.Match defines 'groups' in its own __dict__; groups() returns all captured groups as a tuple; it is synchronous with no async equivalent on the Match type; verified with Python 3.12"]
    - [re1501ma008,
       re.Match.__dict__.__contains__,
       ["span"],
       true,
       "re.Match.__dict__.__contains__('span') == True — positive anchor: re.Match defines 'span' in its own __dict__; span() returns the (start, end) tuple of the match position; sync positional methods are present while all five async protocol dunders are absent; verified with Python 3.12"]

table re_extra1501.error_async_protocol:
  description: "re.error async protocol absence — all five async protocol dunders are absent from re.error.__dict__; as an Exception subclass, re.error inherits no async protocol from the exception hierarchy; cross-checks confirm Pattern and Match also lack all async dunders; wave 547; new to extra1501"
  kind: python_call_eq
  category: async_protocol
  id_prefix: re1501er
  columns: [id, function, args, expected, description]
  rows:
    - [re1501er001,
       re.error.__dict__.__contains__,
       ["__await__"],
       false,
       "re.error.__dict__.__contains__('__await__') == False — re.error is the exception class raised for invalid regular expression patterns; as an Exception subclass it does not implement the awaitable protocol; __await__ is absent from re.error.__dict__ and from the entire exception MRO; verified with Python 3.12"]
    - [re1501er002,
       re.error.__dict__.__contains__,
       ["__aiter__"],
       false,
       "re.error.__dict__.__contains__('__aiter__') == False — re.error does not implement __aiter__; exception objects are not async-iterable; the exception hierarchy (Exception, BaseException, object) defines no async iteration protocol; verified with Python 3.12"]
    - [re1501er003,
       re.error.__dict__.__contains__,
       ["__aenter__"],
       false,
       "re.error.__dict__.__contains__('__aenter__') == False — re.error does not implement the async context manager protocol; __aenter__ is absent; exception instances cannot be used with 'async with'; verified with Python 3.12"]
    - [re1501er004,
       re.error.__dict__.__contains__,
       ["__aexit__"],
       false,
       "re.error.__dict__.__contains__('__aexit__') == False — re.error does not implement __aexit__; the async context manager protocol is entirely absent from the exception hierarchy; verified with Python 3.12"]
    - [re1501er005,
       re.error.__dict__.__contains__,
       ["__init__"],
       true,
       "re.error.__dict__.__contains__('__init__') == True — positive anchor: re.error defines __init__ in its own __dict__ to store pattern, pos, and msg attributes about the invalid regex; __init__ is present while all five async protocol dunders are absent; verified with Python 3.12"]
    - [re1501er006,
       re.Pattern.__dict__.__contains__,
       ["__aenter__"],
       false,
       "re.Pattern.__dict__.__contains__('__aenter__') == False — cross-check: Pattern also lacks __aenter__; no re class implements the async context manager protocol; verified with Python 3.12"]
    - [re1501er007,
       re.Match.__dict__.__contains__,
       ["__aenter__"],
       false,
       "re.Match.__dict__.__contains__('__aenter__') == False — cross-check: Match also lacks __aenter__; confirmed that none of the three main re classes (Pattern, Match, error) define any async protocol dunder in their __dict__; verified with Python 3.12"]
    - [re1501er008,
       re.error.__class__.__name__.__eq__,
       ["type"],
       true,
       "re.error.__class__.__name__ == 'type' — positive anchor: re.error is a class object whose metaclass is the built-in type; this confirms re.error is a proper class despite implementing no async protocol dunders; verified with Python 3.12"]
