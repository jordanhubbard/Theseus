spec: uuid_extra277
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — SafeUUID enum and UUID class identity"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "SafeUUID inherits from Enum (not IntEnum); __bases__[0].__name__ is 'Enum'"
    - "SafeUUID.safe == 0, SafeUUID.unsafe == -1, SafeUUID.unknown.value is None"
    - "uuid.UUID.__slots__ is ('int', 'is_safe', '__weakref__') — 3 elements"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table uuid_extra277.safeuuid_values:
  description: "SafeUUID enum member integer values"
  kind: python_call_eq
  category: identity
  id_prefix: uuidval

  columns: [id, function, args, expected, description]
  rows:
    - [uuidval001, uuid.SafeUUID.safe.value, [], 0, "SafeUUID.safe has value 0"]
    - [uuidval002, uuid.SafeUUID.unsafe.value, [], -1, "SafeUUID.unsafe has value -1"]
    - [uuidval003, uuid.SafeUUID.safe.__class__.__name__, [], SafeUUID, "SafeUUID.safe member is a SafeUUID instance"]
    - [uuidval004, uuid.SafeUUID.unsafe.__class__.__name__, [], SafeUUID, "SafeUUID.unsafe member is a SafeUUID instance"]
    - [uuidval005, uuid.SafeUUID.unknown.__class__.__name__, [], SafeUUID, "SafeUUID.unknown member is a SafeUUID instance"]

table uuid_extra277.safeuuid_identity:
  description: "SafeUUID class identity attributes"
  kind: python_call_eq
  category: identity
  id_prefix: uuidid

  columns: [id, function, args, expected, description]
  rows:
    - [uuidid001, uuid.SafeUUID.__name__, [], SafeUUID, "SafeUUID class __name__"]
    - [uuidid002, uuid.SafeUUID.__module__, [], uuid, "SafeUUID class lives in uuid module"]
    - [uuidid003, uuid.SafeUUID.__bases__.__len__, [], 1, "SafeUUID has exactly one base class"]
    - ["uuidid004", "uuid.SafeUUID.__bases__[0].__name__", "[]", "Enum", "SafeUUID base is Enum"]

invariant uuid_extra277.uuid_slots_len:
  description: "UUID.__slots__ has exactly 3 entries"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.__slots__.__len__
  args: []
  expected: 3

invariant uuid_extra277.uuid_slots_type:
  description: "UUID.__slots__ is a tuple"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.__slots__.__class__.__name__
  args: []
  expected: tuple

invariant uuid_extra277.safeuuid_unknown_value_none:
  description: "SafeUUID.unknown.value is None"
  category: identity
  kind: python_call_eq
  function: uuid.SafeUUID.unknown.value.__class__.__name__
  args: []
  expected: NoneType
