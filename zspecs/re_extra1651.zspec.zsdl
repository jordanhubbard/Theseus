spec: re_extra1651
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "Python re documentation — https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re.zspec.zsdl — covers sub, findall, split, escape, compile error cases"
    - "re_extra.zspec.zsdl — covers Pattern/Match/error class identity, flags, match/search/sub/split/findall"
  notes:
    - "Theme: __init_subclass__, __set_name__, __class_getitem__ — class creation and parameterization protocol."
    - "re.Pattern and re.Match are C-implemented types; they do not own __init_subclass__ in their __dict__."
    - "re.error is a pure-Python exception class; it also does not define __init_subclass__ in its own __dict__."
    - "re.Pattern and re.Match DO own __class_getitem__ (Python 3.9+): Pattern[str] and Match[str] are valid generic alias expressions."
    - "__class_getitem__ is installed on Pattern and Match by the _sre C extension specifically to support PEP 585 generic syntax."
    - "re.error does NOT own __class_getitem__; exceptions are not generic containers."
    - "Module-level attributes are verified via re.__dict__.__contains__; RegexFlag is an enum.IntFlag subclass added in Python 3.6."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: no_init_subclass
# re C types (Pattern, Match) and the re.error exception class do not define
# __init_subclass__ in their own __dict__. The hook is inherited from object.
# ---------------------------------------------------------------------------

table re_extra1651.no_init_subclass:
  description: "re types do not own __init_subclass__ in their __dict__"
  kind: python_call_eq
  category: init_subclass
  id_prefix: re1651

  columns: [id, function, args, expected]
  rows:
    - ["re1651_pattern_no_init_subclass", Pattern.__dict__.__contains__, ["__init_subclass__"], false]
    - ["re1651_match_no_init_subclass",   Match.__dict__.__contains__,   ["__init_subclass__"], false]
    - ["re1651_error_no_init_subclass",   error.__dict__.__contains__,   ["__init_subclass__"], false]

# ---------------------------------------------------------------------------
# Table 2: class_getitem_support
# Pattern and Match own __class_getitem__ (PEP 585, Python 3.9+).
# re.error does not — exception classes are not parameterizable.
# This table probes the class parameterization protocol directly.
# ---------------------------------------------------------------------------

table re_extra1651.class_getitem_support:
  description: "Pattern and Match own __class_getitem__; re.error does not"
  kind: python_call_eq
  category: class_getitem
  id_prefix: re1651

  columns: [id, function, args, expected]
  rows:
    - ["re1651_pattern_has_class_getitem", Pattern.__dict__.__contains__, ["__class_getitem__"], true]
    - ["re1651_match_has_class_getitem",   Match.__dict__.__contains__,   ["__class_getitem__"], true]
    - ["re1651_error_no_class_getitem",    error.__dict__.__contains__,   ["__class_getitem__"], false]

# ---------------------------------------------------------------------------
# Table 3: module_attr_presence
# Verifies that all documented public names are present in re.__dict__.
# This confirms the module-level namespace was populated correctly at import.
# ---------------------------------------------------------------------------

table re_extra1651.module_attr_presence:
  description: "All documented public names are present in re.__dict__"
  kind: python_call_eq
  category: module_attrs
  id_prefix: re1651

  columns: [id, function, args, expected]
  rows:
    - ["re1651_mod_compile",    __dict__.__contains__, ["compile"],    true]
    - ["re1651_mod_match",      __dict__.__contains__, ["match"],      true]
    - ["re1651_mod_search",     __dict__.__contains__, ["search"],     true]
    - ["re1651_mod_fullmatch",  __dict__.__contains__, ["fullmatch"],  true]
    - ["re1651_mod_findall",    __dict__.__contains__, ["findall"],    true]
    - ["re1651_mod_finditer",   __dict__.__contains__, ["finditer"],   true]
    - ["re1651_mod_sub",        __dict__.__contains__, ["sub"],        true]
    - ["re1651_mod_subn",       __dict__.__contains__, ["subn"],       true]
    - ["re1651_mod_split",      __dict__.__contains__, ["split"],      true]
    - ["re1651_mod_escape",     __dict__.__contains__, ["escape"],     true]
    - ["re1651_mod_purge",      __dict__.__contains__, ["purge"],      true]
    - ["re1651_mod_error",      __dict__.__contains__, ["error"],      true]
    - ["re1651_mod_Pattern",    __dict__.__contains__, ["Pattern"],    true]
    - ["re1651_mod_Match",      __dict__.__contains__, ["Match"],      true]
    - ["re1651_mod_RegexFlag",  __dict__.__contains__, ["RegexFlag"],  true]
