spec: pathlib_extra661
backend: python_module(pathlib)
description: "pathlib.Path and pathlib.PurePath additional property descriptor checks"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __doc__ class identity and __qualname__ values for Path and PurePath methods"]
  created_at: "2026-04-12T00:00:00Z"

table pathlib_extra661.path_doc_class_names:
  description: "pathlib.Path method __doc__.__class__.__name__ identity"
  kind: python_call_eq
  category: doc_class_name_identity
  id_prefix: pl661dc
  columns: [id, function, args, expected]
  rows:
    - [pl661dc001, "pathlib.Path.stat.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [pl661dc002, "pathlib.Path.exists.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [pl661dc003, "pathlib.Path.glob.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [pl661dc004, "pathlib.Path.open.__doc__.__class__.__name__.__eq__", ["str"], true]

table pathlib_extra661.path_qualnames:
  description: "pathlib.Path method __qualname__ identity"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: pl661pq
  columns: [id, function, args, expected]
  rows:
    - [pl661pq001, "pathlib.Path.rglob.__qualname__.__eq__", ["Path.rglob"], true]
    - [pl661pq002, "pathlib.Path.walk.__qualname__.__eq__", ["Path.walk"], true]
    - [pl661pq003, "pathlib.Path.samefile.__qualname__.__eq__", ["Path.samefile"], true]
    - [pl661pq004, "pathlib.Path.owner.__qualname__.__eq__", ["Path.owner"], true]
    - [pl661pq005, "pathlib.Path.group.__qualname__.__eq__", ["Path.group"], true]

table pathlib_extra661.purepath_qualnames:
  description: "pathlib.PurePath method __qualname__ identity"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: pl661uq
  columns: [id, function, args, expected]
  rows:
    - [pl661uq001, "pathlib.PurePath.match.__qualname__.__eq__", ["PurePath.match"], true]
    - [pl661uq002, "pathlib.PurePath.full_match.__qualname__.__eq__", ["PurePath.full_match"], true]
    - [pl661uq003, "pathlib.PurePath.with_segments.__qualname__.__eq__", ["PurePath.with_segments"], true]
    - [pl661uq004, "pathlib.PurePath.with_stem.__qualname__.__eq__", ["PurePath.with_stem"], true]
