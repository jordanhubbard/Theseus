spec: pathlib_extra209
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "pathlib_extra208.zspec.zsdl — covers pathlib.__name__, pathlib.__package__, pathlib.__spec__.name, pathlib.__loader__.__class__.__name__, pathlib.__doc__.__class__.__name__"
  notes:
    - "This spec covers pathlib.__spec__ deeper attributes: name, has_location, parent, __class__.__name__, and submodule_search_locations.__class__.__name__."
    - "pathlib.__spec__.name == 'pathlib'; the ModuleSpec name matches the module name; confirmed Python 3.14.3 macOS."
    - "pathlib.__spec__.has_location == True; pathlib is a pure-Python package loaded from a file on disk; confirmed Python 3.14.3 macOS."
    - "pathlib.__spec__.parent == 'pathlib'; pathlib is a package, so __spec__.parent equals the package name; confirmed Python 3.14.3 macOS."
    - "pathlib.__spec__.__class__.__name__ == 'ModuleSpec'; all module specs are ModuleSpec instances; confirmed Python 3.14.3 macOS."
    - "pathlib.__spec__.submodule_search_locations.__class__.__name__ == 'list'; packages have a submodule_search_locations list; confirmed Python 3.14.3 macOS."
    - "pathlib is a package (directory with __init__.py), so has_location is True and submodule_search_locations is a list with one entry."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib.__spec__.name identity
# name == 'pathlib', length == 7
# ---------------------------------------------------------------------------

table pathlib_extra209.spec_name:
  description: "pathlib.__spec__.name attribute identity: value, equality, and length"
  kind: python_call_eq
  category: spec_identity
  id_prefix: pathlibspec209

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,        pathlib.__spec__.name.__eq__,   ["pathlib"], true,  "pathlib.__spec__.name == 'pathlib'; the ModuleSpec name matches the module name; confirmed Python 3.14.3 macOS"]
    - [name_len,       pathlib.__spec__.name.__len__,  [],          7,     "pathlib.__spec__.name.__len__() == 7; 'pathlib' has p(1)a(2)t(3)h(4)l(5)i(6)b(7); confirmed Python 3.14.3 macOS"]
    - [name_not_path,  pathlib.__spec__.name.__eq__,   ["path"],    false, "pathlib.__spec__.name != 'path'; the full package name includes the 'lib' suffix; confirmed Python 3.14.3 macOS"]
    - [name_not_empty, pathlib.__spec__.name.__eq__,   [""],        false, "pathlib.__spec__.name is not empty string; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: pathlib.__spec__.has_location and pathlib.__spec__.parent
# has_location == True (file-based package), parent == 'pathlib' (is a package)
# ---------------------------------------------------------------------------

table pathlib_extra209.spec_has_location_and_parent:
  description: "pathlib.__spec__.has_location and pathlib.__spec__.parent attribute identity"
  kind: python_call_eq
  category: spec_identity
  id_prefix: pathlibspec209

  columns: [id, function, args, expected, description]
  rows:
    - [has_location_true,      pathlib.__spec__.has_location.__eq__,   [true],      true,  "pathlib.__spec__.has_location == True; pathlib is a pure-Python package loaded from disk; confirmed Python 3.14.3 macOS"]
    - [has_location_not_false, pathlib.__spec__.has_location.__eq__,   [false],     false, "pathlib.__spec__.has_location != False; pathlib has a file location; confirmed Python 3.14.3 macOS"]
    - [parent_eq,              pathlib.__spec__.parent.__eq__,         ["pathlib"], true,  "pathlib.__spec__.parent == 'pathlib'; pathlib is a package, __spec__.parent equals the package name; confirmed Python 3.14.3 macOS"]
    - [parent_len,             pathlib.__spec__.parent.__len__,        [],          7,     "pathlib.__spec__.parent.__len__() == 7; 'pathlib' has p(1)a(2)t(3)h(4)l(5)i(6)b(7); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: pathlib.__spec__.__class__.__name__ and submodule_search_locations class name
# __class__.__name__ == 'ModuleSpec', submodule_search_locations.__class__.__name__ == 'list'
# ---------------------------------------------------------------------------

table pathlib_extra209.spec_class_and_submodule:
  description: "pathlib.__spec__.__class__.__name__ and submodule_search_locations.__class__.__name__ identity"
  kind: python_call_eq
  category: spec_identity
  id_prefix: pathlibspec209

  columns: [id, function, args, expected, description]
  rows:
    - [class_name_eq,     pathlib.__spec__.__class__.__name__.__eq__,                                  ["ModuleSpec"], true,  "pathlib.__spec__.__class__.__name__ == 'ModuleSpec'; all module specs are ModuleSpec instances; confirmed Python 3.14.3 macOS"]
    - [class_name_len,    pathlib.__spec__.__class__.__name__.__len__,                                 [],             10,    "pathlib.__spec__.__class__.__name__.__len__() == 10; 'ModuleSpec' has 10 characters; confirmed Python 3.14.3 macOS"]
    - [ssl_class_name_eq, "pathlib.__spec__.submodule_search_locations.__class__.__name__.__eq__",     ["list"],       true,  "pathlib.__spec__.submodule_search_locations.__class__.__name__ == 'list'; packages have a list for submodule_search_locations; confirmed Python 3.14.3 macOS"]
    - [ssl_class_name_len, "pathlib.__spec__.submodule_search_locations.__class__.__name__.__len__",   [],             4,     "pathlib.__spec__.submodule_search_locations.__class__.__name__.__len__() == 4; 'list' has l(1)i(2)s(3)t(4); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra209.spec_name_eq:
  description: "pathlib.__spec__.name == 'pathlib' — the ModuleSpec name matches the module name; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: pathlib.__spec__.name.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra209.spec_name_len:
  description: "pathlib.__spec__.name.__len__() == 7 — 'pathlib' has p(1)a(2)t(3)h(4)l(5)i(6)b(7); confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: pathlib.__spec__.name.__len__
  args: []
  expected: 7

invariant pathlib_extra209.spec_has_location_true:
  description: "pathlib.__spec__.has_location == True — pathlib is a pure-Python package loaded from disk; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: pathlib.__spec__.has_location.__eq__
  args: [true]
  expected: true

invariant pathlib_extra209.spec_parent_eq:
  description: "pathlib.__spec__.parent == 'pathlib' — pathlib is a package, __spec__.parent equals the package name; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: pathlib.__spec__.parent.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra209.spec_parent_len:
  description: "pathlib.__spec__.parent.__len__() == 7 — 'pathlib' has seven characters; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: pathlib.__spec__.parent.__len__
  args: []
  expected: 7

invariant pathlib_extra209.spec_class_name_eq:
  description: "pathlib.__spec__.__class__.__name__ == 'ModuleSpec' — all module specs are ModuleSpec instances; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: pathlib.__spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant pathlib_extra209.spec_class_name_len:
  description: "pathlib.__spec__.__class__.__name__.__len__() == 10 — 'ModuleSpec' has 10 characters; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: pathlib.__spec__.__class__.__name__.__len__
  args: []
  expected: 10

invariant pathlib_extra209.spec_ssl_class_name_eq:
  description: "pathlib.__spec__.submodule_search_locations.__class__.__name__ == 'list' — packages have a list for submodule_search_locations; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: "pathlib.__spec__.submodule_search_locations.__class__.__name__.__eq__"
  args: ["list"]
  expected: true
