    - [exec_module_eq,
       Executor.__module__.__eq__,
       ["concurrent.futures._base"],
       true,
       "concurrent.futures.Executor.__module__.__eq__('concurrent.futures._base') == True — Executor is defined in the private _base submodule of concurrent.futures; its __module__ is 'concurrent.futures._base'; str.__eq__('concurrent.futures._base') returns True; new to extra178"]
    - [exec_qualname_eq,
       Executor.__qualname__.__eq__,
       ["Executor"],
       true,
       "concurrent.futures.Executor.__qualname__.__eq__('Executor') == True — Executor is a top-level class in concurrent.futures._base so its __qualname__ equals its __name__; str.__eq__('Executor') returns True; new to extra178"]
    - [exec_mro_len_2,
       Executor.__mro__.__len__,
       [],
       2,
       "concurrent.futures.Executor.__mro__.__len__() == 2 — MRO is [Executor, object]; Executor directly inherits from object with no intermediate classes; tuple.__len__() returns 2; new to extra178"]

