spec: struct_extra59
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra58.zspec.zsdl — covers struct.__doc__.__contains__('struct') / error.__doc__.__class__.__name__.__eq__('NoneType') / pack.__doc__.__class__.__name__.__eq__('str') / unpack.__doc__.__contains__('format') (table + invariants)."
    - "struct_extra57.zspec.zsdl — covers struct.__doc__.__class__.__name__.__eq__('str') / Struct.__doc__.__contains__('Struct') / Struct.__doc__.__contains__('fmt') / error.__doc__.__class__.__name__.__len__()==8 / pack.__doc__.__contains__('format') (table + invariants)."
    - "struct_extra56.zspec.zsdl — covers Struct.__init_subclass__/__subclasshook__/__getattribute__/__delattr__/__setattr__ __qualname__.__eq__ string values (table + invariants)."
    - "struct_extra55.zspec.zsdl — covers struct.__spec__.origin.__class__.__name__.__eq__('str') / submodule_search_locations.__class__.__name__.__eq__('NoneType') / has_location==True / __loader__.__class__.__name__.__len__()==16 (table + invariants)."
    - "struct_extra54.zspec.zsdl — covers struct.__loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__.__class__.__name__.__eq__('str') / __cached__.__class__.__name__.__eq__('str') (table + invariant)."
    - "struct_extra41.zspec.zsdl — covers Struct.size/__name__.__eq__('size') and Struct.format/__name__/__qualname__.__eq__; Struct.size/format __class__.__name__.__eq__('getset_descriptor')."
    - "struct_extra11.zspec.zsdl — covers struct.error.__module__.__eq__('struct') and Struct.__module__.__eq__('_struct') as standalone invariants."
    - "struct_extra8.zspec.zsdl — covers function __module__ (all '_struct' except error 'struct'); pack return type/length for '>I'/'>H'; calcsize('>IHB'); unpack('>H',0100); Struct('>IHB') format/size; calcsize('>Q')."
    - "struct.zspec — covers struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra58; it does NOT duplicate invariants present in those files."
    - "Wave 230 theme: __code__ deep chains for Python functions + docstring content for C extension types."
    - "struct module-level functions (pack, unpack, pack_into, unpack_from, iter_unpack, calcsize) are all C builtin_function_or_method objects from _struct — they do NOT have __code__ attributes. struct.Struct is a C extension type. The __code__ deep chain theme for wave 230 therefore applies to docstring content checks for struct."
    - "struct.unpack.__doc__ contains 'unpack' — the docstring begins 'Return a tuple containing values unpacked...' and the word 'unpacked' (containing 'unpack') appears in the first sentence. struct_extra58 checks unpack.__doc__.__contains__('format') (wave 229). This spec checks 'unpack' — a different keyword not yet checked in any prior struct spec. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__doc__ contains 'tuple' — the docstring begins 'Return a tuple containing values unpacked...' The word 'tuple' appears in the first sentence. No prior struct spec checks unpack.__doc__.__contains__('tuple'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__doc__ contains 'size' — the docstring is 'Return size in bytes of the struct described by the format string.' The word 'size' appears in the first position after 'Return'. No prior struct spec checks calcsize.__doc__.__contains__('size'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__doc__ contains 'format' — the docstring ends '...described by the format string.' The word 'format' appears in the docstring. No prior struct spec checks calcsize.__doc__.__contains__('format'). struct_extra57 checks pack.__doc__.__contains__('format') and struct_extra58 checks unpack.__doc__.__contains__('format'), but neither checks calcsize. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__doc__ does NOT contain 'pack' — the Struct C type docstring is 'Struct(fmt) --> compiled struct object\\n\\n'. The abbreviation 'fmt' is used (not 'format'), and there is no mention of 'pack'. struct_extra57 already checks __contains__('fmt') and __contains__('Struct'). This spec checks 'compiled' and 'object', words present in the Struct docstring that have not been checked in any prior struct spec."
    - "struct.pack.__doc__.__len__() == 176 — the pack C builtin docstring has exactly 176 characters. No prior struct spec checks pack.__doc__.__len__(). This provides a length anchor complementary to the content anchor (pack.__doc__.__contains__('format') in struct_extra57) and the type identity anchor (pack.__doc__.__class__.__name__.__eq__('str') in struct_extra58). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.unpack __doc__ content checks — 'unpack' and 'tuple'
#
# Wave 230 theme: docstring content for C extension types.
#
# struct.unpack.__doc__ begins 'Return a tuple containing values unpacked
# according to the format string.' Both 'tuple' and 'unpack' (as 'unpacked')
# appear in the first sentence. struct_extra58 checks
# unpack.__doc__.__contains__('format') (wave 229). This spec adds checks for
# 'unpack' and 'tuple', two additional keywords not yet covered.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra59.unpack_doc_contains:
  description: "struct.unpack.__doc__.__contains__('unpack') and __contains__('tuple') — C builtin docstring begins 'Return a tuple containing values unpacked according to the format string.'; 'unpacked' contains 'unpack' and 'tuple' appears in the first sentence; struct_extra58 checks __contains__('format') (wave 229); no prior struct spec checks unpack.__doc__.__contains__('unpack') or __contains__('tuple'); complementary doc content checks for unpack"
  kind: python_call_eq
  category: docstrings
  id_prefix: structdoc2_59

  columns: [id, function, args, expected]
  rows:
    - [unpack_doc_contains_unpack, unpack.__doc__.__contains__, ["unpack"], true]
    - [unpack_doc_contains_tuple,  unpack.__doc__.__contains__, ["tuple"],  true]

# ---------------------------------------------------------------------------
# struct.calcsize __doc__ content checks — 'size' and 'format'
#
# Wave 230 theme: docstring content for C extension types.
#
# struct.calcsize.__doc__ is 'Return size in bytes of the struct described by
# the format string.' Both 'size' and 'format' appear in this one-sentence
# docstring. struct_extra57 checks pack.__doc__.__contains__('format') and
# struct_extra58 checks unpack.__doc__.__contains__('format') — neither checks
# calcsize. No prior struct spec checks calcsize.__doc__.__contains__ for any
# keyword. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra59.calcsize_doc_contains:
  description: "struct.calcsize.__doc__.__contains__('size') and __contains__('format') — C builtin docstring is 'Return size in bytes of the struct described by the format string.'; 'size' and 'format' both appear in this one-sentence docstring; struct_extra57 checks pack.__doc__.__contains__('format') but not calcsize; struct_extra58 checks unpack.__doc__.__contains__('format') but not calcsize; no prior struct spec checks calcsize.__doc__.__contains__ for any keyword"
  kind: python_call_eq
  category: docstrings
  id_prefix: structdoc2_59

  columns: [id, function, args, expected]
  rows:
    - [calcsize_doc_contains_size,   calcsize.__doc__.__contains__, ["size"],   true]
    - [calcsize_doc_contains_format, calcsize.__doc__.__contains__, ["format"], true]

# ---------------------------------------------------------------------------
# struct.Struct __doc__ content checks — 'compiled' and 'object'
#
# Wave 230 theme: docstring content for C extension types.
#
# struct.Struct.__doc__ is 'Struct(fmt) --> compiled struct object\n\n'.
# The words 'compiled' and 'object' both appear in this docstring.
# struct.Struct.__doc__ does NOT contain 'pack'. struct_extra57 checks
# __contains__('Struct') and __contains__('fmt'). This spec adds checks for
# 'compiled' and 'object', two additional keywords not covered in any prior
# struct spec. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra59.Struct_doc_contains:
  description: "struct.Struct.__doc__.__contains__('compiled') and __contains__('object') — C extension type docstring is 'Struct(fmt) --> compiled struct object\\n\\n'; 'compiled' and 'object' both appear in the docstring; struct_extra57 checks __contains__('Struct') and __contains__('fmt'); struct.Struct.__doc__ does NOT contain 'pack'; no prior struct spec checks Struct.__doc__.__contains__('compiled') or __contains__('object')"
  kind: python_call_eq
  category: docstrings
  id_prefix: structdoc2_59

  columns: [id, function, args, expected]
  rows:
    - [Struct_doc_contains_compiled, "Struct.__doc__.__contains__", ["compiled"], true]
    - [Struct_doc_contains_object,   "Struct.__doc__.__contains__", ["object"],   true]

# ---------------------------------------------------------------------------
# struct.pack __doc__ length anchor
#
# struct.pack is a C builtin_function_or_method. Its docstring has exactly
# 176 characters. No prior struct spec checks pack.__doc__.__len__(). This
# provides a length anchor complementary to the content anchor in
# struct_extra57 (pack.__doc__.__contains__('format')) and the type identity
# anchor in struct_extra58 (pack.__doc__.__class__.__name__.__eq__('str')).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra59.pack_doc_len:
  description: "struct.pack.__doc__.__len__()==176 — C builtin_function_or_method docstring has exactly 176 characters; struct_extra57 checks pack.__doc__.__contains__('format') (content anchor); struct_extra58 checks pack.__doc__.__class__.__name__.__eq__('str') (type identity anchor); no prior struct spec checks pack.__doc__.__len__(); complementary length anchor for pack docstring"
  kind: python_call_eq
  category: docstrings
  id_prefix: structdoc2_59

  columns: [id, function, args, expected]
  rows:
    - [pack_doc_len_176, pack.__doc__.__len__, [], 176]

# ---------------------------------------------------------------------------
# struct.unpack.__doc__.__contains__('unpack') — standalone
#
# struct.unpack is a C builtin_function_or_method from _struct. Its docstring
# begins 'Return a tuple containing values unpacked according to the format
# string.' The word 'unpacked' (which contains 'unpack') is the domain term
# for this function's core operation. struct_extra58 checks
# unpack.__doc__.__contains__('format') (the format keyword axis). No prior
# struct spec checks unpack.__doc__.__contains__('unpack'). First 'unpack'
# content anchor for struct.unpack's docstring. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant struct_extra59.unpack_doc_contains_unpack:
  description: "struct.unpack.__doc__.__contains__('unpack') == True — C builtin docstring begins 'Return a tuple containing values unpacked according to the format string.'; 'unpacked' contains 'unpack' — the core domain term for this function; struct_extra58 checks __contains__('format') (format keyword axis); no prior struct spec checks unpack.__doc__.__contains__('unpack'); first 'unpack' content anchor for struct.unpack's docstring"
  category: docstrings
  kind: python_call_eq
  function: unpack.__doc__.__contains__
  args: ["unpack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.calcsize.__doc__.__contains__('size') — standalone
#
# struct.calcsize is a C builtin_function_or_method. Its docstring is 'Return
# size in bytes of the struct described by the format string.' The word 'size'
# is the first content word after 'Return' and is the core concept of the
# function (it returns the size of a packed struct). No prior struct spec
# checks calcsize.__doc__.__contains__ for any keyword. First docstring content
# anchor for struct.calcsize. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra59.calcsize_doc_contains_size:
  description: "struct.calcsize.__doc__.__contains__('size') == True — C builtin docstring is 'Return size in bytes of the struct described by the format string.'; 'size' is the first content word after 'Return' and represents the core concept; no prior struct spec checks calcsize.__doc__.__contains__ for any keyword; first docstring content anchor for struct.calcsize"
  category: docstrings
  kind: python_call_eq
  function: calcsize.__doc__.__contains__
  args: ["size"]
  expected: true
