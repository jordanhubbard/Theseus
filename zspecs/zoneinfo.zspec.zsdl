spec: zoneinfo
version: ">=3.9"
backend: python_module(zoneinfo)

docs: https://docs.python.org/3/library/zoneinfo.html

provenance:
  derived_from:
    - "Python zoneinfo documentation — https://docs.python.org/3/library/zoneinfo.html"
    - "Test vectors verified by running Python 3.14.3 zoneinfo module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/zoneinfo/_common.py"
    - "tzdata package — https://pypi.org/project/tzdata/"
  notes:
    - "zoneinfo was added in Python 3.9 as the standard IANA time zone interface."
    - "available_timezones() returns a set of all IANA time zone keys available on the system."
    - "UTC is guaranteed to be present in available_timezones() on all platforms."
    - "America/New_York is present on any system with a standard IANA tzdata installation."
    - "ZoneInfoNotFoundError inherits from KeyError, not from a zoneinfo-specific base."
    - "ZoneInfo objects are cached; ZoneInfo('UTC') returns the same object on repeated calls."
    - "All expected values verified by running Python 3.14.3 zoneinfo module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "ZoneInfo() raises ZoneInfoNotFoundError (subclass of KeyError) for unknown timezone keys"
  stderr: "null"
  stickiness: "N/A"
  codes: {}

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

invariant zoneinfo.ZoneInfo.name:
  description: "zoneinfo.ZoneInfo.__name__ == 'ZoneInfo'"
  category: classes
  kind: python_call_eq
  function: ZoneInfo.__name__.__eq__
  args: ["ZoneInfo"]
  expected: true

invariant zoneinfo.ZoneInfoNotFoundError.name:
  description: "zoneinfo.ZoneInfoNotFoundError.__name__ == 'ZoneInfoNotFoundError'"
  category: classes
  kind: python_call_eq
  function: ZoneInfoNotFoundError.__name__.__eq__
  args: ["ZoneInfoNotFoundError"]
  expected: true

# ---------------------------------------------------------------------------
# Module membership
# ---------------------------------------------------------------------------

invariant zoneinfo.ZoneInfo.module:
  description: "zoneinfo.ZoneInfo.__module__ == 'zoneinfo'"
  category: classes
  kind: python_call_eq
  function: ZoneInfo.__module__.__eq__
  args: ["zoneinfo"]
  expected: true

# ---------------------------------------------------------------------------
# Function name check
# ---------------------------------------------------------------------------

invariant zoneinfo.available_timezones.name:
  description: "zoneinfo.available_timezones.__name__ == 'available_timezones'"
  category: functions
  kind: python_call_eq
  function: available_timezones.__name__.__eq__
  args: ["available_timezones"]
  expected: true

# ---------------------------------------------------------------------------
# Inheritance hierarchy
# ---------------------------------------------------------------------------

invariant zoneinfo.ZoneInfoNotFoundError.base:
  description: "zoneinfo.ZoneInfoNotFoundError.__bases__[0].__name__ == 'KeyError'"
  category: hierarchy
  kind: python_call_eq
  function: ZoneInfoNotFoundError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "KeyError"

# ---------------------------------------------------------------------------
# Behavioral — available_timezones() returns a set
# ---------------------------------------------------------------------------

invariant zoneinfo.available_timezones.returns_set:
  description: "zoneinfo.available_timezones().__class__.__name__ == 'set' — function returns a set"
  category: behavioral
  kind: python_call_eq
  function: available_timezones
  args: []
  method: __class__
  method_args: []
  method_chain: __name__
  expected: "set"

# ---------------------------------------------------------------------------
# Behavioral — known timezone keys are always present
# ---------------------------------------------------------------------------

invariant zoneinfo.available_timezones.contains_utc:
  description: "zoneinfo.available_timezones().__contains__('UTC') == True — UTC is always present"
  category: behavioral
  kind: python_call_eq
  function: available_timezones
  args: []
  method: __contains__
  method_args: ["UTC"]
  expected: true

invariant zoneinfo.available_timezones.contains_new_york:
  description: "zoneinfo.available_timezones().__contains__('America/New_York') == True"
  category: behavioral
  kind: python_call_eq
  function: available_timezones
  args: []
  method: __contains__
  method_args: ["America/New_York"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral — ZoneInfo('UTC') constructor produces a ZoneInfo instance
# ---------------------------------------------------------------------------

invariant zoneinfo.ZoneInfo.utc_instance_class:
  description: "zoneinfo.ZoneInfo('UTC').__class__.__name__ == 'ZoneInfo'"
  category: behavioral
  kind: python_call_eq
  function: ZoneInfo
  args: ["UTC"]
  method: __class__
  method_args: []
  method_chain: __name__
  expected: "ZoneInfo"
