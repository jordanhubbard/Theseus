spec: io_extra272
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/io.py"
  notes:
    - "io.IOBase.__module__ == 'io' in Python 3.14 (the abstract class is exposed via the io module namespace, not _io)."
    - "io.IOBase.__bases__[0].__name__ == '_IOBase' — the C-internal private base class underpinning IOBase."
    - "io.RawIOBase.__bases__[0].__name__ == '_RawIOBase' — C-internal private base."
    - "io.BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase' — C-internal private base."
    - "io.TextIOBase.__bases__[0].__name__ == '_TextIOBase' — C-internal private base."
    - "io.FileIO, io.BufferedReader, io.BufferedWriter are concrete C-extension classes with __module__ == '_io'."
    - "FileIO.__bases__[0].__name__ == '_RawIOBase' — concrete raw I/O inherits from the private C base."
    - "BufferedReader and BufferedWriter both have __bases__[0].__name__ == '_BufferedIOBase'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: abstract base class identity — name, module, base
# ---------------------------------------------------------------------------

table io_extra272.abstract_base_identity:
  description: "Abstract base class __name__, __module__, and __bases__[0].__name__ for IOBase, RawIOBase, BufferedIOBase, TextIOBase"
  kind: python_call_eq
  category: identity
  id_prefix: abc

  columns: [id, function, args, expected, description]
  rows:
    - [IOBase_name,         IOBase.__name__.__eq__,         ["IOBase"],         true, "io.IOBase.__name__ == 'IOBase'"]
    - [IOBase_module,       IOBase.__module__.__eq__,       ["io"],             true, "io.IOBase.__module__ == 'io'"]
    - [RawIOBase_name,      RawIOBase.__name__.__eq__,      ["RawIOBase"],      true, "io.RawIOBase.__name__ == 'RawIOBase'"]
    - [RawIOBase_module,    RawIOBase.__module__.__eq__,    ["io"],             true, "io.RawIOBase.__module__ == 'io'"]
    - [BufferedIOBase_name, BufferedIOBase.__name__.__eq__, ["BufferedIOBase"], true, "io.BufferedIOBase.__name__ == 'BufferedIOBase'"]
    - [BufferedIOBase_mod,  BufferedIOBase.__module__.__eq__, ["io"],           true, "io.BufferedIOBase.__module__ == 'io'"]
    - [TextIOBase_name,     TextIOBase.__name__.__eq__,     ["TextIOBase"],     true, "io.TextIOBase.__name__ == 'TextIOBase'"]
    - [TextIOBase_module,   TextIOBase.__module__.__eq__,   ["io"],             true, "io.TextIOBase.__module__ == 'io'"]

# ---------------------------------------------------------------------------
# Table: concrete class identity — name, module, base class name
# ---------------------------------------------------------------------------

table io_extra272.concrete_class_identity:
  description: "Concrete class __name__, __module__ for FileIO, BufferedReader, BufferedWriter"
  kind: python_call_eq
  category: identity
  id_prefix: conc

  columns: [id, function, args, expected, description]
  rows:
    - [FileIO_name,          FileIO.__name__.__eq__,         ["FileIO"],         true, "io.FileIO.__name__ == 'FileIO'"]
    - [FileIO_module,        FileIO.__module__.__eq__,       ["_io"],            true, "io.FileIO.__module__ == '_io' (C extension)"]
    - [BufferedReader_name,  BufferedReader.__name__.__eq__, ["BufferedReader"], true, "io.BufferedReader.__name__ == 'BufferedReader'"]
    - [BufferedReader_mod,   BufferedReader.__module__.__eq__, ["_io"],          true, "io.BufferedReader.__module__ == '_io' (C extension)"]
    - [BufferedWriter_name,  BufferedWriter.__name__.__eq__, ["BufferedWriter"], true, "io.BufferedWriter.__name__ == 'BufferedWriter'"]
    - [BufferedWriter_mod,   BufferedWriter.__module__.__eq__, ["_io"],          true, "io.BufferedWriter.__module__ == '_io' (C extension)"]

# ---------------------------------------------------------------------------
# Standalone invariants: __bases__[0].__name__ for abstract base classes
# ---------------------------------------------------------------------------

invariant io_extra272.IOBase.base_name:
  description: "io.IOBase.__bases__[0].__name__ == '_IOBase' — C-internal private base underpins IOBase"
  category: identity
  kind: python_call_eq
  function: "IOBase.__bases__[0].__name__.__eq__"
  args: ["_IOBase"]
  expected: true

invariant io_extra272.RawIOBase.base_name:
  description: "io.RawIOBase.__bases__[0].__name__ == '_RawIOBase' — C-internal private base underpins RawIOBase"
  category: identity
  kind: python_call_eq
  function: "RawIOBase.__bases__[0].__name__.__eq__"
  args: ["_RawIOBase"]
  expected: true

invariant io_extra272.BufferedIOBase.base_name:
  description: "io.BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase' — C-internal private base underpins BufferedIOBase"
  category: identity
  kind: python_call_eq
  function: "BufferedIOBase.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra272.TextIOBase.base_name:
  description: "io.TextIOBase.__bases__[0].__name__ == '_TextIOBase' — C-internal private base underpins TextIOBase"
  category: identity
  kind: python_call_eq
  function: "TextIOBase.__bases__[0].__name__.__eq__"
  args: ["_TextIOBase"]
  expected: true

invariant io_extra272.FileIO.base_name:
  description: "io.FileIO.__bases__[0].__name__ == '_RawIOBase' — FileIO inherits from the C-internal raw base"
  category: identity
  kind: python_call_eq
  function: "FileIO.__bases__[0].__name__.__eq__"
  args: ["_RawIOBase"]
  expected: true

invariant io_extra272.BufferedReader.base_name:
  description: "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' — BufferedReader inherits from C-internal buffered base"
  category: identity
  kind: python_call_eq
  function: "BufferedReader.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra272.BufferedWriter.base_name:
  description: "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' — BufferedWriter inherits from C-internal buffered base"
  category: identity
  kind: python_call_eq
  function: "BufferedWriter.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true
