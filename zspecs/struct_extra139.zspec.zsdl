spec: struct_extra139
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra138.zspec.zsdl — covers Struct method __qualname__ string equality (pack/unpack/pack_into/unpack_from/iter_unpack) / __qualname__ length ordering / error.__name__/__qualname__/__bases__[0].__name__/__bases__[0].__name__.__len__() (table + invariants)."
    - "struct_extra137.zspec.zsdl — covers struct.pack/__doc__/__class__.__name__.__eq__('str') / Struct.format/__doc__/__len__()==20 / Struct.size/__doc__/__len__()==20 / format vs size __doc__ inequality / module function __doc__ length ordering (calcsize/unpack/pack/pack_into)."
    - "struct_extra136.zspec.zsdl — covers struct.Struct method __doc__ lengths (pack/pack_into/unpack/unpack_from/iter_unpack) / module-level pack_into/unpack_from/iter_unpack __doc__ lengths / module-level vs Struct-method __doc__ inequality."
    - "struct_extra135.zspec.zsdl — covers struct.Struct.__eq__ inherited from object / struct.error MRO member names / struct module-level function __doc__ lengths (pack/unpack/calcsize) / struct.__doc__.__len__() and __class__.__name__."
    - "struct_extra134.zspec.zsdl — covers struct.__spec__ and __loader__ attribute identity / Struct method __doc__ lengths / Struct class __doc__ identity."
    - "struct_extra99.zspec.zsdl — covers struct module-level function __doc__ lengths (all six) / Struct.size and Struct.format __doc__ equality and lengths / struct module __doc__ length."
    - "struct_extra98.zspec.zsdl — covers Struct.size/__format__ getset_descriptor class names and qualnames."
    - "struct_extra97.zspec.zsdl — covers struct module __spec__/__loader__ attribute lengths / Struct/__module__/__len__()==7 / error/__module__/__len__()==6."
    - "struct_extra96.zspec.zsdl — covers Struct method __name__.__len__() / module-level function __name__.__len__() / Struct.__name__/__len__() / error.__name__/__len__()."
    - "struct_extra95.zspec.zsdl — covers struct.pack_into/unpack_from/iter_unpack __qualname__.__len__() / Struct.__qualname__.__len__()==6 / error.__qualname__.__len__()==5."
    - "struct_extra94.zspec.zsdl — covers Struct method __qualname__.__len__() / struct.error MRO depth / module-level function __qualname__.__len__()."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / Struct.format/__qualname__ / error __bases__ and __module__ / Struct __module__/__qualname__/__bases__/__mro__.__len__()==2."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra138."
    - "Wave 300 theme: struct module-level function __qualname__ string equality (pack/unpack/calcsize/pack_into/unpack_from/iter_unpack) / module-level function __module__ == '_struct' for all six / full __doc__ length ordering (calcsize=66 < unpack=173 < pack=176 < unpack_from=188 < iter_unpack=239 < pack_into=274) / struct.Struct.__module__ == '_struct' (same as module-level functions)."
    - "struct.pack.__qualname__ == 'pack' (len 4). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__qualname__ == 'unpack' (len 6). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__qualname__ == 'calcsize' (len 8). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__qualname__ == 'pack_into' (len 9). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__qualname__ == 'unpack_from' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__qualname__ == 'iter_unpack' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__module__ == '_struct' (len 7). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__module__ == '_struct' (same as module-level functions). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Full __doc__ length ordering: calcsize(66) < unpack(173) < pack(176) < unpack_from(188) < iter_unpack(239) < pack_into(274). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: All six module-level struct functions (pack/unpack/calcsize/pack_into/unpack_from/iter_unpack) and the Struct class all have __module__ == '_struct' (7 chars, with underscore prefix). This is the private C extension backing struct; extra97 anchors Struct/__module__/__len__()==7 at module level; this spec anchors the equality string and the individual function module identity."
    - "Note: Module-level function qualnames are simple (not class-qualified): pack='pack' (4), unpack='unpack' (6), calcsize='calcsize' (8), pack_into='pack_into' (9), unpack_from/iter_unpack='...' (both 11). extra94/95 anchor the __len__() values; this spec anchors the equality strings."
    - "Note: The complete __doc__ length ordering is calcsize(66) < unpack(173) < pack(176) < unpack_from(188) < iter_unpack(239) < pack_into(274). extra137 anchors the sub-ordering for calcsize/unpack/pack/pack_into; unpack_from(188) and iter_unpack(239) slot in between pack(176) and pack_into(274), giving the complete 6-element ordering."
    - "Note: unpack_from (188) is 15 chars longer than pack (176) because it also documents the optional offset parameter and the buffer-size constraint 'minus offset'. iter_unpack (239) is longer still (239) because it documents the iterator protocol and the length-divisibility requirement."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack.__qualname__.__eq__('pack')
# struct.unpack.__qualname__.__eq__('unpack')
# struct.calcsize.__qualname__.__eq__('calcsize')
# struct.pack_into.__qualname__.__eq__('pack_into')
# struct.unpack_from.__qualname__.__eq__('unpack_from')
# struct.iter_unpack.__qualname__.__eq__('iter_unpack')
#
# Wave 300 theme: module-level function __qualname__ string equality.
#
# All six module-level struct functions have simple (non-class-qualified) qualnames
# equal to their __name__ because they are module-level C functions.
# extra94/95 anchor the __qualname__.__len__() values; no prior struct spec anchors
# all six qualname equality strings as a single table under structfn139.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra139.module_function_qualname_equality:
  description: "struct.pack/__qualname__.__eq__('pack')==True / unpack/__qualname__.__eq__('unpack')==True / calcsize/__qualname__.__eq__('calcsize')==True / pack_into/__qualname__.__eq__('pack_into')==True / unpack_from/__qualname__.__eq__('unpack_from')==True / iter_unpack/__qualname__.__eq__('iter_unpack')==True — all six have simple (non-class-qualified) qualnames equal to __name__; module-level C functions from _struct; extra94/95 anchor lengths; first structfn139 anchor for all six equality strings"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: structfn139

  columns: [id, function, args, expected, description]
  rows:
    - [pack_qualname_eq,        pack.__qualname__.__eq__,        ["pack"],        true, "struct.pack.__qualname__ == 'pack' (4 chars; shortest module-level qualname)"]
    - [unpack_qualname_eq,      unpack.__qualname__.__eq__,      ["unpack"],      true, "struct.unpack.__qualname__ == 'unpack' (6 chars)"]
    - [calcsize_qualname_eq,    calcsize.__qualname__.__eq__,    ["calcsize"],    true, "struct.calcsize.__qualname__ == 'calcsize' (8 chars)"]
    - [pack_into_qualname_eq,   pack_into.__qualname__.__eq__,   ["pack_into"],   true, "struct.pack_into.__qualname__ == 'pack_into' (9 chars)"]
    - [unpack_from_qualname_eq, unpack_from.__qualname__.__eq__, ["unpack_from"], true, "struct.unpack_from.__qualname__ == 'unpack_from' (11 chars; ties with iter_unpack)"]
    - [iter_unpack_qualname_eq, iter_unpack.__qualname__.__eq__, ["iter_unpack"], true, "struct.iter_unpack.__qualname__ == 'iter_unpack' (11 chars; ties with unpack_from)"]

# ---------------------------------------------------------------------------
# struct.pack.__module__.__eq__('_struct')
# struct.unpack.__module__.__eq__('_struct')
# struct.calcsize.__module__.__eq__('_struct')
# struct.pack_into.__module__.__eq__('_struct')
# struct.unpack_from.__module__.__eq__('_struct')
# struct.iter_unpack.__module__.__eq__('_struct')
# struct.Struct.__module__.__eq__('_struct')
#
# Wave 300 theme: all six module-level functions and Struct class share _struct module.
#
# '_struct' (7 chars, with underscore prefix) is the private C extension backing
# struct. extra97 anchors Struct.__module__.__len__()==7; no prior struct spec
# anchors the equality string '__struct' for individual functions as a table
# under structfn139. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra139.module_function_module_identity:
  description: "struct.pack/__module__.__eq__('_struct')==True / unpack/__module__.__eq__('_struct')==True / calcsize/__module__.__eq__('_struct')==True / pack_into/__module__.__eq__('_struct')==True / unpack_from/__module__.__eq__('_struct')==True / iter_unpack/__module__.__eq__('_struct')==True / Struct/__module__.__eq__('_struct')==True — all seven come from the _struct C extension (7 chars); extra97 anchors Struct/__module__/__len__()==7; first structfn139 anchor for function module equality strings"
  kind: python_call_eq
  category: identity
  id_prefix: structfn139

  columns: [id, function, args, expected, description]
  rows:
    - [pack_module_eq,        pack.__module__.__eq__,        ["_struct"], true, "struct.pack.__module__ == '_struct' (private C extension backing struct)"]
    - [unpack_module_eq,      unpack.__module__.__eq__,      ["_struct"], true, "struct.unpack.__module__ == '_struct' (same _struct C extension)"]
    - [calcsize_module_eq,    calcsize.__module__.__eq__,    ["_struct"], true, "struct.calcsize.__module__ == '_struct' (same _struct C extension)"]
    - [pack_into_module_eq,   pack_into.__module__.__eq__,   ["_struct"], true, "struct.pack_into.__module__ == '_struct' (same _struct C extension)"]
    - [unpack_from_module_eq, unpack_from.__module__.__eq__, ["_struct"], true, "struct.unpack_from.__module__ == '_struct' (same _struct C extension)"]
    - [iter_unpack_module_eq, iter_unpack.__module__.__eq__, ["_struct"], true, "struct.iter_unpack.__module__ == '_struct' (same _struct C extension)"]
    - [Struct_module_eq,      Struct.__module__.__eq__,      ["_struct"], true, "struct.Struct.__module__ == '_struct' (class and functions share the _struct C extension)"]

# ---------------------------------------------------------------------------
# Full __doc__ length ordering:
# calcsize(66) < unpack(173) < pack(176) < unpack_from(188) < iter_unpack(239) < pack_into(274)
#
# Wave 300 theme: complete 6-element __doc__ length ordering.
#
# extra137 anchors the sub-ordering calcsize < unpack < pack < pack_into. This table
# anchors unpack_from (188) and iter_unpack (239), which slot between pack (176) and
# pack_into (274), completing the full 6-element ordering. No prior struct spec
# anchors the complete 6-element ordering as a table under structfn139.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra139.full_doc_length_ordering:
  description: "struct.calcsize/__doc__/__len__()==66 / unpack/__doc__/__len__()==173 / pack/__doc__/__len__()==176 / unpack_from/__doc__/__len__()==188 / iter_unpack/__doc__/__len__()==239 / pack_into/__doc__/__len__()==274 — complete 6-element ordering: calcsize(66) < unpack(173) < pack(176) < unpack_from(188) < iter_unpack(239) < pack_into(274); extra137 anchors the sub-ordering for calcsize/unpack/pack/pack_into; unpack_from/iter_unpack complete the ordering; first structfn139 anchor for the full 6-element ordering"
  kind: python_call_eq
  category: doc_lengths
  id_prefix: structfn139

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_doc_len,    calcsize.__doc__.__len__,    [], 66,  "struct.calcsize.__doc__.__len__() is 66 (shortest; one sentence)"]
    - [unpack_doc_len,      unpack.__doc__.__len__,      [], 173, "struct.unpack.__doc__.__len__() is 173 (second; documents buffer size constraint)"]
    - [pack_doc_len,        pack.__doc__.__len__,        [], 176, "struct.pack.__doc__.__len__() is 176 (third; 3 chars longer than unpack)"]
    - [unpack_from_doc_len, unpack_from.__doc__.__len__, [], 188, "struct.unpack_from.__doc__.__len__() is 188 (fourth; documents offset parameter and buffer-size-minus-offset constraint)"]
    - [iter_unpack_doc_len, iter_unpack.__doc__.__len__, [], 239, "struct.iter_unpack.__doc__.__len__() is 239 (fifth; documents iterator protocol and length-divisibility requirement)"]
    - [pack_into_doc_len,   pack_into.__doc__.__len__,   [], 274, "struct.pack_into.__doc__.__len__() is 274 (longest; documents buffer, offset, and that offset is required)"]

# ---------------------------------------------------------------------------
# struct.pack.__qualname__.__eq__('pack') — standalone
#
# struct.pack.__qualname__ is 'pack' (4 chars). This is the shortest module-level
# function qualname in struct: 'pack' is a 4-char name with no class qualification.
# Module-level C functions have simple qualnames equal to their __name__. The
# qualname 'pack' is distinct from Struct.pack.__qualname__ ('Struct.pack', 11 chars).
# extra94 anchors pack.__qualname__.__len__()==4; no prior struct spec anchors
# pack.__qualname__ == 'pack' as a standalone under structfn139.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra139.pack_qualname_eq_pack:
  description: "struct.pack.__qualname__.__eq__('pack') == True — 'pack' (4 chars); shortest module-level function qualname; equals __name__; distinct from Struct.pack.__qualname__ ('Struct.pack', 11 chars); extra94 anchors the length; first standalone under structfn139"
  category: qualname_identity
  kind: python_call_eq
  function: pack.__qualname__.__eq__
  args: ["pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.unpack_from.__doc__.__len__()==188 — standalone
#
# struct.unpack_from.__doc__.__len__() is 188. unpack_from is the fourth-shortest
# of the six module-level function docstrings (188 chars), slotting between pack
# (176) and iter_unpack (239). It is 15 chars longer than pack (176) because it
# documents the optional offset parameter and the constraint that the buffer size
# minus offset must be at least calcsize(format). No prior struct spec anchors
# module-level unpack_from.__doc__.__len__()==188 as a standalone under structfn139.
# (extra136 anchors this at table level within a different context.)
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra139.unpack_from_doc_len_188:
  description: "struct.unpack_from.__doc__.__len__() == 188 — fourth-shortest of six; 15 chars longer than pack (176); documents offset parameter and buffer-size-minus-offset constraint; slots between pack (176) and iter_unpack (239) in the complete ordering; first standalone under structfn139"
  category: doc_lengths
  kind: python_call_eq
  function: unpack_from.__doc__.__len__
  args: []
  expected: 188

# ---------------------------------------------------------------------------
# struct.iter_unpack.__doc__.__len__()==239 — standalone
#
# struct.iter_unpack.__doc__.__len__() is 239. iter_unpack is the second-longest
# of the six module-level function docstrings (239 chars), between unpack_from (188)
# and pack_into (274). It is 51 chars longer than unpack_from because it additionally
# documents the iterator protocol, the repeated invocation of unpack_from(), and
# the requirement that the bytes length be a multiple of the format struct size.
# No prior struct spec anchors module-level iter_unpack.__doc__.__len__()==239
# as a standalone under structfn139. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra139.iter_unpack_doc_len_239:
  description: "struct.iter_unpack.__doc__.__len__() == 239 — second-longest of six; 51 chars longer than unpack_from (188); documents iterator protocol, repeated unpack_from() invocation, and length-divisibility requirement; slots between unpack_from (188) and pack_into (274); first standalone under structfn139"
  category: doc_lengths
  kind: python_call_eq
  function: iter_unpack.__doc__.__len__
  args: []
  expected: 239

# ---------------------------------------------------------------------------
# struct.pack.__module__.__eq__('_struct') — standalone
#
# struct.pack.__module__ is '_struct' (7 chars). The '_struct' C extension uses
# the standard CPython private-extension naming convention (underscore prefix + public
# name). '_struct' (7 chars) is the same length as '_blake2' (7 chars) in the hashlib
# module, but they are different extensions. All six module-level struct functions and
# the Struct class share this module. extra97 anchors Struct.__module__.__len__()==7;
# no prior struct spec anchors module-level pack.__module__ equality as a standalone
# under structfn139. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra139.pack_module_eq_struct:
  description: "struct.pack.__module__.__eq__('_struct') == True — '_struct' (7 chars); private C extension backing all six module-level functions and Struct class; same length as '_blake2' (7 chars) from hashlib; extra97 anchors Struct/__module__/__len__()==7; first standalone for function module equality under structfn139"
  category: identity
  kind: python_call_eq
  function: pack.__module__.__eq__
  args: ["_struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.iter_unpack.__qualname__.__eq__('iter_unpack') — standalone
#
# struct.iter_unpack.__qualname__ is 'iter_unpack' (11 chars). The module-level
# iter_unpack qualname ties with unpack_from (also 11 chars) as the longest
# module-level function qualname in struct. iter_unpack was added in Python 3.4
# to allow memory-efficient repeated unpacking without materializing all tuples at
# once. Its qualname 'iter_unpack' is a simple name (not class-qualified) because
# it is a module-level C function. extra95 anchors iter_unpack.__qualname__.__len__();
# no prior struct spec anchors iter_unpack.__qualname__ == 'iter_unpack' as a
# standalone under structfn139. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra139.iter_unpack_qualname_eq:
  description: "struct.iter_unpack.__qualname__.__eq__('iter_unpack') == True — 'iter_unpack' (11 chars); ties with unpack_from as longest module-level function qualname; simple (non-class-qualified) name; added in Python 3.4 for memory-efficient repeated unpacking; extra95 anchors the length; first standalone for iter_unpack qualname equality under structfn139"
  category: qualname_identity
  kind: python_call_eq
  function: iter_unpack.__qualname__.__eq__
  args: ["iter_unpack"]
  expected: true

