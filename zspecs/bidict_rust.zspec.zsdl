spec: bidict_rust
version: ">=3.9"
backend: rust_module(bidict_rust)

docs: https://bidict.readthedocs.io/

provenance:
  derived_from:
    - "https://bidict.readthedocs.io/ — bidict library documentation"
  not_derived_from:
    - "bidict source: bidict/_base.py"
  notes:
    - "bidict is a bidirectional mapping library."
    - "bidict({'a': 1, 'b': 2}).inverse[1] == 'a'."
    - "bidict({'a': 1}).inverse == {1: 'a'}."
    - "Expose bidict_get(pairs, key) -> any: bidict(dict(pairs))[key]."
    - "Expose bidict_inverse_get(pairs, val) -> any: bidict(dict(pairs)).inverse[val]."
    - "Expose bidict_len(pairs) -> int: len(bidict(dict(pairs)))."
    - "bidict({'a': 1, 'b': 2})['a'] == 1."
    - "bidict({'a': 1, 'b': 2}).inverse[2] == 'b'."
    - "len(bidict({'a': 1, 'b': 2})) == 2."
    - "All test vectors verified against bidict 0.23.1."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# bidict_get — forward lookup
table bidict_rust.forward.get:
  kind: python_call_eq
  category: forward
  id_prefix: bd_fwd
  function: bidict_get

  columns: [id, args, expected]
  rows:
    - [a,  [[["a", 1], ["b", 2]], "a"], 1]
    - [b,  [[["a", 1], ["b", 2]], "b"], 2]
    - [x,  [[["x", 10]],         "x"], 10]

# bidict_inverse_get — inverse lookup
table bidict_rust.inverse.get:
  kind: python_call_eq
  category: inverse
  id_prefix: bd_inv
  function: bidict_inverse_get

  columns: [id, args, expected]
  rows:
    - [by_1,  [[["a", 1], ["b", 2]], 1], "a"]
    - [by_2,  [[["a", 1], ["b", 2]], 2], "b"]
    - [by_10, [[["x", 10]],        10], "x"]

# bidict_len — length
invariant bidict_rust.len.two:
  description: "bidict({'a':1,'b':2}) has len 2"
  category: len
  kind: python_call_eq
  function: bidict_len
  args: [[["a", 1], ["b", 2]]]
  expected: 2

invariant bidict_rust.len.empty:
  description: "bidict({}) has len 0"
  category: len
  kind: python_call_eq
  function: bidict_len
  args: [[]]
  expected: 0

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T00:23:29Z
  iterations: 2
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 2 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
