spec: dataclasses_extra
version: ">=3.7"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "Python dataclasses documentation — https://docs.python.org/3/library/dataclasses.html"
    - "PEP 557 — Data Classes"
    - "Test vectors verified by running Python 3.14.3 dataclasses module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "Complements dataclasses.zspec.zsdl and dataclasses_field.zspec.zsdl."
    - "dataclasses.zspec.zsdl covers: type checks (function.__class__.__name__), is_dataclass false-cases, make_dataclass, MISSING/KW_ONLY sentinels."
    - "dataclasses_field.zspec.zsdl covers: field(), fields(), FrozenInstanceError name/base/module, InitVar."
    - "This spec adds __name__ checks for each public function and module membership checks."
    - "dataclasses.dataclass.__name__ is 'dataclass' — the decorator is a plain function."
    - "dataclasses.field.__name__ is 'field', fields.__name__ is 'fields', etc."
    - "All public dataclasses functions have __module__ == 'dataclasses'."
    - "dataclasses.Field.__name__ is 'Field' and __module__ is 'dataclasses'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ checks
#
# Each public dataclasses callable should have a __name__ that matches its
# exported identifier. dataclasses.zspec.zsdl checked __class__.__name__;
# here we check the function's own __name__ attribute.
# ---------------------------------------------------------------------------

table dataclasses_extra.function_names:
  description: "Public dataclasses functions have correct __name__ attributes"
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [dataclass,      dataclass.__name__.__eq__,      ["dataclass"],      true]
    - [field,          field.__name__.__eq__,           ["field"],          true]
    - [fields,         fields.__name__.__eq__,          ["fields"],         true]
    - [asdict,         asdict.__name__.__eq__,          ["asdict"],         true]
    - [astuple,        astuple.__name__.__eq__,         ["astuple"],        true]
    - [make_dataclass, make_dataclass.__name__.__eq__,  ["make_dataclass"], true]
    - [replace,        replace.__name__.__eq__,         ["replace"],        true]
    - [is_dataclass,   is_dataclass.__name__.__eq__,    ["is_dataclass"],   true]

# ---------------------------------------------------------------------------
# Function __module__ checks
#
# All public dataclasses callables are defined in the 'dataclasses' module.
# ---------------------------------------------------------------------------

table dataclasses_extra.function_modules:
  description: "Public dataclasses functions have __module__ == 'dataclasses'"
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [dataclass,      dataclass.__module__.__eq__,      ["dataclasses"], true]
    - [field,          field.__module__.__eq__,           ["dataclasses"], true]
    - [fields,         fields.__module__.__eq__,          ["dataclasses"], true]
    - [asdict,         asdict.__module__.__eq__,          ["dataclasses"], true]
    - [astuple,        astuple.__module__.__eq__,         ["dataclasses"], true]
    - [make_dataclass, make_dataclass.__module__.__eq__,  ["dataclasses"], true]
    - [replace,        replace.__module__.__eq__,         ["dataclasses"], true]
    - [is_dataclass,   is_dataclass.__module__.__eq__,    ["dataclasses"], true]

# ---------------------------------------------------------------------------
# Field class identity
#
# dataclasses.field() returns an internal Field object. Its class lives in
# the 'dataclasses' module and is named 'Field'.
# dataclasses_field.zspec.zsdl checks __class__.__name__ == 'Field';
# here we verify the module.
# ---------------------------------------------------------------------------

invariant dataclasses_extra.Field.class_module:
  description: "dataclasses.field().__class__.__module__ == 'dataclasses'"
  category: Field
  kind: python_call_eq
  function: field.__class__.__module__.__eq__
  args: ["dataclasses"]
  expected: true

# ---------------------------------------------------------------------------
# make_dataclass — returned class has dataclasses module
#
# make_dataclass creates a fresh class; its __module__ should be 'dataclasses'.
# ---------------------------------------------------------------------------

invariant dataclasses_extra.make_dataclass.class_module:
  description: "make_dataclass('X', ['a']).__module__ == 'dataclasses'"
  category: make_dataclass
  kind: python_call_eq
  function: make_dataclass
  args: ["X", ["a"]]
  method: __module__
  method_args: []
  expected: "dataclasses"

# ---------------------------------------------------------------------------
# is_dataclass — returns True for a dataclass created by make_dataclass
#
# The existing spec only checks false-cases. This checks the positive case
# by nesting make_dataclass as the argument via the __call__ dict form.
# ---------------------------------------------------------------------------

invariant dataclasses_extra.is_dataclass.true_for_make_dataclass:
  description: "is_dataclass(make_dataclass('Y', ['b'])) == True"
  category: is_dataclass
  kind: python_call_eq
  function: is_dataclass
  args: [{"__call__": "make_dataclass", "__call_args__": ["Y", ["b"]]}]
  expected: true
