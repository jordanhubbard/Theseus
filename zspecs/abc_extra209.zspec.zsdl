spec: abc_extra209
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: __doc__ string contains checks using NEW words for abc.ABC, abc.ABCMeta, abc.abstractmethod, and abc.get_cache_token — none of these words appeared in wave 379."
    - "abc.ABC.__doc__ == 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n' (len=78). Wave 379 used 'base','Abstract','abstract','class'. NEW: 'Helper'==True, 'standard'==True, 'inherit'==True. Verified with Python 3.14.3."
    - "abc.ABCMeta.__doc__ (len=576): 'metaclass'==True, 'register'==True, 'subclass'==True, 'virtual'==True, 'mix-in'==True. Wave 379 used 'Abstract','abstract','class'. Verified with Python 3.14.3."
    - "abc.abstractmethod.__doc__ (len=537): 'decorator'==True, 'method'==True, 'overridden'==True, 'instantiated'==True, 'Usage'==True. Wave 379 used 'decorator','abstract'. NEW: 'overridden','instantiated','Usage'. Verified with Python 3.14.3."
    - "abc.get_cache_token.__doc__ (len=230): 'opaque'==True, 'cache'==True, 'version'==True, 'virtual'==True, 'register'==True. Wave 379 used 'token','cache'. NEW: 'opaque','version','virtual','register'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABC __doc__ new-word contains checks — extra209
#
# abc.ABC.__doc__ == 'Helper class that provides a standard way to create an ABC using\ninheritance.\n'
# len == 78
# NEW (not in wave 379): 'Helper'==True, 'standard'==True, 'inherit'==True
# ---------------------------------------------------------------------------

table abc_extra209.abc_ABC_doc_new_words:
  description: "abc.ABC.__doc__ contains checks using words NOT in wave 379 — abce209abc: 'Helper'==True ('Helper class that provides...'); 'standard'==True ('a standard way'); 'inherit'==True ('using inheritance'); wave 379 used 'base','Abstract','abstract','class'; len==78; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abce209abc

  columns: [id, function, args, expected, description]
  rows:
    - [abc_doc_has_Helper,   abc.ABC.__doc__.__contains__, ["Helper"],   true,  "abc.ABC.__doc__.__contains__('Helper') == True; 'Helper class that provides'; verified with Python 3.14.3"]
    - [abc_doc_has_standard, abc.ABC.__doc__.__contains__, ["standard"], true,  "abc.ABC.__doc__.__contains__('standard') == True; 'a standard way to create an ABC'; verified with Python 3.14.3"]
    - [abc_doc_has_inherit,  abc.ABC.__doc__.__contains__, ["inherit"],  true,  "abc.ABC.__doc__.__contains__('inherit') == True; 'create an ABC using inheritance'; verified with Python 3.14.3"]
    - [abc_doc_no_token,     abc.ABC.__doc__.__contains__, ["token"],    false, "abc.ABC.__doc__.__contains__('token') == False; 'token' not in brief ABC docstring; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta __doc__ new-word contains checks — extra209
#
# abc.ABCMeta.__doc__ (len=576): metaclass for defining ABCs
# NEW (not in wave 379): 'metaclass'==True, 'register'==True, 'subclass'==True, 'virtual'==True, 'mix-in'==True
# ---------------------------------------------------------------------------

table abc_extra209.abc_ABCMeta_doc_new_words:
  description: "abc.ABCMeta.__doc__ contains checks using words NOT in wave 379 — abce209meta: 'metaclass'==True; 'register'==True; 'subclass'==True; 'virtual'==True; 'mix-in'==True; wave 379 used 'Abstract','abstract','class'; len==576; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abce209meta

  columns: [id, function, args, expected, description]
  rows:
    - [meta_doc_has_metaclass, abc.ABCMeta.__doc__.__contains__, ["metaclass"], true, "abc.ABCMeta.__doc__.__contains__('metaclass') == True; 'Metaclass for defining Abstract Base Classes'; verified with Python 3.14.3"]
    - [meta_doc_has_register,  abc.ABCMeta.__doc__.__contains__, ["register"],  true, "abc.ABCMeta.__doc__.__contains__('register') == True; 'You can also register unrelated concrete classes'; verified with Python 3.14.3"]
    - [meta_doc_has_subclass,  abc.ABCMeta.__doc__.__contains__, ["subclass"],  true, "abc.ABCMeta.__doc__.__contains__('subclass') == True; 'ABC can be subclassed directly'; verified with Python 3.14.3"]
    - [meta_doc_has_virtual,   abc.ABCMeta.__doc__.__contains__, ["virtual"],   true, "abc.ABCMeta.__doc__.__contains__('virtual') == True; 'virtual subclasses' described; verified with Python 3.14.3"]
    - [meta_doc_has_mix_in,    abc.ABCMeta.__doc__.__contains__, ["mix-in"],    true, "abc.ABCMeta.__doc__.__contains__('mix-in') == True; 'acts as a mix-in class'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.abstractmethod __doc__ new-word contains checks — extra209
#
# abc.abstractmethod.__doc__ (len=537): decorator for abstract methods
# NEW (not in wave 379): 'overridden'==True, 'instantiated'==True, 'Usage'==True
# ---------------------------------------------------------------------------

table abc_extra209.abc_abstractmethod_doc_new_words:
  description: "abc.abstractmethod.__doc__ contains checks using words NOT in wave 379 — abce209am: 'overridden'==True ('unless all of its abstract methods are overridden'); 'instantiated'==True ('cannot be instantiated unless...'); 'Usage'==True (example block titled 'Usage:'); wave 379 used 'decorator','abstract'; len==537; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abce209am

  columns: [id, function, args, expected, description]
  rows:
    - [am_doc_has_overridden,    abc.abstractmethod.__doc__.__contains__, ["overridden"],    true, "abc.abstractmethod.__doc__.__contains__('overridden') == True; 'abstract methods are overridden'; verified with Python 3.14.3"]
    - [am_doc_has_instantiated,  abc.abstractmethod.__doc__.__contains__, ["instantiated"],  true, "abc.abstractmethod.__doc__.__contains__('instantiated') == True; 'cannot be instantiated unless'; verified with Python 3.14.3"]
    - [am_doc_has_Usage,         abc.abstractmethod.__doc__.__contains__, ["Usage"],         true, "abc.abstractmethod.__doc__.__contains__('Usage') == True; 'Usage:' code example block in docstring; verified with Python 3.14.3"]
    - [am_doc_has_method,        abc.abstractmethod.__doc__.__contains__, ["method"],        true, "abc.abstractmethod.__doc__.__contains__('method') == True; 'indicating abstract methods'; verified with Python 3.14.3"]
    - [am_doc_len,               abc.abstractmethod.__doc__.__len__,      [],                537,  "abc.abstractmethod.__doc__.__len__() == 537; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.get_cache_token __doc__ new-word contains checks — extra209
#
# abc.get_cache_token.__doc__ (len=230): returns opaque token for ABC cache version
# NEW (not in wave 379): 'opaque'==True, 'version'==True, 'virtual'==True, 'register'==True
# ---------------------------------------------------------------------------

table abc_extra209.abc_get_cache_token_doc_new_words:
  description: "abc.get_cache_token.__doc__ contains checks using words NOT in wave 379 — abce209gct: 'opaque'==True ('opaque object supporting equality testing'); 'version'==True ('current version of the ABC cache'); 'virtual'==True ('virtual subclasses'); 'register'==True ('every call to register()'); wave 379 used 'token','cache'; len==230; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abce209gct

  columns: [id, function, args, expected, description]
  rows:
    - [gct_doc_has_opaque,    abc.get_cache_token.__doc__.__contains__, ["opaque"],    true, "abc.get_cache_token.__doc__.__contains__('opaque') == True; 'opaque object (supporting equality testing)'; verified with Python 3.14.3"]
    - [gct_doc_has_version,   abc.get_cache_token.__doc__.__contains__, ["version"],   true, "abc.get_cache_token.__doc__.__contains__('version') == True; 'current version of the ABC cache'; verified with Python 3.14.3"]
    - [gct_doc_has_virtual,   abc.get_cache_token.__doc__.__contains__, ["virtual"],   true, "abc.get_cache_token.__doc__.__contains__('virtual') == True; 'ABC cache for virtual subclasses'; verified with Python 3.14.3"]
    - [gct_doc_has_register,  abc.get_cache_token.__doc__.__contains__, ["register"],  true, "abc.get_cache_token.__doc__.__contains__('register') == True; 'every call to register()'; verified with Python 3.14.3"]
    - [gct_doc_no_invalidation, abc.get_cache_token.__doc__.__contains__, ["invalidation"], false, "abc.get_cache_token.__doc__.__contains__('invalidation') == False; 'invalidation' not in 230-char docstring; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra209
# ---------------------------------------------------------------------------

invariant abc_extra209.ABCMeta_doc_has_metaclass:
  description: "abc.ABCMeta.__doc__.__contains__('metaclass') returns True — ABCMeta.__doc__ (len=576) opens with 'Metaclass for defining Abstract Base Classes (ABCs).'; 'metaclass' not used for ABCMeta in wave 379 (which used 'Abstract','abstract'); ABCMeta is itself a metaclass — it governs how ABC subclasses are constructed; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__doc__.__contains__
  args: ["metaclass"]
  expected: true

invariant abc_extra209.abstractmethod_doc_has_overridden:
  description: "abc.abstractmethod.__doc__.__contains__('overridden') returns True — abstractmethod.__doc__ (len=537) states 'a class that has a metaclass derived from ABCMeta cannot be instantiated unless all of its abstract methods are overridden.'; 'overridden' not used in wave 379; this is the key contract of abstract methods; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__doc__.__contains__
  args: ["overridden"]
  expected: true

invariant abc_extra209.get_cache_token_doc_has_opaque:
  description: "abc.get_cache_token.__doc__.__contains__('opaque') returns True — get_cache_token.__doc__ (len=230) describes the return value as 'an opaque object (supporting equality testing) identifying the current version of the ABC cache for virtual subclasses.'; 'opaque' not used in wave 379; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__doc__.__contains__
  args: ["opaque"]
  expected: true

invariant abc_extra209.ABC_doc_has_Helper:
  description: "abc.ABC.__doc__.__contains__('Helper') returns True — ABC.__doc__ is 'Helper class that provides a standard way to create an ABC using inheritance.' (len=78); 'Helper' not used in wave 379 (which used 'base','Abstract','abstract','class'); ABC is a convenience helper built on ABCMeta; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__doc__.__contains__
  args: ["Helper"]
  expected: true
