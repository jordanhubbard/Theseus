spec: passlib_rust
version: ">=3.9"
backend: rust_module(passlib_rust)

docs: https://passlib.readthedocs.io/en/stable/

provenance:
  derived_from:
    - "https://passlib.readthedocs.io/en/stable/ — passlib documentation"
  not_derived_from:
    - "passlib source: passlib/__init__.py"
  notes:
    - "passlib provides password hashing for Python."
    - "from passlib.hash import bcrypt; hash = bcrypt.hash('secret')."
    - "bcrypt.verify('secret', hash) == True."
    - "bcrypt.verify('wrong', hash) == False."
    - "from passlib.hash import sha256_crypt; sha256_crypt.hash('pw') starts with '$5$'."
    - "Expose passlib_bcrypt_verify(pw) -> bool: bcrypt.verify(pw, bcrypt.hash(pw))."
    - "Expose passlib_bcrypt_wrong(pw) -> bool: bcrypt.verify('wrong_'+pw, bcrypt.hash(pw))."
    - "Expose passlib_sha256_prefix() -> str: sha256_crypt.hash('pw')[:3]."
    - "All test vectors verified against passlib 1.7.4."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# passlib_bcrypt_verify — correct password verifies
table passlib_rust.bcrypt.verify:
  kind: python_call_eq
  category: bcrypt_verify
  id_prefix: pl_bv
  function: passlib_bcrypt_verify

  columns: [id, args, expected]
  rows:
    - [secret, ["secret"], true]
    - [hello,  ["hello"],  true]

# passlib_bcrypt_wrong — wrong password fails
table passlib_rust.bcrypt.wrong:
  kind: python_call_eq
  category: bcrypt_wrong
  id_prefix: pl_bw
  function: passlib_bcrypt_wrong

  columns: [id, args, expected]
  rows:
    - [secret, ["secret"], false]
    - [hello,  ["hello"],  false]

# passlib_sha256_prefix — sha256_crypt starts with '$5$'
invariant passlib_rust.sha256.prefix:
  description: "sha256_crypt hash starts with '$5$'"
  category: sha256
  kind: python_call_eq
  function: passlib_sha256_prefix
  args: []
  expected: "$5$"

