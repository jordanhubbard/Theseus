spec: concurrent_futures_extra1126
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module __name__/__spec__.name/__doc__ identity, ThreadPoolExecutor/ProcessPoolExecutor class module/qualname/name, Executor submit/map/shutdown qualnames, Future/__doc__ class names"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks concurrent.futures.__name__/__spec__.name/__doc__ class, ThreadPoolExecutor/ProcessPoolExecutor module/qualname/name/class, Executor.submit/map/shutdown qualnames, Future/__doc__ class, as_completed/__doc__ class — behaviors not covered by extra1096 or extra1111"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra1126.module_identity:
  description: "concurrent.futures module __name__, __spec__.name, __doc__ class, and __spec__ class identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: cf1126mi
  columns: [id, function, args, expected]
  rows:
    - [cf1126mi001, concurrent.futures.__name__.__eq__,                        ["concurrent.futures"],          true]
    - [cf1126mi002, concurrent.futures.__spec__.name.__eq__,                   ["concurrent.futures"],          true]
    - [cf1126mi003, concurrent.futures.__doc__.__class__.__name__.__eq__,      ["str"],                         true]
    - [cf1126mi004, concurrent.futures.__spec__.__class__.__name__.__eq__,     ["ModuleSpec"],                  true]
    - [cf1126mi005, concurrent.futures.Future.__doc__.__class__.__name__.__eq__, ["str"],                       true]
    - [cf1126mi006, concurrent.futures.as_completed.__doc__.__class__.__name__.__eq__, ["str"],                 true]
    - [cf1126mi007, concurrent.futures.wait.__doc__.__class__.__name__.__eq__, ["str"],                         true]

