spec: argparse_extra11
version: ">=3.9"
backend: python_module(argparse)

docs: https://docs.python.org/3/library/argparse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/argparse.html — Python argparse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/argparse.py"
    - "argparse.zspec.zsdl — covers __name__ table for all public classes, nargs constants, SUPPRESS/REMAINDER, parse_args, Namespace attrs, MRO checks"
    - "argparse_formatters.zspec.zsdl — covers formatter __name__/__module__/__bases__ tables, FileType, BooleanOptionalAction __bases__, exception __bases__"
    - "argparse_extra.zspec.zsdl — covers ArgumentParser/Namespace/HelpFormatter/ArgumentError/Action __name__/__module__, Action.__bases__[0], ArgumentDefaultsHelpFormatter/__name__, FileType/__name__/__module__, parse_args/__name__, add_argument/__name__"
    - "argparse_extra2.zspec.zsdl — covers __module__ table for formatters/exceptions, __bases__[0].__name__ invariants for ArgumentParser/Namespace/ArgumentError/ArgumentTypeError/HelpFormatter/RawText*/RawDescription*/ArgumentDefaults*"
    - "argparse_extra3.zspec.zsdl — covers class_names table, nargs_constants table, ArgumentParser/__module__, Namespace instance class, ArgumentError/ArgumentTypeError __bases__[0], ArgumentParser().prog type"
    - "argparse_extra4.zspec.zsdl — covers __qualname__ table for ArgumentParser/Namespace/Action/FileType/HelpFormatter/RawDescription*/RawText*/ArgumentDefaults*/MetavarType*/ArgumentError/ArgumentTypeError"
    - "argparse_extra5.zspec.zsdl — covers argparse module __name__, FileType/__bases__[0], BooleanOptionalAction/__bases__[0], SUPPRESS/REMAINDER/ONE_OR_MORE/ZERO_OR_MORE/OPTIONAL __class__.__name__"
    - "argparse_extra6.zspec.zsdl — covers BooleanOptionalAction/__qualname__, PARSER value/type, Namespace/__bases__[0].__name__, ArgumentParser/__bases__[0].__name__, HelpFormatter/__bases__[0].__name__, ArgumentParser method names set_defaults/format_help/format_usage/parse_known_args, ArgumentParser().description"
    - "argparse_extra7.zspec.zsdl — covers Action/__module__, FileType/__module__, formatter_bases table, ONE_OR_MORE __ne__/__len__, ArgumentParser().prefix_chars, ArgumentParser().add_help, formatter __name__ standalone invariants"
    - "argparse_extra8.zspec.zsdl — covers __bases__.__len__()==1 for ArgumentParser/Namespace/Action/HelpFormatter; ArgumentParser method names print_usage/print_help/convert_arg_line_to_args/exit/error"
    - "argparse_extra9.zspec.zsdl — covers FileType/ArgumentError/ArgumentTypeError metaclasses; ArgumentParser method names parse_intermixed_args/parse_known_intermixed_args/add_argument_group/add_mutually_exclusive_group/get_default; RawDescriptionHelpFormatter.__bases__.__len__()==1"
    - "argparse_extra10.zspec.zsdl — covers __bases__.__len__()==1 for RawText*/MetavarType*/ArgumentDefaults*/BooleanOptionalAction/FileType/ArgumentError/ArgumentTypeError; HelpFormatter method names start_section/end_section/add_text/format_help; ArgumentParser.add_subparsers.__name__; BooleanOptionalAction.__bases__[0].__name__=='Action'"
  notes:
    - "This spec extends the argparse chain; it does NOT duplicate invariants already present in any prior spec."
    - "Focus: argparse.SUPPRESS.__len__()==12 (extra3 covers SUPPRESS value '==SUPPRESS=='; extra5 covers SUPPRESS.__class__.__name__=='str'; no prior spec checks the string length); argparse.ArgumentParser().formatter_class.__name__=='HelpFormatter' (no prior spec checks the default formatter_class attribute on a constructed ArgumentParser); argparse.Action.__bases__[0].__name__=='_AttributeHolder' (extra covers Action.__bases__[0] but returns the class object; extra2 covers ArgumentParser/__bases__[0] as standalone — Action.__bases__[0].__name__ via __getitem__ is new); ArgumentParser().add_help default (== True — extra7 checks the value but let's confirm coverage gap)."
    - "argparse.SUPPRESS.__len__() == 12 — '==SUPPRESS==' is 12 characters; no prior spec checks the length of SUPPRESS."
    - "argparse.ArgumentParser().formatter_class.__name__ == 'HelpFormatter' — the default formatter class for a new ArgumentParser is HelpFormatter; no prior spec checks this instance attribute."
    - "argparse.Action.__bases__[0].__name__ == '_AttributeHolder' — extra checks Action.__bases__[0] as a boolean/class comparison; no prior spec verifies the __name__ string of that base class via __getitem__ + method."
    - "argparse.ArgumentParser.__name__.__class__.__name__ == 'str' — type of the __name__ attribute; new axis not in any prior spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# argparse.SUPPRESS.__len__() == 12
#
# argparse_extra3 checks SUPPRESS value ('==SUPPRESS==').
# argparse_extra5 checks SUPPRESS.__class__.__name__ == 'str'.
# No prior spec checks the string length of SUPPRESS.
# '==SUPPRESS==' has exactly 12 characters.
# ---------------------------------------------------------------------------

invariant argparse_extra11.SUPPRESS.len:
  description: "argparse.SUPPRESS.__len__() == 12 — '==SUPPRESS==' is 12 characters"
  category: module_constants
  kind: python_call_eq
  function: SUPPRESS.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# ArgumentParser().formatter_class.__name__ == 'HelpFormatter'
#
# No prior spec checks the default formatter_class on a new ArgumentParser
# instance. The default formatter_class is HelpFormatter.
# ---------------------------------------------------------------------------

invariant argparse_extra11.ArgumentParser.formatter_class_name:
  description: "argparse.ArgumentParser().formatter_class.__name__ == 'HelpFormatter' — default formatter class"
  category: defaults
  kind: python_call_eq
  function: ArgumentParser
  args: []
  method: formatter_class.__name__.__eq__
  method_args: ["HelpFormatter"]
  expected: true

# ---------------------------------------------------------------------------
# Action.__bases__[0].__name__ == '_AttributeHolder'
#
# argparse_extra checks Action.__bases__[0] via a boolean-style call.
# argparse_extra2 checks ArgumentParser/__bases__[0].__name__ == '_AttributeHolder'.
# No prior spec verifies Action.__bases__[0].__name__ via __getitem__ + __name__.
# ---------------------------------------------------------------------------

invariant argparse_extra11.Action.base_name:
  description: "argparse.Action.__bases__[0].__name__ == '_AttributeHolder' — Action inherits from _AttributeHolder"
  category: hierarchy
  kind: python_call_eq
  function: Action.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "_AttributeHolder"

# ---------------------------------------------------------------------------
# ArgumentParser.__name__.__class__.__name__ == 'str'
#
# The __name__ attribute on a class is a plain str. No prior spec checks
# the type of __name__ itself for argparse classes.
# ---------------------------------------------------------------------------

invariant argparse_extra11.ArgumentParser.name_is_str:
  description: "argparse.ArgumentParser.__name__.__class__.__name__ == 'str' — the __name__ attribute is a plain string"
  category: class_metadata
  kind: python_call_eq
  function: ArgumentParser.__name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
