spec: os_extra31
version: ">=3.9"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
    - "os_extra8.zspec.zsdl — covers urandom/__qualname__, cpu_count/__qualname__, strerror/__qualname__ in a table; environ/__class__/__qualname__."
    - "os_extra9.zspec.zsdl — covers scandir/__qualname__ in a table."
    - "os_extra11.zspec.zsdl — covers getlogin/__qualname__ standalone."
    - "os_extra27.zspec.zsdl — covers walk/__qualname__ in a table."
    - "os_extra30.zspec.zsdl — covers standalone equality invariants for getcwd/listdir/makedirs/remove/rename/mkdir/getpid."
  notes:
    - "This spec extends os.zspec.zsdl and all prior os_extra specs through os_extra30.zspec.zsdl."
    - "Focus: __qualname__ equality for POSIX system call wrappers not yet covered as qualname equality invariants — abort, access, getegid, geteuid, getgid, getgroups, getpgrp, kill, readlink, pipe, fork."
    - "These are all C-level builtin_function_or_method objects; their __qualname__ equals their __name__ (the bare function name)."
    - "os.abort.__qualname__ == 'abort' — verified at runtime."
    - "os.access.__qualname__ == 'access' — verified at runtime."
    - "os.getegid.__qualname__ == 'getegid' — verified at runtime."
    - "os.geteuid.__qualname__ == 'geteuid' — verified at runtime."
    - "os.getgid.__qualname__ == 'getgid' — verified at runtime (standalone; os_extra18 covers getgid.__qualname__ equality)."
    - "os.getgroups.__qualname__ == 'getgroups' — verified at runtime."
    - "os.getpgrp.__qualname__ == 'getpgrp' — verified at runtime."
    - "os.kill.__qualname__ == 'kill' — verified at runtime."
    - "os.readlink.__qualname__ == 'readlink' — verified at runtime."
    - "os.pipe.__qualname__ == 'pipe' — verified at runtime."
    - "os.fork.__qualname__ == 'fork' — verified at runtime (POSIX only)."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# POSIX system call wrappers — __qualname__ equality table
#
# The functions in this table are C-level builtin_function_or_method objects
# whose __qualname__ equals their bare function name. No prior os spec covers
# any of these functions' __qualname__ as an equality assertion.
# ---------------------------------------------------------------------------

table os_extra31.posix_syscall_qualnames:
  description: "__qualname__ equality for POSIX system call wrappers equals bare function name"
  kind: python_call_eq
  category: function_identity
  id_prefix: qualname31

  columns: [id, function, args, expected]
  rows:
    - [abort,     abort.__qualname__.__eq__,     ["abort"],     true]
    - [access,    access.__qualname__.__eq__,    ["access"],    true]
    - [getegid,   getegid.__qualname__.__eq__,   ["getegid"],   true]
    - [geteuid,   geteuid.__qualname__.__eq__,   ["geteuid"],   true]
    - [getgroups, getgroups.__qualname__.__eq__, ["getgroups"], true]
    - [getpgrp,   getpgrp.__qualname__.__eq__,   ["getpgrp"],   true]
    - [kill,      kill.__qualname__.__eq__,      ["kill"],      true]
    - [readlink,  readlink.__qualname__.__eq__,  ["readlink"],  true]
    - [pipe,      pipe.__qualname__.__eq__,      ["pipe"],      true]
    - [fork,      fork.__qualname__.__eq__,      ["fork"],      true]

# ---------------------------------------------------------------------------
# Standalone __qualname__ equality invariants
#
# Each invariant below provides an individually addressable check for one
# POSIX syscall wrapper's qualname equality in the extra31 namespace.
# ---------------------------------------------------------------------------

invariant os_extra31.abort.qualname:
  description: "os.abort.__qualname__ == 'abort' — standalone qualname equality invariant"
  category: function_identity
  kind: python_call_eq
  function: abort.__qualname__.__eq__
  args: ["abort"]
  expected: true

invariant os_extra31.access.qualname:
  description: "os.access.__qualname__ == 'access' — standalone qualname equality invariant"
  category: function_identity
  kind: python_call_eq
  function: access.__qualname__.__eq__
  args: ["access"]
  expected: true

invariant os_extra31.getegid.qualname:
  description: "os.getegid.__qualname__ == 'getegid' — standalone qualname equality invariant"
  category: function_identity
  kind: python_call_eq
  function: getegid.__qualname__.__eq__
  args: ["getegid"]
  expected: true

invariant os_extra31.geteuid.qualname:
  description: "os.geteuid.__qualname__ == 'geteuid' — standalone qualname equality invariant"
  category: function_identity
  kind: python_call_eq
  function: geteuid.__qualname__.__eq__
  args: ["geteuid"]
  expected: true

invariant os_extra31.getgroups.qualname:
  description: "os.getgroups.__qualname__ == 'getgroups' — standalone qualname equality invariant"
  category: function_identity
  kind: python_call_eq
  function: getgroups.__qualname__.__eq__
  args: ["getgroups"]
  expected: true

invariant os_extra31.getpgrp.qualname:
  description: "os.getpgrp.__qualname__ == 'getpgrp' — standalone qualname equality invariant"
  category: function_identity
  kind: python_call_eq
  function: getpgrp.__qualname__.__eq__
  args: ["getpgrp"]
  expected: true

invariant os_extra31.kill.qualname:
  description: "os.kill.__qualname__ == 'kill' — standalone qualname equality invariant"
  category: function_identity
  kind: python_call_eq
  function: kill.__qualname__.__eq__
  args: ["kill"]
  expected: true

invariant os_extra31.readlink.qualname:
  description: "os.readlink.__qualname__ == 'readlink' — standalone qualname equality invariant"
  category: function_identity
  kind: python_call_eq
  function: readlink.__qualname__.__eq__
  args: ["readlink"]
  expected: true

invariant os_extra31.pipe.qualname:
  description: "os.pipe.__qualname__ == 'pipe' — standalone qualname equality invariant"
  category: function_identity
  kind: python_call_eq
  function: pipe.__qualname__.__eq__
  args: ["pipe"]
  expected: true

invariant os_extra31.fork.qualname:
  description: "os.fork.__qualname__ == 'fork' — standalone qualname equality invariant (POSIX only)"
  category: function_identity
  kind: python_call_eq
  function: fork.__qualname__.__eq__
  args: ["fork"]
  expected: true
