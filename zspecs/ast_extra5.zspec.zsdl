spec: ast_extra5
version: ">=3.9"
backend: python_module(ast)

docs: https://docs.python.org/3/library/ast.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/ast.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ast.py"
    - "CPython source: Python/Python-ast.c"
    - "ast.zspec.zsdl — covers literal_eval primitives/containers/tuple-access, error cases, literal_eval.__name__, and node classnames"
    - "ast_extra.zspec.zsdl — covers parse.__name__, parse.__module__, dump.__name__, get_docstring.__name__, fix_missing_locations.__name__, NodeVisitor.__name__, NodeTransformer.__name__, NodeTransformer.__bases__[0].__name__, AST.__name__, literal_eval('42'), literal_eval('\"hello\"'), literal_eval('[1,2,3]')"
    - "ast_extra2.zspec.zsdl — covers literal_eval for int/str/list/dict/bool/None value checks"
    - "ast_extra3.zspec.zsdl — covers __module__ for parse/dump/literal_eval/get_docstring/fix_missing_locations/walk/NodeVisitor/NodeTransformer/Module/FunctionDef/Constant/Name/AST/Expr/ClassDef"
    - "ast_extra4.zspec.zsdl — covers __qualname__ for literal_eval/get_docstring/dump/walk/fix_missing_locations/NodeVisitor/NodeTransformer/AST/Module/Constant, plus parse.__qualname__ and literal_eval type checks"
  notes:
    - "This spec covers __qualname__ for additional ast node classes not yet covered: FunctionDef, Expr, ClassDef, Name, If, For, Import, Call."
    - "Also covers __qualname__ for functions not yet checked: get_docstring.__qualname__, fix_missing_locations.__qualname__."
    - "ast.FunctionDef.__qualname__ == 'FunctionDef' — top-level node class."
    - "ast.Expr.__qualname__ == 'Expr' — top-level node class."
    - "ast.ClassDef.__qualname__ == 'ClassDef' — top-level node class."
    - "ast.Name.__qualname__ == 'Name' — top-level node class."
    - "ast.If.__qualname__ == 'If' — top-level node class."
    - "ast.For.__qualname__ == 'For' — top-level node class."
    - "ast.Import.__qualname__ == 'Import' — top-level node class."
    - "ast.Call.__qualname__ == 'Call' — top-level node class."
    - "ast.Assign.__qualname__ == 'Assign' — top-level node class."
    - "ast.Return.__qualname__ == 'Return' — top-level node class."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for additional ast node classes
# Not covered in ast_extra4 (which covers Module, Constant, AST, NodeVisitor,
# NodeTransformer, literal_eval, get_docstring, dump, walk, fix_missing_locations,
# parse).
# ---------------------------------------------------------------------------

table ast_extra5.node_class_qualnames:
  kind: python_call_eq
  category: qualname_attrs
  id_prefix: nqname

  columns: [id, function, args, expected]
  rows:
    - [FunctionDef, FunctionDef.__qualname__.__eq__, ["FunctionDef"], true]
    - [Expr,        Expr.__qualname__.__eq__,        ["Expr"],        true]
    - [ClassDef,    ClassDef.__qualname__.__eq__,    ["ClassDef"],    true]
    - [Name,        Name.__qualname__.__eq__,        ["Name"],        true]
    - [If,          If.__qualname__.__eq__,          ["If"],          true]
    - [For,         For.__qualname__.__eq__,         ["For"],         true]
    - [Import,      Import.__qualname__.__eq__,      ["Import"],      true]
    - [Call,        Call.__qualname__.__eq__,        ["Call"],        true]
    - [Assign,      Assign.__qualname__.__eq__,      ["Assign"],      true]
    - [Return,      Return.__qualname__.__eq__,      ["Return"],      true]

# ---------------------------------------------------------------------------
# __qualname__ checks for ast node classes introduced in 3.8+
# ---------------------------------------------------------------------------

table ast_extra5.newer_node_class_qualnames:
  kind: python_call_eq
  category: qualname_attrs
  id_prefix: nnqname

  columns: [id, function, args, expected]
  rows:
    - [AsyncFunctionDef, AsyncFunctionDef.__qualname__.__eq__, ["AsyncFunctionDef"], true]
    - [AsyncFor,         AsyncFor.__qualname__.__eq__,         ["AsyncFor"],         true]
    - [AsyncWith,        AsyncWith.__qualname__.__eq__,        ["AsyncWith"],        true]
    - [With,             With.__qualname__.__eq__,             ["With"],             true]
    - [Delete,           Delete.__qualname__.__eq__,           ["Delete"],           true]

# ---------------------------------------------------------------------------
# __qualname__ for remaining top-level ast utility functions
# (get_docstring and fix_missing_locations are covered in ast_extra4 via table;
# these are standalone invariants using a different format for cross-verification)
# Actually: ast_extra4 table covers get_docstring and fix_missing_locations.
# We cover increment.__qualname__ for parse_constant_value helper functions
# not in prior specs. We add unparse (Python 3.9+) and copy_location.
# ---------------------------------------------------------------------------

invariant ast_extra5.unparse.qualname:
  description: "ast.unparse.__qualname__ == 'unparse' (Python 3.9+)"
  category: qualname_attrs
  kind: python_call_eq
  function: unparse.__qualname__.__eq__
  args: ["unparse"]
  expected: true

invariant ast_extra5.unparse.module:
  description: "ast.unparse.__module__ == 'ast' (Python 3.9+)"
  category: module_attrs
  kind: python_call_eq
  function: unparse.__module__.__eq__
  args: ["ast"]
  expected: true

invariant ast_extra5.copy_location.qualname:
  description: "ast.copy_location.__qualname__ == 'copy_location'"
  category: qualname_attrs
  kind: python_call_eq
  function: copy_location.__qualname__.__eq__
  args: ["copy_location"]
  expected: true

invariant ast_extra5.copy_location.module:
  description: "ast.copy_location.__module__ == 'ast'"
  category: module_attrs
  kind: python_call_eq
  function: copy_location.__module__.__eq__
  args: ["ast"]
  expected: true

invariant ast_extra5.increment_lineno.qualname:
  description: "ast.increment_lineno.__qualname__ == 'increment_lineno'"
  category: qualname_attrs
  kind: python_call_eq
  function: increment_lineno.__qualname__.__eq__
  args: ["increment_lineno"]
  expected: true

invariant ast_extra5.increment_lineno.module:
  description: "ast.increment_lineno.__module__ == 'ast'"
  category: module_attrs
  kind: python_call_eq
  function: increment_lineno.__module__.__eq__
  args: ["ast"]
  expected: true
