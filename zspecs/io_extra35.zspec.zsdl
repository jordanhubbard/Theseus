invariant io_extra35.BufferedReader.qualname_len:
  description: "io.BufferedReader.__qualname__.__len__() == 14 — 'BufferedReader' has 14 characters"
  category: class_identity
  kind: python_call_eq
  function: BufferedReader.__qualname__.__len__
  args: []
  expected: 14

invariant io_extra35.BufferedWriter.qualname_len:
  description: "io.BufferedWriter.__qualname__.__len__() == 14 — 'BufferedWriter' has 14 characters"
  category: class_identity
  kind: python_call_eq
