spec: io_extra35
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra9.zspec.zsdl — covers BytesIO/StringIO __qualname__ in table rows; IOBase.__module__ in table"
    - "io_extra31.zspec.zsdl — covers IOBase/__qualname__/__module__; RawIOBase/__qualname__/__module__; BufferedIOBase/__qualname__/__module__; TextIOBase/__qualname__/__module__"
    - "io_extra32.zspec.zsdl — covers FileIO/BytesIO/StringIO/BufferedReader/BufferedWriter/TextIOWrapper __qualname__/__module__/__bases__[0].__name__"
    - "io_extra33.zspec.zsdl — covers IOBase/RawIOBase/BufferedIOBase/TextIOBase __qualname__ standalone; BytesIO/StringIO/FileIO/TextIOWrapper __qualname__ standalone; UnsupportedOperation/__qualname__/__module__/__bases__[0].__name__; io.open/__qualname__"
    - "io_extra34.zspec.zsdl — covers __module__.__len__() for IOBase/RawIOBase/BufferedIOBase/TextIOBase/BytesIO/StringIO; __name__.__len__() for same six classes"
  notes:
    - "This spec extends io_extra34.zspec.zsdl."
    - "Prior specs covered: IOBase/RawIOBase/BufferedIOBase/TextIOBase __name__/__module__/__qualname__, BytesIO/StringIO/FileIO/TextIOWrapper __name__/__module__/__qualname__, UnsupportedOperation attributes, io.open qualname, DEFAULT_BUFFER_SIZE, __module__.__len__() and __name__.__len__() for IOBase/RawIOBase/BufferedIOBase/TextIOBase/BytesIO/StringIO."
    - "This spec covers: __module__.__len__() and __name__.__len__() for FileIO, BufferedReader, BufferedWriter, TextIOWrapper; __qualname__.__len__() for IOBase, RawIOBase, BufferedIOBase, TextIOBase, BytesIO, StringIO, FileIO, BufferedReader, BufferedWriter, TextIOWrapper."
    - "IMPORTANT: FileIO, BufferedReader, BufferedWriter, TextIOWrapper have __module__ == '_io' (len 3). The abstract base classes IOBase, RawIOBase, BufferedIOBase, TextIOBase have __module__ == 'io' (len 2)."
    - "io.FileIO.__module__ == '_io' (len 3) — C-extension concrete class; verified Python 3.12."
    - "io.BufferedReader.__module__ == '_io' (len 3) — C-extension concrete class; verified Python 3.12."
    - "io.BufferedWriter.__module__ == '_io' (len 3) — C-extension concrete class; verified Python 3.12."
    - "io.TextIOWrapper.__module__ == '_io' (len 3) — C-extension concrete class; verified Python 3.12."
    - "io.FileIO.__name__ == 'FileIO' (len 6) — verified Python 3.12."
    - "io.BufferedReader.__name__ == 'BufferedReader' (len 14) — verified Python 3.12."
    - "io.BufferedWriter.__name__ == 'BufferedWriter' (len 14) — verified Python 3.12."
    - "io.TextIOWrapper.__name__ == 'TextIOWrapper' (len 13) — verified Python 3.12."
    - "io.IOBase.__qualname__ == 'IOBase' (len 6) — verified Python 3.12."
    - "io.RawIOBase.__qualname__ == 'RawIOBase' (len 9) — verified Python 3.12."
    - "io.BufferedIOBase.__qualname__ == 'BufferedIOBase' (len 14) — verified Python 3.12."
    - "io.TextIOBase.__qualname__ == 'TextIOBase' (len 10) — verified Python 3.12."
    - "io.BytesIO.__qualname__ == 'BytesIO' (len 7) — verified Python 3.12."
    - "io.StringIO.__qualname__ == 'StringIO' (len 8) — verified Python 3.12."
    - "io.FileIO.__qualname__ == 'FileIO' (len 6) — verified Python 3.12."
    - "io.BufferedReader.__qualname__ == 'BufferedReader' (len 14) — verified Python 3.12."
    - "io.BufferedWriter.__qualname__ == 'BufferedWriter' (len 14) — verified Python 3.12."
    - "io.TextIOWrapper.__qualname__ == 'TextIOWrapper' (len 13) — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__len__() for concrete C-extension classes:
# FileIO, BufferedReader, BufferedWriter, TextIOWrapper
#
# These four concrete classes are implemented in C and have __module__ == '_io'
# (3 characters). This contrasts with the abstract base classes (which have
# __module__ == 'io', len 2) covered in io_extra34. No prior io spec checks
# the __module__.__len__() for any of these four classes.
# ---------------------------------------------------------------------------

table io_extra35.concrete_class_module_lengths:
  description: "__module__.__len__() for FileIO, BufferedReader, BufferedWriter, TextIOWrapper — all 3 (module name '_io')"
  kind: python_call_eq
  category: class_identity
  id_prefix: ccml35

  columns: [id, function, args, expected]
  rows:
    - [FileIO,          FileIO.__module__.__len__,          [], 3]
    - [BufferedReader,  BufferedReader.__module__.__len__,  [], 3]
    - [BufferedWriter,  BufferedWriter.__module__.__len__,  [], 3]
    - [TextIOWrapper,   TextIOWrapper.__module__.__len__,   [], 3]

# ---------------------------------------------------------------------------
# __name__.__len__() for concrete C-extension classes:
# FileIO, BufferedReader, BufferedWriter, TextIOWrapper
#
# Each class name has a distinct length:
#   FileIO         -> 'FileIO'         -> 6
#   BufferedReader -> 'BufferedReader' -> 14
#   BufferedWriter -> 'BufferedWriter' -> 14
#   TextIOWrapper  -> 'TextIOWrapper'  -> 13
# No prior io spec checks __name__.__len__() for any of these four classes.
# ---------------------------------------------------------------------------

table io_extra35.concrete_class_name_lengths:
  description: "__name__.__len__() for FileIO, BufferedReader, BufferedWriter, TextIOWrapper"
  kind: python_call_eq
  category: class_identity
  id_prefix: ccnl35

  columns: [id, function, args, expected]
  rows:
    - [FileIO,          FileIO.__name__.__len__,          [],  6]
    - [BufferedReader,  BufferedReader.__name__.__len__,  [], 14]
    - [BufferedWriter,  BufferedWriter.__name__.__len__,  [], 14]
    - [TextIOWrapper,   TextIOWrapper.__name__.__len__,   [], 13]

# ---------------------------------------------------------------------------
# __qualname__.__len__() for all ten io classes
#
# For all ten io classes __qualname__ equals __name__ (no nesting), so their
# lengths mirror the __name__ lengths already established:
#   abstract base classes (module 'io'):    IOBase=6, RawIOBase=9,
#     BufferedIOBase=14, TextIOBase=10
#   concrete classes (module '_io'):        BytesIO=7, StringIO=8,
#     FileIO=6, BufferedReader=14, BufferedWriter=14, TextIOWrapper=13
# No prior io spec checks __qualname__.__len__() for any of these ten classes.
# ---------------------------------------------------------------------------

invariant io_extra35.IOBase.qualname_len:
  description: "io.IOBase.__qualname__.__len__() == 6 — 'IOBase' has 6 characters"
  category: class_identity
  kind: python_call_eq
  function: IOBase.__qualname__.__len__
  args: []
  expected: 6

invariant io_extra35.RawIOBase.qualname_len:
  description: "io.RawIOBase.__qualname__.__len__() == 9 — 'RawIOBase' has 9 characters"
  category: class_identity
  kind: python_call_eq
  function: RawIOBase.__qualname__.__len__
  args: []
  expected: 9

invariant io_extra35.BufferedIOBase.qualname_len:
  description: "io.BufferedIOBase.__qualname__.__len__() == 14 — 'BufferedIOBase' has 14 characters"
  category: class_identity
  kind: python_call_eq
  function: BufferedIOBase.__qualname__.__len__
  args: []
  expected: 14

invariant io_extra35.TextIOBase.qualname_len:
  description: "io.TextIOBase.__qualname__.__len__() == 10 — 'TextIOBase' has 10 characters"
  category: class_identity
  kind: python_call_eq
  function: TextIOBase.__qualname__.__len__
  args: []
  expected: 10

invariant io_extra35.BytesIO.qualname_len:
  description: "io.BytesIO.__qualname__.__len__() == 7 — 'BytesIO' has 7 characters"
  category: class_identity
  kind: python_call_eq
  function: BytesIO.__qualname__.__len__
  args: []
  expected: 7

invariant io_extra35.StringIO.qualname_len:
  description: "io.StringIO.__qualname__.__len__() == 8 — 'StringIO' has 8 characters"
  category: class_identity
  kind: python_call_eq
  function: StringIO.__qualname__.__len__
  args: []
  expected: 8

invariant io_extra35.FileIO.qualname_len:
  description: "io.FileIO.__qualname__.__len__() == 6 — 'FileIO' has 6 characters"
  category: class_identity
  kind: python_call_eq
  function: FileIO.__qualname__.__len__
  args: []
