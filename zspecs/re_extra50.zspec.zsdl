spec: re_extra50
version: ">=3.11"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra49.zspec.zsdl — covers re.Pattern/__class__.__name__.__eq__('type'); re.Match/__class__.__name__.__eq__('type'); re.RegexFlag/__class__.__name__.__eq__('EnumType'); re.search/compile/sub/__class__.__name__.__eq__('function'); re.error/__class__.__name__.__eq__('type')."
    - "re_extra48.zspec.zsdl — covers re.RegexFlag member ._name_ equality and ._name_.__len__() for IGNORECASE/ASCII/MULTILINE/DOTALL/VERBOSE/UNICODE/LOCALE."
    - "re_extra47.zspec.zsdl — covers re.error/__qualname__.__len__()==12; re.PatternError identity attributes."
    - "re_extra35.zspec.zsdl — covers RegexFlag/__name__.__len__()==9; RegexFlag/__mro__.__len__()==7."
    - "re_extra27.zspec.zsdl — covers RegexFlag/__module__.__eq__('re'); RegexFlag/__bases__[0].__name__.__eq__('IntFlag')."
    - "re_extra22.zspec.zsdl — covers Pattern/__name__/__module__/__bases__[0].__name__; Match/__name__/__module__/__bases__[0].__name__; function __name__ attributes table."
    - "re_extra9.zspec.zsdl — covers error/__qualname__; Pattern/__qualname__; Match/__qualname__."
  notes:
    - "This spec extends re_extra49.zspec.zsdl."
    - "Prior specs collectively covered: re.Pattern/__class__.__name__=='type' equality (re_extra49); re.Match/__class__.__name__=='type' equality (re_extra49); re.RegexFlag/__class__.__name__=='EnumType' equality (re_extra49); re.search/compile/sub/__class__.__name__=='function' equality (re_extra49); re.error/__class__.__name__=='type' equality (re_extra49). NO prior re spec checks __class__.__qualname__ for any re object — all __qualname__ path anchors in this spec are novel."
    - "This spec covers: re.Pattern.__class__.__qualname__.__eq__('type') (NOVEL — re_extra49 anchors Pattern.__class__.__name__=='type' via __name__ path; no prior re spec checks Pattern.__class__.__qualname__; for top-level builtin types __qualname__==__name__=='type'; novel __qualname__ path anchor in re_extra50 namespace); re.Match.__class__.__qualname__.__eq__('type') (NOVEL — same reasoning; novel); re.RegexFlag.__class__.__qualname__.__eq__('EnumType') (NOVEL — re_extra49 anchors RegexFlag.__class__.__name__=='EnumType' via __name__; EnumType is a top-level class so __qualname__=='EnumType'==__name__; no prior re spec checks RegexFlag.__class__.__qualname__; novel); re.search.__class__.__qualname__.__eq__('function') (NOVEL — re_extra49 anchors search.__class__.__name__=='function' via __name__; for the builtin 'function' type, __qualname__=='function'==__name__; no prior re spec checks search.__class__.__qualname__; novel); re.compile.__class__.__qualname__.__eq__('function') (NOVEL); re.sub.__class__.__qualname__.__eq__('function') (NOVEL); re.error.__class__.__qualname__.__eq__('type') (NOVEL — re_extra49 anchors error.__class__.__name__=='type' via __name__; no prior re spec checks error.__class__.__qualname__; novel); re.fullmatch.__class__.__qualname__.__eq__('function') (NOVEL — re_extra49 covers search/compile/sub but not fullmatch; fullmatch is also a regular Python function in re/__init__.py; no prior re spec checks fullmatch.__class__.__qualname__ or fullmatch.__class__.__name__; novel); re.findall.__class__.__qualname__.__eq__('function') (NOVEL — no prior re spec checks findall.__class__.__qualname__ or findall.__class__.__name__; novel)."
    - "re.Pattern.__class__.__qualname__ == 'type'. Pattern is a C-extension type from _sre. Its metaclass is 'type'. For top-level builtin types __qualname__==__name__=='type'. re_extra49 anchors via __name__ path; no prior re spec accesses __class__.__qualname__. Novel __qualname__ path anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.RegexFlag.__class__.__qualname__ == 'EnumType'. RegexFlag is an IntFlag subclass; its metaclass is EnumType. EnumType is a top-level class in enum module, __qualname__=='EnumType'==__name__. re_extra49 anchors via __name__ path; no prior re spec checks __class__.__qualname__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.search.__class__.__qualname__ == 'function'. re.search is a regular Python function; its type's __qualname__ is 'function'. re_extra49 anchors via __name__ path; no prior re spec checks search.__class__.__qualname__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.fullmatch.__class__.__qualname__ == 'function'. re.fullmatch is a regular Python function defined in re/__init__.py. re_extra49 covers search/compile/sub/__class__.__name__ but omits fullmatch. No prior re spec checks fullmatch.__class__.__qualname__ or fullmatch.__class__.__name__. Novel equality anchor for both the fullmatch function and the __qualname__ path. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.findall.__class__.__qualname__ == 'function'. re.findall is a regular Python function defined in re/__init__.py. No prior re spec checks findall.__class__.__qualname__ or findall.__class__.__name__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern and re.Match __class__.__qualname__
#
# Pattern and Match are C-extension types from _sre with the standard 'type'
# metaclass. For top-level builtin types, __qualname__==__name__:
#
#   Pattern.__class__.__qualname__  == 'type'
#   Match.__class__.__qualname__    == 'type'
#
# re_extra49 anchors these via __class__.__name__ (__name__ path).
# No prior re spec checks __class__.__qualname__ for Pattern or Match.
# Both anchors are novel in the re_extra50 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant re_extra50.Pattern_class_qualname_eq:
  description: "re.Pattern.__class__.__qualname__ == 'type' — Pattern is a C-extension type from _sre; its metaclass is 'type'; for top-level builtin types __qualname__==__name__=='type'; re_extra49 anchors Pattern.__class__.__name__=='type' via __name__ path; no prior re spec checks Pattern.__class__.__qualname__; novel __qualname__ path anchor in re_extra50 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant re_extra50.Match_class_qualname_eq:
  description: "re.Match.__class__.__qualname__ == 'type' — Match is a C-extension type from _sre; its metaclass is 'type'; for top-level builtin types __qualname__==__name__=='type'; re_extra49 anchors Match.__class__.__name__=='type' via __name__ path; no prior re spec checks Match.__class__.__qualname__; novel __qualname__ path anchor in re_extra50 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Match.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# re.RegexFlag.__class__.__qualname__ — EnumType metaclass qualname
#
# RegexFlag is an IntFlag subclass. In Python 3.11+, enum types use the
# EnumType metaclass. EnumType is a top-level class in enum so its
# __qualname__=='EnumType'==__name__:
#
#   RegexFlag.__class__.__qualname__  == 'EnumType'
#
# re_extra49 anchors via __class__.__name__ (__name__ path).
# No prior re spec checks RegexFlag.__class__.__qualname__.
# Novel __qualname__ path anchor in the re_extra50 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant re_extra50.RegexFlag_class_qualname_eq:
  description: "re.RegexFlag.__class__.__qualname__ == 'EnumType' — RegexFlag is an IntFlag subclass; its metaclass is EnumType (Python 3.11+ enum metaclass); EnumType is a top-level class so __qualname__=='EnumType'==__name__; re_extra49 anchors RegexFlag.__class__.__name__=='EnumType' via __name__ path; no prior re spec checks RegexFlag.__class__.__qualname__; novel __qualname__ path anchor in re_extra50 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: RegexFlag.__class__.__qualname__.__eq__
  args: ["EnumType"]
  expected: true

# ---------------------------------------------------------------------------
# re module function __class__.__qualname__ equality
#
# The re module functions are regular Python functions. Their type's
# __qualname__ is 'function' (top-level builtin type, __qualname__==__name__):
#
#   search.__class__.__qualname__   == 'function'
#   compile.__class__.__qualname__  == 'function'
#   sub.__class__.__qualname__      == 'function'
#   fullmatch.__class__.__qualname__ == 'function'
#   findall.__class__.__qualname__  == 'function'
#
# re_extra49 anchors search/compile/sub via __class__.__name__ (__name__ path)
# but does not cover fullmatch or findall at all.
# No prior re spec checks __class__.__qualname__ for any re function.
# All five anchors are novel in the re_extra50 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra50.function_class_qualnames:
  description: "re module function __class__.__qualname__.__eq__('function') for search/compile/sub/fullmatch/findall — all are regular Python functions in re/__init__.py; for the builtin 'function' type __qualname__==__name__=='function'; re_extra49 covers search/compile/sub via __name__ path but not __qualname__; fullmatch and findall are novel across both __class__.__name__ and __class__.__qualname__; all five novel anchors in re_extra50 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: reclsqual50

  columns: [id, function, args, expected]
  rows:
    - [search_class_qualname,   search.__class__.__qualname__.__eq__,   ["function"], true]
    - [compile_class_qualname,  compile.__class__.__qualname__.__eq__,  ["function"], true]
    - [sub_class_qualname,      sub.__class__.__qualname__.__eq__,      ["function"], true]
    - [fullmatch_class_qualname, fullmatch.__class__.__qualname__.__eq__, ["function"], true]
    - [findall_class_qualname,  findall.__class__.__qualname__.__eq__,  ["function"], true]

# ---------------------------------------------------------------------------
# re.error.__class__.__qualname__
#
# re.error is an alias for re.PatternError, a regular exception class whose
# metaclass is 'type'. For top-level builtin types, __qualname__==__name__:
#
#   error.__class__.__qualname__  == 'type'
#
# re_extra49 anchors error.__class__.__name__=='type' via the __name__ path.
# No prior re spec checks error.__class__.__qualname__.
# Novel __qualname__ path anchor in the re_extra50 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant re_extra50.error_class_qualname_eq:
  description: "re.error.__class__.__qualname__ == 'type' — re.error is an alias for PatternError, a regular exception class whose metaclass is 'type'; for top-level builtin types __qualname__==__name__=='type'; re_extra49 anchors error.__class__.__name__=='type' via __name__ path; no prior re spec checks error.__class__.__qualname__; novel __qualname__ path anchor in re_extra50 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: error.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true
