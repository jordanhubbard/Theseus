spec: io_extra72
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pyio.py"
    - "CPython source: Modules/_io/"
    - "io_extra71.zspec.zsdl — covers io.open/__doc__.__contains__('open'/'file'); FileIO/__doc__.__contains__('file'); BytesIO/__doc__.__contains__('bytes'); StringIO/__doc__.__contains__('buffer'); DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__('int') and __eq__(8192)."
    - "io_extra70.zspec.zsdl — covers BufferedReader/__doc__.__contains__('read'/'buffer'); BufferedWriter/__doc__.__contains__('write'/'buffer'); io/__doc__.__contains__('Python'/'I/O'); IOBase/__doc__.__contains__('base')."
  notes:
    - "This spec extends io_extra71.zspec.zsdl."
    - "Theme: io class hierarchy — __bases__[0].__name__ and __mro__.__len__() for abstract and concrete io classes."
    - "io classes (IOBase, RawIOBase, BufferedIOBase, TextIOBase, FileIO, BufferedReader, BufferedWriter, TextIOWrapper) are all C extension types. No __code__ on their methods. Focus on class hierarchy invariants."
    - "RawIOBase.__bases__[0].__name__ == 'IOBase' — RawIOBase inherits directly from IOBase (the abstract base for all I/O classes). No prior io spec checks RawIOBase.__bases__[0].__name__. Novel hierarchy anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "BufferedIOBase.__bases__[0].__name__ == 'IOBase' — BufferedIOBase inherits directly from IOBase (not from RawIOBase). No prior io spec checks BufferedIOBase.__bases__[0].__name__. Novel hierarchy anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "TextIOBase.__bases__[0].__name__ == 'IOBase' — TextIOBase inherits directly from IOBase. No prior io spec checks TextIOBase.__bases__[0].__name__. Novel hierarchy anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "FileIO.__bases__[0].__name__ == 'RawIOBase' — FileIO inherits from RawIOBase (the abstract base for raw I/O). No prior io spec checks FileIO.__bases__[0].__name__. Novel hierarchy anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "BufferedReader.__bases__[0].__name__ == 'BufferedIOBase' — BufferedReader inherits from BufferedIOBase. No prior io spec checks BufferedReader.__bases__[0].__name__. Novel hierarchy anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "TextIOWrapper.__bases__[0].__name__ == 'TextIOBase' — TextIOWrapper inherits from TextIOBase. No prior io spec checks TextIOWrapper.__bases__[0].__name__. Novel hierarchy anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "RawIOBase.__mro__.__len__() == 3 — MRO is [RawIOBase, IOBase, object]; 3 entries. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "BufferedIOBase.__mro__.__len__() == 3 — MRO is [BufferedIOBase, IOBase, object]; 3 entries. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "TextIOBase.__mro__.__len__() == 3 — MRO is [TextIOBase, IOBase, object]; 3 entries. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "FileIO.__mro__.__len__() == 4 — MRO is [FileIO, RawIOBase, IOBase, object]; 4 entries. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "BufferedReader.__mro__.__len__() == 4 — MRO is [BufferedReader, BufferedIOBase, IOBase, object]; 4 entries. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "TextIOWrapper.__mro__.__len__() == 4 — MRO is [TextIOWrapper, TextIOBase, IOBase, object]; 4 entries. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Table row function values containing '[' must be double-quoted per ZSDL rules."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Abstract io base classes: __bases__[0].__name__ == 'IOBase'
#
# RawIOBase, BufferedIOBase, and TextIOBase all inherit directly from IOBase.
# No prior io spec checks __bases__[0].__name__ for any of these.
# Function values containing '[' must be double-quoted in table rows.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra72.iobase_subclass_bases:
  description: "RawIOBase/BufferedIOBase/TextIOBase __bases__[0].__name__.__eq__('IOBase') — all three abstract io base classes inherit directly from IOBase; __bases__[0] is IOBase; IOBase.__name__ is 'IOBase'; no prior io spec checks __bases__[0].__name__ for any of these in iohier72 namespace; function values with '[' are double-quoted per ZSDL rules; novel class hierarchy anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: iohier72bases

  columns: [id, function, args, expected]
  rows:
    - [raw_io_base_bases_iobase,      "RawIOBase.__bases__[0].__name__.__eq__",     ["IOBase"], true]
    - [buffered_io_base_bases_iobase, "BufferedIOBase.__bases__[0].__name__.__eq__", ["IOBase"], true]
    - [text_io_base_bases_iobase,     "TextIOBase.__bases__[0].__name__.__eq__",    ["IOBase"], true]

# ---------------------------------------------------------------------------
# Concrete io classes: __bases__[0].__name__ for FileIO/BufferedReader/TextIOWrapper
#
# FileIO inherits from RawIOBase; BufferedReader from BufferedIOBase;
# TextIOWrapper from TextIOBase.
# No prior io spec checks __bases__[0].__name__ for any of these.
# Function values containing '[' must be double-quoted in table rows.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra72.concrete_class_bases:
  description: "FileIO/__bases__[0].__name__=='RawIOBase', BufferedReader/__bases__[0].__name__=='BufferedIOBase', TextIOWrapper/__bases__[0].__name__=='TextIOBase' — each concrete io class inherits from its corresponding abstract base; __bases__[0].__name__ gives the immediate base name; no prior io spec checks __bases__[0].__name__ for FileIO/BufferedReader/TextIOWrapper in iohier72 namespace; function values with '[' are double-quoted per ZSDL rules; novel class hierarchy anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: iohier72cbases

  columns: [id, function, args, expected]
  rows:
    - [file_io_bases_rawiobase,           "FileIO.__bases__[0].__name__.__eq__",          ["RawIOBase"],      true]
    - [buffered_reader_bases_bufferedbase, "BufferedReader.__bases__[0].__name__.__eq__",  ["BufferedIOBase"], true]
    - [text_io_wrapper_bases_textbase,     "TextIOWrapper.__bases__[0].__name__.__eq__",   ["TextIOBase"],     true]

# ---------------------------------------------------------------------------
# Abstract io base classes: __mro__.__len__() == 3
#
# RawIOBase, BufferedIOBase, and TextIOBase each have a 3-entry MRO:
#   [RawIOBase, IOBase, object]
#   [BufferedIOBase, IOBase, object]
#   [TextIOBase, IOBase, object]
#
# No prior io spec checks __mro__.__len__() for any io class. Novel anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra72.abstract_mro_lengths:
  description: "RawIOBase/BufferedIOBase/TextIOBase __mro__.__len__()==3 — each abstract io base class has a 3-entry MRO: [ClassItself, IOBase, object]; no prior io spec checks __mro__.__len__() for any io class in iohier72 namespace; novel MRO length anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: iohier72amro

  columns: [id, function, args, expected]
  rows:
    - [raw_io_base_mro_3,      RawIOBase.__mro__.__len__,     [], 3]
    - [buffered_io_base_mro_3, BufferedIOBase.__mro__.__len__, [], 3]
    - [text_io_base_mro_3,     TextIOBase.__mro__.__len__,    [], 3]

# ---------------------------------------------------------------------------
# Concrete io classes: __mro__.__len__() == 4
#
# FileIO, BufferedReader, and TextIOWrapper each have a 4-entry MRO:
#   [FileIO, RawIOBase, IOBase, object]
#   [BufferedReader, BufferedIOBase, IOBase, object]
#   [TextIOWrapper, TextIOBase, IOBase, object]
#
# No prior io spec checks __mro__.__len__() for any io class. Novel anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra72.concrete_mro_lengths:
  description: "FileIO/BufferedReader/TextIOWrapper __mro__.__len__()==4 — each concrete io class has a 4-entry MRO: [ClassItself, AbstractBase, IOBase, object]; no prior io spec checks __mro__.__len__() for any io class in iohier72 namespace; novel MRO length anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: iohier72cmro

  columns: [id, function, args, expected]
  rows:
    - [file_io_mro_4,          FileIO.__mro__.__len__,         [], 4]
    - [buffered_reader_mro_4,  BufferedReader.__mro__.__len__,  [], 4]
    - [text_io_wrapper_mro_4,  TextIOWrapper.__mro__.__len__,   [], 4]

invariant io_extra72.RawIOBase_bases_IOBase:
  description: "RawIOBase.__bases__[0].__name__.__eq__('IOBase') == True — RawIOBase inherits directly from IOBase (the abstract base for all I/O classes); __bases__[0] is IOBase; IOBase.__name__ is 'IOBase'; no prior io spec checks RawIOBase.__bases__[0].__name__ in iohier72 namespace; novel class hierarchy anchor; function value contains '[' so it is double-quoted; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_hierarchy
  kind: python_call_eq
  function: "RawIOBase.__bases__[0].__name__.__eq__"
  args: ["IOBase"]
  expected: true

invariant io_extra72.FileIO_bases_RawIOBase:
  description: "FileIO.__bases__[0].__name__.__eq__('RawIOBase') == True — FileIO inherits from RawIOBase (the abstract base for raw byte I/O); __bases__[0] is RawIOBase; RawIOBase.__name__ is 'RawIOBase'; no prior io spec checks FileIO.__bases__[0].__name__ in iohier72 namespace; novel class hierarchy anchor; function value contains '[' so it is double-quoted; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_hierarchy
  kind: python_call_eq
  function: "FileIO.__bases__[0].__name__.__eq__"
  args: ["RawIOBase"]
  expected: true

invariant io_extra72.RawIOBase_mro_3:
  description: "RawIOBase.__mro__.__len__() == 3 — the MRO for RawIOBase is [RawIOBase, IOBase, object] with 3 entries; no prior io spec checks RawIOBase.__mro__.__len__() in iohier72 namespace; novel MRO length anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_hierarchy
  kind: python_call_eq
