spec: mp3361
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "https://docs.python.org/3/library/multiprocessing.managers.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 671 (mp3361): __invert__, __floor__, __ceil__ dict-presence (unary ~x, math.floor(x), math.ceil(x)) for multiprocessing types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: multiprocessing.Process, pool.Pool, pool.AsyncResult, pool.MapResult, managers.SyncManager, managers.BaseListProxy, managers._BaseDictProxy, managers._BaseSetProxy."
    - "Key finding (__invert__): all 8 multiprocessing classes return false for __invert__. Bitwise inversion (__invert__, ~x) belongs to the integer numeric data model (numbers.Integral). None of the 8 multiprocessing types model an integer bitfield. multiprocessing.Process is a subprocess lifecycle manager; ~process is not a defined Python expression. pool.Pool/AsyncResult/MapResult: work-dispatch and result-handle types; no integer data model. managers.SyncManager: server process manager; ~manager is undefined. managers.BaseListProxy: proxies list — list defines no __invert__. managers._BaseDictProxy: proxies dict — dict defines no __invert__. managers._BaseSetProxy: proxies set — set defines no __invert__; set operations use binary &, |, ^, - operators, not unary bitwise inversion."
    - "Key finding (__floor__): all 8 multiprocessing classes return false for __floor__. math.floor() delegates to __floor__ (numbers.Real protocol). multiprocessing types define no arithmetic protocol — confirmed false across waves 658–670. managers._BaseSetProxy key note: set defines no __floor__; set cardinality is obtained via len(), not math.floor(). managers._BaseDictProxy: dict defines no __floor__; dict size is obtained via len(). managers.BaseListProxy: list defines no __floor__; list length is obtained via len(). Process/Pool/AsyncResult/MapResult/SyncManager: process-management types with no numeric rounding semantics whatsoever."
    - "Key finding (__ceil__): all 8 multiprocessing classes return false for __ceil__. math.ceil() delegates to __ceil__ (numbers.Real protocol), analogously to __floor__. None of the 8 multiprocessing types implement numeric magnitude. managers._BaseSetProxy key note: set defines no __ceil__; set cardinality is len(), not ceil(). managers._BaseDictProxy: dict defines no __ceil__. managers.BaseListProxy: list defines no __ceil__. multiprocessing.Process/pool.Pool/pool.AsyncResult/pool.MapResult/managers.SyncManager: process-management types with no numeric rounding semantics."
    - "All 24 values in this wave are false. multiprocessing is a process-based concurrency library; its types interact exclusively through explicit method calls, subprocess lifecycle management, and IPC — never through Python's integer inversion or numeric rounding operators."
    - "Cross-wave summary for mp subjects:"
    - "  Wave 658 (mp3166): __add__/__sub__/__mul__ — BaseListProxy __add__=true, __mul__=true; others false."
    - "  Wave 659 (mp3181): __truediv__/__floordiv__/__mod__ — all false for all 8."
    - "  Wave 660 (mp3196): __pow__/__lshift__/__rshift__ — all false for all 8."
    - "  Wave 661 (mp3211): __and__/__or__/__xor__ — all false for all 8."
    - "  Wave 662 (mp3226): __radd__/__rsub__/__rmul__ — all false for all 8."
    - "  Wave 663 (mp3241): __rtruediv__/__rfloordiv__/__rmod__ — all false for all 8."
    - "  Wave 664 (mp3256): __rpow__/__rlshift__/__rrshift__ — all false for all 8."
    - "  Wave 665 (mp3271): __rand__/__ror__/__rxor__ — all false for all 8."
    - "  Wave 666 (mp3286): __iadd__/__isub__/__imul__ — all false for all 8."
    - "  Wave 667 (mp3301): __itruediv__/__ifloordiv__/__imod__ — all false for all 8."
    - "  Wave 668 (mp3316): __ipow__/__ilshift__/__irshift__ — all false for all 8."
    - "  Wave 669 (mp3331): __iand__/__ior__/__ixor__ — all false for all 8."
    - "  Wave 670 (mp3346): __neg__/__pos__/__abs__ — all false for all 8."
    - "  Wave 671 (mp3361): __invert__/__floor__/__ceil__ — all false for all 8."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __invert__ dict-presence — operator.contains(Cls.__dict__, '__invert__')
#
# All 8 multiprocessing classes return false for __invert__.
# Bitwise inversion (__invert__, ~x) is an integer numeric data model method.
# multiprocessing.Process: subprocess lifecycle manager; ~process is not a
#   valid Python expression.
# pool.Pool/AsyncResult/MapResult: work-dispatch and result-handle types;
#   no integer data model is defined for any of them.
# managers.SyncManager: server process manager; ~manager is undefined.
# managers.BaseListProxy: proxies list — list defines no __invert__.
# managers._BaseDictProxy: proxies dict — dict defines no __invert__.
# managers._BaseSetProxy: proxies set — set defines no __invert__. Set
#   operations use binary &, |, ^, - operators (not unary bitwise inversion).
#   ~proxy is not a valid Python expression for any proxy type.
# ---------------------------------------------------------------------------

table mp3361.invert:
  description: "multiprocessing types __invert__ dict-presence checks; wave 671"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3361

  columns: [id, function, args, expected]
  rows:
    - ["mp3361001", operator.contains, [multiprocessing.Process.__dict__,                 "__invert__"], false]
    - ["mp3361002", operator.contains, [multiprocessing.pool.Pool.__dict__,               "__invert__"], false]
    - ["mp3361003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__invert__"], false]
    - ["mp3361004", operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__invert__"], false]
    - ["mp3361005", operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__invert__"], false]
    - ["mp3361006", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__invert__"], false]
    - ["mp3361007", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__invert__"], false]
    - ["mp3361008", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__invert__"], false]

# ---------------------------------------------------------------------------
# __floor__ dict-presence — operator.contains(Cls.__dict__, '__floor__')
#
# All 8 multiprocessing classes return false for __floor__.
# math.floor() delegates to __floor__ (numbers.Real protocol). multiprocessing
#   types define no arithmetic protocol — confirmed false across waves 658–670.
# managers._BaseSetProxy key note: set defines no __floor__. Set cardinality is
#   obtained via len(s), not math.floor(s). The proxy does not define __floor__.
# managers._BaseDictProxy: dict defines no __floor__. Dict size is len(d).
# managers.BaseListProxy: list defines no __floor__. List length is len(l).
# multiprocessing.Process: subprocess lifecycle manager; math.floor(process) is
#   not a meaningful Python operation.
# pool.Pool/AsyncResult/MapResult: task dispatchers and result handles;
#   no numeric rounding semantics are defined.
# managers.SyncManager: server process manager; math.floor(manager) is not
#   defined.
# ---------------------------------------------------------------------------

