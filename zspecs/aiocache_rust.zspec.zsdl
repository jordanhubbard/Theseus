spec: aiocache_rust
version: ">=3.9"
backend: rust_module(aiocache_rust)

docs: https://aiocache.aio-libs.org/en/latest/

provenance:
  derived_from:
    - "https://aiocache.aio-libs.org/en/latest/ — aiocache documentation"
  not_derived_from:
    - "aiocache source: aiocache/__init__.py"
  notes:
    - "aiocache provides async caching for Python."
    - "aiocache.Cache is available."
    - "aiocache.SimpleMemoryCache is available."
    - "aiocache.SimpleMemoryCache.__name__ == 'SimpleMemoryCache'."
    - "aiocache.__version__ is a non-empty string."
    - "Expose aiocache_simple_name() -> str: aiocache.SimpleMemoryCache.__name__."
    - "Expose aiocache_has_cache() -> bool: hasattr(aiocache, 'Cache')."
    - "Expose aiocache_version_nonempty() -> bool: len(aiocache.__version__) > 0."
    - "All test vectors verified against aiocache 0.12.3."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# aiocache_simple_name — SimpleMemoryCache class name
invariant aiocache_rust.cache.simple_name:
  description: "aiocache.SimpleMemoryCache.__name__ == 'SimpleMemoryCache'"
  category: cache
  kind: python_call_eq
  function: aiocache_simple_name
  args: []
  expected: "SimpleMemoryCache"

# aiocache_has_cache — Cache class present
invariant aiocache_rust.module.has_cache:
  description: "aiocache.Cache is available"
  category: module
  kind: python_call_eq
  function: aiocache_has_cache
  args: []
  expected: true

# aiocache_version_nonempty — version non-empty
invariant aiocache_rust.version.nonempty:
  description: "aiocache.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: aiocache_version_nonempty
  args: []
  expected: true

