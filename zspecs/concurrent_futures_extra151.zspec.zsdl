spec: concurrent_futures_extra151
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: concurrent.futures module-level function identity. concurrent.futures.wait.__module__=='concurrent.futures._base' (len=24; wait is defined in Lib/concurrent/futures/_base.py); concurrent.futures.wait.__code__.co_name=='wait' (len=4); concurrent.futures.wait.__code__.co_argcount==3 (positional args: fs, timeout, return_when); concurrent.futures.as_completed.__module__=='concurrent.futures._base' (len=24; same module as wait); concurrent.futures.as_completed.__code__.co_name=='as_completed' (len=12); concurrent.futures.as_completed.__code__.co_argcount==2 (positional args: fs, timeout); concurrent.futures.FIRST_COMPLETED.__class__.__name__=='str' (FIRST_COMPLETED is a string constant, not an enum value); concurrent.futures.ALL_COMPLETED.__class__.__name__=='str' (same — all return_when constants are plain strings in Python 3.14.3). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.wait.__code__.co_argcount==3 — wait() signature is wait(fs, timeout=None, return_when=ALL_COMPLETED); the 3 positional parameters are: fs (iterable of futures), timeout (optional timeout in seconds), return_when (one of FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED); co_argcount counts all positional params including those with defaults; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.as_completed.__code__.co_argcount==2 — as_completed() signature is as_completed(fs, timeout=None); 2 positional parameters: fs (iterable of futures), timeout; co_argcount==2; as_completed yields futures as they complete (unordered); compare wait() which returns all at once; as_completed has fewer parameters (2) than wait (3); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.FIRST_COMPLETED.__class__.__name__=='str' — the return_when constants (FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED) are plain Python string objects in Python 3.14.3, NOT an Enum; FIRST_COMPLETED.__class__.__name__=='str' (len=3); this contrasts with some other Python stdlib modules that use enum.Enum for such constants; the string values are the constant names themselves; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.wait function identity — extra151
#
# concurrent.futures.wait.__module__.__eq__('concurrent.futures._base')  == True
# concurrent.futures.wait.__code__.co_name.__eq__('wait')                == True
# concurrent.futures.wait.__code__.co_argcount                           == 3
# ---------------------------------------------------------------------------

table concurrent_futures_extra151.cf_wait_function_identity:
  description: "concurrent.futures.wait function identity checks in cfwait151 namespace — concurrent.futures.wait.__module__=='concurrent.futures._base' (len=24; wait is defined in Lib/concurrent/futures/_base.py — the same private submodule that defines Executor, Future, and the exception classes; NOT in 'concurrent.futures' top-level); concurrent.futures.wait.__code__.co_name=='wait' (len=4; the code object's co_name matches the function name); concurrent.futures.wait.__code__.co_argcount==3 (the 3 positional parameters are: fs, timeout, return_when — all positional-or-keyword, including those with defaults; wait's signature is wait(fs, timeout=None, return_when=ALL_COMPLETED)); wait returns a named tuple (done, not_done) of sets; wait.__module__.__len__()==24 ('concurrent.futures._base': len=24); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfwait151

  columns: [id, function, args, expected, description]
  rows:
    - [wait_mod_eq,       "concurrent.futures.wait.__module__.__eq__",               ["concurrent.futures._base"],  true,  "concurrent.futures.wait.__module__ == 'concurrent.futures._base' (len=24; defined in _base.py); verified with Python 3.14.3"]
    - [wait_coname_eq,    "concurrent.futures.wait.__code__.co_name.__eq__",         ["wait"],                      true,  "concurrent.futures.wait.__code__.co_name == 'wait' (len=4); verified with Python 3.14.3"]
    - [wait_argcount_eq,  "concurrent.futures.wait.__code__.co_argcount.__eq__",     [3],                           true,  "concurrent.futures.wait.__code__.co_argcount == 3 (fs, timeout, return_when); verified with Python 3.14.3"]
    - [wait_mod_len,      "concurrent.futures.wait.__module__.__len__",              [],                            24,    "concurrent.futures.wait.__module__.__len__() == 24 ('concurrent.futures._base'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.as_completed function identity — extra151
#
# concurrent.futures.as_completed.__module__.__eq__('concurrent.futures._base') == True
# concurrent.futures.as_completed.__code__.co_name.__eq__('as_completed')       == True
# concurrent.futures.as_completed.__code__.co_argcount                          == 2
# ---------------------------------------------------------------------------

table concurrent_futures_extra151.cf_as_completed_function_identity:
  description: "concurrent.futures.as_completed function identity checks in cfascomp151 namespace — concurrent.futures.as_completed.__module__=='concurrent.futures._base' (len=24; same module as wait — both utility functions are defined in _base.py); concurrent.futures.as_completed.__code__.co_name=='as_completed' (len=12; the code object's co_name matches the function name; 'as_completed' is 12 chars: 'as'=2+'_'=1+'completed'=9=12); concurrent.futures.as_completed.__code__.co_argcount==2 (the 2 positional parameters are: fs, timeout — 1 fewer than wait which has 3; as_completed yields futures as they complete in unordered fashion); as_completed.__code__.co_name.__len__()==12 (3 times longer than wait's 'wait'=4); co_argcount comparison: as_completed(2) < wait(3); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfascomp151

  columns: [id, function, args, expected, description]
  rows:
    - [ascomp_mod_eq,      "concurrent.futures.as_completed.__module__.__eq__",              ["concurrent.futures._base"],  true,  "concurrent.futures.as_completed.__module__ == 'concurrent.futures._base' (len=24; same module as wait); verified with Python 3.14.3"]
    - [ascomp_coname_eq,   "concurrent.futures.as_completed.__code__.co_name.__eq__",       ["as_completed"],              true,  "concurrent.futures.as_completed.__code__.co_name == 'as_completed' (len=12); verified with Python 3.14.3"]
    - [ascomp_argcount_eq, "concurrent.futures.as_completed.__code__.co_argcount.__eq__",   [2],                           true,  "concurrent.futures.as_completed.__code__.co_argcount == 2 (fs, timeout — 1 fewer than wait's 3); verified with Python 3.14.3"]
    - [ascomp_coname_len,  "concurrent.futures.as_completed.__code__.co_name.__len__",      [],                            12,    "concurrent.futures.as_completed.__code__.co_name.__len__() == 12 ('as_completed'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures return_when constants identity — extra151
#
# concurrent.futures.FIRST_COMPLETED.__class__.__name__.__eq__('str') == True
# concurrent.futures.ALL_COMPLETED.__class__.__name__.__eq__('str')   == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra151.cf_return_when_constants_identity:
  description: "concurrent.futures return_when constants class identity checks in cfconst151 namespace — concurrent.futures.FIRST_COMPLETED.__class__.__name__=='str' (len=3; FIRST_COMPLETED is a plain Python string constant, NOT an enum.Enum value; it is one of three return_when constants accepted by wait()); concurrent.futures.ALL_COMPLETED.__class__.__name__=='str' (len=3; same — ALL_COMPLETED is the default value for wait()'s return_when parameter); the three return_when constants (FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED) are all plain strings in Python 3.14.3 — their class name is 'str' not 'str' subclass or Enum; FIRST_COMPLETED.__class__.__name__.__len__()==3 ('str'); ALL_COMPLETED.__class__.__name__.__len__()==3 ('str'; same length as FIRST_COMPLETED's class name); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfconst151

  columns: [id, function, args, expected, description]
  rows:
    - [firstcomp_cls_eq, "concurrent.futures.FIRST_COMPLETED.__class__.__name__.__eq__", ["str"],  true,  "concurrent.futures.FIRST_COMPLETED.__class__.__name__ == 'str' (plain string constant, not an Enum); verified with Python 3.14.3"]
    - [allcomp_cls_eq,   "concurrent.futures.ALL_COMPLETED.__class__.__name__.__eq__",   ["str"],  true,  "concurrent.futures.ALL_COMPLETED.__class__.__name__ == 'str' (plain string constant, default for wait()'s return_when); verified with Python 3.14.3"]
    - [firstcomp_len,    "concurrent.futures.FIRST_COMPLETED.__class__.__name__.__len__", [],       3,     "concurrent.futures.FIRST_COMPLETED.__class__.__name__.__len__() == 3 ('str'); verified with Python 3.14.3"]
    - [allcomp_len,      "concurrent.futures.ALL_COMPLETED.__class__.__name__.__len__",   [],       3,     "concurrent.futures.ALL_COMPLETED.__class__.__name__.__len__() == 3 ('str'; same as FIRST_COMPLETED class name len); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra151
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra151.cf_wait_module_is_base:
  description: "concurrent.futures.wait.__module__.__eq__('concurrent.futures._base') returns True — concurrent.futures.wait is defined in Lib/concurrent/futures/_base.py and its __module__ is 'concurrent.futures._base' (len=24); wait() blocks until futures in the given set are done or a timeout occurs; it returns a named tuple (done, not_done) of two sets; wait() accepts 3 positional parameters: fs (iterable of futures), timeout (optional float), return_when (one of FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED); wait.__module__=='concurrent.futures._base' is the same as Executor.__module__ and Future.__module__ (established in extra150); NEW in extra151: first standalone concurrent.futures.wait.__module__ identity invariant in cfwait151 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.wait.__module__.__eq__"
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra151.cf_wait_co_argcount_3:
  description: "concurrent.futures.wait.__code__.co_argcount.__eq__(3) returns True — concurrent.futures.wait has 3 positional-or-keyword parameters: fs (the iterable of futures to wait for), timeout (optional maximum time in seconds to wait, default None), and return_when (one of FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED, default ALL_COMPLETED); co_argcount counts all positional parameters including those with defaults; compare: concurrent.futures.as_completed.__code__.co_argcount==2 (only fs and timeout — no return_when parameter; as_completed always yields all futures as they complete); the co_argcount of wait(3) > as_completed(2) reflects wait's additional return_when parameter; NEW in extra151: first standalone concurrent.futures.wait.__code__.co_argcount invariant in cfwait151 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.wait.__code__.co_argcount.__eq__"
  args: [3]
  expected: true

invariant concurrent_futures_extra151.cf_as_completed_co_argcount_2:
  description: "concurrent.futures.as_completed.__code__.co_argcount.__eq__(2) returns True — concurrent.futures.as_completed has 2 positional-or-keyword parameters: fs (iterable of futures) and timeout (optional timeout in seconds, default None); as_completed is a generator function that yields futures as they complete in completion order (not submission order); co_argcount==2 is 1 fewer than wait's co_argcount==3 because as_completed has no return_when parameter (it always yields all futures); as_completed.__code__.co_name=='as_completed' (len=12); as_completed.__module__=='concurrent.futures._base' (len=24; same as wait); NEW in extra151: first standalone concurrent.futures.as_completed.__code__.co_argcount invariant in cfascomp151 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.as_completed.__code__.co_argcount.__eq__"
  args: [2]
  expected: true

invariant concurrent_futures_extra151.cf_FIRST_COMPLETED_class_is_str:
  description: "concurrent.futures.FIRST_COMPLETED.__class__.__name__.__eq__('str') returns True — concurrent.futures.FIRST_COMPLETED is a plain Python string constant (str), NOT an enum.Enum value; FIRST_COMPLETED is one of three constants accepted by concurrent.futures.wait()'s return_when parameter (the other two are FIRST_EXCEPTION and ALL_COMPLETED); all three constants are plain strings in Python 3.14.3; FIRST_COMPLETED.__class__.__name__=='str' (len=3); this can be contrasted with some other stdlib modules that have migrated to using enum.Enum for named constants; the string value of FIRST_COMPLETED is 'FIRST_COMPLETED' (the constant name itself); NEW in extra151: first standalone concurrent.futures.FIRST_COMPLETED class name identity invariant in cfconst151 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.FIRST_COMPLETED.__class__.__name__.__eq__"
  args: ["str"]
  expected: true

invariant concurrent_futures_extra151.cf_as_completed_coname_eq:
  description: "concurrent.futures.as_completed.__code__.co_name.__eq__('as_completed') returns True — as_completed's code object has co_name=='as_completed' (len=12; 'as'=2+'_'=1+'completed'=9=12); co_name is the name given to the function object at definition time; it matches the function's __name__ attribute; as_completed.__code__.co_name.__len__()==12; compare: concurrent.futures.wait.__code__.co_name=='wait' (len=4; 3 times shorter than 'as_completed'=12); as_completed is a generator function that yields Future objects in the order they complete; both wait and as_completed are defined in concurrent.futures._base (module len=24); NEW in extra151: first standalone concurrent.futures.as_completed.__code__.co_name identity invariant in cfascomp151 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.as_completed.__code__.co_name.__eq__"
  args: ["as_completed"]
  expected: true

