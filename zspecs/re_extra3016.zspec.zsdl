spec: re3016
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module class hierarchy"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 648 (re3016): __iter__, __next__, __reversed__ dict-presence checks for re types."
    - "re.Pattern is a compiled regular expression object — not an iterator or sequence; it does not define __iter__, __next__, or __reversed__."
    - "re.Match is a match result object — not iterable; it does not define __iter__, __next__, or __reversed__."
    - "re.RegexFlag is an IntFlag enum; enum iteration is done on the class itself via the metaclass, not via __iter__ in RegexFlag.__dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __iter__ dict-presence — operator.contains(Cls.__dict__, '__iter__')
#
# re.Pattern, re.Match, and re.RegexFlag do not define __iter__; all false.
# ---------------------------------------------------------------------------

table re3016.iter:
  description: "re types __iter__ dict-presence checks; wave 648"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re3016
  columns: [id, function, args, expected]
  rows:
    - ["re3016001", operator.contains, [re.Pattern.__dict__,   "__iter__"], false]
    - ["re3016002", operator.contains, [re.Match.__dict__,     "__iter__"], false]
    - ["re3016003", operator.contains, [re.RegexFlag.__dict__, "__iter__"], false]
    - ["re3016004", operator.contains, [re.Pattern.__dict__,   "__iter__"], false]
    - ["re3016005", operator.contains, [re.Match.__dict__,     "__iter__"], false]
    - ["re3016006", operator.contains, [re.RegexFlag.__dict__, "__iter__"], false]

