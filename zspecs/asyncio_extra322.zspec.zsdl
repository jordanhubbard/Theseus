spec: asyncio_extra322
version: ">=3.4"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-exceptions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-exceptions.html — asyncio Exceptions documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers the asyncio exception class hierarchy: __name__, __module__, and __bases__[0].__name__."
    - "asyncio.CancelledError.__module__ == 'asyncio.exceptions' — defined in the asyncio.exceptions submodule."
    - "asyncio.TimeoutError.__module__ == 'builtins' — it is the built-in TimeoutError re-exported by asyncio."
    - "asyncio.TimeoutError.__bases__[0].__name__ == 'OSError' — built-in TimeoutError inherits from OSError."
    - "asyncio.InvalidStateError.__module__ == 'asyncio.exceptions'."
    - "asyncio.SendfileNotAvailableError.__module__ == 'asyncio.exceptions'."
    - "asyncio.IncompleteReadError.__module__ == 'asyncio.exceptions' — defined there, not asyncio.streams."
    - "asyncio.LimitOverrunError.__module__ == 'asyncio.exceptions'."
    - "asyncio.CancelledError.__bases__[0].__name__ == 'BaseException' — it is a BaseException subclass."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# CancelledError — name, module, and base class
#
# asyncio.CancelledError inherits from BaseException (not Exception), so it
# can propagate through blanket except Exception handlers unchanged.
# Its __module__ is 'asyncio.exceptions' (the submodule where it is defined),
# not '_asyncio' or 'asyncio'.
# ---------------------------------------------------------------------------

invariant asyncio_extra322.CancelledError.name:
  description: "asyncio.CancelledError.__name__ == 'CancelledError'"
  category: exception_names
  kind: python_call_eq
  function: CancelledError.__name__.__eq__
  args: ["CancelledError"]
  expected: true

invariant asyncio_extra322.CancelledError.module:
  description: "asyncio.CancelledError.__module__ == 'asyncio.exceptions'"
  category: exception_modules
  kind: python_call_eq
  function: CancelledError.__module__.__eq__
  args: ["asyncio.exceptions"]
  expected: true

invariant asyncio_extra322.CancelledError.base:
  description: "asyncio.CancelledError.__bases__[0].__name__ == 'BaseException'"
  category: exception_hierarchy
  kind: python_call_eq
  function: CancelledError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "BaseException"

# ---------------------------------------------------------------------------
# TimeoutError — name, module, and base class
#
# asyncio.TimeoutError is the built-in TimeoutError re-exported by asyncio.
# Its __module__ is 'builtins' and its base is OSError (the built-in hierarchy).
# ---------------------------------------------------------------------------

invariant asyncio_extra322.TimeoutError.name:
  description: "asyncio.TimeoutError.__name__ == 'TimeoutError'"
  category: exception_names
  kind: python_call_eq
  function: TimeoutError.__name__.__eq__
  args: ["TimeoutError"]
  expected: true

invariant asyncio_extra322.TimeoutError.module:
  description: "asyncio.TimeoutError.__module__ == 'builtins' — it is the built-in TimeoutError"
  category: exception_modules
  kind: python_call_eq
  function: TimeoutError.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant asyncio_extra322.TimeoutError.base:
  description: "asyncio.TimeoutError.__bases__[0].__name__ == 'OSError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: TimeoutError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "OSError"

# ---------------------------------------------------------------------------
# InvalidStateError — name, module, and base class
#
# asyncio.InvalidStateError is raised when a Future or Task is put into
# an invalid state. It inherits from Exception.
# ---------------------------------------------------------------------------

invariant asyncio_extra322.InvalidStateError.name:
  description: "asyncio.InvalidStateError.__name__ == 'InvalidStateError'"
  category: exception_names
  kind: python_call_eq
  function: InvalidStateError.__name__.__eq__
  args: ["InvalidStateError"]
  expected: true

invariant asyncio_extra322.InvalidStateError.module:
  description: "asyncio.InvalidStateError.__module__ == 'asyncio.exceptions'"
  category: exception_modules
  kind: python_call_eq
  function: InvalidStateError.__module__.__eq__
  args: ["asyncio.exceptions"]
  expected: true

invariant asyncio_extra322.InvalidStateError.base:
  description: "asyncio.InvalidStateError.__bases__[0].__name__ == 'Exception'"
  category: exception_hierarchy
  kind: python_call_eq
  function: InvalidStateError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

# ---------------------------------------------------------------------------
# SendfileNotAvailableError — name, module, and base class
#
# asyncio.SendfileNotAvailableError is raised when the OS sendfile() syscall
# is unavailable or unsupported. It inherits from RuntimeError.
# ---------------------------------------------------------------------------

invariant asyncio_extra322.SendfileNotAvailableError.name:
  description: "asyncio.SendfileNotAvailableError.__name__ == 'SendfileNotAvailableError'"
  category: exception_names
  kind: python_call_eq
  function: SendfileNotAvailableError.__name__.__eq__
  args: ["SendfileNotAvailableError"]
  expected: true

invariant asyncio_extra322.SendfileNotAvailableError.module:
  description: "asyncio.SendfileNotAvailableError.__module__ == 'asyncio.exceptions'"
  category: exception_modules
  kind: python_call_eq
  function: SendfileNotAvailableError.__module__.__eq__
  args: ["asyncio.exceptions"]
  expected: true

invariant asyncio_extra322.SendfileNotAvailableError.base:
  description: "asyncio.SendfileNotAvailableError.__bases__[0].__name__ == 'RuntimeError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: SendfileNotAvailableError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "RuntimeError"

# ---------------------------------------------------------------------------
# IncompleteReadError — name, module, and base class
#
# asyncio.IncompleteReadError is raised by StreamReader when the connection is
# closed before enough bytes are available. It inherits from EOFError.
# Despite being closely associated with asyncio.streams, it is defined in
# asyncio.exceptions.
# ---------------------------------------------------------------------------

invariant asyncio_extra322.IncompleteReadError.name:
  description: "asyncio.IncompleteReadError.__name__ == 'IncompleteReadError'"
  category: exception_names
  kind: python_call_eq
  function: IncompleteReadError.__name__.__eq__
  args: ["IncompleteReadError"]
  expected: true

invariant asyncio_extra322.IncompleteReadError.module:
  description: "asyncio.IncompleteReadError.__module__ == 'asyncio.exceptions'"
  category: exception_modules
  kind: python_call_eq
  function: IncompleteReadError.__module__.__eq__
  args: ["asyncio.exceptions"]
  expected: true

invariant asyncio_extra322.IncompleteReadError.base:
  description: "asyncio.IncompleteReadError.__bases__[0].__name__ == 'EOFError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: IncompleteReadError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "EOFError"

# ---------------------------------------------------------------------------
# LimitOverrunError — name, module, and base class
#
# asyncio.LimitOverrunError is raised by StreamReader when the read buffer
# exceeds the configured limit. It inherits from Exception.
# ---------------------------------------------------------------------------

invariant asyncio_extra322.LimitOverrunError.name:
  description: "asyncio.LimitOverrunError.__name__ == 'LimitOverrunError'"
  category: exception_names
  kind: python_call_eq
  function: LimitOverrunError.__name__.__eq__
  args: ["LimitOverrunError"]
  expected: true

invariant asyncio_extra322.LimitOverrunError.module:
  description: "asyncio.LimitOverrunError.__module__ == 'asyncio.exceptions'"
  category: exception_modules
  kind: python_call_eq
  function: LimitOverrunError.__module__.__eq__
  args: ["asyncio.exceptions"]
  expected: true

invariant asyncio_extra322.LimitOverrunError.base:
  description: "asyncio.LimitOverrunError.__bases__[0].__name__ == 'Exception'"
  category: exception_hierarchy
  kind: python_call_eq
  function: LimitOverrunError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"
