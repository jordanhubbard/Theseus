spec: multiprocessing_extra2071
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "https://docs.python.org/3/library/multiprocessing.html#synchronization-primitives"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 585 (_extra2071): __pos__/__neg__, __getattribute__, __reduce__/__reduce_ex__, __copy__/__deepcopy__ dict-presence checks."
    - "multiprocessing.Process and synchronize types are process/IPC primitives, not numeric or copy-protocol types."
    - "multiprocessing.synchronize provides Lock, RLock, Semaphore, BoundedSemaphore, Event, Condition."
    - "None of these types define __pos__, __neg__, __getattribute__, __reduce__, __reduce_ex__, __copy__, or __deepcopy__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table multiprocessing_extra2071.unary_sign_protocol:
  description: "multiprocessing.Process and synchronize types __pos__/__neg__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2071

  columns: [id, function, args, expected]
  rows:
    - ["mp2071001", "multiprocessing.Process.__dict__.__contains__", ["__pos__"], false]
    - ["mp2071002", "multiprocessing.Process.__dict__.__contains__", ["__neg__"], false]
    - ["mp2071003", "multiprocessing.synchronize.Lock.__dict__.__contains__", ["__pos__"], false]
    - ["mp2071004", "multiprocessing.synchronize.Lock.__dict__.__contains__", ["__neg__"], false]
    - ["mp2071005", "multiprocessing.synchronize.RLock.__dict__.__contains__", ["__pos__"], false]
    - ["mp2071006", "multiprocessing.synchronize.RLock.__dict__.__contains__", ["__neg__"], false]
    - ["mp2071007", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__pos__"], false]
    - ["mp2071008", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__neg__"], false]
    - ["mp2071009", "multiprocessing.synchronize.Event.__dict__.__contains__", ["__pos__"], false]
    - ["mp2071010", "multiprocessing.synchronize.Event.__dict__.__contains__", ["__neg__"], false]

