    - "All values false — itertools iterator types do not define __format__, __sizeof__, or __dir__ in their own __dict__."
    - "itertools.pairwise requires Python >= 3.10."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

