spec: threading_extra222
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers threading class name length contracts."
    - "threading.Thread.__name__.__len__() == 6 — 'Thread' has 6 characters. Verified with Python 3.14.3."
    - "threading.Semaphore.__name__.__len__() == 9 — 'Semaphore' has 9 characters. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__name__.__len__() == 16 — 'BoundedSemaphore' has 16 characters. Verified with Python 3.14.3."
    - "threading.Condition.__name__.__len__() == 9 — 'Condition' has 9 characters. Verified with Python 3.14.3."
    - "threading.Event.__name__.__len__() == 5 — 'Event' has 5 characters. Verified with Python 3.14.3."
    - "threading.Timer.__name__.__len__() == 5 — 'Timer' has 5 characters. Verified with Python 3.14.3."
    - "threading.Barrier.__name__.__len__() == 7 — 'Barrier' has 7 characters. Verified with Python 3.14.3."
    - "threading.Thread.__name__.__lt__('Timer') == True — 'Thread' < 'Timer' alphabetically (Th < Ti). Verified with Python 3.14.3."
    - "threading.Semaphore.__name__.__eq__('Semaphore') == True. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__name__.__contains__('Semaphore') == True — 'BoundedSemaphore' contains the substring 'Semaphore'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading class name lengths
#
# Verified with Python 3.14.3:
#   Thread.__name__.__len__() == 6
#   Semaphore.__name__.__len__() == 9
#   BoundedSemaphore.__name__.__len__() == 16
#   Condition.__name__.__len__() == 9
#   Event.__name__.__len__() == 5
#   Timer.__name__.__len__() == 5
#   Barrier.__name__.__len__() == 7
# ---------------------------------------------------------------------------

table threading_extra222.name_lengths:
  description: "threading class __name__ length checks; new to extra222"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra222namelen

  columns: [id, function, args, expected, description]
  rows:
    - [thread_name_len_eq,
       Thread.__name__.__len__,
       [],
       6,
       "threading.Thread.__name__.__len__() == 6 — the Thread class name string is 'Thread' which has 6 characters; str.__len__() returns 6; new to extra222"]
    - [semaphore_name_len_eq,
       Semaphore.__name__.__len__,
       [],
       9,
       "threading.Semaphore.__name__.__len__() == 9 — the Semaphore class name string is 'Semaphore' which has 9 characters; str.__len__() returns 9; new to extra222"]
    - [bounded_semaphore_name_len_eq,
       BoundedSemaphore.__name__.__len__,
       [],
       16,
       "threading.BoundedSemaphore.__name__.__len__() == 16 — the BoundedSemaphore class name string is 'BoundedSemaphore' which has 16 characters; str.__len__() returns 16; new to extra222"]
    - [condition_name_len_eq,
       Condition.__name__.__len__,
       [],
       9,
       "threading.Condition.__name__.__len__() == 9 — the Condition class name string is 'Condition' which has 9 characters; str.__len__() returns 9; new to extra222"]
    - [event_name_len_eq,
       Event.__name__.__len__,
       [],
       5,
       "threading.Event.__name__.__len__() == 5 — the Event class name string is 'Event' which has 5 characters; str.__len__() returns 5; new to extra222"]
    - [timer_name_len_eq,
       Timer.__name__.__len__,
       [],
       5,
       "threading.Timer.__name__.__len__() == 5 — the Timer class name string is 'Timer' which has 5 characters; str.__len__() returns 5; new to extra222"]
    - [barrier_name_len_eq,
       Barrier.__name__.__len__,
       [],
       7,
       "threading.Barrier.__name__.__len__() == 7 — the Barrier class name string is 'Barrier' which has 7 characters; str.__len__() returns 7; new to extra222"]

# ---------------------------------------------------------------------------
# Table 2: threading class name ordering and equality checks
#
# Verified with Python 3.14.3:
#   Thread.__name__.__lt__('Timer') == True   ('Th' < 'Ti')
#   Semaphore.__name__.__eq__('Semaphore') == True
#   BoundedSemaphore.__name__.__contains__('Semaphore') == True
# ---------------------------------------------------------------------------

table threading_extra222.name_ordering:
  description: "threading class __name__ ordering and containment checks; new to extra222"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra222nameord

  columns: [id, function, args, expected, description]
  rows:
    - [thread_lt_timer,
       Thread.__name__.__lt__,
       ["Timer"],
       true,
       "threading.Thread.__name__.__lt__('Timer') == True — 'Thread' is alphabetically less than 'Timer' because 'Th' < 'Ti' (third character 'r' vs 'i' does not matter since 'h' < 'i' at position 1); str.__lt__('Timer') returns True; new to extra222"]
    - [semaphore_eq_semaphore,
       Semaphore.__name__.__eq__,
       ["Semaphore"],
       true,
       "threading.Semaphore.__name__.__eq__('Semaphore') == True — the Semaphore class __name__ is the string 'Semaphore'; str.__eq__('Semaphore') returns True; new to extra222"]
    - [bounded_semaphore_contains_semaphore,
       BoundedSemaphore.__name__.__contains__,
       ["Semaphore"],
       true,
       "threading.BoundedSemaphore.__name__.__contains__('Semaphore') == True — 'BoundedSemaphore' contains the substring 'Semaphore' starting at index 7; str.__contains__('Semaphore') returns True; new to extra222"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra222
# ---------------------------------------------------------------------------

invariant threading_extra222.thread_name_len:
  description: "threading.Thread.__name__.__len__() == 6 — 'Thread' has 6 characters; new to extra222"
  kind: python_call_eq
  function: Thread.__name__.__len__
  args: []
  expected: 6

invariant threading_extra222.semaphore_name_len:
  description: "threading.Semaphore.__name__.__len__() == 9 — 'Semaphore' has 9 characters; new to extra222"
  kind: python_call_eq
  function: Semaphore.__name__.__len__
  args: []
  expected: 9

invariant threading_extra222.bounded_semaphore_name_len:
  description: "threading.BoundedSemaphore.__name__.__len__() == 16 — 'BoundedSemaphore' has 16 characters; new to extra222"
  kind: python_call_eq
  function: BoundedSemaphore.__name__.__len__
  args: []
  expected: 16

invariant threading_extra222.condition_name_len:
  description: "threading.Condition.__name__.__len__() == 9 — 'Condition' has 9 characters; new to extra222"
  kind: python_call_eq
  function: Condition.__name__.__len__
  args: []
  expected: 9

invariant threading_extra222.event_name_len:
  description: "threading.Event.__name__.__len__() == 5 — 'Event' has 5 characters; new to extra222"
  kind: python_call_eq
  function: Event.__name__.__len__
  args: []
  expected: 5

invariant threading_extra222.timer_name_len:
  description: "threading.Timer.__name__.__len__() == 5 — 'Timer' has 5 characters; new to extra222"
  kind: python_call_eq
  function: Timer.__name__.__len__
  args: []
  expected: 5

invariant threading_extra222.barrier_name_len:
  description: "threading.Barrier.__name__.__len__() == 7 — 'Barrier' has 7 characters; new to extra222"
  kind: python_call_eq
  function: Barrier.__name__.__len__
  args: []
  expected: 7

invariant threading_extra222.thread_lt_timer:
  description: "threading.Thread.__name__.__lt__('Timer') == True — 'Thread' < 'Timer' alphabetically; new to extra222"
  kind: python_call_eq
  function: Thread.__name__.__lt__
  args: ["Timer"]
  expected: true

invariant threading_extra222.semaphore_eq_semaphore:
  description: "threading.Semaphore.__name__.__eq__('Semaphore') == True; new to extra222"
  kind: python_call_eq
  function: Semaphore.__name__.__eq__
  args: ["Semaphore"]
  expected: true

invariant threading_extra222.bounded_semaphore_contains_semaphore:
  description: "threading.BoundedSemaphore.__name__.__contains__('Semaphore') == True; new to extra222"
  kind: python_call_eq
  function: BoundedSemaphore.__name__.__contains__
  args: ["Semaphore"]
  expected: true
