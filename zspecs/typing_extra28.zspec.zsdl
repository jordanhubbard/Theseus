spec: typing_extra28
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html — Python typing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "This spec extends typing_extra27.zspec.zsdl."
    - "Focus: __module__ values for TypeVar/Protocol/final/overload and __class__.__name__ for TypeVar/Protocol in the extra28 namespace."
    - "typing_extra27 covers TypeVar.__or__.__qualname__, Generic.__class_getitem__.__qualname__, Protocol.__init_subclass__.__qualname__, and Protocol/NamedTuple/TypedDict/Any __qualname__ combined tables."
    - "typing_extra26 covers TypeVar.__repr__.__qualname__ and module-level function qualnames (get_type_hints/get_args/get_origin/cast/overload)."
    - "typing_extra23 covers combined __qualname__.__eq__ table for overload/final/no_type_check/cast in the extra23 namespace."
    - "No prior typing spec records __module__ values for TypeVar/Protocol/final/overload in a combined table in the extra28 namespace."
    - "No prior typing spec records TypeVar.__class__.__name__ == 'type' or Protocol.__class__.__name__ == '_ProtocolMeta' in any invariant or table."
    - "TypeVar.__class__ is 'type' because TypeVar is a regular class; Protocol.__class__ is '_ProtocolMeta' (its metaclass)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# typing class and function __module__ values — combined table
#
# TypeVar, Protocol, final, and overload all live in the 'typing' module;
# each has __module__ == 'typing'. No prior typing spec has these four
# together in a combined __module__.__eq__ table in the extra28 namespace.
# ---------------------------------------------------------------------------

table typing_extra28.module_attrs:
  description: "__module__.__eq__ for typing.TypeVar, Protocol, final, overload"
  kind: python_call_eq
  category: module_attrs
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [TypeVar,   TypeVar.__module__.__eq__,   ["typing"], true]
    - [Protocol,  Protocol.__module__.__eq__,  ["typing"], true]
    - [final,     final.__module__.__eq__,     ["typing"], true]
    - [overload,  overload.__module__.__eq__,  ["typing"], true]

# ---------------------------------------------------------------------------
# typing class and function __module__.__len__() — combined table
#
# All four __module__ strings equal 'typing' which has length 6.
# No prior typing spec collects these four module name lengths together
# in a single table in the extra28 namespace.
# ---------------------------------------------------------------------------

table typing_extra28.module_attr_lens:
  description: "__module__.__len__() for typing.TypeVar, Protocol, final, overload"
  kind: python_call_eq
  category: module_attr_lengths
  id_prefix: module_len

  columns: [id, function, args, expected]
  rows:
    - [TypeVar,   TypeVar.__module__.__len__,   [], 6]
    - [Protocol,  Protocol.__module__.__len__,  [], 6]
    - [final,     final.__module__.__len__,     [], 6]
    - [overload,  overload.__module__.__len__,  [], 6]

# ---------------------------------------------------------------------------
# typing.TypeVar.__class__.__name__ == 'type' — standalone invariant
#
# TypeVar is a regular Python class whose metaclass is 'type'.
# TypeVar.__class__ is type; type.__name__ is 'type'.
# No prior typing spec records TypeVar.__class__.__name__ in any invariant.
# ---------------------------------------------------------------------------

invariant typing_extra28.TypeVar.class_name:
  description: "typing.TypeVar.__class__.__name__ == 'type' — TypeVar is a regular class with metaclass type"
  category: class_attrs
  kind: python_call_eq
  function: TypeVar.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# typing.Protocol.__class__.__name__ == '_ProtocolMeta' — standalone invariant
#
# Protocol's metaclass is the internal _ProtocolMeta class (not plain 'type').
# No prior typing spec records Protocol.__class__.__name__ in any invariant.
# ---------------------------------------------------------------------------

invariant typing_extra28.Protocol.class_name:
  description: "typing.Protocol.__class__.__name__ == '_ProtocolMeta' — Protocol uses internal _ProtocolMeta metaclass"
  category: class_attrs
  kind: python_call_eq
  function: Protocol.__class__.__name__.__eq__
  args: ["_ProtocolMeta"]
  expected: true

# ---------------------------------------------------------------------------
# typing.TypeVar.__class__.__name__.__len__() == 4 — standalone invariant
#
# len('type') == 4.
# No prior typing spec records this length in the extra28 namespace.
# ---------------------------------------------------------------------------

invariant typing_extra28.TypeVar.class_name_len:
  description: "len(typing.TypeVar.__class__.__name__) == 4 — len('type') == 4"
  category: class_attr_lengths
  kind: python_call_eq
  function: TypeVar.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# typing.Protocol.__class__.__name__.__len__() == 13 — standalone invariant
#
# len('_ProtocolMeta') == 13.
# No prior typing spec records this length in the extra28 namespace.
# ---------------------------------------------------------------------------

invariant typing_extra28.Protocol.class_name_len:
  description: "len(typing.Protocol.__class__.__name__) == 13 — len('_ProtocolMeta') == 13"
  category: class_attr_lengths
  kind: python_call_eq
  function: Protocol.__class__.__name__.__len__
  args: []
  expected: 13
