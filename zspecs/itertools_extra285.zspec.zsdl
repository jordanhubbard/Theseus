spec: itertools_extra285
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools C-extension iterator class identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "All itertools classes are C types; __module__ == 'itertools' for all"
    - "All itertools classes inherit directly from object"
    - "zip_longest added in Python 3.x as replacement for izip_longest"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table itertools_extra285.class_names:
  description: "Verify __name__ attribute for itertools iterator classes"
  kind: python_call_eq
  category: identity
  id_prefix: icn

  columns: [id, function, args, expected, description]
  rows:
    - [icn001, itertools.chain.__name__.__eq__, ["chain"], true, "itertools.chain.__name__ is 'chain'"]
    - [icn002, itertools.count.__name__.__eq__, ["count"], true, "itertools.count.__name__ is 'count'"]
    - [icn003, itertools.cycle.__name__.__eq__, ["cycle"], true, "itertools.cycle.__name__ is 'cycle'"]
    - [icn004, itertools.repeat.__name__.__eq__, ["repeat"], true, "itertools.repeat.__name__ is 'repeat'"]
    - [icn005, itertools.zip_longest.__name__.__eq__, ["zip_longest"], true, "itertools.zip_longest.__name__ is 'zip_longest'"]
    - [icn006, itertools.product.__name__.__eq__, ["product"], true, "itertools.product.__name__ is 'product'"]
    - [icn007, itertools.combinations.__name__.__eq__, ["combinations"], true, "itertools.combinations.__name__ is 'combinations'"]
    - [icn008, itertools.permutations.__name__.__eq__, ["permutations"], true, "itertools.permutations.__name__ is 'permutations'"]
    - [icn009, itertools.accumulate.__name__.__eq__, ["accumulate"], true, "itertools.accumulate.__name__ is 'accumulate'"]
    - [icn010, itertools.islice.__name__.__eq__, ["islice"], true, "itertools.islice.__name__ is 'islice'"]
    - [icn011, itertools.starmap.__name__.__eq__, ["starmap"], true, "itertools.starmap.__name__ is 'starmap'"]
    - [icn012, itertools.filterfalse.__name__.__eq__, ["filterfalse"], true, "itertools.filterfalse.__name__ is 'filterfalse'"]

table itertools_extra285.class_modules:
  description: "Verify __module__ attribute for itertools iterator classes"
  kind: python_call_eq
  category: identity
  id_prefix: icm

  columns: [id, function, args, expected, description]
  rows:
    - [icm001, itertools.chain.__module__.__eq__, ["itertools"], true, "itertools.chain.__module__ is 'itertools'"]
    - [icm002, itertools.count.__module__.__eq__, ["itertools"], true, "itertools.count.__module__ is 'itertools'"]
    - [icm003, itertools.cycle.__module__.__eq__, ["itertools"], true, "itertools.cycle.__module__ is 'itertools'"]
    - [icm004, itertools.repeat.__module__.__eq__, ["itertools"], true, "itertools.repeat.__module__ is 'itertools'"]
    - [icm005, itertools.zip_longest.__module__.__eq__, ["itertools"], true, "itertools.zip_longest.__module__ is 'itertools'"]
    - [icm006, itertools.product.__module__.__eq__, ["itertools"], true, "itertools.product.__module__ is 'itertools'"]
    - [icm007, itertools.combinations.__module__.__eq__, ["itertools"], true, "itertools.combinations.__module__ is 'itertools'"]
    - [icm008, itertools.permutations.__module__.__eq__, ["itertools"], true, "itertools.permutations.__module__ is 'itertools'"]
    - [icm009, itertools.accumulate.__module__.__eq__, ["itertools"], true, "itertools.accumulate.__module__ is 'itertools'"]

invariant itertools_extra285.chain_base_is_object:
  description: "itertools.chain base class is object"
  category: identity
  kind: python_call_eq
  function: itertools.chain.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

invariant itertools_extra285.count_base_is_object:
  description: "itertools.count base class is object"
  category: identity
  kind: python_call_eq
  function: itertools.count.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

invariant itertools_extra285.repeat_base_is_object:
  description: "itertools.repeat base class is object"
  category: identity
  kind: python_call_eq
  function: itertools.repeat.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

invariant itertools_extra285.chain_doc_is_str:
  description: "itertools.chain.__doc__ is a str"
  category: identity
  kind: python_call_eq
  function: itertools.chain.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant itertools_extra285.accumulate_doc_is_str:
  description: "itertools.accumulate.__doc__ is a str"
  category: identity
  kind: python_call_eq
  function: itertools.accumulate.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
