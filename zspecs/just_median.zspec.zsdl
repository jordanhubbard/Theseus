spec: just_median
version: ">=2.2.0"
backend: node(just-median)

docs: https://www.npmjs.com/package/just-median

provenance:
  derived_from:
    - "just-median README — https://www.npmjs.com/package/just-median"
    - "Test vectors verified with just-median via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "just-median source"
  notes:
    - "just-median is an npm package. Install: npm install just-median"
    - "Returns the median value of an array of numbers."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_median.median:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: jmed

  columns: [id, args, expected]
  rows:
    - [odd_count,   [[1, 2, 3, 4, 5]], 3]
    - [even_count,  [[1, 2, 3, 4]],    2.5]
    - [single,      [[7]],             7]

