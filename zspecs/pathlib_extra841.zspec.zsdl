spec: pathlib_extra841
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "cpython/Lib/pathlib.py"
  not_derived_from:
    - "any third-party pathlib replacement"
  notes:
    - "Covers __qualname__ invariants for Path filesystem and link methods"
    - "hardlink_to was added in CPython 3.10; qualname stable from 3.10+"
  created_at: "2026-04-12"

table pathlib_extra841.path_nav_qualnames:
  description: "pathlib.Path navigation and resolution method __qualname__ equality checks"
  kind: python_call_eq
  category: qualname
  id_prefix: pl841nv
  columns: [id, function, args, expected]
  rows:
    - [pl841nv001, pathlib.Path.glob.__qualname__.__eq__, ["Path.glob"], true]
    - [pl841nv002, pathlib.Path.rglob.__qualname__.__eq__, ["Path.rglob"], true]
    - [pl841nv003, pathlib.Path.iterdir.__qualname__.__eq__, ["Path.iterdir"], true]
    - [pl841nv004, pathlib.Path.resolve.__qualname__.__eq__, ["Path.resolve"], true]
    - [pl841nv005, pathlib.Path.absolute.__qualname__.__eq__, ["Path.absolute"], true]
    - [pl841nv006, pathlib.Path.expanduser.__qualname__.__eq__, ["Path.expanduser"], true]

table pathlib_extra841.path_fs_qualnames:
  description: "pathlib.Path filesystem mutation and stat method __qualname__ equality checks"
  kind: python_call_eq
  category: qualname
  id_prefix: pl841fs
  columns: [id, function, args, expected]
  rows:
    - [pl841fs001, pathlib.Path.symlink_to.__qualname__.__eq__, ["Path.symlink_to"], true]
    - [pl841fs002, pathlib.Path.hardlink_to.__qualname__.__eq__, ["Path.hardlink_to"], true]
    - [pl841fs003, pathlib.Path.touch.__qualname__.__eq__, ["Path.touch"], true]
    - [pl841fs004, pathlib.Path.chmod.__qualname__.__eq__, ["Path.chmod"], true]
    - [pl841fs005, pathlib.Path.lchmod.__qualname__.__eq__, ["Path.lchmod"], true]
    - [pl841fs006, pathlib.Path.lstat.__qualname__.__eq__, ["Path.lstat"], true]
