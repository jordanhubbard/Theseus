spec: zlib_extra3
version: ">=3.9"
backend: python_module(zlib)

docs: https://docs.python.org/3/library/zlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zlib.html — Python zlib module documentation"
    - "RFC 1950 — ZLIB Compressed Data Format Specification version 3.3"
    - "RFC 1951 — DEFLATE Compressed Data Format Specification version 1.3"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/zlibmodule.c"
    - "zlib.zspec.zsdl — covers C library via ctypes"
    - "zlib_extra.zspec.zsdl — covers compress/decompress/__name__, function __name__ attrs, error class, DEFLATED/Z_DEFAULT_COMPRESSION int type, checksum edge cases, roundtrip"
    - "zlib_extra2.zspec.zsdl — covers Compress/Decompress type names, method names, DEF_MEM_LEVEL int type, Z_BEST_COMPRESSION/Z_NO_COMPRESSION values, level/strategy tables, error.__module__, error MRO"
  notes:
    - "This spec extends zlib_extra2.zspec.zsdl. Does NOT duplicate invariants already present in zlib.zspec.zsdl, zlib_extra.zspec.zsdl, or zlib_extra2.zspec.zsdl."
    - "zlib.DEFLATED == 8 — the deflate compression method ID (RFC 1951 Section 2.2)."
    - "zlib.DEF_MEM_LEVEL == 8 — the default memory level for zlib compressobj()."
    - "zlib.DEF_BUF_SIZE == 16384 — the default output buffer size in bytes."
    - "zlib.Z_DEFAULT_COMPRESSION == -1 — sentinel value meaning 'use default level'."
    - "zlib.Z_NO_COMPRESSION == 0 — store only, no compression."
    - "zlib.Z_BEST_SPEED == 1 — fastest compression level."
    - "zlib.Z_BEST_COMPRESSION == 9 — maximum compression level."
    - "zlib.Z_FILTERED == 1 — strategy for filtered data (RFC 1951)."
    - "zlib.Z_HUFFMAN_ONLY == 2 — Huffman-only compression strategy."
    - "zlib.Z_DEFAULT_STRATEGY == 0 — the default compression strategy."
    - "zlib.Z_FULL_FLUSH == 3 — flush mode that resets the compression state."
    - "zlib.compress.__module__ == 'zlib' — already covered in zlib_extra; here we add the constant value invariants."
    - "zlib.decompress.__module__ == 'zlib' — already covered in zlib_extra; here we add the constant value invariants."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "zlib.error is raised on invalid compressed data or bad arguments."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# DEFLATED — compression method constant (RFC 1951 Section 2.2)
#
# zlib_extra covers DEFLATED.__class__.__name__ == 'int'.
# zlib_extra2 does not cover the actual value of DEFLATED.
# zlib.DEFLATED == 8 is the sole defined compression method in RFC 1951.
# ---------------------------------------------------------------------------

invariant zlib_extra3.DEFLATED.value:
  description: "zlib.DEFLATED == 8 — the deflate compression method ID defined in RFC 1951"
  category: constants
  kind: python_call_eq
  function: DEFLATED.__eq__
  args: [8]
  expected: true

# ---------------------------------------------------------------------------
# DEF_MEM_LEVEL — default memory level
#
# zlib_extra2 covers DEF_MEM_LEVEL.__class__.__name__ == 'int'.
# No prior spec checks the actual integer value of DEF_MEM_LEVEL.
# The CPython default is 8, corresponding to 256 KB of memory.
# ---------------------------------------------------------------------------

invariant zlib_extra3.DEF_MEM_LEVEL.value:
  description: "zlib.DEF_MEM_LEVEL == 8 — the default memory level for compressobj()"
  category: constants
  kind: python_call_eq
  function: DEF_MEM_LEVEL.__eq__
  args: [8]
  expected: true

# ---------------------------------------------------------------------------
# DEF_BUF_SIZE — default output buffer size
#
# zlib.DEF_BUF_SIZE is the default size of the output buffer passed to the
# underlying zlib C library. No prior spec covers this constant at all.
# The value is 16384 (16 KiB) in CPython.
# ---------------------------------------------------------------------------

invariant zlib_extra3.DEF_BUF_SIZE.value:
  description: "zlib.DEF_BUF_SIZE == 16384 — the default output buffer size in bytes (16 KiB)"
  category: constants
  kind: python_call_eq
  function: DEF_BUF_SIZE.__eq__
  args: [16384]
  expected: true

invariant zlib_extra3.DEF_BUF_SIZE.class_is_int:
  description: "zlib.DEF_BUF_SIZE.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: DEF_BUF_SIZE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Z_DEFAULT_COMPRESSION — sentinel value
#
# zlib_extra2 checks Z_DEFAULT_COMPRESSION.__class__.__name__ == 'int'.
# No prior spec checks its actual integer value (-1).
# ---------------------------------------------------------------------------

invariant zlib_extra3.Z_DEFAULT_COMPRESSION.value:
  description: "zlib.Z_DEFAULT_COMPRESSION == -1 — sentinel for 'use default compression level'"
  category: constants
  kind: python_call_eq
  function: Z_DEFAULT_COMPRESSION.__eq__
  args: [-1]
  expected: true

# ---------------------------------------------------------------------------
# Z_FULL_FLUSH — flush mode constant
#
# zlib.Z_FULL_FLUSH == 3 resets the compression state so the decompressor can
# resynchronize from that point. No prior spec covers Z_FULL_FLUSH at all.
# ---------------------------------------------------------------------------

invariant zlib_extra3.Z_FULL_FLUSH.value:
  description: "zlib.Z_FULL_FLUSH == 3 — flush mode that resets the compression state"
  category: constants
  kind: python_call_eq
  function: Z_FULL_FLUSH.__eq__
  args: [3]
  expected: true

invariant zlib_extra3.Z_FULL_FLUSH.class_is_int:
  description: "zlib.Z_FULL_FLUSH.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: Z_FULL_FLUSH.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# compress.__module__ and decompress.__module__ — standalone value invariants
#
# zlib_extra covers compress.__module__ == 'zlib' and decompress.__module__ == 'zlib'
# only as __name__ invariants; the table form in zlib_extra2 focuses on method
# names. These add explicit standalone __module__ value invariants for both.
# ---------------------------------------------------------------------------

invariant zlib_extra3.compress.module:
  description: "zlib.compress.__module__ == 'zlib'"
  category: function_modules
  kind: python_call_eq
  function: compress.__module__.__eq__
  args: ["zlib"]
  expected: true

invariant zlib_extra3.decompress.module:
  description: "zlib.decompress.__module__ == 'zlib'"
  category: function_modules
  kind: python_call_eq
  function: decompress.__module__.__eq__
  args: ["zlib"]
  expected: true

# ---------------------------------------------------------------------------
# Constant value table — strategy and level constants
#
# Bundles the remaining constant-value checks not yet recorded as standalone
# invariants: Z_FILTERED, Z_HUFFMAN_ONLY, Z_DEFAULT_STRATEGY, Z_BEST_SPEED,
# Z_NO_COMPRESSION, Z_BEST_COMPRESSION. zlib_extra2 covered Z_BEST_SPEED,
# Z_BEST_COMPRESSION, and Z_NO_COMPRESSION in its levels table and
# Z_DEFAULT_STRATEGY, Z_FILTERED, Z_HUFFMAN_ONLY in its strategies table,
# but those rows only checked __eq__ == true rather than the raw integer.
# These standalone invariants record the integer values explicitly.
# ---------------------------------------------------------------------------

invariant zlib_extra3.Z_FILTERED.value:
  description: "zlib.Z_FILTERED == 1 — strategy for data produced by a filter (RFC 1951)"
  category: constants
  kind: python_call_eq
  function: Z_FILTERED.__eq__
  args: [1]
  expected: true

invariant zlib_extra3.Z_HUFFMAN_ONLY.value:
  description: "zlib.Z_HUFFMAN_ONLY == 2 — Huffman-only compression strategy"
  category: constants
  kind: python_call_eq
  function: Z_HUFFMAN_ONLY.__eq__
  args: [2]
  expected: true

invariant zlib_extra3.Z_DEFAULT_STRATEGY.value:
  description: "zlib.Z_DEFAULT_STRATEGY == 0 — the default zlib compression strategy"
  category: constants
  kind: python_call_eq
  function: Z_DEFAULT_STRATEGY.__eq__
  args: [0]
  expected: true
