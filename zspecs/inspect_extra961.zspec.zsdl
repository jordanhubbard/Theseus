spec: inspect_extra961
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks inspect.signature, getsource, getfile error conditions and qualname/return-value identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra961.function_qualnames:
  description: "inspect function __qualname__ identity checks"
  kind: python_call_eq
  category: qualnames
  id_prefix: ip961qn
  columns: [id, function, args, expected]
  rows:
    - [ip961qn001, inspect.isbuiltin.__qualname__.__eq__,        ["isbuiltin"],        true]
    - [ip961qn002, inspect.isroutine.__qualname__.__eq__,        ["isroutine"],        true]
    - [ip961qn003, inspect.ismethodwrapper.__qualname__.__eq__,  ["ismethodwrapper"],  true]
    - [ip961qn004, inspect.isfunction.__qualname__.__eq__,       ["isfunction"],       true]
    - [ip961qn005, inspect.ismodule.__qualname__.__eq__,         ["ismodule"],         true]
    - [ip961qn006, inspect.isclass.__qualname__.__eq__,          ["isclass"],          true]

table inspect_extra961.predicate_returns:
  description: "inspect predicate functions return True for built-in len"
  kind: python_call_eq
  category: predicate_returns
  id_prefix: ip961pr
  columns: [id, function, args, expected]
  rows:
    - [ip961pr001, inspect.isbuiltin,  ["len"], true]
    - [ip961pr002, inspect.isroutine,  ["len"], true]
    - [ip961pr003, inspect.isbuiltin,  ["print"], true]
    - [ip961pr004, inspect.isroutine,  ["print"], true]
    - [ip961pr005, inspect.isclass,    ["int"],   true]
    - [ip961pr006, inspect.ismodule,   ["inspect"], true]

table inspect_extra961.raises_on_builtins:
  description: "inspect.signature, getsource, getfile raise on built-ins"
  kind: python_call_raises
  category: builtin_errors
  id_prefix: ip961be
  columns: [id, function, args, expected]
  rows:
    - [ip961be001, inspect.getsource, ["len"],   OSError]
    - [ip961be002, inspect.getsource, ["print"], OSError]
    - [ip961be003, inspect.getsource, ["int"],   OSError]
    - [ip961be004, inspect.getfile,   ["len"],   TypeError]
    - [ip961be005, inspect.getfile,   ["print"], TypeError]
    - [ip961be006, inspect.signature, ["42"],    TypeError]
    - [ip961be007, inspect.signature, ["\"hello\""], ValueError]
