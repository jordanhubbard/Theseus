spec: threading_extra1546
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "Wave 550 theme: bitwise operator dict-presence checks via __dict__.__contains__ for threading classes."
    - "threading.Thread.__dict__.__contains__ returns False for all bitwise dunder methods. Thread is a Python class; synchronization primitives are not numeric or bitwise types. Verified with Python 3.14."
    - "threading.Semaphore.__dict__.__contains__ returns False for all bitwise dunder methods. Semaphore is a Python class implementing a counting semaphore; bitwise operators are not applicable. Verified with Python 3.14."
    - "threading.Barrier.__dict__.__contains__ returns False for all bitwise dunder methods. Barrier is a Python class (added in 3.2); it defines no bitwise operators in its own __dict__. Verified with Python 3.14."
    - "threading.Condition.__dict__.__contains__ returns False for all bitwise dunder methods. Condition is a Python class; it defines no bitwise operators. Verified with Python 3.14."
    - "Bitwise dunders checked: __and__, __or__, __xor__, __invert__, __lshift__, __rshift__, __rand__, __ror__, __rxor__, __rlshift__, __rrshift__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread — bitwise operator dict-presence checks
#
# Wave 550 theme: Thread is a Python class. Its own __dict__ does not define
# any bitwise dunder methods. Thread objects represent OS threads; they are
# not value types and have no bitwise semantics.
# ---------------------------------------------------------------------------

table threading_extra1546.thread_bitwise_dict_contains:
  description: "threading.Thread.__dict__.__contains__ returns False for all bitwise dunder methods; wave 550; new to extra1546"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1546th

  columns: [id, function, args, expected, description]
  rows:
    - ["th1546th001",
       "Thread.__dict__.__contains__",
       ["__and__"],
       false,
       "threading.Thread.__dict__.__contains__('__and__') == False — Thread is a Python class; its __dict__ does not define __and__; wave 550; new to extra1546"]
    - ["th1546th002",
       "Thread.__dict__.__contains__",
       ["__or__"],
       false,
       "threading.Thread.__dict__.__contains__('__or__') == False — Thread does not define __or__ in its own class __dict__; wave 550; new to extra1546"]
    - ["th1546th003",
