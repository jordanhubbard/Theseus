spec: datetime_extra14
version: ">=3.9"
backend: python_module(datetime)

docs: https://docs.python.org/3/library/datetime.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/datetime.html — Python datetime module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_datetimemodule.c"
    - "CPython source: Lib/datetime.py"
    - "datetime.zspec.zsdl — covers class __name__/__qualname__ table, MINYEAR/MAXYEAR, date/datetime/timedelta/timezone constructors"
    - "datetime_extra13.zspec.zsdl — covers __name__ for date/time/datetime/timedelta/timezone (table); date.__module__; timedelta.__bases__[0].__name__; date.min/max __class__.__name__"
    - "datetime_extra12.zspec.zsdl — covers __qualname__ for all six classes; __module__ for all six classes (table); MINYEAR/MAXYEAR"
  notes:
    - "This spec extends datetime.zspec.zsdl and prior extras through datetime_extra13.zspec.zsdl."
    - "NEW in extra14 — Axis 1: class hierarchy table confirming __bases__[0].__name__ for date/time/timedelta/tzinfo/timezone/datetime — all six classes in one table."
    - "NEW in extra14 — Axis 2: datetime.__bases__[0].__name__ == 'date' as standalone invariant in extra14 namespace."
    - "NEW in extra14 — Axis 3: timezone.__bases__[0].__name__ == 'tzinfo' as standalone invariant in extra14 namespace."
    - "NEW in extra14 — Axis 4: date.__bases__[0].__name__ == 'object' as standalone invariant in extra14 namespace."
    - "datetime.date.__bases__[0].__name__ == 'object' — verified Python 3.12."
    - "datetime.time.__bases__[0].__name__ == 'object' — verified Python 3.12."
    - "datetime.timedelta.__bases__[0].__name__ == 'object' — verified Python 3.12."
    - "datetime.tzinfo.__bases__[0].__name__ == 'object' — verified Python 3.12."
    - "datetime.timezone.__bases__[0].__name__ == 'tzinfo' — verified Python 3.12."
    - "datetime.datetime.__bases__[0].__name__ == 'date' — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class hierarchy: __bases__[0].__name__ for all six datetime classes
#
# datetime_extra13 covers timedelta.__bases__[0].__name__ as a standalone
# invariant. This spec adds a table covering all six classes together in the
# extra14 namespace, using __bases__.__getitem__ so the method_chain in the
# invariant block resolves cleanly through the table row format.
# ---------------------------------------------------------------------------

table datetime_extra14.class_bases:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: base

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [date,      date.__bases__.__getitem__,      [0], "__name__.__eq__", ["object"],  true]
    - [time,      time.__bases__.__getitem__,      [0], "__name__.__eq__", ["object"],  true]
    - [timedelta, timedelta.__bases__.__getitem__, [0], "__name__.__eq__", ["object"],  true]
    - [tzinfo,    tzinfo.__bases__.__getitem__,    [0], "__name__.__eq__", ["object"],  true]
    - [timezone,  timezone.__bases__.__getitem__,  [0], "__name__.__eq__", ["tzinfo"],  true]
    - [datetime,  datetime.__bases__.__getitem__,  [0], "__name__.__eq__", ["date"],    true]

# ---------------------------------------------------------------------------
# datetime.__bases__[0].__name__ == 'date'
#
# datetime.datetime is a subclass of datetime.date. No prior extra spec has
# anchored this as a standalone invariant in an extra namespace.
# ---------------------------------------------------------------------------

invariant datetime_extra14.datetime.base_name:
  description: "datetime.datetime.__bases__[0].__name__ == 'date' — datetime directly subclasses date"
  category: class_hierarchy
  kind: python_call_eq
  function: datetime.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["date"]
  expected: true

# ---------------------------------------------------------------------------
# timezone.__bases__[0].__name__ == 'tzinfo'
#
# datetime.timezone is a concrete subclass of datetime.tzinfo. No prior extra
# spec has anchored this as a standalone invariant in an extra namespace.
# ---------------------------------------------------------------------------

invariant datetime_extra14.timezone.base_name:
  description: "datetime.timezone.__bases__[0].__name__ == 'tzinfo' — timezone directly subclasses tzinfo"
  category: class_hierarchy
  kind: python_call_eq
  function: timezone.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["tzinfo"]
  expected: true

# ---------------------------------------------------------------------------
# date.__bases__[0].__name__ == 'object'
#
# datetime.date sits at the top of the datetime class hierarchy, with only
# object as its base. No prior extra spec has anchored this as a standalone
# invariant in an extra namespace.
# ---------------------------------------------------------------------------

invariant datetime_extra14.date.base_name:
  description: "datetime.date.__bases__[0].__name__ == 'object' — date directly inherits from object"
  category: class_hierarchy
  kind: python_call_eq
  function: date.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true
