spec: struct_extra234
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html
rfcs:
  - "IEEE 754-2019 — Standard for Floating-Point Arithmetic (for float/double format strings)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"
    - "Test vectors verified by running Python 3.14.3 struct module on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "This spec extends struct.zspec.zsdl and struct_extra.zspec.zsdl; it does NOT duplicate invariants present in those files."
    - "struct.zspec.zsdl covers: pack/unpack vectors for big-endian/little-endian; calcsize for >H/>I/>Q/>HI/>HIQ/>q/>h/>b/?/>e; roundtrip tests; error cases."
    - "struct_extra.zspec.zsdl covers: Struct format/size attrs; calcsize >f/>d/>B/4s/>BHI; pack_into/unpack_from/iter_unpack; error class identity."
    - "This spec uses native byte order WITHOUT alignment prefix (no '@'/'=') for single-char format strings."
    - "calcsize('b') == 1 — signed char, always 1 byte on all platforms."
    - "calcsize('h') == 2 — signed short, always 2 bytes (C99 guarantees)."
    - "calcsize('i') == 4 — signed int, always 4 bytes on all modern 32/64-bit platforms."
    - "calcsize('q') == 8 — signed long long, always 8 bytes (C99 guarantees)."
    - "calcsize('f') == 4 — IEEE 754 single-precision float, always 4 bytes."
    - "calcsize('d') == 8 — IEEE 754 double-precision float, always 8 bytes."
    - "calcsize('s') == 1 — single char/byte string, always 1 byte."
    - "calcsize('p') == 1 — Pascal string with 1-byte length prefix in 1-byte field."
    - "calcsize('4s') == 4 — fixed-length 4-char/byte string field."
    - "calcsize('2i') == 8 — two int fields; 2 * 4 = 8 bytes."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model:
  semantics: "struct.error is raised for mismatched buffer sizes and invalid format strings."
  stderr: "null"
  stickiness: "N/A — calcsize is a pure function; results depend only on the format string."
  codes: {}

# ---------------------------------------------------------------------------
# calcsize — single primitive format characters (native byte order, no alignment)
# struct.zspec.zsdl covers: >H, >I, >Q, >HI, >HIQ, >q, >h, >b, ?, >e
# struct_extra.zspec.zsdl covers: >f, >d, >B, 4s, >BHI
# This spec covers: b, h, i, q, f, d, s, p (no byte-order prefix; native)
# ---------------------------------------------------------------------------

table struct_extra234.calcsize.native_primitives:
  kind: python_call_eq
  category: calcsize
  function: calcsize
  id_prefix: struct234cs

  columns: [id, args, expected]
  rows:
    - [b_int8,    ["b"], 1]
    - [h_int16,   ["h"], 2]
    - [i_int32,   ["i"], 4]
    - [q_int64,   ["q"], 8]
    - [f_float32, ["f"], 4]
    - [d_float64, ["d"], 8]
    - [s_char,    ["s"], 1]
    - [p_pascal,  ["p"], 1]

# ---------------------------------------------------------------------------
# calcsize — compound format strings
# ---------------------------------------------------------------------------

table struct_extra234.calcsize.compound_formats:
  kind: python_call_eq
  category: calcsize
  function: calcsize
  id_prefix: struct234cs

  columns: [id, args, expected]
  rows:
    - [four_s,  ["4s"], 4]
    - [two_i,   ["2i"], 8]

# ---------------------------------------------------------------------------
# calcsize function identity — __name__ and __module__
# ---------------------------------------------------------------------------

invariant struct_extra234.calcsize.function_name:
  description: "struct.calcsize.__name__ == 'calcsize'"
  category: function_identity
  kind: python_call_eq
  function: calcsize.__name__.__eq__
  args: ["calcsize"]
  expected: true

invariant struct_extra234.calcsize.module_name:
  description: "struct.calcsize.__module__ == '_struct' (built-in C implementation)"
  category: function_identity
  kind: python_call_eq
  function: calcsize.__module__.__eq__
  args: ["_struct"]
  expected: true

# ---------------------------------------------------------------------------
# calcsize return type is always int
# ---------------------------------------------------------------------------

invariant struct_extra234.calcsize.return_type_b:
  description: "struct.calcsize('b').__class__.__name__ == 'int' — calcsize always returns an int"
  category: properties
  kind: python_call_eq
  function: calcsize
  args: ["b"]
  method: __class__.__name__.__eq__
  method_args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# calcsize — consistency: 2*calcsize('i') == calcsize('2i')
# Both must equal 8; we verify each independently.
# ---------------------------------------------------------------------------

invariant struct_extra234.calcsize.two_i_eq_8:
  description: "struct.calcsize('2i') == 8 — two int fields; 2 * calcsize('i') = 2 * 4 = 8"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["2i"]
  expected: 8

invariant struct_extra234.calcsize.four_s_eq_4:
  description: "struct.calcsize('4s') == 4 — fixed-length 4-char string field"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["4s"]
  expected: 4

invariant struct_extra234.calcsize.b_eq_1:
  description: "struct.calcsize('b') == 1 — signed char is always 1 byte"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["b"]
  expected: 1

invariant struct_extra234.calcsize.h_eq_2:
  description: "struct.calcsize('h') == 2 — signed short is always 2 bytes"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["h"]
  expected: 2

invariant struct_extra234.calcsize.i_eq_4:
  description: "struct.calcsize('i') == 4 — signed int is always 4 bytes on modern platforms"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["i"]
  expected: 4

invariant struct_extra234.calcsize.q_eq_8:
  description: "struct.calcsize('q') == 8 — signed long long is always 8 bytes (C99)"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["q"]
  expected: 8
