spec: multiprocessing_extra210
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "multiprocessing.ProcessError.__name__ == 'ProcessError'; __module__ == 'multiprocessing.context'."
    - "multiprocessing.ProcessError.__bases__[0].__name__ == 'Exception' — ProcessError inherits directly from Exception."
    - "multiprocessing.BufferTooShort.__name__ == 'BufferTooShort'; __bases__[0].__name__ == 'ProcessError'."
    - "multiprocessing.AuthenticationError.__name__ == 'AuthenticationError'; __name__.__len__() == 19."
    - "multiprocessing.ProcessError.__name__.__len__() == 12 ('ProcessError' = 12 chars)."
    - "multiprocessing.TimeoutError.__name__ == 'TimeoutError'; __name__.__len__() == 12; __bases__[0].__name__ == 'ProcessError'."
    - "multiprocessing.context.ProcessError.__name__ == 'ProcessError' (accessible via submodule reference)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.ProcessError class identity — extra210 namespace
#
# ProcessError is the base exception for all multiprocessing-specific errors.
# Its __module__ is 'multiprocessing.context' and it inherits from Exception.
# ---------------------------------------------------------------------------

table multiprocessing_extra210.process_error_identity:
  description: "multiprocessing.ProcessError class __name__ and __module__ checks in extra210 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: mp210procerr

  columns: [id, function, args, expected, description]
  rows:
    - [pe_name_eq,   multiprocessing.ProcessError.__name__.__eq__,   ["ProcessError"],             true, "multiprocessing.ProcessError.__name__ == 'ProcessError'; verified with Python 3.14.3"]
    - [pe_module_eq, multiprocessing.ProcessError.__module__.__eq__, ["multiprocessing.context"],  true, "multiprocessing.ProcessError.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [pe_name_len,  multiprocessing.ProcessError.__name__.__len__,  [],                           12,   "multiprocessing.ProcessError.__name__.__len__() == 12 ('ProcessError'=12); verified with Python 3.14.3"]

invariant multiprocessing_extra210.process_error_base_name:
  description: "multiprocessing.ProcessError.__bases__[0].__name__ == 'Exception' — ProcessError inherits directly from Exception; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "multiprocessing.ProcessError.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# multiprocessing.BufferTooShort class identity — extra210 namespace
#
# BufferTooShort inherits from ProcessError.
# ---------------------------------------------------------------------------

table multiprocessing_extra210.buffer_too_short_identity:
  description: "multiprocessing.BufferTooShort class __name__ checks in extra210 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: mp210buftooshot

  columns: [id, function, args, expected, description]
  rows:
    - [bts_name_eq,  multiprocessing.BufferTooShort.__name__.__eq__,  ["BufferTooShort"], true, "multiprocessing.BufferTooShort.__name__ == 'BufferTooShort'; verified with Python 3.14.3"]
    - [bts_name_len, multiprocessing.BufferTooShort.__name__.__len__, [],                 14,   "multiprocessing.BufferTooShort.__name__.__len__() == 14 ('BufferTooShort'=14); verified with Python 3.14.3"]

invariant multiprocessing_extra210.buffer_too_short_base_name:
  description: "multiprocessing.BufferTooShort.__bases__[0].__name__ == 'ProcessError' — BufferTooShort inherits from ProcessError; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "multiprocessing.BufferTooShort.__bases__[0].__name__.__eq__"
  args: ["ProcessError"]
  expected: true

# ---------------------------------------------------------------------------
# multiprocessing.AuthenticationError name length — extra210 namespace
# ---------------------------------------------------------------------------

invariant multiprocessing_extra210.authentication_error_name_len:
  description: "multiprocessing.AuthenticationError.__name__.__len__() == 19 ('AuthenticationError' = 19 chars); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.AuthenticationError.__name__.__len__
  args: []
  expected: 19

# ---------------------------------------------------------------------------
# multiprocessing.TimeoutError class identity — extra210 namespace
#
# multiprocessing.TimeoutError.__name__ == 'TimeoutError' (12 chars).
# Its base is ProcessError (NOT builtins.TimeoutError).
# ---------------------------------------------------------------------------

table multiprocessing_extra210.timeout_error_identity:
  description: "multiprocessing.TimeoutError class __name__ checks in extra210 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: mp210mptimeout

  columns: [id, function, args, expected, description]
  rows:
    - [mpto_name_eq,  multiprocessing.TimeoutError.__name__.__eq__,  ["TimeoutError"], true, "multiprocessing.TimeoutError.__name__ == 'TimeoutError'; verified with Python 3.14.3"]
    - [mpto_name_len, multiprocessing.TimeoutError.__name__.__len__, [],               12,   "multiprocessing.TimeoutError.__name__.__len__() == 12 ('TimeoutError'=12); verified with Python 3.14.3"]

invariant multiprocessing_extra210.timeout_error_base_name:
  description: "multiprocessing.TimeoutError.__bases__[0].__name__ == 'ProcessError' — multiprocessing.TimeoutError inherits from ProcessError (not from builtins.TimeoutError); verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "multiprocessing.TimeoutError.__bases__[0].__name__.__eq__"
  args: ["ProcessError"]
  expected: true

# ---------------------------------------------------------------------------
# multiprocessing.context.ProcessError identity — extra210 namespace
#
# Accessible via the context submodule reference.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra210.context_process_error_name:
  description: "multiprocessing.context.ProcessError.__name__ == 'ProcessError' — same class accessible via submodule; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.context.ProcessError.__name__.__eq__
  args: ["ProcessError"]
  expected: true
