invariant abc_extra128.ABCMeta_instancecheck_qualname_len_25:
  description: "abc.ABCMeta.__instancecheck__.__qualname__.__len__() == 25 — ABCMeta.__instancecheck__.__qualname__ is 'ABCMeta.__instancecheck__' (25 chars: 'ABCMeta'=7 + '.'=1 + '__instancecheck__'=17 = 25); this is the longest ABCMeta method qualname along with ABCMeta.__subclasscheck__ (also 25); ABCMeta.__instancecheck__ is called by Python's isinstance() built-in when the second argument is an ABCMeta instance; it checks both direct subclassing and virtual subclass registration via register(); ABCMeta.__instancecheck__.__code__.co_argcount is 2 (self, instance); ABCMeta.__instancecheck__.__class__.__name__ is 'function'; NEW in extra128: first standalone ABCMeta.__instancecheck__ qualname length invariant in abcabcmetaqn128 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__instancecheck__.__qualname__.__len__
  args: []
  expected: 25

invariant abc_extra128.ABCMeta_subclasscheck_qualname_eq:
  description: "abc.ABCMeta.__subclasscheck__.__qualname__.__eq__('ABCMeta.__subclasscheck__') returns True — ABCMeta.__subclasscheck__.__qualname__ is 'ABCMeta.__subclasscheck__' (25 chars: 'ABCMeta'=7 + '.'=1 + '__subclasscheck__'=17 = 25); this qualname has the same length as ABCMeta.__instancecheck__ (both 25 chars), as '__instancecheck__'=17 and '__subclasscheck__'=17 have the same character count; ABCMeta.__subclasscheck__ is called by Python's issubclass() built-in; it checks both structural subclassing and virtual subclass registration; ABCMeta.__subclasscheck__.__code__.co_argcount is 2 (self, subclass); NEW in extra128: first standalone ABCMeta.__subclasscheck__ qualname equality invariant in abcabcmetaqn128 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__subclasscheck__.__qualname__.__eq__
  args: ["ABCMeta.__subclasscheck__"]
  expected: true

invariant abc_extra128.ABCMeta_register_qualname_len_16:
  description: "abc.ABCMeta.register.__qualname__.__len__() == 16 — ABCMeta.register.__qualname__ is 'ABCMeta.register' (16 chars: 'ABCMeta'=7 + '.'=1 + 'register'=8 = 16); this is the shortest ABCMeta method qualname in this spec: register=16 < _dump_registry=22 < __init_subclass__=21 < __instancecheck__=25 == __subclasscheck__=25; ABCMeta.register is used to register a class as a virtual subclass of an ABC; ABCMeta.register.__code__.co_argcount is 2 (self, subclass); ABCMeta.register.__code__.co_name is 'register'; ABCMeta.register.__class__.__name__ is 'function'; NEW in extra128: first standalone ABCMeta.register qualname length invariant in abcabcmetaqn128 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.register.__qualname__.__len__
  args: []
  expected: 16

invariant abc_extra128.ABCMeta_mro_len_3:
  description: "abc.ABCMeta.__mro__.__len__() == 3 — ABCMeta's MRO is [ABCMeta, type, object] (length=3); ABCMeta inherits from type (the built-in metaclass), making it a metaclass itself; ABCMeta.__bases__[0].__name__ is 'type'; this 3-element depth matches asyncio.Event.__mro__.__len__()==3 and asyncio.Queue.__mro__.__len__()==3, though ABCMeta's depth-3 arises from metaclass inheritance (type) while Event's arises from _LoopBoundMixin; compare: abc.ABC.__mro__.__len__() is 2 ([ABC, object]) — ABC itself has a much shallower MRO than its metaclass ABCMeta; ABCMeta.__module__ is 'abc'; NEW in extra128: first standalone ABCMeta MRO length invariant in abcabcmetaqn128 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__mro__.__len__
  args: []
  expected: 3

invariant abc_extra128.ABC_init_subclass_qualname_len_21:
  description: "abc.ABC.__init_subclass__.__qualname__.__len__() == 21 — ABC.__init_subclass__.__qualname__ is 'ABC.__init_subclass__' (21 chars: 'ABC'=3 + '.'=1 + '__init_subclass__'=17 = 21); ABC.__init_subclass__ is a builtin_function_or_method (not a Python function), so it has __qualname__ but no __code__ attribute; the qualname length 21 is between ABCMeta._dump_registry (22) and ABCMeta.register (16) in the ranking; '__init_subclass__' (17 chars) has the same length as '__instancecheck__' and '__subclasscheck__' (both 17 chars), but the prefix 'ABC.' (4 chars) is shorter than 'ABCMeta.' (8 chars), making the full qualname 21 instead of 25; NEW in extra128: first standalone ABC.__init_subclass__ qualname length invariant in abcabcmetaqn128 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__init_subclass__.__qualname__.__len__
  args: []
  expected: 21

