spec: socket_extra2251
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "_socket_extra.zspec.zsdl"
    - "_socket.zspec.zsdl"
  notes:
    - "Wave 597 (_extra2251): callable protocol and function-attribute dict-presence checks for socket types and functions."
    - "socket.socket is a pure-Python wrapper class; __call__ is absent from its __dict__ (type metaclass provides __call__)."
    - "socket.socket defines __init__, accept, close, detach, dup, makefile, sendfile, get_inheritable, set_inheritable, family, type in its __dict__; connect, bind, listen, send, recv are inherited from the underlying _socket.socket C type and are NOT in socket.socket.__dict__."
    - "socket.error is an alias for OSError; __call__ is absent from its __dict__."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses; __call__ is absent from their __dict__s; AF_INET/SOCK_STREAM member names ARE in their __dict__s."
    - "socket.getaddrinfo, socket.create_connection, socket.create_server, socket.getfqdn, socket.has_dualstack_ipv6 are Python functions with __code__ (class name 'code') and __globals__ (class name 'dict')."
    - "socket.gethostname, socket.gethostbyname, socket.getfqdn (wait: getfqdn IS Python) are C builtins with no __code__."
    - "socket.getaddrinfo has __defaults__=(0, 0, 0, 0); socket.getfqdn has __defaults__=('',)."
    - "socket.create_connection has __kwdefaults__={'all_errors': False}."
    - "Function-object attributes (__code__, __globals__, __defaults__, etc.) are absent from socket.socket, socket.error, socket.AddressFamily, socket.SocketKind class __dict__s."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table socket_extra2251.socket_class_call_protocol:
  description: "socket.socket class callable protocol and function-attribute dict-presence"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2251
  columns: [id, function, args, expected]
  rows:
    - ["sk2251001", "socket.socket.__dict__.__contains__", ["__call__"],        false]
    - ["sk2251002", "socket.socket.__dict__.__contains__", ["__code__"],        false]
    - ["sk2251003", "socket.socket.__dict__.__contains__", ["__globals__"],     false]
    - ["sk2251004", "socket.socket.__dict__.__contains__", ["__defaults__"],    false]
    - ["sk2251005", "socket.socket.__dict__.__contains__", ["__kwdefaults__"],  false]
    - ["sk2251006", "socket.socket.__dict__.__contains__", ["__annotations__"], false]
    - ["sk2251007", "socket.socket.__dict__.__contains__", ["__builtins__"],    false]

table socket_extra2251.socket_class_positive_anchors:
  description: "socket.socket dict members that ARE present (Python-level wrapper methods and slots)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2251
  columns: [id, function, args, expected]
  rows:
    - ["sk2251008", "socket.socket.__dict__.__contains__", ["__init__"],    true]
    - ["sk2251009", "socket.socket.__dict__.__contains__", ["__doc__"],     true]
    - ["sk2251010", "socket.socket.__dict__.__contains__", ["accept"],      true]
    - ["sk2251011", "socket.socket.__dict__.__contains__", ["close"],       true]
    - ["sk2251012", "socket.socket.__dict__.__contains__", ["detach"],      true]
    - ["sk2251013", "socket.socket.__dict__.__contains__", ["dup"],         true]
    - ["sk2251014", "socket.socket.__dict__.__contains__", ["makefile"],    true]
    - ["sk2251015", "socket.socket.__dict__.__contains__", ["sendfile"],    true]

table socket_extra2251.socket_class_absent_c_methods:
  description: "socket.socket dict members NOT present — connect, bind, listen, send, recv are inherited from _socket.socket C type"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2251
  columns: [id, function, args, expected]
  rows:
    - ["sk2251016", "socket.socket.__dict__.__contains__", ["connect"], false]
    - ["sk2251017", "socket.socket.__dict__.__contains__", ["bind"],    false]
    - ["sk2251018", "socket.socket.__dict__.__contains__", ["listen"],  false]
    - ["sk2251019", "socket.socket.__dict__.__contains__", ["send"],    false]
    - ["sk2251020", "socket.socket.__dict__.__contains__", ["recv"],    false]

table socket_extra2251.error_and_enum_call_protocol:
  description: "socket.error, socket.AddressFamily, socket.SocketKind — __call__ absent; enum members present"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2251
  columns: [id, function, args, expected]
  rows:
    - ["sk2251021", "socket.error.__dict__.__contains__",           ["__call__"],    false]
    - ["sk2251022", "socket.error.__dict__.__contains__",           ["__doc__"],     true]
    - ["sk2251023", "socket.AddressFamily.__dict__.__contains__",   ["__call__"],    false]
    - ["sk2251024", "socket.AddressFamily.__dict__.__contains__",   ["AF_INET"],     true]
    - ["sk2251025", "socket.AddressFamily.__dict__.__contains__",   ["AF_INET6"],    true]
    - ["sk2251026", "socket.AddressFamily.__dict__.__contains__",   ["AF_UNIX"],     true]
    - ["sk2251027", "socket.SocketKind.__dict__.__contains__",      ["__call__"],    false]
    - ["sk2251028", "socket.SocketKind.__dict__.__contains__",      ["SOCK_STREAM"], true]
    - ["sk2251029", "socket.SocketKind.__dict__.__contains__",      ["SOCK_DGRAM"],  true]

table socket_extra2251.module_func_code_globals:
  description: "socket module-level Python functions: __code__ and __globals__ class names (always 'code' and 'dict')"
  kind: python_call_eq
  category: code_globals
  id_prefix: sk2251
  columns: [id, function, args, expected]
  rows:
    - ["sk2251030", "socket.getaddrinfo.__code__.__class__.__name__.__eq__",        ["code"], true]
    - ["sk2251031", "socket.getaddrinfo.__globals__.__class__.__name__.__eq__",     ["dict"], true]
    - ["sk2251032", "socket.create_connection.__code__.__class__.__name__.__eq__",  ["code"], true]
    - ["sk2251033", "socket.create_connection.__globals__.__class__.__name__.__eq__",["dict"],true]
    - ["sk2251034", "socket.create_server.__code__.__class__.__name__.__eq__",      ["code"], true]
    - ["sk2251035", "socket.create_server.__globals__.__class__.__name__.__eq__",   ["dict"], true]
    - ["sk2251036", "socket.getfqdn.__code__.__class__.__name__.__eq__",            ["code"], true]
    - ["sk2251037", "socket.getfqdn.__globals__.__class__.__name__.__eq__",         ["dict"], true]
    - ["sk2251038", "socket.has_dualstack_ipv6.__code__.__class__.__name__.__eq__", ["code"], true]
    - ["sk2251039", "socket.has_dualstack_ipv6.__globals__.__class__.__name__.__eq__",["dict"],true]

table socket_extra2251.module_func_defaults:
  description: "socket module-level Python function __defaults__ and __annotations__ class names"
  kind: python_call_eq
  category: func_attributes
  id_prefix: sk2251
  columns: [id, function, args, expected]
  rows:
    - ["sk2251040", "socket.getaddrinfo.__defaults__.__class__.__name__.__eq__",      ["tuple"], true]
    - ["sk2251041", "socket.getaddrinfo.__annotations__.__class__.__name__.__eq__",   ["dict"],  true]
    - ["sk2251042", "socket.getfqdn.__defaults__.__class__.__name__.__eq__",          ["tuple"], true]
    - ["sk2251043", "socket.getfqdn.__annotations__.__class__.__name__.__eq__",       ["dict"],  true]
    - ["sk2251044", "socket.create_connection.__annotations__.__class__.__name__.__eq__",["dict"],true]
