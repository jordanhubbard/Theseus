spec: signal_extra8
version: ">=3.9"
backend: python_module(signal)

docs: https://docs.python.org/3/library/signal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/signal.html — Python signal module documentation"
    - "POSIX.1-2017 — The Open Group Base Specifications Issue 7, 2018 Edition"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/signalmodule.c"
  notes:
    - "Extends signal.zspec.zsdl through signal_extra7.zspec.zsdl."
    - "signal_extra covers: SIG_DFL/SIG_IGN class names; getsignal/raise_signal/strsignal/valid_signals __name__; SIGABRT/SIGFPE/SIGILL/SIGINT/SIGSEGV/SIGTERM class names."
    - "signal_extra2 covers: signal/__name__; getsignal/__name__; SIG_DFL/SIG_IGN/SIGTERM/SIGINT class names (standalone); Signals/Handlers __name__."
    - "signal_extra3 covers: SIGHUP/SIGKILL/SIGQUIT/SIGALRM/SIGPIPE class names."
    - "signal_extra4 covers: signal/getsignal/raise_signal/strsignal/valid_signals __qualname__; Signals/Handlers __qualname__/__module__."
    - "signal_extra7 covers: SIGUSR1/SIGUSR2/SIGCHLD/SIGWINCH .value/.name; strsignal and valid_signals membership for same."
    - "NOT yet covered in any prior spec: alarm/__name__, alarm/__qualname__, alarm/__module__ (POSIX only)."
    - "NOT yet covered: SIGUSR1/SIGUSR2/SIGCHLD/SIGWINCH __class__.__name__ == 'Signals'."
    - "alarm.__module__ == '_signal' — alarm is implemented in the C extension _signal, not the Python wrapper."
    - "alarm.__qualname__ == 'alarm' — module-level C builtin; qualname equals name."
    - "SIGUSR1 == 30, SIGUSR2 == 31 on macOS/Darwin; SIGCHLD == 20; SIGWINCH == 28."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# alarm — __name__, __qualname__, __module__
#
# signal.alarm is a POSIX-only C builtin function (from _signal extension).
# No prior spec in this corpus covers any attribute of alarm.
# alarm.__module__ == '_signal' (the C extension), not 'signal' (the wrapper).
# ---------------------------------------------------------------------------

invariant signal_extra8.alarm.name:
  description: "signal.alarm.__name__ == 'alarm' — POSIX alarm function name"
  category: function_identity
  kind: python_call_eq
  function: alarm.__name__.__eq__
  args: ["alarm"]
  expected: true

invariant signal_extra8.alarm.qualname:
  description: "signal.alarm.__qualname__ == 'alarm' — C builtin qualname equals name"
  category: function_identity
  kind: python_call_eq
  function: alarm.__qualname__.__eq__
  args: ["alarm"]
  expected: true

invariant signal_extra8.alarm.module:
  description: "signal.alarm.__module__ == '_signal' — alarm is in the C extension _signal"
  category: function_identity
  kind: python_call_eq
  function: alarm.__module__.__eq__
  args: ["_signal"]
  expected: true

# ---------------------------------------------------------------------------
# SIGUSR1, SIGUSR2, SIGCHLD, SIGWINCH — __class__.__name__ == 'Signals'
#
# signal_extra7 covers .value and .name for these four signals on macOS.
# No prior spec records __class__.__name__ for any of these four signals.
# All are members of the Signals enum.
# ---------------------------------------------------------------------------

table signal_extra8.macOS_signals_class_names:
  description: "SIGUSR1/SIGUSR2/SIGCHLD/SIGWINCH are Signals enum members (macOS)"
  kind: python_call_eq
  category: signals_enum
  id_prefix: sig_class

  columns: [id, function, args, expected]
  rows:
    - [SIGUSR1,  SIGUSR1.__class__.__name__.__eq__,  ["Signals"], true]
    - [SIGUSR2,  SIGUSR2.__class__.__name__.__eq__,  ["Signals"], true]
    - [SIGCHLD,  SIGCHLD.__class__.__name__.__eq__,  ["Signals"], true]
    - [SIGWINCH, SIGWINCH.__class__.__name__.__eq__, ["Signals"], true]
