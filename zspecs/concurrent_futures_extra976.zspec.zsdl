spec: concurrent_futures_extra976
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks concurrent.futures.Future and ThreadPoolExecutor method qualnames"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra976.future_method_qualnames:
  description: "concurrent.futures.Future method __qualname__ identity"
  kind: python_call_eq
  category: future_method_qualnames
  id_prefix: cf976fm
  columns: [id, function, args, expected]
  rows:
    - [cf976fm001, concurrent.futures.Future.result.__qualname__.__eq__,            ["Future.result"],            true]
    - [cf976fm002, concurrent.futures.Future.cancel.__qualname__.__eq__,            ["Future.cancel"],            true]
    - [cf976fm003, concurrent.futures.Future.done.__qualname__.__eq__,              ["Future.done"],              true]
    - [cf976fm004, concurrent.futures.Future.running.__qualname__.__eq__,           ["Future.running"],           true]
    - [cf976fm005, concurrent.futures.Future.cancelled.__qualname__.__eq__,         ["Future.cancelled"],         true]
    - [cf976fm006, concurrent.futures.Future.add_done_callback.__qualname__.__eq__, ["Future.add_done_callback"], true]
    - [cf976fm007, concurrent.futures.Future.exception.__qualname__.__eq__,         ["Future.exception"],         true]

table concurrent_futures_extra976.threadpool_method_qualnames:
  description: "concurrent.futures.ThreadPoolExecutor method __qualname__ identity"
  kind: python_call_eq
  category: threadpool_method_qualnames
  id_prefix: cf976tm
  columns: [id, function, args, expected]
  rows:
    - [cf976tm001, concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__eq__,   ["ThreadPoolExecutor.submit"],   true]
    - [cf976tm002, concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__.__eq__, ["ThreadPoolExecutor.shutdown"], true]
    - [cf976tm003, concurrent.futures.ThreadPoolExecutor.map.__qualname__.__eq__,      ["ThreadPoolExecutor.map"],      true]
    - [cf976tm004, concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__eq__, ["ThreadPoolExecutor.__init__"], true]

table concurrent_futures_extra976.class_identity:
  description: "concurrent.futures class identity and module membership"
  kind: python_call_eq
  category: class_identity
  id_prefix: cf976ci
  columns: [id, function, args, expected]
  rows:
    - [cf976ci001, concurrent.futures.Future.__module__.__eq__,              ["concurrent.futures._base"], true]
    - [cf976ci002, concurrent.futures.Future.__name__.__eq__,                ["Future"],                   true]
    - [cf976ci003, concurrent.futures.ThreadPoolExecutor.__name__.__eq__,    ["ThreadPoolExecutor"],        true]
    - [cf976ci004, concurrent.futures.Future.__class__.__name__.__eq__,      ["type"],                     true]
