invariant itertools_extra147.loader_name_len:
  description: "len(itertools.__loader__.__name__) == 15 — __loader__.__name__ is 'BuiltinImporter'; wave 270; new to extra147"
  kind: python_call_eq
  function: __loader__.__name__.__len__
  args: []
  expected: 15

invariant itertools_extra147.spec_origin_eq_built_in:
  description: "itertools.__spec__.origin == 'built-in' — builtin C extension module origin string; wave 270; new to extra147"
