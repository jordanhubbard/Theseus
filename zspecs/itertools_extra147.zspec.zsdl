spec: itertools_extra147
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.__loader__ (BuiltinImporter type, __name__ len 15); itertools.__spec__.origin (str 'built-in', len 8); itertools.product.__doc__ len 681; itertools.permutations.__doc__ len 140; itertools.combinations.__doc__ len 134; itertools.accumulate.__doc__ len 69; itertools.zip_longest/__bases__[0].__name__ and product/__bases__[0].__name__ (both 'object'); itertools.chain.from_iterable identity (__qualname__ len 19) (Wave 270)."
    - "itertools.__loader__ is the BuiltinImporter class (not an instance); __class__.__name__ == 'type'; __loader__.__name__ == 'BuiltinImporter' (len 15). Verified with Python 3.14.3."
    - "itertools.__spec__.origin == 'built-in' (len 8); its __class__.__name__ is 'str'. Verified with Python 3.14.3."
    - "itertools.product.__doc__ len == 681. Verified with Python 3.14.3."
    - "itertools.permutations.__doc__ len == 140. Verified with Python 3.14.3."
    - "itertools.combinations.__doc__ len == 134. Verified with Python 3.14.3."
    - "itertools.accumulate.__doc__ len == 69. Verified with Python 3.14.3."
    - "itertools.zip_longest.__bases__[0].__name__ == 'object' — C extension types at module scope inherit from object. Verified with Python 3.14.3."
    - "itertools.product.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable' (len 19); __class__.__name__ == 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.__loader__ and __spec__.origin identity
#
# Wave 270 theme: itertools module metadata — __loader__ and __spec__.origin.
#
# itertools.__loader__.__class__.__name__ == 'type'
# itertools.__loader__.__name__ == 'BuiltinImporter' (len 15)
# itertools.__spec__.origin == 'built-in' (len 8)
# itertools.__spec__.origin.__class__.__name__ == 'str'
#
# itertools is a C extension module; its __loader__ is the BuiltinImporter
# class (not an instance), and __spec__.origin is the string 'built-in'.
# New to extra147.
# ---------------------------------------------------------------------------

table itertools_extra147.loader_spec_identity:
  description: "itertools.__loader__ is BuiltinImporter type (len 15); __spec__.origin is 'built-in' str (len 8); wave 270; new to extra147"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsmeta147

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_name_eq_type,
       "__loader__.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.__loader__.__class__.__name__.__eq__('type') == True — itertools.__loader__ is the BuiltinImporter class itself (not an instance); it is a type object; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra147"]
    - [loader_name_eq_builtinimporter,
       "__loader__.__name__.__eq__",
       ["BuiltinImporter"],
       true,
       "itertools.__loader__.__name__.__eq__('BuiltinImporter') == True — itertools is a builtin C extension module loaded by _frozen_importlib.BuiltinImporter; __loader__ is that class; __name__ is 'BuiltinImporter'; str.__eq__('BuiltinImporter') returns True; new to extra147"]
    - [loader_name_len_eq_15,
       "__loader__.__name__.__len__",
       [],
       15,
       "itertools.__loader__.__name__.__len__() == 15 — __loader__.__name__ is 'BuiltinImporter' which has 15 characters; len('BuiltinImporter') == 15; new to extra147"]
    - [spec_origin_eq_built_in,
       "__spec__.origin.__eq__",
       ["built-in"],
       true,
       "itertools.__spec__.origin.__eq__('built-in') == True — the ModuleSpec for a builtin C extension module has its origin attribute set to the string 'built-in'; str.__eq__('built-in') returns True; new to extra147"]
    - [spec_origin_len_eq_8,
       "__spec__.origin.__len__",
       [],
       8,
       "itertools.__spec__.origin.__len__() == 8 — __spec__.origin is 'built-in' which has 8 characters; len('built-in') == 8; new to extra147"]
    - [spec_origin_class_name_eq_str,
       "__spec__.origin.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.__spec__.origin.__class__.__name__.__eq__('str') == True — __spec__.origin is a plain Python string; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra147"]

# ---------------------------------------------------------------------------
# Table 2: itertools C-type __doc__ lengths
#
# Wave 270 theme: itertools C-type docstring lengths for product, permutations,
# combinations, and accumulate.
#
# len(itertools.product.__doc__) == 681
# len(itertools.permutations.__doc__) == 140
# len(itertools.combinations.__doc__) == 134
# len(itertools.accumulate.__doc__) == 69
#
# All itertools C types have a __doc__ attribute set in the PyTypeObject.
# The lengths are fixed in Python 3.14.3. New to extra147.
# ---------------------------------------------------------------------------

table itertools_extra147.ctype_doc_lengths:
  description: "itertools.product/__doc__ len 681; permutations/__doc__ len 140; combinations/__doc__ len 134; accumulate/__doc__ len 69; wave 270; new to extra147"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsdoc147

  columns: [id, function, args, expected, description]
  rows:
    - [product_doc_len_eq_681,
       "product.__doc__.__len__",
       [],
       681,
       "itertools.product.__doc__.__len__() == 681 — the product type docstring has 681 characters in Python 3.14.3; it describes Cartesian product of input iterables and equivalent nested for-loops; len(__doc__) == 681; verified with Python 3.14.3; new to extra147"]
    - [permutations_doc_len_eq_140,
       "permutations.__doc__.__len__",
       [],
       140,
       "itertools.permutations.__doc__.__len__() == 140 — the permutations type docstring has 140 characters; it describes successive r-length permutations; len(__doc__) == 140; verified with Python 3.14.3; new to extra147"]
    - [combinations_doc_len_eq_134,
       "combinations.__doc__.__len__",
       [],
       134,
       "itertools.combinations.__doc__.__len__() == 134 — the combinations type docstring has 134 characters; it describes successive r-length combinations; len(__doc__) == 134; verified with Python 3.14.3; new to extra147"]
    - [accumulate_doc_len_eq_69,
       "accumulate.__doc__.__len__",
       [],
       69,
       "itertools.accumulate.__doc__.__len__() == 69 — the accumulate type docstring has 69 characters: 'Return series of accumulated sums (or other binary function results).'; len(__doc__) == 69; verified with Python 3.14.3; new to extra147"]

# ---------------------------------------------------------------------------
# Table 3: itertools C-type __bases__[0].__name__ (all 'object')
#
# Wave 270 theme: itertools C extension types all inherit from object at the C
# level; __bases__[0].__name__ is 'object' for all major types.
#
# itertools.zip_longest.__bases__[0].__name__ == 'object'
# itertools.product.__bases__[0].__name__ == 'object'
# itertools.combinations.__bases__[0].__name__ == 'object'
# itertools.permutations.__bases__[0].__name__ == 'object'
#
# All C extension types defined in itertoolsmodule.c have PyObject as their
# tp_base, which maps to the Python 'object' type. New to extra147.
# ---------------------------------------------------------------------------

table itertools_extra147.bases_object_group:
  description: "itertools zip_longest/product/combinations/permutations __bases__[0].__name__ == 'object'; all C extension types inherit from object; wave 270; new to extra147"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsbases147

  columns: [id, function, args, expected, description]
  rows:
    - [zip_longest_bases_first_eq_object,
       "zip_longest.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.zip_longest.__bases__[0].__name__.__eq__('object') == True — zip_longest is a C extension type defined in itertoolsmodule.c; its tp_base is PyObject (the C-level base for object); __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra147"]
    - [product_bases_first_eq_object,
       "product.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.product.__bases__[0].__name__.__eq__('object') == True — product is a C extension type; its tp_base is PyObject; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra147"]
    - [combinations_bases_first_eq_object,
       "combinations.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.combinations.__bases__[0].__name__.__eq__('object') == True — combinations is a C extension type; its tp_base is PyObject; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra147"]
    - [permutations_bases_first_eq_object,
       "permutations.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.permutations.__bases__[0].__name__.__eq__('object') == True — permutations is a C extension type; its tp_base is PyObject; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra147"]

# ---------------------------------------------------------------------------
# Table 4: itertools.chain.from_iterable — class method identity
#
# Wave 270 theme: itertools.chain.from_iterable — a C-level class method on the
# chain type that creates a chain from a single iterable of iterables.
#
# itertools.chain.from_iterable.__class__.__name__ == 'builtin_function_or_method'
# itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable' (len 19)
# itertools.chain.from_iterable.__name__ == 'from_iterable' (len 13)
#
# chain.from_iterable is a C class method; it appears as a
# builtin_function_or_method when accessed on the class. New to extra147.
# ---------------------------------------------------------------------------

table itertools_extra147.chain_from_iterable_identity:
  description: "itertools.chain.from_iterable: builtin_function_or_method, __qualname__ 'chain.from_iterable' len 19, __name__ 'from_iterable' len 13; wave 270; new to extra147"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolscfi147

  columns: [id, function, args, expected, description]
  rows:
    - [from_iterable_class_eq_builtin,
       "chain.from_iterable.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.chain.from_iterable.__class__.__name__.__eq__('builtin_function_or_method') == True — chain.from_iterable is a C class method defined in itertoolsmodule.c; when accessed on the chain class it is exposed as a builtin_function_or_method; str.__eq__('builtin_function_or_method') returns True; new to extra147"]
    - [from_iterable_qualname_eq,
       "chain.from_iterable.__qualname__.__eq__",
       ["chain.from_iterable"],
       true,
       "itertools.chain.from_iterable.__qualname__.__eq__('chain.from_iterable') == True — the class method's __qualname__ includes the class prefix 'chain.from_iterable'; str.__eq__('chain.from_iterable') returns True; new to extra147"]
    - [from_iterable_qualname_len_eq_19,
       "chain.from_iterable.__qualname__.__len__",
       [],
       19,
       "itertools.chain.from_iterable.__qualname__.__len__() == 19 — __qualname__ is 'chain.from_iterable' which has 19 characters; len('chain.from_iterable') == 19; new to extra147"]
    - [from_iterable_name_eq,
       "chain.from_iterable.__name__.__eq__",
       ["from_iterable"],
       true,
       "itertools.chain.from_iterable.__name__.__eq__('from_iterable') == True — the simple __name__ of the class method is 'from_iterable' (without the class prefix); str.__eq__('from_iterable') returns True; new to extra147"]
    - [from_iterable_name_len_eq_13,
       "chain.from_iterable.__name__.__len__",
       [],
       13,
       "itertools.chain.from_iterable.__name__.__len__() == 13 — __name__ is 'from_iterable' which has 13 characters; len('from_iterable') == 13; new to extra147"]

