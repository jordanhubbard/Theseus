invariant itertools_extra147.zip_longest_bases_object:
  description: "itertools.zip_longest.__bases__[0].__name__ == 'object' — C extension type inherits from object; wave 270; new to extra147"
  kind: python_call_eq
  function: "zip_longest.__bases__[0].__name__.__eq__"
