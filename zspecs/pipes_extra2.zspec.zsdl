spec: pipes_extra2
version: ">=3.9,<3.13"
backend: python_module(pipes)

docs: https://docs.python.org/3/library/pipes.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pipes.html — Python pipes documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pipes.py"
  notes:
    - "This spec extends pipes.zspec.zsdl and pipes_extra.zspec.zsdl."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Template.open() raises ValueError if the pipeline is misconfigured. Underlying shell errors propagate through subprocess."
  stderr: "null"
  stickiness: "N/A — each Template instance is independent."
  codes: {}

# ---------------------------------------------------------------------------
# Template class — qualname
# ---------------------------------------------------------------------------

invariant pipes_extra2.Template_qualname:
  description: "pipes.Template.__qualname__ == 'Template'"
  category: classnames
  kind: python_call_eq
  function: Template.__qualname__.__eq__
  args: ["Template"]
  expected: true

# ---------------------------------------------------------------------------
# Template class — bases[0] qualname
# ---------------------------------------------------------------------------

invariant pipes_extra2.Template_base_qualname:
  description: "pipes.Template.__bases__[0].__qualname__ == 'object'"
  category: classnames
  kind: python_call_eq
  function: Template.__bases__.__getitem__
  args: [0]
  method: __qualname__
  method_args: []
  expected: "object"

# ---------------------------------------------------------------------------
# Template instance — class name via instance (different path from pipes.zspec.zsdl)
# ---------------------------------------------------------------------------

invariant pipes_extra2.Template_instance_module:
  description: "pipes.Template().__class__.__module__ == 'pipes'"
  category: instance
  kind: python_call_eq
  function: Template
  args: []
  method: __class__.__module__.__eq__
  method_args: ["pipes"]
  expected: true

# ---------------------------------------------------------------------------
# STDIN length check — novel invariant not in prior specs
# ---------------------------------------------------------------------------

invariant pipes_extra2.STDIN_len:
  description: "len(pipes.STDIN) == 1 — STDIN is a single-character string"
  category: constants
  kind: python_call_eq
  function: STDIN.__len__
  args: []
  expected: 1

invariant pipes_extra2.STDOUT_len:
  description: "len(pipes.STDOUT) == 1 — STDOUT is a single-character string"
  category: constants
  kind: python_call_eq
  function: STDOUT.__len__
  args: []
  expected: 1
