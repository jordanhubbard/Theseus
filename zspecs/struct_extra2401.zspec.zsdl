spec: struct_extra2401
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "struct_extra2401: __hash__ and __eq__ implementation type classification for struct.Struct and struct.error."
    - "struct.Struct is a C extension type. Its class-level __hash__ and __eq__ are both 'wrapper_descriptor' inherited from object."
    - "struct.Struct does NOT define __hash__ or __eq__ in its own __dict__ — both __dict__.__contains__ checks return False."
    - "struct.error is a Python exception subclassing Exception → BaseException → object. Its __hash__ and __eq__ are both 'wrapper_descriptor', also inherited from object."
    - "struct.error MRO: struct.error, Exception, BaseException, object — no custom __hash__ or __eq__ at any level in this chain."
    - "struct.Struct instances ARE hashable via object's identity-based hash — struct.Struct does not set __hash__ = None."
    - "All expected values verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table struct_extra2401.struct_hash_eq_class_name:
  description: "struct.Struct class-level __hash__ and __eq__ are both 'wrapper_descriptor' — C extension type, inherits from object"
  kind: python_call_eq
  category: hash_eq_classification
  id_prefix: st2401sh

  columns: [id, function, args, expected]
  rows:
    - ["st2401001", "struct.Struct.__hash__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["st2401002", "struct.Struct.__eq__.__class__.__name__.__eq__",   ["wrapper_descriptor"], true]
    - ["st2401003", "struct.Struct.__hash__.__class__.__name__.__eq__", ["function"],           false]
    - ["st2401004", "struct.Struct.__eq__.__class__.__name__.__eq__",   ["function"],           false]
    - ["st2401005", "struct.Struct.__hash__.__class__.__name__.__eq__", ["method-wrapper"],     false]
    - ["st2401006", "struct.Struct.__eq__.__class__.__name__.__eq__",   ["method-wrapper"],     false]

table struct_extra2401.struct_error_hash_eq_class_name:
  description: "struct.error class-level __hash__ and __eq__ are both 'wrapper_descriptor' — exception inheriting from object via BaseException"
  kind: python_call_eq
  category: hash_eq_classification
  id_prefix: st2401eh

  columns: [id, function, args, expected]
  rows:
    - ["st2401007", "struct.error.__hash__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["st2401008", "struct.error.__eq__.__class__.__name__.__eq__",   ["wrapper_descriptor"], true]
    - ["st2401009", "struct.error.__hash__.__class__.__name__.__eq__", ["function"],           false]
    - ["st2401010", "struct.error.__eq__.__class__.__name__.__eq__",   ["function"],           false]
    - ["st2401011", "struct.error.__hash__.__class__.__name__.__eq__", ["method-wrapper"],     false]
    - ["st2401012", "struct.error.__eq__.__class__.__name__.__eq__",   ["method-wrapper"],     false]

table struct_extra2401.struct_dict_contains:
  description: "struct.Struct.__dict__.__contains__ returns false for __hash__ and __eq__ — neither is defined in Struct's own __dict__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2401sd

  columns: [id, function, args, expected]
  rows:
    - ["st2401013", "struct.Struct.__dict__.__contains__", ["__hash__"], false]
    - ["st2401014", "struct.Struct.__dict__.__contains__", ["__eq__"],   false]
    - ["st2401015", "struct.Struct.__dict__.__contains__", ["pack"],     true]
    - ["st2401016", "struct.Struct.__dict__.__contains__", ["unpack"],   true]

table struct_extra2401.struct_error_dict_contains:
  description: "struct.error.__dict__.__contains__ returns false for __hash__ and __eq__ — exception does not define either in its own __dict__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2401ed

  columns: [id, function, args, expected]
  rows:
    - ["st2401017", "struct.error.__dict__.__contains__", ["__hash__"], false]
    - ["st2401018", "struct.error.__dict__.__contains__", ["__eq__"],   false]
    - ["st2401019", "struct.error.__dict__.__contains__", ["args"],     false]
    - ["st2401020", "struct.error.__dict__.__contains__", ["__doc__"],  true]
