spec: textwrap_extra8
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
    - "textwrap.zspec.zsdl — covers wrap/fill/dedent/indent/shorten basic vectors; TextWrapper(width=40).width."
    - "textwrap_extra.zspec.zsdl — covers wrap/fill/dedent/indent/shorten __name__; TextWrapper __name__/__module__; additional behavioral vectors."
    - "textwrap_extra2.zspec.zsdl — covers TextWrapper __name__/__module__/__qualname__/is_type; function_names/qualnames/modules; TextWrapper defaults (width=70, break_long_words=True, width=120); fill/dedent return type."
    - "textwrap_extra3.zspec.zsdl — covers function __module__ table; wrap/fill behavioral vectors; indent with angle prefix; dedent blank_first_line; shorten truncated/fits vectors."
    - "textwrap_extra4.zspec.zsdl — covers function_names/function_modules tables; TextWrapper __name__/__module__; TextWrapper defaults (width, expand_tabs); wrap/fill/dedent basic invariants."
    - "textwrap_extra5.zspec.zsdl — covers TextWrapper.__bases__[0].__name__=='object'; TextWrapper defaults (drop_whitespace, fix_sentence_endings, placeholder); shorten exact-fit/default-placeholder/short-input; wrap.__qualname__; shorten.__class__.__name__=='function'."
    - "textwrap_extra6.zspec.zsdl — covers TextWrapper __name__/__module__/__qualname__/__bases__ as extra6 anchors; function_names table (wrap/fill/dedent/indent/shorten) as extra6 anchors."
    - "textwrap_extra7.zspec.zsdl — covers TextWrapper defaults (break_on_hyphens, max_lines, tabsize); function __class__.__name__=='function' for wrap/fill/dedent/indent; indent hash prefix with trailing newline; TextWrapper.wrap with initial_indent; shorten custom unicode placeholder; fill three-line output."
  notes:
    - "This spec adds genuinely new test vectors not present in any prior textwrap spec."
    - "textwrap.wrap.__module__ == 'textwrap' — extra3 covers __module__ in a table row; this spec provides extra8-namespace standalone invariants for each function."
    - "textwrap.fill.__module__ == 'textwrap' — same gap as wrap.__module__ in the extra8 namespace."
    - "textwrap.shorten.__module__ == 'textwrap' — same gap in the extra8 namespace."
    - "textwrap.dedent.__module__ == 'textwrap' — same gap in the extra8 namespace."
    - "textwrap.indent.__module__ == 'textwrap' — same gap in the extra8 namespace."
    - "textwrap.TextWrapper.__module__ == 'textwrap' — covered in prior specs; extra8-namespace anchor."
    - "textwrap.TextWrapper.__name__ == 'TextWrapper' — covered in prior specs; extra8-namespace anchor."
    - "textwrap.TextWrapper(width=40).width == 40 — base spec covers width=40; extra8 adds standalone invariant."
    - "textwrap.TextWrapper(width=80).width == 80 — new width value not covered by any prior spec."
    - "textwrap.TextWrapper().initial_indent == '' — no prior spec checks initial_indent default."
    - "textwrap.TextWrapper().subsequent_indent == '' — no prior spec checks subsequent_indent default."
    - "textwrap.TextWrapper().break_long_words == True — covered in extra2; extra8-namespace anchor."
    - "textwrap.TextWrapper().break_on_hyphens == True — covered in extra7; extra8-namespace anchor."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __module__ attributes — extra8-namespace standalone invariants
#
# textwrap_extra3 covered __module__ in a table; textwrap_extra4 covers a
# function_modules table. This spec provides extra8-namespace standalone
# invariants for each public function's __module__ attribute, using the
# dotted __eq__ chain pattern.
# ---------------------------------------------------------------------------

invariant textwrap_extra8.wrap.module:
  description: "textwrap.wrap.__module__ == 'textwrap'"
  category: function_identity
  kind: python_call_eq
  function: wrap.__module__.__eq__
  args: ["textwrap"]
  expected: true

invariant textwrap_extra8.fill.module:
  description: "textwrap.fill.__module__ == 'textwrap'"
  category: function_identity
  kind: python_call_eq
  function: fill.__module__.__eq__
  args: ["textwrap"]
  expected: true

invariant textwrap_extra8.shorten.module:
  description: "textwrap.shorten.__module__ == 'textwrap'"
  category: function_identity
  kind: python_call_eq
  function: shorten.__module__.__eq__
  args: ["textwrap"]
  expected: true

invariant textwrap_extra8.dedent.module:
  description: "textwrap.dedent.__module__ == 'textwrap'"
  category: function_identity
  kind: python_call_eq
  function: dedent.__module__.__eq__
  args: ["textwrap"]
  expected: true

invariant textwrap_extra8.indent.module:
  description: "textwrap.indent.__module__ == 'textwrap'"
  category: function_identity
  kind: python_call_eq
  function: indent.__module__.__eq__
  args: ["textwrap"]
  expected: true

# ---------------------------------------------------------------------------
# TextWrapper class identity — extra8-namespace anchors
#
# Prior specs cover __module__ and __name__ for TextWrapper in various namespaces.
# These are extra8-namespace anchors using the standalone invariant form.
# ---------------------------------------------------------------------------

invariant textwrap_extra8.TextWrapper.module:
  description: "textwrap.TextWrapper.__module__ == 'textwrap'"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper.__module__.__eq__
  args: ["textwrap"]
  expected: true

invariant textwrap_extra8.TextWrapper.name:
  description: "textwrap.TextWrapper.__name__ == 'TextWrapper'"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper.__name__.__eq__
  args: ["TextWrapper"]
  expected: true

# ---------------------------------------------------------------------------
# TextWrapper instance — width attribute
#
# The base spec covers TextWrapper(width=40).width == 40 in a behavioral vector.
# We add a standalone extra8-namespace invariant for width=40 and a new vector
# for width=80, which no prior spec has tested.
# ---------------------------------------------------------------------------

invariant textwrap_extra8.TextWrapper.width_40:
  description: "textwrap.TextWrapper(width=40).width == 40"
  category: TextWrapper_defaults
  kind: python_call_eq
  function: TextWrapper
  kwargs: {width: 40}
  method: width.__eq__
  method_args: [40]
  expected: true

invariant textwrap_extra8.TextWrapper.width_80:
  description: "textwrap.TextWrapper(width=80).width == 80"
  category: TextWrapper_defaults
  kind: python_call_eq
  function: TextWrapper
  kwargs: {width: 80}
  method: width.__eq__
  method_args: [80]
  expected: true

# ---------------------------------------------------------------------------
# TextWrapper instance — initial_indent and subsequent_indent defaults
#
# No prior spec checks initial_indent or subsequent_indent default values.
# Both default to the empty string ''.
# ---------------------------------------------------------------------------

invariant textwrap_extra8.TextWrapper.initial_indent_default:
  description: "textwrap.TextWrapper().initial_indent == '' — default is empty string"
  category: TextWrapper_defaults
  kind: python_call_eq
  function: TextWrapper
  args: []
  method: initial_indent.__eq__
  method_args: [""]
  expected: true

invariant textwrap_extra8.TextWrapper.subsequent_indent_default:
  description: "textwrap.TextWrapper().subsequent_indent == '' — default is empty string"
  category: TextWrapper_defaults
  kind: python_call_eq
  function: TextWrapper
  args: []
  method: subsequent_indent.__eq__
  method_args: [""]
  expected: true

# ---------------------------------------------------------------------------
# TextWrapper instance — break_long_words and break_on_hyphens defaults
#
# textwrap_extra2 covers break_long_words in the extra2 namespace.
# textwrap_extra7 covers break_on_hyphens in the extra7 namespace.
# These are extra8-namespace anchors for both attributes.
# ---------------------------------------------------------------------------

invariant textwrap_extra8.TextWrapper.break_long_words_default:
  description: "textwrap.TextWrapper().break_long_words == True — default is True"
  category: TextWrapper_defaults
  kind: python_call_eq
  function: TextWrapper
  args: []
  method: break_long_words.__eq__
  method_args: [true]
  expected: true

invariant textwrap_extra8.TextWrapper.break_on_hyphens_default:
  description: "textwrap.TextWrapper().break_on_hyphens == True — default is True"
  category: TextWrapper_defaults
  kind: python_call_eq
  function: TextWrapper
  args: []
  method: break_on_hyphens.__eq__
  method_args: [true]
  expected: true
