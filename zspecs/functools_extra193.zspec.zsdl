spec: functools_extra193
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "functools.total_ordering.__name__ == 'total_ordering' (len=14); verified with Python 3.14.3."
    - "functools.total_ordering.__module__ == 'functools'; verified with Python 3.14.3."
    - "functools.total_ordering.__qualname__ == 'total_ordering'; verified with Python 3.14.3."
    - "functools.total_ordering.__class__.__name__ == 'function' — total_ordering is a plain Python function (not a class or builtin); verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS is a tuple of length 6 in Python 3.14.3: ('__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'). NOTE: Python 3.14 added '__annotate__' and '__type_params__' to WRAPPER_ASSIGNMENTS; earlier versions had length 5. Value 6 verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES is a tuple of length 1: ('__dict__',); verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'; functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple'; both verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.total_ordering identity
#
# functools.total_ordering.__name__    == 'total_ordering' (len=14)
# functools.total_ordering.__module__  == 'functools'
# functools.total_ordering.__qualname__ == 'total_ordering'
#
# total_ordering is a decorator implemented as a plain Python function.
# Its __name__ and __qualname__ are both 'total_ordering'. New to extra193.
# ---------------------------------------------------------------------------

table functools_extra193.total_ordering_identity:
  description: "functools.total_ordering identity: __name__=='total_ordering' (len=14); __module__=='functools'; __qualname__=='total_ordering'; __class__.__name__=='function'; new to extra193"
  kind: python_call_eq
  category: identity
  id_prefix: functtotalord193

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,
       total_ordering.__name__.__eq__,
       ["total_ordering"],
       true,
       "functools.total_ordering.__name__.__eq__('total_ordering') == True — the decorator's __name__ is 'total_ordering'; str.__eq__('total_ordering') returns True; verified with Python 3.14.3; new to extra193"]
    - [name_len,
       total_ordering.__name__.__len__,
       [],
       14,
       "functools.total_ordering.__name__.__len__() == 14 — 'total_ordering' has 14 characters: t-o-t-a-l-_-o-r-d-e-r-i-n-g; str.__len__() returns 14; verified with Python 3.14.3; new to extra193"]
    - [module_eq,
       total_ordering.__module__.__eq__,
       ["functools"],
       true,
       "functools.total_ordering.__module__.__eq__('functools') == True — total_ordering is defined in the functools module; str.__eq__('functools') returns True; verified with Python 3.14.3; new to extra193"]
    - [qualname_eq,
       total_ordering.__qualname__.__eq__,
       ["total_ordering"],
       true,
       "functools.total_ordering.__qualname__.__eq__('total_ordering') == True — top-level function so __qualname__ equals __name__; str.__eq__('total_ordering') returns True; verified with Python 3.14.3; new to extra193"]
    - [class_name_eq,
       total_ordering.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.total_ordering.__class__.__name__.__eq__('function') == True — total_ordering is a plain Python function not a class; __class__.__name__ is 'function'; str.__eq__('function') returns True; verified with Python 3.14.3; new to extra193"]

# ---------------------------------------------------------------------------
# Table 2: WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES class identity
#
# functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'
# functools.WRAPPER_UPDATES.__class__.__name__     == 'tuple'
# functools.WRAPPER_ASSIGNMENTS.__len__()          == 6 (Python 3.14.3)
# functools.WRAPPER_UPDATES.__len__()              == 1
#
# Both constants are plain Python tuples. WRAPPER_ASSIGNMENTS has 6 elements
# in Python 3.14.3 (added __annotate__ and __type_params__ since 3.12).
# WRAPPER_UPDATES has always had 1 element: __dict__. New to extra193.
# ---------------------------------------------------------------------------

table functools_extra193.wrapper_constants_class:
  description: "WRAPPER_ASSIGNMENTS.__class__.__name__=='tuple'; WRAPPER_UPDATES.__class__.__name__=='tuple'; WRAPPER_ASSIGNMENTS.__len__()==6 (Python 3.14.3: includes __annotate__ and __type_params__); WRAPPER_UPDATES.__len__()==1; new to extra193"
  kind: python_call_eq
  category: identity
  id_prefix: functtotalord193

  columns: [id, function, args, expected, description]
  rows:
    - [wa_class_eq,
       WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('tuple') == True — WRAPPER_ASSIGNMENTS is a plain Python tuple; __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; verified with Python 3.14.3; new to extra193"]
    - [wu_class_eq,
       WRAPPER_UPDATES.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.WRAPPER_UPDATES.__class__.__name__.__eq__('tuple') == True — WRAPPER_UPDATES is a plain Python tuple; __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; verified with Python 3.14.3; new to extra193"]
    - [wa_len,
       WRAPPER_ASSIGNMENTS.__len__,
       [],
       6,
       "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — Python 3.14.3 has 6 elements: __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__; tuple.__len__() returns 6; verified with Python 3.14.3; new to extra193"]
    - [wu_len,
       WRAPPER_UPDATES.__len__,
       [],
       1,
       "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES contains only '__dict__'; tuple.__len__() returns 1; verified with Python 3.14.3; new to extra193"]

# ---------------------------------------------------------------------------
# Table 3: total_ordering __name__ length and module length
#
# functools.total_ordering.__name__.__len__()   == 14
# functools.total_ordering.__module__.__len__() == 9
#
# Extra length checks reinforce the identity claims in Table 1. New to extra193.
# ---------------------------------------------------------------------------

table functools_extra193.total_ordering_lengths:
  description: "total_ordering.__name__.__len__()==14; total_ordering.__module__.__len__()==9 ('functools' has 9 chars); WRAPPER_UPDATES.__len__()==1; new to extra193"
  kind: python_call_eq
  category: identity
  id_prefix: functtotalord193

  columns: [id, function, args, expected, description]
  rows:
    - [name_len14,
       total_ordering.__name__.__len__,
       [],
       14,
       "functools.total_ordering.__name__.__len__() == 14 — 'total_ordering' is 14 characters; t-o-t-a-l-_-o-r-d-e-r-i-n-g; verified with Python 3.14.3; new to extra193"]
    - [module_len9,
       total_ordering.__module__.__len__,
       [],
       9,
       "functools.total_ordering.__module__.__len__() == 9 — __module__ is 'functools' which has 9 characters: f-u-n-c-t-o-o-l-s; verified with Python 3.14.3; new to extra193"]
    - [wu_len1,
       WRAPPER_UPDATES.__len__,
       [],
       1,
       "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES has exactly 1 element ('__dict__'); verified with Python 3.14.3; new to extra193"]

