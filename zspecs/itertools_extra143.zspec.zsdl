spec: itertools_extra143
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.chain (C type), itertools.cycle (C type), itertools.repeat (C type), itertools.count (C type), itertools.product (C type), itertools.permutations (C type), itertools.combinations (C type) — __qualname__, __module__, __name__ len, __doc__ len, MRO len (Wave 271)."
    - "itertools.chain: __name__ == 'chain' (len 5); __qualname__ == 'chain' (len 5); __module__ == 'itertools'; __doc__ len == 190; MRO len == 2. Verified with Python 3.14.3."
    - "itertools.cycle: __name__ == 'cycle' (len 5); __qualname__ == 'cycle' (len 5); __module__ == 'itertools'; __doc__ len == 95; MRO len == 2. Verified with Python 3.14.3."
    - "itertools.repeat: __name__ == 'repeat' (len 6); __qualname__ == 'repeat' (len 6); __module__ == 'itertools'; __doc__ len == 154; MRO len == 2. Verified with Python 3.14.3."
    - "itertools.count: __name__ == 'count' (len 5); __qualname__ == 'count' (len 5); __module__ == 'itertools'; __doc__ len == 205; MRO len == 2. Verified with Python 3.14.3."
    - "itertools.product: __name__ == 'product' (len 7); __qualname__ == 'product' (len 7); __module__ == 'itertools'; __doc__ len == 681; MRO len == 2. Verified with Python 3.14.3."
    - "itertools.permutations: __name__ == 'permutations' (len 12); __qualname__ == 'permutations' (len 12); __module__ == 'itertools'; __doc__ len == 140; MRO len == 2. Verified with Python 3.14.3."
    - "itertools.combinations: __name__ == 'combinations' (len 12); __qualname__ == 'combinations' (len 12); __module__ == 'itertools'; __doc__ len == 134; MRO len == 2. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.chain and itertools.cycle — C type qualname and module
#
# Wave 271 theme: itertools.chain and itertools.cycle — infinite and chaining
# C extension types in itertoolsmodule.c.
#
# itertools.chain.__class__.__name__ == 'type'
# itertools.chain.__name__ == 'chain' (len 5)
# itertools.chain.__qualname__ == 'chain' (len 5)
# itertools.chain.__module__ == 'itertools' (len 9)
# len(itertools.chain.__doc__) == 190
# len(itertools.chain.__mro__) == 2
# itertools.cycle.__class__.__name__ == 'type'
# itertools.cycle.__name__ == 'cycle' (len 5)
# itertools.cycle.__qualname__ == 'cycle' (len 5)
# itertools.cycle.__module__ == 'itertools' (len 9)
# len(itertools.cycle.__doc__) == 95
# len(itertools.cycle.__mro__) == 2
#
# chain(*iterables) chains iterables end-to-end; cycle(iterable) repeats
# infinitely. New to extra143.
# ---------------------------------------------------------------------------

table itertools_extra143.chain_cycle_attrs:
