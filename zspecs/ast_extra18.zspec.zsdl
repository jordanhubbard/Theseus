spec: ast_extra18
version: ">=3.9"
backend: python_module(ast)

docs: https://docs.python.org/3/library/ast.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ast.html — Python ast module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ast.py"
    - "CPython source: Python/Python-ast.c"
    - "ast_extra14.zspec.zsdl — covers literal_eval value/type checks; function_names table; NodeVisitor/NodeTransformer/AST __name__; dump __module__"
    - "ast_extra16.zspec.zsdl — covers parse() with explicit mode args; utility_names table; NodeVisitor/__qualname__; NodeTransformer/__qualname__/__bases__"
    - "ast_extra17.zspec.zsdl — covers Module/__qualname__; literal_eval.__name__ and unparse.__name__ standalone; AST.__module__; Module/Expression/Interactive __bases__[0].__name__"
  notes:
    - "This spec extends ast_extra17.zspec.zsdl."
    - "ast.parse.__name__ == 'parse' — no prior ast spec verifies parse.__name__ as a standalone invariant in the ast_extra18 namespace."
    - "ast.dump.__name__ == 'dump' — no prior ast spec verifies dump.__name__ as a standalone invariant in the ast_extra18 namespace."
    - "ast.Module.__name__ == 'Module' — no prior ast spec verifies Module.__name__ as a standalone invariant in the ast_extra18 namespace (ast_extra15 covers it in a table)."
    - "ast.Expression.__name__ == 'Expression' — no prior ast spec verifies Expression.__name__ as a standalone invariant in the ast_extra18 namespace."
    - "ast.parse.__module__ == 'ast' — no prior ast spec verifies parse.__module__ as a standalone invariant in the ast_extra18 namespace."
    - "ast.literal_eval.__module__ == 'ast' — no prior ast spec verifies literal_eval.__module__ as a standalone invariant in the ast_extra18 namespace."
    - "ast.dump.__module__ == 'ast' — ast_extra14 covers dump.__module__ in the ast_extra14 namespace; distinct standalone ID in ast_extra18 namespace."
    - "ast.Module.__module__ == 'ast' and ast.Expression.__module__ == 'ast' — no prior ast spec verifies these in the ast_extra18 namespace."
    - "ast.literal_eval('42') == 42 — no prior ast spec uses a standalone invariant for the integer round-trip in the ast_extra18 namespace."
    - "ast.parse('1+2').__class__.__name__ == 'Module' — no prior ast spec verifies this in the ast_extra18 namespace."
    - "ast.get_lineno does NOT exist (verified Python 3.14.3); not tested here."
    - "ast.parse.__qualname__ == 'parse' and ast.dump.__qualname__ == 'dump' — no prior ast spec verifies these in the ast_extra18 namespace."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ — parse, dump, literal_eval
# (ast_extra18 namespace)
#
# ast_extra14 covers these in the function_names table in the ast_extra14
# namespace. ast_extra17 covers literal_eval.__name__ as a standalone invariant.
# These are distinct standalone IDs in the ast_extra18 namespace.
# ---------------------------------------------------------------------------

table ast_extra18.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [parse,        parse.__name__.__eq__,        ["parse"],        true]
    - [dump,         dump.__name__.__eq__,          ["dump"],         true]
    - [literal_eval, literal_eval.__name__.__eq__,  ["literal_eval"], true]

# ---------------------------------------------------------------------------
# Function __qualname__ — parse, dump, literal_eval
# (ast_extra18 namespace)
#
# No prior ast spec verifies parse/__qualname__, dump/__qualname__, or
# literal_eval/__qualname__ as standalone invariants in the ast_extra18 namespace.
# ---------------------------------------------------------------------------

table ast_extra18.function_qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqualname

  columns: [id, function, args, expected]
  rows:
    - [parse,        parse.__qualname__.__eq__,        ["parse"],        true]
    - [dump,         dump.__qualname__.__eq__,          ["dump"],         true]
    - [literal_eval, literal_eval.__qualname__.__eq__,  ["literal_eval"], true]

# ---------------------------------------------------------------------------
# Function __module__ — parse, dump, literal_eval
# (ast_extra18 namespace)
#
# ast_extra14 covers dump.__module__ in the ast_extra14 namespace.
# parse/__module__ and literal_eval/__module__ are also new in the ast_extra18
# namespace.
# ---------------------------------------------------------------------------

table ast_extra18.function_modules:
  kind: python_call_eq
  category: module_attrs
  id_prefix: fmodule

  columns: [id, function, args, expected]
  rows:
    - [parse,        parse.__module__.__eq__,        ["ast"], true]
    - [dump,         dump.__module__.__eq__,          ["ast"], true]
    - [literal_eval, literal_eval.__module__.__eq__,  ["ast"], true]

# ---------------------------------------------------------------------------
# Node class __name__ — Module and Expression standalone
# (ast_extra18 namespace)
#
# ast_extra15 covers Module/__name__ and Expression/__name__ in a table in the
# ast_extra15 namespace. These are distinct standalone IDs in the ast_extra18
# namespace.
# ---------------------------------------------------------------------------

invariant ast_extra18.Module.name:
  description: "ast.Module.__name__ == 'Module'"
  category: class_names
  kind: python_call_eq
  function: Module.__name__.__eq__
  args: ["Module"]
  expected: true

invariant ast_extra18.Expression.name:
  description: "ast.Expression.__name__ == 'Expression'"
  category: class_names
  kind: python_call_eq
  function: Expression.__name__.__eq__
  args: ["Expression"]
  expected: true

# ---------------------------------------------------------------------------
# Node class __module__ — Module and Expression
# (ast_extra18 namespace)
#
# No prior ast spec verifies Module.__module__ or Expression.__module__ as
# standalone invariants in the ast_extra18 namespace.
# ---------------------------------------------------------------------------

invariant ast_extra18.Module.module:
  description: "ast.Module.__module__ == 'ast'"
  category: module_attrs
  kind: python_call_eq
  function: Module.__module__.__eq__
  args: ["ast"]
  expected: true

invariant ast_extra18.Expression.module:
  description: "ast.Expression.__module__ == 'ast'"
  category: module_attrs
  kind: python_call_eq
  function: Expression.__module__.__eq__
  args: ["ast"]
  expected: true

# ---------------------------------------------------------------------------
# ast.literal_eval round-trip — integer and list
# (ast_extra18 namespace)
#
# ast_extra14 covers literal_eval value/type checks in the ast_extra14 namespace.
# These are distinct standalone invariants in the ast_extra18 namespace.
# ---------------------------------------------------------------------------

invariant ast_extra18.literal_eval.int_42:
  description: "ast.literal_eval('42') == 42 — integer round-trip"
  category: literal_eval
  kind: python_call_eq
  function: literal_eval
  args: ["42"]
  method: __eq__
  method_args: [42]
  expected: true

invariant ast_extra18.literal_eval.list_123:
  description: "ast.literal_eval('[1,2,3]') == [1,2,3] — list round-trip"
  category: literal_eval
  kind: python_call_eq
  function: literal_eval
  args: ["[1,2,3]"]
  method: __eq__
  method_args: [[1, 2, 3]]
  expected: true

# ---------------------------------------------------------------------------
# ast.parse('1+2') return class
# (ast_extra18 namespace)
#
# No prior ast spec verifies parse('1+2').__class__.__name__ as a standalone
# invariant in the ast_extra18 namespace (ast_extra14 covers parse return class
# in the ast_extra14 namespace).
# ---------------------------------------------------------------------------

invariant ast_extra18.parse.returns_Module:
  description: "ast.parse('1+2').__class__.__name__ == 'Module' — parse returns a Module node"
  category: parse
  kind: python_call_eq
  function: parse
  args: ["1+2"]
  method: __class__.__name__.__eq__
  method_args: ["Module"]
  expected: true
