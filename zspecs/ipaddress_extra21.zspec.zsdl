spec: ipaddress_extra21
version: ">=3.9"
backend: python_module(ipaddress)

docs: https://docs.python.org/3/library/ipaddress.html
rfcs:
  - "RFC 791 — Internet Protocol (IPv4)"
  - "RFC 2460 — Internet Protocol, Version 6 (IPv6)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ipaddress.html — Python ipaddress module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ipaddress.py"
    - "ipaddress_extra5.zspec.zsdl — covers __qualname__.__eq__ for IPv4Address/IPv6Address/IPv4Network/IPv6Network/IPv4Interface/IPv6Interface and ip_address/ip_network/ip_interface factories."
    - "ipaddress_extra16.zspec.zsdl — covers __qualname__.__len__() for IPv4Address/IPv6Address/IPv4Network/IPv6Network."
    - "ipaddress_extra17.zspec.zsdl — covers __name__.__eq__ for utility functions; module __name__ and __package__."
    - "ipaddress_extra20.zspec.zsdl — covers IPv6Address/IPv6Network dunder method qualnames; AddressValueError/NetmaskValueError qualnames."
  notes:
    - "This spec extends the ipaddress chain through ipaddress_extra20; it does NOT duplicate invariants in any prior spec."
    - "Focus: __module__ for IPv4Address/IPv6Address/IPv4Network/IPv6Network; __qualname__ and __module__ for ip_address/ip_network/ip_interface factory functions; __qualname__ for IPv4Interface/IPv6Interface classes; __qualname__ string lengths for ip_address/ip_network/ip_interface and IPv4Interface/IPv6Interface."
    - "ipaddress.IPv4Address.__module__ == 'ipaddress' — no prior ipaddress spec checks __module__ on any address or network class."
    - "ipaddress.IPv6Address.__module__ == 'ipaddress' — same as IPv4Address."
    - "ipaddress.IPv4Network.__module__ == 'ipaddress' — same as address classes."
    - "ipaddress.IPv6Network.__module__ == 'ipaddress' — same as address classes."
    - "ipaddress.ip_address.__qualname__ == 'ip_address' — ipaddress_extra5 covers __qualname__.__eq__ for ip_address in a table; ipaddress_extra17 covers __name__.__eq__ (not __qualname__.__eq__). A standalone invariant from extra21 provides a cross-namespace checkpoint."
    - "ipaddress.ip_address.__module__ == 'ipaddress' — no prior spec checks __module__ on any factory function."
    - "ipaddress.ip_network.__qualname__ == 'ip_network' — same rationale as ip_address."
    - "ipaddress.ip_network.__module__ == 'ipaddress' — same as ip_address."
    - "ipaddress.ip_interface.__qualname__ == 'ip_interface' — same rationale."
    - "ipaddress.ip_interface.__module__ == 'ipaddress' — same as ip_address."
    - "ipaddress.IPv4Interface.__qualname__ == 'IPv4Interface' — ipaddress_extra5 covers this in a table; standalone from extra21 adds cross-namespace checkpoint."
    - "ipaddress.IPv6Interface.__qualname__ == 'IPv6Interface' — same rationale."
    - "ip_address/ip_network qualname length == 10; ip_interface length == 12; IPv4Interface/IPv6Interface length == 13. No prior spec checks these lengths."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# IPv4Address, IPv6Address, IPv4Network, IPv6Network __module__
#
# No prior ipaddress spec checks __module__ on any address or network class.
# All four are defined in the top-level 'ipaddress' module.
# ---------------------------------------------------------------------------

table ipaddress_extra21.address_network_modules:
  description: "__module__ == 'ipaddress' for address and network classes — no prior spec checks class __module__"
  kind: python_call_eq
  category: class_modules
  id_prefix: anmod21

  columns: [id, function, args, expected]
  rows:
    - [IPv4Address, IPv4Address.__module__.__eq__, ["ipaddress"], true]
    - [IPv6Address, IPv6Address.__module__.__eq__, ["ipaddress"], true]
    - [IPv4Network, IPv4Network.__module__.__eq__, ["ipaddress"], true]
    - [IPv6Network, IPv6Network.__module__.__eq__, ["ipaddress"], true]

# ---------------------------------------------------------------------------
# ip_address, ip_network, ip_interface factory __qualname__ standalone
#
# ipaddress_extra5 covers __qualname__.__eq__ for all three in a table.
# No prior spec checks them as standalone invariants (cross-namespace
# regression checkpoints following the pattern used in extra20 for
# AddressValueError/NetmaskValueError).
# ---------------------------------------------------------------------------

invariant ipaddress_extra21.ip_address.qualname:
  description: "ipaddress.ip_address.__qualname__ == 'ip_address' — standalone from extra21 namespace"
  category: function_qualnames
  kind: python_call_eq
  function: ip_address.__qualname__.__eq__
  args: ["ip_address"]
  expected: true

invariant ipaddress_extra21.ip_network.qualname:
  description: "ipaddress.ip_network.__qualname__ == 'ip_network' — standalone from extra21 namespace"
  category: function_qualnames
  kind: python_call_eq
  function: ip_network.__qualname__.__eq__
  args: ["ip_network"]
  expected: true

invariant ipaddress_extra21.ip_interface.qualname:
  description: "ipaddress.ip_interface.__qualname__ == 'ip_interface' — standalone from extra21 namespace"
  category: function_qualnames
  kind: python_call_eq
  function: ip_interface.__qualname__.__eq__
  args: ["ip_interface"]
  expected: true

# ---------------------------------------------------------------------------
# ip_address, ip_network, ip_interface factory __module__
#
# No prior ipaddress spec checks __module__ on any factory function. All
# three are defined in the top-level 'ipaddress' module.
# ---------------------------------------------------------------------------

table ipaddress_extra21.factory_modules:
  description: "ip_address/ip_network/ip_interface __module__ == 'ipaddress' — no prior spec checks factory __module__"
  kind: python_call_eq
  category: function_modules
  id_prefix: factmod21

  columns: [id, function, args, expected]
  rows:
    - [ip_address,   ip_address.__module__.__eq__,   ["ipaddress"], true]
    - [ip_network,   ip_network.__module__.__eq__,   ["ipaddress"], true]
    - [ip_interface, ip_interface.__module__.__eq__, ["ipaddress"], true]

# ---------------------------------------------------------------------------
# IPv4Interface and IPv6Interface __qualname__ standalone
#
# ipaddress_extra5 covers IPv4Interface/IPv6Interface __qualname__ in a table.
# Standalone invariants from extra21 add cross-namespace regression checkpoints.
# ---------------------------------------------------------------------------

invariant ipaddress_extra21.IPv4Interface.qualname:
  description: "ipaddress.IPv4Interface.__qualname__ == 'IPv4Interface' — standalone from extra21 namespace"
  category: class_qualnames
  kind: python_call_eq
  function: IPv4Interface.__qualname__.__eq__
  args: ["IPv4Interface"]
  expected: true

invariant ipaddress_extra21.IPv6Interface.qualname:
  description: "ipaddress.IPv6Interface.__qualname__ == 'IPv6Interface' — standalone from extra21 namespace"
  category: class_qualnames
  kind: python_call_eq
  function: IPv6Interface.__qualname__.__eq__
  args: ["IPv6Interface"]
  expected: true

# ---------------------------------------------------------------------------
# Factory and Interface class __qualname__ string lengths
#
# No prior ipaddress spec checks the string lengths of ip_address,
# ip_network, ip_interface, IPv4Interface, or IPv6Interface qualnames.
# ip_address and ip_network are both 10 chars; ip_interface is 12;
# IPv4Interface and IPv6Interface are both 13.
# ---------------------------------------------------------------------------

table ipaddress_extra21.qualname_lengths:
  description: "ip_address/ip_network/ip_interface/IPv4Interface/IPv6Interface __qualname__ string lengths — no prior spec checks these"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: qnlen21

  columns: [id, function, args, expected]
  rows:
    - [ip_address,    ip_address.__qualname__.__len__,    [], 10]
    - [ip_network,    ip_network.__qualname__.__len__,    [], 10]
    - [ip_interface,  ip_interface.__qualname__.__len__,  [], 12]
    - [IPv4Interface, IPv4Interface.__qualname__.__len__, [], 13]
    - [IPv6Interface, IPv6Interface.__qualname__.__len__, [], 13]
