spec: threading_extra10
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading.zspec.zsdl and threading_extra through threading_extra9."
    - "threading_extra4 covers: Thread/__bases__[0].__name__=='object'; Semaphore/__bases__[0].__name__=='object'; BoundedSemaphore/__bases__[0].__name__=='Semaphore'; Event/__bases__[0].__name__=='object'; Timer/__bases__[0].__name__=='Thread'."
    - "threading_extra5 covers: __module__ for all major classes and functions; TIMEOUT_MAX type."
    - "threading_extra9 covers: __qualname__ for settrace/setprofile/stack_size/enumerate; get_ident __name__/__module__/__qualname__; excepthook/__qualname__."
    - "This spec adds: Barrier/__bases__[0].__name__ (not in extra4); Condition/__bases__[0].__name__ (not in extra4); RLock/__bases__[0].__name__ (not in extra4); local/__bases__[0].__name__ (not in extra4); settrace/__module__, setprofile/__module__, stack_size/__module__, enumerate/__module__ (function modules not in prior specs); BrokenBarrierError/__module__ (not in extra3 which only covers __name__, __bases__, __mro__)."
    - "threading.Barrier.__bases__[0].__name__ == 'object' — Barrier inherits directly from object."
    - "threading.Condition.__bases__[0].__name__ == 'object' — Condition inherits directly from object."
    - "threading.RLock.__bases__[0].__name__ == 'object' — RLock inherits directly from object."
    - "threading.local.__bases__[0].__name__ == 'object' — local inherits directly from object."
    - "threading.settrace.__module__ == 'threading' — defined in threading.py."
    - "threading.setprofile.__module__ == 'threading' — defined in threading.py."
    - "threading.stack_size.__module__ == 'threading' — defined in threading.py."
    - "threading.enumerate.__module__ == 'threading' — defined in threading.py."
    - "threading.BrokenBarrierError.__module__ == 'threading' — exception class defined in threading.py."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class hierarchy — __bases__[0].__name__ for classes not covered in extra4
#
# threading_extra4 covers Thread, Semaphore, BoundedSemaphore, Event, Timer.
# This spec adds Barrier, Condition, RLock, and local — none of which had
# their __bases__[0].__name__ checked in any prior threading spec.
# ---------------------------------------------------------------------------

invariant threading_extra10.Barrier.base:
  description: "threading.Barrier.__bases__[0].__name__ == 'object' — inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Barrier.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant threading_extra10.Condition.base:
  description: "threading.Condition.__bases__[0].__name__ == 'object' — inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Condition.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant threading_extra10.RLock.base:
  description: "threading.RLock.__bases__[0].__name__ == 'object' — inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: RLock.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant threading_extra10.local.base:
  description: "threading.local.__bases__[0].__name__ == 'object' — inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: local.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Function __module__ checks — settrace, setprofile, stack_size, enumerate
#
# threading_extra5 covers __module__ for current_thread/main_thread/active_count/
# excepthook and all class primitives. threading_extra9 covers __qualname__ for
# settrace/setprofile/stack_size/enumerate. No prior spec checks __module__ for
# these four functions.
# ---------------------------------------------------------------------------

table threading_extra10.function_modules:
  description: "threading module functions have correct __module__"
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [settrace,   settrace.__module__.__eq__,   ["threading"], true]
    - [setprofile, setprofile.__module__.__eq__, ["threading"], true]
    - [stack_size, stack_size.__module__.__eq__, ["threading"], true]
    - [enumerate,  enumerate.__module__.__eq__,  ["threading"], true]

# ---------------------------------------------------------------------------
# BrokenBarrierError — __module__
#
# threading_extra3.zspec.zsdl covers BrokenBarrierError.__name__, __bases__,
# and __mro__. No prior spec checks BrokenBarrierError.__module__.
# ---------------------------------------------------------------------------

invariant threading_extra10.BrokenBarrierError.module:
  description: "threading.BrokenBarrierError.__module__ == 'threading'"
  category: exception_modules
  kind: python_call_eq
  function: BrokenBarrierError.__module__.__eq__
  args: ["threading"]
  expected: true

# ---------------------------------------------------------------------------
# BrokenBarrierError — __qualname__
#
# threading_extra3 covers __name__ and __bases__ for BrokenBarrierError.
# No prior spec checks __qualname__ for BrokenBarrierError.
# ---------------------------------------------------------------------------

invariant threading_extra10.BrokenBarrierError.qualname:
  description: "threading.BrokenBarrierError.__qualname__ == 'BrokenBarrierError'"
  category: exception_qualnames
  kind: python_call_eq
  function: BrokenBarrierError.__qualname__.__eq__
  args: ["BrokenBarrierError"]
  expected: true
