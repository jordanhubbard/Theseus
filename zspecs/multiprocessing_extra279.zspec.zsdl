spec: multiprocessing_extra279
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing.Process class"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "multiprocessing.Process.__module__ is 'multiprocessing.process'"
    - "multiprocessing.Process.__bases__[0].__name__ is 'object'"
    - "All method qualnames follow 'Process.<method>' pattern"
    - "pid, name, daemon, exitcode, authkey, sentinel, ident are all property descriptors"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table multiprocessing_extra279.process_method_qualnames:
  description: "multiprocessing.Process method __qualname__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: mp279m

  columns: [id, function, args, expected, description]
  rows:
    - [mp279m_001, multiprocessing.Process.start.__qualname__.__eq__, ["Process.start"], true, "start qualname is 'Process.start'"]
    - [mp279m_002, multiprocessing.Process.run.__qualname__.__eq__, ["Process.run"], true, "run qualname is 'Process.run'"]
    - [mp279m_003, multiprocessing.Process.join.__qualname__.__eq__, ["Process.join"], true, "join qualname is 'Process.join'"]
    - [mp279m_004, multiprocessing.Process.is_alive.__qualname__.__eq__, ["Process.is_alive"], true, "is_alive qualname is 'Process.is_alive'"]
    - [mp279m_005, multiprocessing.Process.terminate.__qualname__.__eq__, ["Process.terminate"], true, "terminate qualname is 'Process.terminate'"]
    - [mp279m_006, multiprocessing.Process.kill.__qualname__.__eq__, ["Process.kill"], true, "kill qualname is 'Process.kill'"]
    - [mp279m_007, multiprocessing.Process.close.__qualname__.__eq__, ["Process.close"], true, "close qualname is 'Process.close'"]

table multiprocessing_extra279.process_property_types:
  description: "multiprocessing.Process property descriptor class name checks"
  kind: python_call_eq
  category: identity
  id_prefix: mp279p

  columns: [id, function, args, expected, description]
  rows:
    - [mp279p_001, multiprocessing.Process.pid.__class__.__name__.__eq__, ["property"], true, "pid is a property"]
    - [mp279p_002, multiprocessing.Process.name.__class__.__name__.__eq__, ["property"], true, "name is a property"]
    - [mp279p_003, multiprocessing.Process.daemon.__class__.__name__.__eq__, ["property"], true, "daemon is a property"]
    - [mp279p_004, multiprocessing.Process.exitcode.__class__.__name__.__eq__, ["property"], true, "exitcode is a property"]
    - [mp279p_005, multiprocessing.Process.authkey.__class__.__name__.__eq__, ["property"], true, "authkey is a property"]
    - [mp279p_006, multiprocessing.Process.sentinel.__class__.__name__.__eq__, ["property"], true, "sentinel is a property"]
    - [mp279p_007, multiprocessing.Process.ident.__class__.__name__.__eq__, ["property"], true, "ident is a property"]

invariant multiprocessing_extra279.process_name:
  description: "multiprocessing.Process.__name__ is 'Process'"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Process.__name__.__eq__
  args: ["Process"]
  expected: true

invariant multiprocessing_extra279.process_module:
  description: "multiprocessing.Process.__module__ is 'multiprocessing.process'"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Process.__module__.__eq__
  args: ["multiprocessing.process"]
  expected: true

invariant multiprocessing_extra279.process_base_is_object:
  description: "multiprocessing.Process.__bases__[0].__name__ is 'object'"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Process.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true
