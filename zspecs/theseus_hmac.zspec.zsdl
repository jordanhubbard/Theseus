spec: theseus_hmac
version: ">=3.9"
backend: python_cleanroom(theseus_hmac)
blocks: hmac

docs: https://www.rfc-editor.org/rfc/rfc2104

provenance:
  derived_from:
    - "https://www.rfc-editor.org/rfc/rfc2104 — HMAC RFC"
  notes:
    - "Clean-room HMAC-SHA256. Do NOT import hmac or hashlib."
    - "May import theseus_hashlib from the Theseus registry for SHA-256."
    - "HMAC(key, message, digestmod) = H((key XOR opad) || H((key XOR ipad) || message))."
    - "ipad = 0x36 repeated, opad = 0x5C repeated, block size 64 bytes for SHA-256."
    - "hmac_new_result(): HMAC-SHA256(b'key', b'message') returns 32-byte hex digest."
    - "hmac_compare_digest_equal(): compare_digest(a, a) == True."
    - "hmac_compare_digest_unequal(): compare_digest(a, b) == False when a != b."
    - "Export: new(key, msg, digestmod) -> HMAC object with hexdigest() method, compare_digest(a, b)."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_hmac.new_result:
  description: "HMAC-SHA256(b'key', b'message') returns 64-char hex string"
  category: hmac
  kind: python_call_eq
  function: hmac_new_result
  args: []
  expected: true

invariant theseus_hmac.compare_equal:
  description: "compare_digest(a, a) == True"
  category: compare
  kind: python_call_eq
  function: hmac_compare_digest_equal
  args: []
  expected: true

invariant theseus_hmac.compare_unequal:
  description: "compare_digest(a, b) == False when a != b"
  category: compare
  kind: python_call_eq
  function: hmac_compare_digest_unequal
  args: []
  expected: false
