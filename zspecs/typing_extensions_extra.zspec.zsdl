spec: typing_extensions_extra
version: ">=4.0"
backend: python_module(typing_extensions)

docs: https://typing-extensions.readthedocs.io/en/latest/

provenance:
  derived_from:
    - "typing-extensions documentation — https://typing-extensions.readthedocs.io/en/latest/"
    - "PEP 612 — Parameter Specification Variables"
    - "PEP 646 — Variadic Generics"
    - "PEP 673 — Self Type"
    - "PEP 675 — Arbitrary Literal String Type"
    - "PEP 702 — Marking deprecations using the type system"
    - "Test vectors verified with typing_extensions 4.15.0 on Python 3.14 / macOS Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "typing_extensions source: typing_extensions.py"
  notes:
    - "typing_extensions.zspec covers: get_args/__name__; get_origin/__name__; get_type_hints/__name__; reveal_type(int/str); assert_never/__name__; get_overloads/__name__; Literal/TypedDict/Protocol/Final/Annotated class names; version smoke test."
    - "NEW axes in this spec: __qualname__ for get_args/get_origin/get_type_hints/assert_never/get_overloads; __name__ for dataclass_transform/override/is_typeddict/deprecated; class names for dataclass_transform and override; reveal_type with bool and None; assert_type name and qualname."
    - "get_args.__qualname__ == 'get_args' — top-level function; qualname equals name."
    - "get_origin.__qualname__ == 'get_origin' — top-level function."
    - "get_type_hints.__qualname__ == 'get_type_hints' — top-level function."
    - "assert_never.__qualname__ == 'assert_never' — top-level function."
    - "get_overloads.__qualname__ == 'get_overloads' — top-level function."
    - "dataclass_transform.__name__ == 'dataclass_transform' — decorator helper."
    - "override.__name__ == 'override' — decorator for method override marking."
    - "is_typeddict.__name__ == 'is_typeddict' — runtime predicate."
    - "deprecated.__name__ == 'deprecated' — deprecation decorator."
    - "reveal_type(True) == True — returns bool unchanged at runtime."
    - "reveal_type(None) is None — returns None unchanged at runtime."
    - "assert_type.__name__ == 'assert_type' — no-op at runtime; returns value."
    - "assert_type.__qualname__ == 'assert_type' — top-level function."
    - "All expected values verified with typing_extensions 4.15.0 on Python 3.14.3, macOS/Darwin 25.4.0."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for introspection functions
#
# typing_extensions.zspec covers __name__ for get_args, get_origin,
# get_type_hints. No prior spec checks __qualname__ for any of these.
# For top-level functions, qualname equals name.
# ---------------------------------------------------------------------------

table typing_extensions_extra.introspection_qualnames:
  kind: python_call_eq
  category: introspection
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [get_args,        get_args.__qualname__.__eq__,        ["get_args"],        true]
    - [get_origin,      get_origin.__qualname__.__eq__,      ["get_origin"],      true]
    - [get_type_hints,  get_type_hints.__qualname__.__eq__,  ["get_type_hints"],  true]

# ---------------------------------------------------------------------------
# __qualname__ for runtime helpers
#
# typing_extensions.zspec covers __name__ for assert_never and get_overloads.
# No prior spec checks __qualname__ for these. For top-level functions,
# qualname equals name.
# ---------------------------------------------------------------------------

table typing_extensions_extra.runtime_helper_qualnames:
  kind: python_call_eq
  category: runtime_helpers
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [assert_never,  assert_never.__qualname__.__eq__,  ["assert_never"],  true]
    - [get_overloads, get_overloads.__qualname__.__eq__, ["get_overloads"], true]

# ---------------------------------------------------------------------------
# dataclass_transform — name check
#
# typing_extensions.zspec does not test dataclass_transform at all.
# dataclass_transform is a decorator factory introduced in PEP 681 /
# typing_extensions 4.1. Its __name__ should be 'dataclass_transform'.
# ---------------------------------------------------------------------------

invariant typing_extensions_extra.dataclass_transform.name:
  description: "dataclass_transform.__name__ == 'dataclass_transform' — decorator factory is correctly bound"
  category: decorator_names
  kind: python_call_eq
  function: dataclass_transform.__name__.__eq__
  args: ["dataclass_transform"]
  expected: true

invariant typing_extensions_extra.dataclass_transform.qualname:
  description: "dataclass_transform.__qualname__ == 'dataclass_transform' — top-level function"
  category: decorator_names
  kind: python_call_eq
  function: dataclass_transform.__qualname__.__eq__
  args: ["dataclass_transform"]
  expected: true

# ---------------------------------------------------------------------------
# override — name check
#
# typing_extensions.zspec does not test override at all.
# override is a decorator introduced in PEP 698 / Python 3.12 backported
# via typing_extensions. Its __name__ should be 'override'.
# ---------------------------------------------------------------------------

invariant typing_extensions_extra.override.name:
  description: "override.__name__ == 'override' — method-override decorator is correctly bound"
  category: decorator_names
  kind: python_call_eq
  function: override.__name__.__eq__
  args: ["override"]
  expected: true

invariant typing_extensions_extra.override.qualname:
  description: "override.__qualname__ == 'override' — top-level function; qualname equals name"
  category: decorator_names
  kind: python_call_eq
  function: override.__qualname__.__eq__
  args: ["override"]
  expected: true

# ---------------------------------------------------------------------------
# is_typeddict — name and qualname
#
# typing_extensions.zspec does not test is_typeddict at all.
# is_typeddict is a runtime predicate that returns True if its argument
# is a TypedDict class.
# ---------------------------------------------------------------------------

invariant typing_extensions_extra.is_typeddict.name:
  description: "is_typeddict.__name__ == 'is_typeddict' — runtime predicate is correctly bound"
  category: predicate_names
  kind: python_call_eq
  function: is_typeddict.__name__.__eq__
  args: ["is_typeddict"]
  expected: true

invariant typing_extensions_extra.is_typeddict.qualname:
  description: "is_typeddict.__qualname__ == 'is_typeddict' — top-level function"
  category: predicate_names
  kind: python_call_eq
  function: is_typeddict.__qualname__.__eq__
  args: ["is_typeddict"]
  expected: true

# ---------------------------------------------------------------------------
# assert_type — name and qualname
#
# typing_extensions.zspec does not test assert_type at all.
# assert_type(x, T) is a no-op at runtime that returns its first argument.
# It is a static-analysis-only check (PEP 702 / typing_extensions).
# ---------------------------------------------------------------------------

invariant typing_extensions_extra.assert_type.name:
  description: "assert_type.__name__ == 'assert_type' — static noop is correctly bound"
  category: runtime_helpers
  kind: python_call_eq
  function: assert_type.__name__.__eq__
  args: ["assert_type"]
  expected: true

invariant typing_extensions_extra.assert_type.qualname:
  description: "assert_type.__qualname__ == 'assert_type' — top-level function"
  category: runtime_helpers
  kind: python_call_eq
  function: assert_type.__qualname__.__eq__
  args: ["assert_type"]
  expected: true

# ---------------------------------------------------------------------------
# reveal_type with bool and None
#
# typing_extensions.zspec covers reveal_type(42) == 42 and reveal_type('hello').
# New here: reveal_type with bool True and NoneType None — confirming the
# identity return also works for falsy-ish and None values.
# ---------------------------------------------------------------------------

invariant typing_extensions_extra.reveal_type.bool_true:
  description: "reveal_type(True) == True — returns bool True unchanged at runtime"
  category: runtime_helpers
  kind: python_call_eq
  function: reveal_type
  args: [true]
  expected: true

invariant typing_extensions_extra.reveal_type.none:
  description: "reveal_type(None) is None — returns None unchanged at runtime"
  category: runtime_helpers
  kind: python_call_eq
  function: reveal_type
  args: [~]
  expected: ~
