spec: abc_extra1936
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/abc.html"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "Wave 576 (_extra1936): __get__/__set__/__delete__ descriptor protocol, __set_name__, __class__ checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "abc.ABCMeta and abc.ABC do not define __get__, __set__, __delete__, or __set_name__ in their own __dict__."
    - "abc.abstractmethod is a function (not a class); its __class__.__name__ == 'function'. Its instance __dict__ is empty; __get__ is not present."
    - "abc.abstractclassmethod inherits from classmethod (which has __get__) but does not define __get__ in its own __dict__."
    - "abc.abstractstaticmethod inherits from staticmethod (which has __get__) but does not define __get__ in its own __dict__."
    - "abc.abstractproperty inherits from property (which has __get__, __set__, __delete__) but defines none of these in its own __dict__."
    - "abc.ABC.__class__.__name__ == 'ABCMeta' because ABC is an instance of ABCMeta metaclass."
    - "abc.ABCMeta.__class__.__name__ == 'type' (ABCMeta's metaclass is type)."
    - "abc.abstractmethod.__class__.__name__ == 'function' (it is a plain function, not a class)."
  created_at: "2026-04-12"
error_model: python_exceptions

table abc_extra1936.descriptor_get:
  description: "abc types __get__ dict-presence checks — none define __get__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1936

  columns: [id, function, args, expected]
  rows:
    - ["ab1936001", "abc.ABCMeta.__dict__.__contains__",            ["__get__"], false]
    - ["ab1936002", "abc.ABC.__dict__.__contains__",                ["__get__"], false]
    - ["ab1936003", "abc.abstractclassmethod.__dict__.__contains__", ["__get__"], false]
    - ["ab1936004", "abc.abstractstaticmethod.__dict__.__contains__", ["__get__"], false]
    - ["ab1936005", "abc.abstractproperty.__dict__.__contains__",   ["__get__"], false]

table abc_extra1936.abstractmethod_dict:
  description: "abc.abstractmethod is a function; its instance __dict__ is empty — no __get__, __set__, __delete__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1936

  columns: [id, function, args, expected]
  rows:
    - ["ab1936006", "abc.abstractmethod.__dict__.__contains__", ["__get__"],    false]
    - ["ab1936007", "abc.abstractmethod.__dict__.__contains__", ["__set__"],    false]
    - ["ab1936008", "abc.abstractmethod.__dict__.__contains__", ["__delete__"], false]

