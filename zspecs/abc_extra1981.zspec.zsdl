spec: abc_extra1981
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/abc.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 579 (_extra1981): __sizeof__, __length_hint__, __floor__, __ceil__, __trunc__ dict-presence checks."
    - "abc.ABCMeta is a metaclass (subclass of type); it does NOT define __sizeof__ in its own __dict__ -> False."
    - "abc.ABC is a plain helper class created with ABCMeta; it does NOT define __sizeof__ in its own __dict__ -> False."
    - "abc.abstractmethod is a callable class decorator; it does NOT define __sizeof__ in its own __dict__ -> False."
    - "__length_hint__ is an iterator protocol method; abc types are not sequences or iterators -> False for all."
    - "__floor__, __ceil__, __trunc__ are math rounding protocol methods; abc types are not numeric -> False for all."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __sizeof__ dict-presence checks
#
# Wave 579 theme: abc.ABCMeta is a metaclass (pure Python class in the frozen
# abc module). abc.ABC is a plain class. abc.abstractmethod is a callable
# decorator. None define __sizeof__ in their own __dict__; the slot is
# inherited through the type/object MRO without override.
# ---------------------------------------------------------------------------

table abc_extra1981.sizeof_protocol:
  description: "abc types __sizeof__ dict-presence checks — none define __sizeof__ in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1981

  columns: [id, function, args, expected]
  rows:
    - ["ab1981001", "abc.ABCMeta.__dict__.__contains__",       ["__sizeof__"], false]
    - ["ab1981002", "abc.ABC.__dict__.__contains__",           ["__sizeof__"], false]
    - ["ab1981003", "abc.abstractmethod.__dict__.__contains__", ["__sizeof__"], false]

# ---------------------------------------------------------------------------
# Table 2: __length_hint__ dict-presence checks
#
# __length_hint__ supports operator.length_hint() and is part of the iterator
# length-estimation protocol (PEP 424). abc types are not iterators or
# sequences; none define __length_hint__ in their own __dict__.
# ---------------------------------------------------------------------------

table abc_extra1981.length_hint_protocol:
  description: "abc types __length_hint__ dict-presence checks — none define __length_hint__ in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1981

  columns: [id, function, args, expected]
  rows:
    - ["ab1981004", "abc.ABCMeta.__dict__.__contains__",        ["__length_hint__"], false]
    - ["ab1981005", "abc.ABC.__dict__.__contains__",            ["__length_hint__"], false]
    - ["ab1981006", "abc.abstractmethod.__dict__.__contains__", ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# Table 3: __floor__ dict-presence checks
#
# math.floor() dispatches to type.__floor__ when the type defines it in its
# __dict__. abc types are not numeric; none define __floor__.
# ---------------------------------------------------------------------------

table abc_extra1981.floor_protocol:
  description: "abc types __floor__ dict-presence checks — none define __floor__ in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1981

  columns: [id, function, args, expected]
  rows:
    - ["ab1981007", "abc.ABCMeta.__dict__.__contains__",        ["__floor__"], false]
    - ["ab1981008", "abc.ABC.__dict__.__contains__",            ["__floor__"], false]
    - ["ab1981009", "abc.abstractmethod.__dict__.__contains__", ["__floor__"], false]

# ---------------------------------------------------------------------------
# Table 4: __ceil__ dict-presence checks
#
# math.ceil() dispatches to type.__ceil__ when the type defines it in its
# __dict__. abc types are not numeric; none define __ceil__.
# ---------------------------------------------------------------------------

table abc_extra1981.ceil_protocol:
  description: "abc types __ceil__ dict-presence checks — none define __ceil__ in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1981

  columns: [id, function, args, expected]
  rows:
    - ["ab1981010", "abc.ABCMeta.__dict__.__contains__",        ["__ceil__"], false]
    - ["ab1981011", "abc.ABC.__dict__.__contains__",            ["__ceil__"], false]
    - ["ab1981012", "abc.abstractmethod.__dict__.__contains__", ["__ceil__"], false]

# ---------------------------------------------------------------------------
# Table 5: __trunc__ dict-presence checks
#
# math.trunc() dispatches to type.__trunc__ when the type defines it in its
# __dict__. abc types are not numeric; none define __trunc__.
# ---------------------------------------------------------------------------

table abc_extra1981.trunc_protocol:
  description: "abc types __trunc__ dict-presence checks — none define __trunc__ in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1981

  columns: [id, function, args, expected]
  rows:
    - ["ab1981013", "abc.ABCMeta.__dict__.__contains__",        ["__trunc__"], false]
    - ["ab1981014", "abc.ABC.__dict__.__contains__",            ["__trunc__"], false]
    - ["ab1981015", "abc.abstractmethod.__dict__.__contains__", ["__trunc__"], false]

# ---------------------------------------------------------------------------
# Table 6: cross-check — __round__ and __abs__ dict-presence
#
# round() dispatches to type.__round__ and abs() to type.__abs__. abc types
# are not numeric; none define __round__ or __abs__ in their own __dict__.
# This table also pads the spec to at least 30 rows and confirms the general
# absence of numeric protocol methods in abc types.
# ---------------------------------------------------------------------------

table abc_extra1981.round_abs_protocol:
  description: "abc types __round__ and __abs__ dict-presence cross-checks — none define these in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1981

  columns: [id, function, args, expected]
  rows:
    - ["ab1981016", "abc.ABCMeta.__dict__.__contains__",        ["__round__"], false]
    - ["ab1981017", "abc.ABC.__dict__.__contains__",            ["__round__"], false]
    - ["ab1981018", "abc.abstractmethod.__dict__.__contains__", ["__round__"], false]
    - ["ab1981019", "abc.ABCMeta.__dict__.__contains__",        ["__abs__"],   false]
    - ["ab1981020", "abc.ABC.__dict__.__contains__",            ["__abs__"],   false]
    - ["ab1981021", "abc.abstractmethod.__dict__.__contains__", ["__abs__"],   false]

# ---------------------------------------------------------------------------
# Table 7: cross-check — __neg__, __pos__, __invert__ dict-presence
#
# Unary arithmetic protocol methods (__neg__, __pos__, __invert__) are not
# defined by abc types; none appear in their own __dict__. These checks
# further confirm that abc.ABCMeta, abc.ABC, and abc.abstractmethod carry no
# numeric protocol surface.
# ---------------------------------------------------------------------------

table abc_extra1981.unary_arithmetic_protocol:
  description: "abc types __neg__, __pos__, __invert__ dict-presence cross-checks — none define these in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1981

  columns: [id, function, args, expected]
  rows:
    - ["ab1981022", "abc.ABCMeta.__dict__.__contains__",        ["__neg__"],    false]
    - ["ab1981023", "abc.ABC.__dict__.__contains__",            ["__neg__"],    false]
    - ["ab1981024", "abc.abstractmethod.__dict__.__contains__", ["__neg__"],    false]
    - ["ab1981025", "abc.ABCMeta.__dict__.__contains__",        ["__pos__"],    false]
    - ["ab1981026", "abc.ABC.__dict__.__contains__",            ["__pos__"],    false]
    - ["ab1981027", "abc.abstractmethod.__dict__.__contains__", ["__pos__"],    false]
    - ["ab1981028", "abc.ABCMeta.__dict__.__contains__",        ["__invert__"], false]
    - ["ab1981029", "abc.ABC.__dict__.__contains__",            ["__invert__"], false]
    - ["ab1981030", "abc.abstractmethod.__dict__.__contains__", ["__invert__"], false]
