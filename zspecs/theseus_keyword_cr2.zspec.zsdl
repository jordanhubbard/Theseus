spec: theseus_keyword_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_keyword_cr2)
blocks: keyword

docs: https://docs.python.org/3/library/keyword.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/keyword.html"
    - "https://docs.python.org/3/reference/lexical_analysis.html#keywords"
  notes:
    - "Clean-room extended keyword utilities. Do NOT import keyword."
    - "kwlist: list of all Python hard keywords (if, else, for, while, etc.) — at least 30."
    - "softkwlist: list of soft keywords (match, case, type) introduced in newer Python."
    - "iskeyword(s): return True if s is a hard keyword."
    - "keyword2_softkwlist(): 'match' in softkwlist — returns True."
    - "keyword2_kwlist_count(): len(kwlist) > 30 — returns True."
    - "keyword2_iskeyword_false(): iskeyword('hello') == False."
    - "Zero-arg invariant signatures — def keyword2_softkwlist(): return bool"
    - "Hard keywords include: False, None, True, and, as, assert, async, await, break, class, continue, def, del, elif, else, except, finally, for, from, global, if, import, in, is, lambda, nonlocal, not, or, pass, raise, return, try, while, with, yield."
    - "Soft keywords include: match, case, type (Python 3.10+)."
    - "Export: kwlist, softkwlist, iskeyword(s) -> bool, issoftkeyword(s) -> bool."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_keyword_cr2.softkwlist:
  description: "'match' in softkwlist"
  category: softkwlist
  kind: python_call_eq
  function: keyword2_softkwlist
  args: []
  expected: true

invariant theseus_keyword_cr2.kwlist_count:
  description: "len(kwlist) > 30"
  category: kwlist
  kind: python_call_eq
  function: keyword2_kwlist_count
  args: []
  expected: true

invariant theseus_keyword_cr2.iskeyword_false:
  description: "iskeyword('hello') == False"
  category: iskeyword
  kind: python_call_eq
  function: keyword2_iskeyword_false
  args: []
  expected: false
