spec: pathlib_extra2476
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/pathlib/_local.py"
    - "CPython source: Lib/pathlib/_abc.py"
  notes:
    - "Theme: __contains__ and __getitem__ dict-presence — checking whether pathlib classes define membership test and item access protocol in their class __dict__."
    - "pathlib.PurePath and pathlib.Path are path-manipulation objects — they expose no __contains__ or __getitem__ in their own __dict__."
    - "pathlib.PurePath.__dict__ does NOT contain '__contains__' (False) — PurePath does not support 'x in path'."
    - "pathlib.PurePath.__dict__ does NOT contain '__getitem__' (False) — PurePath does not support subscript access."
    - "pathlib.Path.__dict__ does NOT contain '__contains__' (False)."
    - "pathlib.Path.__dict__ does NOT contain '__getitem__' (False)."
    - "pathlib.PurePath.__dict__ DOES contain '__truediv__', '__str__', '__repr__', '__hash__', '__eq__', '__fspath__' (all True) — path operators and protocol hooks."
    - "pathlib.PurePath.__dict__ DOES contain 'parent', 'name', 'stem', 'suffix', 'parts', 'root', 'anchor', 'suffixes', 'drive' (all True) — path properties."
    - "pathlib.Path.__dict__ DOES contain 'stat', 'open', 'read_text', 'write_text', 'iterdir', 'glob', 'exists', 'is_file', 'is_dir', 'mkdir', 'unlink' (all True) — filesystem methods."
    - "Accessing a missing key via pathlib.PurePath.__dict__.__getitem__ raises KeyError."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath.__dict__.__contains__ — protocol absence
# PurePath is a pure path-manipulation object; it defines no __contains__ or
# __getitem__ in its own __dict__. Path operations use / (truediv), not [].
# ---------------------------------------------------------------------------

table pathlib_extra2476.PurePath_dict_protocol_absence:
  description: "pathlib.PurePath.__dict__ does not contain __contains__ or __getitem__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pp2476

  columns: [id, function, args, expected]
  rows:
    - ["pp2476001", pathlib.PurePath.__dict__.__contains__, ["__contains__"], false]
    - ["pp2476002", pathlib.PurePath.__dict__.__contains__, ["__getitem__"],  false]

# ---------------------------------------------------------------------------
# pathlib.PurePath.__dict__.__contains__ — operator and protocol hooks present
# __truediv__ enables the / operator; __fspath__ enables os.fspath() support.
# These contrast with the absent container-protocol entries.
# ---------------------------------------------------------------------------

table pathlib_extra2476.PurePath_dict_operator_presence:
  description: "pathlib.PurePath.__dict__ contains operator and protocol hooks: __truediv__, __str__, __repr__, __hash__, __eq__, __fspath__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pp2476

  columns: [id, function, args, expected]
  rows:
    - ["pp2476003", pathlib.PurePath.__dict__.__contains__, ["__truediv__"], true]
    - ["pp2476004", pathlib.PurePath.__dict__.__contains__, ["__str__"],     true]
    - ["pp2476005", pathlib.PurePath.__dict__.__contains__, ["__repr__"],    true]
    - ["pp2476006", pathlib.PurePath.__dict__.__contains__, ["__hash__"],    true]
    - ["pp2476007", pathlib.PurePath.__dict__.__contains__, ["__eq__"],      true]
    - ["pp2476008", pathlib.PurePath.__dict__.__contains__, ["__fspath__"],  true]

# ---------------------------------------------------------------------------
# pathlib.PurePath.__dict__.__contains__ — path properties present
# parent, name, stem, suffix, parts, root, anchor, suffixes, drive are all
# property descriptors defined directly on PurePath.
# ---------------------------------------------------------------------------

table pathlib_extra2476.PurePath_dict_property_presence:
  description: "pathlib.PurePath.__dict__ contains path properties: parent, name, stem, suffix, parts, root, anchor, suffixes, drive"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pp2476

  columns: [id, function, args, expected]
  rows:
    - ["pp2476009", pathlib.PurePath.__dict__.__contains__, ["parent"],   true]
    - ["pp2476010", pathlib.PurePath.__dict__.__contains__, ["name"],     true]
    - ["pp2476011", pathlib.PurePath.__dict__.__contains__, ["stem"],     true]
    - ["pp2476012", pathlib.PurePath.__dict__.__contains__, ["suffix"],   true]
    - ["pp2476013", pathlib.PurePath.__dict__.__contains__, ["parts"],    true]
    - ["pp2476014", pathlib.PurePath.__dict__.__contains__, ["root"],     true]
    - ["pp2476015", pathlib.PurePath.__dict__.__contains__, ["anchor"],   true]
    - ["pp2476016", pathlib.PurePath.__dict__.__contains__, ["suffixes"], true]
    - ["pp2476017", pathlib.PurePath.__dict__.__contains__, ["drive"],    true]

# ---------------------------------------------------------------------------
# pathlib.PurePath.__dict__.__getitem__ — KeyError for missing keys
# Confirms that accessing an absent key via __getitem__ raises KeyError,
# consistent with mappingproxy semantics.
# ---------------------------------------------------------------------------

table pathlib_extra2476.PurePath_dict_getitem_missing:
  description: "pathlib.PurePath.__dict__.__getitem__ raises KeyError for absent keys"
  kind: python_call_raises
  category: dict_membership
  id_prefix: pp2476

  columns: [id, function, args, expected]
  rows:
    - ["pp2476018", pathlib.PurePath.__dict__.__getitem__, ["__contains__"], KeyError]
    - ["pp2476019", pathlib.PurePath.__dict__.__getitem__, ["__getitem__"],  KeyError]

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__.__contains__ — protocol absence and filesystem method presence
# Path extends PurePath with filesystem operations but still defines no
# __contains__ or __getitem__ in its own class __dict__.
# ---------------------------------------------------------------------------

