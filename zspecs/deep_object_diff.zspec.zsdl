spec: deep_object_diff
version: ">=1.1.9"
backend: node(deep-object-diff)

docs: https://www.npmjs.com/package/deep-object-diff

provenance:
  derived_from:
    - "deep-object-diff README — https://www.npmjs.com/package/deep-object-diff"
    - "Test vectors verified with deep-object-diff via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "deep-object-diff source"
  notes:
    - "deep-object-diff is an npm package. Install: npm install deep-object-diff"
    - "diff(a, b) returns only the properties that changed (with their new values)."
    - "addedDiff(a, b) returns only properties added in b."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a partial object containing only changed/added properties."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table deep_object_diff.diff:
  kind: node_module_call_eq
  function: diff
  category: diff
  id_prefix: doddiff

  columns: [id, args, expected]
  rows:
    - [changed_val, [{"a": 1, "b": 2}, {"a": 1, "b": 3}], {"b": 3}]
    - [no_change,   [{"a": 1}, {"a": 1}],                  {}]

table deep_object_diff.addedDiff:
  kind: node_module_call_eq
  function: addedDiff
  category: diff
  id_prefix: dodadd

  columns: [id, args, expected]
  rows:
    - [new_key,  [{"a": 1}, {"a": 1, "b": 2}], {"b": 2}]
    - [no_add,   [{"a": 1}, {"a": 2}],          {}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:08:08Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
