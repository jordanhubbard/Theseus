spec: struct_extra69
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra68.zspec.zsdl — covers Struct.size/format/__class__/__name__=='getset_descriptor' / Struct.__doc__/__class__/__name__=='str' / Struct.__name__/__module__/__qualname__ / pack/unpack/calcsize/__qualname__ (table + invariants)."
    - "struct_extra67.zspec.zsdl — covers pack/unpack/calcsize/pack_into/unpack_from/iter_unpack/__class__/__name__=='builtin_function_or_method' / error/__name__=='error' / error/__module__=='struct' / error/__bases__[0].__name__=='Exception' / error/__mro__.__len__()==4 (table + invariants)."
    - "struct_extra66.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __class__/__name__=='method_descriptor' / __qualname__ eq and len (table + invariants)."
    - "struct_extra65.zspec.zsdl — covers Struct.__dict__.__class__.__name__=='mappingproxy' / Struct.__dict__.__contains__ pack/unpack/pack_into/unpack_from/iter_unpack/size/format (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra68; it does NOT duplicate invariants present in those files."
    - "Wave 240 theme: struct.Struct method qualname lengths + error exception code attributes."
    - "struct.Struct.pack.__qualname__.__len__() == 11 — 'Struct.pack' is 11 chars (S-t-r-u-c-t-.-p-a-c-k). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__qualname__.__len__() == 13 — 'Struct.unpack' is 13 chars. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__qualname__.__len__() == 16 — 'Struct.pack_into' is 16 chars. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__qualname__.__len__() == 18 — 'Struct.unpack_from' is 18 chars. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__qualname__.__len__() == 18 — 'Struct.iter_unpack' is 18 chars. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__qualname__ == 'error' — struct.error has simple qualname 'error'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__doc__.__class__.__name__ == 'NoneType' — struct.error has no docstring (doc is None). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('__sizeof__') == True — Struct defines __sizeof__ in its class __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__qualname__ == 'Struct.size' — Struct.size is a getset_descriptor with qualname 'Struct.size'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.pack / unpack __qualname__.__len__()
#
# Wave 240 theme: Struct method qualname lengths.
#
# struct.Struct.pack.__qualname__ is 'Struct.pack' (11 chars).
# struct.Struct.unpack.__qualname__ is 'Struct.unpack' (13 chars).
# struct_extra66 covers Struct.pack.__qualname__ == 'Struct.pack'. No prior
# struct spec checks __qualname__.__len__() for pack or unpack.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra69.Struct_method_qualname_len_pack_unpack:
  description: "struct.Struct.pack/__qualname__.__len__()==11 / Struct.unpack/__qualname__.__len__()==13 — 'Struct.pack' is 11 chars; 'Struct.unpack' is 13 chars; struct_extra66 covers qualname equality for pack/unpack; no prior struct spec checks qualname.__len__() for pack or unpack; first qualname length anchor for pack and unpack"
  kind: python_call_eq
  category: qualnames
  id_prefix: structmore69

  columns: [id, function, args, expected]
  rows:
    - [Struct_pack_qualname_len_11,   Struct.pack.__qualname__.__len__,   [], 11]
    - [Struct_unpack_qualname_len_13, Struct.unpack.__qualname__.__len__, [], 13]

# ---------------------------------------------------------------------------
# struct.Struct.pack_into / unpack_from / iter_unpack __qualname__.__len__()
#
# Wave 240 theme: Struct method qualname lengths (pack_into, unpack_from, iter_unpack).
#
# struct.Struct.pack_into.__qualname__ is 'Struct.pack_into' (16 chars).
# struct.Struct.unpack_from.__qualname__ is 'Struct.unpack_from' (18 chars).
# struct.Struct.iter_unpack.__qualname__ is 'Struct.iter_unpack' (18 chars).
# struct_extra66 covers qualname equality for these methods. No prior struct
# spec checks qualname.__len__() for pack_into, unpack_from, or iter_unpack.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra69.Struct_method_qualname_len_pack_into_unpack_from_iter:
  description: "struct.Struct.pack_into/__qualname__.__len__()==16 / Struct.unpack_from/__qualname__.__len__()==18 / Struct.iter_unpack/__qualname__.__len__()==18 — 'Struct.pack_into' is 16 chars; 'Struct.unpack_from' is 18 chars; 'Struct.iter_unpack' is 18 chars; struct_extra66 covers qualname equality; no prior struct spec checks qualname.__len__() for these three methods; first qualname length anchor for pack_into/unpack_from/iter_unpack"
  kind: python_call_eq
  category: qualnames
  id_prefix: structmore69

  columns: [id, function, args, expected]
  rows:
    - [Struct_pack_into_qualname_len_16,   Struct.pack_into.__qualname__.__len__,   [], 16]
    - [Struct_unpack_from_qualname_len_18, Struct.unpack_from.__qualname__.__len__, [], 18]
    - [Struct_iter_unpack_qualname_len_18, Struct.iter_unpack.__qualname__.__len__, [], 18]

# ---------------------------------------------------------------------------
# struct.error __qualname__ and __doc__.__class__.__name__
#
# Wave 240 theme: struct.error exception identity attributes.
#
# struct.error has simple qualname 'error' (not 'struct.error'). Its __doc__
# is None, so __doc__.__class__.__name__ is 'NoneType'. struct_extra67 covers
# error.__name__, __module__, __bases__[0], and __mro__.__len__().
# No prior struct spec checks error.__qualname__ or error.__doc__.__class__.__name__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra69.error_qualname_doc:
  description: "struct.error/__qualname__.__eq__('error')==True / error/__doc__/__class__/__name__.__eq__('NoneType')==True — struct.error has simple qualname 'error'; error.__doc__ is None so its class is NoneType; struct_extra67 covers error.__name__/__module__/__bases__; no prior struct spec checks error.__qualname__ or error.__doc__.__class__.__name__; first qualname and doc class anchor for struct.error"
  kind: python_call_eq
  category: class_identity
  id_prefix: structmore69

  columns: [id, function, args, expected]
  rows:
    - [error_qualname_error,        error.__qualname__.__eq__,                ["error"],    true]
    - [error_doc_class_NoneType,    error.__doc__.__class__.__name__.__eq__,  ["NoneType"], true]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('__sizeof__') and Struct.size.__qualname__
#
# Wave 240 theme: Struct __dict__ content and getset_descriptor qualname.
#
# struct.Struct.__dict__ contains '__sizeof__'. struct.Struct.size is a
# getset_descriptor with qualname 'Struct.size'. struct_extra65 covers
# Struct.__dict__.__contains__ for 'size' and 'format'. No prior struct spec
# checks __contains__ for '__sizeof__' or checks Struct.size.__qualname__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra69.Struct_dict_sizeof_and_size_qualname:
  description: "struct.Struct/__dict__.__contains__('__sizeof__')==True / Struct.size/__qualname__.__eq__('Struct.size')==True — Struct.__dict__ contains '__sizeof__'; Struct.size getset_descriptor has qualname 'Struct.size'; struct_extra65 covers Struct.__dict__.__contains__ for size/format; no prior struct spec checks __sizeof__ in Struct.__dict__ or Struct.size.__qualname__; first __sizeof__ dict contains and Struct.size qualname anchor"
  kind: python_call_eq
  category: class_identity
  id_prefix: structmore69

  columns: [id, function, args, expected]
  rows:
    - [Struct_dict_contains_sizeof, Struct.__dict__.__contains__,    ["__sizeof__"], true]
    - [Struct_size_qualname,        Struct.size.__qualname__.__eq__, ["Struct.size"], true]

# ---------------------------------------------------------------------------
# struct.Struct.pack.__qualname__.__len__() == 11 — standalone
#
# struct.Struct.pack.__qualname__ is 'Struct.pack' — 11 characters.
# struct_extra66 covers pack.__qualname__ equality. No prior struct spec checks
# pack.__qualname__.__len__(). First qualname length standalone for pack.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra69.Struct_pack_qualname_len_11:
  description: "struct.Struct.pack.__qualname__.__len__() == 11 — 'Struct.pack' is 11 chars; struct_extra66 covers pack.__qualname__ equality; no prior struct spec checks pack.__qualname__.__len__(); first qualname length standalone for Struct.pack"
  category: qualnames
  kind: python_call_eq
  function: Struct.pack.__qualname__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# struct.Struct.unpack_from.__qualname__.__len__() == 18 — standalone
#
# struct.Struct.unpack_from.__qualname__ is 'Struct.unpack_from' — 18 characters.
# struct_extra66 covers unpack_from.__qualname__ equality. No prior struct spec
# checks unpack_from.__qualname__.__len__(). First qualname length standalone
# for unpack_from. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra69.Struct_unpack_from_qualname_len_18:
  description: "struct.Struct.unpack_from.__qualname__.__len__() == 18 — 'Struct.unpack_from' is 18 chars; struct_extra66 covers unpack_from.__qualname__ equality; no prior struct spec checks unpack_from.__qualname__.__len__(); first qualname length standalone for Struct.unpack_from"
  category: qualnames
  kind: python_call_eq
  function: Struct.unpack_from.__qualname__.__len__
  args: []
  expected: 18

# ---------------------------------------------------------------------------
# struct.error.__qualname__.__eq__('error') — standalone
#
# struct.error has simple qualname 'error'. No prior struct spec checks
# error.__qualname__. First qualname standalone for struct.error.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra69.error_qualname_error:
  description: "struct.error.__qualname__.__eq__('error') == True — struct.error has simple qualname 'error'; no prior struct spec checks error.__qualname__; first qualname standalone for struct.error"
  category: class_identity
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["error"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('__sizeof__') — standalone
#
# struct.Struct.__dict__ contains '__sizeof__'. No prior struct spec checks
# Struct.__dict__.__contains__('__sizeof__'). First __sizeof__ dict contains
# standalone for Struct. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra69.Struct_dict_contains_sizeof:
  description: "struct.Struct.__dict__.__contains__('__sizeof__') == True — Struct defines __sizeof__ in its class __dict__; no prior struct spec checks __contains__ for '__sizeof__'; first __sizeof__ dict contains standalone for Struct"
  category: class_identity
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["__sizeof__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.size.__qualname__.__eq__('Struct.size') — standalone
#
# struct.Struct.size is a getset_descriptor with qualname 'Struct.size'.
# No prior struct spec checks Struct.size.__qualname__. First qualname
# standalone for Struct.size. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra69.Struct_size_qualname:
  description: "struct.Struct.size.__qualname__.__eq__('Struct.size') == True — Struct.size is a getset_descriptor with qualname 'Struct.size'; no prior struct spec checks Struct.size.__qualname__; first qualname standalone for Struct.size"
  category: class_identity
  kind: python_call_eq
  function: Struct.size.__qualname__.__eq__
  args: ["Struct.size"]
  expected: true
