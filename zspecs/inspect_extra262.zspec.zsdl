spec: inspect_extra262
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect.zspec.zsdl — covers isfunction, isbuiltin, isclass, ismodule, isroutine, isgeneratorfunction, iscoroutinefunction, isasyncgenfunction, signature, getmembers, getdoc classname checks"
    - "inspect_extra.zspec.zsdl — covers ismethod, isgenerator, iscoroutine, getsourcefile __name__/__module__; behavioral checks"
    - "inspect_extra261.zspec.zsdl — covers getattr_static, getmro, classify_class_attrs, getdoc, getcomments identity"
  notes:
    - "inspect.ismodule.__name__ == 'ismodule'; __qualname__ == 'ismodule'; __module__ == 'inspect'; __class__.__name__ == 'function'."
    - "inspect.isabstract.__name__ == 'isabstract'; __qualname__ == 'isabstract'; __module__ == 'inspect'; __class__.__name__ == 'function'."
    - "inspect.ismethodwrapper.__name__ == 'ismethodwrapper'; __qualname__ == 'ismethodwrapper'; __module__ == 'inspect'; __class__.__name__ == 'function'."
    - "inspect.isroutine.__name__ == 'isroutine'; __qualname__ == 'isroutine'; __module__ == 'inspect'; __class__.__name__ == 'function'."
    - "inspect.isgenerator.__name__ == 'isgenerator'; __qualname__ == 'isgenerator'; __module__ == 'inspect'; __class__.__name__ == 'function'."
    - "inspect.isgeneratorfunction.__name__ == 'isgeneratorfunction'; __qualname__ == 'isgeneratorfunction'; __module__ == 'inspect'; __class__.__name__ == 'function'."
    - "All six functions are Python-level functions (not C builtins): __class__.__name__ == 'function'."
    - "All values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ checks — six inspect predicate functions
# ---------------------------------------------------------------------------

table inspect_extra262.function_names:
  description: "ismodule, isabstract, ismethodwrapper, isroutine, isgenerator, isgeneratorfunction __name__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [ismodule,            ismodule.__name__.__eq__,            ["ismodule"],            true]
    - [isabstract,          isabstract.__name__.__eq__,          ["isabstract"],          true]
    - [ismethodwrapper,     ismethodwrapper.__name__.__eq__,     ["ismethodwrapper"],     true]
    - [isroutine,           isroutine.__name__.__eq__,           ["isroutine"],           true]
    - [isgenerator,         isgenerator.__name__.__eq__,         ["isgenerator"],         true]
    - [isgeneratorfunction, isgeneratorfunction.__name__.__eq__, ["isgeneratorfunction"], true]

# ---------------------------------------------------------------------------
# __qualname__ checks — all six match __name__ (top-level, not nested)
# ---------------------------------------------------------------------------

table inspect_extra262.function_qualnames:
  description: "ismodule, isabstract, ismethodwrapper, isroutine, isgenerator, isgeneratorfunction __qualname__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: fqname

  columns: [id, function, args, expected]
  rows:
    - [ismodule,            ismodule.__qualname__.__eq__,            ["ismodule"],            true]
    - [isabstract,          isabstract.__qualname__.__eq__,          ["isabstract"],          true]
    - [ismethodwrapper,     ismethodwrapper.__qualname__.__eq__,     ["ismethodwrapper"],     true]
    - [isroutine,           isroutine.__qualname__.__eq__,           ["isroutine"],           true]
    - [isgenerator,         isgenerator.__qualname__.__eq__,         ["isgenerator"],         true]
    - [isgeneratorfunction, isgeneratorfunction.__qualname__.__eq__, ["isgeneratorfunction"], true]

# ---------------------------------------------------------------------------
# __module__ checks — all six belong to the 'inspect' module
# ---------------------------------------------------------------------------

table inspect_extra262.function_modules:
  description: "ismodule, isabstract, ismethodwrapper, isroutine, isgenerator, isgeneratorfunction __module__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [ismodule,            ismodule.__module__.__eq__,            ["inspect"], true]
    - [isabstract,          isabstract.__module__.__eq__,          ["inspect"], true]
    - [ismethodwrapper,     ismethodwrapper.__module__.__eq__,     ["inspect"], true]
    - [isroutine,           isroutine.__module__.__eq__,           ["inspect"], true]
    - [isgenerator,         isgenerator.__module__.__eq__,         ["inspect"], true]
    - [isgeneratorfunction, isgeneratorfunction.__module__.__eq__, ["inspect"], true]

# ---------------------------------------------------------------------------
# __class__.__name__ checks — all six are Python-level functions
# ---------------------------------------------------------------------------

table inspect_extra262.function_class_names:
  description: "ismodule, isabstract, ismethodwrapper, isroutine, isgenerator, isgeneratorfunction are Python functions"
  kind: python_call_eq
  category: identity
  id_prefix: fclass

  columns: [id, function, args, expected]
  rows:
    - [ismodule,            ismodule.__class__.__name__.__eq__,            ["function"], true]
    - [isabstract,          isabstract.__class__.__name__.__eq__,          ["function"], true]
    - [ismethodwrapper,     ismethodwrapper.__class__.__name__.__eq__,     ["function"], true]
    - [isroutine,           isroutine.__class__.__name__.__eq__,           ["function"], true]
    - [isgenerator,         isgenerator.__class__.__name__.__eq__,         ["function"], true]
    - [isgeneratorfunction, isgeneratorfunction.__class__.__name__.__eq__, ["function"], true]
