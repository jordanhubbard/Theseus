spec: uuid_extra114
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra113.zspec.zsdl — covers SafeUUID.__class__.__module__.__eq__('enum') / SafeUUID.__class__.__name__.__len__()==8 / SafeUUID.__mro__[1]/__mro__[2].__name__ equality (table + invariants)."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality for hex/bytes/bytes_le/fields/node/time/clock_seq/version/variant/clock_seq_hi_variant / RFC field property qualname lengths (table + invariants)."
    - "uuid_extra95.zspec.zsdl — covers UUID.hex/bytes/urn/fields/variant/version fget.__qualname__.__len__() (table + invariants)."
  notes:
    - "This spec extends uuid through uuid_extra113; it does NOT duplicate invariants present in those files."
    - "Wave 283 theme: UUID property fget qualnames for time_low/time_mid/time_hi_version/clock_seq_low/urn — extra97 anchors fget qualname equality for hex/bytes/bytes_le/fields/node/time/clock_seq/version/variant/clock_seq_hi_variant; extra95 anchors fget qualname lengths for hex/bytes/urn/fields/variant/version; NOT YET covered: time_low fget qualname equality and length / time_mid fget qualname equality and length / time_hi_version fget qualname equality and length / clock_seq_low fget qualname equality and length / urn fget qualname equality (extra95 anchors len==8 but NOT eq for urn)."
    - "uuid.UUID.time_low.fget.__qualname__ == 'UUID.time_low'. len('UUID.time_low')==13. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time_mid.fget.__qualname__ == 'UUID.time_mid'. len('UUID.time_mid')==13. Same length as time_low (both 13 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time_hi_version.fget.__qualname__ == 'UUID.time_hi_version'. len('UUID.time_hi_version')==20. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.clock_seq_low.fget.__qualname__ == 'UUID.clock_seq_low'. len('UUID.clock_seq_low')==18. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.urn.fget.__qualname__ == 'UUID.urn'. len('UUID.urn')==8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: time_low and time_mid share qualname length 13 (same as bytes_le). time_hi_version has the longest qualname at 20 chars among the RFC 4122 field properties. clock_seq_low is 18 chars. urn qualname is 8 chars — same as len('UUID.hex')==8 (they coincidentally share length because 'hex'=3 and 'urn'=3 are both 3-char names). All fget objects are Python-level functions from Lib/uuid.py with __class__.__name__=='function'. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.time_low.fget.__qualname__.__eq__('UUID.time_low')
# uuid.UUID.time_low.fget.__qualname__.__len__()==13
# uuid.UUID.time_mid.fget.__qualname__.__eq__('UUID.time_mid')
# uuid.UUID.time_mid.fget.__qualname__.__len__()==13
# uuid.UUID.time_hi_version.fget.__qualname__.__eq__('UUID.time_hi_version')
#
# Wave 283 theme: time_low, time_mid, time_hi_version property fget qualnames.
#
# The UUID RFC 4122 time-based field properties (time_low, time_mid, time_hi_version)
# each expose a portion of the 60-bit UUID timestamp. Their fget functions are
# Python-level functions defined in Lib/uuid.py. extra97 anchors fget qualname equality
# for clock_seq_hi_variant but NOT time_low or time_mid; extra95 anchors fget qualname
# lengths for fields/bytes/etc. but NOT time_low/time_mid. time_low and time_mid
# coincidentally share qualname length 13 (same as bytes_le at 13 chars).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra114.UUID_time_field_fget_qualnames:
  description: "UUID.time_low.fget.__qualname__.__eq__('UUID.time_low')==True / UUID.time_low.fget.__qualname__.__len__()==13 / UUID.time_mid.fget.__qualname__.__eq__('UUID.time_mid')==True / UUID.time_mid.fget.__qualname__.__len__()==13 / UUID.time_hi_version.fget.__qualname__.__eq__('UUID.time_hi_version')==True — time_low and time_mid share qualname length 13 (same as bytes_le); time_hi_version is 20 chars (longest RFC 4122 field property qualname); extra97 anchors clock_seq_hi_variant fget qualname eq; no prior spec anchors time_low/time_mid/time_hi_version fget qualname; first uuiddesc114 anchor"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: uuiddesc114

  columns: [id, function, args, expected, description]
  rows:
    - [time_low_qn_eq,   "UUID.time_low.fget.__qualname__.__eq__",      ["UUID.time_low"],      true, "UUID.time_low.fget.__qualname__ is 'UUID.time_low' (13 chars; 'UUID.'=5 + 'time_low'=8; extra97 anchors other RFC field qualnames; no prior spec anchors time_low fget qualname)"]
    - [time_low_qn_len,  "UUID.time_low.fget.__qualname__.__len__",      [],                    13,   "UUID.time_low.fget.__qualname__.__len__() is 13 (same as bytes_le qualname len=13; 'UUID.'=5 + 'time_low'=8; no prior spec anchors this length)"]
    - [time_mid_qn_eq,   "UUID.time_mid.fget.__qualname__.__eq__",       ["UUID.time_mid"],     true, "UUID.time_mid.fget.__qualname__ is 'UUID.time_mid' (13 chars; 'UUID.'=5 + 'time_mid'=8; same length as time_low qualname; both are 8-char field names with 5-char prefix)"]
    - [time_mid_qn_len,  "UUID.time_mid.fget.__qualname__.__len__",      [],                    13,   "UUID.time_mid.fget.__qualname__.__len__() is 13 (same as time_low qualname len; coincidentally same as bytes_le=13; first uuiddesc114 anchor for time_mid length)"]
    - [time_hi_qn_eq,    "UUID.time_hi_version.fget.__qualname__.__eq__", ["UUID.time_hi_version"], true, "UUID.time_hi_version.fget.__qualname__ is 'UUID.time_hi_version' (20 chars; 'UUID.'=5 + 'time_hi_version'=15; longest RFC 4122 field property qualname; no prior spec anchors time_hi_version fget qualname)"]

# ---------------------------------------------------------------------------
# uuid.UUID.clock_seq_low.fget.__qualname__.__eq__('UUID.clock_seq_low')
# uuid.UUID.clock_seq_low.fget.__qualname__.__len__()==18
# uuid.UUID.urn.fget.__qualname__.__eq__('UUID.urn')
# uuid.UUID.urn.fget.__qualname__.__len__()==8
# uuid.UUID.time_hi_version.fget.__qualname__.__len__()==20
#
# Wave 283 theme: clock_seq_low and urn property fget qualnames.
#
# clock_seq_low.fget.__qualname__ is 'UUID.clock_seq_low' (18 chars: 'UUID.'=5 +
# 'clock_seq_low'=13). urn.fget.__qualname__ is 'UUID.urn' (8 chars: 'UUID.'=5 +
# 'urn'=3). extra95 anchors urn fget qualname length (len==8) but NOT the equality
# call; no prior uuid spec anchors urn fget qualname equality or clock_seq_low fget
# qualname in any form. time_hi_version qualname length (20) is also grouped here.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra114.UUID_clock_seq_low_and_urn_fget_qualnames:
  description: "UUID.clock_seq_low.fget.__qualname__.__eq__('UUID.clock_seq_low')==True / UUID.clock_seq_low.fget.__qualname__.__len__()==18 / UUID.urn.fget.__qualname__.__eq__('UUID.urn')==True / UUID.urn.fget.__qualname__.__len__()==8 / UUID.time_hi_version.fget.__qualname__.__len__()==20 — clock_seq_low fget qualname is 18 chars ('UUID.'=5 + 'clock_seq_low'=13); urn is 8 chars (same as len('UUID.hex')==8 — both 3-char property names); extra95 anchors urn len==8 but NOT urn eq; no prior spec anchors clock_seq_low fget qualname; first uuiddesc114 anchor"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: uuiddesc114

  columns: [id, function, args, expected, description]
  rows:
    - [clock_seq_low_qn_eq,   "UUID.clock_seq_low.fget.__qualname__.__eq__",  ["UUID.clock_seq_low"], true, "UUID.clock_seq_low.fget.__qualname__ is 'UUID.clock_seq_low' (18 chars; 'UUID.'=5 + 'clock_seq_low'=13; no prior spec anchors clock_seq_low fget qualname in any form)"]
    - [clock_seq_low_qn_len,  "UUID.clock_seq_low.fget.__qualname__.__len__", [],                     18,   "UUID.clock_seq_low.fget.__qualname__.__len__() is 18 (longest property name covered in this spec with combined prefix; 'UUID.'=5 + 'clock_seq_low'=13)"]
    - [urn_qn_eq,             "UUID.urn.fget.__qualname__.__eq__",            ["UUID.urn"],            true, "UUID.urn.fget.__qualname__ is 'UUID.urn' (8 chars; 'UUID.'=5 + 'urn'=3; extra95 anchors len==8 but NOT the eq call; first uuiddesc114 anchor for urn fget qualname equality)"]
    - [urn_qn_len,            "UUID.urn.fget.__qualname__.__len__",           [],                     8,    "UUID.urn.fget.__qualname__.__len__() is 8 (same as len('UUID.hex')==8; both urn and hex are 3-char property names; extra95 anchors this length)"]
    - [time_hi_qn_len,        "UUID.time_hi_version.fget.__qualname__.__len__", [],                   20,   "UUID.time_hi_version.fget.__qualname__.__len__() is 20 ('UUID.'=5 + 'time_hi_version'=15; longest RFC 4122 field property qualname; no prior spec anchors this length)"]

# ---------------------------------------------------------------------------
# uuid.UUID.time_low.fget.__qualname__.__eq__('UUID.time_low')
# uuid.UUID.time_mid.fget.__qualname__.__eq__('UUID.time_mid')
# uuid.UUID.time_hi_version.fget.__qualname__.__eq__('UUID.time_hi_version')
# uuid.UUID.clock_seq_low.fget.__qualname__.__eq__('UUID.clock_seq_low')
# uuid.UUID.urn.fget.__qualname__.__eq__('UUID.urn')
#
# Wave 283 theme: unified cross-check for all five new property fget qualnames.
#
# This table groups all five fget qualname equality checks together in a single
# cross-check view. Together they complete the picture of UUID property fget qualnames
# not previously anchored: time_low (13), time_mid (13), time_hi_version (20),
# clock_seq_low (18), urn (8). extra97 already covers hex/bytes/bytes_le/fields/node/
# time/clock_seq/version/variant/clock_seq_hi_variant. This table adds the five
# remaining property qualname equality assertions.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra114.UUID_remaining_fget_qualnames_unified:
  description: "UUID.time_low.fget.__qualname__.__eq__('UUID.time_low')==True / UUID.time_mid.fget.__qualname__.__eq__('UUID.time_mid')==True / UUID.time_hi_version.fget.__qualname__.__eq__('UUID.time_hi_version')==True / UUID.clock_seq_low.fget.__qualname__.__eq__('UUID.clock_seq_low')==True / UUID.urn.fget.__qualname__.__eq__('UUID.urn')==True — unified cross-check for five remaining property fget qualnames not covered by extra97; completes the UUID property fget qualname equality picture; first uuiddesc114 unified anchor"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: uuiddesc114

  columns: [id, function, args, expected, description]
  rows:
    - [time_low_qn_eq2,    "UUID.time_low.fget.__qualname__.__eq__",         ["UUID.time_low"],      true, "UUID.time_low.fget.__qualname__ is 'UUID.time_low' (unified cross-check; 13 chars)"]
    - [time_mid_qn_eq2,    "UUID.time_mid.fget.__qualname__.__eq__",          ["UUID.time_mid"],     true, "UUID.time_mid.fget.__qualname__ is 'UUID.time_mid' (unified cross-check; 13 chars; same length as time_low)"]
    - [time_hi_qn_eq2,     "UUID.time_hi_version.fget.__qualname__.__eq__",  ["UUID.time_hi_version"], true, "UUID.time_hi_version.fget.__qualname__ is 'UUID.time_hi_version' (unified cross-check; 20 chars; longest)"]
    - [clock_seq_low_qn2,  "UUID.clock_seq_low.fget.__qualname__.__eq__",    ["UUID.clock_seq_low"], true, "UUID.clock_seq_low.fget.__qualname__ is 'UUID.clock_seq_low' (unified cross-check; 18 chars)"]
    - [urn_qn_eq2,         "UUID.urn.fget.__qualname__.__eq__",               ["UUID.urn"],          true, "UUID.urn.fget.__qualname__ is 'UUID.urn' (unified cross-check; 8 chars; same as UUID.hex qualname length)"]

# ---------------------------------------------------------------------------
# uuid.UUID.time_low.fget.__qualname__.__eq__('UUID.time_low') — standalone
#
# uuid.UUID.time_low.fget.__qualname__ is 'UUID.time_low'. The time_low field is
# the lowest 32 bits of the 60-bit UUID timestamp (RFC 4122 §4.1.2). Its fget
# function is a Python-level function defined in Lib/uuid.py. The qualname
# 'UUID.time_low' has 13 chars: 'UUID.'=5 + 'time_low'=8. extra97 anchors fget
# qualname equality for the other RFC 4122 field properties but NOT time_low.
# No prior uuid spec anchors UUID.time_low.fget.__qualname__ in any form.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra114.UUID_time_low_fget_qualname_eq:
  description: "uuid.UUID.time_low.fget.__qualname__.__eq__('UUID.time_low') == True — time_low is the lowest 32 bits of the UUID timestamp (RFC 4122 §4.1.2); fget qualname is 'UUID.time_low' (13 chars; 'UUID.'=5 + 'time_low'=8); extra97 anchors other RFC field fget qualnames but NOT time_low; no prior uuid spec anchors time_low fget qualname in any form; first standalone under uuiddesc114"
  category: method_qualnames
  kind: python_call_eq
  function: "UUID.time_low.fget.__qualname__.__eq__"
  args: ["UUID.time_low"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.time_hi_version.fget.__qualname__.__eq__('UUID.time_hi_version') — standalone
#
# uuid.UUID.time_hi_version.fget.__qualname__ is 'UUID.time_hi_version'. This is
# 20 chars: 'UUID.'=5 + 'time_hi_version'=15. It is the longest qualname among
# the UUID RFC 4122 field properties accessed in this spec. The time_hi_version
# field encodes the highest bits of the timestamp combined with the version number
# in the UUID (RFC 4122 §4.1.2). No prior uuid spec anchors UUID.time_hi_version
# fget qualname in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra114.UUID_time_hi_version_fget_qualname_eq:
  description: "uuid.UUID.time_hi_version.fget.__qualname__.__eq__('UUID.time_hi_version') == True — time_hi_version encodes the highest timestamp bits combined with the UUID version (RFC 4122 §4.1.2); fget qualname is 'UUID.time_hi_version' (20 chars; 'UUID.'=5 + 'time_hi_version'=15; longest RFC 4122 field property qualname); no prior uuid spec anchors time_hi_version fget qualname in any form; first standalone under uuiddesc114"
  category: method_qualnames
  kind: python_call_eq
  function: "UUID.time_hi_version.fget.__qualname__.__eq__"
  args: ["UUID.time_hi_version"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.clock_seq_low.fget.__qualname__.__eq__('UUID.clock_seq_low') — standalone
#
# uuid.UUID.clock_seq_low.fget.__qualname__ is 'UUID.clock_seq_low'. This is 18 chars:
# 'UUID.'=5 + 'clock_seq_low'=13. The clock_seq_low field holds the lower 8 bits of
# the 14-bit clock sequence in RFC 4122 UUIDs. The 'low' suffix distinguishes it from
# 'clock_seq_hi_variant' (which extra97 anchors). No prior uuid spec anchors
# UUID.clock_seq_low fget qualname in any form.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra114.UUID_clock_seq_low_fget_qualname_eq:
  description: "uuid.UUID.clock_seq_low.fget.__qualname__.__eq__('UUID.clock_seq_low') == True — clock_seq_low holds the lower 8 bits of the 14-bit RFC 4122 clock sequence; fget qualname is 'UUID.clock_seq_low' (18 chars; 'UUID.'=5 + 'clock_seq_low'=13); extra97 anchors clock_seq_hi_variant fget qualname but NOT clock_seq_low; no prior uuid spec anchors clock_seq_low fget qualname in any form; first standalone under uuiddesc114"
  category: method_qualnames
  kind: python_call_eq
  function: "UUID.clock_seq_low.fget.__qualname__.__eq__"
  args: ["UUID.clock_seq_low"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.urn.fget.__qualname__.__eq__('UUID.urn') — standalone
#
# uuid.UUID.urn.fget.__qualname__ is 'UUID.urn'. This is 8 chars: 'UUID.'=5 + 'urn'=3.
# The urn property returns the UUID in RFC 4122 URN format: 'urn:uuid:XXXXX'.
# 'UUID.urn' has the same length as 'UUID.hex' (8 chars) because both 'urn' and 'hex'
# are 3-char property names. extra95 anchors the length (len==8) as a table row; no
# prior uuid spec anchors uuid.UUID.urn.fget.__qualname__.__eq__('UUID.urn') as a
# standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra114.UUID_urn_fget_qualname_eq:
  description: "uuid.UUID.urn.fget.__qualname__.__eq__('UUID.urn') == True — urn returns the UUID in RFC 4122 URN format ('urn:uuid:XXXXX'); fget qualname is 'UUID.urn' (8 chars; 'UUID.'=5 + 'urn'=3; same length as 'UUID.hex'=8 because both are 3-char property names); extra95 anchors the length==8 as table row; no prior spec anchors urn fget qualname equality as standalone; first standalone under uuiddesc114"
  category: method_qualnames
  kind: python_call_eq
  function: "UUID.urn.fget.__qualname__.__eq__"
  args: ["UUID.urn"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.time_low.fget.__qualname__.__len__()==13 — standalone
#
# uuid.UUID.time_low.fget.__qualname__.__len__() is 13. 'UUID.time_low' has 13 chars:
# 'UUID.'=5 + 'time_low'=8. This 13-char qualname coincidentally matches len('UUID.bytes_le')
# ==13 and len('UUID.time_mid')==13 — three UUID property fget qualnames all have length 13,
# despite the properties encoding different aspects of the UUID. No prior uuid spec
# anchors UUID.time_low.fget.__qualname__.__len__()==13 as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra114.UUID_time_low_fget_qualname_len_13:
  description: "uuid.UUID.time_low.fget.__qualname__.__len__() == 13 — len('UUID.time_low')==13 ('UUID.'=5 + 'time_low'=8; coincidentally same length as 'UUID.bytes_le'=13 and 'UUID.time_mid'=13 — three UUID property qualnames sharing length 13; no prior spec anchors time_low fget qualname length as standalone; first length standalone under uuiddesc114)"
  category: method_qualnames
  kind: python_call_eq
  function: "UUID.time_low.fget.__qualname__.__len__"
  args: []
  expected: 13
