spec: shortid
version: ">=2.0.0"
backend: node(shortid)

docs: https://github.com/dylang/shortid#readme

provenance:
  derived_from:
    - "shortid README — https://github.com/dylang/shortid#readme"
    - "Test vectors verified with shortid via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "shortid source"
  notes:
    - "Generates URL-friendly unique IDs — alternative to uuid / nanoid (now legacy)."
    - "Install: npm install shortid"
    - "v2 CJS; module export IS the generate function; .generate / .seed / .worker / .characters / .isValid attached."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure functions; never throw."
  stderr: "null"
  stickiness: "Internal counter persists across calls; reset via .seed()."
  codes: {}

invariant shortid.module_is_function:
  description: "Module export is a function (alias of .generate)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant shortid.has_generate:
  description: "generate() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "generate.constructor.name"}
  expected: "Function"

invariant shortid.has_isValid:
  description: "isValid(id) predicate exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "isValid.constructor.name"}
  expected: "Function"

invariant shortid.has_seed:
  description: "seed() (re-seed) exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "seed.constructor.name"}
  expected: "Function"

invariant shortid.has_worker:
  description: "worker() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "worker.constructor.name"}
  expected: "Function"

invariant shortid.has_characters:
  description: "characters() (alphabet customization) exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "characters.constructor.name"}
  expected: "Function"

invariant shortid.isValid_invalid_input:
  description: "isValid('a@b.c!') is false (contains invalid chars)"
  category: validate
  kind: node_chain_eq
  entry: named
  function: isValid
  entry_args: ["a@b.c!"]
  chain: []
  expected: false

invariant shortid.isValid_empty_string:
  description: "isValid('') is false"
  category: validate
  kind: node_chain_eq
  entry: named
  function: isValid
  entry_args: [""]
  chain: []
  expected: false

invariant shortid.generated_id_is_valid:
  description: "Newly generated ID passes isValid()"
  category: validate
  kind: node_chain_eq
  entry: named
  function: generate
  entry_args: []
  chain:
    - {get: "constructor.name"}
  expected: "String"
