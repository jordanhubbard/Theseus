# asyncio.create_task.__doc__.__len__() == 85
# asyncio.create_task co_argcount == 1
# asyncio.create_task co_varnames len == 3
# ---------------------------------------------------------------------------

table asyncio_extra145.run_and_create_task:
  description: "asyncio.run and asyncio.create_task identity, doc, and code checks — run.__qualname__.__eq__('run')==True (len=3: the shortest qualname of any function in this spec; top-level function with qualname equal to name); run.__module__.__eq__('asyncio.runners')==True (len=15: 'asyncio'=7+'.'=1+'runners'=7=15; same length as asyncio.events but a different submodule); run.__doc__.__len__()==885 (multi-paragraph doc beginning 'Execute the coroutine and return the result.' — the longest __doc__ in this spec); run.__code__.co_argcount.__eq__(1)==True ('main', the coroutine to run); run.__code__.co_varnames.__len__()==4 ('main','debug','loop_factory','runner' — 1 required param + 3 additional: 2 keyword params and 1 local); create_task.__qualname__.__eq__('create_task')==True (len=11: 'create_task'=11); create_task.__module__.__eq__('asyncio.tasks')==True (len=13: 'asyncio'=7+'.'=1+'tasks'=5=13); create_task.__doc__.__len__()==85 (doc beginning 'Schedule the execution of coroutine coro.'); create_task.__code__.co_argcount.__eq__(1)==True ('coro', the coroutine); create_task.__code__.co_varnames.__len__()==3 ('coro','kwargs','loop'); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncio_run145

  columns: [id, function, args, expected, description]
  rows:
    - [run_qn_eq,    asyncio.run.__qualname__.__eq__,           ["run"],              true,  "asyncio.run.__qualname__ == 'run' (len=3); verified with Python 3.14.3"]
    - [run_qn_len,   asyncio.run.__qualname__.__len__,           [],                  3,     "asyncio.run.__qualname__.__len__() == 3; verified with Python 3.14.3"]
    - [run_mod_eq,   asyncio.run.__module__.__eq__,             ["asyncio.runners"],  true,  "asyncio.run.__module__ == 'asyncio.runners' (len=15); verified with Python 3.14.3"]
    - [run_mod_len,  asyncio.run.__module__.__len__,             [],                  15,    "asyncio.run.__module__.__len__() == 15; verified with Python 3.14.3"]
    - [run_doc_len,  asyncio.run.__doc__.__len__,                [],                  885,   "asyncio.run.__doc__.__len__() == 885; verified with Python 3.14.3"]
    - [run_argc,     asyncio.run.__code__.co_argcount.__eq__,   [1],                  true,  "asyncio.run.__code__.co_argcount == 1 ('main'); verified with Python 3.14.3"]
    - [run_vlen,     asyncio.run.__code__.co_varnames.__len__,   [],                  4,     "asyncio.run.__code__.co_varnames.__len__() == 4 ('main','debug','loop_factory','runner'); verified with Python 3.14.3"]
    - [ct_qn_eq,     asyncio.create_task.__qualname__.__eq__,   ["create_task"],      true,  "asyncio.create_task.__qualname__ == 'create_task' (len=11); verified with Python 3.14.3"]
    - [ct_qn_len,    asyncio.create_task.__qualname__.__len__,   [],                  11,    "asyncio.create_task.__qualname__.__len__() == 11; verified with Python 3.14.3"]
    - [ct_mod_eq,    asyncio.create_task.__module__.__eq__,     ["asyncio.tasks"],    true,  "asyncio.create_task.__module__ == 'asyncio.tasks' (len=13); verified with Python 3.14.3"]
    - [ct_mod_len,   asyncio.create_task.__module__.__len__,     [],                  13,    "asyncio.create_task.__module__.__len__() == 13; verified with Python 3.14.3"]
    - [ct_doc_len,   asyncio.create_task.__doc__.__len__,        [],                  85,    "asyncio.create_task.__doc__.__len__() == 85; verified with Python 3.14.3"]
    - [ct_argc,      asyncio.create_task.__code__.co_argcount.__eq__, [1],             true,  "asyncio.create_task.__code__.co_argcount == 1 ('coro'); verified with Python 3.14.3"]
    - [ct_vlen,      asyncio.create_task.__code__.co_varnames.__len__, [],             3,     "asyncio.create_task.__code__.co_varnames.__len__() == 3 ('coro','kwargs','loop'); verified with Python 3.14.3"]

