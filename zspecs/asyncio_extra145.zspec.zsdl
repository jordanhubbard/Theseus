invariant asyncio_extra145.get_event_loop_module_c_asyncio:
  description: "asyncio.get_event_loop.__module__.__len__() == 8 — asyncio.get_event_loop.__module__ is '_asyncio' (8 chars: the C extension module that implements the core event loop primitives; note the leading underscore indicating it is an internal C extension); this is the shortest module name of all functions in this spec (compare asyncio.events=15, asyncio.runners=15, asyncio.tasks=13); get_event_loop.__qualname__=='get_event_loop' (len=14); get_event_loop is a C builtin (no __code__); __doc__.__len__()==306; NEW in extra145: first standalone get_event_loop module length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.get_event_loop.__module__.__len__
  args: []
  expected: 8

invariant asyncio_extra145.get_running_loop_qualname_len_16:
  description: "asyncio.get_running_loop.__qualname__.__len__() == 16 — asyncio.get_running_loop.__qualname__ is 'get_running_loop' (16 chars: the longest qualname in this spec; 2 more than get_event_loop and new_event_loop at 14, 5 more than create_task at 11, and 13 more than run at 3); get_running_loop.__module__=='_asyncio' (len=8: C extension, not pure Python); get_running_loop is a C builtin (no __code__); __doc__.__len__()==105; NEW in extra145: first standalone get_running_loop qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.get_running_loop.__qualname__.__len__
  args: []
  expected: 16

invariant asyncio_extra145.get_event_loop_doc_len_306:
  description: "asyncio.get_event_loop.__doc__.__len__() == 306 — asyncio.get_event_loop.__doc__ is a 306-char multi-paragraph doc beginning 'Return an asyncio event loop.' and describing deprecation behaviour when called with no running event loop and no current event loop set; this is longer than get_running_loop.__doc__ (105) because it documents the additional policy-fallback behaviour; get_event_loop.__qualname__=='get_event_loop' (len=14); get_event_loop.__module__=='_asyncio' (len=8); NEW in extra145: first standalone get_event_loop doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.get_event_loop.__doc__.__len__
  args: []
  expected: 306

invariant asyncio_extra145.run_doc_len_885:
  description: "asyncio.run.__doc__.__len__() == 885 — asyncio.run.__doc__ is an 885-char multi-paragraph doc beginning 'Execute the coroutine and return the result.'; this is the longest __doc__ in this spec (compare: get_event_loop=306, create_task=85, get_running_loop=105); run.__qualname__=='run' (len=3: the shortest qualname in this spec); run.__module__=='asyncio.runners' (len=15); co_argcount==1; co_varnames.__len__()==4; NEW in extra145: first standalone asyncio.run doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.run.__doc__.__len__
  args: []
  expected: 885

invariant asyncio_extra145.new_event_loop_varnames_len_0:
  description: "asyncio.new_event_loop.__code__.co_varnames.__len__() == 0 — asyncio.new_event_loop.__code__.co_varnames is () (empty tuple; no parameters or local variables); new_event_loop is a minimal one-line delegate: 'return get_event_loop_policy().new_event_loop()'; co_argcount==0 (no arguments); new_event_loop.__qualname__=='new_event_loop' (len=14); new_event_loop.__module__=='asyncio.events' (len=15); this contrasts with asyncio.run which has 4 varnames and asyncio.create_task which has 3; NEW in extra145: first standalone new_event_loop co_varnames length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.new_event_loop.__code__.co_varnames.__len__
  args: []
  expected: 0

invariant asyncio_extra145.run_varnames_len_4:
  description: "asyncio.run.__code__.co_varnames.__len__() == 4 — asyncio.run.__code__.co_varnames is ('main','debug','loop_factory','runner') (4 elements: 1 required positional param 'main' + 2 keyword-only params 'debug' and 'loop_factory' + 1 local 'runner'); this is the largest varnames tuple in this spec (compare: create_task=3, new_event_loop=0); run.__qualname__=='run' (len=3); run.__module__=='asyncio.runners' (len=15); co_argcount==1 ('main'); NEW in extra145: first standalone asyncio.run co_varnames length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.run.__code__.co_varnames.__len__
  args: []
  expected: 4

invariant asyncio_extra145.create_task_doc_len_85:
  description: "asyncio.create_task.__doc__.__len__() == 85 — asyncio.create_task.__doc__ is an 85-char doc beginning 'Schedule the execution of coroutine coro.'; create_task.__qualname__=='create_task' (len=11); create_task.__module__=='asyncio.tasks' (len=13); co_argcount==1 ('coro'); co_varnames.__len__()==3 ('coro','kwargs','loop'); this is one of the shorter docs in this spec (compare run=885, get_event_loop=306, get_running_loop=105); NEW in extra145: first standalone asyncio.create_task doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.create_task.__doc__.__len__
  args: []
  expected: 85

