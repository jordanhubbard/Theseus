spec: asyncio_extra145
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-eventloop.html — Python asyncio event loop documentation"
    - "https://docs.python.org/3/library/asyncio-runner.html — Python asyncio runner documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — Python asyncio task documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/events.py, Lib/asyncio/runners.py, Lib/asyncio/tasks.py"
  notes:
    - "This spec covers: asyncio.get_event_loop — a C builtin (no __code__); __qualname__=='get_event_loop' (len=14); __module__=='_asyncio' (len=8); __doc__.__len__()==306. asyncio.get_running_loop — a C builtin; __qualname__=='get_running_loop' (len=16); __module__=='_asyncio' (len=8); __doc__.__len__()==105. asyncio.new_event_loop — a Python function; __qualname__=='new_event_loop' (len=14); __module__=='asyncio.events' (len=15); __doc__.__len__()==63; co_argcount==0; co_varnames.__len__()==0. asyncio.run — __qualname__=='run' (len=3); __module__=='asyncio.runners' (len=15); __doc__.__len__()==885; co_argcount==1; co_varnames.__len__()==4 ('main','debug','loop_factory','runner'). asyncio.create_task — __qualname__=='create_task' (len=11); __module__=='asyncio.tasks' (len=13); __doc__.__len__()==85; co_argcount==1; co_varnames.__len__()==3 ('coro','kwargs','loop'). asyncio.set_event_loop — __qualname__=='set_event_loop' (len=14); __module__=='asyncio.events' (len=15); __doc__.__len__()==67. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.get_event_loop and asyncio.get_running_loop are both C builtins from _asyncio (module len=8); new_event_loop and set_event_loop are pure Python from asyncio.events (len=15). asyncio.run is in asyncio.runners (len=15), asyncio.create_task in asyncio.tasks (len=13). asyncio.run.__qualname__=='run' (len=3: the shortest qualname of any function in this spec); get_running_loop has the longest qualname (len=16). asyncio.run co_varnames.__len__()==4 vs create_task co_varnames.__len__()==3. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio C-builtin event loop access functions — extra145
#
# asyncio.get_event_loop.__qualname__       == 'get_event_loop'  (len=14)
# asyncio.get_event_loop.__module__         == '_asyncio'        (len=8)
# asyncio.get_event_loop.__doc__.__len__()  == 306
# asyncio.get_running_loop.__qualname__     == 'get_running_loop' (len=16)
# asyncio.get_running_loop.__module__       == '_asyncio'         (len=8)
# asyncio.get_running_loop.__doc__.__len__() == 105
# ---------------------------------------------------------------------------

table asyncio_extra145.c_builtin_event_loop_funcs:
  description: "asyncio.get_event_loop and get_running_loop identity checks — both are C builtins from the _asyncio extension module (no __code__); get_event_loop.__qualname__.__eq__('get_event_loop')==True (len=14: 'get_event_loop'=14); get_event_loop.__module__.__eq__('_asyncio')==True (len=8: the C extension, not the pure-Python asyncio package; compare asyncio.events or asyncio.tasks at len=15/13); get_event_loop.__doc__.__len__()==306 (multi-paragraph doc beginning 'Return an asyncio event loop.' and describing deprecation behaviour when called with no running loop); get_running_loop.__qualname__.__eq__('get_running_loop')==True (len=16: 'get_running_loop'=16, the longest qualname in this spec; 2 more than get_event_loop); get_running_loop.__module__.__eq__('_asyncio')==True (len=8: same C extension module as get_event_loop); get_running_loop.__doc__.__len__()==105 (shorter doc: 'Return the running event loop. Raise a RuntimeError if there is no running event loop.'); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncio_cel145

  columns: [id, function, args, expected, description]
  rows:
    - [gel_qn_eq,    asyncio.get_event_loop.__qualname__.__eq__,     ["get_event_loop"],   true,  "asyncio.get_event_loop.__qualname__ == 'get_event_loop' (len=14); verified with Python 3.14.3"]
    - [gel_qn_len,   asyncio.get_event_loop.__qualname__.__len__,     [],                  14,    "asyncio.get_event_loop.__qualname__.__len__() == 14; verified with Python 3.14.3"]
    - [gel_mod_eq,   asyncio.get_event_loop.__module__.__eq__,       ["_asyncio"],         true,  "asyncio.get_event_loop.__module__ == '_asyncio' (len=8); verified with Python 3.14.3"]
    - [gel_mod_len,  asyncio.get_event_loop.__module__.__len__,       [],                  8,     "asyncio.get_event_loop.__module__.__len__() == 8; verified with Python 3.14.3"]
    - [gel_doc_len,  asyncio.get_event_loop.__doc__.__len__,          [],                  306,   "asyncio.get_event_loop.__doc__.__len__() == 306; verified with Python 3.14.3"]
    - [grl_qn_eq,    asyncio.get_running_loop.__qualname__.__eq__,   ["get_running_loop"],  true,  "asyncio.get_running_loop.__qualname__ == 'get_running_loop' (len=16); verified with Python 3.14.3"]
    - [grl_qn_len,   asyncio.get_running_loop.__qualname__.__len__,   [],                  16,    "asyncio.get_running_loop.__qualname__.__len__() == 16; verified with Python 3.14.3"]
    - [grl_mod_eq,   asyncio.get_running_loop.__module__.__eq__,     ["_asyncio"],         true,  "asyncio.get_running_loop.__module__ == '_asyncio' (len=8); verified with Python 3.14.3"]
    - [grl_mod_len,  asyncio.get_running_loop.__module__.__len__,     [],                  8,     "asyncio.get_running_loop.__module__.__len__() == 8; verified with Python 3.14.3"]
    - [grl_doc_len,  asyncio.get_running_loop.__doc__.__len__,        [],                  105,   "asyncio.get_running_loop.__doc__.__len__() == 105; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.new_event_loop and set_event_loop — extra145
#
# asyncio.new_event_loop.__qualname__      == 'new_event_loop' (len=14)
# asyncio.new_event_loop.__module__        == 'asyncio.events' (len=15)
# asyncio.new_event_loop.__doc__.__len__() == 63
# asyncio.new_event_loop co_argcount       == 0
# asyncio.new_event_loop co_varnames len   == 0
# asyncio.set_event_loop.__qualname__      == 'set_event_loop' (len=14)
# asyncio.set_event_loop.__module__        == 'asyncio.events' (len=15)
# asyncio.set_event_loop.__doc__.__len__() == 67
# ---------------------------------------------------------------------------

table asyncio_extra145.new_and_set_event_loop:
  description: "asyncio.new_event_loop and set_event_loop identity, doc, and code checks — new_event_loop.__qualname__.__eq__('new_event_loop')==True (len=14: same length as get_event_loop.__qualname__; 'new_event_loop'=14); new_event_loop.__module__.__eq__('asyncio.events')==True (len=15: 'asyncio'=7+'.'=1+'events'=6=15; pure-Python delegate function, unlike get_event_loop which lives in '_asyncio' C extension at len=8); new_event_loop.__doc__.__eq__('Equivalent to calling get_event_loop_policy().new_event_loop().')==True (len=63: a terse one-sentence delegate description); new_event_loop.__code__.co_argcount.__eq__(0)==True (takes no arguments; delegates entirely to the policy); new_event_loop.__code__.co_varnames.__len__()==0 (no locals — the function body is a single return statement with no intermediate variables); set_event_loop.__qualname__.__eq__('set_event_loop')==True (len=14: ties with new_event_loop qualname); set_event_loop.__module__.__eq__('asyncio.events')==True (len=15: same events module); set_event_loop.__doc__.__len__()==67 (doc is 'Equivalent to calling get_event_loop_policy().set_event_loop(loop).', 4 chars longer than new_event_loop doc at 63); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncio_nel145

  columns: [id, function, args, expected, description]
  rows:
    - [nel_qn_eq,    asyncio.new_event_loop.__qualname__.__eq__,          ["new_event_loop"],  true,  "asyncio.new_event_loop.__qualname__ == 'new_event_loop' (len=14); verified with Python 3.14.3"]
    - [nel_qn_len,   asyncio.new_event_loop.__qualname__.__len__,          [],                 14,    "asyncio.new_event_loop.__qualname__.__len__() == 14; verified with Python 3.14.3"]
    - [nel_mod_eq,   asyncio.new_event_loop.__module__.__eq__,            ["asyncio.events"],  true,  "asyncio.new_event_loop.__module__ == 'asyncio.events' (len=15); verified with Python 3.14.3"]
    - [nel_mod_len,  asyncio.new_event_loop.__module__.__len__,            [],                 15,    "asyncio.new_event_loop.__module__.__len__() == 15; verified with Python 3.14.3"]
    - [nel_doc_len,  asyncio.new_event_loop.__doc__.__len__,               [],                 63,    "asyncio.new_event_loop.__doc__.__len__() == 63; verified with Python 3.14.3"]
    - [nel_argc,     asyncio.new_event_loop.__code__.co_argcount.__eq__,  [0],                 true,  "asyncio.new_event_loop.__code__.co_argcount == 0 (no arguments); verified with Python 3.14.3"]
    - [nel_vlen,     asyncio.new_event_loop.__code__.co_varnames.__len__,  [],                 0,     "asyncio.new_event_loop.__code__.co_varnames.__len__() == 0 (no locals); verified with Python 3.14.3"]
    - [sel_qn_eq,    asyncio.set_event_loop.__qualname__.__eq__,          ["set_event_loop"],  true,  "asyncio.set_event_loop.__qualname__ == 'set_event_loop' (len=14); verified with Python 3.14.3"]
    - [sel_qn_len,   asyncio.set_event_loop.__qualname__.__len__,          [],                 14,    "asyncio.set_event_loop.__qualname__.__len__() == 14; verified with Python 3.14.3"]
    - [sel_mod_len,  asyncio.set_event_loop.__module__.__len__,            [],                 15,    "asyncio.set_event_loop.__module__.__len__() == 15 ('asyncio.events'); verified with Python 3.14.3"]
    - [sel_doc_len,  asyncio.set_event_loop.__doc__.__len__,               [],                 67,    "asyncio.set_event_loop.__doc__.__len__() == 67; verified with Python 3.14.3"]

