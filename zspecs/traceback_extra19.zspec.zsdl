spec: traceback_extra19
version: ">=3.9"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/traceback.html — Python traceback module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
  notes:
    - "This spec extends prior traceback specs through traceback_extra18.zspec.zsdl."
    - "traceback_extra18 covers: format_exc/format_tb/format_stack/print_exc/print_tb/extract_tb/extract_stack module-level function __qualname__ values and TracebackException/StackSummary class __qualname__ values."
    - "Focus: __qualname__ values for class-bound methods on TracebackException and StackSummary, and the FrameSummary class itself."
    - "traceback.TracebackException.from_exception.__qualname__ == 'TracebackException.from_exception' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.TracebackException.format.__qualname__ == 'TracebackException.format' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.TracebackException.format_exception_only.__qualname__ == 'TracebackException.format_exception_only' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.StackSummary.extract.__qualname__ == 'StackSummary.extract' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.StackSummary.from_list.__qualname__ == 'StackSummary.from_list' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.StackSummary.format.__qualname__ == 'StackSummary.format' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.FrameSummary.__qualname__ == 'FrameSummary' — top-level class; verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# traceback.TracebackException class-bound method __qualname__ values
#
# traceback_extra18 records TracebackException.__qualname__ as a class.
# No prior traceback spec records __qualname__ for the class-bound methods
# from_exception, format, or format_exception_only.
# ---------------------------------------------------------------------------

invariant traceback_extra19.TracebackException.from_exception.qualname:
  description: "traceback.TracebackException.from_exception.__qualname__ == 'TracebackException.from_exception'"
  category: method_qualname
  kind: python_call_eq
  function: "TracebackException.from_exception.__qualname__.__eq__"
  args: ["TracebackException.from_exception"]
  expected: true

invariant traceback_extra19.TracebackException.format.qualname:
  description: "traceback.TracebackException.format.__qualname__ == 'TracebackException.format'"
  category: method_qualname
  kind: python_call_eq
  function: "TracebackException.format.__qualname__.__eq__"
  args: ["TracebackException.format"]
  expected: true

invariant traceback_extra19.TracebackException.format_exception_only.qualname:
  description: "traceback.TracebackException.format_exception_only.__qualname__ == 'TracebackException.format_exception_only'"
  category: method_qualname
  kind: python_call_eq
  function: "TracebackException.format_exception_only.__qualname__.__eq__"
  args: ["TracebackException.format_exception_only"]
  expected: true

# ---------------------------------------------------------------------------
# traceback.StackSummary class-bound method __qualname__ values
#
# traceback_extra18 records StackSummary.__qualname__ as a class.
# No prior traceback spec records __qualname__ for the class-bound methods
# extract, from_list, or format.
# ---------------------------------------------------------------------------

invariant traceback_extra19.StackSummary.extract.qualname:
  description: "traceback.StackSummary.extract.__qualname__ == 'StackSummary.extract'"
  category: method_qualname
  kind: python_call_eq
  function: "StackSummary.extract.__qualname__.__eq__"
  args: ["StackSummary.extract"]
  expected: true

invariant traceback_extra19.StackSummary.from_list.qualname:
  description: "traceback.StackSummary.from_list.__qualname__ == 'StackSummary.from_list'"
  category: method_qualname
  kind: python_call_eq
  function: "StackSummary.from_list.__qualname__.__eq__"
  args: ["StackSummary.from_list"]
  expected: true

invariant traceback_extra19.StackSummary.format.qualname:
  description: "traceback.StackSummary.format.__qualname__ == 'StackSummary.format'"
  category: method_qualname
  kind: python_call_eq
  function: "StackSummary.format.__qualname__.__eq__"
  args: ["StackSummary.format"]
  expected: true

# ---------------------------------------------------------------------------
# traceback.FrameSummary class __qualname__ value
#
# FrameSummary is a top-level class representing a single frame in a
# StackSummary. Its __qualname__ equals its class name.
# No prior traceback spec records __qualname__ for FrameSummary.
# ---------------------------------------------------------------------------

invariant traceback_extra19.FrameSummary.qualname:
  description: "traceback.FrameSummary.__qualname__ == 'FrameSummary' — top-level class"
  category: class_qualname
  kind: python_call_eq
  function: FrameSummary.__qualname__.__eq__
  args: ["FrameSummary"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all seven __qualname__ checks
#
# Covers TracebackException.from_exception/format/format_exception_only
# (class-bound methods), StackSummary.extract/from_list/format
# (class-bound methods), and FrameSummary (class).
# ---------------------------------------------------------------------------

table traceback_extra19.method_qualnames:
  description: "__qualname__ values for class-bound methods on TracebackException and StackSummary, and FrameSummary class"
  kind: python_call_eq
  category: method_qualname

  columns: [id, function, args, expected]
  rows:
    - [TracebackException.from_exception,      "TracebackException.from_exception.__qualname__.__eq__",      ["TracebackException.from_exception"],      true]
    - [TracebackException.format,              "TracebackException.format.__qualname__.__eq__",              ["TracebackException.format"],              true]
    - [TracebackException.format_exception_only, "TracebackException.format_exception_only.__qualname__.__eq__", ["TracebackException.format_exception_only"], true]
    - [StackSummary.extract,                   "StackSummary.extract.__qualname__.__eq__",                   ["StackSummary.extract"],                   true]
    - [StackSummary.from_list,                 "StackSummary.from_list.__qualname__.__eq__",                 ["StackSummary.from_list"],                 true]
    - [StackSummary.format,                    "StackSummary.format.__qualname__.__eq__",                    ["StackSummary.format"],                    true]
    - [FrameSummary,                           FrameSummary.__qualname__.__eq__,                             ["FrameSummary"],                           true]
