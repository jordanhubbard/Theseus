spec: inspect_extra90
version: ">=3.9"
backend: python_module(inspect)
extends: inspect_extra89

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra89.zspec.zsdl."
    - "This spec covers: inspect.Parameter, inspect.Signature, inspect.BoundArguments __dict__.__class__.__name__ and __bases__[0].__name__; and FullArgSpec/FrameInfo/ArgInfo/Traceback namedtuple identity (Wave 250)."
    - "inspect.Parameter.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is a mappingproxy object. Verified with Python 3.14.3."
    - "inspect.Signature.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is a mappingproxy object. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is a mappingproxy object. Verified with Python 3.14.3."
    - "inspect.Parameter.__bases__[0].__name__ == 'object' — Parameter directly inherits from object. Verified with Python 3.14.3."
    - "inspect.Signature.__bases__[0].__name__ == 'object' — Signature directly inherits from object. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__bases__[0].__name__ == 'object' — BoundArguments directly inherits from object. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__name__ == 'FullArgSpec' — namedtuple defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__module__ == 'inspect' — namedtuple's __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__bases__[0].__name__ == 'tuple' — namedtuple classes directly inherit from tuple. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__name__ == 'FrameInfo' — exists in Python 3.14.3 as a NamedTuple subclass. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__module__ == 'inspect' — __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__bases__[0].__name__ == '_FrameInfo' — inherits from _FrameInfo (not tuple directly) in Python 3.14.3. Verified with Python 3.14.3."
    - "inspect.Traceback.__name__ == 'Traceback' — exists in Python 3.14.3 as a NamedTuple subclass. Verified with Python 3.14.3."
    - "inspect.Traceback.__module__ == 'inspect' — __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.ArgInfo.__name__ == 'ArgInfo' — namedtuple defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.ArgInfo.__module__ == 'inspect' — __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.ArgInfo.__bases__[0].__name__ == 'tuple' — ArgInfo namedtuple directly inherits from tuple. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Parameter/Signature/BoundArguments __dict__.__class__.__name__
#
# Wave 250 theme: inspect class __dict__ proxy class names — mappingproxy.
#
# inspect.Parameter.__dict__.__class__.__name__.__eq__('mappingproxy')      == True
# inspect.Signature.__dict__.__class__.__name__.__eq__('mappingproxy')      == True
# inspect.BoundArguments.__dict__.__class__.__name__.__eq__('mappingproxy') == True
# inspect.Parameter.__dict__.__class__.__name__.__eq__('dict')              == False (cross-check)
#
# Prior spec extra89 checked _ParameterKind enum members. This spec (extra90) checks class dict proxies. New to extra90.
# ---------------------------------------------------------------------------

table inspect_extra90.class_dict_proxy_names:
  description: "Parameter/Signature/BoundArguments __dict__.__class__.__name__ == 'mappingproxy'; class __dict__ is always a mappingproxy; wave 250; new to extra90"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectclshier90

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_dict_class_name_eq_mappingproxy,
       Parameter.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "inspect.Parameter.__dict__.__class__.__name__.__eq__('mappingproxy') == True — class __dict__ in Python is not a plain dict but a mappingproxy object (types.MappingProxyType); this prevents direct modification of the class namespace; __dict__.__class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; prior spec extra89 checked _ParameterKind enum members; this spec (extra90) checks class dict proxies; new to extra90"]
    - [Signature_dict_class_name_eq_mappingproxy,
       Signature.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "inspect.Signature.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Signature class __dict__ is a mappingproxy; __dict__.__class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; new to extra90"]
    - [BoundArguments_dict_class_name_eq_mappingproxy,
       BoundArguments.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "inspect.BoundArguments.__dict__.__class__.__name__.__eq__('mappingproxy') == True — BoundArguments class __dict__ is a mappingproxy; __dict__.__class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; new to extra90"]
    - [Parameter_dict_class_name_ne_dict,
       Parameter.__dict__.__class__.__name__.__eq__,
       ["dict"],
       false,
       "inspect.Parameter.__dict__.__class__.__name__.__eq__('dict') == False — class __dict__ is a mappingproxy, not a plain dict; mappingproxy is read-only while dict is mutable; str.__eq__('dict') returns False; confirms the class namespace is protected; new to extra90"]

# ---------------------------------------------------------------------------
# Parameter/Signature/BoundArguments __bases__[0].__name__
#
# Wave 250 theme: inspect class hierarchy — Parameter/Signature/BoundArguments base classes.
#
# inspect.Parameter.__bases__[0].__name__.__eq__('object')       == True
# inspect.Signature.__bases__[0].__name__.__eq__('object')       == True
# inspect.BoundArguments.__bases__[0].__name__.__eq__('object')  == True
# inspect.Signature.__bases__[0].__name__.__eq__('Parameter')    == False (cross-check)
#
# No prior inspect spec checks __bases__[0].__name__ for these classes via inspectclshier90. New to extra90.
# ---------------------------------------------------------------------------

table inspect_extra90.class_bases:
  description: "Parameter/Signature/BoundArguments __bases__[0].__name__ == 'object'; all directly inherit from object; wave 250; new to extra90"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: inspectclshier90

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_bases0_name_eq_object,
       "Parameter.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Parameter.__bases__[0].__name__.__eq__('object') == True — Parameter is defined in Lib/inspect.py and directly inherits from object; __bases__ is (object,); __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; no prior inspect spec checks __bases__[0].__name__ for these classes via inspectclshier90; new to extra90"]
    - [Signature_bases0_name_eq_object,
       "Signature.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Signature.__bases__[0].__name__.__eq__('object') == True — Signature is defined in Lib/inspect.py and directly inherits from object; __bases__ is (object,); __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra90"]
    - [BoundArguments_bases0_name_eq_object,
       "BoundArguments.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.BoundArguments.__bases__[0].__name__.__eq__('object') == True — BoundArguments is defined in Lib/inspect.py and directly inherits from object; __bases__ is (object,); __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra90"]
    - [Signature_bases0_name_ne_Parameter,
       "Signature.__bases__[0].__name__.__eq__",
       ["Parameter"],
       false,
       "inspect.Signature.__bases__[0].__name__.__eq__('Parameter') == False — Signature does not inherit from Parameter; both independently inherit from object; __bases__[0].__name__ is 'object', not 'Parameter'; str.__eq__('Parameter') returns False; confirms Signature and Parameter are sibling classes; new to extra90"]

# ---------------------------------------------------------------------------
# FullArgSpec and FrameInfo namedtuple identity
#
# Wave 250 theme: inspect namedtuple __name__/__module__ identity — FullArgSpec and FrameInfo.
#
# inspect.FullArgSpec.__name__.__eq__('FullArgSpec')   == True
# inspect.FullArgSpec.__module__.__eq__('inspect')     == True
# inspect.FrameInfo.__name__.__eq__('FrameInfo')       == True
# inspect.FrameInfo.__module__.__eq__('inspect')       == True
#
# No prior inspect spec checks FullArgSpec or FrameInfo identity via inspectclshier90. New to extra90.
# ---------------------------------------------------------------------------

table inspect_extra90.fullargspec_frameinfo_identity:
  description: "FullArgSpec/FrameInfo __name__ and __module__ identity; namedtuple and NamedTuple types in Lib/inspect.py; wave 250; new to extra90"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectclshier90

  columns: [id, function, args, expected, description]
  rows:
    - [FullArgSpec_name_eq_FullArgSpec,
       FullArgSpec.__name__.__eq__,
       ["FullArgSpec"],
       true,
       "inspect.FullArgSpec.__name__.__eq__('FullArgSpec') == True — FullArgSpec is a namedtuple defined in Lib/inspect.py with fields (args, varargs, varkw, defaults, kwonlyargs, kwonlydefaults, annotations); __name__ is 'FullArgSpec'; str.__eq__('FullArgSpec') returns True; no prior inspect spec checks FullArgSpec identity via inspectclshier90; new to extra90"]
    - [FullArgSpec_module_eq_inspect,
       FullArgSpec.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.FullArgSpec.__module__.__eq__('inspect') == True — FullArgSpec is a namedtuple created in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra90"]
    - [FrameInfo_name_eq_FrameInfo,
       FrameInfo.__name__.__eq__,
       ["FrameInfo"],
       true,
       "inspect.FrameInfo.__name__.__eq__('FrameInfo') == True — FrameInfo is a NamedTuple subclass defined in Lib/inspect.py representing a named tuple of frame information; __name__ is 'FrameInfo'; str.__eq__('FrameInfo') returns True; new to extra90"]
    - [FrameInfo_module_eq_inspect,
       FrameInfo.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.FrameInfo.__module__.__eq__('inspect') == True — FrameInfo is a NamedTuple subclass defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra90"]

# ---------------------------------------------------------------------------
# ArgInfo and Traceback namedtuple identity
#
# Wave 250 theme: inspect namedtuple __name__/__module__ identity — ArgInfo and Traceback.
#
# inspect.ArgInfo.__name__.__eq__('ArgInfo')       == True
# inspect.ArgInfo.__module__.__eq__('inspect')     == True
# inspect.Traceback.__name__.__eq__('Traceback')   == True
# inspect.Traceback.__module__.__eq__('inspect')   == True
#
# No prior inspect spec checks ArgInfo or Traceback identity via inspectclshier90. New to extra90.
# ---------------------------------------------------------------------------

table inspect_extra90.arginfo_traceback_identity:
  description: "ArgInfo/Traceback __name__ and __module__ identity; namedtuple types in Lib/inspect.py; wave 250; new to extra90"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectclshier90

  columns: [id, function, args, expected, description]
  rows:
    - [ArgInfo_name_eq_ArgInfo,
       ArgInfo.__name__.__eq__,
       ["ArgInfo"],
       true,
       "inspect.ArgInfo.__name__.__eq__('ArgInfo') == True — ArgInfo is a namedtuple defined in Lib/inspect.py with fields (args, varargs, keywords, locals); returned by getargvalues(); __name__ is 'ArgInfo'; str.__eq__('ArgInfo') returns True; no prior inspect spec checks ArgInfo identity via inspectclshier90; new to extra90"]
    - [ArgInfo_module_eq_inspect,
       ArgInfo.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.ArgInfo.__module__.__eq__('inspect') == True — ArgInfo is a namedtuple created in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra90"]
    - [Traceback_name_eq_Traceback,
       Traceback.__name__.__eq__,
       ["Traceback"],
       true,
       "inspect.Traceback.__name__.__eq__('Traceback') == True — Traceback is a NamedTuple subclass defined in Lib/inspect.py; __name__ is 'Traceback'; str.__eq__('Traceback') returns True; new to extra90"]
    - [Traceback_module_eq_inspect,
       Traceback.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Traceback.__module__.__eq__('inspect') == True — Traceback is a NamedTuple subclass defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra90"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra90
# ---------------------------------------------------------------------------

invariant inspect_extra90.Parameter_dict_class_name_eq_mappingproxy:
  description: "inspect.Parameter.__dict__.__class__.__name__.__eq__('mappingproxy') == True — class __dict__ is a mappingproxy; wave 250; new to extra90"
  kind: python_call_eq
  function: Parameter.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant inspect_extra90.Parameter_bases0_name_eq_object:
  description: "inspect.Parameter.__bases__[0].__name__.__eq__('object') == True — Parameter directly inherits from object; wave 250; new to extra90"
  kind: python_call_eq
  function: "Parameter.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant inspect_extra90.Signature_bases0_name_eq_object:
  description: "inspect.Signature.__bases__[0].__name__.__eq__('object') == True — Signature directly inherits from object; wave 250; new to extra90"
  kind: python_call_eq
  function: "Signature.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant inspect_extra90.FullArgSpec_name_eq_FullArgSpec:
  description: "inspect.FullArgSpec.__name__.__eq__('FullArgSpec') == True — FullArgSpec namedtuple __name__ is 'FullArgSpec'; wave 250; new to extra90"
  kind: python_call_eq
  function: FullArgSpec.__name__.__eq__
  args: ["FullArgSpec"]
  expected: true

invariant inspect_extra90.ArgInfo_module_eq_inspect:
  description: "inspect.ArgInfo.__module__.__eq__('inspect') == True — ArgInfo namedtuple __module__ is 'inspect'; wave 250; new to extra90"
  kind: python_call_eq
  function: ArgInfo.__module__.__eq__
  args: ["inspect"]
  expected: true
