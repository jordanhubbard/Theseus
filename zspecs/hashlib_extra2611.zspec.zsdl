spec: hashlib_extra2611
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 621 theme: __init_subclass__, __subclasshook__, and __class_getitem__ dict-presence checks."
    - "hashlib.HASH (type(hashlib.new('sha256'))) does NOT define __init_subclass__ in its own __dict__ — it inherits from object."
    - "hashlib.HASH does NOT define __subclasshook__ in its own __dict__ — this is an ABCMeta hook not relevant to HASH."
    - "hashlib.HASH does NOT define __class_getitem__ in its own __dict__ — no PEP 585 generic alias support on HASH."
    - "hashlib.blake2b and hashlib.blake2s are type objects that likewise do NOT define any of the three dunder methods."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# hashlib.HASH — __init_subclass__, __subclasshook__, __class_getitem__
# type(hashlib.new('sha256')) is the HASH C type from _hashlib
# ---------------------------------------------------------------------------

table hashlib_extra2611.hash_type_init_subclass:
  description: "__init_subclass__ is absent from hashlib HASH type __dict__ — inherited from object, not defined on HASH itself"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2611

  columns: [id, function, args, expected]
  rows:
    - ["hl2611001", "hashlib.new.__class__.__dict__.__contains__", ["__init_subclass__"], false]

table hashlib_extra2611.hash_type_subclasshook:
  description: "__subclasshook__ is absent from hashlib HASH type __dict__ — ABCMeta hook not defined on HASH"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2611

  columns: [id, function, args, expected]
  rows:
    - ["hl2611002", "hashlib.new.__class__.__dict__.__contains__", ["__subclasshook__"], false]

table hashlib_extra2611.hash_type_class_getitem:
  description: "__class_getitem__ is absent from hashlib HASH type __dict__ — no PEP 585 generic alias support on HASH"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2611

  columns: [id, function, args, expected]
  rows:
    - ["hl2611003", "hashlib.new.__class__.__dict__.__contains__", ["__class_getitem__"], false]

table hashlib_extra2611.blake2_dict_presence:
  description: "hashlib.blake2b and hashlib.blake2s do not define __init_subclass__, __subclasshook__, or __class_getitem__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2611

  columns: [id, function, args, expected]
  rows:
    - ["hl2611004", "hashlib.blake2b.__dict__.__contains__", ["__init_subclass__"],  false]
    - ["hl2611005", "hashlib.blake2b.__dict__.__contains__", ["__subclasshook__"],   false]
    - ["hl2611006", "hashlib.blake2b.__dict__.__contains__", ["__class_getitem__"],  false]
    - ["hl2611007", "hashlib.blake2s.__dict__.__contains__", ["__init_subclass__"],  false]
    - ["hl2611008", "hashlib.blake2s.__dict__.__contains__", ["__subclasshook__"],   false]
    - ["hl2611009", "hashlib.blake2s.__dict__.__contains__", ["__class_getitem__"],  false]
