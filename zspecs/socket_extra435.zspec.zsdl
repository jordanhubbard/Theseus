spec: socket_extra435
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module class identity and constants"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "socket.error is an alias for OSError; its __name__ reflects OSError, not 'error'"
    - "AF_INET == 2 and SOCK_STREAM == 1 are POSIX-mandated constants stable across platforms"
    - "SOCK_DGRAM == 2 is stable on all POSIX platforms"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra435.class_identity:
  description: "Identity attributes of socket.socket class and exception classes"
  kind: python_call_eq
  category: identity
  id_prefix: skex

  columns: [id, function, args, expected]
  rows:
    - [skex001, socket.socket.__name__.__eq__,                    ["socket"],  true]
    - [skex002, socket.socket.__module__.__eq__,                  ["socket"],  true]
    - [skex003, "socket.socket.__bases__[0].__name__.__eq__",     ["object"],  true]
    - [skex004, socket.error.__name__.__eq__,                     ["OSError"], true]
    - [skex005, socket.timeout.__name__.__eq__,                   ["timeout"], true]
    - [skex006, socket.timeout.__module__.__eq__,                 ["socket"],  true]
    - [skex007, socket.herror.__name__.__eq__,                    ["herror"],  true]
    - [skex008, socket.gaierror.__name__.__eq__,                  ["gaierror"], true]

table socket_extra435.constants:
  description: "Well-known socket address family and socket type constant values"
  kind: python_call_eq
  category: constants
  id_prefix: skco

  columns: [id, function, args, expected]
  rows:
    - [skco001, socket.AF_INET.__eq__,      [2], true]
    - [skco002, socket.SOCK_STREAM.__eq__,  [1], true]
    - [skco003, socket.SOCK_DGRAM.__eq__,   [2], true]
