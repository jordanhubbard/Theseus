spec: iso8601_duration
version: ">=1.0.0"
backend: node(iso8601-duration)

docs: https://www.npmjs.com/package/iso8601-duration

provenance:
  derived_from:
    - "iso8601-duration README — https://www.npmjs.com/package/iso8601-duration"
    - "Test vectors verified with iso8601-duration via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "iso8601-duration source"
  notes:
    - "iso8601-duration is an npm package. Install: npm install iso8601-duration"
    - "parse(str) parses an ISO 8601 duration string to an object with years/months/weeks/days/hours/minutes/seconds."
    - "toSeconds(duration) converts a parsed duration object to total seconds."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns parsed duration object or total seconds."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table iso8601_duration.parse:
  kind: node_module_call_eq
  function: parse
  category: parse
  id_prefix: isodp

  columns: [id, args, expected]
  rows:
    - [full, ["P3Y6M4DT12H30M5S"],
       {"years": 3, "months": 6, "weeks": 0, "days": 4,
        "hours": 12, "minutes": 30, "seconds": 5}]
    - [time, ["PT1H30M"],
       {"years": 0, "months": 0, "weeks": 0, "days": 0,
        "hours": 1, "minutes": 30, "seconds": 0}]

table iso8601_duration.toSeconds:
  kind: node_module_call_eq
  function: toSeconds
  category: convert
  id_prefix: isodts

  columns: [id, args, expected]
  rows:
    - [one_hour_30m, [{"years": 0, "months": 0, "weeks": 0, "days": 0,
                       "hours": 1, "minutes": 30, "seconds": 0}],
       5400]
    - [one_day,      [{"years": 0, "months": 0, "weeks": 0, "days": 1,
                       "hours": 0, "minutes": 0, "seconds": 0}],
       86400]
