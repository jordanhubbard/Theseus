spec: lodash_assignin
version: ">=4.0.0"
backend: node(lodash.assignin)

docs: https://lodash.com/docs/#assignIn

provenance:
  derived_from:
    - "lodash.assignin README — https://www.npmjs.com/package/lodash.assignin"
    - "Test vectors verified with lodash.assignin@4.2.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.assignin exports the _.assignIn function directly as module.exports."
    - "assignIn(object, ...sources) copies own and inherited enumerable properties."
    - "Like assign but also copies inherited properties."
    - "For plain objects, behavior matches assign."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns target object with properties assigned from sources."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_assignin.assignin:
  kind: node_module_call_eq
  function: ~
  category: assignin
  id_prefix: lai

  columns: [id, args, expected]
  rows:
    - [basic,    [{"a": 1}, {"b": 2}],                {"a": 1, "b": 2}]
    - [multi,    [{"a": 1}, {"b": 2}, {"c": 3}],      {"a": 1, "b": 2, "c": 3}]
    - [override, [{"a": 1, "b": 2}, {"b": 3}],        {"a": 1, "b": 3}]

