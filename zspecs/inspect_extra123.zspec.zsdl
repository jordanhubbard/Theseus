spec: inspect_extra123
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra122.zspec.zsdl."
    - "This spec covers: inspect.isroutine, inspect.ismethod, inspect.ismethoddescriptor function __code__.co_varnames elements not previously covered — isroutine co_varnames[0]='object'(6), co_varnames len=1; ismethod co_varnames[0]='object'(6), co_varnames len=1; ismethoddescriptor co_varnames[0]='object'(6), co_varnames[1]='tp'(2), co_varnames len=2; co_name string lengths; wave 274."
    - "Prior spec extra69 covered ismethod.__code__.co_argcount==1. Prior extra74 covered ismethod.__code__.co_name=='ismethod' and co_argcount==1. Prior extra75 covered isroutine.__code__.co_name=='isroutine' and co_argcount==1; ismethoddescriptor.__code__.co_name=='ismethoddescriptor' and co_argcount==1. New here: the co_varnames elements for all three functions."
    - "inspect.isroutine.__code__.co_varnames[0] == 'object' (len 6). Verified with Python 3.14.3."
    - "inspect.isroutine.__code__.co_varnames.__len__() == 1. Verified with Python 3.14.3."
    - "inspect.ismethod.__code__.co_varnames[0] == 'object' (len 6). Verified with Python 3.14.3."
    - "inspect.ismethod.__code__.co_varnames.__len__() == 1. Verified with Python 3.14.3."
    - "inspect.ismethoddescriptor.__code__.co_varnames[0] == 'object' (len 6). Verified with Python 3.14.3."
    - "inspect.ismethoddescriptor.__code__.co_varnames[1] == 'tp' (len 2). Verified with Python 3.14.3."
    - "inspect.ismethoddescriptor.__code__.co_varnames.__len__() == 2. Verified with Python 3.14.3."
    - "isroutine.__code__.co_name == 'isroutine' (len 9). ismethod.__code__.co_name == 'ismethod' (len 8). ismethoddescriptor.__code__.co_name == 'ismethoddescriptor' (len 18). Verified with Python 3.14.3."
    - "All three predicate functions use 'object' as their first parameter name, consistent with the inspect module convention for predicates that accept any Python object."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.isroutine and ismethod __code__.co_varnames[0] and len
#
# Wave 274 theme: inspect.isroutine(object) and inspect.ismethod(object) are
# pure-Python predicate functions in Lib/inspect.py. Both share the same
# parameter name: co_varnames[0] == 'object' (6 chars). 'object' is the
# conventional parameter name in the inspect module for predicates that
# accept any Python value. Both functions have co_varnames with exactly 1 entry
# (the single declared parameter, no internal locals), reflecting their simple
# implementation as a chain of isinstance/hasattr tests. Prior specs covered
# co_argcount==1 and co_name for both. New here: the string value and length
# of co_varnames[0], and the total co_varnames tuple length.
#
# isroutine.__code__.co_varnames[0] == 'object'  (len 6)
# isroutine.__code__.co_varnames.__len__() == 1
# ismethod.__code__.co_varnames[0] == 'object'   (len 6)
# ismethod.__code__.co_varnames.__len__() == 1
#
# New to extra123.
# ---------------------------------------------------------------------------

table inspect_extra123.isroutine_ismethod_co_varnames:
  description: "inspect.isroutine and ismethod co_varnames[0]='object'(6); both have tuple len=1; shared parameter name 'object' is the inspect module convention for single-arg predicates; prior extra74/75 covered co_name and co_argcount; wave 274; new to extra123"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectircv123

  columns: [id, function, args, expected, description]
  rows:
    - [isroutine_cv0_eq,
       "isroutine.__code__.co_varnames.__getitem__",
       [0],
       "object",
       "inspect.isroutine.__code__.co_varnames[0] == 'object' — the sole parameter of isroutine(object); 'object' is the conventional inspect module parameter name for predicates accepting any Python value; tuple.__getitem__(0) returns 'object'; new to extra123"]
    - [isroutine_cv0_len,
       "isroutine.__code__.co_varnames.__getitem__(0).__len__",
       [],
       6,
       "inspect.isroutine.__code__.co_varnames[0].__len__() == 6 — 'object' has 6 chars: o-b-j-e-c-t; same length as ismethod co_varnames[0] and ismethoddescriptor co_varnames[0] (all 'object', 6 chars); str.__len__() returns 6; new to extra123"]
    - [isroutine_cv_len,
       "isroutine.__code__.co_varnames.__len__",
       [],
       1,
       "inspect.isroutine.__code__.co_varnames.__len__() == 1 — isroutine has only 1 local variable name: 'object'; no internal locals; its implementation is a single boolean expression checking multiple type predicates; tuple.__len__() returns 1; new to extra123"]
    - [ismethod_cv0_eq,
       "ismethod.__code__.co_varnames.__getitem__",
       [0],
       "object",
       "inspect.ismethod.__code__.co_varnames[0] == 'object' — the sole parameter of ismethod(object); same parameter name as isroutine; both are single-argument inspect predicates using 'object' as the conventional name; tuple.__getitem__(0) returns 'object'; new to extra123"]
    - [ismethod_cv0_len,
       "ismethod.__code__.co_varnames.__getitem__(0).__len__",
       [],
       6,
       "inspect.ismethod.__code__.co_varnames[0].__len__() == 6 — 'object' has 6 chars; same as isroutine co_varnames[0] and ismethoddescriptor co_varnames[0]; str.__len__() returns 6; new to extra123"]
    - [ismethod_cv_len,
       "ismethod.__code__.co_varnames.__len__",
       [],
       1,
       "inspect.ismethod.__code__.co_varnames.__len__() == 1 — ismethod has only 1 local variable name: 'object'; simple predicate returning isinstance(object, types.MethodType); tuple.__len__() returns 1; new to extra123"]

# ---------------------------------------------------------------------------
# Table 2: inspect.ismethoddescriptor __code__.co_varnames elements and length
#
# Wave 274 theme: inspect.ismethoddescriptor(object) is more complex than
# isroutine and ismethod: its co_varnames has 2 entries:
#   co_varnames[0] == 'object' (6 chars) — the input object to test
#   co_varnames[1] == 'tp'     (2 chars) — a local holding type(object)
# The internal local 'tp' is used in the implementation to avoid calling
# type() multiple times. ismethoddescriptor also has the longest co_name
# among the three predicates: 'ismethoddescriptor' (18 chars), compared to
# 'isroutine' (9) and 'ismethod' (8). co_argcount is still 1 (only 'object'
# is a declared parameter); 'tp' is a purely internal local.
#
# ismethoddescriptor.__code__.co_varnames[0] == 'object'  (len 6)
# ismethoddescriptor.__code__.co_varnames[1] == 'tp'      (len 2)
# ismethoddescriptor.__code__.co_varnames.__len__() == 2
#
# New to extra123.
# ---------------------------------------------------------------------------

table inspect_extra123.ismethoddescriptor_co_varnames:
  description: "inspect.ismethoddescriptor co_varnames[0]='object'(6), [1]='tp'(2); tuple len=2; more complex than isroutine/ismethod (both len=1); 'tp' is local holding type(object); co_name='ismethoddescriptor'(18); wave 274; new to extra123"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectimdc123

  columns: [id, function, args, expected, description]
  rows:
    - [imd_cv0_eq,
       "ismethoddescriptor.__code__.co_varnames.__getitem__",
       [0],
       "object",
       "inspect.ismethoddescriptor.__code__.co_varnames[0] == 'object' — first parameter; the same 'object' convention as isroutine and ismethod; ismethoddescriptor(object) returns True if object is a method descriptor but not a method/class/function; tuple.__getitem__(0) returns 'object'; new to extra123"]
    - [imd_cv0_len,
       "ismethoddescriptor.__code__.co_varnames.__getitem__(0).__len__",
       [],
       6,
       "inspect.ismethoddescriptor.__code__.co_varnames[0].__len__() == 6 — 'object' has 6 chars; same as isroutine/ismethod co_varnames[0]; all three inspect predicates share this parameter name; str.__len__() returns 6; new to extra123"]
    - [imd_cv1_eq,
       "ismethoddescriptor.__code__.co_varnames.__getitem__",
       [1],
       "tp",
       "inspect.ismethoddescriptor.__code__.co_varnames[1] == 'tp' — internal local holding type(object); used to avoid repeated type() calls when checking for __get__ and absence of __set__ and __delete__; tuple.__getitem__(1) returns 'tp'; new to extra123"]
    - [imd_cv1_len,
       "ismethoddescriptor.__code__.co_varnames.__getitem__(1).__len__",
       [],
       2,
       "inspect.ismethoddescriptor.__code__.co_varnames[1].__len__() == 2 — 'tp' has 2 chars: t-p; the shortest co_varnames entry among the three predicates; abbreviation for 'type'; str.__len__() returns 2; new to extra123"]
    - [imd_cv_len,
       "ismethoddescriptor.__code__.co_varnames.__len__",
       [],
       2,
       "inspect.ismethoddescriptor.__code__.co_varnames.__len__() == 2 — ismethoddescriptor has 2 local variable names: 'object' (parameter) and 'tp' (internal local); more than isroutine/ismethod (both 1); tuple.__len__() returns 2; new to extra123"]

# ---------------------------------------------------------------------------
# Table 3: inspect isroutine/ismethod/ismethoddescriptor co_name string lengths
#
# Wave 274 theme: The three predicates have co_name values equal to their
# function names, with different lengths:
#   isroutine.__code__.co_name        == 'isroutine'         (len  9)
#   ismethod.__code__.co_name         == 'ismethod'          (len  8)
#   ismethoddescriptor.__code__.co_name == 'ismethoddescriptor' (len 18)
# ismethoddescriptor is the longest at 18 chars — double the length of
# isroutine (9) and more than twice ismethod (8). All three have co_argcount==1.
# The co_name lengths reflect the naming convention: shorter predicates have
# shorter names. The 'ismethoddescriptor' name's length (18) is exactly 2x
# isroutine (9). Prior extra74/75 covered co_name equality for all three.
# New here: the character length of each co_name string.
#
# isroutine.__code__.co_name.__len__()         == 9
# ismethod.__code__.co_name.__len__()          == 8
# ismethoddescriptor.__code__.co_name.__len__() == 18
#
# New to extra123.
# ---------------------------------------------------------------------------

table inspect_extra123.predicate_co_name_lengths:
  description: "inspect predicate co_name lengths: isroutine=9, ismethod=8, ismethoddescriptor=18; ismethoddescriptor is 2x isroutine (18=2*9); all co_argcount=1; prior extra74/75 covered co_name equality; wave 274; new to extra123"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectpcnl123

  columns: [id, function, args, expected, description]
  rows:
    - [isroutine_coname_len,
       "isroutine.__code__.co_name.__len__",
       [],
       9,
       "inspect.isroutine.__code__.co_name.__len__() == 9 — 'isroutine' has 9 chars: i-s-r-o-u-t-i-n-e; 1 more than ismethod (8); half of ismethoddescriptor (18); prior extra75 confirmed co_name=='isroutine'; str.__len__() returns 9; new to extra123"]
    - [ismethod_coname_len,
       "ismethod.__code__.co_name.__len__",
       [],
       8,
       "inspect.ismethod.__code__.co_name.__len__() == 8 — 'ismethod' has 8 chars: i-s-m-e-t-h-o-d; 1 less than isroutine (9) and 10 less than ismethoddescriptor (18); prior extra74 confirmed co_name=='ismethod'; str.__len__() returns 8; new to extra123"]
    - [imd_coname_len,
       "ismethoddescriptor.__code__.co_name.__len__",
       [],
       18,
       "inspect.ismethoddescriptor.__code__.co_name.__len__() == 18 — 'ismethoddescriptor' has 18 chars; exactly 2x isroutine (9) and more than 2x ismethod (8); prior extra75 confirmed co_name=='ismethoddescriptor'; str.__len__() returns 18; new to extra123"]
    - [imd_coname_gt_isroutine,
       "ismethoddescriptor.__code__.co_name.__len__().__gt__",
       [9],
       true,
       "inspect.ismethoddescriptor.__code__.co_name.__len__().__gt__(9) == True — 'ismethoddescriptor' (18) is longer than 'isroutine' (9); int.__gt__(9) returns True; new to extra123"]
    - [isroutine_coname_gt_ismethod,
       "isroutine.__code__.co_name.__len__().__gt__",
       [8],
       true,
       "inspect.isroutine.__code__.co_name.__len__().__gt__(8) == True — 'isroutine' (9) is longer than 'ismethod' (8); int.__gt__(8) returns True; new to extra123"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra123
# ---------------------------------------------------------------------------

invariant inspect_extra123.isroutine_cv0_object:
  description: "inspect.isroutine.__code__.co_varnames[0] == 'object' — sole parameter; 6 chars; same convention as ismethod/ismethoddescriptor; prior extra75 covered co_name; wave 274; new to extra123"
  kind: python_call_eq
  function: "isroutine.__code__.co_varnames.__getitem__"
  args: [0]
  expected: "object"

invariant inspect_extra123.ismethod_cv0_object:
  description: "inspect.ismethod.__code__.co_varnames[0] == 'object' — sole parameter; 6 chars; shared with isroutine and ismethoddescriptor; prior extra74 covered co_name; wave 274; new to extra123"
  kind: python_call_eq
  function: "ismethod.__code__.co_varnames.__getitem__"
  args: [0]
  expected: "object"

invariant inspect_extra123.imd_cv1_tp:
  description: "inspect.ismethoddescriptor.__code__.co_varnames[1] == 'tp' — internal local holding type(object); 2 chars; shortest entry among all predicate co_varnames; wave 274; new to extra123"
  kind: python_call_eq
  function: "ismethoddescriptor.__code__.co_varnames.__getitem__"
  args: [1]
  expected: "tp"

invariant inspect_extra123.imd_cv_len:
  description: "inspect.ismethoddescriptor.__code__.co_varnames.__len__() == 2 — 'object' + 'tp'; more than isroutine/ismethod (both len=1); more complex implementation; wave 274; new to extra123"
  kind: python_call_eq
  function: "ismethoddescriptor.__code__.co_varnames.__len__"
  args: []
  expected: 2

invariant inspect_extra123.imd_coname_len:
  description: "inspect.ismethoddescriptor.__code__.co_name.__len__() == 18 — 'ismethoddescriptor' is the longest co_name of the three predicates; 2x isroutine (9); prior extra75 confirmed co_name equality; wave 274; new to extra123"
  kind: python_call_eq
  function: "ismethoddescriptor.__code__.co_name.__len__"
  args: []
  expected: 18

