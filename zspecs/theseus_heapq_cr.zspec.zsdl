spec: theseus_heapq_cr
version: ">=3.8"
backend: python_cleanroom(theseus_heapq_cr)
blocks: heapq

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/heapq.html"
  not_derived_from:
    - "CPython source: Lib/heapq.py (internal implementation)"
  notes:
    - "Clean-room heapq module. Do NOT import heapq."

error_model: python_exceptions

invariant theseus_heapq_cr.heapq2_push_pop:
  description: "heappush + heappop maintains heap invariant"
  category: heappush
  kind: python_call_eq
  function: heapq2_push_pop
  args: []
  expected: 1

invariant theseus_heapq_cr.heapq2_heapify:
  description: "heapify converts list to valid heap in-place"
  category: heapify
  kind: python_call_eq
  function: heapq2_heapify
  args: []
  expected: true

invariant theseus_heapq_cr.heapq2_nsmallest:
  description: "nsmallest(3, [5,3,1,4,2]) returns [1,2,3]"
  category: nsmallest
  kind: python_call_eq
  function: heapq2_nsmallest
  args: []
  expected: true
