spec: collections_extra31
version: ">=3.9"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html — Python collections module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
    - "CPython source: Modules/_collectionsmodule.c"
  notes:
    - "This spec extends collections_extra30.zspec.zsdl."
    - "Prior specs covered: OrderedDict/defaultdict/Counter/deque/ChainMap/UserDict/UserList/UserString __name__/__module__/__qualname__/__bases__, namedtuple, collections.__name__/__package__, collections.abc.__name__, various class __module__ checks, __bases__[0].__name__ for all eight classes."
    - "This spec covers: __module__.__len__() for all eight core collection classes; __name__.__len__() for OrderedDict/defaultdict/Counter/deque."
    - "Key findings: all eight classes share __module__ == 'collections' (len 11); OrderedDict and defaultdict __name__ len == 11, Counter len == 7, deque len == 5."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__len__() table — module string length for all core classes
#
# All eight core collection classes (OrderedDict, defaultdict, Counter, deque,
# ChainMap, UserDict, UserList, UserString) report __module__ == 'collections'.
# The string 'collections' has length 11. This table verifies the length of
# that module string via __len__, complementing prior __module__.__eq__ checks.
# No prior collections spec records __module__.__len__() for all eight classes
# together in the extra31 namespace.
# ---------------------------------------------------------------------------

table collections_extra31.module_str_lengths:
  kind: python_call_eq
  category: string_properties
  columns: [id, function, args, expected, description]
  rows:
    - [collections_extra31.module_str_lengths.ordereddict,
       OrderedDict.__module__.__len__,
       [],
       11,
       "len(collections.OrderedDict.__module__) == 11"]
    - [collections_extra31.module_str_lengths.defaultdict,
       defaultdict.__module__.__len__,
       [],
       11,
       "len(collections.defaultdict.__module__) == 11"]
    - [collections_extra31.module_str_lengths.counter,
       Counter.__module__.__len__,
       [],
       11,
       "len(collections.Counter.__module__) == 11"]
    - [collections_extra31.module_str_lengths.deque,
       deque.__module__.__len__,
       [],
       11,
       "len(collections.deque.__module__) == 11"]
    - [collections_extra31.module_str_lengths.chainmap,
       ChainMap.__module__.__len__,
       [],
       11,
       "len(collections.ChainMap.__module__) == 11"]
    - [collections_extra31.module_str_lengths.userdict,
       UserDict.__module__.__len__,
       [],
       11,
       "len(collections.UserDict.__module__) == 11"]
    - [collections_extra31.module_str_lengths.userlist,
       UserList.__module__.__len__,
       [],
       11,
       "len(collections.UserList.__module__) == 11"]
    - [collections_extra31.module_str_lengths.userstring,
       UserString.__module__.__len__,
       [],
       11,
       "len(collections.UserString.__module__) == 11"]

# ---------------------------------------------------------------------------
# __name__.__len__() table — name string lengths for dict-subclass and deque
#
# The four classes OrderedDict, defaultdict, Counter, and deque have different
# name lengths. OrderedDict and defaultdict both have 11 characters; Counter
# has 7; deque has 5. This table captures the diversity in name lengths across
# the four most commonly used collection classes. No prior collections spec
# records __name__.__len__() for these four classes together in the extra31
# namespace.
# ---------------------------------------------------------------------------

table collections_extra31.name_str_lengths:
  kind: python_call_eq
  category: string_properties
  columns: [id, function, args, expected, description]
  rows:
    - [collections_extra31.name_str_lengths.ordereddict,
       OrderedDict.__name__.__len__,
       [],
       11,
       "len(collections.OrderedDict.__name__) == 11"]
    - [collections_extra31.name_str_lengths.defaultdict,
       defaultdict.__name__.__len__,
       [],
       11,
       "len(collections.defaultdict.__name__) == 11"]
    - [collections_extra31.name_str_lengths.counter,
       Counter.__name__.__len__,
       [],
       7,
       "len(collections.Counter.__name__) == 7"]
    - [collections_extra31.name_str_lengths.deque,
       deque.__name__.__len__,
       [],
       5,
       "len(collections.deque.__name__) == 5"]

# ---------------------------------------------------------------------------
# OrderedDict.__module__.__len__() — standalone string length
#
# collections.OrderedDict.__module__ is 'collections', a string of length 11.
# This standalone invariant isolates the module string length for OrderedDict,
# the most commonly used ordered mapping in the standard library. All eight
# core collection classes share this same module string length; this standalone
# calls it out for OrderedDict specifically. No prior collections spec records
# this standalone in the extra31 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra31.OrderedDict.module_len:
  description: "len(collections.OrderedDict.__module__) == 11"
  category: string_properties
  kind: python_call_eq
  function: OrderedDict.__module__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# deque.__name__.__len__() — standalone name string length
#
# collections.deque.__name__ is 'deque', a string of length 5. This is the
# shortest name among the eight core collection classes. deque is a C-level
# doubly-linked list type implementing efficient appends and pops from both
# ends. Its short name reflects its origins as a direct port of the STL deque
# data structure. No prior collections spec records this standalone in the
# extra31 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra31.deque.name_len:
  description: "len(collections.deque.__name__) == 5"
  category: string_properties
  kind: python_call_eq
  function: deque.__name__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# Counter.__name__.__len__() — standalone name string length
#
# collections.Counter.__name__ is 'Counter', a string of length 7. Counter is
# a dict subclass for counting hashable objects. Its name length (7) is shorter
# than OrderedDict/defaultdict (11) but longer than deque (5). No prior
# collections spec records this standalone in the extra31 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra31.Counter.name_len:
  description: "len(collections.Counter.__name__) == 7"
  category: string_properties
  kind: python_call_eq
  function: Counter.__name__.__len__
  args: []
  expected: 7
