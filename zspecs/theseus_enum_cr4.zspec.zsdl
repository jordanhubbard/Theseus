spec: theseus_enum_cr4
version: ">=3.9"
backend: python_cleanroom(theseus_enum_cr4)
blocks: enum

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html"
    - "PEP 435 — Adding an Enum type to Python"
  notes:
    - "Clean-room extended enum utilities. Do NOT import enum."
    - "IntEnum: Enum subclass where members are also int subclass instances."
    - "unique: class decorator that raises ValueError if any duplicate values exist."
    - "enum4_intenum(): class Status(IntEnum): OK=200; Status.OK == 200 and isinstance(Status.OK, int)."
    - "enum4_unique(): @unique with duplicate raises ValueError — returns True (error caught)."
    - "enum4_intenum_compare(): Status.OK > 0 — returns True (IntEnum supports int comparison)."
    - "Zero-arg invariant signatures — def enum4_intenum(): return bool"
    - "IntEnum members are int subclasses: isinstance(member, int) == True."
    - "unique decorator: check all member values are distinct; raise ValueError if not."
    - "IntEnum supports all int operations: comparison, arithmetic, etc."
    - "Export: Enum, IntEnum, Flag, IntFlag, auto, unique, EnumMeta."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_enum_cr4.intenum:
  description: "IntEnum member equals its int value and is an int instance"
  category: IntEnum
  kind: python_call_eq
  function: enum4_intenum
  args: []
  expected: true

invariant theseus_enum_cr4.unique:
  description: "@unique raises ValueError for duplicate values"
  category: unique
  kind: python_call_eq
  function: enum4_unique
  args: []
  expected: true

invariant theseus_enum_cr4.intenum_compare:
  description: "IntEnum member supports integer comparison"
  category: IntEnum
  kind: python_call_eq
  function: enum4_intenum_compare
  args: []
  expected: true
