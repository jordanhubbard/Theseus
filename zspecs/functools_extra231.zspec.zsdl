spec: functools_extra231
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers functools module __dict__ membership checks for all major public names and constants."
    - "functools.__dict__.__contains__('reduce') == True — reduce is a C extension function in functools. Verified with Python 3.14.3."
    - "functools.__dict__.__contains__('partial') == True — partial is a C extension type in functools. Verified with Python 3.14.3."
    - "functools.__dict__.__contains__('lru_cache') == True — lru_cache is a Python decorator in functools. Verified with Python 3.14.3."
    - "functools.__dict__.__contains__('singledispatch') == True — singledispatch is a Python decorator in functools. Verified with Python 3.14.3."
    - "functools.__dict__.__contains__('cached_property') == True — cached_property is a Python descriptor class in functools. Verified with Python 3.14.3."
    - "functools.__dict__.__contains__('wraps') == True — wraps is a Python decorator in functools. Verified with Python 3.14.3."
    - "functools.__dict__.__contains__('update_wrapper') == True — update_wrapper is a Python function in functools. Verified with Python 3.14.3."
    - "functools.__dict__.__contains__('total_ordering') == True — total_ordering is a Python class decorator in functools. Verified with Python 3.14.3."
    - "functools.__dict__.__contains__('partialmethod') == True — partialmethod is a Python descriptor class in functools. Verified with Python 3.14.3."
    - "functools.__dict__.__contains__('WRAPPER_ASSIGNMENTS') == True — WRAPPER_ASSIGNMENTS is a tuple constant in functools. Verified with Python 3.14.3."
    - "functools.__dict__.__contains__('WRAPPER_UPDATES') == True — WRAPPER_UPDATES is a tuple constant in functools. Verified with Python 3.14.3."
    - "functools.__dict__.__class__.__name__ == 'dict' — the module __dict__ is a plain dict (not a mappingproxy). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.__dict__.__contains__ — core functions and decorators
#
# functools.__dict__.__contains__('reduce') == True
# functools.__dict__.__contains__('partial') == True
# functools.__dict__.__contains__('lru_cache') == True
# functools.__dict__.__contains__('singledispatch') == True
# functools.__dict__.__contains__('cached_property') == True
#
# All are public names in the functools module registered in its __dict__.
# New to extra231.
# ---------------------------------------------------------------------------

table functools_extra231.module_dict_contains_core:
  description: "functools.__dict__.__contains__: reduce True, partial True, lru_cache True, singledispatch True, cached_property True; new to extra231"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra231dictcore

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_reduce,
       __dict__.__contains__,
       ["reduce"],
       true,
       "functools.__dict__.__contains__('reduce') == True — reduce is a C extension function registered in the functools module dict; it applies a two-argument function cumulatively; dict.__contains__('reduce') returns True; new to extra231"]
    - [dict_contains_partial,
       __dict__.__contains__,
       ["partial"],
       true,
       "functools.__dict__.__contains__('partial') == True — partial is a C extension type registered in the functools module dict; it creates a new function with partial application; dict.__contains__('partial') returns True; new to extra231"]
    - [dict_contains_lru_cache,
       __dict__.__contains__,
       ["lru_cache"],
       true,
       "functools.__dict__.__contains__('lru_cache') == True — lru_cache is a Python decorator registered in the functools module dict; it memoizes function results with a least-recently-used cache; dict.__contains__('lru_cache') returns True; new to extra231"]
    - [dict_contains_singledispatch,
       __dict__.__contains__,
       ["singledispatch"],
       true,
       "functools.__dict__.__contains__('singledispatch') == True — singledispatch is a Python decorator registered in the functools module dict; it transforms a function into a single-dispatch generic function; dict.__contains__('singledispatch') returns True; new to extra231"]
    - [dict_contains_cached_property,
       __dict__.__contains__,
       ["cached_property"],
       true,
       "functools.__dict__.__contains__('cached_property') == True — cached_property is a Python descriptor class registered in the functools module dict; it transforms a method into a lazy attribute; dict.__contains__('cached_property') returns True; new to extra231"]

# ---------------------------------------------------------------------------
# Table 2: functools.__dict__.__contains__ — wrapper utilities and ordering
#
# functools.__dict__.__contains__('wraps') == True
# functools.__dict__.__contains__('update_wrapper') == True
# functools.__dict__.__contains__('total_ordering') == True
# functools.__dict__.__contains__('partialmethod') == True
#
# New to extra231.
# ---------------------------------------------------------------------------

table functools_extra231.module_dict_contains_wrappers:
  description: "functools.__dict__.__contains__: wraps True, update_wrapper True, total_ordering True, partialmethod True; new to extra231"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra231dictwrap

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_wraps,
       __dict__.__contains__,
       ["wraps"],
       true,
       "functools.__dict__.__contains__('wraps') == True — wraps is a Python decorator registered in the functools module dict; it updates a wrapper function to look like the wrapped function; dict.__contains__('wraps') returns True; new to extra231"]
    - [dict_contains_update_wrapper,
       __dict__.__contains__,
       ["update_wrapper"],
       true,
       "functools.__dict__.__contains__('update_wrapper') == True — update_wrapper is a Python function registered in the functools module dict; it updates a wrapper function to look like the wrapped function; dict.__contains__('update_wrapper') returns True; new to extra231"]
    - [dict_contains_total_ordering,
       __dict__.__contains__,
       ["total_ordering"],
       true,
       "functools.__dict__.__contains__('total_ordering') == True — total_ordering is a Python class decorator registered in the functools module dict; it fills in missing ordering methods given __eq__ and one of __lt__/__le__/__gt__/__ge__; dict.__contains__('total_ordering') returns True; new to extra231"]
    - [dict_contains_partialmethod,
       __dict__.__contains__,
       ["partialmethod"],
       true,
       "functools.__dict__.__contains__('partialmethod') == True — partialmethod is a Python descriptor class registered in the functools module dict; it is like partial but designed to be used as a method definition; dict.__contains__('partialmethod') returns True; new to extra231"]

# ---------------------------------------------------------------------------
# Table 3: functools.__dict__.__contains__ — constants and dict class
#
# functools.__dict__.__contains__('WRAPPER_ASSIGNMENTS') == True
# functools.__dict__.__contains__('WRAPPER_UPDATES') == True
# functools.__dict__.__class__.__name__ == 'dict'
#
# New to extra231.
# ---------------------------------------------------------------------------

table functools_extra231.module_dict_constants:
  description: "functools.__dict__.__contains__: WRAPPER_ASSIGNMENTS True, WRAPPER_UPDATES True; __dict__.__class__.__name__ == 'dict'; new to extra231"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra231dictconst

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_wrapper_assignments,
       __dict__.__contains__,
       ["WRAPPER_ASSIGNMENTS"],
       true,
       "functools.__dict__.__contains__('WRAPPER_ASSIGNMENTS') == True — WRAPPER_ASSIGNMENTS is a tuple constant registered in the functools module dict listing the attributes copied by update_wrapper; dict.__contains__('WRAPPER_ASSIGNMENTS') returns True; new to extra231"]
    - [dict_contains_wrapper_updates,
       __dict__.__contains__,
       ["WRAPPER_UPDATES"],
       true,
       "functools.__dict__.__contains__('WRAPPER_UPDATES') == True — WRAPPER_UPDATES is a tuple constant registered in the functools module dict listing the attributes updated by update_wrapper; dict.__contains__('WRAPPER_UPDATES') returns True; new to extra231"]
    - [dict_class_name_dict,
       __dict__.__class__.__name__.__eq__,
       ["dict"],
       true,
       "functools.__dict__.__class__.__name__ == 'dict' — the functools module __dict__ is a plain Python dict (not a mappingproxy); __class__.__name__.__eq__('dict') returns True; new to extra231"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra231
# ---------------------------------------------------------------------------

invariant functools_extra231.dict_contains_reduce:
  description: "functools.__dict__.__contains__('reduce') == True — reduce is in module dict; new to extra231"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["reduce"]
  expected: true

invariant functools_extra231.dict_contains_partial:
  description: "functools.__dict__.__contains__('partial') == True — partial is in module dict; new to extra231"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["partial"]
  expected: true

invariant functools_extra231.dict_contains_lru_cache:
  description: "functools.__dict__.__contains__('lru_cache') == True — lru_cache is in module dict; new to extra231"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["lru_cache"]
  expected: true

invariant functools_extra231.dict_contains_singledispatch:
  description: "functools.__dict__.__contains__('singledispatch') == True — singledispatch is in module dict; new to extra231"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["singledispatch"]
  expected: true

invariant functools_extra231.dict_contains_cached_property:
  description: "functools.__dict__.__contains__('cached_property') == True — cached_property is in module dict; new to extra231"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["cached_property"]
  expected: true

invariant functools_extra231.dict_contains_wraps:
  description: "functools.__dict__.__contains__('wraps') == True — wraps is in module dict; new to extra231"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["wraps"]
  expected: true

invariant functools_extra231.dict_contains_update_wrapper:
  description: "functools.__dict__.__contains__('update_wrapper') == True — update_wrapper is in module dict; new to extra231"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["update_wrapper"]
  expected: true

invariant functools_extra231.dict_contains_total_ordering:
  description: "functools.__dict__.__contains__('total_ordering') == True — total_ordering is in module dict; new to extra231"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["total_ordering"]
  expected: true

invariant functools_extra231.dict_contains_partialmethod:
  description: "functools.__dict__.__contains__('partialmethod') == True — partialmethod is in module dict; new to extra231"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["partialmethod"]
  expected: true

invariant functools_extra231.dict_contains_wrapper_assignments:
  description: "functools.__dict__.__contains__('WRAPPER_ASSIGNMENTS') == True — WRAPPER_ASSIGNMENTS is in module dict; new to extra231"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["WRAPPER_ASSIGNMENTS"]
  expected: true

invariant functools_extra231.dict_contains_wrapper_updates:
  description: "functools.__dict__.__contains__('WRAPPER_UPDATES') == True — WRAPPER_UPDATES is in module dict; new to extra231"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["WRAPPER_UPDATES"]
  expected: true

invariant functools_extra231.dict_class_name_dict:
  description: "functools.__dict__.__class__.__name__ == 'dict' — module __dict__ is a plain dict; new to extra231"
  kind: python_call_eq
  function: __dict__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true
