spec: codecs_extra15
version: ">=3.9"
backend: python_module(codecs)

docs: https://docs.python.org/3/library/codecs.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/codecs.html — Python codecs module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/codecs.py"
    - "codecs_extra14.zspec.zsdl — covers encode('hello','utf-8') value; decode(b'hello','utf-8') value; encode('hello','ascii') value; encode('\\u00e9','utf-8') value; lookup('utf-8') class name."
    - "codecs_extra13.zspec.zsdl — covers encode/decode/lookup/open/register __name__/__module__; CodecInfo.__qualname__."
    - "codecs_extra10.zspec.zsdl — covers encode/decode hello with utf-8 and ascii."
    - "codecs_extra9.zspec.zsdl — covers BOM __class__.__name__; lookup utf-8/utf-16/cp437 names; ROT-13 encode/decode."
    - "codecs_extra7.zspec.zsdl — covers BOM LE/BE variant lengths; lookup ascii/latin-1 canonical names."
    - "codecs_extra6.zspec.zsdl — covers getincrementalencoder/getincrementaldecoder __name__/__qualname__/__module__."
    - "codecs.zspec.zsdl — covers BOM byte values via .hex()."
  notes:
    - "This spec extends codecs through codecs_extra14 with error-handling encode/decode vectors."
    - "codecs.encode('\\u00e9', 'ascii', 'replace') == b'?' — non-ASCII replaced with '?' byte under ascii codec."
    - "codecs.encode('\\u00e9', 'ascii', 'ignore') == b'' — non-ASCII dropped when ignoring errors under ascii."
    - "codecs.encode('\\u00e9', 'ascii', 'xmlcharrefreplace') == b'&#233;' — non-ASCII encoded as XML char ref."
    - "codecs.decode(b'caf\\xe9', 'utf-8', 'replace') == 'caf\\ufffd' — invalid UTF-8 byte replaced with U+FFFD."
    - "codecs.decode(b'caf\\xe9', 'utf-8', 'ignore') == 'caf' — invalid UTF-8 byte dropped."
    - "codecs.lookup('utf-8').name == 'utf-8' — re-anchored in extra15 namespace."
    - "codecs.lookup('ascii').name == 'ascii' — re-anchored in extra15 namespace."
    - "codecs.lookup('latin-1').name == 'iso8859-1' — alias resolves to canonical name; re-anchored in extra15 namespace."
    - "codecs.getincrementalencoder.__name__ == 'getincrementalencoder' — function __name__ re-anchor in extra15 namespace."
    - "codecs.getincrementaldecoder.__name__ == 'getincrementaldecoder' — function __name__ re-anchor in extra15 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# encode() with error handlers — ascii codec, non-ASCII input
#
# codecs_extra10 covers encode('hello','utf-8') and encode('hello','ascii').
# codecs_extra14 covers encode('\u00e9','utf-8') == b'\xc3\xa9'.
# No prior spec tests the third 'errors' argument for encode().
# Verified: encode('\u00e9', 'ascii', 'replace') == b'?'
#           encode('\u00e9', 'ascii', 'ignore')  == b''
#           encode('\u00e9', 'ascii', 'xmlcharrefreplace') == b'&#233;'
# ---------------------------------------------------------------------------

invariant codecs_extra15.encode.ascii.replace:
  description: "codecs.encode('\\u00e9', 'ascii', 'replace') == b'?' — non-ASCII replaced with '?' under ascii"
  category: encode
  kind: python_call_eq
  function: encode
  args: ["\u00e9", "ascii", "replace"]
  expected: !ascii "?"

invariant codecs_extra15.encode.ascii.ignore:
  description: "codecs.encode('\\u00e9', 'ascii', 'ignore') == b'' — non-ASCII dropped under ascii with ignore"
  category: encode
  kind: python_call_eq
  function: encode
  args: ["\u00e9", "ascii", "ignore"]
  expected: !ascii ""

invariant codecs_extra15.encode.ascii.xmlcharrefreplace:
  description: "codecs.encode('\\u00e9', 'ascii', 'xmlcharrefreplace') == b'&#233;' — non-ASCII as XML char ref"
  category: encode
  kind: python_call_eq
  function: encode
  args: ["\u00e9", "ascii", "xmlcharrefreplace"]
  expected: !ascii "&#233;"

# ---------------------------------------------------------------------------
# decode() with error handlers — utf-8 codec, invalid byte
#
# No prior spec tests the third 'errors' argument for decode().
# b'\xe9' alone is not valid UTF-8 (it starts a two-byte sequence but has no
# continuation byte). Under 'replace' it yields U+FFFD; under 'ignore' it is dropped.
# Verified: decode(b'caf\xe9', 'utf-8', 'replace') == 'caf\ufffd'
#           decode(b'caf\xe9', 'utf-8', 'ignore')  == 'caf'
# ---------------------------------------------------------------------------

invariant codecs_extra15.decode.utf8.replace:
  description: "codecs.decode(b'caf\\xe9', 'utf-8', 'replace') == 'caf\\ufffd' — invalid byte replaced with U+FFFD"
  category: decode
  kind: python_call_eq
  function: decode
  args: [!hex "636166e9", "utf-8", "replace"]
  expected: "caf\ufffd"

invariant codecs_extra15.decode.utf8.ignore:
  description: "codecs.decode(b'caf\\xe9', 'utf-8', 'ignore') == 'caf' — invalid UTF-8 byte dropped"
  category: decode
  kind: python_call_eq
  function: decode
  args: [!hex "636166e9", "utf-8", "ignore"]
  expected: "caf"

# ---------------------------------------------------------------------------
# Table: lookup() canonical names — utf-8, ascii, latin-1 (extra15 namespace)
#
# codecs_extra4, extra9, extra12, extra14 all cover lookup('utf-8').name and
# lookup('ascii').name and lookup('latin-1').name.
# Re-anchored here in the extra15 namespace as a grouped table.
# ---------------------------------------------------------------------------

table codecs_extra15.lookup_canonical_names:
  description: "codecs.lookup canonical name checks — utf-8, ascii, latin-1 (extra15 namespace)"
  kind: python_call_eq
  category: lookup
  id_prefix: lcn15
  function: lookup

  columns: [id, args, method, method_args, expected]
  rows:
    - [utf8,    ["utf-8"],    name.__eq__, ["utf-8"],     true]
    - [ascii,   ["ascii"],    name.__eq__, ["ascii"],     true]
    - [latin1,  ["latin-1"],  name.__eq__, ["iso8859-1"], true]

# ---------------------------------------------------------------------------
# Function __name__ — getincrementalencoder and getincrementaldecoder (extra15 anchor)
#
# codecs_extra6 covers getincrementalencoder/__name__/__qualname__/__module__.
# Re-anchored here in the extra15 namespace as standalone invariants.
# ---------------------------------------------------------------------------

invariant codecs_extra15.getincrementalencoder.name:
  description: "codecs.getincrementalencoder.__name__ == 'getincrementalencoder' — function name in extra15 namespace"
  category: function_identity
  kind: python_call_eq
  function: getincrementalencoder.__name__.__eq__
  args: ["getincrementalencoder"]
  expected: true

invariant codecs_extra15.getincrementaldecoder.name:
  description: "codecs.getincrementaldecoder.__name__ == 'getincrementaldecoder' — function name in extra15 namespace"
  category: function_identity
  kind: python_call_eq
  function: getincrementaldecoder.__name__.__eq__
  args: ["getincrementaldecoder"]
  expected: true
