    - [socket_module_socket,    "socket.__module__.__eq__",            ["socket"], true, "socket.socket.__module__ == 'socket' (6 chars; public module; distinguishes from _socket C extension)"]
    - [socket_bases_socket,     "socket.__bases__[0].__name__.__eq__", ["socket"], true, "socket.socket.__bases__[0].__name__ == 'socket' (6 chars; base is _socket.socket, also named 'socket')"]
    - [socket_name_len_6,       "socket.__name__.__len__",             [],         6,    "socket.socket.__name__.__len__() is 6 ('socket' = 6 chars; same length as 'Struct' and 'object')"]

# ---------------------------------------------------------------------------
