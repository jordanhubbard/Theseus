# socket.error.__name__.__eq__('OSError')
# socket.gaierror.__name__.__eq__('gaierror')
# socket.gaierror.__module__.__eq__('socket')
#
# Wave 334 theme: socket exception class names — error is OSError alias, gaierror is proper subclass.
#
# socket.error.__name__ == 'OSError' (7 chars) — socket.error IS OSError (an alias).
# socket.gaierror.__name__ == 'gaierror' (8 chars) — a proper exception subclass.
# socket.gaierror.__module__ == 'socket' (6 chars).
# No prior socket spec anchors socket.error.__name__ or gaierror.__name__/__module__
# as a table under sockcls152. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra152.socket_exception_identity:
  description: "socket.error.__name__.__eq__('OSError')==True / socket.gaierror.__name__.__eq__('gaierror')==True / socket.gaierror.__module__.__eq__('socket')==True / socket.error.__name__.__len__()==7 — socket.error is an alias for OSError (__name__=='OSError', 7 chars); socket.gaierror is a proper subclass (__name__=='gaierror', 8 chars, lowercase); both modules report 'socket' (6 chars); contrast with struct.error (__name__=='error', inherits from Exception not OSError); first sockcls152 anchor for socket error/gaierror identity"
  kind: python_call_eq
  category: identity
  id_prefix: sockcls152

  columns: [id, function, args, expected, description]
  rows:
    - [socket_error_name_OSError,    "error.__name__.__eq__",            ["OSError"],   true, "socket.error.__name__ == 'OSError' (7 chars; socket.error IS OSError alias, not a subclass; backward compat)"]
    - [socket_gaierror_name,         "gaierror.__name__.__eq__",         ["gaierror"],  true, "socket.gaierror.__name__ == 'gaierror' (8 chars; lowercase; raised by getaddrinfo/DNS resolution failures)"]
    - [socket_gaierror_module,       "gaierror.__module__.__eq__",       ["socket"],    true, "socket.gaierror.__module__ == 'socket' (6 chars; proper subclass defined in socket module, not _socket)"]
    - [socket_error_name_len_7,      "error.__name__.__len__",           [],            7,    "socket.error.__name__.__len__() is 7 ('OSError' = 7 chars; reflects the true class name, not 'error')"]

# ---------------------------------------------------------------------------
# socket.socket.__name__.__eq__('socket') — standalone
#
# socket.socket.__name__ is 'socket' (6 chars). The Python-level socket.socket class
# and the C extension _socket.socket class both have __name__ == 'socket'. This name
# collision (class named the same as the module) is intentional — the socket class is
# the primary API object of the socket module. Unlike struct.Struct which uses CapWords
# ('Struct'), socket uses lowercase ('socket') matching the module name. The socket class
# can be used as a context manager (with socket.socket() as s:). extra144 anchors
# socket.socket.__module__.__eq__('socket'); no prior socket spec anchors
# socket.socket.__name__.__eq__('socket') as a standalone. First standalone under sockcls152.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra152.socket_name_eq_socket:
  description: "socket.socket.__name__.__eq__('socket') == True — 6 chars; class named same as module (intentional); lowercase unlike CapWords (struct.Struct); both Python socket.socket and C _socket.socket have __name__=='socket'; primary API object for network I/O; extra144 anchors __module__=='socket'; no prior socket spec anchors this as a standalone; first standalone under sockcls152"
  category: identity
  kind: python_call_eq
  function: socket.__name__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.connect.__qualname__.__eq__('socket.connect') — standalone
#
# socket.socket.connect.__qualname__ is 'socket.connect' (14 chars). The qualname
# uses 'socket.' (7-char prefix) derived from the C extension class name _socket.socket.
# connect() establishes a TCP (or UDP) connection to a remote address. For TCP sockets,
# connect() performs the three-way handshake. The qualname format 'socket.connect'
# rather than 'socket.socket.connect' reflects that the qualname comes from the
# method_descriptor on the C extension type (_socket.socket), not the Python wrapper.
# The 'socket.' prefix (7 chars) is longer than 'Struct.' (7 chars, same length).
# No prior socket spec anchors socket.socket.connect.__qualname__ as a standalone.
# First standalone under sockcls152. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra152.socket_connect_qualname_eq:
  description: "socket.socket.connect.__qualname__.__eq__('socket.connect') == True — 14 chars; 'socket.'=7 + 'connect'=7; qualname from C extension type method_descriptor; 'socket.connect' not 'socket.socket.connect' (qualname reflects C class __name__, not full module path); connect() performs TCP three-way handshake; same prefix length as Struct.pack ('Struct.'=7); no prior socket spec anchors this as a standalone; first standalone under sockcls152"
  category: identity
  kind: python_call_eq
  function: socket.connect.__qualname__.__eq__
  args: ["socket.connect"]
  expected: true

# ---------------------------------------------------------------------------
# socket.error.__name__.__eq__('OSError') — standalone
#
# socket.error.__name__ is 'OSError' (7 chars). socket.error is literally the same
# object as OSError — not a subclass, but an alias (socket.error is OSError evaluates
# to True). Therefore socket.error.__name__ returns 'OSError', the true class name.
# This differs from socket.gaierror and socket.herror which are actual subclasses of
# OSError with their own names. In Python 3.3+, OSError was unified with IOError,
# EnvironmentError, socket.error, and others. The alias exists for backward
# compatibility with Python 2 code that used socket.error. No prior socket spec anchors
# socket.error.__name__.__eq__('OSError') as a standalone under sockcls152.
# First standalone under sockcls152. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra152.socket_error_name_OSError:
  description: "socket.error.__name__.__eq__('OSError') == True — 7 chars; socket.error IS OSError (same object, not subclass); unified in Python 3.3 (PEP 3151); socket.error.__name__ returns 'OSError' not 'error'; contrasts with struct.error (__name__=='error', 5 chars) and socket.gaierror (__name__=='gaierror'); backward compat alias; no prior socket spec anchors this as a standalone; first standalone under sockcls152"
  category: identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# socket.gaierror.__module__.__eq__('socket') — standalone
#
# socket.gaierror.__module__ is 'socket' (6 chars). gaierror is defined in the socket
# Python module (Lib/socket.py) as a subclass of OSError. Its name 'gaierror' comes
# from the POSIX function getaddrinfo() — 'GAI' stands for GetAddrInfo. gaierror is
# raised when getaddrinfo() fails, typically due to DNS resolution errors (hostname not
# found, network unreachable, etc.). Its __module__ is 'socket' (the public module, 6
# chars) rather than '_socket' (7 chars, the C extension). gaierror.__name__ is
# 'gaierror' (8 chars, lowercase) matching the historical naming pattern for socket
# exception subclasses. No prior socket spec anchors gaierror.__module__ as a standalone.
# First standalone under sockcls152. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra152.socket_gaierror_module_eq:
  description: "socket.gaierror.__module__.__eq__('socket') == True — 6 chars (no underscore); defined in pure-Python socket.py not _socket C extension; 'GAI' = GetAddrInfo; raised by getaddrinfo()/DNS resolution failures; __name__=='gaierror' (8 chars, lowercase); subclass of OSError (socket.error); no prior socket spec anchors this as a standalone; first standalone under sockcls152"
  category: identity
  kind: python_call_eq
  function: gaierror.__module__.__eq__
  args: ["socket"]
  expected: true

