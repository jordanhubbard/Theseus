# ---------------------------------------------------------------------------

table socket_extra152.socket_method_qualnames:
  description: "socket.socket.connect.__qualname__.__eq__('socket.connect')==True / socket.socket.bind.__qualname__.__eq__('socket.bind')==True / socket.socket.listen.__qualname__.__eq__('socket.listen')==True / socket.socket.connect.__qualname__.__len__()==14 — 'socket.' prefix (7 chars) comes from C extension class name (_socket.socket.__name__=='socket'); qualname lengths: bind(11) < listen(13) < connect(14); 'socket.'=7+'bind'=4=11 / 'socket.'=7+'listen'=6=13 / 'socket.'=7+'connect'=7=14; first sockcls152 anchor for socket method qualnames"
  kind: python_call_eq
  category: identity
  id_prefix: sockcls152

  columns: [id, function, args, expected, description]
  rows:
    - [socket_connect_qualname,     "socket.connect.__qualname__.__eq__",  ["socket.connect"], true, "socket.socket.connect.__qualname__ == 'socket.connect' (14 chars; 'socket.'=7 + 'connect'=7; TCP connection method)"]
    - [socket_bind_qualname,        "socket.bind.__qualname__.__eq__",     ["socket.bind"],    true, "socket.socket.bind.__qualname__ == 'socket.bind' (11 chars; 'socket.'=7 + 'bind'=4; binds to local address/port)"]
    - [socket_listen_qualname,      "socket.listen.__qualname__.__eq__",   ["socket.listen"],  true, "socket.socket.listen.__qualname__ == 'socket.listen' (13 chars; 'socket.'=7 + 'listen'=6; enables server accept loop)"]
    - [socket_connect_qualname_len, "socket.connect.__qualname__.__len__", [],                 14,   "socket.socket.connect.__qualname__.__len__() is 14 ('socket.connect' = 7+7 = 14 chars)"]

