spec: theseus_email_errors_cr
version: ">=3.0"
backend: python_cleanroom(theseus_email_errors_cr)
blocks: email.errors

docs: https://docs.python.org/3/library/email.errors.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/email.errors.html"
  not_derived_from:
    - "CPython source: Lib/email/errors.py"
  notes:
    - "Clean-room email.errors module. Do NOT import email.errors."

error_model: python_exceptions

invariant theseus_email_errors_cr.emailerr2_message_error:
  description: "MessageError base class exists"
  category: behavior
  kind: python_call_eq
  function: emailerr2_message_error
  args: []
  expected: true

invariant theseus_email_errors_cr.emailerr2_defect:
  description: "MessageDefect and related defect classes exist"
  category: behavior
  kind: python_call_eq
  function: emailerr2_defect
  args: []
  expected: true

invariant theseus_email_errors_cr.emailerr2_parse_defect:
  description: "HeaderParseError and MultipartConversionError exist"
  category: behavior
  kind: python_call_eq
  function: emailerr2_parse_defect
  args: []
  expected: true
