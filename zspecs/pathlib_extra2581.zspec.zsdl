spec: pathlib_extra2581
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 pathlib documentation — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
    - "pathlib_extra.zspec.zsdl — covers existing pathlib invariants"
  notes:
    - "Wave 2581 theme: __call__ dict-presence. No pathlib class defines __call__ in its own __dict__."
    - "pathlib.PurePath is the abstract base; defines __hash__, __eq__, __lt__, __str__, __new__, __truediv__, __fspath__ but NOT __call__."
    - "pathlib.Path inherits from PurePath; defines __new__ but does NOT define __call__ in its own __dict__."
    - "pathlib.PurePosixPath and pathlib.PureWindowsPath are concrete pure-path classes; neither defines __call__."
    - "pathlib.PosixPath is the concrete POSIX path class; does NOT define __call__ in its own __dict__."
    - "Path objects represent filesystem paths — they are not callable objects/functors."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __call__ dict-presence — pure path classes
# pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath
# ---------------------------------------------------------------------------

table pathlib_extra2581.pure_path_no_call:
  description: "__call__ is absent from all pure-path class __dict__s — path objects are not callable"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2581

  columns: [id, function, args, expected]
  rows:
    - ["pp2581001", "pathlib.PurePath.__dict__.__contains__",        ["__call__"], false]
    - ["pp2581002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__call__"], false]
    - ["pp2581003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__call__"], false]

# ---------------------------------------------------------------------------
# __call__ dict-presence — concrete path classes
# pathlib.Path, pathlib.PosixPath
# ---------------------------------------------------------------------------

table pathlib_extra2581.concrete_path_no_call:
  description: "__call__ is absent from concrete path class __dict__s — Path and PosixPath are not functors"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2581

  columns: [id, function, args, expected]
  rows:
    - ["pp2581004", "pathlib.Path.__dict__.__contains__",      ["__call__"], false]
    - ["pp2581005", "pathlib.PosixPath.__dict__.__contains__", ["__call__"], false]

# ---------------------------------------------------------------------------
# Complementary: pathlib.PurePath DOES define comparison/hashing protocol
# Confirms PurePath has rich dunder definitions — it just does NOT define __call__
# ---------------------------------------------------------------------------

table pathlib_extra2581.purepath_has_comparison_protocol:
  description: "pathlib.PurePath defines __hash__, __eq__, __lt__, __str__ (path semantics) but not __call__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2581

  columns: [id, function, args, expected]
  rows:
    - ["pp2581006", "pathlib.PurePath.__dict__.__contains__", ["__hash__"],     true]
    - ["pp2581007", "pathlib.PurePath.__dict__.__contains__", ["__eq__"],       true]
    - ["pp2581008", "pathlib.PurePath.__dict__.__contains__", ["__lt__"],       true]
    - ["pp2581009", "pathlib.PurePath.__dict__.__contains__", ["__str__"],      true]
    - ["pp2581010", "pathlib.PurePath.__dict__.__contains__", ["__call__"],     false]
    - ["pp2581011", "pathlib.PurePath.__dict__.__contains__", ["__iter__"],     false]

# ---------------------------------------------------------------------------
# Complementary: pathlib.PurePath defines path arithmetic (__truediv__, __rtruediv__)
# and filesystem protocol (__fspath__) but NOT __call__
# ---------------------------------------------------------------------------

table pathlib_extra2581.purepath_path_arithmetic:
  description: "pathlib.PurePath defines __truediv__ and __fspath__ for path operations but not __call__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2581

  columns: [id, function, args, expected]
  rows:
    - ["pp2581012", "pathlib.PurePath.__dict__.__contains__", ["__truediv__"],  true]
    - ["pp2581013", "pathlib.PurePath.__dict__.__contains__", ["__rtruediv__"], true]
    - ["pp2581014", "pathlib.PurePath.__dict__.__contains__", ["__fspath__"],   true]
    - ["pp2581015", "pathlib.PurePath.__dict__.__contains__", ["__new__"],      true]
    - ["pp2581016", "pathlib.PurePath.__dict__.__contains__", ["__call__"],     false]

# ---------------------------------------------------------------------------
# Complementary: pathlib.Path inherits but does not add __call__
# Path.__new__ is present; __call__ is not — cross-check
# ---------------------------------------------------------------------------

table pathlib_extra2581.path_own_dict_no_call:
  description: "pathlib.Path defines __new__ in its own __dict__ but not __call__ — inherits path ops from PurePath"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2581

  columns: [id, function, args, expected]
  rows:
    - ["pp2581017", "pathlib.Path.__dict__.__contains__", ["__new__"],  true]
    - ["pp2581018", "pathlib.Path.__dict__.__contains__", ["__call__"], false]
    - ["pp2581019", "pathlib.Path.__dict__.__contains__", ["__iter__"], false]
    - ["pp2581020", "pathlib.Path.__dict__.__contains__", ["__hash__"], false]
