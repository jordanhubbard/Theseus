spec: io_extra1216
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io.IOBase.__dict__.__contains__ checks for methods IOBase defines directly: read, readline, readlines, writelines, seek, tell, close, closed"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks io.IOBase.__dict__.__contains__ for method and property names that IOBase defines directly in its own namespace; checks io.RawIOBase.__dict__.__contains__ for methods RawIOBase adds on top of IOBase; checks io.BufferedIOBase.__dict__.__contains__ for methods BufferedIOBase adds; none of these __dict__.__contains__ membership checks were covered in _extra1186, _extra1201, or any prior io_extra spec"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra1216.iobase_dict_contains_present:
  description: "io.IOBase.__dict__.__contains__ checks for methods and properties IOBase defines directly — readline, readlines, writelines, seek, tell, close, closed, readable all present in IOBase.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1216ib
  columns: [id, function, args, expected]
  rows:
    - [io1216ib001, io.IOBase.__dict__.__contains__, ["readline"],   true]
    - [io1216ib002, io.IOBase.__dict__.__contains__, ["readlines"],  true]
    - [io1216ib003, io.IOBase.__dict__.__contains__, ["writelines"], true]
    - [io1216ib004, io.IOBase.__dict__.__contains__, ["seek"],       true]
    - [io1216ib005, io.IOBase.__dict__.__contains__, ["tell"],       true]
    - [io1216ib006, io.IOBase.__dict__.__contains__, ["close"],      true]
    - [io1216ib007, io.IOBase.__dict__.__contains__, ["closed"],     true]
    - [io1216ib008, io.IOBase.__dict__.__contains__, ["readable"],   true]
    - [io1216ib009, io.IOBase.__dict__.__contains__, ["writable"],   true]
    - [io1216ib010, io.IOBase.__dict__.__contains__, ["seekable"],   true]

table io_extra1216.iobase_dict_contains_absent:
  description: "io.IOBase.__dict__.__contains__ checks for names NOT in IOBase.__dict__ — methods that belong to subclasses (read, write, getvalue) or builtins (__add__, __len__) are absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1216ia
  columns: [id, function, args, expected]
  rows:
    - [io1216ia001, io.IOBase.__dict__.__contains__, ["read"],      false]
    - [io1216ia002, io.IOBase.__dict__.__contains__, ["write"],     false]
    - [io1216ia003, io.IOBase.__dict__.__contains__, ["getvalue"],  false]
    - [io1216ia004, io.IOBase.__dict__.__contains__, ["__add__"],   false]
    - [io1216ia005, io.IOBase.__dict__.__contains__, ["__len__"],   false]
    - [io1216ia006, io.IOBase.__dict__.__contains__, ["flush"],     true]
    - [io1216ia007, io.IOBase.__dict__.__contains__, ["truncate"],  false]
    - [io1216ia008, io.IOBase.__dict__.__contains__, ["__iter__"],  true]

table io_extra1216.rawiobase_bufferediobase_dict_contains:
  description: "io.RawIOBase.__dict__.__contains__ and io.BufferedIOBase.__dict__.__contains__ checks — each subclass adds its own methods on top of IOBase; read and readinto are in RawIOBase; read, read1, readinto are in BufferedIOBase"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1216rb
  columns: [id, function, args, expected]
  rows:
    - [io1216rb001, io.RawIOBase.__dict__.__contains__,     ["read"],      true]
    - [io1216rb002, io.RawIOBase.__dict__.__contains__,     ["readinto"],  true]
    - [io1216rb003, io.RawIOBase.__dict__.__contains__,     ["write"],     true]
    - [io1216rb004, io.RawIOBase.__dict__.__contains__,     ["getvalue"],  false]
    - [io1216rb005, io.BufferedIOBase.__dict__.__contains__, ["read"],     true]
    - [io1216rb006, io.BufferedIOBase.__dict__.__contains__, ["read1"],    true]
    - [io1216rb007, io.BufferedIOBase.__dict__.__contains__, ["readinto"], true]
    - [io1216rb008, io.BufferedIOBase.__dict__.__contains__, ["write"],    true]
    - [io1216rb009, io.BufferedIOBase.__dict__.__contains__, ["detach"],   true]
    - [io1216rb010, io.BufferedIOBase.__dict__.__contains__, ["readline"], false]
