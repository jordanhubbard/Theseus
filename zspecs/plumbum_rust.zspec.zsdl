spec: plumbum_rust
version: ">=3.9"
backend: rust_module(plumbum_rust)

docs: https://plumbum.readthedocs.io/en/latest/

provenance:
  derived_from:
    - "https://plumbum.readthedocs.io/en/latest/ — Plumbum documentation"
  not_derived_from:
    - "plumbum source: plumbum/__init__.py"
  notes:
    - "Plumbum provides shell scripting in Python."
    - "from plumbum import local; local is available."
    - "plumbum.local is available."
    - "plumbum.cmd is available."
    - "plumbum.__version__ is a non-empty string."
    - "Expose plumbum_has_local() -> bool: hasattr(plumbum, 'local')."
    - "Expose plumbum_has_cmd() -> bool: hasattr(plumbum, 'cmd')."
    - "Expose plumbum_version_nonempty() -> bool: len(plumbum.__version__) > 0."
    - "All test vectors verified against plumbum 1.9.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# plumbum_has_local — local present
invariant plumbum_rust.module.has_local:
  description: "plumbum.local is available"
  category: module
  kind: python_call_eq
  function: plumbum_has_local
  args: []
  expected: true

# plumbum_has_cmd — cmd module present
invariant plumbum_rust.module.has_cmd:
  description: "plumbum.cmd is available"
  category: module
  kind: python_call_eq
  function: plumbum_has_cmd
  args: []
  expected: true

# plumbum_version_nonempty — version non-empty
invariant plumbum_rust.version.nonempty:
  description: "plumbum.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: plumbum_version_nonempty
  args: []
  expected: true

