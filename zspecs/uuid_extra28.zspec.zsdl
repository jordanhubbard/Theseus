spec: uuid_extra28
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra27.zspec.zsdl — covers UUID.bytes_le.__class__.__name__.__len__()==8; uuid3/uuid5 result __class__.__name__.__len__()==4; NAMESPACE_URL.__class__.__qualname__.__len__()==4; uuid3/uuid5.__qualname__.__len__()==5 standalone anchors."
    - "uuid_extra26.zspec.zsdl — covers UUID.int/is_safe member_descriptor class name len (17); UUID.hex/urn/variant/version property descriptor class name len (8)."
    - "uuid_extra24.zspec.zsdl — covers UUID.node/time/clock_seq/time_hi_version/clock_seq_hi_variant fget __qualname__.__len__(); SafeUUID identity; getnode identity."
    - "uuid_extra23.zspec.zsdl — covers UUID.hex/bytes/bytes_le fget __qualname__.__len__(); uuid1/3/4/5 __qualname__.__len__()==5."
    - "uuid_extra18.zspec.zsdl — covers UUID property fget __qualname__ values and lengths for hex/bytes/urn/version/bytes_le/fields/variant."
    - "uuid_extra16.zspec.zsdl — covers UUID.__str__/__repr__/__eq__/__hash__/__init__/__int__ __qualname__.__eq__ and __qualname__.__len__()."
  notes:
    - "This spec extends uuid through uuid_extra27; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: UUID property fget qualname lengths for hex/bytes/bytes_le/urn/version/fields/variant (extra18/extra23); UUID.node/time/clock_seq/time_hi_version/clock_seq_hi_variant fget __qualname__.__len__() (extra24); UUID.hex/urn/variant/version property descriptor class name len (8) (extra26); UUID.bytes_le property descriptor class name len (8) (extra27)."
    - "This spec covers: UUID.time_low.__class__.__name__.__len__() (NOVEL — 'property' has 8 chars; extra26 covers hex/urn/variant/version descriptor class name len; extra27 covers bytes_le; no prior spec checks time_low descriptor class name length); UUID.time_mid.__class__.__name__.__len__() (NOVEL — same gap; no prior spec covers time_mid descriptor class name length); UUID.clock_seq_low.__class__.__name__.__len__() (NOVEL — same; no prior spec covers clock_seq_low descriptor class name length); UUID.time_low.fget.__qualname__.__len__() (NOVEL — extra18 covers hex/bytes/urn/version/bytes_le/fields/variant; extra24 covers node/time/clock_seq/time_hi_version/clock_seq_hi_variant; time_low/time_mid/clock_seq_low are absent from both; 'UUID.time_low' has 13 chars); UUID.time_mid.fget.__qualname__.__len__() (NOVEL — same; 'UUID.time_mid' has 13 chars); UUID.clock_seq_low.fget.__qualname__.__len__() (NOVEL — same; 'UUID.clock_seq_low' has 18 chars)."
    - "UUID.time_low is a Python property descriptor on the UUID class. Its __class__.__name__ == 'property' (len 8). extra26 checks hex/urn/variant/version descriptor class name len; extra27 checks bytes_le; no prior spec checks time_low. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "UUID.time_mid is a Python property descriptor. __class__.__name__ == 'property' (len 8). No prior spec checks time_mid descriptor class name length. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "UUID.clock_seq_low is a Python property descriptor. __class__.__name__ == 'property' (len 8). No prior spec checks clock_seq_low descriptor class name length. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "UUID.time_low.fget.__qualname__ == 'UUID.time_low' (len 13). extra18 covers fget qualnames for hex/bytes/urn/version/bytes_le/fields/variant. extra24 covers node/time/clock_seq/time_hi_version/clock_seq_hi_variant. time_low/time_mid/clock_seq_low are absent from all prior fget coverage. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "UUID.time_mid.fget.__qualname__ == 'UUID.time_mid' (len 13). Same gap as time_low. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "UUID.clock_seq_low.fget.__qualname__ == 'UUID.clock_seq_low' (len 18). Same gap; longer qualname than time_low/time_mid. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UUID.time_low, UUID.time_mid, UUID.clock_seq_low descriptor class name lengths
#
# All three are Python property descriptors on the UUID class. When accessed
# on the class (not an instance), they yield property objects whose
# __class__.__name__ == 'property' (len 8).
#
# extra26 checks UUID.hex/urn/variant/version.__class__.__name__.__len__()==8.
# extra27 checks UUID.bytes_le.__class__.__name__.__len__()==8.
# The three attributes time_low, time_mid, clock_seq_low are absent from all
# prior descriptor-class-name-length checks.
# ---------------------------------------------------------------------------

table uuid_extra28.uuid_time_field_descriptor_class_name_lens:
  description: "UUID.time_low/time_mid/clock_seq_low property descriptor class name len (8) — novel; extra26 covers hex/urn/variant/version; extra27 covers bytes_le; time_low/time_mid/clock_seq_low not covered"
  kind: python_call_eq
  category: class_introspection
  id_prefix: utfdcnl28

  columns: [id, function, args, expected]
  rows:
    - [time_low_desc_len,      "UUID.time_low.__class__.__name__.__len__",      [], 8]
    - [time_mid_desc_len,      "UUID.time_mid.__class__.__name__.__len__",      [], 8]
    - [clock_seq_low_desc_len, "UUID.clock_seq_low.__class__.__name__.__len__", [], 8]

# ---------------------------------------------------------------------------
# UUID.time_low, UUID.time_mid, UUID.clock_seq_low fget __qualname__.__len__()
#
# Each UUID property has a fget function whose __qualname__ includes the
# class name and attribute name as 'UUID.<attr>'.
#
# extra18 covers fget qualname lengths for hex(8)/bytes(10)/urn(8)/version(12)/
#   bytes_le(13)/fields(11)/variant(12).
# extra24 covers fget qualname lengths for node(9)/time(9)/clock_seq(14)/
#   time_hi_version(20)/clock_seq_hi_variant(25).
# The three attributes time_low, time_mid, clock_seq_low appear in neither
# extra18 nor extra24. This table closes that gap.
#
#   UUID.time_low.fget.__qualname__ == 'UUID.time_low'      -> len 13
#   UUID.time_mid.fget.__qualname__ == 'UUID.time_mid'      -> len 13
#   UUID.clock_seq_low.fget.__qualname__ == 'UUID.clock_seq_low' -> len 18
# ---------------------------------------------------------------------------

table uuid_extra28.uuid_time_field_fget_qualname_lens:
  description: "UUID.time_low/time_mid/clock_seq_low fget __qualname__.__len__() — novel; extra18 covers hex/bytes/bytes_le/urn/version/fields/variant; extra24 covers node/time/clock_seq/time_hi_version/clock_seq_hi_variant; these three are absent"
  kind: python_call_eq
  category: method_identity
  id_prefix: utffqln28

  columns: [id, function, args, expected]
  rows:
    - [time_low_fget_qualname_len,      UUID.time_low.fget.__qualname__.__len__,      [], 13]
    - [time_mid_fget_qualname_len,      UUID.time_mid.fget.__qualname__.__len__,      [], 13]
    - [clock_seq_low_fget_qualname_len, UUID.clock_seq_low.fget.__qualname__.__len__, [], 18]
