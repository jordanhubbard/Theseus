spec: hashlib_extra265
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib documentation"
    - "FIPS 202 — SHA-3 Standard: Permutation-Based Hash and Extendable-Output Functions, August 2015"
    - "RFC 7693 — The BLAKE2 Cryptographic Hash and Message Authentication Code (MAC)"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_sha3module.c"
    - "CPython source: Modules/_blake2module.c"
    - "CPython source: Modules/_hashopenssl.c"
  notes:
    - "sha3_256 digest_size == 32 (256 bits), block_size == 136, name == 'sha3_256', hexdigest length == 64."
    - "sha3_512 digest_size == 64 (512 bits), block_size == 72, name == 'sha3_512', hexdigest length == 128."
    - "blake2b(digest_size=32) produces a 32-byte digest; block_size == 128, name == 'blake2b'."
    - "hexdigest() on an empty input returns a hex string of length 2 * digest_size."
    - "blake2b.default_digest_size and blake2b.custom_digest_size_32 are already in hashlib_extra.zspec.zsdl; this spec uses digest_size=32 to independently verify block_size and name."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sha3_256 — digest_size, block_size, name, hexdigest length
# ---------------------------------------------------------------------------

invariant hashlib_extra265.sha3_256.digest_size:
  description: "hashlib.sha3_256().digest_size == 32 (256 bits)"
  category: properties
  kind: python_call_eq
  function: sha3_256
  args: []
  method: digest_size.__eq__
  method_args: [32]
  expected: true

invariant hashlib_extra265.sha3_256.block_size:
  description: "hashlib.sha3_256().block_size == 136 (rate = 1600 - 2*256 bits, divided by 8)"
  category: properties
  kind: python_call_eq
  function: sha3_256
  args: []
  method: block_size.__eq__
  method_args: [136]
  expected: true

invariant hashlib_extra265.sha3_256.name:
  description: "hashlib.sha3_256().name == 'sha3_256'"
  category: properties
  kind: python_call_eq
  function: sha3_256
  args: []
  method: name.__eq__
  method_args: ["sha3_256"]
  expected: true

invariant hashlib_extra265.sha3_256.hexdigest_len:
  description: "len(hashlib.sha3_256().hexdigest()) == 64 (2 hex chars per byte * 32 bytes)"
  category: properties
  kind: python_call_eq
  function: sha3_256
  args: []
  method: hexdigest
  method_chain: __len__.__eq__
  method_chain_args: [64]
  expected: true

# ---------------------------------------------------------------------------
# sha3_512 — digest_size, block_size, name, hexdigest length
# ---------------------------------------------------------------------------

invariant hashlib_extra265.sha3_512.digest_size:
  description: "hashlib.sha3_512().digest_size == 64 (512 bits)"
  category: properties
  kind: python_call_eq
  function: sha3_512
  args: []
  method: digest_size.__eq__
  method_args: [64]
  expected: true

invariant hashlib_extra265.sha3_512.block_size:
  description: "hashlib.sha3_512().block_size == 72 (rate = 1600 - 2*512 bits, divided by 8)"
  category: properties
  kind: python_call_eq
  function: sha3_512
  args: []
  method: block_size.__eq__
  method_args: [72]
  expected: true

invariant hashlib_extra265.sha3_512.name:
  description: "hashlib.sha3_512().name == 'sha3_512'"
  category: properties
  kind: python_call_eq
  function: sha3_512
  args: []
  method: name.__eq__
  method_args: ["sha3_512"]
  expected: true

invariant hashlib_extra265.sha3_512.hexdigest_len:
  description: "len(hashlib.sha3_512().hexdigest()) == 128 (2 hex chars per byte * 64 bytes)"
  category: properties
  kind: python_call_eq
  function: sha3_512
  args: []
  method: hexdigest
  method_chain: __len__.__eq__
  method_chain_args: [128]
  expected: true

# ---------------------------------------------------------------------------
# blake2b(digest_size=32) — digest_size, block_size, name
# ---------------------------------------------------------------------------

invariant hashlib_extra265.blake2b.custom32_digest_size:
  description: "hashlib.blake2b(digest_size=32).digest_size == 32"
  category: properties
  kind: python_call_eq
  function: blake2b
  args: []
  kwargs:
    digest_size: 32
  method: digest_size.__eq__
  method_args: [32]
  expected: true

invariant hashlib_extra265.blake2b.custom32_block_size:
  description: "hashlib.blake2b(digest_size=32).block_size == 128 (BLAKE2b always uses 128-byte blocks)"
  category: properties
  kind: python_call_eq
  function: blake2b
  args: []
  kwargs:
    digest_size: 32
  method: block_size.__eq__
  method_args: [128]
  expected: true

invariant hashlib_extra265.blake2b.custom32_name:
  description: "hashlib.blake2b(digest_size=32).name == 'blake2b'"
  category: properties
  kind: python_call_eq
  function: blake2b
  args: []
  kwargs:
    digest_size: 32
  method: name.__eq__
  method_args: ["blake2b"]
  expected: true
