spec: uuid_extra38
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra37.zspec.zsdl — covers UUID property fget __name__.__eq__ string values for time/variant/bytes/hex/urn/node/version/clock_seq."
    - "uuid_extra36.zspec.zsdl — covers UUID dunder method __module__.__eq__('uuid') for __repr__/__hash__/__eq__/__int__/__lt__/__le__/__gt__/__ge__."
    - "uuid_extra35.zspec.zsdl — covers UUID dunder method __name__.__eq__ string values."
    - "uuid_extra34.zspec.zsdl — covers UUID property fget __qualname__.__eq__ string values."
    - "uuid_extra18.zspec.zsdl — covers UUID property fget __qualname__.__eq__ and __qualname__.__len__() for bytes/version/bytes_le/fields/variant."
  notes:
    - "This spec extends uuid through uuid_extra37; it does NOT duplicate invariants present in those files."
    - "Coverage gap: No prior uuid spec checks __class__.__name__.__eq__ for UUID (the class itself), for the uuid4/uuid1/uuid3/uuid5/getnode module-level functions, or for UUID.time.fget. The __class__.__name__ axis identifies the Python object type of each callable (type vs. function), providing structural regression vectors distinct from __name__/__qualname__/__module__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__class__.__name__ == 'type'. UUID is a Python class; its metaclass is type. No prior spec checks UUID.__class__.__name__.__eq__('type'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__class__.__name__ == 'function'. uuid4 is a pure Python function defined in Lib/uuid.py. No prior spec checks uuid4.__class__.__name__.__eq__('function'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__class__.__name__ == 'function'. uuid1 is a pure Python function defined in Lib/uuid.py. No prior spec checks uuid1.__class__.__name__.__eq__('function'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__class__.__name__ == 'function'. uuid3 is a pure Python function defined in Lib/uuid.py. No prior spec checks uuid3.__class__.__name__.__eq__('function'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__class__.__name__ == 'function'. uuid5 is a pure Python function defined in Lib/uuid.py. No prior spec checks uuid5.__class__.__name__.__eq__('function'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID'. NAMESPACE_DNS is a UUID instance; its class is UUID. No prior spec checks NAMESPACE_DNS.__class__.__name__.__eq__('UUID'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.getnode.__class__.__name__ == 'function'. getnode is a pure Python function defined in Lib/uuid.py. No prior spec checks getnode.__class__.__name__.__eq__('function'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.time.fget.__class__.__name__ == 'function'. The fget of the time property is a Python function; __class__ is the built-in function type. No prior spec checks UUID.time.fget.__class__.__name__.__eq__('function'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid module-level and class-level callable __class__.__name__.__eq__ values
#
# No prior uuid spec checks __class__.__name__.__eq__ for UUID, uuid4, uuid1,
# uuid3, uuid5, getnode, or UUID.time.fget.
# uuid.UUID.__class__.__name__ == 'type'
# uuid.uuid4/uuid1/uuid3/uuid5/getnode.__class__.__name__ == 'function'
# uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID'
# uuid.UUID.time.fget.__class__.__name__ == 'function'
# ---------------------------------------------------------------------------

table uuid_extra38.callable_class_names:
  description: "uuid UUID/uuid4/uuid1/uuid3/uuid5/NAMESPACE_DNS/getnode __class__.__name__.__eq__ and UUID.time.fget.__class__.__name__.__eq__('function') — novel __class__.__name__ axis; no prior uuid spec checks __class__.__name__.__eq__ for any of these objects"
  kind: python_call_eq
  category: type_structure
  id_prefix: uccn38

  columns: [id, function, args, expected]
  rows:
    - [UUID_class_name_eq,           UUID.__class__.__name__.__eq__,                    ["type"],     true]
    - [uuid4_class_name_eq,          uuid4.__class__.__name__.__eq__,                   ["function"], true]
    - [uuid1_class_name_eq,          uuid1.__class__.__name__.__eq__,                   ["function"], true]
    - [uuid3_class_name_eq,          uuid3.__class__.__name__.__eq__,                   ["function"], true]
    - [uuid5_class_name_eq,          uuid5.__class__.__name__.__eq__,                   ["function"], true]
    - [NAMESPACE_DNS_class_name_eq,  NAMESPACE_DNS.__class__.__name__.__eq__,           ["UUID"],     true]
    - [getnode_class_name_eq,        getnode.__class__.__name__.__eq__,                 ["function"], true]
    - [time_fget_class_name_eq,      "UUID.time.fget.__class__.__name__.__eq__",        ["function"], true]
