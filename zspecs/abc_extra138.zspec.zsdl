spec: abc_extra138
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "This spec covers: abc.ABC.__dict__.__class__.__name__ == 'mappingproxy' (len=12); abc.ABC.__abstractmethods__.__class__.__name__ == 'frozenset' (len=9); abc.ABC.__name__=='ABC' (len=3); abc.ABC.__module__=='abc' (len=3); abc.ABC.__doc__.__len__()==78. abc.ABCMeta.__dict__.__len__()==11 (keys: __module__, __firstlineno__, __doc__, __new__, register, __instancecheck__, __subclasscheck__, _dump_registry, _abc_registry_clear, _abc_caches_clear, __static_attributes__). abc.abstractmethod — __name__=='abstractmethod' (len=14); __module__=='abc' (len=3); __doc__.__len__()==537; __code__.co_argcount==1; __code__.co_consts.__len__()==2; __code__.co_varnames.__len__()==1 (just 'funcobj'). abc.ABCMeta._dump_registry — __qualname__=='ABCMeta._dump_registry' (len=22); __doc__.__len__()==39; co_argcount==2. abc.ABCMeta._abc_registry_clear — __qualname__=='ABCMeta._abc_registry_clear' (len=27); abc.ABCMeta._abc_caches_clear — __qualname__=='ABCMeta._abc_caches_clear' (len=25). abc.ABCMeta.__new__ — __qualname__=='ABCMeta.__new__' (len=15); co_argcount==4. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__dict__.__class__.__name__=='mappingproxy' (len=12: the type of __dict__ for all class objects, providing a read-only view of the class namespace); abc.ABC.__abstractmethods__.__class__.__name__=='frozenset' (len=9: abstract methods are tracked in an immutable frozenset; for abc.ABC it is empty — frozenset()); abc.ABCMeta.__dict__.__len__()==11 (11 methods/attributes defined directly on ABCMeta, not inherited); abc.abstractmethod.__code__.co_consts.__len__()==2 (the docstring and True — True is the value assigned to funcobj.__isabstractmethod__); abc.abstractmethod.__code__.co_varnames.__len__()==1 (only 'funcobj', a single-parameter decorator). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABC class identity and meta-level checks — extra138
#
# abc.ABC.__dict__.__class__.__name__             == 'mappingproxy' (len=12)
# abc.ABC.__abstractmethods__.__class__.__name__  == 'frozenset'    (len=9)
# abc.ABC.__name__                                == 'ABC'          (len=3)
# abc.ABC.__module__                              == 'abc'          (len=3)
# abc.ABC.__doc__.__len__()                       == 78
# ---------------------------------------------------------------------------

table abc_extra138.abc_class_meta:
  description: "abc.ABC class meta-level and identity checks — ABC.__dict__.__class__.__name__.__eq__('mappingproxy')==True (len=12: 'mappingproxy'=12, the type of __dict__ for all Python class objects, providing a read-only view of the class namespace); ABC.__dict__.__class__.__name__.__len__()==12; ABC.__abstractmethods__.__class__.__name__.__eq__('frozenset')==True (len=9: abstract methods are stored in an immutable frozenset; abc.ABC has none so abc.ABC.__abstractmethods__==frozenset()); ABC.__abstractmethods__.__class__.__name__.__len__()==9; ABC.__name__.__eq__('ABC')==True (len=3: the canonical short name for Abstract Base Class); ABC.__module__.__eq__('abc')==True (len=3: same 3-char module name as ABCMeta; abc.ABC lives in the pure-Python abc module unlike get_cache_token which lives in _abc); ABC.__doc__.__len__()==78 (one-paragraph doc: 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n'); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcclass138

  columns: [id, function, args, expected, description]
  rows:
    - [dict_cls_eq,   "abc.ABC.__dict__.__class__.__name__.__eq__",   ["mappingproxy"],  true,  "abc.ABC.__dict__.__class__.__name__ == 'mappingproxy' (len=12); verified with Python 3.14.3"]
    - [dict_cls_len,  "abc.ABC.__dict__.__class__.__name__.__len__",  [],                12,    "abc.ABC.__dict__.__class__.__name__.__len__() == 12; verified with Python 3.14.3"]
    - [absmeth_eq,    "abc.ABC.__abstractmethods__.__class__.__name__.__eq__", ["frozenset"], true, "abc.ABC.__abstractmethods__.__class__.__name__ == 'frozenset' (len=9); verified with Python 3.14.3"]
    - [absmeth_len,   "abc.ABC.__abstractmethods__.__class__.__name__.__len__", [],        9,     "abc.ABC.__abstractmethods__.__class__.__name__.__len__() == 9; verified with Python 3.14.3"]
    - [name_eq,       abc.ABC.__name__.__eq__,                        ["ABC"],           true,  "abc.ABC.__name__ == 'ABC' (len=3); verified with Python 3.14.3"]
    - [name_len,      abc.ABC.__name__.__len__,                        [],               3,     "abc.ABC.__name__.__len__() == 3; verified with Python 3.14.3"]
    - [mod_eq,        abc.ABC.__module__.__eq__,                      ["abc"],           true,  "abc.ABC.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [mod_len,       abc.ABC.__module__.__len__,                      [],               3,     "abc.ABC.__module__.__len__() == 3; verified with Python 3.14.3"]
    - [doc_len,       abc.ABC.__doc__.__len__,                         [],               78,    "abc.ABC.__doc__.__len__() == 78; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta.__dict__.__len__() and ABCMeta internal methods — extra138
#
# abc.ABCMeta.__dict__.__len__()                == 11
# abc.ABCMeta._dump_registry.__qualname__       == 'ABCMeta._dump_registry'      (len=22)
# abc.ABCMeta._dump_registry.__doc__.__len__()  == 39
# abc.ABCMeta._dump_registry co_argcount        == 2
# abc.ABCMeta._abc_registry_clear.__qualname__  == 'ABCMeta._abc_registry_clear' (len=27)
# abc.ABCMeta._abc_caches_clear.__qualname__    == 'ABCMeta._abc_caches_clear'   (len=25)
# ---------------------------------------------------------------------------

table abc_extra138.abcmeta_dict_and_internals:
  description: "abc.ABCMeta.__dict__ size and internal method qualnames — ABCMeta.__dict__.__len__()==11 (11 keys: __module__, __firstlineno__, __doc__, __new__, register, __instancecheck__, __subclasscheck__, _dump_registry, _abc_registry_clear, _abc_caches_clear, __static_attributes__); _dump_registry.__qualname__.__eq__('ABCMeta._dump_registry')==True (len=22: 'ABCMeta'=7+'.'=1+'_dump_registry'=14=22); _dump_registry.__doc__.__len__()==39 (doc is 'Debug helper to print the ABC registry.'); _dump_registry.__code__.co_argcount.__eq__(2)==True ('cls','file'); _abc_registry_clear.__qualname__.__eq__('ABCMeta._abc_registry_clear')==True (len=27: 'ABCMeta'=7+'.'=1+'_abc_registry_clear'=19=27, the longest method qualname in this spec); _abc_caches_clear.__qualname__.__eq__('ABCMeta._abc_caches_clear')==True (len=25: 'ABCMeta'=7+'.'=1+'_abc_caches_clear'=17=25); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcdict138

  columns: [id, function, args, expected, description]
  rows:
    - [dict_len,    abc.ABCMeta.__dict__.__len__,                             [],                              11,    "abc.ABCMeta.__dict__.__len__() == 11; verified with Python 3.14.3"]
    - [dr_qn_eq,    abc.ABCMeta._dump_registry.__qualname__.__eq__,          ["ABCMeta._dump_registry"],       true,  "abc.ABCMeta._dump_registry.__qualname__ == 'ABCMeta._dump_registry' (len=22); verified with Python 3.14.3"]
    - [dr_qn_len,   abc.ABCMeta._dump_registry.__qualname__.__len__,          [],                              22,    "abc.ABCMeta._dump_registry.__qualname__.__len__() == 22; verified with Python 3.14.3"]
    - [dr_doc_len,  abc.ABCMeta._dump_registry.__doc__.__len__,               [],                              39,    "abc.ABCMeta._dump_registry.__doc__.__len__() == 39; verified with Python 3.14.3"]
    - [dr_argc,     abc.ABCMeta._dump_registry.__code__.co_argcount.__eq__,  [2],                              true,  "abc.ABCMeta._dump_registry.__code__.co_argcount == 2 ('cls','file'); verified with Python 3.14.3"]
    - [arc_qn_eq,   abc.ABCMeta._abc_registry_clear.__qualname__.__eq__,     ["ABCMeta._abc_registry_clear"],  true,  "abc.ABCMeta._abc_registry_clear.__qualname__ == 'ABCMeta._abc_registry_clear' (len=27); verified with Python 3.14.3"]
    - [arc_qn_len,  abc.ABCMeta._abc_registry_clear.__qualname__.__len__,     [],                              27,    "abc.ABCMeta._abc_registry_clear.__qualname__.__len__() == 27; verified with Python 3.14.3"]
    - [acc_qn_eq,   abc.ABCMeta._abc_caches_clear.__qualname__.__eq__,       ["ABCMeta._abc_caches_clear"],    true,  "abc.ABCMeta._abc_caches_clear.__qualname__ == 'ABCMeta._abc_caches_clear' (len=25); verified with Python 3.14.3"]
    - [acc_qn_len,  abc.ABCMeta._abc_caches_clear.__qualname__.__len__,       [],                              25,    "abc.ABCMeta._abc_caches_clear.__qualname__.__len__() == 25; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.abstractmethod code object introspection — extra138
#
# abc.abstractmethod.__name__                  == 'abstractmethod' (len=14)
# abc.abstractmethod.__doc__.__len__()         == 537
# abc.abstractmethod.__code__.co_argcount      == 1
# abc.abstractmethod.__code__.co_consts.__len__() == 2
# abc.abstractmethod.__code__.co_varnames.__len__() == 1
# ---------------------------------------------------------------------------

table abc_extra138.abstractmethod_code:
  description: "abc.abstractmethod code object introspection — abstractmethod.__name__.__eq__('abstractmethod')==True (len=14: 'abstractmethod'=14); abstractmethod.__module__.__eq__('abc')==True (len=3: implemented in the pure-Python abc module, unlike get_cache_token which lives in _abc); abstractmethod.__doc__.__len__()==537 (multi-paragraph doc with class example showing @abstractmethod usage); abstractmethod.__code__.co_argcount.__eq__(1)==True (takes only 'funcobj', the decorated function); abstractmethod.__code__.co_consts.__len__()==2 (constants are: the docstring and True — True is the value assigned to funcobj.__isabstractmethod__); abstractmethod.__code__.co_varnames.__len__()==1 ('funcobj' is the only local variable — no additional locals, a minimal decorator body); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcam138

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,    abc.abstractmethod.__name__.__eq__,                      ["abstractmethod"],  true,  "abc.abstractmethod.__name__ == 'abstractmethod' (len=14); verified with Python 3.14.3"]
    - [name_len,   abc.abstractmethod.__name__.__len__,                      [],                 14,    "abc.abstractmethod.__name__.__len__() == 14; verified with Python 3.14.3"]
    - [mod_eq,     abc.abstractmethod.__module__.__eq__,                    ["abc"],             true,  "abc.abstractmethod.__module__ == 'abc' (len=3: pure-Python abc module, not the C extension _abc); verified with Python 3.14.3"]
    - [doc_len,    abc.abstractmethod.__doc__.__len__,                       [],                 537,   "abc.abstractmethod.__doc__.__len__() == 537; verified with Python 3.14.3"]
    - [argc,       abc.abstractmethod.__code__.co_argcount.__eq__,          [1],                 true,  "abc.abstractmethod.__code__.co_argcount == 1 ('funcobj' only); verified with Python 3.14.3"]
    - [consts_len, abc.abstractmethod.__code__.co_consts.__len__,            [],                 2,     "abc.abstractmethod.__code__.co_consts.__len__() == 2 (the docstring and True); verified with Python 3.14.3"]
    - [vlen,       abc.abstractmethod.__code__.co_varnames.__len__,          [],                 1,     "abc.abstractmethod.__code__.co_varnames.__len__() == 1 ('funcobj' only); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
