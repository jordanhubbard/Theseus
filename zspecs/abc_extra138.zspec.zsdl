# ---------------------------------------------------------------------------

table abc_extra138.abcmeta_new:
  description: "abc.ABCMeta.__new__ qualname and code checks — ABCMeta.__new__.__qualname__.__eq__('ABCMeta.__new__')==True (len=15: 'ABCMeta'=7+'.'=1+'__new__'=7=15); ABCMeta.__new__.__qualname__.__len__()==15; ABCMeta.__new__.__code__.co_argcount.__eq__(4)==True (parameters are 'mcls','name','bases','namespace' — the metaclass, the new class name, base classes tuple, and class namespace dict — the four arguments passed to a metaclass __new__); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcnew138

  columns: [id, function, args, expected, description]
  rows:
    - [qn_eq,    abc.ABCMeta.__new__.__qualname__.__eq__,      ["ABCMeta.__new__"],  true,  "abc.ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__' (len=15); verified with Python 3.14.3"]
    - [qn_len,   abc.ABCMeta.__new__.__qualname__.__len__,      [],                  15,    "abc.ABCMeta.__new__.__qualname__.__len__() == 15; verified with Python 3.14.3"]
    - [argc,     abc.ABCMeta.__new__.__code__.co_argcount.__eq__, [4],               true,  "abc.ABCMeta.__new__.__code__.co_argcount == 4 ('mcls','name','bases','namespace'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra138
# ---------------------------------------------------------------------------

invariant abc_extra138.abc_dict_class_name_mappingproxy:
  description: "abc.ABC.__dict__.__class__.__name__.__len__() == 12 — abc.ABC.__dict__.__class__.__name__ is 'mappingproxy' (12 chars: the read-only mapping type wrapping every class __dict__ in Python); abc.ABC.__name__=='ABC' (len=3); abc.ABC.__module__=='abc' (len=3); distinct from dict (4 chars) — the mappingproxy prevents direct assignment to class attributes via __dict__; NEW in extra138: first standalone ABC.__dict__.__class__.__name__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  "function": "abc.ABC.__dict__.__class__.__name__.__len__"
  args: []
  expected: 12

invariant abc_extra138.abc_abstractmethods_class_frozenset:
  description: "abc.ABC.__abstractmethods__.__class__.__name__.__len__() == 9 — abc.ABC.__abstractmethods__.__class__.__name__ is 'frozenset' (9 chars: the immutable set type used to track abstract method names); abc.ABC.__abstractmethods__ is frozenset() (empty) because ABC itself has no abstract methods — it is just a helper base class; this frozenset is checked at class instantiation time by type.__call__ to prevent instantiation of classes with unimplemented abstract methods; NEW in extra138: first standalone ABC.__abstractmethods__.__class__.__name__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  "function": "abc.ABC.__abstractmethods__.__class__.__name__.__len__"
  args: []
  expected: 9

invariant abc_extra138.abcmeta_dict_len_11:
  description: "abc.ABCMeta.__dict__.__len__() == 11 — abc.ABCMeta.__dict__ has 11 entries: __module__, __firstlineno__, __doc__, __new__, register, __instancecheck__, __subclasscheck__, _dump_registry, _abc_registry_clear, _abc_caches_clear, __static_attributes__; this is the count of methods and attributes defined directly on ABCMeta (not inherited from type); NEW in extra138: first standalone ABCMeta.__dict__.__len__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__len__
  args: []
  expected: 11

invariant abc_extra138.abstractmethod_doc_len_537:
  description: "abc.abstractmethod.__doc__.__len__() == 537 — abc.abstractmethod.__doc__ is a 537-char multi-paragraph doc beginning 'A decorator indicating abstract methods.' and including a class example showing @abstractmethod usage; abstractmethod.__module__=='abc' (len=3: pure-Python implementation, unlike get_cache_token.__module__=='_abc'); co_argcount==1 (single-argument decorator taking 'funcobj'); co_consts.__len__()==2 (docstring and True); NEW in extra138: first standalone abstractmethod doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__doc__.__len__
  args: []
  expected: 537

invariant abc_extra138.abc_registry_clear_qualname_len_27:
  description: "abc.ABCMeta._abc_registry_clear.__qualname__.__len__() == 27 — abc.ABCMeta._abc_registry_clear.__qualname__ is 'ABCMeta._abc_registry_clear' (27 chars: 'ABCMeta'=7+'.'=1+'_abc_registry_clear'=19=27); this is the longest method qualname in this spec (compare: _abc_caches_clear=25, _dump_registry=22, __instancecheck__=25, ABCMeta.__new__=15); the _abc_ prefix indicates these are internal methods delegating to the C extension _abc; NEW in extra138: first standalone _abc_registry_clear qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta._abc_registry_clear.__qualname__.__len__
  args: []
  expected: 27

invariant abc_extra138.abc_class_doc_len_78:
  description: "abc.ABC.__doc__.__len__() == 78 — abc.ABC.__doc__ is 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n' (78 chars including the embedded newlines); ABC.__name__=='ABC' (len=3); ABC.__module__=='abc' (len=3); ABC.__abstractmethods__==frozenset() (empty frozenset); NEW in extra138: first standalone abc.ABC.__doc__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__doc__.__len__
  args: []
  expected: 78

invariant abc_extra138.abstractmethod_consts_len_2:
  description: "abc.abstractmethod.__code__.co_consts.__len__() == 2 — abc.abstractmethod.__code__.co_consts contains exactly 2 constants: the docstring (the 537-char decorator description) and True (the value assigned to funcobj.__isabstractmethod__ to mark it as abstract); this minimal constant pool reflects the simplicity of the abstractmethod decorator body; co_argcount==1 ('funcobj'); co_varnames.__len__()==1 ('funcobj', no additional locals); NEW in extra138: first standalone abstractmethod co_consts length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__code__.co_consts.__len__
  args: []
  expected: 2
