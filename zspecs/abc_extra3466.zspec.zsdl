spec: ab3466
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 678 (ab3466): __iter__, __next__, __len__ dict-presence checks for abc module types."
    - "Theme: __iter__/__next__/__len__ dict-presence (iter(x), next(x), len(x))."
    - "All values False — abc types are abstract base class machinery with no custom iter/next/len defined in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: abc.ABC, abc.ABCMeta, and type(abc.abstractmethod(lambda: None)) — the built-in function type."
    - "Key finding (__iter__): all 3 abc subjects return false for __iter__. iter(x) calls __iter__ when defined in the class's own __dict__. abc.ABC is a pure abstract base class convenience wrapper with no __iter__ in its own __dict__. abc.ABCMeta is a metaclass responsible for abstract method tracking and virtual subclass registration; iteration has no role in ABCMeta's responsibilities and __iter__ is absent from ABCMeta.__dict__. The function type (type(abc.abstractmethod(lambda: None)) is <class 'function'>) does not define __iter__ in its own __dict__ — functions are callables and descriptors; iteration is not meaningful for function objects."
    - "Key finding (__next__): all 3 abc subjects return false for __next__. next(x) delegates to __next__ when defined in the class's own __dict__. abc.ABC: no __next__ in its own __dict__; calling next() raises TypeError by default. abc.ABCMeta: does not define __next__ in ABCMeta.__dict__; the metaclass's API surface (__subclasshook__, register(), __abstractmethods__) has no iterator advancement component. The function type: functions define no __next__ in their own __dict__; calling next() on a function object raises TypeError at runtime."
    - "Key finding (__len__): all 3 abc subjects return false for __len__. len(x) delegates to __len__ when defined in the class's own __dict__. abc.ABC: no __len__ in its own __dict__; len() raises TypeError by default. abc.ABCMeta: does not define __len__ in ABCMeta.__dict__. The function type: functions define no sizing protocol in their own __dict__; len(f) raises TypeError at runtime. Wave 656 (ab3136) already confirmed __len__ is false for all 3 abc subjects."
    - "All 9 values in this wave are false — consistent with the all-false pattern for iterator/sizing dunders first tested for __len__ in wave 656."
    - "The function type profile across all waves: true only for __get__ (wave 652), __repr__ (wave 655), and __call__ (wave 656). All other dunders tested — including this wave's __iter__, __next__, and __len__ (at the dict-contains level) — are false."
    - "abc.ABCMeta has now returned false for every dunder tested across 27 consecutive waves (652–678). Its entire capability is expressed through class-hierarchy machinery — not operator overloading, comparison, display, iteration, or sizing protocol overrides."
    - "Cross-wave summary for abc subjects:"
    - "  Wave 652 (ab3076): __get__ true for function type; __set__/__delete__ false."
    - "  Wave 653 (ab3091): __hash__/__eq__/__bool__ all false for all 3."
    - "  Wave 654 (ab3106): __lt__/__le__/__gt__ all false for all 3."
    - "  Wave 655 (ab3121): __ge__ false; __repr__ true for function type only; __str__ false."
    - "  Wave 656 (ab3136): __call__ true for function type only; __len__/__getitem__ false."
    - "  Wave 657 (ab3151): __setitem__/__delitem__/__contains__ — all false for all 3."
    - "  Wave 658 (ab3166): __add__/__sub__/__mul__ — all false for all 3."
    - "  Wave 659 (ab3181): __truediv__/__floordiv__/__mod__ — all false for all 3."
    - "  Wave 660 (ab3196): __pow__/__lshift__/__rshift__ — all false for all 3."
    - "  Wave 661 (ab3211): __and__/__or__/__xor__ — all false for all 3."
    - "  Wave 662 (ab3226): __radd__/__rsub__/__rmul__ — all false for all 3."
    - "  Wave 663 (ab3241): __rtruediv__/__rfloordiv__/__rmod__ — all false for all 3."
    - "  Wave 664 (ab3256): __rpow__/__rlshift__/__rrshift__ — all false for all 3."
    - "  Wave 665 (ab3271): __rand__/__ror__/__rxor__ — all false for all 3."
    - "  Wave 666 (ab3286): __iadd__/__isub__/__imul__ — all false for all 3."
    - "  Wave 667 (ab3301): __itruediv__/__ifloordiv__/__imod__ — all false for all 3."
    - "  Wave 668 (ab3316): __ipow__/__ilshift__/__irshift__ — all false for all 3."
    - "  Wave 669 (ab3331): __iand__/__ior__/__ixor__ — all false for all 3."
    - "  Wave 670 (ab3346): __neg__/__pos__/__abs__ — all false for all 3."
    - "  Wave 671 (ab3361): __invert__/__floor__/__ceil__ — all false for all 3."
    - "  Wave 672 (ab3376): __trunc__/__round__/__index__ — all false for all 3."
    - "  Wave 673 (ab3391): __int__/__float__/__complex__ — all false for all 3."
    - "  Wave 674 (ab3406): __bool__/__str__/__repr__ — all false for all 3."
    - "  Wave 675 (ab3421): __hash__/__eq__/__lt__ — all false for all 3."
    - "  Wave 676 (ab3436): __le__/__gt__/__ge__ — all false for all 3."
    - "  Wave 677 (ab3451): __getitem__/__setitem__/__delitem__ — all false for all 3."
    - "  Wave 678 (ab3466): __iter__/__next__/__len__ — all false for all 3."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __iter__ dict-presence — operator.contains(Cls.__dict__, '__iter__')
#
# All 3 abc subjects return false for __iter__.
# iter(x) calls __iter__ when defined in the class's own __dict__.
# abc.ABC: a plain abstract base class convenience wrapper with no __iter__
#   in its own __dict__. iter(obj) raises TypeError by default since object
#   provides no __iter__.
# abc.ABCMeta: a metaclass for abstract method tracking and virtual subclass
#   registration. __iter__ is absent from ABCMeta.__dict__ — the metaclass's
#   API surface (__subclasshook__, register(), __abstractmethods__) has no
#   iteration component.
# type(abc.abstractmethod(lambda: None)) is <class 'function'>:
#   functions do not define __iter__ in their own __dict__. iter(f) on a
#   function object raises TypeError at runtime.
# ---------------------------------------------------------------------------

table ab3466.iter:
  description: "abc types __iter__ dict-presence checks; wave 678"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3466

  columns: [id, function, args, expected]
  rows:
    - ["ab3466001", operator.contains, [abc.ABC.__dict__,                                 "__iter__"], false]
    - ["ab3466002", operator.contains, [abc.ABCMeta.__dict__,                             "__iter__"], false]
    - ["ab3466003", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__iter__"], false]

# ---------------------------------------------------------------------------
# __next__ dict-presence — operator.contains(Cls.__dict__, '__next__')
#
# All 3 abc subjects return false for __next__.
# next(x) delegates to __next__ when defined in the class's own __dict__.
# abc.ABC: no __next__ in its own __dict__; next(obj) raises TypeError
#   by default since object does not define __next__.
# abc.ABCMeta: does not define __next__ in ABCMeta.__dict__. The metaclass
#   is focused on abstract method registration and subclass checking, not
#   iterator advancement.
# type(abc.abstractmethod(lambda: None)) is <class 'function'>:
#   functions do not define __next__ in their own __dict__. next(f)
#   raises TypeError at runtime since object provides no __next__.
# ---------------------------------------------------------------------------

table ab3466.next:
  description: "abc types __next__ dict-presence checks; wave 678"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3466

  columns: [id, function, args, expected]
  rows:
    - ["ab3466004", operator.contains, [abc.ABC.__dict__,                                 "__next__"], false]
    - ["ab3466005", operator.contains, [abc.ABCMeta.__dict__,                             "__next__"], false]
    - ["ab3466006", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__next__"], false]

# ---------------------------------------------------------------------------
# __len__ dict-presence — operator.contains(Cls.__dict__, '__len__')
#
# All 3 abc subjects return false for __len__.
# len(x) delegates to __len__ when defined in the class's own __dict__.
# abc.ABC: no __len__ in its own __dict__; len(obj) raises TypeError
#   by default since object does not define __len__.
# abc.ABCMeta: does not define __len__ in ABCMeta.__dict__. The metaclass
#   is focused on abstract method registration and subclass checking, not
#   sizing. Wave 656 (ab3136) first confirmed this result.
# type(abc.abstractmethod(lambda: None)) is <class 'function'>:
#   functions do not define __len__ in their own __dict__. len(f)
#   raises TypeError at runtime since object provides no __len__.
#   Wave 656 (ab3136) first confirmed this result.
# ---------------------------------------------------------------------------

table ab3466.len:
  description: "abc types __len__ dict-presence checks; wave 678"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
