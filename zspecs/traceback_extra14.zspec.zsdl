spec: traceback_extra14
version: ">=3.9"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/traceback.html — Python traceback module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
  notes:
    - "This spec extends traceback.zspec.zsdl through traceback_extra13.zspec.zsdl."
    - "Prior specs cover: __name__/__qualname__/__module__ for print_exc/print_tb/format_exc/format_tb/extract_tb/extract_stack/walk_tb/walk_stack/clear_frames/format_exception/print_exception/format_list/print_list/format_exception_only/format_stack/print_stack; TracebackException/__name__/__qualname__/__module__/__bases__/__mro__; StackSummary/__name__/__qualname__/__module__/__bases__/__mro__; FrameSummary/__name__/__qualname__/__module__/__bases__/__mro__; __class__.__name__ == 'function' for all 16 module-level functions."
    - "This spec covers: __qualname__ for format_exc/print_exc/format_tb/extract_tb as standalone invariants (prior specs record these only in table rows); __class__.__name__ == 'type' for TracebackException/StackSummary/FrameSummary (not yet recorded in any prior spec)."
    - "traceback.TracebackException, StackSummary, and FrameSummary are plain Python classes; their metaclass is the builtin 'type'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level functions — __qualname__ as standalone invariants
#
# Prior specs record __qualname__ for all 16 traceback module-level functions
# in table rows. The four functions most prominent in the task specification
# (format_exc, format_exc.__module__, print_exc, format_tb, extract_tb) are
# recorded here as standalone invariants for individual addressability.
# Note: __qualname__ == __name__ for all top-level functions (no enclosing
# class or scope).
# ---------------------------------------------------------------------------

invariant traceback_extra14.format_exc.qualname:
  description: "traceback.format_exc.__qualname__ == 'format_exc'"
  category: function_identity
  kind: python_call_eq
  function: format_exc.__qualname__.__eq__
  args: ["format_exc"]
  expected: true

invariant traceback_extra14.print_exc.qualname:
  description: "traceback.print_exc.__qualname__ == 'print_exc'"
  category: function_identity
  kind: python_call_eq
  function: print_exc.__qualname__.__eq__
  args: ["print_exc"]
  expected: true

invariant traceback_extra14.format_tb.qualname:
  description: "traceback.format_tb.__qualname__ == 'format_tb'"
  category: function_identity
  kind: python_call_eq
  function: format_tb.__qualname__.__eq__
  args: ["format_tb"]
  expected: true

invariant traceback_extra14.extract_tb.qualname:
  description: "traceback.extract_tb.__qualname__ == 'extract_tb'"
  category: function_identity
  kind: python_call_eq
  function: extract_tb.__qualname__.__eq__
  args: ["extract_tb"]
  expected: true

# ---------------------------------------------------------------------------
# TracebackException, StackSummary, FrameSummary — __class__.__name__
#
# Prior specs record __name__, __qualname__, __module__, __bases__, and
# __mro__ for all three classes, but no prior spec records __class__.__name__
# for any of them. All three are plain Python classes whose metaclass is the
# builtin 'type'.
# ---------------------------------------------------------------------------

table traceback_extra14.class_metaclass_names:
  description: "__class__.__name__ == 'type' for TracebackException, StackSummary, FrameSummary"
  kind: python_call_eq
  category: class_identity

  columns: [id, function, args, expected]
  rows:
    - [TracebackException, TracebackException.__class__.__name__.__eq__, ["type"], true]
    - [StackSummary,       StackSummary.__class__.__name__.__eq__,       ["type"], true]
    - [FrameSummary,       FrameSummary.__class__.__name__.__eq__,       ["type"], true]
