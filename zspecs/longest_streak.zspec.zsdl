spec: longest_streak
version: ">=3.1.0"
backend: node(longest-streak)

docs: https://www.npmjs.com/package/longest-streak

provenance:
  derived_from:
    - "longest-streak README — https://www.npmjs.com/package/longest-streak"
    - "Test vectors verified with longest-streak via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "longest-streak source"
  notes:
    - "longest-streak is an npm package. Install: npm install longest-streak"
    - "Returns the length of the longest consecutive run of a character in a string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table longest_streak.longestStreak:
  kind: node_module_call_eq
  function: longestStreak
  category: string
  id_prefix: lstreak

  columns: [id, args, expected]
  rows:
    - [two_a,    ["aabaa",   "a"],  2]
    - [three_a,  ["aaabbc",  "a"],  3]
    - [one,      ["abcabc",  "a"],  1]
    - [none,     ["bbb",     "a"],  0]

