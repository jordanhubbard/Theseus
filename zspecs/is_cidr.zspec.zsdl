spec: is_cidr
version: ">=6.0.4"
backend: node(is-cidr)

docs: https://www.npmjs.com/package/is-cidr

provenance:
  derived_from:
    - "is-cidr README — https://www.npmjs.com/package/is-cidr"
    - "Test vectors verified with is-cidr via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "is-cidr source"
  notes:
    - "is-cidr is an npm package. Install: npm install is-cidr"
    - "Returns 4 for IPv4 CIDR, 6 for IPv6 CIDR, or 0 if not a valid CIDR."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns 4, 6, or 0."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_cidr.check:
  kind: node_module_call_eq
  function: "default"
  category: network
  id_prefix: icidr

  columns: [id, args, expected]
  rows:
    - [ipv4_cidr,  ["192.168.0.0/24"],  4]
    - [ipv6_cidr,  ["2001:db8::/32"],   6]
    - [not_cidr,   ["192.168.0.1"],     0]

