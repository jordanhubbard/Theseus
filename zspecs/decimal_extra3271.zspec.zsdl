spec: dc3271
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal: Decimal fixed-point and floating-point arithmetic"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 665 (dc3271): __rand__, __ror__, __rxor__ dict-presence checks for decimal types."
    - "Classes covered: decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow."
    - "Theme: __rand__, __ror__, __rxor__ dict-presence (reflected bitwise logical)."
    - "Decimal does NOT define __rand__ in its own __dict__: __rand__ is a reflected integer bitwise AND operator; Decimal is an IEEE 754 floating-point type without bitwise semantics, consistent with wave 661 where __and__ = false for Decimal."
    - "Decimal does NOT define __ror__ in its own __dict__: __ror__ is a reflected integer bitwise OR operator; Decimal does not support bitwise OR, consistent with wave 661 where __or__ = false for Decimal."
    - "Decimal does NOT define __rxor__ in its own __dict__: __rxor__ is a reflected integer bitwise XOR operator; Decimal does not support bitwise XOR, consistent with wave 661 where __xor__ = false for Decimal."
    - "decimal.Context does NOT define __rand__, __ror__, or __rxor__ in its own __dict__: Context is a precision/rounding configuration object, not a numeric operand."
    - "decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow are exception subclasses with no arithmetic protocol defined in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __rand__ dict-presence — operator.contains(Cls.__dict__, '__rand__')
#
# decimal.Decimal does NOT define __rand__ in its own __dict__: false.
# __rand__ is the reflected integer bitwise AND operator; Decimal is an
# IEEE 754 decimal floating-point type with no bitwise semantics.
# Consistent with wave 661 where __and__ = false for Decimal.
# All decimal classes: false.
# ---------------------------------------------------------------------------

table dc3271.rand:
  description: "decimal types __rand__ dict-presence checks; wave 665"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3271

  columns: [id, function, args, expected]
  rows:
    - ["dc3271001", operator.contains, [decimal.Decimal.__dict__,          "__rand__"], false]
    - ["dc3271002", operator.contains, [decimal.Context.__dict__,           "__rand__"], false]
    - ["dc3271003", operator.contains, [decimal.DecimalException.__dict__,  "__rand__"], false]
    - ["dc3271004", operator.contains, [decimal.InvalidOperation.__dict__,  "__rand__"], false]
    - ["dc3271005", operator.contains, [decimal.Overflow.__dict__,          "__rand__"], false]
    - ["dc3271006", operator.contains, [decimal.Underflow.__dict__,         "__rand__"], false]

