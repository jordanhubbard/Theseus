spec: inspect_extra208
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "Python inspect documentation — https://docs.python.org/3/library/inspect.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect_extra207.zspec.zsdl — covers co_flags, co_stacksize, and co_filename checks for signature, getmembers, getsource, getfile, isfunction, isclass"
    - "inspect_extra.zspec.zsdl — covers __name__ and __module__ checks for inspect functions; isclass/isbuiltin/isfunction behavioral checks"
    - "inspect_signature.zspec.zsdl — covers BoundArguments, Signature, Parameter kinds and attributes"
  notes:
    - "inspect.signature.__code__.co_varnames is a tuple of 6 elements: ('obj', 'follow_wrapped', 'globals', 'locals', 'eval_str', 'annotation_format'). Verified with Python 3.14.3."
    - "inspect.signature.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple of local variable names. Verified with Python 3.14.3."
    - "inspect.getmembers.__code__.co_varnames is a tuple of 2 elements: ('object', 'predicate'). It does NOT contain 'key'. Verified with Python 3.14.3."
    - "inspect.getmembers.__code__.co_varnames.__contains__('key') == False — getmembers uses 'predicate' not 'key' for the filter argument. Verified with Python 3.14.3."
    - "inspect.getsource.__code__.co_varnames is a tuple of 3 elements: ('object', 'lines', 'lnum'). It contains 'lines'. Verified with Python 3.14.3."
    - "inspect.Parameter.__dict__.__contains__('POSITIONAL_ONLY') == True — POSITIONAL_ONLY is a class attribute of Parameter. Verified with Python 3.14.3."
    - "inspect.Parameter.__dict__.__contains__('KEYWORD_ONLY') == True — KEYWORD_ONLY is a class attribute of Parameter. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: co_varnames.__class__.__name__ == 'tuple' and __len__ for inspect functions
#
# inspect.signature has 6 co_varnames.
# inspect.getmembers has 2 co_varnames.
# inspect.getsource has 3 co_varnames.
# All co_varnames are tuple instances.
# ---------------------------------------------------------------------------

table inspect_extra208.co_varnames_class_and_len:
  description: "__code__.co_varnames.__class__.__name__ == 'tuple' and __len__ for inspect functions; signature has 6, getmembers has 2, getsource has 3; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_object
  id_prefix: inspectcovarnames208

  columns: [id, function, args, expected, description]
  rows:
    - [signature_varnames_class,
       "inspect.signature.__code__.co_varnames.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "inspect.signature.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is a tuple of 6 local variable names: obj, follow_wrapped, globals, locals, eval_str, annotation_format; str.__eq__('tuple') returns True; new to extra208"]
    - [signature_varnames_len,
       "inspect.signature.__code__.co_varnames.__len__",
       [],
       6,
       "inspect.signature.__code__.co_varnames.__len__() == 6 — signature has 6 local variable names: obj, follow_wrapped, globals, locals, eval_str, annotation_format; tuple.__len__() returns 6; new to extra208"]
    - [getmembers_varnames_class,
       "inspect.getmembers.__code__.co_varnames.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "inspect.getmembers.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is a tuple of 2 local variable names: object, predicate; str.__eq__('tuple') returns True; new to extra208"]
    - [getsource_varnames_class,
       "inspect.getsource.__code__.co_varnames.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "inspect.getsource.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is a tuple of 3 local variable names: object, lines, lnum; str.__eq__('tuple') returns True; new to extra208"]

# ---------------------------------------------------------------------------
# Table 2: co_varnames.__contains__ membership checks for inspect functions
#
# signature: does not contain 'key' but contains 'obj'
# getmembers: does not contain 'key' (uses 'predicate') — False
# getsource: contains 'lines' — True
# getsource: contains 'lnum' — True
# ---------------------------------------------------------------------------

table inspect_extra208.co_varnames_contains:
  description: "__code__.co_varnames.__contains__ membership checks for inspect functions; getmembers does not contain 'key' (uses 'predicate'); getsource contains 'lines' and 'lnum'; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_object
  id_prefix: inspectcovarnames208

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_not_contains_key,
       "inspect.getmembers.__code__.co_varnames.__contains__",
       ["key"],
       false,
       "inspect.getmembers.__code__.co_varnames.__contains__('key') == False — getmembers uses 'predicate' not 'key' for its filter argument; the co_varnames tuple is ('object', 'predicate'); tuple.__contains__('key') returns False; new to extra208"]
    - [getsource_contains_lines,
       "inspect.getsource.__code__.co_varnames.__contains__",
       ["lines"],
       true,
       "inspect.getsource.__code__.co_varnames.__contains__('lines') == True — 'lines' is a local variable in getsource storing the source lines from findsource; tuple.__contains__('lines') returns True; new to extra208"]
    - [getsource_contains_lnum,
       "inspect.getsource.__code__.co_varnames.__contains__",
       ["lnum"],
       true,
       "inspect.getsource.__code__.co_varnames.__contains__('lnum') == True — 'lnum' is a local variable in getsource storing the line number from findsource; tuple.__contains__('lnum') returns True; new to extra208"]
    - [signature_contains_obj,
       "inspect.signature.__code__.co_varnames.__contains__",
       ["obj"],
       true,
       "inspect.signature.__code__.co_varnames.__contains__('obj') == True — 'obj' is the first positional argument to inspect.signature (the callable whose signature is retrieved); tuple.__contains__('obj') returns True; new to extra208"]

# ---------------------------------------------------------------------------
# Table 3: Parameter.__dict__ membership checks
#
# inspect.Parameter defines kind constants as class attributes.
# POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD, VAR_POSITIONAL, KEYWORD_ONLY,
# VAR_KEYWORD are all present in Parameter.__dict__.
# ---------------------------------------------------------------------------

table inspect_extra208.parameter_dict_contains:
  description: "inspect.Parameter.__dict__.__contains__ checks for kind constants; POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD, KEYWORD_ONLY, VAR_POSITIONAL, VAR_KEYWORD are all class attributes of Parameter; verified with Python 3.14.3"
  kind: python_call_eq
  category: parameter
  id_prefix: inspectcovarnames208

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_has_positional_only,
       "inspect.Parameter.__dict__.__contains__",
       ["POSITIONAL_ONLY"],
       true,
       "inspect.Parameter.__dict__.__contains__('POSITIONAL_ONLY') == True — POSITIONAL_ONLY is a ParameterKind class attribute on Parameter; dict.__contains__('POSITIONAL_ONLY') returns True; new to extra208"]
    - [parameter_has_keyword_only,
       "inspect.Parameter.__dict__.__contains__",
       ["KEYWORD_ONLY"],
       true,
       "inspect.Parameter.__dict__.__contains__('KEYWORD_ONLY') == True — KEYWORD_ONLY is a ParameterKind class attribute on Parameter; dict.__contains__('KEYWORD_ONLY') returns True; new to extra208"]
    - [parameter_has_var_positional,
       "inspect.Parameter.__dict__.__contains__",
       ["VAR_POSITIONAL"],
       true,
       "inspect.Parameter.__dict__.__contains__('VAR_POSITIONAL') == True — VAR_POSITIONAL is a ParameterKind class attribute on Parameter representing *args parameters; dict.__contains__('VAR_POSITIONAL') returns True; new to extra208"]
    - [parameter_has_var_keyword,
       "inspect.Parameter.__dict__.__contains__",
       ["VAR_KEYWORD"],
       true,
       "inspect.Parameter.__dict__.__contains__('VAR_KEYWORD') == True — VAR_KEYWORD is a ParameterKind class attribute on Parameter representing **kwargs parameters; dict.__contains__('VAR_KEYWORD') returns True; new to extra208"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra208
# ---------------------------------------------------------------------------

invariant inspect_extra208.signature_varnames_class_tuple:
  description: "inspect.signature.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is a tuple of 6 local variable names for signature; new to extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: inspect.signature.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant inspect_extra208.signature_varnames_len_6:
  description: "inspect.signature.__code__.co_varnames.__len__() == 6 — signature has 6 local variable names: obj, follow_wrapped, globals, locals, eval_str, annotation_format; new to extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: inspect.signature.__code__.co_varnames.__len__
  args: []
  expected: 6

invariant inspect_extra208.getmembers_varnames_not_contains_key:
  description: "inspect.getmembers.__code__.co_varnames.__contains__('key') == False — getmembers uses 'predicate' not 'key'; co_varnames is ('object', 'predicate'); new to extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: inspect.getmembers.__code__.co_varnames.__contains__
  args: ["key"]
  expected: false

invariant inspect_extra208.getsource_varnames_contains_lines:
  description: "inspect.getsource.__code__.co_varnames.__contains__('lines') == True — 'lines' is a local variable in getsource; new to extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: inspect.getsource.__code__.co_varnames.__contains__
  args: ["lines"]
  expected: true

invariant inspect_extra208.parameter_dict_has_positional_only:
  description: "inspect.Parameter.__dict__.__contains__('POSITIONAL_ONLY') == True — POSITIONAL_ONLY is a class attribute of Parameter; new to extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: inspect.Parameter.__dict__.__contains__
  args: ["POSITIONAL_ONLY"]
  expected: true

invariant inspect_extra208.parameter_dict_has_keyword_only:
  description: "inspect.Parameter.__dict__.__contains__('KEYWORD_ONLY') == True — KEYWORD_ONLY is a class attribute of Parameter; new to extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: inspect.Parameter.__dict__.__contains__
  args: ["KEYWORD_ONLY"]
  expected: true

invariant inspect_extra208.getmembers_varnames_class_tuple:
  description: "inspect.getmembers.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is a tuple of 2 local variable names: object, predicate; new to extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: inspect.getmembers.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant inspect_extra208.getsource_varnames_class_tuple:
  description: "inspect.getsource.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is a tuple of 3 local variable names: object, lines, lnum; new to extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: inspect.getsource.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

