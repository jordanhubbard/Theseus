spec: threading_extra154
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.Thread class identity (__name__ 'Thread', __module__ 'threading', __bases__[0].__name__ 'object'); threading.Event class identity (__name__ 'Event', __module__ 'threading', __bases__[0].__name__ 'object'); threading.Lock.__class__.__name__ 'type' (Lock is a C builtin returning _thread.lock instances); threading.RLock.__name__ 'RLock'; threading.Semaphore class identity (__name__ 'Semaphore', __module__ 'threading', __bases__[0].__name__ 'object') (Wave 282)."
    - "threading.Thread.__name__ == 'Thread' — Thread is a Python class defined in Lib/threading.py; its __name__ is 'Thread'. Verified with Python 3.14.3."
    - "threading.Thread.__module__ == 'threading' — Thread is defined in Lib/threading.py; its __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.Thread.__bases__[0].__name__ == 'object' — Thread inherits directly from object; __bases__[0].__name__ is 'object'. Verified with Python 3.14.3."
    - "threading.Event.__name__ == 'Event' — Event is a Python class in Lib/threading.py; its __name__ is 'Event'. Verified with Python 3.14.3."
    - "threading.Event.__module__ == 'threading' — Event is defined in Lib/threading.py; its __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.Event.__bases__[0].__name__ == 'object' — Event inherits directly from object. Verified with Python 3.14.3."
    - "threading.Lock.__class__.__name__ == 'type' — Lock is a callable (a C builtin type alias) that creates _thread.lock objects; Lock itself is a class whose metaclass is type. Verified with Python 3.14.3."
    - "threading.RLock.__name__ == 'RLock' — RLock has __name__ attribute and its value is 'RLock'. Verified with Python 3.14.3."
    - "threading.Semaphore.__name__ == 'Semaphore' — Semaphore is a Python class in Lib/threading.py; its __name__ is 'Semaphore'. Verified with Python 3.14.3."
    - "threading.Semaphore.__module__ == 'threading' — Semaphore is defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Semaphore.__bases__[0].__name__ == 'object' — Semaphore inherits directly from object. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread class identity
#
# Wave 282 theme: threading.Thread and threading.Event class identity.
#
# threading.Thread.__name__ == 'Thread'
# threading.Thread.__module__ == 'threading'
# threading.Thread.__bases__[0].__name__ == 'object'
#
# Thread is the core class in Lib/threading.py representing a thread of
# control. It inherits directly from object. New to extra154.
# ---------------------------------------------------------------------------

table threading_extra154.thread_class_identity:
  description: "threading.Thread: __name__ 'Thread', __module__ 'threading', __bases__[0] 'object'; core threading class identity; wave 282; new to extra154"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingthreadid154

  columns: [id, function, args, expected, description]
  rows:
    - [thread_name_eq,
       "Thread.__name__.__eq__",
       ["Thread"],
       true,
       "threading.Thread.__name__.__eq__('Thread') == True — Thread is a Python class in Lib/threading.py representing a thread of control; its __name__ is 'Thread'; str.__eq__('Thread') returns True; new to extra154"]
    - [thread_module_eq_threading,
       "Thread.__module__.__eq__",
       ["threading"],
       true,
       "threading.Thread.__module__.__eq__('threading') == True — Thread is defined in Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra154"]
    - ["thread_bases_0_name_eq_object",
       "Thread.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Thread.__bases__[0].__name__.__eq__('object') == True — Thread inherits directly from object; __bases__ is (object,) so __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra154"]
    - [thread_qualname_eq,
       "Thread.__qualname__.__eq__",
       ["Thread"],
       true,
       "threading.Thread.__qualname__.__eq__('Thread') == True — Thread is defined at module scope in Lib/threading.py; its __qualname__ equals its __name__ 'Thread'; str.__eq__('Thread') returns True; new to extra154"]

# ---------------------------------------------------------------------------
# Table 2: threading.Event class identity
#
# Wave 282 theme: threading.Event class identity.
#
# threading.Event.__name__ == 'Event'
# threading.Event.__module__ == 'threading'
# threading.Event.__bases__[0].__name__ == 'object'
#
# Event is a Python class in Lib/threading.py that implements thread
# synchronization via a simple boolean flag. New to extra154.
# ---------------------------------------------------------------------------

table threading_extra154.event_class_identity:
  description: "threading.Event: __name__ 'Event', __module__ 'threading', __bases__[0] 'object'; synchronization primitive class identity; wave 282; new to extra154"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingeventid154

  columns: [id, function, args, expected, description]
  rows:
    - [event_name_eq,
       "Event.__name__.__eq__",
       ["Event"],
       true,
       "threading.Event.__name__.__eq__('Event') == True — Event is a Python class in Lib/threading.py that implements thread synchronization via a boolean flag; its __name__ is 'Event'; str.__eq__('Event') returns True; new to extra154"]
    - [event_module_eq_threading,
       "Event.__module__.__eq__",
       ["threading"],
       true,
       "threading.Event.__module__.__eq__('threading') == True — Event is defined in Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra154"]
    - ["event_bases_0_name_eq_object",
       "Event.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Event.__bases__[0].__name__.__eq__('object') == True — Event inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra154"]
    - [event_qualname_eq,
       "Event.__qualname__.__eq__",
       ["Event"],
       true,
       "threading.Event.__qualname__.__eq__('Event') == True — Event is defined at module scope in Lib/threading.py; its __qualname__ equals its __name__ 'Event'; str.__eq__('Event') returns True; new to extra154"]

# ---------------------------------------------------------------------------
# Table 3: threading.Lock, threading.RLock, threading.Semaphore identity
#
# Wave 282 theme: threading.Lock class type, threading.RLock name, and
# threading.Semaphore class identity.
#
# threading.Lock.__class__.__name__ == 'type'
# threading.RLock.__name__ == 'RLock'
# threading.Semaphore.__name__ == 'Semaphore'
# threading.Semaphore.__module__ == 'threading'
# threading.Semaphore.__bases__[0].__name__ == 'object'
#
# Lock is a C builtin factory from _thread that returns _thread.lock objects;
# Lock itself is a class (metaclass is type). RLock is a C type from _thread
# with __name__ 'RLock'. Semaphore is a pure-Python class in threading.py.
# New to extra154.
# ---------------------------------------------------------------------------

table threading_extra154.lock_rlock_semaphore_identity:
  description: "threading.Lock: __class__.__name__ 'type'; threading.RLock: __name__ 'RLock'; threading.Semaphore: __name__ 'Semaphore', __module__ 'threading', __bases__[0] 'object'; wave 282; new to extra154"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadinglrsid154

  columns: [id, function, args, expected, description]
  rows:
    - [lock_class_eq_type,
       "Lock.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.Lock.__class__.__name__.__eq__('type') == True — Lock is a C builtin type alias from _thread that creates _thread.lock objects; Lock itself is a class whose metaclass is type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra154"]
    - [rlock_name_eq,
       "RLock.__name__.__eq__",
       ["RLock"],
       true,
       "threading.RLock.__name__.__eq__('RLock') == True — RLock is a C extension type from _thread for re-entrant locks; it has a __name__ attribute equal to 'RLock'; str.__eq__('RLock') returns True; new to extra154"]
    - [semaphore_name_eq,
       "Semaphore.__name__.__eq__",
       ["Semaphore"],
       true,
       "threading.Semaphore.__name__.__eq__('Semaphore') == True — Semaphore is a Python class in Lib/threading.py implementing counting semaphores; its __name__ is 'Semaphore'; str.__eq__('Semaphore') returns True; new to extra154"]
    - [semaphore_module_eq_threading,
       "Semaphore.__module__.__eq__",
       ["threading"],
       true,
       "threading.Semaphore.__module__.__eq__('threading') == True — Semaphore is defined in Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra154"]
    - ["semaphore_bases_0_name_eq_object",
       "Semaphore.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Semaphore.__bases__[0].__name__.__eq__('object') == True — Semaphore inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra154"]

