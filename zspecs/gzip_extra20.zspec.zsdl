spec: gzip_extra20
version: ">=3.8"
backend: python_module(gzip)

docs: https://docs.python.org/3/library/gzip.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gzip.html — Python gzip module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/gzip.py"
  notes:
    - "This spec extends gzip_extra19.zspec.zsdl."
    - "Prior specs covered: GzipFile/__name__/__module__/__qualname__, BadGzipFile/__name__/__module__, open/__name__/__module__, compress/__name__/__module__, decompress/__name__/__module__, GzipFile/__init__.__name__, BadGzipFile/__init__.__name__, open/__qualname__, compress/__qualname__, decompress/__qualname__, module/__len__() and __name__.__len__() and __qualname__.__len__() for various identifiers, GzipFile/__mro__.__len__(), BadGzipFile/__mro__.__len__(), GzipFile/__bases__[0].__name__.__len__(), BadGzipFile/__bases__[0].__name__.__len__(), GzipFile method __qualname__.__len__() for __init__, read, write, close."
    - "This spec covers: gzip.GzipFile.__dict__.__class__.__name__.__len__(), gzip.BadGzipFile.__dict__.__class__.__name__.__len__(), gzip.GzipFile.__name__.__len__(), gzip.BadGzipFile.__name__.__len__(), gzip.GzipFile.__qualname__.__len__(), gzip.BadGzipFile.__qualname__.__len__(), gzip.GzipFile.seek.__qualname__.__len__(), gzip.GzipFile.peek.__qualname__.__len__(), gzip.GzipFile.tell.__qualname__.__len__(), gzip.GzipFile.flush.__qualname__.__len__(), gzip.GzipFile.readable.__qualname__.__len__(), gzip.GzipFile.writable.__qualname__.__len__()."
    - "gzip.GzipFile.__dict__.__class__.__name__ == 'mappingproxy' (len 12): both GzipFile and BadGzipFile have __dict__ of type mappingproxy. Verified 2026-04-10."
    - "gzip.GzipFile.__name__ == 'GzipFile' (len 8). Verified 2026-04-10."
    - "gzip.BadGzipFile.__name__ == 'BadGzipFile' (len 11). Verified 2026-04-10."
    - "gzip.GzipFile.__qualname__ == 'GzipFile' (len 8): not a nested class, so __qualname__ == __name__. Verified 2026-04-10."
    - "gzip.BadGzipFile.__qualname__ == 'BadGzipFile' (len 11): not a nested class, so __qualname__ == __name__. Verified 2026-04-10."
    - "gzip.GzipFile.seek.__qualname__ == 'GzipFile.seek' (len 13). Verified 2026-04-10."
    - "gzip.GzipFile.peek.__qualname__ == 'GzipFile.peek' (len 13). Verified 2026-04-10."
    - "gzip.GzipFile.tell.__qualname__ == 'GzipFile.tell' (len 13). Verified 2026-04-10."
    - "gzip.GzipFile.flush.__qualname__ == 'GzipFile.flush' (len 14). Verified 2026-04-10."
    - "gzip.GzipFile.readable.__qualname__ == 'GzipFile.readable' (len 17). Verified 2026-04-10."
    - "gzip.GzipFile.writable.__qualname__ == 'GzipFile.writable' (len 17). Verified 2026-04-10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# GzipFile.__dict__.__class__.__name__.__len__() == 12 — novel, extra20 anchor
#
# gzip.GzipFile.__dict__ is of type mappingproxy. The class name 'mappingproxy'
# has 12 characters. No prior gzip spec checks __dict__.__class__.__name__.__len__()
# for GzipFile. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant gzip_extra20.GzipFile.dict_class_name_len:
  description: "gzip.GzipFile.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has twelve characters (extra20)"
  category: type_names
  kind: python_call_eq
  function: GzipFile.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# BadGzipFile.__dict__.__class__.__name__.__len__() == 12 — novel, extra20 anchor
#
# gzip.BadGzipFile.__dict__ is of type mappingproxy. The class name
# 'mappingproxy' has 12 characters. No prior gzip spec checks
# __dict__.__class__.__name__.__len__() for BadGzipFile. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant gzip_extra20.BadGzipFile.dict_class_name_len:
  description: "gzip.BadGzipFile.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has twelve characters (extra20)"
  category: type_names
  kind: python_call_eq
  function: BadGzipFile.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# GzipFile.__name__.__len__() == 8 — novel, extra20 anchor
#
# gzip.GzipFile.__name__ == 'GzipFile' which has 8 characters. No prior gzip
# spec checks __name__.__len__() directly on the GzipFile class object itself.
# Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant gzip_extra20.GzipFile.name_len:
  description: "gzip.GzipFile.__name__.__len__() == 8 — 'GzipFile' has eight characters (extra20)"
  category: name_lengths
  kind: python_call_eq
  function: GzipFile.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# BadGzipFile.__name__.__len__() == 11 — novel, extra20 anchor
#
# gzip.BadGzipFile.__name__ == 'BadGzipFile' which has 11 characters. No
# prior gzip spec checks __name__.__len__() on the BadGzipFile class object.
# Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant gzip_extra20.BadGzipFile.name_len:
  description: "gzip.BadGzipFile.__name__.__len__() == 11 — 'BadGzipFile' has eleven characters (extra20)"
  category: name_lengths
  kind: python_call_eq
  function: BadGzipFile.__name__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# GzipFile.__qualname__.__len__() == 8 — novel, extra20 anchor
#
# gzip.GzipFile.__qualname__ == 'GzipFile' which has 8 characters. GzipFile
# is not a nested class so __qualname__ == __name__. No prior gzip spec checks
# __qualname__.__len__() on the GzipFile class object itself. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant gzip_extra20.GzipFile.qualname_len:
  description: "gzip.GzipFile.__qualname__.__len__() == 8 — 'GzipFile' qualname has eight characters (extra20)"
  category: name_lengths
  kind: python_call_eq
  function: GzipFile.__qualname__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# BadGzipFile.__qualname__.__len__() == 11 — novel, extra20 anchor
#
# gzip.BadGzipFile.__qualname__ == 'BadGzipFile' which has 11 characters.
# BadGzipFile is not a nested class so __qualname__ == __name__. No prior gzip
# spec checks __qualname__.__len__() on the BadGzipFile class object itself.
# Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant gzip_extra20.BadGzipFile.qualname_len:
  description: "gzip.BadGzipFile.__qualname__.__len__() == 11 — 'BadGzipFile' qualname has eleven characters (extra20)"
  category: name_lengths
  kind: python_call_eq
  function: BadGzipFile.__qualname__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# GzipFile.seek.__qualname__.__len__() == 13 — novel, extra20 anchor
#
# gzip.GzipFile.seek.__qualname__ == 'GzipFile.seek' which has 13 characters.
# No prior gzip spec checks __qualname__.__len__() for GzipFile.seek.
# Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant gzip_extra20.GzipFile.seek_qualname_len:
  description: "gzip.GzipFile.seek.__qualname__.__len__() == 13 — 'GzipFile.seek' has thirteen characters (extra20)"
  category: name_lengths
  kind: python_call_eq
  function: GzipFile.seek.__qualname__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
