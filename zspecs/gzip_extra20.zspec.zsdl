invariant gzip_extra20.GzipFile.flush_qualname_len:
  description: "gzip.GzipFile.flush.__qualname__.__len__() == 14 — 'GzipFile.flush' has fourteen characters (extra20)"
  category: name_lengths
  kind: python_call_eq
