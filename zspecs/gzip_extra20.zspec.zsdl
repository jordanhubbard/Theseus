# ---------------------------------------------------------------------------
# __dict__.__class__.__name__.__len__() table — GzipFile, BadGzipFile (extra20)
#
# Both GzipFile and BadGzipFile store their class namespace as a mappingproxy.
# 'mappingproxy' has 12 characters. This table anchors both checks from the
# extra20 namespace.
# ---------------------------------------------------------------------------

table gzip_extra20.dict_class_name_lengths:
  kind: python_call_eq
  category: type_names
  id_prefix: dictcnlen20

  columns: [id, function, args, expected]
  rows:
    - [GzipFile,    GzipFile.__dict__.__class__.__name__.__len__,    [], 12]
    - [BadGzipFile, BadGzipFile.__dict__.__class__.__name__.__len__, [], 12]

# ---------------------------------------------------------------------------
# Class __name__.__len__() and __qualname__.__len__() table — GzipFile,
#                                                            BadGzipFile (extra20)
#
# GzipFile.__name__ == GzipFile.__qualname__ == 'GzipFile' (len 8);
# BadGzipFile.__name__ == BadGzipFile.__qualname__ == 'BadGzipFile' (len 11).
# Neither is a nested class so __qualname__ == __name__ for both.
# Verified 2026-04-10.
# ---------------------------------------------------------------------------

table gzip_extra20.class_name_qualname_lengths:
  kind: python_call_eq
  category: name_lengths
  id_prefix: classnqnlen20

  columns: [id, function, args, expected]
  rows:
    - [GzipFile_name,       GzipFile.__name__.__len__,       [], 8]
    - [GzipFile_qualname,   GzipFile.__qualname__.__len__,   [], 8]
    - [BadGzipFile_name,    BadGzipFile.__name__.__len__,    [], 11]
    - [BadGzipFile_qualname, BadGzipFile.__qualname__.__len__, [], 11]

# ---------------------------------------------------------------------------
# GzipFile extra method __qualname__.__len__() table — seek, peek, tell,
#                                                      flush, readable, writable
#                                                      (extra20)
#
# Six additional GzipFile methods not covered in extra19. seek=13, peek=13,
# tell=13, flush=14, readable=17, writable=17. Verified 2026-04-10.
# ---------------------------------------------------------------------------

table gzip_extra20.GzipFile_extra_method_qualname_lengths:
  kind: python_call_eq
  category: name_lengths
  id_prefix: extramethqnlen20

  columns: [id, function, args, expected]
  rows:
    - [seek,     GzipFile.seek.__qualname__.__len__,     [], 13]
    - [peek,     GzipFile.peek.__qualname__.__len__,     [], 13]
    - [tell,     GzipFile.tell.__qualname__.__len__,     [], 13]
    - [flush,    GzipFile.flush.__qualname__.__len__,    [], 14]
    - [readable, GzipFile.readable.__qualname__.__len__, [], 17]
    - [writable, GzipFile.writable.__qualname__.__len__, [], 17]
