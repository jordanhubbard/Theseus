spec: http_server_extra4
version: ">=3.9"
backend: python_module(http.server)

docs: https://docs.python.org/3/library/http.server.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/http.server.html — Python http.server module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/server.py"
  notes:
    - "This spec extends http_server.zspec.zsdl through http_server_extra3.zspec.zsdl."
    - "http_server.zspec.zsdl covers: class_names table; BaseHTTPRequestHandler string constants (server_version/protocol_version/default_request_version/error_content_type); extensions_map type."
    - "http_server_handlers.zspec.zsdl covers: modules; Simple→Base hierarchy; CGI→Simple hierarchy; HTTP→TCPServer hierarchy; SimpleHTTP server_version prefix; cgi_directories type and contents."
    - "http_server_extra.zspec.zsdl covers: BaseHTTPRequestHandler base (StreamRequestHandler); ThreadingHTTPServer module/bases[0/1]; SimpleHTTPRequestHandler.index_pages contains index.html; BaseHTTPRequestHandler.responses type and contains 200."
    - "http_server_extra2.zspec.zsdl covers: ThreadingHTTPServer/BaseHTTPRequestHandler/SimpleHTTPRequestHandler __qualname__; DEFAULT_ERROR_MESSAGE type; DEFAULT_ERROR_CONTENT_TYPE type/value; BaseHTTPRequestHandler rbufsize/wbufsize/disable_nagle_algorithm; responses contains 404/500; index_pages len/contains index.htm."
    - "http_server_extra3.zspec.zsdl covers: responses contains 301/302; CGIHTTPRequestHandler.cgi_directories len; extensions_map contains .html/empty-string key; DEFAULT_ERROR_MESSAGE nonempty; handler_string_nonempty table (server_version/protocol_version/default_request_version lengths); extensions_map['.html'] == 'text/html'."
    - "Focus: new axes not in any prior http.server spec."
    - "No prior spec covers: responses contains 100 (Continue) or 204 (No Content)."
    - "No prior spec covers: responses contains 400 (Bad Request) or 401 (Unauthorized) or 403 (Forbidden)."
    - "No prior spec covers: responses contains 503 (Service Unavailable)."
    - "No prior spec covers: extensions_map contains '.gz' or '.bz2' or '.xz'."
    - "No prior spec covers: extensions_map['.gz'] == 'application/gzip'."
    - "No prior spec covers: len(extensions_map) == 4."
    - "No prior spec covers: SimpleHTTPRequestHandler.__bases__[0].__name__ == 'BaseHTTPRequestHandler'."
    - "No prior spec covers: CGIHTTPRequestHandler.__bases__[0].__name__ == 'SimpleHTTPRequestHandler'."
    - "BaseHTTPRequestHandler.responses is a dict mapping int status codes to (short, long) description tuples."
    - "SimpleHTTPRequestHandler.extensions_map has exactly 4 entries on CPython 3.9+: .gz, .Z, .bz2, .xz."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BaseHTTPRequestHandler.responses — additional status codes not yet covered
#
# http_server_extra covers 200; http_server_extra2 covers 404/500;
# http_server_extra3 covers 301/302.
# 100 (Continue), 204 (No Content), 400 (Bad Request), 401 (Unauthorized),
# 403 (Forbidden), and 503 (Service Unavailable) are new.
# ---------------------------------------------------------------------------

table http_server_extra4.responses_more:
  kind: python_call_eq
  category: constants
  id_prefix: resp
  function: BaseHTTPRequestHandler.responses.__contains__

  columns: [id, args, expected]
  rows:
    - [r100, [100], true]
    - [r204, [204], true]
    - [r400, [400], true]
    - [r401, [401], true]
    - [r403, [403], true]
    - [r503, [503], true]

# ---------------------------------------------------------------------------
# SimpleHTTPRequestHandler.extensions_map — additional key/value checks
#
# http_server_extra3 covers contains '.html', contains '' (empty key),
# and extensions_map['.html'] == 'text/html'.
# The .gz, .bz2, .xz keys and extensions_map['.gz'] value are new.
# ---------------------------------------------------------------------------

table http_server_extra4.extensions_map_keys:
  kind: python_call_eq
  category: constants
  id_prefix: extkey
  function: SimpleHTTPRequestHandler.extensions_map.__contains__

  columns: [id, args, expected]
  rows:
    - [gz,  [".gz"],  true]
    - [bz2, [".bz2"], true]
    - [xz,  [".xz"],  true]

invariant http_server_extra4.extensions_map.gz_value:
  description: "SimpleHTTPRequestHandler.extensions_map['.gz'] == 'application/gzip'"
  category: constants
  kind: python_call_eq
  function: SimpleHTTPRequestHandler.extensions_map.__getitem__
  args: [".gz"]
  expected: "application/gzip"

invariant http_server_extra4.extensions_map.len:
  description: "len(SimpleHTTPRequestHandler.extensions_map) == 4 — exactly four entries on CPython 3.9+"
  category: constants
  kind: python_call_eq
  function: SimpleHTTPRequestHandler.extensions_map.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# SimpleHTTPRequestHandler and CGIHTTPRequestHandler — direct base class names
#
# http_server_handlers covers the Simple→Base and CGI→Simple inheritance
# via isinstance-style checks. No prior spec checks __bases__[0].__name__
# directly for these two classes.
# ---------------------------------------------------------------------------

invariant http_server_extra4.SimpleHTTPRequestHandler.base_name:
  description: "http.server.SimpleHTTPRequestHandler.__bases__[0].__name__ == 'BaseHTTPRequestHandler'"
  category: class_hierarchy
  kind: python_call_eq
  function: SimpleHTTPRequestHandler.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BaseHTTPRequestHandler"

invariant http_server_extra4.CGIHTTPRequestHandler.base_name:
  description: "http.server.CGIHTTPRequestHandler.__bases__[0].__name__ == 'SimpleHTTPRequestHandler'"
  category: class_hierarchy
  kind: python_call_eq
  function: CGIHTTPRequestHandler.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "SimpleHTTPRequestHandler"
