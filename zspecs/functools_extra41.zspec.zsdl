spec: functools_extra41
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra40.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for wraps(5)/partial(7)/lru_cache(9)/total_ordering(14)/singledispatch(14)/cached_property(15)/reduce(6)/cmp_to_key(10)/partialmethod(13)/singledispatchmethod(20)/update_wrapper(14); __qualname__.__len__() for update_wrapper(14)/partialmethod(13)/singledispatchmethod(20)/cache(5)/total_ordering(14)/singledispatch(14)/cmp_to_key(10)/cached_property(15)/lru_cache(9)/wraps(5)/reduce(6)/partial(7); WRAPPER_ASSIGNMENTS lengths and class name; WRAPPER_UPDATES lengths and class name; __all__.__len__()==15; __all__.__class__.__name__.__len__()==4; __all__[0].__len__()==14; __all__[1].__len__()==5; __all__[-1].__len__()==11; __all__[-2].__len__()==15; partial.__doc__.__class__.__name__.__len__()==3; reduce.__doc__.__len__()==389; partial.__doc__.__len__()==83; reduce(add,[1,2,3],10)==16; class __dict__.__class__.__name__.__len__() for partial/partialmethod/singledispatchmethod/cached_property (all 12)."
    - "This spec covers: partial.__class__.__name__.__len__() (4 — 'type', the metatype of class objects); lru_cache.__class__.__name__.__len__() (8 — 'function', since lru_cache is a plain decorator function); reduce.__class__.__name__.__len__() (26 — 'builtin_function_or_method', the longest class name in the module); functools.__all__[2].__len__() (19 — 'WRAPPER_ASSIGNMENTS', the longest __all__ entry); functools.__all__[3].__len__() (15 — 'WRAPPER_UPDATES'); functools.__all__[4].__len__() (14 — 'total_ordering')."
    - "Key findings: functools.partial.__class__.__name__ is 'type' (4 chars) — partial is itself a class and its metatype is the built-in 'type'. functools.lru_cache.__class__.__name__ is 'function' (8 chars) — lru_cache is implemented as a plain Python function (not a class). functools.reduce.__class__.__name__ is 'builtin_function_or_method' (26 chars) — the longest class name produced by any functools attribute, reflecting its C-level origin. functools.__all__[2] is 'WRAPPER_ASSIGNMENTS' (19 chars) — the single longest name in __all__. functools.__all__[3] is 'WRAPPER_UPDATES' (15 chars). functools.__all__[4] is 'total_ordering' (14 chars)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class metatype names — partial, lru_cache, reduce — extra41 namespace
#
# functools.partial.__class__.__name__ is 'type' (4 chars) — partial is a class,
# and its metatype is the built-in 'type'. functools.lru_cache.__class__.__name__
# is 'function' (8 chars) — lru_cache is a plain Python decorator function, not
# a class. functools.reduce.__class__.__name__ is 'builtin_function_or_method'
# (26 chars) — the longest metatype name produced by any functools attribute,
# reflecting its C-level (_functools) origin. No prior functools spec records
# these three metatype name lengths together in the extra41 namespace.
# ---------------------------------------------------------------------------

table functools_extra41.class_metatype_name_lengths:
  description: "functools attribute metatype __class__.__name__.__len__(): partial(4), lru_cache(8), reduce(26)"
  kind: python_call_eq
  category: string_properties
  id_prefix: metatypelen41

  columns: [id, function, args, expected, description]
  rows:
    - [partial_metatype,
       partial.__class__.__name__.__len__,
       [],
       4,
       "len(functools.partial.__class__.__name__) == 4 — 'type' (partial is a class; its metatype is the built-in 'type')"]
    - [lru_cache_metatype,
       lru_cache.__class__.__name__.__len__,
       [],
       8,
       "len(functools.lru_cache.__class__.__name__) == 8 — 'function' (lru_cache is a plain Python decorator function, not a class)"]
    - [reduce_metatype,
       reduce.__class__.__name__.__len__,
       [],
       26,
       "len(functools.reduce.__class__.__name__) == 26 — 'builtin_function_or_method' (the longest metatype name in functools, from C extension _functools)"]

# ---------------------------------------------------------------------------
# functools.__all__ indexed element lengths — [2], [3], [4] — extra41 namespace
#
# functools.__all__[2] is 'WRAPPER_ASSIGNMENTS' (19 chars) — the single longest
# name in __all__, longer than 'update_wrapper' (14) or 'cached_property' (15).
# functools.__all__[3] is 'WRAPPER_UPDATES' (15 chars) — second-longest alongside
# 'cached_property'. functools.__all__[4] is 'total_ordering' (14 chars) — sharing
# the same length as 'update_wrapper' (__all__[0]). Prior specs recorded __all__[0]
# (extra39), __all__[1] (extra40), __all__[-1] (extra38), and __all__[-2] (extra40),
# but not indices 2, 3, or 4. No prior functools spec records these three values
# together in the extra41 namespace.
# ---------------------------------------------------------------------------

table functools_extra41.all_mid_element_lengths:
  description: "functools.__all__ element lengths at indices [2](19), [3](15), [4](14)"
  kind: python_call_eq
  category: module_metadata
  id_prefix: allmidelem41

  columns: [id, function, args, expected, description]
  rows:
    - [all_idx2,
       "__all__[2].__len__",
       [],
       19,
       "len(functools.__all__[2]) == 19 — '__all__[2]' is 'WRAPPER_ASSIGNMENTS', the longest name in __all__"]
    - [all_idx3,
       "__all__[3].__len__",
       [],
       15,
       "len(functools.__all__[3]) == 15 — '__all__[3]' is 'WRAPPER_UPDATES' (same length as 'cached_property' at __all__[-2])"]
    - [all_idx4,
       "__all__[4].__len__",
       [],
       14,
       "len(functools.__all__[4]) == 14 — '__all__[4]' is 'total_ordering' (same length as 'update_wrapper' at __all__[0])"]

# ---------------------------------------------------------------------------
# lru_cache(128) method chain — extra41 namespace
#
# functools.lru_cache(128) returns a decorator callable. Calling __ne__ on
# the decorator with None confirms the factory returned a real (non-None)
# object. lru_cache(128).__class__.__name__ is 'functools._lru_cache_wrapper'
# after applying to a function, but the decorator itself (before application)
# has class name 'function'. We record the __ne__ == True fact because it is
# a simple, deterministic behavioral invariant for lru_cache(128).
# ---------------------------------------------------------------------------

invariant functools_extra41.lru_cache_128_not_none:
  description: "functools.lru_cache(128).__ne__(None) == True — lru_cache factory returns a non-None callable"
  category: behavioral
  kind: python_call_eq
  function: lru_cache
  args: [128]
  method: __ne__
  method_args: [null]
  expected: true
