spec: uuid_extra230
version: ">=3.2"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 9562 — Universally Unique IDentifiers (UUID) — https://www.rfc-editor.org/rfc/rfc9562"

provenance:
  derived_from:
    - "Python uuid documentation — https://docs.python.org/3/library/uuid.html"
    - "RFC 9562 — Universally Unique IDentifiers (UUID) — https://www.rfc-editor.org/rfc/rfc9562"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "CPython source: internal PRNG or MAC address resolution"
  notes:
    - "This spec extends uuid_extra.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "uuid_extra.zspec.zsdl covers: UUID.__name__=='UUID'; UUID.__module__=='uuid'; uuid1/uuid3/uuid4/uuid5 function names; uuid4().__class__.__name__=='UUID'; uuid4().version==4; NAMESPACE_* class names; UUID int and hex attribute class names."
    - "uuid4() is non-deterministic; only identity contracts (class name, version) are tested — not exact values."
    - "uuid1() is time-based and non-deterministic; only its class name and version are tested."
    - "uuid.UUID.__name__ == 'UUID' — verified by running Python 3.14.3 on macOS/Darwin 25.4.0."
    - "uuid.UUID.__module__ == 'uuid' — the UUID class is defined in the uuid module."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' — all NAMESPACE_* constants are UUID instances."
    - "uuid1().__class__.__name__ == 'UUID' — uuid1 returns a UUID instance (RFC 9562 §5.1)."
    - "uuid1().version == 1 — the version nibble for time-based UUIDs is always 1."
    - "uuid4().__class__.__name__ == 'UUID' — uuid4 returns a UUID instance (RFC 9562 §5.4)."
    - "uuid4().version == 4 — the version nibble for random UUIDs is always 4."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID class identity — __name__ and __module__
# ---------------------------------------------------------------------------

table uuid_extra230.UUID.identity:
  kind: python_call_eq
  category: class_metadata
  id_prefix: uuid230id

  columns: [id, function, args, expected]
  rows:
    - [class_name,   UUID.__name__.__eq__,   ["UUID"], true]
    - [module_name,  UUID.__module__.__eq__,  ["uuid"], true]

# ---------------------------------------------------------------------------
# uuid4() — return class name and version (non-deterministic; identity only)
# ---------------------------------------------------------------------------

invariant uuid_extra230.uuid4.class_name:
  description: "uuid4().__class__.__name__ == 'UUID' — uuid4 returns a UUID instance"
  category: uuid4
  kind: python_call_eq
  function: uuid4
  args: []
  method: __class__.__name__.__eq__
  method_args: ["UUID"]
  expected: true

invariant uuid_extra230.uuid4.version:
  description: "uuid4().version == 4 — version nibble is always 4 for RFC 9562 §5.4 random UUIDs"
  category: uuid4
  kind: python_call_eq
  function: uuid4
  args: []
  method: version.__eq__
  method_args: [4]
  expected: true

# ---------------------------------------------------------------------------
# uuid1() — return class name and version (non-deterministic; identity only)
# ---------------------------------------------------------------------------

invariant uuid_extra230.uuid1.class_name:
  description: "uuid1().__class__.__name__ == 'UUID' — uuid1 returns a UUID instance"
  category: uuid1
  kind: python_call_eq
  function: uuid1
  args: []
  method: __class__.__name__.__eq__
  method_args: ["UUID"]
  expected: true

invariant uuid_extra230.uuid1.version:
  description: "uuid1().version == 1 — version nibble is always 1 for RFC 9562 §5.1 time-based UUIDs"
  category: uuid1
  kind: python_call_eq
  function: uuid1
  args: []
  method: version.__eq__
  method_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# uuid1/uuid4 function module identity
# ---------------------------------------------------------------------------

table uuid_extra230.functions.modules:
  description: "uuid generator functions are defined in the uuid module"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuid230gen

  columns: [id, function, args, expected]
  rows:
    - [uuid1_module, uuid1.__module__.__eq__, ["uuid"], true]
    - [uuid4_module, uuid4.__module__.__eq__, ["uuid"], true]

# ---------------------------------------------------------------------------
# uuid1/uuid4 function qualnames
# ---------------------------------------------------------------------------

table uuid_extra230.functions.qualnames:
  description: "uuid generator functions have __qualname__ equal to their string name"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuid230gen

  columns: [id, function, args, expected]
  rows:
    - [uuid1_qualname, uuid1.__qualname__.__eq__, ["uuid1"], true]
    - [uuid4_qualname, uuid4.__qualname__.__eq__, ["uuid4"], true]

# ---------------------------------------------------------------------------
# NAMESPACE_DNS — class name check
# (NAMESPACE_URL, OID, X500 covered in uuid_extra.zspec.zsdl)
# ---------------------------------------------------------------------------

invariant uuid_extra230.NAMESPACE_DNS.class_name:
  description: "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID'"
  category: namespaces
  kind: python_call_eq
  function: NAMESPACE_DNS.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid4 variant attribute — must be non-negative int
# (variant encodes bits 63–62 of clock_seq_hi_and_reserved; always 2 for RFC 9562 UUIDs)
# ---------------------------------------------------------------------------

invariant uuid_extra230.uuid4.variant_class:
  description: "uuid4().variant.__class__.__name__ == 'str' — variant is a plain Python str"
  category: uuid4
  kind: python_call_eq
  function: uuid4
  args: []
  method: variant.__class__.__name__.__eq__
  method_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# uuid4 hex attribute — 32-char lowercase hex string
# ---------------------------------------------------------------------------

invariant uuid_extra230.uuid4.hex_len:
  description: "len(uuid4().hex) == 32 — UUID hex representation is always 32 lowercase hex chars"
  category: uuid4
  kind: python_call_eq
  function: uuid4
  args: []
  method: hex.__len__
  method_args: []
  expected: 32

# ---------------------------------------------------------------------------
# uuid1 hex attribute — 32-char lowercase hex string
# ---------------------------------------------------------------------------

invariant uuid_extra230.uuid1.hex_len:
  description: "len(uuid1().hex) == 32 — UUID hex representation is always 32 lowercase hex chars"
  category: uuid1
  kind: python_call_eq
  function: uuid1
  args: []
  method: hex.__len__
  method_args: []
  expected: 32

# ---------------------------------------------------------------------------
# uuid4 int attribute — 128-bit integer
# (uuid4().int is always a Python int; its class name is 'int')
# ---------------------------------------------------------------------------

invariant uuid_extra230.uuid4.int_class:
  description: "uuid4().int.__class__.__name__ == 'int' — UUID integer representation is a Python int"
  category: uuid4
  kind: python_call_eq
  function: uuid4
  args: []
  method: int.__class__.__name__.__eq__
  method_args: ["int"]
  expected: true
