spec: builtins_extra4
version: ">=3.9"
backend: python_module(builtins)

docs: https://docs.python.org/3/library/builtins.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/builtins.html — Python builtins module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/bltinmodule.c"
    - "builtins.zspec.zsdl — covers __name__ for built-in functions and types"
    - "builtins_extra.zspec.zsdl — covers function call behavior for abs, all, any, bin, chr, ord, divmod, hex, oct, pow, round, sorted, sum, max, min, len, isinstance, issubclass"
    - "builtins_extra2.zspec.zsdl — covers exception class hierarchies"
    - "builtins_extra3.zspec.zsdl — covers __name__ for print, input, open, vars, dir, id, frozenset, memoryview, slice, staticmethod, classmethod, super; __module__ for built-in types; base class checks"
  notes:
    - "This spec covers __qualname__ for the first 26 built-in functions and types (abs through id)."
    - "For built-in functions implemented in C (abs, all, any, bin, callable, chr, compile, delattr, dir, divmod, eval, exec, format, getattr, globals, hasattr, hash, hex, id), __qualname__ == __name__."
    - "For built-in types (bool, complex, dict, enumerate, filter, float, frozenset), __qualname__ == __name__."
    - "All __qualname__ values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — built-in functions and types, abs through id
#
# For all built-in functions and types, __qualname__ == __name__ because
# they are defined at module (top) level in the C extension, with no
# enclosing class or function scope.
# ---------------------------------------------------------------------------

table builtins_extra4.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [abs,       abs.__qualname__.__eq__,       ["abs"],       true]
    - [all,       all.__qualname__.__eq__,       ["all"],       true]
    - [any,       any.__qualname__.__eq__,       ["any"],       true]
    - [bin,       bin.__qualname__.__eq__,       ["bin"],       true]
    - [bool,      bool.__qualname__.__eq__,      ["bool"],      true]
    - [callable,  callable.__qualname__.__eq__,  ["callable"],  true]
    - [chr,       chr.__qualname__.__eq__,       ["chr"],       true]
    - [compile,   compile.__qualname__.__eq__,   ["compile"],   true]
    - [complex,   complex.__qualname__.__eq__,   ["complex"],   true]
    - [delattr,   delattr.__qualname__.__eq__,   ["delattr"],   true]
    - [dict,      dict.__qualname__.__eq__,      ["dict"],      true]
    - [dir,       dir.__qualname__.__eq__,       ["dir"],       true]
    - [divmod,    divmod.__qualname__.__eq__,    ["divmod"],    true]
    - [enumerate, enumerate.__qualname__.__eq__, ["enumerate"], true]
    - [eval,      eval.__qualname__.__eq__,      ["eval"],      true]
    - [exec,      exec.__qualname__.__eq__,      ["exec"],      true]
    - [filter,    filter.__qualname__.__eq__,    ["filter"],    true]
    - [float,     float.__qualname__.__eq__,     ["float"],     true]
    - [format,    format.__qualname__.__eq__,    ["format"],    true]
    - [frozenset, frozenset.__qualname__.__eq__, ["frozenset"], true]
    - [getattr,   getattr.__qualname__.__eq__,   ["getattr"],   true]
    - [globals,   globals.__qualname__.__eq__,   ["globals"],   true]
    - [hasattr,   hasattr.__qualname__.__eq__,   ["hasattr"],   true]
    - [hash,      hash.__qualname__.__eq__,      ["hash"],      true]
    - [hex,       hex.__qualname__.__eq__,       ["hex"],       true]
    - [id,        id.__qualname__.__eq__,        ["id"],        true]
