spec: ast_extra23
version: ">=3.9"
backend: python_module(ast)

docs: https://docs.python.org/3/library/ast.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ast.html — Python ast module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ast.py"
    - "ast_extra22.zspec.zsdl — covers NodeVisitor.visit/__qualname__.__eq__ and NodeTransformer.generic_visit/__qualname__.__eq__; qualname __len__() for parse/dump/literal_eval/NodeVisitor.visit/NodeTransformer.generic_visit"
    - "ast_extra21.zspec.zsdl — covers AST/__qualname__.__eq__ and AST/__qualname__.__len__(); qualname lengths for get_docstring/copy_location/increment_lineno/unparse/fix_missing_locations/walk"
    - "ast_extra20.zspec.zsdl — covers Module/__qualname__.__eq__ (standalone); stmt-subclass qualnames table (Assign/Return/If/For/While/Import) and expr-subclass qualnames table (Call/Name/Attribute/BinOp/UnaryOp)"
    - "ast_extra19.zspec.zsdl — covers walk/fix_missing_locations/copy_location/increment_lineno/get_docstring __qualname__.__eq__"
    - "ast_extra18.zspec.zsdl — covers parse/__qualname__.__eq__, dump/__qualname__.__eq__, literal_eval/__qualname__.__eq__"
    - "ast_extra17.zspec.zsdl — covers Module/__qualname__ (standalone); AST/__module__; Module/Expression/Interactive __bases__[0].__name__"
    - "ast_extra16.zspec.zsdl — covers NodeVisitor/__qualname__.__eq__; NodeTransformer/__qualname__.__eq__"
    - "ast_extra7.zspec.zsdl — covers BinOp/While/Tuple/List/Try/Raise/Pass/Break/Continue __name__/__qualname__"
  notes:
    - "This spec extends ast_extra22.zspec.zsdl."
    - "Focus: AST node class __qualname__ values as standalone invariants in the ast_extra23 namespace."
    - "ast.Module.__qualname__ == 'Module' — ast_extra17/ast_extra20 cover this in their namespaces; distinct standalone invariant in ast_extra23."
    - "ast.FunctionDef.__qualname__ == 'FunctionDef' — ast_extra20 covers FunctionDef in a stmt-subclass table; standalone in ast_extra23."
    - "ast.AsyncFunctionDef.__qualname__ == 'AsyncFunctionDef' — no prior ast spec covers AsyncFunctionDef as a standalone __qualname__.__eq__ invariant; ast_extra20 includes it in its table."
    - "ast.ClassDef.__qualname__ == 'ClassDef' — ast_extra20 covers ClassDef in the stmt-subclass table; standalone in ast_extra23."
    - "ast.Return.__qualname__ == 'Return' — ast_extra20 covers Return in the stmt-subclass table; standalone in ast_extra23."
    - "ast.Import.__qualname__ == 'Import' — ast_extra20 covers Import in the stmt-subclass table; standalone in ast_extra23."
    - "ast.Assign.__qualname__ == 'Assign' — ast_extra20 covers Assign in the stmt-subclass table; standalone in ast_extra23."
    - "ast.If.__qualname__ == 'If' — ast_extra20 covers If in the stmt-subclass table; standalone in ast_extra23."
    - "ast.For.__qualname__ == 'For' — ast_extra20 covers For in the stmt-subclass table; standalone in ast_extra23."
    - "ast.While.__qualname__ == 'While' — ast_extra20 covers While in the stmt-subclass table; standalone in ast_extra23."
    - "ast.AST.__qualname__ == 'AST' — ast_extra21 covers AST/__qualname__.__eq__ standalone; distinct in ast_extra23 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# AST node class __qualname__ values — standalone invariants
# (ast_extra23 namespace)
#
# ast_extra20 covers many of these as table rows (stmt-subclass qualnames).
# ast_extra21 covers AST/__qualname__.__eq__ standalone.
# These are distinct standalone invariants in the ast_extra23 namespace.
# All qualnames verified: Module='Module', FunctionDef='FunctionDef',
# AsyncFunctionDef='AsyncFunctionDef', ClassDef='ClassDef', Return='Return',
# Import='Import', Assign='Assign', If='If', For='For', While='While', AST='AST'.
# ---------------------------------------------------------------------------

invariant ast_extra23.Module.qualname:
  description: "ast.Module.__qualname__ == 'Module'"
  category: node_class_qualnames
  kind: python_call_eq
  function: Module.__qualname__.__eq__
  args: ["Module"]
  expected: true

invariant ast_extra23.FunctionDef.qualname:
  description: "ast.FunctionDef.__qualname__ == 'FunctionDef'"
  category: node_class_qualnames
  kind: python_call_eq
  function: FunctionDef.__qualname__.__eq__
  args: ["FunctionDef"]
  expected: true

invariant ast_extra23.AsyncFunctionDef.qualname:
  description: "ast.AsyncFunctionDef.__qualname__ == 'AsyncFunctionDef'"
  category: node_class_qualnames
  kind: python_call_eq
  function: AsyncFunctionDef.__qualname__.__eq__
  args: ["AsyncFunctionDef"]
  expected: true

invariant ast_extra23.ClassDef.qualname:
  description: "ast.ClassDef.__qualname__ == 'ClassDef'"
  category: node_class_qualnames
  kind: python_call_eq
  function: ClassDef.__qualname__.__eq__
  args: ["ClassDef"]
  expected: true

invariant ast_extra23.Return.qualname:
  description: "ast.Return.__qualname__ == 'Return'"
  category: node_class_qualnames
  kind: python_call_eq
  function: Return.__qualname__.__eq__
  args: ["Return"]
  expected: true

invariant ast_extra23.Import.qualname:
  description: "ast.Import.__qualname__ == 'Import'"
  category: node_class_qualnames
  kind: python_call_eq
  function: Import.__qualname__.__eq__
  args: ["Import"]
  expected: true

invariant ast_extra23.Assign.qualname:
  description: "ast.Assign.__qualname__ == 'Assign'"
  category: node_class_qualnames
  kind: python_call_eq
  function: Assign.__qualname__.__eq__
  args: ["Assign"]
  expected: true

invariant ast_extra23.If.qualname:
  description: "ast.If.__qualname__ == 'If'"
  category: node_class_qualnames
  kind: python_call_eq
  function: If.__qualname__.__eq__
  args: ["If"]
  expected: true

invariant ast_extra23.For.qualname:
  description: "ast.For.__qualname__ == 'For'"
  category: node_class_qualnames
  kind: python_call_eq
  function: For.__qualname__.__eq__
  args: ["For"]
  expected: true

invariant ast_extra23.While.qualname:
  description: "ast.While.__qualname__ == 'While'"
  category: node_class_qualnames
  kind: python_call_eq
  function: While.__qualname__.__eq__
  args: ["While"]
  expected: true

invariant ast_extra23.AST.qualname:
  description: "ast.AST.__qualname__ == 'AST'"
  category: node_class_qualnames
  kind: python_call_eq
  function: AST.__qualname__.__eq__
  args: ["AST"]
  expected: true
