# ---------------------------------------------------------------------------
# __delitem__ dict-presence — operator.contains(Cls.__dict__, '__delitem__')
#
# All 10 asyncio classes return false for __delitem__.
# del obj[key] delegates to __delitem__ when defined in the class's own __dict__.
# asyncio types define no container/mapping deletion protocol in their own __dict__.
# asyncio.Queue/PriorityQueue/LifoQueue: queue items are consumed via get()
#   coroutines, not deleted by key; no __delitem__ in their own __dict__.
# asyncio.Task/Future: completed tasks are garbage-collected; no __delitem__
#   defined in their own __dict__.
# asyncio.Event/Lock/Condition/Semaphore/BoundedSemaphore: synchronization
#   guards with no __delitem__ in their own __dict__.
# ---------------------------------------------------------------------------

