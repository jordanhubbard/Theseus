spec: lodash_split
version: ">=4.0.0"
backend: node(lodash.split)

docs: https://lodash.com/docs/#split

provenance:
  derived_from:
    - "lodash.split README — https://www.npmjs.com/package/lodash.split"
    - "Test vectors verified with lodash.split@4.3.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.split exports the _.split function directly as module.exports."
    - "split(string, separator, limit) splits string by separator up to limit parts."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array of substrings."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_split.split:
  kind: node_module_call_eq
  function: ~
  category: split
  id_prefix: lspl

  columns: [id, args, expected]
  rows:
    - [comma,     ["a,b,c", ","],       ["a", "b", "c"]]
    - [space,     ["foo bar baz", " "], ["foo", "bar", "baz"]]
    - [limited,   ["a,b,c,d", ",", 2], ["a", "b"]]
    - [no_match,  ["hello", ","],       ["hello"]]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:44:39Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
