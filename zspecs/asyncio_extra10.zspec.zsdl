spec: asyncio_extra10
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks and Coroutines"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queues"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/runners.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "Extends asyncio.zspec.zsdl, asyncio_events.zspec.zsdl, asyncio_extra.zspec.zsdl through asyncio_extra9.zspec.zsdl."
    - "asyncio_extra9 covers: exception __bases__[0].__name__ (CancelledError/TimeoutError/InvalidStateError/IncompleteReadError); event loop hierarchy (AbstractEventLoop/BaseEventLoop __bases__[0].__name__); PriorityQueue/LifoQueue __bases__[0].__name__; InvalidStateError/IncompleteReadError __module__; Condition/BoundedSemaphore/PriorityQueue/LifoQueue __module__; gather/sleep/create_task __class__.__name__."
    - "asyncio_extra8 covers: Task/Future __module__; Event/__module__; Barrier/TaskGroup/Runner __module__ (3.11+); Task/Future/QueueEmpty/QueueFull __bases__[0].__name__; PriorityQueue/LifoQueue __name__ standalone."
    - "No prior spec checks __qualname__ for sync primitives (Semaphore/BoundedSemaphore/Lock/Event/Condition/Queue)."
    - "No prior spec checks __qualname__ for queue exceptions (QueueEmpty/QueueFull) or asyncio exceptions (CancelledError/TimeoutError/InvalidStateError/IncompleteReadError)."
    - "No prior spec checks __name__ or __qualname__ for run/wait/shield/wait_for."
    - "No prior spec checks __module__ for run/wait/shield/wait_for."
    - "No prior spec checks QueueEmpty/QueueFull MRO index 2 (BaseException)."
    - "asyncio.Semaphore.__qualname__ == 'Semaphore' — top-level class."
    - "asyncio.BoundedSemaphore.__qualname__ == 'BoundedSemaphore' — top-level class."
    - "asyncio.Lock.__qualname__ == 'Lock' — top-level class."
    - "asyncio.Event.__qualname__ == 'Event' — top-level class."
    - "asyncio.Condition.__qualname__ == 'Condition' — top-level class."
    - "asyncio.Queue.__qualname__ == 'Queue' — top-level class."
    - "asyncio.QueueEmpty.__qualname__ == 'QueueEmpty' — top-level exception class."
    - "asyncio.QueueFull.__qualname__ == 'QueueFull' — top-level exception class."
    - "asyncio.CancelledError.__qualname__ == 'CancelledError'."
    - "asyncio.TimeoutError.__qualname__ == 'TimeoutError'."
    - "asyncio.run.__name__ == 'run'; asyncio.run.__module__ == 'asyncio.runners'."
    - "asyncio.wait.__name__ == 'wait'; asyncio.wait.__module__ == 'asyncio.tasks'."
    - "asyncio.shield.__name__ == 'shield'; asyncio.shield.__module__ == 'asyncio.tasks'."
    - "asyncio.wait_for.__name__ == 'wait_for'; asyncio.wait_for.__module__ == 'asyncio.tasks'."
    - "asyncio.QueueEmpty.__mro__[2].__name__ == 'BaseException' — three-level exception MRO."
    - "asyncio.QueueFull.__mro__[2].__name__ == 'BaseException' — three-level exception MRO."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for asyncio synchronization primitives
#
# No prior asyncio spec checks __qualname__ for Semaphore, BoundedSemaphore,
# Lock, Event, Condition, or Queue. All are top-level classes with simple
# __qualname__ equal to their __name__.
# ---------------------------------------------------------------------------

table asyncio_extra10.sync_primitive_qualnames:
  description: "asyncio sync primitives have __qualname__ equal to their class name"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: sqname

  columns: [id, function, args, expected]
  rows:
    - [Semaphore,        Semaphore.__qualname__.__eq__,        ["Semaphore"],        true]
    - [BoundedSemaphore, BoundedSemaphore.__qualname__.__eq__, ["BoundedSemaphore"], true]
    - [Lock,             Lock.__qualname__.__eq__,             ["Lock"],             true]
    - [Event,            Event.__qualname__.__eq__,            ["Event"],            true]
    - [Condition,        Condition.__qualname__.__eq__,        ["Condition"],        true]
    - [Queue,            Queue.__qualname__.__eq__,            ["Queue"],            true]

# ---------------------------------------------------------------------------
# __qualname__ for asyncio queue exception classes
#
# asyncio_extra8 checks __bases__[0].__name__ for QueueEmpty and QueueFull.
# No prior spec checks __qualname__ for either.
# ---------------------------------------------------------------------------

invariant asyncio_extra10.QueueEmpty.qualname:
  description: "asyncio.QueueEmpty.__qualname__ == 'QueueEmpty'"
  category: class_qualnames
  kind: python_call_eq
  function: QueueEmpty.__qualname__.__eq__
  args: ["QueueEmpty"]
  expected: true

invariant asyncio_extra10.QueueFull.qualname:
  description: "asyncio.QueueFull.__qualname__ == 'QueueFull'"
  category: class_qualnames
  kind: python_call_eq
  function: QueueFull.__qualname__.__eq__
  args: ["QueueFull"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ for asyncio exception classes
#
# asyncio_extra7 checks __name__/__qualname__ for InvalidStateError and
# IncompleteReadError. No prior spec checks __qualname__ for CancelledError
# or TimeoutError.
# ---------------------------------------------------------------------------

invariant asyncio_extra10.CancelledError.qualname:
  description: "asyncio.CancelledError.__qualname__ == 'CancelledError'"
  category: class_qualnames
  kind: python_call_eq
  function: CancelledError.__qualname__.__eq__
  args: ["CancelledError"]
  expected: true

invariant asyncio_extra10.TimeoutError.qualname:
  description: "asyncio.TimeoutError.__qualname__ == 'TimeoutError'"
  category: class_qualnames
  kind: python_call_eq
  function: TimeoutError.__qualname__.__eq__
  args: ["TimeoutError"]
  expected: true

# ---------------------------------------------------------------------------
# run/wait/shield/wait_for — __name__ and __module__
#
# Prior specs cover gather/sleep/create_task for __name__, __qualname__,
# __module__, and __class__.__name__. No prior spec checks these axes for
# run, wait, shield, or wait_for.
# ---------------------------------------------------------------------------

table asyncio_extra10.task_function_names:
  description: "asyncio task functions have correct __name__"
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [run,      run.__name__.__eq__,      ["run"],      true]
    - [wait,     wait.__name__.__eq__,     ["wait"],     true]
    - [shield,   shield.__name__.__eq__,   ["shield"],   true]
    - [wait_for, wait_for.__name__.__eq__, ["wait_for"], true]

table asyncio_extra10.task_function_modules:
  description: "asyncio task functions have correct __module__"
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [run,      run.__module__.__eq__,      ["asyncio.runners"], true]
    - [wait,     wait.__module__.__eq__,     ["asyncio.tasks"],   true]
    - [shield,   shield.__module__.__eq__,   ["asyncio.tasks"],   true]
    - [wait_for, wait_for.__module__.__eq__, ["asyncio.tasks"],   true]

# ---------------------------------------------------------------------------
# QueueEmpty and QueueFull — MRO index 2 (BaseException)
#
# asyncio_extra8 checks __bases__[0].__name__ == 'Exception' for QueueEmpty
# and QueueFull. No prior spec checks MRO index 2 (which is BaseException)
# for these exception classes.
# ---------------------------------------------------------------------------

invariant asyncio_extra10.QueueEmpty.mro_index2:
  description: "asyncio.QueueEmpty.__mro__[2].__name__ == 'BaseException' — full exception MRO"
  category: exception_hierarchy
  kind: python_call_eq
  function: QueueEmpty.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "BaseException"

invariant asyncio_extra10.QueueFull.mro_index2:
  description: "asyncio.QueueFull.__mro__[2].__name__ == 'BaseException' — full exception MRO"
  category: exception_hierarchy
  kind: python_call_eq
  function: QueueFull.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "BaseException"
