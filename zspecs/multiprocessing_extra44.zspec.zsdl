spec: multiprocessing_extra44
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.context.BaseContext — BaseContext documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra43.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', Process.__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() tables, Process method __qualname__.__len__() tables, Pool method tables, Process/Pool __mro__.__len__() tables, __all__ metadata, class __dict__ tables, DefaultContext method qualname lengths, BaseProcess metadata, function __name__.__len__() tables, pool result class tables, Process/__name__=='Process', Process/__module__=='multiprocessing.context', Queue/__name__=='Queue', Pipe/__name__=='Pipe', Process method qualname lens for start/join/run, Process.__bases__[0].__name__=='BaseProcess'/__mro__.__len__()==3/Manager.__name__=='Manager', function __name__/__module__ string equality for cpu_count/current_process/active_children, AuthenticationError/__name__/__module__/__bases__[0].__name__, ProcessError/__name__/__bases__[0].__name__, BufferTooShort/__name__, TimeoutError/__name__/__bases__[0].__name__, all four exception __module__ string equality, ProcessError/__mro__.__len__()==4, exception subclass MRO depths, Process/__qualname__=='Process', Process/__qualname__.__len__()==7, context.BaseContext/__name__=='BaseContext', Queue/__qualname__=='BaseContext.Queue', Pipe/__qualname__=='BaseContext.Pipe', cpu_count/__qualname__=='BaseContext.cpu_count', current_process/__qualname__=='current_process', active_children/__qualname__=='active_children', get_start_method/__qualname__=='DefaultContext.get_start_method', set_start_method/__name__=='set_start_method', ProcessError/__qualname__=='ProcessError', AuthenticationError/__qualname__=='AuthenticationError', TimeoutError/__qualname__=='TimeoutError', BufferTooShort/__qualname__=='BufferTooShort', BaseContext/__qualname__/__module__/__mro__.__len__(), SpawnContext/ForkContext/ForkServerContext/DefaultContext __name__ equality, context subclass __qualname__.__len__() tables, context subclass __mro__.__len__()==3 (extra43)."
    - "This spec covers: context.SpawnContext/__qualname__=='SpawnContext'; context.ForkContext/__qualname__=='ForkContext'; context.ForkServerContext/__qualname__=='ForkServerContext'; context.DefaultContext/__qualname__=='DefaultContext'; context.SpawnContext/__module__=='multiprocessing.context'; context.ForkContext/__module__=='multiprocessing.context'; context.ForkServerContext/__module__=='multiprocessing.context'; context.DefaultContext/__module__=='multiprocessing.context'; context subclass __module__.__len__()==23 for all four; context.DefaultContext/__qualname__.__len__()==14."
    - "multiprocessing.context.SpawnContext.__qualname__ == 'SpawnContext'. SpawnContext is a top-level class in multiprocessing.context that subclasses BaseContext; __qualname__ equals __name__ for top-level classes. extra43 captured __qualname__.__len__()==12 and __name__ string equality; extra44 captures the __qualname__ string equality directly. Verified with Python 3.14.3."
    - "multiprocessing.context.ForkContext.__qualname__ == 'ForkContext'. ForkContext is a top-level class; __qualname__ equals __name__. extra43 captured __qualname__.__len__()==11; extra44 adds string equality. Verified with Python 3.14.3."
    - "multiprocessing.context.ForkServerContext.__qualname__ == 'ForkServerContext'. ForkServerContext is a top-level class; __qualname__ equals __name__ (17 chars). extra43 captured __qualname__.__len__()==17; extra44 adds string equality. Verified with Python 3.14.3."
    - "multiprocessing.context.DefaultContext.__qualname__ == 'DefaultContext'. DefaultContext is a top-level class; __qualname__ equals __name__ (14 chars). extra43 captured __name__ string equality; extra44 captures __qualname__ string equality and __qualname__.__len__()==14. Verified with Python 3.14.3."
    - "All four context subclasses (SpawnContext, ForkContext, ForkServerContext, DefaultContext) share __module__ == 'multiprocessing.context' (23 chars). This was noted in the extra43 notes but the string equality invariants were not captured in tables; extra44 captures them explicitly. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.context subclass __qualname__ string equality — extra44
#
# All four context subclasses are top-level classes; __qualname__ equals __name__:
#   SpawnContext.__qualname__      == 'SpawnContext'       (12 chars)
#   ForkContext.__qualname__       == 'ForkContext'        (11 chars)
#   ForkServerContext.__qualname__ == 'ForkServerContext'  (17 chars)
#   DefaultContext.__qualname__    == 'DefaultContext'     (14 chars)
# Extra43 captured __name__ equality and __qualname__.__len__() for all four;
# extra44 captures the __qualname__ string equality directly.
# ---------------------------------------------------------------------------

table multiprocessing_extra44.context_subclass_qualname_eq:
  description: "multiprocessing.context subclass __qualname__ string equality in extra44 namespace — SpawnContext, ForkContext, ForkServerContext, DefaultContext"
  kind: python_call_eq
  category: class_names
  id_prefix: mpctxsubqneq44

  columns: [id, function, args, expected, description]
  rows:
    - [SpawnContext,      "context.SpawnContext.__qualname__.__eq__",      ["SpawnContext"],      true, "SpawnContext.__qualname__ == 'SpawnContext' — top-level class; qualname equals name (12 chars)"]
    - [ForkContext,       "context.ForkContext.__qualname__.__eq__",       ["ForkContext"],       true, "ForkContext.__qualname__ == 'ForkContext' — top-level class; qualname equals name (11 chars)"]
    - [ForkServerContext, "context.ForkServerContext.__qualname__.__eq__", ["ForkServerContext"], true, "ForkServerContext.__qualname__ == 'ForkServerContext' — top-level class; qualname equals name (17 chars)"]
    - [DefaultContext,    "context.DefaultContext.__qualname__.__eq__",    ["DefaultContext"],    true, "DefaultContext.__qualname__ == 'DefaultContext' — top-level class; qualname equals name (14 chars)"]

# ---------------------------------------------------------------------------
# multiprocessing.context subclass __module__ string equality — extra44
#
# All four context subclasses share the same module:
#   SpawnContext.__module__      == 'multiprocessing.context'   (23 chars)
#   ForkContext.__module__       == 'multiprocessing.context'   (23 chars)
#   ForkServerContext.__module__ == 'multiprocessing.context'   (23 chars)
#   DefaultContext.__module__    == 'multiprocessing.context'   (23 chars)
# Extra43 noted these values but captured only BaseContext's __module__ string
# equality in a table. Extra44 captures all four subclass __module__ equalities.
# ---------------------------------------------------------------------------

table multiprocessing_extra44.context_subclass_module_eq:
  description: "multiprocessing.context subclass __module__ string equality in extra44 namespace — SpawnContext, ForkContext, ForkServerContext, DefaultContext"
  kind: python_call_eq
  category: module_identity
  id_prefix: mpctxsubmodeq44

  columns: [id, function, args, expected, description]
  rows:
    - [SpawnContext,      "context.SpawnContext.__module__.__eq__",      ["multiprocessing.context"], true, "SpawnContext.__module__ == 'multiprocessing.context' — defined in multiprocessing.context sub-module"]
    - [ForkContext,       "context.ForkContext.__module__.__eq__",       ["multiprocessing.context"], true, "ForkContext.__module__ == 'multiprocessing.context' — defined in multiprocessing.context sub-module"]
    - [ForkServerContext, "context.ForkServerContext.__module__.__eq__", ["multiprocessing.context"], true, "ForkServerContext.__module__ == 'multiprocessing.context' — defined in multiprocessing.context sub-module"]
    - [DefaultContext,    "context.DefaultContext.__module__.__eq__",    ["multiprocessing.context"], true, "DefaultContext.__module__ == 'multiprocessing.context' — defined in multiprocessing.context sub-module"]

# ---------------------------------------------------------------------------
# multiprocessing.context subclass __module__.__len__() — extra44
#
# All four context subclasses share the same module path length:
#   SpawnContext.__module__.__len__()      == 23
#   ForkContext.__module__.__len__()       == 23
#   ForkServerContext.__module__.__len__() == 23
#   DefaultContext.__module__.__len__()    == 23
# 'multiprocessing.context' has 23 characters; this equals BaseContext's module
# length (captured in extra43). All five context classes (BaseContext plus
# the four subclasses) share the same module path and the same path length.
# ---------------------------------------------------------------------------

table multiprocessing_extra44.context_subclass_module_lengths:
  description: "multiprocessing.context subclass __module__.__len__() in extra44 namespace — all four subclasses share 23 characters"
  kind: python_call_eq
  category: module_identity
  id_prefix: mpctxsubmodlen44

  columns: [id, function, args, expected, description]
  rows:
    - [SpawnContext,      "context.SpawnContext.__module__.__len__",      [], 23, "SpawnContext.__module__.__len__() == 23 — 'multiprocessing.context' has 23 characters"]
    - [ForkContext,       "context.ForkContext.__module__.__len__",       [], 23, "ForkContext.__module__.__len__() == 23 — 'multiprocessing.context' has 23 characters"]
    - [ForkServerContext, "context.ForkServerContext.__module__.__len__", [], 23, "ForkServerContext.__module__.__len__() == 23 — 'multiprocessing.context' has 23 characters"]
    - [DefaultContext,    "context.DefaultContext.__module__.__len__",    [], 23, "DefaultContext.__module__.__len__() == 23 — 'multiprocessing.context' has 23 characters; same as BaseContext"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra44
# ---------------------------------------------------------------------------

invariant multiprocessing_extra44.SpawnContext_qualname_eq:
  description: "multiprocessing.context.SpawnContext.__qualname__ == 'SpawnContext' — top-level class; qualname equals name (12 chars)"
  category: class_names
  kind: python_call_eq
  function: "context.SpawnContext.__qualname__.__eq__"
  args: ["SpawnContext"]
  expected: true

invariant multiprocessing_extra44.ForkContext_qualname_eq:
  description: "multiprocessing.context.ForkContext.__qualname__ == 'ForkContext' — top-level class; qualname equals name (11 chars)"
  category: class_names
  kind: python_call_eq
  function: "context.ForkContext.__qualname__.__eq__"
  args: ["ForkContext"]
  expected: true

invariant multiprocessing_extra44.ForkServerContext_qualname_eq:
  description: "multiprocessing.context.ForkServerContext.__qualname__ == 'ForkServerContext' — top-level class; qualname equals name (17 chars)"
  category: class_names
  kind: python_call_eq
  function: "context.ForkServerContext.__qualname__.__eq__"
  args: ["ForkServerContext"]
  expected: true

invariant multiprocessing_extra44.DefaultContext_qualname_eq:
  description: "multiprocessing.context.DefaultContext.__qualname__ == 'DefaultContext' — top-level class; qualname equals name (14 chars)"
  category: class_names
  kind: python_call_eq
  function: "context.DefaultContext.__qualname__.__eq__"
  args: ["DefaultContext"]
  expected: true

invariant multiprocessing_extra44.DefaultContext_qualname_len:
  description: "multiprocessing.context.DefaultContext.__qualname__.__len__() == 14 — 'DefaultContext' has 14 characters"
  category: class_names
  kind: python_call_eq
  function: "context.DefaultContext.__qualname__.__len__"
  args: []
  expected: 14

invariant multiprocessing_extra44.SpawnContext_module_eq:
  description: "multiprocessing.context.SpawnContext.__module__ == 'multiprocessing.context' — defined in the context sub-module (23 chars)"
  category: module_identity
  kind: python_call_eq
  function: "context.SpawnContext.__module__.__eq__"
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra44.ForkContext_module_eq:
  description: "multiprocessing.context.ForkContext.__module__ == 'multiprocessing.context' — defined in the context sub-module (23 chars)"
  category: module_identity
  kind: python_call_eq
  function: "context.ForkContext.__module__.__eq__"
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra44.ForkServerContext_module_eq:
  description: "multiprocessing.context.ForkServerContext.__module__ == 'multiprocessing.context' — defined in the context sub-module (23 chars)"
  category: module_identity
  kind: python_call_eq
  function: "context.ForkServerContext.__module__.__eq__"
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra44.DefaultContext_module_eq:
  description: "multiprocessing.context.DefaultContext.__module__ == 'multiprocessing.context' — defined in the context sub-module (23 chars)"
  category: module_identity
  kind: python_call_eq
  function: "context.DefaultContext.__module__.__eq__"
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra44.SpawnContext_module_len:
  description: "multiprocessing.context.SpawnContext.__module__.__len__() == 23 — 'multiprocessing.context' has 23 characters"
  category: module_identity
  kind: python_call_eq
  function: "context.SpawnContext.__module__.__len__"
  args: []
  expected: 23

invariant multiprocessing_extra44.ForkServerContext_module_len:
  description: "multiprocessing.context.ForkServerContext.__module__.__len__() == 23 — 'multiprocessing.context' has 23 characters"
  category: module_identity
  kind: python_call_eq
  function: "context.ForkServerContext.__module__.__len__"
  args: []
  expected: 23

invariant multiprocessing_extra44.DefaultContext_module_len:
  description: "multiprocessing.context.DefaultContext.__module__.__len__() == 23 — 'multiprocessing.context' has 23 characters; same as BaseContext"
  category: module_identity
  kind: python_call_eq
  function: "context.DefaultContext.__module__.__len__"
