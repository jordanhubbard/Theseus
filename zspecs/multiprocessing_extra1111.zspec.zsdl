spec: multiprocessing_extra1111
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing.queues.Queue class, multiprocessing.Process.__init__, and multiprocessing synchronize Lock/RLock/Semaphore instance class identity documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks multiprocessing.queues.Queue module/qualname/name/method qualnames, multiprocessing.Process.__init__ qualname/module, multiprocessing.Lock/RLock/Semaphore instance __class__.__name__/__module__/__qualname__ — behaviors not covered by extra1081 or extra1096"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra1111.queues_queue_identity:
  description: "multiprocessing.queues.Queue class module, qualname, name, and method qualname identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: mp1111qq
  columns: [id, function, args, expected]
  rows:
    - [mp1111qq001, multiprocessing.queues.Queue.__module__.__eq__,          ["multiprocessing.queues"],  true]
    - [mp1111qq002, multiprocessing.queues.Queue.__qualname__.__eq__,        ["Queue"],                   true]
    - [mp1111qq003, multiprocessing.queues.Queue.__name__.__eq__,            ["Queue"],                   true]
    - [mp1111qq004, multiprocessing.queues.Queue.__class__.__name__.__eq__,  ["type"],                    true]
    - [mp1111qq005, multiprocessing.queues.Queue.__init__.__qualname__.__eq__, ["Queue.__init__"],        true]
    - [mp1111qq006, multiprocessing.queues.Queue.__init__.__module__.__eq__, ["multiprocessing.queues"],  true]
    - [mp1111qq007, multiprocessing.queues.Queue.put.__qualname__.__eq__,    ["Queue.put"],               true]
    - [mp1111qq008, multiprocessing.queues.Queue.get.__qualname__.__eq__,    ["Queue.get"],               true]
    - [mp1111qq009, multiprocessing.queues.Queue.empty.__qualname__.__eq__,  ["Queue.empty"],             true]
    - [mp1111qq010, multiprocessing.queues.Queue.close.__qualname__.__eq__,  ["Queue.close"],             true]

table multiprocessing_extra1111.process_init_qualname:
  description: "multiprocessing.Process.__init__ qualname, module, class, and name identity"
