  category: method_qualnames
  id_prefix: mp1111pi
  columns: [id, function, args, expected]
  rows:
    - [mp1111pi001, multiprocessing.Process.__init__.__qualname__.__eq__,        ["BaseProcess.__init__"],     true]
    - [mp1111pi002, multiprocessing.Process.__init__.__module__.__eq__,          ["multiprocessing.process"],  true]
    - [mp1111pi003, multiprocessing.Process.__init__.__class__.__name__.__eq__,  ["function"],                 true]
    - [mp1111pi004, multiprocessing.Process.__init__.__name__.__eq__,            ["__init__"],                 true]

table multiprocessing_extra1111.sync_primitives_instance_class:
  description: "multiprocessing.Lock, RLock, and Semaphore instance __class__.__name__, __module__, and __qualname__ identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: mp1111sp
  columns: [id, function, args, expected]
  rows:
    - [mp1111sp001, multiprocessing.Lock().__class__.__name__.__eq__,          ["Lock"],                          true]
    - [mp1111sp002, multiprocessing.Lock().__class__.__module__.__eq__,        ["multiprocessing.synchronize"],   true]
    - [mp1111sp003, multiprocessing.Lock().__class__.__qualname__.__eq__,      ["Lock"],                          true]
    - [mp1111sp004, multiprocessing.RLock().__class__.__name__.__eq__,         ["RLock"],                         true]
    - [mp1111sp005, multiprocessing.RLock().__class__.__module__.__eq__,       ["multiprocessing.synchronize"],   true]
    - [mp1111sp006, multiprocessing.RLock().__class__.__qualname__.__eq__,     ["RLock"],                         true]
    - [mp1111sp007, multiprocessing.Semaphore().__class__.__name__.__eq__,     ["Semaphore"],                     true]
    - [mp1111sp008, multiprocessing.Semaphore().__class__.__module__.__eq__,   ["multiprocessing.synchronize"],   true]
    - [mp1111sp009, multiprocessing.Semaphore().__class__.__qualname__.__eq__, ["Semaphore"],                     true]
