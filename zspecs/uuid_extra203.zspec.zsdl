spec: uuid_extra203
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 9562 — Universally Unique IDentifiers (UUID)"
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 9562 — Universally Unique IDentifiers (UUID)"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "CPython source: internal PRNG or MAC address resolution"
  notes:
    - "This spec extends uuid_extra202.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "uuid.UUID.__qualname__ == 'UUID' — simple class-level qualname, not nested."
    - "uuid.SafeUUID.__qualname__ == 'SafeUUID' — IntEnum subclass; qualname matches class name."
    - "uuid.uuid1.__qualname__ == 'uuid1'; uuid.uuid3.__qualname__ == 'uuid3'."
    - "uuid.uuid4.__qualname__ == 'uuid4'; uuid.uuid5.__qualname__ == 'uuid5'."
    - "uuid.getnode.__qualname__ == 'getnode' — module-level function."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID and uuid.SafeUUID — __qualname__ checks
#
# uuid.UUID.__qualname__ == 'UUID'
# uuid.SafeUUID.__qualname__ == 'SafeUUID'
# ---------------------------------------------------------------------------

table uuid_extra203.UUID_and_SafeUUID_qualnames:
  description: "uuid.UUID and uuid.SafeUUID __qualname__ equality checks in uuidqualname203 namespace — wave 258 theme: uuid.UUID.__qualname__=='UUID' (module-level class; qualname equals simple class name); uuid.SafeUUID.__qualname__=='SafeUUID' (IntEnum subclass; qualname equals class name); uuid.UUID.__module__=='uuid'; uuid.SafeUUID.__module__=='uuid'; both are defined in Lib/uuid.py at module scope so their qualnames are their plain class names without nesting; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: uuidqualname203

  columns: [id, function, args, expected, description]
  rows:
    - [UUID_qualname_eq,     UUID.__qualname__.__eq__,     ["UUID"],     true, "uuid.UUID.__qualname__ == 'UUID'; top-level class qualname; verified with Python 3.14.3"]
    - [SafeUUID_qualname_eq, SafeUUID.__qualname__.__eq__, ["SafeUUID"], true, "uuid.SafeUUID.__qualname__ == 'SafeUUID'; IntEnum subclass qualname; verified with Python 3.14.3"]
    - [UUID_module_eq,       UUID.__module__.__eq__,       ["uuid"],     true, "uuid.UUID.__module__ == 'uuid'; defined in Lib/uuid.py; verified with Python 3.14.3"]
    - [SafeUUID_module_eq,   SafeUUID.__module__.__eq__,   ["uuid"],     true, "uuid.SafeUUID.__module__ == 'uuid'; defined in Lib/uuid.py; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# uuid.uuid1 and uuid.uuid3 — __qualname__ checks
#
# uuid.uuid1.__qualname__ == 'uuid1'
# uuid.uuid3.__qualname__ == 'uuid3'
# ---------------------------------------------------------------------------

table uuid_extra203.uuid1_and_uuid3_qualnames:
  description: "uuid.uuid1 and uuid.uuid3 __qualname__ equality checks in uuidqualname203a namespace — wave 258 theme: uuid.uuid1.__qualname__=='uuid1' (module-level function; qualname matches public name); uuid.uuid3.__qualname__=='uuid3' (name-based UUID using MD5; qualname matches public name); uuid.uuid1.__module__=='uuid'; uuid.uuid3.__module__=='uuid'; both are pure-Python functions defined in Lib/uuid.py; uuid1 generates time-based UUIDs (RFC 9562 version 1); uuid3 generates name-based UUIDs using MD5 (RFC 9562 version 3); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: uuidqualname203a

  columns: [id, function, args, expected, description]
  rows:
    - [uuid1_qualname_eq,  uuid1.__qualname__.__eq__, ["uuid1"], true, "uuid.uuid1.__qualname__ == 'uuid1'; time-based UUID generator qualname; verified with Python 3.14.3"]
    - [uuid3_qualname_eq,  uuid3.__qualname__.__eq__, ["uuid3"], true, "uuid.uuid3.__qualname__ == 'uuid3'; MD5 name-based UUID generator qualname; verified with Python 3.14.3"]
    - [uuid1_module_eq,    uuid1.__module__.__eq__,   ["uuid"],  true, "uuid.uuid1.__module__ == 'uuid'; defined in Lib/uuid.py; verified with Python 3.14.3"]
    - [uuid3_module_eq,    uuid3.__module__.__eq__,   ["uuid"],  true, "uuid.uuid3.__module__ == 'uuid'; defined in Lib/uuid.py; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# uuid.uuid4 and uuid.uuid5 — __qualname__ checks
#
# uuid.uuid4.__qualname__ == 'uuid4'
# uuid.uuid5.__qualname__ == 'uuid5'
# ---------------------------------------------------------------------------

table uuid_extra203.uuid4_and_uuid5_qualnames:
  description: "uuid.uuid4 and uuid.uuid5 __qualname__ equality checks in uuidqualname203b namespace — wave 258 theme: uuid.uuid4.__qualname__=='uuid4' (random UUID; qualname matches public name); uuid.uuid5.__qualname__=='uuid5' (SHA-1 name-based UUID; qualname matches public name); uuid.uuid4.__module__=='uuid'; uuid.uuid5.__module__=='uuid'; uuid4 generates random UUIDs (RFC 9562 version 4); uuid5 generates name-based UUIDs using SHA-1 (RFC 9562 version 5); getnode.__qualname__=='getnode' also shown for completeness; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: uuidqualname203b

  columns: [id, function, args, expected, description]
  rows:
    - [uuid4_qualname_eq,   uuid4.__qualname__.__eq__,    ["uuid4"],    true, "uuid.uuid4.__qualname__ == 'uuid4'; random UUID generator qualname; verified with Python 3.14.3"]
    - [uuid5_qualname_eq,   uuid5.__qualname__.__eq__,    ["uuid5"],    true, "uuid.uuid5.__qualname__ == 'uuid5'; SHA-1 name-based UUID generator qualname; verified with Python 3.14.3"]
    - [uuid4_module_eq,     uuid4.__module__.__eq__,      ["uuid"],     true, "uuid.uuid4.__module__ == 'uuid'; defined in Lib/uuid.py; verified with Python 3.14.3"]
    - [getnode_qualname_eq, getnode.__qualname__.__eq__,  ["getnode"],  true, "uuid.getnode.__qualname__ == 'getnode'; MAC address getter qualname; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — uuid_extra203
# ---------------------------------------------------------------------------

invariant uuid_extra203.UUID_qualname_is_UUID:
  description: "uuid.UUID.__qualname__.__eq__('UUID') returns True — uuid.UUID is a module-level class defined in Lib/uuid.py; its qualname is simply 'UUID' (not a nested or inner class qualifier); qualname equals the simple class name when the class is defined at module scope; compare: a nested class like 'Outer.Inner' would have qualname 'Outer.Inner'; UUID has __slots__ and stores its value as a Python int internally; NEW in uuid_extra203: first standalone UUID.__qualname__ invariant in uuidqualname203 namespace; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: UUID.__qualname__.__eq__
  args: ["UUID"]
  expected: true

invariant uuid_extra203.SafeUUID_qualname_is_SafeUUID:
  description: "uuid.SafeUUID.__qualname__.__eq__('SafeUUID') returns True — SafeUUID is an IntEnum subclass defined at module level in Lib/uuid.py with members SAFE (-1) and UNSAFE (0); its qualname is 'SafeUUID' (top-level class, no nesting); SafeUUID was added in Python 3.7 to indicate whether a UUID was generated using a multiprocessing-safe method; compare: uuid.UUID.__qualname__=='UUID' (also top-level); NEW in uuid_extra203: first standalone SafeUUID.__qualname__ invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: SafeUUID.__qualname__.__eq__
  args: ["SafeUUID"]
  expected: true

invariant uuid_extra203.uuid1_qualname_is_uuid1:
  description: "uuid.uuid1.__qualname__.__eq__('uuid1') returns True — uuid1 is a module-level function in Lib/uuid.py that generates version-1 time-based UUIDs per RFC 9562; its qualname equals its public name 'uuid1'; uuid1 uses the current time and MAC address (via uuid.getnode()) as inputs; the qualname 'uuid1' has no class prefix since the function is not a method; compare: uuid3/4/5 all follow the same pattern; NEW in uuid_extra203: first standalone uuid1.__qualname__ invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: uuid1.__qualname__.__eq__
  args: ["uuid1"]
  expected: true

invariant uuid_extra203.uuid3_qualname_is_uuid3:
  description: "uuid.uuid3.__qualname__.__eq__('uuid3') returns True — uuid3 is a module-level function in Lib/uuid.py that generates version-3 name-based UUIDs using MD5 per RFC 9562; its qualname equals its public name 'uuid3'; uuid3 takes a namespace UUID and a name string, hashes them with MD5, and sets the version bits to 3; compare: uuid5 uses SHA-1 instead of MD5 for the same purpose; both uuid3 and uuid5 qualnames match their public names; NEW in uuid_extra203: first standalone uuid3.__qualname__ invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: uuid3.__qualname__.__eq__
  args: ["uuid3"]
  expected: true

invariant uuid_extra203.uuid4_qualname_is_uuid4:
  description: "uuid.uuid4.__qualname__.__eq__('uuid4') returns True — uuid4 is a module-level function in Lib/uuid.py that generates version-4 random UUIDs per RFC 9562; its qualname equals its public name 'uuid4'; uuid4 uses os.urandom(16) to generate 16 random bytes, then sets the version (4) and variant bits; it is the simplest UUID generator requiring no namespace or time inputs; qualname 'uuid4' indicates a top-level function; NEW in uuid_extra203: first standalone uuid4.__qualname__ invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: uuid4.__qualname__.__eq__
  args: ["uuid4"]
  expected: true

invariant uuid_extra203.uuid5_qualname_is_uuid5:
  description: "uuid.uuid5.__qualname__.__eq__('uuid5') returns True — uuid5 is a module-level function in Lib/uuid.py that generates version-5 name-based UUIDs using SHA-1 per RFC 9562; its qualname equals its public name 'uuid5'; uuid5 takes a namespace UUID and a name string, hashes them with SHA-1, and sets the version bits to 5; compare: uuid3 uses MD5 instead; SHA-1 is preferred over MD5 for new applications per RFC 9562 section 6.5; NEW in uuid_extra203: first standalone uuid5.__qualname__ invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: uuid5.__qualname__.__eq__
  args: ["uuid5"]
  expected: true

invariant uuid_extra203.UUID_module_is_uuid:
  description: "uuid.UUID.__module__.__eq__('uuid') returns True — uuid.UUID is defined in Lib/uuid.py so its __module__ is 'uuid'; this is the standard behavior for Python classes defined at module level in that module; compare: a class imported from a C extension would show the C module name as __module__; UUID is a pure-Python class with __slots__ storing the UUID as a Python int via the 'int' slot; __module__ helps tools locate the source of the class definition; NEW in uuid_extra203: first standalone UUID.__module__ invariant in uuidqualname203 namespace; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: UUID.__module__.__eq__
  args: ["uuid"]
  expected: true

invariant uuid_extra203.SafeUUID_module_is_uuid:
  description: "uuid.SafeUUID.__module__.__eq__('uuid') returns True — SafeUUID is defined in Lib/uuid.py so its __module__ is 'uuid'; SafeUUID is an IntEnum subclass with values SAFE (-1) and UNSAFE (0); the is_safe attribute of a UUID instance is a SafeUUID value indicating whether the UUID was generated in a multiprocessing-safe way; __module__=='uuid' for both UUID and SafeUUID confirms both classes are defined in the same module; NEW in uuid_extra203: first standalone SafeUUID.__module__ invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: SafeUUID.__module__.__eq__
  args: ["uuid"]
  expected: true

