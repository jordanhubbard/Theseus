spec: uuid_extra1981
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#object.__sizeof__"
    - "https://docs.python.org/3/reference/datamodel.html#object.__length_hint__"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 579 (_extra1981): __sizeof__, __length_hint__, __floor__, __ceil__, __trunc__ dict-presence checks."
    - "uuid.UUID does not define __sizeof__ in its own dict — it uses the inherited object.__sizeof__."
    - "uuid.SafeUUID is an IntEnum subclass and does not define __sizeof__ in its own dict."
    - "Neither uuid.UUID nor uuid.SafeUUID define __length_hint__ — they are not iterators."
    - "uuid.UUID does not define __floor__, __ceil__, or __trunc__ — UUID is not a numeric type."
    - "uuid.SafeUUID inherits from enum.IntEnum which inherits from int, but SafeUUID does not define these in its own dict."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table uuid_extra1981.sizeof_protocol:
  description: "uuid types __sizeof__ dict-presence checks — none define __sizeof__ in own dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1981
  columns: [id, function, args, expected]
  rows:
    - ["uu1981001", "uuid.UUID.__dict__.__contains__",     ["__sizeof__"], false]
    - ["uu1981002", "uuid.SafeUUID.__dict__.__contains__", ["__sizeof__"], false]

