spec: abc_extra30
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra29.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__.__len__() and __name__.__len__() and __qualname__.__len__() for ABC/ABCMeta/abstractmethod/get_cache_token, abstractproperty lengths, ABCMeta.register/__name__/__qualname__ lengths, ABCMeta.__new__/__instancecheck__ __qualname__.__len__(), __mro__.__len__() for ABCMeta(3)/ABC(2), ABC/__ABCMeta __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__() for ABC/ABCMeta (both 12), ABCMeta.__subclasscheck__/__qualname__.__len__()==25, update_abstractmethods/__qualname__.__len__()==22, ABC.__abstractmethods__.__class__.__name__.__len__()==9, ABC.__name__.__len__()==3, ABCMeta.register.__qualname__.__len__()==16, abstractmethod.__name__.__len__()==14, get_cache_token.__name__.__len__()==15, abc.__name__.__len__()==3, ABCMeta mro entry name lengths, ABC mro entry name lengths, ABCMeta.__subclasshook__/__qualname__.__len__()==24, issubclass/isinstance behavioral invariants, abstractmethod.__class__.__name__.__len__()==8, ABC.__doc__.__class__.__name__.__len__()==3, update_abstractmethods/__name__.__len__()==22, ABC.__module__.__len__()==3."
    - "This spec covers: ABCMeta.__prepare__.__qualname__.__len__()==19 ('ABCMeta.__prepare__'); ABCMeta.__init__.__qualname__.__len__()==13 ('type.__init__'); ABCMeta.__getattribute__.__qualname__.__len__()==21 ('type.__getattribute__'); ABCMeta.__prepare__.__name__.__len__()==11 ('__prepare__')."
    - "ABCMeta.__prepare__.__qualname__ == 'ABCMeta.__prepare__' (19 chars) — ABCMeta defines __prepare__ itself; the qualname carries the ABCMeta prefix."
    - "ABCMeta.__init__.__qualname__ == 'type.__init__' (13 chars) — ABCMeta does not define its own __init__; it resolves to type.__init__ (ABCMeta is a subclass of type)."
    - "ABCMeta.__getattribute__.__qualname__ == 'type.__getattribute__' (21 chars) — ABCMeta inherits __getattribute__ from type; the qualname reveals the true owner."
    - "ABCMeta.__prepare__.__name__ == '__prepare__' (11 chars) — the dunder name includes four underscores (2 leading + 2 trailing) plus 'prepare' (7), totaling 11."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ABCMeta.__prepare__ qualname and name lengths — extra30 namespace
#
# ABCMeta defines __prepare__ as a classmethod. Its qualname carries the
# ABCMeta prefix:
#   ABCMeta.__prepare__.__qualname__ == 'ABCMeta.__prepare__' (19 chars)
#     = 'ABCMeta' (7) + '.' (1) + '__prepare__' (11) = 19
# The short __name__ is '__prepare__' (11 chars):
#     = '__' (2) + 'prepare' (7) + '__' (2) = 11
# No prior abc spec has measured ABCMeta.__prepare__.__qualname__.__len__() or
# ABCMeta.__prepare__.__name__.__len__().
# ---------------------------------------------------------------------------

table abc_extra30.abcmeta_prepare_name_lengths:
  description: "ABCMeta.__prepare__ __qualname__.__len__() and __name__.__len__() in extra30 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: abcprepnamelen30

  columns: [id, function, args, expected]
  rows:
    - [qualname_len, ABCMeta.__prepare__.__qualname__.__len__, [], 19]
    - [name_len,     ABCMeta.__prepare__.__name__.__len__,     [], 11]

# ---------------------------------------------------------------------------
# ABCMeta inherited method qualname lengths — extra30 namespace
#
# ABCMeta subclasses type. Several special methods are inherited from type,
# so their __qualname__ carries 'type.' as the prefix rather than 'ABCMeta.':
#   ABCMeta.__init__.__qualname__         == 'type.__init__'         (13 chars)
#   ABCMeta.__getattribute__.__qualname__ == 'type.__getattribute__' (21 chars)
#
# This contrasts with ABCMeta.__new__ and ABCMeta.__instancecheck__ and
# ABCMeta.__prepare__, which ARE defined on ABCMeta and carry 'ABCMeta.' prefix.
#
# ABCMeta.__init__.__qualname__ was confirmed to be 'type.__init__' in extra21
# (via the __name__ check) but __qualname__.__len__() == 13 has not been
# captured as a table row or invariant in any prior abc spec.
#
# ABCMeta.__getattribute__.__qualname__ == 'type.__getattribute__' (21 chars)
# has not been covered in any prior abc spec.
# ---------------------------------------------------------------------------

table abc_extra30.abcmeta_inherited_method_qualname_lengths:
  description: "ABCMeta inherited-from-type method __qualname__.__len__() in extra30 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: abcmetainherqlen30

  columns: [id, function, args, expected, description]
  rows:
    - [init,           ABCMeta.__init__.__qualname__.__len__,         [], 13, "'type.__init__' (13 chars) — inherited from type, not defined on ABCMeta"]
    - [getattribute,   ABCMeta.__getattribute__.__qualname__.__len__, [], 21, "'type.__getattribute__' (21 chars) — inherited from type"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra30
# ---------------------------------------------------------------------------

invariant abc_extra30.ABCMeta_prepare_qualname_len:
  description: "abc.ABCMeta.__prepare__.__qualname__.__len__() == 19 — 'ABCMeta.__prepare__' has 19 characters; __prepare__ is defined on ABCMeta itself"
  category: method_names
  kind: python_call_eq
  function: ABCMeta.__prepare__.__qualname__.__len__
  args: []
  expected: 19

invariant abc_extra30.ABCMeta_init_qualname_len:
  description: "abc.ABCMeta.__init__.__qualname__.__len__() == 13 — resolves to 'type.__init__' (13 chars); ABCMeta does not define its own __init__"
  category: method_names
  kind: python_call_eq
  function: ABCMeta.__init__.__qualname__.__len__
  args: []
  expected: 13

invariant abc_extra30.ABCMeta_getattribute_qualname_len:
  description: "abc.ABCMeta.__getattribute__.__qualname__.__len__() == 21 — resolves to 'type.__getattribute__' (21 chars); inherited from type"
  category: method_names
  kind: python_call_eq
  function: ABCMeta.__getattribute__.__qualname__.__len__
  args: []
  expected: 21
