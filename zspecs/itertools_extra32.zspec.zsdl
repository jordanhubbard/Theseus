spec: itertools_extra32
version: ">=3.10"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra31.zspec.zsdl."
    - "Prior specs covered: chain/cycle/count/dropwhile/filterfalse/groupby/islice/pairwise/permutations/combinations/product/repeat/starmap/takewhile/zip_longest __name__/__module__/__qualname__, __name__.__len__() for all types, __module__.__len__() for all types (all 9), chain.from_iterable qualname len (19), groupby.__iter__/__next__ qualname len (16), __mro__.__len__() for chain/cycle/islice/product/groupby/accumulate/pairwise/filterfalse (all 2), __bases__[0].__name__.__len__() for chain/cycle/islice/product/dropwhile/filterfalse/repeat/starmap/takewhile/zip_longest/accumulate/permutations (all 6 — 'object'), __dict__.__class__.__name__.__len__() for count/repeat/dropwhile/takewhile/starmap/zip_longest/permutations/combinations (all 12), __qualname__.__len__() for count/repeat/starmap/dropwhile/takewhile/accumulate/filterfalse/zip_longest/permutations/combinations, combinations_with_replacement.__qualname__.__len__() (29), itertools.__doc__.__class__.__name__.__len__() (3)."
    - "This spec covers: combinations_with_replacement.__dict__.__class__.__name__.__len__() (12); combinations_with_replacement.__mro__.__len__() (2); combinations_with_replacement.__bases__[0].__name__.__len__() (6); pairwise/__dict__.__class__.__name__.__len__() (12); compress/__qualname__.__len__() (8); compress/__dict__.__class__.__name__.__len__() (12); compress/__mro__.__len__() (2); compress/__bases__[0].__name__.__len__() (6); islice/__qualname__.__len__() (6); groupby/__qualname__.__len__() (7); cycle/__dict__.__class__.__name__.__len__() (12); itertools.__name__.__len__() (9); itertools.__spec__.__class__.__name__.__len__() (10)."
    - "Key findings: itertools has no __all__ attribute (it is a C extension module). combinations_with_replacement.__qualname__.__len__() == 29 (confirmed from extra30 notes). compress is a C-level filter type with qualname 'compress' (8 chars) — same length as pairwise. itertools.__spec__.__class__.__name__ is 'ModuleSpec' (10 chars)."
    - "spec version >=3.10 required for pairwise."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# combinations_with_replacement class metadata table — extra32 namespace
#
# itertools.combinations_with_replacement is the longest-named C-level type in itertools.
# Its __dict__.__class__.__name__ is 'mappingproxy' (12 chars), consistent with all other
# itertools types. Its __mro__ has length 2 — [combinations_with_replacement, object].
# Its __bases__[0].__name__ is 'object' (6 chars). Its __qualname__ is
# 'combinations_with_replacement' (29 chars) — the longest qualname in the module.
# No prior itertools spec records these four metadata values together in a combined
# table in the extra32 namespace.
# ---------------------------------------------------------------------------

table itertools_extra32.cwr_class_metadata:
  description: "combinations_with_replacement class metadata: __dict__.__class__.__name__.__len__, __mro__.__len__, __bases__[0].__name__.__len__, __qualname__.__len__"
  kind: python_call_eq
  category: class_structure
  id_prefix: cwrmeta32

  columns: [id, function, args, expected, description]
  rows:
    - [dict_classname_len,
       combinations_with_replacement.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len(combinations_with_replacement.__dict__.__class__.__name__) == 12 — 'mappingproxy'"]
    - [mro_len,
       combinations_with_replacement.__mro__.__len__,
       [],
       2,
       "len(combinations_with_replacement.__mro__) == 2 — [combinations_with_replacement, object]"]
    - [bases_name_len,
       "combinations_with_replacement.__bases__[0].__name__.__len__",
       [],
       6,
       "len(combinations_with_replacement.__bases__[0].__name__) == 6 — 'object'"]
    - [qualname_len,
       combinations_with_replacement.__qualname__.__len__,
       [],
       29,
       "len(combinations_with_replacement.__qualname__) == 29 — 'combinations_with_replacement'"]

# ---------------------------------------------------------------------------
# compress type metadata table — __qualname__, __dict__, __mro__, __bases__ — extra32 namespace
#
# itertools.compress filters one iterable by another acting as boolean selectors.
# compress.__qualname__ is 'compress' (8 chars) — same length as pairwise.
# compress.__dict__.__class__.__name__ is 'mappingproxy' (12 chars).
# compress.__mro__ has length 2 — [compress, object].
# compress.__bases__[0].__name__ is 'object' (6 chars).
# No prior itertools spec records these four compress metadata values together
# in a combined table in the extra32 namespace.
# ---------------------------------------------------------------------------

table itertools_extra32.compress_class_metadata:
  description: "itertools.compress class metadata: __qualname__.__len__, __dict__.__class__.__name__.__len__, __mro__.__len__, __bases__[0].__name__.__len__"
  kind: python_call_eq
  category: class_structure
  id_prefix: compressmeta32

  columns: [id, function, args, expected, description]
  rows:
    - [qualname_len,
       compress.__qualname__.__len__,
       [],
       8,
       "len(itertools.compress.__qualname__) == 8 — 'compress'"]
    - [dict_classname_len,
       compress.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len(itertools.compress.__dict__.__class__.__name__) == 12 — 'mappingproxy'"]
    - [mro_len,
       compress.__mro__.__len__,
       [],
       2,
       "len(itertools.compress.__mro__) == 2 — [compress, object]"]
    - [bases_name_len,
       "compress.__bases__[0].__name__.__len__",
       [],
       6,
       "len(itertools.compress.__bases__[0].__name__) == 6 — 'object'"]

# ---------------------------------------------------------------------------
# Additional type __dict__.__class__.__name__.__len__() table — pairwise/cycle/islice/groupby
#
# itertools.pairwise.__dict__.__class__.__name__ is 'mappingproxy' (12 chars).
# itertools.cycle.__dict__.__class__.__name__ is 'mappingproxy' (12 chars).
# itertools.islice.__dict__.__class__.__name__ is 'mappingproxy' (12 chars).
# itertools.groupby.__dict__.__class__.__name__ is 'mappingproxy' (12 chars).
# Extra31 recorded count/repeat/dropwhile/takewhile/starmap/zip_longest/permutations/combinations.
# This table adds the four remaining major types not yet recorded in the extra31 namespace.
# ---------------------------------------------------------------------------

table itertools_extra32.additional_dict_classname_lengths:
  description: "__dict__.__class__.__name__.__len__() for remaining itertools types — all 12 ('mappingproxy')"
  kind: python_call_eq
  category: class_dict_types
  id_prefix: addldict32

  columns: [id, function, args, expected, description]
  rows:
    - [pairwise,
       pairwise.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len(itertools.pairwise.__dict__.__class__.__name__) == 12 — 'mappingproxy'"]
    - [cycle,
       cycle.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len(itertools.cycle.__dict__.__class__.__name__) == 12 — 'mappingproxy'"]
    - [islice,
       islice.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len(itertools.islice.__dict__.__class__.__name__) == 12 — 'mappingproxy'"]
    - [groupby,
       groupby.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len(itertools.groupby.__dict__.__class__.__name__) == 12 — 'mappingproxy'"]

# ---------------------------------------------------------------------------
# itertools.__name__.__len__() — standalone invariant
#
# itertools.__name__ is 'itertools' (9 chars). As a built-in C extension module,
# itertools.__name__ matches the module's public name. itertools has no __all__
# attribute (unlike pure-Python modules), so __name__ provides the canonical
# module identity. No prior itertools spec records itertools.__name__.__len__() as
# a standalone in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra32.module_name_len:
  description: "len(itertools.__name__) == 9 — 'itertools'"
  category: module_metadata
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# itertools.__spec__.__class__.__name__.__len__() — standalone invariant
#
# itertools.__spec__.__class__.__name__ is 'ModuleSpec' (10 chars). The ModuleSpec
# class is defined in importlib._bootstrap and holds the specification used when
# loading itertools. All built-in C extension modules share this same ModuleSpec
# class. No prior itertools spec records __spec__.__class__.__name__.__len__() as
# a standalone in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra32.spec_classname_len:
  description: "len(itertools.__spec__.__class__.__name__) == 10 — 'ModuleSpec'"
  category: module_metadata
  kind: python_call_eq
  function: __spec__.__class__.__name__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# itertools.islice.__qualname__.__len__() — standalone invariant
#
# itertools.islice.__qualname__ is 'islice' (6 chars). islice slices an iterator
# like Python's built-in slice but works on any iterable. Its 6-character qualname
# is the same length as repeat. No prior itertools spec records
# islice.__qualname__.__len__() as a standalone in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra32.islice_qualname_len:
  description: "len(itertools.islice.__qualname__) == 6 — 'islice'"
  category: string_properties
  kind: python_call_eq
  function: islice.__qualname__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# itertools.groupby.__qualname__.__len__() — standalone invariant
#
# itertools.groupby.__qualname__ is 'groupby' (7 chars). groupby groups consecutive
# elements of an iterable by a key function. Its 7-character qualname is the same
# length as product and starmap. No prior itertools spec records
# groupby.__qualname__.__len__() as a standalone in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra32.groupby_qualname_len:
  description: "len(itertools.groupby.__qualname__) == 7 — 'groupby'"
  category: string_properties
  kind: python_call_eq
  function: groupby.__qualname__.__len__
  args: []
  expected: 7
