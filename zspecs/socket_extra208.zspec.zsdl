spec: socket_extra208
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "Python 3 socket module documentation — https://docs.python.org/3/library/socket.html"
    - "POSIX.1-2017 — AF_INET, AF_INET6, SOCK_STREAM, SOCK_DGRAM, SOCK_RAW constants"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "This spec extends socket.zspec.zsdl, socket_extra.zspec.zsdl, and socket_extra2.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "socket_extra2.zspec.zsdl covers: AF_INET/AF_INET6/AF_UNIX AddressFamily class names; SOCK_STREAM/SOCK_DGRAM/SOCK_RAW SocketKind class names; AF_INET==2, SOCK_STREAM==1, SOCK_DGRAM==2; gethostname/getfqdn return str; socket.error alias; socket.timeout alias."
    - "socket.socket is a Python-level class wrapping the C socket object. Its __dict__ contains only the Python-layer methods defined in Lib/socket.py; low-level methods like fileno(), getsockopt(), setsockopt() are NOT in socket.socket.__dict__ — they are inherited from _socket.socket (C extension)."
    - "socket.socket.__dict__ DOES contain: __doc__, __init__, __repr__, __enter__, __exit__, accept, close, dup, makefile, sendfile, detach, family, type, get_inheritable, set_inheritable (all verified on Python 3.14.3)."
    - "AF_INET.__class__.__name__ == 'AddressFamily', AF_INET6.__class__.__name__ == 'AddressFamily', SOCK_STREAM.__class__.__name__ == 'SocketKind' (all verified on Python 3.14.3)."
    - "SOCK_DGRAM.__class__.__name__ == 'SocketKind' and SOCK_RAW.__class__.__name__ == 'SocketKind' (verified on Python 3.14.3)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model:
  semantics: "socket raises OSError and subclasses for I/O failures. Class and dict membership checks are stateless and never raise."
  stderr: "null"
  stickiness: "N/A — all tested invariants are class name or dict membership checks."
  codes: {}

# ---------------------------------------------------------------------------
# socket.socket.__dict__ — Python-layer method membership
# Note: fileno, getsockopt, setsockopt are inherited from _socket.socket (C layer)
# and are NOT in socket.socket.__dict__. The Python-layer wrapping methods are here.
# ---------------------------------------------------------------------------

table socketannotations208.socket_dict.known_true:
  description: "socket.socket.__dict__ contains Python-layer method and slot entries"
  kind: python_call_eq
  category: class_metadata
  id_prefix: socketannotations208_dict_true

  columns: [id, function, args, expected, description]
  rows:
    - [doc,       "socket.__dict__.__contains__", ["__doc__"],   true, "socket.socket.__dict__ contains '__doc__'"]
    - [init,      "socket.__dict__.__contains__", ["__init__"],  true, "socket.socket.__dict__ contains '__init__'"]
    - [repr,      "socket.__dict__.__contains__", ["__repr__"],  true, "socket.socket.__dict__ contains '__repr__'"]
    - [accept,    "socket.__dict__.__contains__", ["accept"],    true, "socket.socket.__dict__ contains 'accept' (Python-layer override)"]

# ---------------------------------------------------------------------------
# socket.socket.__dict__ — Python-layer method membership (more entries)
# ---------------------------------------------------------------------------

table socketannotations208.socket_dict.more_methods:
  description: "socket.socket.__dict__ contains additional Python-layer method entries"
  kind: python_call_eq
  category: class_metadata
  id_prefix: socketannotations208_dict_more

  columns: [id, function, args, expected, description]
  rows:
    - [close,         "socket.__dict__.__contains__", ["close"],         true,  "socket.socket.__dict__ contains 'close'"]
    - [dup,           "socket.__dict__.__contains__", ["dup"],           true,  "socket.socket.__dict__ contains 'dup'"]
    - [makefile,      "socket.__dict__.__contains__", ["makefile"],      true,  "socket.socket.__dict__ contains 'makefile'"]
    - [fileno_absent, "socket.__dict__.__contains__", ["fileno"],        false, "fileno is NOT in socket.socket.__dict__ — it is inherited from _socket.socket (C layer)"]

# ---------------------------------------------------------------------------
# socket module constants — AddressFamily and SocketKind enum class names
# (Integer values are covered in socket.zspec.zsdl and socket_extra2.zspec.zsdl.)
# This table covers AF constants not checked in socket_extra2: AF_UNSPEC.
# ---------------------------------------------------------------------------

table socketannotations208.constants.class_names:
  description: "AF_INET, AF_INET6, AF_UNSPEC are AddressFamily enum members; SOCK_STREAM, SOCK_DGRAM, SOCK_RAW are SocketKind enum members"
  kind: python_call_eq
  category: constants
  id_prefix: socketannotations208_consts

  columns: [id, function, args, expected, description]
  rows:
    - [af_inet,    AF_INET.__class__.__name__.__eq__,    ["AddressFamily"], true, "AF_INET is an AddressFamily enum member"]
    - [af_inet6,   AF_INET6.__class__.__name__.__eq__,   ["AddressFamily"], true, "AF_INET6 is an AddressFamily enum member"]
    - [af_unspec,  AF_UNSPEC.__class__.__name__.__eq__,  ["AddressFamily"], true, "AF_UNSPEC is an AddressFamily enum member"]
    - [sock_stream, SOCK_STREAM.__class__.__name__.__eq__, ["SocketKind"],  true, "SOCK_STREAM is a SocketKind enum member"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant socketannotations208.socket_dict.has_accept:
  description: "socket.socket.__dict__.__contains__('accept') == True — accept is a Python-layer method on socket.socket"
  category: class_metadata
  kind: python_call_eq
  function: "socket.__dict__.__contains__"
  args: ["accept"]
  expected: true

invariant socketannotations208.socket_dict.has_makefile:
  description: "socket.socket.__dict__.__contains__('makefile') == True — makefile is a Python-layer method"
  category: class_metadata
  kind: python_call_eq
  function: "socket.__dict__.__contains__"
  args: ["makefile"]
  expected: true

invariant socketannotations208.socket_dict.no_fileno:
  description: "socket.socket.__dict__.__contains__('fileno') == False — fileno is inherited from _socket.socket, not defined in the Python wrapper"
  category: class_metadata
  kind: python_call_eq
  function: "socket.__dict__.__contains__"
  args: ["fileno"]
  expected: false

invariant socketannotations208.socket_dict.no_getsockopt:
  description: "socket.socket.__dict__.__contains__('getsockopt') == False — getsockopt is inherited from _socket.socket (C layer)"
  category: class_metadata
  kind: python_call_eq
  function: "socket.__dict__.__contains__"
  args: ["getsockopt"]
  expected: false

invariant socketannotations208.AF_INET.class_name:
  description: "socket.AF_INET.__class__.__name__ == 'AddressFamily'"
  category: constants
  kind: python_call_eq
  function: AF_INET.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

invariant socketannotations208.AF_INET6.class_name:
  description: "socket.AF_INET6.__class__.__name__ == 'AddressFamily'"
  category: constants
  kind: python_call_eq
  function: AF_INET6.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

invariant socketannotations208.SOCK_STREAM.class_name:
  description: "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind'"
  category: constants
  kind: python_call_eq
  function: SOCK_STREAM.__class__.__name__.__eq__
  args: ["SocketKind"]
  expected: true

invariant socketannotations208.socket_dict.has_detach:
  description: "socket.socket.__dict__.__contains__('detach') == True — detach is a Python-layer method on socket.socket"
  category: class_metadata
  kind: python_call_eq
  function: "socket.__dict__.__contains__"
  args: ["detach"]
  expected: true

