spec: base64_extra15
version: ">=3.9"
backend: python_module(base64)

docs: https://docs.python.org/3/library/base64.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/base64.html — Python base64 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/base64.py"
    - "base64_extra14.zspec.zsdl — covers b64encode single-pad/double-pad/no-pad; b64decode round-trips; urlsafe_b64encode(b'foo+bar'); b16encode(b'hello')."
    - "base64_extra13.zspec.zsdl — covers b64encode(b'hello')/b64decode(b'aGVsbG8='); b16encode(b'hi')/b16decode(b'6869'); urlsafe_b64encode(b'hello') class name."
    - "base64_extra12.zspec.zsdl — covers b64encode/decode/urlsafe_b64encode/decode/b16encode/b32encode __name__/__module__; b64encode(b'') value/class/decode."
    - "base64_extra11.zspec.zsdl — covers urlsafe_b64encode/decode __name__/__module__; b32decode __name__/__module__; urlsafe/b16/b32 encode/decode vectors."
    - "base64_extra10.zspec.zsdl — covers b64decode.__name__/__module__; b64encode/decode abc/Man; urlsafe fbff; b32encode/decode foo/foobar; b16encode/decode DEADBEEF."
    - "base64_extra7.zspec.zsdl — covers b16/b32/b85 __name__ and __module__; b16encode null/ff; b64encode Man; urlsafe return class."
  notes:
    - "This spec extends base64 through base64_extra14 with function __qualname__ and __module__ attributes."
    - "base64.b64encode.__qualname__ == 'b64encode': top-level function; qualname equals simple name."
    - "base64.b64decode.__qualname__ == 'b64decode': top-level function; qualname equals simple name."
    - "base64.urlsafe_b64encode.__qualname__ == 'urlsafe_b64encode': top-level function."
    - "base64.urlsafe_b64decode.__qualname__ == 'urlsafe_b64decode': top-level function."
    - "base64.encodebytes.__module__ == 'base64': encodebytes is a pure-Python function defined in base64.py."
    - "base64.decodebytes.__module__ == 'base64': decodebytes is a pure-Python function defined in base64.py."
    - "base64.encodebytes.__qualname__ == 'encodebytes': top-level function."
    - "base64.decodebytes.__qualname__ == 'decodebytes': top-level function."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# encodebytes and decodebytes — __module__ (extra15 namespace)
#
# base64_extra12 covers b64encode/__module__ and b64decode/__module__.
# No prior spec covers encodebytes.__module__ or decodebytes.__module__.
# Verified: base64.encodebytes.__module__ == 'base64'
#           base64.decodebytes.__module__ == 'base64'
# ---------------------------------------------------------------------------

invariant base64_extra15.encodebytes.module:
  description: "base64.encodebytes.__module__ == 'base64' — pure-Python function defined in base64.py"
  category: function_attrs
  kind: python_call_eq
  function: encodebytes.__module__.__eq__
  args: ["base64"]
  expected: true

invariant base64_extra15.decodebytes.module:
  description: "base64.decodebytes.__module__ == 'base64' — pure-Python function defined in base64.py"
  category: function_attrs
  kind: python_call_eq
  function: decodebytes.__module__.__eq__
  args: ["base64"]
  expected: true

# ---------------------------------------------------------------------------
# encodebytes and decodebytes — __qualname__ (extra15 namespace)
#
# No prior spec covers encodebytes.__qualname__ or decodebytes.__qualname__.
# For top-level functions __qualname__ equals the simple function name.
# Verified: base64.encodebytes.__qualname__ == 'encodebytes'
#           base64.decodebytes.__qualname__ == 'decodebytes'
# ---------------------------------------------------------------------------

invariant base64_extra15.encodebytes.qualname:
  description: "base64.encodebytes.__qualname__ == 'encodebytes' — top-level function; qualname equals name"
  category: function_attrs
  kind: python_call_eq
  function: encodebytes.__qualname__.__eq__
  args: ["encodebytes"]
  expected: true

invariant base64_extra15.decodebytes.qualname:
  description: "base64.decodebytes.__qualname__ == 'decodebytes' — top-level function; qualname equals name"
  category: function_attrs
  kind: python_call_eq
  function: decodebytes.__qualname__.__eq__
  args: ["decodebytes"]
  expected: true

# ---------------------------------------------------------------------------
# urlsafe_b64decode.__qualname__ (extra15 namespace)
#
# base64_extra11 covers urlsafe_b64decode.__name__ and __module__.
# No prior spec covers urlsafe_b64decode.__qualname__ as a standalone
# invariant from the extra15 namespace.
# Verified: base64.urlsafe_b64decode.__qualname__ == 'urlsafe_b64decode'.
# ---------------------------------------------------------------------------

invariant base64_extra15.urlsafe_b64decode.qualname:
  description: "base64.urlsafe_b64decode.__qualname__ == 'urlsafe_b64decode' — top-level function"
  category: function_attrs
  kind: python_call_eq
  function: urlsafe_b64decode.__qualname__.__eq__
  args: ["urlsafe_b64decode"]
  expected: true

# ---------------------------------------------------------------------------
# Table: __qualname__ for b64encode, b64decode, urlsafe_b64encode,
#        urlsafe_b64decode, b32encode, b16encode (extra15 namespace)
#
# base64_extra12 covers __name__ for b64encode/decode/urlsafe variants/b16/b32;
# no prior spec gathers __qualname__ for all six in a single table.
# For top-level functions __qualname__ == __name__.
# ---------------------------------------------------------------------------

table base64_extra15.function_qualnames:
  description: "__qualname__ for six top-level base64 encoding functions"
  kind: python_call_eq
  category: function_attrs

  columns: [id, function, args, expected]
  rows:
    - [b64encode,         b64encode.__qualname__.__eq__,         ["b64encode"],         true]
    - [b64decode,         b64decode.__qualname__.__eq__,         ["b64decode"],         true]
    - [urlsafe_b64encode, urlsafe_b64encode.__qualname__.__eq__, ["urlsafe_b64encode"], true]
    - [urlsafe_b64decode, urlsafe_b64decode.__qualname__.__eq__, ["urlsafe_b64decode"], true]
    - [b32encode,         b32encode.__qualname__.__eq__,         ["b32encode"],         true]
    - [b16encode,         b16encode.__qualname__.__eq__,         ["b16encode"],         true]
