spec: readline_extra2
version: ">=3.9"
backend: python_module(readline)

docs: https://docs.python.org/3/library/readline.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/readline.html — Python readline documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/readline.c"
  notes:
    - "This spec extends readline.zspec.zsdl and readline_extra.zspec.zsdl."
    - "readline.zspec.zsdl covers: __name__ for all main functions in a table; get_history_length default; get_current_history_length non-negative."
    - "readline_extra.zspec.zsdl covers: read_history_file/write_history_file/get_history_length/set_completer/get_completer/parse_and_bind/add_history __name__+__module__; module __name__."
    - "This spec adds: __module__ for set_history_length, clear_history, get_current_history_length, get_history_item, remove_history_item, replace_history_item; individual __name__ invariants for remove_history_item and replace_history_item (base only uses a table)."
    - "readline is a POSIX-only C extension module; its functions are C builtins whose __module__ == 'readline'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# set_history_length — module affiliation
# readline_extra covers get_history_length __name__+__module__; set_history_length
# __module__ is not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant readline_extra2.set_history_length.module:
  description: "readline.set_history_length.__module__ == 'readline'"
  category: functions
  kind: python_call_eq
  function: set_history_length.__module__.__eq__
  args: ["readline"]
  expected: true

# ---------------------------------------------------------------------------
# clear_history — module affiliation
# __name__ covered by base table; __module__ not yet covered.
# ---------------------------------------------------------------------------

invariant readline_extra2.clear_history.module:
  description: "readline.clear_history.__module__ == 'readline'"
  category: functions
  kind: python_call_eq
  function: clear_history.__module__.__eq__
  args: ["readline"]
  expected: true

# ---------------------------------------------------------------------------
# get_current_history_length — module affiliation
# __name__ covered by base table; __module__ not yet covered.
# ---------------------------------------------------------------------------

invariant readline_extra2.get_current_history_length.module:
  description: "readline.get_current_history_length.__module__ == 'readline'"
  category: functions
  kind: python_call_eq
  function: get_current_history_length.__module__.__eq__
  args: ["readline"]
  expected: true

# ---------------------------------------------------------------------------
# get_history_item — module affiliation
# __name__ covered by base table; __module__ not yet covered.
# ---------------------------------------------------------------------------

invariant readline_extra2.get_history_item.module:
  description: "readline.get_history_item.__module__ == 'readline'"
  category: functions
  kind: python_call_eq
  function: get_history_item.__module__.__eq__
  args: ["readline"]
  expected: true

# ---------------------------------------------------------------------------
# remove_history_item — name and module
# __name__ covered only by the base table; individual invariant + __module__ new.
# ---------------------------------------------------------------------------

invariant readline_extra2.remove_history_item.name:
  description: "readline.remove_history_item.__name__ == 'remove_history_item'"
  category: functions
  kind: python_call_eq
  function: remove_history_item.__name__.__eq__
  args: ["remove_history_item"]
  expected: true

invariant readline_extra2.remove_history_item.module:
  description: "readline.remove_history_item.__module__ == 'readline'"
  category: functions
  kind: python_call_eq
  function: remove_history_item.__module__.__eq__
  args: ["readline"]
  expected: true

# ---------------------------------------------------------------------------
# replace_history_item — name and module
# __name__ covered only by the base table; individual invariant + __module__ new.
# ---------------------------------------------------------------------------

invariant readline_extra2.replace_history_item.name:
  description: "readline.replace_history_item.__name__ == 'replace_history_item'"
  category: functions
  kind: python_call_eq
  function: replace_history_item.__name__.__eq__
  args: ["replace_history_item"]
  expected: true

invariant readline_extra2.replace_history_item.module:
  description: "readline.replace_history_item.__module__ == 'readline'"
  category: functions
  kind: python_call_eq
  function: replace_history_item.__module__.__eq__
  args: ["readline"]
  expected: true

# ---------------------------------------------------------------------------
# Table: batch __module__ checks for functions not yet covered by readline_extra
# Covers set_history_length, clear_history, get_current_history_length,
# get_history_item, remove_history_item, replace_history_item together.
# ---------------------------------------------------------------------------

table readline_extra2.function_modules:
  kind: python_call_eq
  category: functions
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [set_history_length,         set_history_length.__module__.__eq__,         ["readline"], true]
    - [clear_history,              clear_history.__module__.__eq__,              ["readline"], true]
    - [get_current_history_length, get_current_history_length.__module__.__eq__, ["readline"], true]
    - [get_history_item,           get_history_item.__module__.__eq__,           ["readline"], true]
    - [remove_history_item,        remove_history_item.__module__.__eq__,        ["readline"], true]
    - [replace_history_item,       replace_history_item.__module__.__eq__,       ["readline"], true]
