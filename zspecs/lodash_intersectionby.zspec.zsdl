spec: lodash_intersectionby
version: ">=4.0.0"
backend: node(lodash.intersectionby)

docs: https://lodash.com/docs/#intersectionBy

provenance:
  derived_from:
    - "lodash.intersectionby README — https://www.npmjs.com/package/lodash.intersectionby"
    - "Test vectors verified with lodash.intersectionby@4.7.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.intersectionby exports the _.intersectionBy function directly as module.exports."
    - "intersectionBy(array, values, iteratee) returns elements present in all arrays."
    - "String iteratee plucks a property for comparison. Returns elements from the first array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array of common elements."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_intersectionby.intersectionby:
  kind: node_module_call_eq
  function: ~
  category: intersectionby
  id_prefix: lib

  columns: [id, args, expected]
  rows:
    - [by_x,  [[{"x": 1, "y": "a"}, {"x": 2, "y": "b"}], [{"x": 2, "y": "c"}], "x"],
       [{"x": 2, "y": "b"}]]
    - [by_n,  [[{"n": 1}, {"n": 2}, {"n": 3}], [{"n": 1}, {"n": 3}], "n"],
       [{"n": 1}, {"n": 3}]]
