spec: hashlib_extra370
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "hashlib.md5.__name__ == 'openssl_md5'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__name__ == 'openssl_sha1'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__name__ == 'openssl_sha256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__name__ == 'openssl_sha512'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__name__ == '__hash_new'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__module__ == 'hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.md5, sha1, sha256, sha512 are OpenSSL-backed constructors in the _hashlib C extension; their __name__ is prefixed with 'openssl_' and __module__ is '_hashlib'."
    - "Note: hashlib.new is a Python-level dispatcher function defined in Lib/hashlib.py; its __name__ is '__hash_new' and __module__ is 'hashlib'."
    - "Note: The 'openssl_' prefix in __name__ reflects that CPython on macOS delegates MD5/SHA1/SHA256/SHA512 to OpenSSL via the _hashlib extension module."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.md5.__name__ / hashlib.md5.__module__
# hashlib.sha1.__name__ / hashlib.sha1.__module__
# hashlib.sha256.__name__ / hashlib.sha256.__module__
# hashlib.sha512.__name__ / hashlib.sha512.__module__
# hashlib.new.__name__ / hashlib.new.__module__
#
# Wave 370 theme: hashlib constructor function identity.
#
# On CPython (macOS), hashlib.md5, sha1, sha256, and sha512 are implemented
# as C built-ins inside the _hashlib extension module, which wraps OpenSSL.
# Their __name__ values are 'openssl_md5', 'openssl_sha1', 'openssl_sha256',
# and 'openssl_sha512' respectively, and their __module__ is '_hashlib'.
#
# hashlib.new is a Python-level function in Lib/hashlib.py that dispatches to
# the appropriate constructor. Its internal name is '__hash_new' and its
# __module__ is 'hashlib'. This naming is an implementation detail of CPython.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra370.constructor_dunder_name:
  description: "hashlib constructor __name__ identity — md5/sha1/sha256/sha512 are OpenSSL-backed builtins in _hashlib with 'openssl_' prefixed names; hashlib.new is a Python dispatcher with __name__ '__hash_new'; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlibfnid370

  columns: [id, function, args, expected]
  rows:
    - [md5_name,    md5.__name__.__eq__,    ["openssl_md5"],    true]
    - [sha1_name,   sha1.__name__.__eq__,   ["openssl_sha1"],   true]
    - [sha256_name, sha256.__name__.__eq__, ["openssl_sha256"], true]
    - [sha512_name, sha512.__name__.__eq__, ["openssl_sha512"], true]
    - [new_name,    new.__name__.__eq__,    ["__hash_new"],     true]

table hashlib_extra370.constructor_dunder_module:
  description: "hashlib constructor __module__ identity — md5/sha1/sha256/sha512 report __module__=='_hashlib' (OpenSSL C extension); hashlib.new reports __module__=='hashlib' (pure-Python dispatcher); verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlibfnid370

  columns: [id, function, args, expected]
  rows:
    - [md5_module,    md5.__module__.__eq__,    ["_hashlib"], true]
    - [sha1_module,   sha1.__module__.__eq__,   ["_hashlib"], true]
    - [sha256_module, sha256.__module__.__eq__, ["_hashlib"], true]
    - [sha512_module, sha512.__module__.__eq__, ["_hashlib"], true]
    - [new_module,    new.__module__.__eq__,    ["hashlib"],  true]

# ---------------------------------------------------------------------------
# hashlib.md5.__name__ == 'openssl_md5' — standalone
#
# hashlib.md5 is the MD5 hash constructor. On CPython with OpenSSL, it is
# implemented as a C function in the _hashlib extension. Its internal
# __name__ attribute is 'openssl_md5', reflecting the OpenSSL backend.
# MD5 is a 128-bit hash function (RFC 1321), now considered cryptographically
# broken for security purposes but still available in hashlib. Verified
# Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra370.md5_name:
  description: "hashlib.md5.__name__.__eq__('openssl_md5') == True — md5 constructor is an OpenSSL-backed C builtin in _hashlib; __name__ is 'openssl_md5' reflecting the OpenSSL backend; MD5 is a 128-bit hash (RFC 1321); verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: md5.__name__.__eq__
  args: ["openssl_md5"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__name__ == '__hash_new' — standalone
#
# hashlib.new is the generic hash constructor that accepts an algorithm name
# string (e.g., hashlib.new('sha256')). It is defined in Lib/hashlib.py as
# a Python-level function. Its internal __name__ is '__hash_new', which is
# an implementation detail of how CPython patches the function into the
# hashlib namespace. Its __module__ is 'hashlib'. Verified Python 3.14.3
# macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra370.new_name:
  description: "hashlib.new.__name__.__eq__('__hash_new') == True — hashlib.new is a Python-level generic dispatcher defined in Lib/hashlib.py; __name__ is '__hash_new' (CPython implementation detail); accepts algorithm name string like 'sha256'; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: new.__name__.__eq__
  args: ["__hash_new"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha256.__module__ == '_hashlib' — standalone
#
# hashlib.sha256 is backed by OpenSSL via the _hashlib C extension. Its
# __module__ is '_hashlib', not 'hashlib'. This reflects that the actual
# function object lives in the C extension, and hashlib.py re-exports it
# into the hashlib namespace. SHA-256 is a 256-bit hash function from the
# SHA-2 family (FIPS 180-4). Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra370.sha256_module:
  description: "hashlib.sha256.__module__.__eq__('_hashlib') == True — sha256 is an OpenSSL C builtin re-exported from _hashlib into hashlib namespace; __module__ is '_hashlib'; SHA-256 is a 256-bit FIPS 180-4 hash function; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: sha256.__module__.__eq__
  args: ["_hashlib"]
  expected: true
