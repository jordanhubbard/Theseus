spec: inspect_extra322
version: ">=3.3"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "inspect.ismodule(inspect) == True — the inspect module object is a module."
    - "inspect.ismodule(42) == False — integers are not modules."
    - "inspect.isclass(int) == True — int is a type/class."
    - "inspect.isclass(42) == False — integers are not classes."
    - "inspect.isfunction(lambda: None) == True — lambda expressions produce function objects."
    - "inspect.isfunction(len) == False — len is a C-level builtin, not a Python function."
    - "inspect.isbuiltin(len) == True — len is a builtin_function_or_method."
    - "inspect.isbuiltin(lambda: None) == False — Python functions are not builtins."
    - "inspect.isgeneratorfunction(lambda: None) == False — a plain lambda is not a generator function."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ismodule — True for module objects, False for non-modules
# ---------------------------------------------------------------------------

invariant inspect_extra322.ismodule.module_true:
  description: "inspect.ismodule(inspect) == True"
  category: ismodule
  kind: python_call_eq
  function: ismodule
  args: [inspect]
  expected: true

invariant inspect_extra322.ismodule.int_false:
  description: "inspect.ismodule(42) == False"
  category: ismodule
  kind: python_call_eq
  function: ismodule
  args: [42]
  expected: false

# ---------------------------------------------------------------------------
# isclass — True for class objects, False for instances
# ---------------------------------------------------------------------------

invariant inspect_extra322.isclass.int_true:
  description: "inspect.isclass(int) == True"
  category: isclass
  kind: python_call_eq
  function: isclass
  args: [int]
  expected: true

invariant inspect_extra322.isclass.int_instance_false:
  description: "inspect.isclass(42) == False"
  category: isclass
  kind: python_call_eq
  function: isclass
  args: [42]
  expected: false

# ---------------------------------------------------------------------------
# isfunction — True for Python functions, False for C builtins
# ---------------------------------------------------------------------------

invariant inspect_extra322.isfunction.lambda_true:
  description: "inspect.isfunction(lambda: None) == True"
  category: isfunction
  kind: python_call_eq
  function: isfunction
  args: [lambda: None]
  expected: true

invariant inspect_extra322.isfunction.builtin_false:
  description: "inspect.isfunction(len) == False — len is a C-level builtin"
  category: isfunction
  kind: python_call_eq
  function: isfunction
  args: [len]
  expected: false

# ---------------------------------------------------------------------------
# isbuiltin — True for C-level builtins, False for Python functions
# ---------------------------------------------------------------------------

invariant inspect_extra322.isbuiltin.len_true:
  description: "inspect.isbuiltin(len) == True"
  category: isbuiltin
  kind: python_call_eq
  function: isbuiltin
  args: [len]
  expected: true

invariant inspect_extra322.isbuiltin.lambda_false:
  description: "inspect.isbuiltin(lambda: None) == False"
  category: isbuiltin
  kind: python_call_eq
  function: isbuiltin
  args: [lambda: None]
  expected: false

# ---------------------------------------------------------------------------
# isgeneratorfunction — False for plain lambdas
# ---------------------------------------------------------------------------

invariant inspect_extra322.isgeneratorfunction.lambda_false:
  description: "inspect.isgeneratorfunction(lambda: None) == False"
  category: isgeneratorfunction
  kind: python_call_eq
  function: isgeneratorfunction
  args: [lambda: None]
  expected: false
