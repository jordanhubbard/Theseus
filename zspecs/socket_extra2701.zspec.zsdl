spec: socket_extra2701
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket classes documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from: ["CPython source code"]
  notes: ["Wave 627: checks socket.socket, socket.AddressFamily, socket.SocketKind __dict__ for __lshift__, __rshift__, __invert__ presence. AddressFamily and SocketKind are IntFlag subclasses — IntFlag does not define __lshift__, __rshift__, or __invert__ — so all three classes return False for all three dunders."]
  created_at: "2026-04-13"
error_model: python_exceptions

table socket_extra2701.socket_dict_presence:
  description: "socket.socket __dict__ does not contain __lshift__, __rshift__, or __invert__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk2701sc
  columns: [id, function, args, expected]
  rows:
    - ["sk2701sc001", socket.socket.__dict__.__contains__, ["__lshift__"], false]
    - ["sk2701sc002", socket.socket.__dict__.__contains__, ["__rshift__"], false]
    - ["sk2701sc003", socket.socket.__dict__.__contains__, ["__invert__"], false]

