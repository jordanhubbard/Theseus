spec: functools_extra1531
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "Wave 549 theme: comparison operator dict-presence checks via __dict__.__contains__ for functools classes."
    - "functools.partial.__dict__.__contains__('__lt__') == False — partial is a C type; no custom __lt__ in its __dict__. Verified with Python 3.14."
    - "functools.partial.__dict__.__contains__('__eq__') == False — partial does not define __eq__ in its own __dict__; equality falls back to identity. Verified with Python 3.14."
    - "functools.partial.__dict__.__contains__('__hash__') == False — partial does not define __hash__ in its own __dict__. Verified with Python 3.14."
    - "functools.cached_property.__dict__.__contains__ returns False for all comparison dunder methods. Verified with Python 3.14."
    - "functools.singledispatchmethod.__dict__.__contains__ returns False for all comparison dunder methods. Verified with Python 3.14."
    - "functools.partialmethod.__dict__.__contains__ returns False for all comparison dunder methods. Verified with Python 3.14."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial — comparison operator dict-presence checks
#
# Wave 549 theme: partial is a C extension type. Its own __dict__ does not
# contain any of the comparison dunder methods. dict.__contains__ returns
# False for __lt__, __le__, __gt__, __ge__, __ne__, __eq__, __hash__.
# ---------------------------------------------------------------------------

table functools_extra1531.partial_dict_contains:
  description: "functools.partial.__dict__.__contains__ returns False for all comparison dunder methods; wave 549; new to extra1531"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1531pa

  columns: [id, function, args, expected, description]
  rows:
    - ["fu1531pa001",
       "partial.__dict__.__contains__",
       ["__lt__"],
       false,
       "functools.partial.__dict__.__contains__('__lt__') == False — partial is a C extension type (functools._partial); its __dict__ does not define __lt__; wave 549; new to extra1531"]
    - ["fu1531pa002",
       "partial.__dict__.__contains__",
       ["__le__"],
       false,
       "functools.partial.__dict__.__contains__('__le__') == False — partial does not define __le__ in its own class __dict__; wave 549; new to extra1531"]
    - ["fu1531pa003",
       "partial.__dict__.__contains__",
       ["__gt__"],
       false,
       "functools.partial.__dict__.__contains__('__gt__') == False — partial does not define __gt__ in its own class __dict__; wave 549; new to extra1531"]
    - ["fu1531pa004",
       "partial.__dict__.__contains__",
       ["__ge__"],
       false,
       "functools.partial.__dict__.__contains__('__ge__') == False — partial does not define __ge__ in its own class __dict__; wave 549; new to extra1531"]
    - ["fu1531pa005",
       "partial.__dict__.__contains__",
       ["__ne__"],
       false,
       "functools.partial.__dict__.__contains__('__ne__') == False — partial does not define __ne__ in its own class __dict__; wave 549; new to extra1531"]
    - ["fu1531pa006",
       "partial.__dict__.__contains__",
       ["__eq__"],
       false,
       "functools.partial.__dict__.__contains__('__eq__') == False — partial does not define __eq__ in its own class __dict__; wave 549; new to extra1531"]
    - ["fu1531pa007",
       "partial.__dict__.__contains__",
       ["__hash__"],
       false,
       "functools.partial.__dict__.__contains__('__hash__') == False — partial does not define __hash__ in its own class __dict__; wave 549; new to extra1531"]

