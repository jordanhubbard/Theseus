invariant functools_extra1531.partial_no_lt:
  description: "functools.partial.__dict__.__contains__('__lt__') == False — partial C type defines no __lt__; wave 549; new to extra1531"
  kind: python_call_eq
  function: partial.__dict__.__contains__
  args: ["__lt__"]
  expected: false

