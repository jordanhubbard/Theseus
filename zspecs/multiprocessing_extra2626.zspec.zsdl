spec: multiprocessing_extra2626
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "Wave 622 theme: __length_hint__, __missing__, and __reversed__ dict-presence checks."
    - "multiprocessing.Process, multiprocessing.pool.Pool, and multiprocessing.pool.AsyncResult do NOT define __length_hint__, __missing__, or __reversed__ in their own __dict__."
    - "These classes manage subprocesses and async results; they are not iterators, dict subclasses, or sequences."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __length_hint__ dict-presence — multiprocessing classes
#
# multiprocessing.Process, pool.Pool, and pool.AsyncResult do NOT define
# __length_hint__ in their own __dict__.
# ---------------------------------------------------------------------------

table multiprocessing_extra2626.length_hint_checks:
  description: "multiprocessing classes do NOT define __length_hint__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2626
  columns: [id, function, args, expected]
  rows:
    - ["mp2626001", "multiprocessing.Process.__dict__.__contains__",             ["__length_hint__"], false]
    - ["mp2626002", "multiprocessing.pool.Pool.__dict__.__contains__",           ["__length_hint__"], false]
    - ["mp2626003", "multiprocessing.pool.AsyncResult.__dict__.__contains__",    ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# __missing__ dict-presence — multiprocessing classes
#
# multiprocessing.Process, pool.Pool, and pool.AsyncResult do NOT define
# __missing__ in their own __dict__.
# ---------------------------------------------------------------------------

table multiprocessing_extra2626.missing_checks:
  description: "multiprocessing classes do NOT define __missing__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2626
  columns: [id, function, args, expected]
  rows:
    - ["mp2626004", "multiprocessing.Process.__dict__.__contains__",             ["__missing__"], false]
    - ["mp2626005", "multiprocessing.pool.Pool.__dict__.__contains__",           ["__missing__"], false]
    - ["mp2626006", "multiprocessing.pool.AsyncResult.__dict__.__contains__",    ["__missing__"], false]

# ---------------------------------------------------------------------------
# __reversed__ dict-presence — multiprocessing classes
#
# multiprocessing.Process, pool.Pool, and pool.AsyncResult do NOT define
# __reversed__ in their own __dict__.
# ---------------------------------------------------------------------------

table multiprocessing_extra2626.reversed_checks:
  description: "multiprocessing classes do NOT define __reversed__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2626
  columns: [id, function, args, expected]
  rows:
    - ["mp2626007", "multiprocessing.Process.__dict__.__contains__",             ["__reversed__"], false]
    - ["mp2626008", "multiprocessing.pool.Pool.__dict__.__contains__",           ["__reversed__"], false]
    - ["mp2626009", "multiprocessing.pool.AsyncResult.__dict__.__contains__",    ["__reversed__"], false]

# ---------------------------------------------------------------------------
# Cross-check: all three dunders absent from synchronize classes
#
# multiprocessing.synchronize.Lock, Event, Semaphore, Condition, and Barrier
# also do NOT define any of the three wave-622 dunders in their own __dict__.
# This extends the coverage to the full set of multiprocessing primitives.
# ---------------------------------------------------------------------------

table multiprocessing_extra2626.synchronize_absent_checks:
  description: "multiprocessing.synchronize classes do NOT define wave-622 dunders in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2626
  columns: [id, function, args, expected]
  rows:
    - ["mp2626010", "multiprocessing.synchronize.Lock.__dict__.__contains__",      ["__length_hint__"], false]
    - ["mp2626011", "multiprocessing.synchronize.Lock.__dict__.__contains__",      ["__missing__"],     false]
    - ["mp2626012", "multiprocessing.synchronize.Lock.__dict__.__contains__",      ["__reversed__"],    false]
    - ["mp2626013", "multiprocessing.synchronize.Event.__dict__.__contains__",     ["__length_hint__"], false]
    - ["mp2626014", "multiprocessing.synchronize.Event.__dict__.__contains__",     ["__missing__"],     false]
    - ["mp2626015", "multiprocessing.synchronize.Event.__dict__.__contains__",     ["__reversed__"],    false]
    - ["mp2626016", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__length_hint__"], false]
    - ["mp2626017", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__missing__"],     false]
    - ["mp2626018", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__reversed__"],    false]
