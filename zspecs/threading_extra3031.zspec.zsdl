spec: th3031
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 649 (th3031): __missing__, __init_subclass__, __class_getitem__ dict-presence checks for threading types."
    - "None of the threading types define __missing__, __init_subclass__, or __class_getitem__ in their own __dict__."
    - "threading.Lock() returns a _thread.lock instance; type(threading.Lock()) is used to access its __dict__."
    - "threading.RLock() returns a _thread.RLock instance; type(threading.RLock()) is used to access its __dict__."
    - "threading.Timer is a Thread subclass; threading.BoundedSemaphore is a Semaphore subclass."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th3031.missing:
  description: "threading types __missing__ dict-presence checks; wave 649"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th3031
  columns: [id, function, args, expected]
  rows:
    - ["th3031001", operator.contains, [threading.Thread.__dict__,            "__missing__"], false]
    - ["th3031002", operator.contains, [type(threading.Lock()).__dict__,      "__missing__"], false]
    - ["th3031003", operator.contains, [type(threading.RLock()).__dict__,     "__missing__"], false]
    - ["th3031004", operator.contains, [threading.Event.__dict__,             "__missing__"], false]
    - ["th3031005", operator.contains, [threading.Condition.__dict__,         "__missing__"], false]
    - ["th3031006", operator.contains, [threading.Semaphore.__dict__,         "__missing__"], false]
    - ["th3031007", operator.contains, [threading.BoundedSemaphore.__dict__,  "__missing__"], false]
    - ["th3031008", operator.contains, [threading.Timer.__dict__,             "__missing__"], false]
    - ["th3031009", operator.contains, [threading.Barrier.__dict__,           "__missing__"], false]
    - ["th3031010", operator.contains, [threading.local.__dict__,             "__missing__"], false]

