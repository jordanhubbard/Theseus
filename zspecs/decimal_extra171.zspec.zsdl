spec: decimal_extra171
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Context method identity — __name__ values for add, subtract, multiply, divide, power, sqrt; and __class__.__name__ for DefaultContext, BasicContext, ExtendedContext."
    - "decimal.Context.add.__name__ == 'add' (len=3)."
    - "decimal.Context.subtract.__name__ == 'subtract' (len=8)."
    - "decimal.Context.multiply.__name__ == 'multiply' (len=8; same as subtract: 'multiply' (8) == 'subtract' (8))."
    - "decimal.Context.divide.__name__ == 'divide' (len=6)."
    - "decimal.Context.power.__name__ == 'power' (len=5)."
    - "decimal.Context.sqrt.__name__ == 'sqrt' (len=4)."
    - "decimal.DefaultContext.__class__.__name__ == 'Context'."
    - "decimal.BasicContext.__class__.__name__ == 'Context'."
    - "decimal.ExtendedContext.__class__.__name__ == 'Context'."
    - "Name length ordering: add (3) < sqrt (4) < power (5) < divide (6) < subtract=multiply (8)."
    - "subtract (8) == multiply (8): two-way tie at 8; both are the maximum method name lengths in this spec."
    - "DefaultContext, BasicContext, and ExtendedContext are all instances of Context: __class__.__name__ == 'Context' for all three."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Context arithmetic method names — add (3), sqrt (4), power (5)
# Context.add.__name__ == 'add' (len=3; minimum)
# Context.sqrt.__name__ == 'sqrt' (len=4)
# Context.power.__name__ == 'power' (len=5)
# ---------------------------------------------------------------------------

table decimal_extra171.short_method_names:
  description: "decimal.Context short method names: add (len=3; minimum), sqrt (len=4), power (len=5); add (3) < sqrt (4) < power (5): a strict ascending sequence from the minimum method name length"
  kind: python_call_eq
  category: identity
  id_prefix: decimalctx171

  columns: [id, function, args, expected, description]
  rows:
    - [add_name,      Context.add.__name__.__eq__,   ["add"],   true, "decimal.Context.add.__name__ == 'add' — 'add' has 3 characters; add (3) is the minimum method name length in this spec; add (3) < sqrt (4) by 1; add (3) < subtract=multiply (8) by 5; Context.add(a, b) returns the sum of a and b within the context precision; confirmed Python 3.14.3 macOS"]
    - [add_name_len,  Context.add.__name__.__len__,  [],        3,    "decimal.Context.add.__name__.__len__() == 3 — 'add' has 3 characters; add (3) is the global minimum in the method name-length ordering: add (3) < sqrt (4) < power (5) < divide (6) < subtract=multiply (8); add (3) < subtract (8) by 5; confirmed Python 3.14.3 macOS"]
    - [sqrt_name,     Context.sqrt.__name__.__eq__,  ["sqrt"],  true, "decimal.Context.sqrt.__name__ == 'sqrt' — 'sqrt' has 4 characters: 's' (1) + 'qrt' (3) = 4; sqrt (4) > add (3) by 1; sqrt (4) < power (5) by 1; Context.sqrt(a) returns the square root of a within the context precision; confirmed Python 3.14.3 macOS"]
    - [sqrt_name_len, Context.sqrt.__name__.__len__, [],        4,    "decimal.Context.sqrt.__name__.__len__() == 4 — 'sqrt' has 4 characters; sqrt (4) > add (3) by 1; sqrt (4) < power (5) by 1; sqrt (4) < divide (6) by 2; sqrt (4) < subtract=multiply (8) by 4; confirmed Python 3.14.3 macOS"]
    - [power_name,    Context.power.__name__.__eq__, ["power"], true, "decimal.Context.power.__name__ == 'power' — 'power' has 5 characters; power (5) > sqrt (4) by 1; power (5) > add (3) by 2; power (5) < divide (6) by 1; Context.power(a, b) returns a raised to the power b within the context; confirmed Python 3.14.3 macOS"]
    - [power_name_len,Context.power.__name__.__len__,[],        5,    "decimal.Context.power.__name__.__len__() == 5 — 'power' has 5 characters; power (5) is between sqrt (4) and divide (6) in the name-length ordering; power (5) > add (3) by 2; power (5) < subtract=multiply (8) by 3; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# decimal.Context arithmetic method names — divide (6), subtract (8), multiply (8)
# Context.divide.__name__ == 'divide' (len=6)
# Context.subtract.__name__ == 'subtract' (len=8)
# Context.multiply.__name__ == 'multiply' (len=8; same as subtract)
# ---------------------------------------------------------------------------

table decimal_extra171.long_method_names:
  description: "decimal.Context longer method names: divide (len=6), subtract (len=8), multiply (len=8); subtract (8) == multiply (8): two-way tie at the maximum name length (8); divide (6) < subtract=multiply (8) by 2"
  kind: python_call_eq
  category: identity
  id_prefix: decimalctx171

  columns: [id, function, args, expected, description]
  rows:
    - [divide_name,      Context.divide.__name__.__eq__,     ["divide"],   true, "decimal.Context.divide.__name__ == 'divide' — 'divide' has 6 characters; divide (6) > power (5) by 1; divide (6) < subtract=multiply (8) by 2; Context.divide(a, b) returns the quotient of a divided by b within the context; confirmed Python 3.14.3 macOS"]
    - [divide_name_len,  Context.divide.__name__.__len__,    [],           6,    "decimal.Context.divide.__name__.__len__() == 6 — 'divide' has 6 characters; divide (6) > power (5) by 1; divide (6) < subtract=multiply (8) by 2; divide sits between power (5) and the two maximum-length methods (8) in the name-length ordering; confirmed Python 3.14.3 macOS"]
    - [sub_name,         Context.subtract.__name__.__eq__,   ["subtract"], true, "decimal.Context.subtract.__name__ == 'subtract' — 'subtract' has 8 characters: 'sub' (3) + 'tract' (5) = 8; subtract (8) == multiply (8): a two-way tie at the maximum name length in this spec; subtract (8) > divide (6) by 2; subtract (8) > add (3) by 5; Context.subtract(a, b) returns the difference of a minus b within the context; confirmed Python 3.14.3 macOS"]
    - [sub_name_len,     Context.subtract.__name__.__len__,  [],           8,    "decimal.Context.subtract.__name__.__len__() == 8 — 'subtract' has 8 characters; subtract (8) == multiply (8): both are the maximum method name lengths in this spec; subtract (8) > divide (6) by 2; subtract (8) > power (5) by 3; subtract (8) > sqrt (4) by 4; subtract (8) > add (3) by 5; confirmed Python 3.14.3 macOS"]
    - [mul_name,         Context.multiply.__name__.__eq__,   ["multiply"], true, "decimal.Context.multiply.__name__ == 'multiply' — 'multiply' has 8 characters: 'multi' (5) + 'ply' (3) = 8; multiply (8) == subtract (8): a two-way tie at 8; multiply (8) > divide (6) by 2; multiply (8) > add (3) by 5; Context.multiply(a, b) returns the product of a and b within the context; confirmed Python 3.14.3 macOS"]
    - [mul_name_len,     Context.multiply.__name__.__len__,  [],           8,    "decimal.Context.multiply.__name__.__len__() == 8 — 'multiply' has 8 characters; multiply (8) == subtract (8): both tie at the maximum name length (8) in this spec; multiply (8) > divide (6) by 2; multiply (8) > sqrt (4) by 4; multiply (8) > add (3) by 5; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# decimal pre-defined Context instances: DefaultContext, BasicContext, ExtendedContext
# All three have __class__.__name__ == 'Context'
# ---------------------------------------------------------------------------

table decimal_extra171.predefined_contexts:
  description: "decimal pre-defined Context instances: DefaultContext.__class__.__name__=='Context'; BasicContext.__class__.__name__=='Context'; ExtendedContext.__class__.__name__=='Context'; all three named contexts are instances of decimal.Context"
  kind: python_call_eq
  category: identity
  id_prefix: decimalctx171

  columns: [id, function, args, expected, description]
  rows:
    - [default_ctx_class,   DefaultContext.__class__.__name__.__eq__,  ["Context"], true, "decimal.DefaultContext.__class__.__name__ == 'Context' — DefaultContext is the default rounding context; __class__.__name__ == 'Context' confirms it is an instance of decimal.Context; DefaultContext (14 chars) is the longest pre-defined context name: 'Default' (7) + 'Context' (7) = 14; DefaultContext provides the default rounding mode (ROUND_HALF_EVEN) and precision (28); confirmed Python 3.14.3 macOS"]
    - [basic_ctx_class,     BasicContext.__class__.__name__.__eq__,    ["Context"], true, "decimal.BasicContext.__class__.__name__ == 'Context' — BasicContext is a pre-defined context for beginners; __class__.__name__ == 'Context' confirms it is an instance of decimal.Context; 'BasicContext' has 12 characters: 'Basic' (5) + 'Context' (7) = 12; BasicContext (12) < DefaultContext (14) by 2 in name length; BasicContext (12) > ExtendedContext (15) — no: 'ExtendedContext' has 15 chars > 'BasicContext' (12); confirmed Python 3.14.3 macOS"]
    - [extended_ctx_class,  ExtendedContext.__class__.__name__.__eq__, ["Context"], true, "decimal.ExtendedContext.__class__.__name__ == 'Context' — ExtendedContext is a pre-defined context aligned with the General Decimal Arithmetic specification; __class__.__name__ == 'Context' confirms it is an instance of decimal.Context; 'ExtendedContext' has 15 characters: 'Extended' (8) + 'Context' (7) = 15; ExtendedContext (15) > DefaultContext (14) > BasicContext (12) in name length; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra171.Context_add_name_is_add:
  description: "decimal.Context.add.__name__ == 'add' — 'add' has 3 characters; add (3) is the minimum method name length in this spec; add (3) < sqrt (4) < power (5) < divide (6) < subtract=multiply (8): add is the global minimum; Context.add(a, b) computes the sum within the context; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Context.add.__name__.__eq__
  args: ["add"]
  expected: true

invariant decimal_extra171.Context_subtract_name_is_subtract:
  description: "decimal.Context.subtract.__name__ == 'subtract' — 'subtract' has 8 characters: 'sub' (3) + 'tract' (5) = 8; subtract (8) == multiply (8): two-way tie at the maximum name length in this spec; subtract (8) > add (3) by 5; Context.subtract(a, b) computes the difference within the context; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Context.subtract.__name__.__eq__
  args: ["subtract"]
  expected: true

invariant decimal_extra171.Context_multiply_name_is_multiply:
  description: "decimal.Context.multiply.__name__ == 'multiply' — 'multiply' has 8 characters: 'multi' (5) + 'ply' (3) = 8; multiply (8) == subtract (8): the two maximum-length method names in this spec; multiply (8) > divide (6) by 2; Context.multiply(a, b) computes the product within the context; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Context.multiply.__name__.__eq__
  args: ["multiply"]
  expected: true

invariant decimal_extra171.Context_divide_name_len_6:
  description: "decimal.Context.divide.__name__.__len__() == 6 — 'divide' has 6 characters; divide (6) > power (5) by 1; divide (6) < subtract=multiply (8) by 2; divide sits between power (5) and the maximum-length methods (8) in the name-length ordering; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Context.divide.__name__.__len__
  args: []
  expected: 6

invariant decimal_extra171.DefaultContext_is_Context:
  description: "decimal.DefaultContext.__class__.__name__ == 'Context' — DefaultContext is the pre-defined default rounding context; __class__.__name__ == 'Context' confirms it is an instance of decimal.Context; DefaultContext, BasicContext, and ExtendedContext all share __class__.__name__ == 'Context'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: DefaultContext.__class__.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra171.BasicContext_is_Context:
  description: "decimal.BasicContext.__class__.__name__ == 'Context' — BasicContext is a pre-defined context for beginners with traps enabled; __class__.__name__ == 'Context' confirms it is an instance of decimal.Context; BasicContext (12 chars) < DefaultContext (14 chars) < ExtendedContext (15 chars) in instance name length; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BasicContext.__class__.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra171.ExtendedContext_is_Context:
  description: "decimal.ExtendedContext.__class__.__name__ == 'Context' — ExtendedContext is the pre-defined context aligned with the General Decimal Arithmetic specification; __class__.__name__ == 'Context' confirms it is an instance of decimal.Context; ExtendedContext (15 chars) is the longest of the three pre-defined context instance names; all three (DefaultContext, BasicContext, ExtendedContext) share __class__.__name__ == 'Context'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: ExtendedContext.__class__.__name__.__eq__
  args: ["Context"]
  expected: true

