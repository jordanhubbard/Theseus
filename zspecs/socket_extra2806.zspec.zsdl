spec: socket_extra2806
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
    - "socket_extra2791.zspec.zsdl — covers __iand__, __ior__, and __ixor__ absence for socket.socket, AddressFamily, SocketKind."
    - "socket_extra2776.zspec.zsdl — covers __isub__, __imul__, and __itruediv__ absence for socket.socket, AddressFamily, SocketKind."
    - "decimal_extra204.zspec.zsdl — covers decimal.Decimal __dict__ membership for arithmetic dunders; same dict-presence pattern."
  notes:
    - "socket.socket.__dict__.__contains__('__ilshift__') == False — socket.socket is a network I/O type; it defines no in-place left-shift operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.socket.__dict__.__contains__('__irshift__') == False — socket.socket defines no in-place right-shift operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.socket.__dict__.__contains__('__ipow__') == False — socket.socket defines no in-place power operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.AddressFamily.__dict__.__contains__('__ilshift__') == False — AddressFamily is an IntEnum subclass; it does not add in-place left-shift to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.AddressFamily.__dict__.__contains__('__irshift__') == False — AddressFamily does not add in-place right-shift to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.AddressFamily.__dict__.__contains__('__ipow__') == False — AddressFamily does not add in-place power to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.SocketKind.__dict__.__contains__('__ilshift__') == False — SocketKind is an IntEnum subclass; it does not add in-place left-shift to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.SocketKind.__dict__.__contains__('__irshift__') == False — SocketKind does not add in-place right-shift to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.SocketKind.__dict__.__contains__('__ipow__') == False — SocketKind does not add in-place power to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: socket.socket.__dict__ — __ilshift__, __irshift__, __ipow__ absence
# socket.socket is the main socket class; it wraps a file descriptor and
# provides network I/O methods (connect, bind, send, recv, etc.). In-place
# shift and power operators (<<=, >>=, **=) have no meaning for a network socket.
# ---------------------------------------------------------------------------

table socket_extra2806.socket_dict_ilshift_irshift_ipow:
  description: "socket.socket.__dict__ does not contain __ilshift__, __irshift__, or __ipow__ — socket.socket is a network I/O type with no in-place shift or power operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: sk2806

  columns: [id, function, args, expected]
  rows:
    - ["sk2806-sock-ilshift", socket.socket.__dict__.__contains__, ["__ilshift__"], false]
    - ["sk2806-sock-irshift", socket.socket.__dict__.__contains__, ["__irshift__"], false]
    - ["sk2806-sock-ipow",    socket.socket.__dict__.__contains__, ["__ipow__"],    false]

# ---------------------------------------------------------------------------
# Table 2: socket.AddressFamily.__dict__ — __ilshift__, __irshift__, __ipow__ absence
# AddressFamily is an IntEnum subclass (AF_INET=2, AF_INET6=10, AF_UNIX=1, etc.).
# It inherits integer arithmetic from int/IntEnum but does not add in-place
# shift or power operators to its own __dict__ (checked with
# 'in AddressFamily.__dict__', not MRO lookup).
# ---------------------------------------------------------------------------

table socket_extra2806.addressfamily_dict_ilshift_irshift_ipow:
  description: "socket.AddressFamily.__dict__ does not contain __ilshift__, __irshift__, or __ipow__ — AddressFamily (IntEnum subclass) adds no new in-place shift or power operators to its own __dict__; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: sk2806

  columns: [id, function, args, expected]
  rows:
    - ["sk2806-af-ilshift", socket.AddressFamily.__dict__.__contains__, ["__ilshift__"], false]
    - ["sk2806-af-irshift", socket.AddressFamily.__dict__.__contains__, ["__irshift__"], false]
    - ["sk2806-af-ipow",    socket.AddressFamily.__dict__.__contains__, ["__ipow__"],    false]

# ---------------------------------------------------------------------------
# Table 3: socket.SocketKind.__dict__ — __ilshift__, __irshift__, __ipow__ absence
# SocketKind is an IntEnum subclass (SOCK_STREAM=1, SOCK_DGRAM=2, etc.).
# Like AddressFamily, it does not add in-place shift or power operators to its
# own __dict__.
# ---------------------------------------------------------------------------

table socket_extra2806.socketkind_dict_ilshift_irshift_ipow:
  description: "socket.SocketKind.__dict__ does not contain __ilshift__, __irshift__, or __ipow__ — SocketKind (IntEnum subclass) adds no new in-place shift or power operators to its own __dict__; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: sk2806

  columns: [id, function, args, expected]
  rows:
    - ["sk2806-sk-ilshift", socket.SocketKind.__dict__.__contains__, ["__ilshift__"], false]
    - ["sk2806-sk-irshift", socket.SocketKind.__dict__.__contains__, ["__irshift__"], false]
    - ["sk2806-sk-ipow",    socket.SocketKind.__dict__.__contains__, ["__ipow__"],    false]

# ---------------------------------------------------------------------------
# Table 4: cross-type summary — socket, AddressFamily, SocketKind all absent
# ---------------------------------------------------------------------------

table socket_extra2806.all_types_all_dunders_absent:
  description: "socket.socket, socket.AddressFamily, and socket.SocketKind all lack __ilshift__, __irshift__, and __ipow__ in __dict__ — no socket type defines these in-place shift or power operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: sk2806

  columns: [id, function, args, expected]
  rows:
    - ["sk2806-x-sock-ilshift", socket.socket.__dict__.__contains__,        ["__ilshift__"], false]
    - ["sk2806-x-sock-irshift", socket.socket.__dict__.__contains__,        ["__irshift__"], false]
    - ["sk2806-x-sock-ipow",    socket.socket.__dict__.__contains__,        ["__ipow__"],    false]
    - ["sk2806-x-af-ilshift",   socket.AddressFamily.__dict__.__contains__, ["__ilshift__"], false]
    - ["sk2806-x-af-irshift",   socket.AddressFamily.__dict__.__contains__, ["__irshift__"], false]
    - ["sk2806-x-af-ipow",      socket.AddressFamily.__dict__.__contains__, ["__ipow__"],    false]
    - ["sk2806-x-sk-ilshift",   socket.SocketKind.__dict__.__contains__,   ["__ilshift__"], false]
    - ["sk2806-x-sk-irshift",   socket.SocketKind.__dict__.__contains__,   ["__irshift__"], false]
    - ["sk2806-x-sk-ipow",      socket.SocketKind.__dict__.__contains__,   ["__ipow__"],    false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant socket_extra2806.socket_no_ilshift:
  description: "socket.socket.__dict__.__contains__('__ilshift__') == False — socket.socket is a network I/O object; it defines no <<= operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: socket.socket.__dict__.__contains__
  args: ["__ilshift__"]
  expected: false

invariant socket_extra2806.socket_no_irshift:
  description: "socket.socket.__dict__.__contains__('__irshift__') == False — socket.socket defines no >>= operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
