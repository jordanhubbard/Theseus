spec: multiprocessing_extra267
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html#managers

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html#managers — Python multiprocessing.managers documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/managers.py"
  notes:
    - "This spec covers: multiprocessing.managers DictProxy, ListProxy, and NamespaceProxy class identity. NEW in extra267: multiprocessing.managers.DictProxy.__module__=='multiprocessing.managers'; multiprocessing.managers.DictProxy.__name__=='DictProxy'; multiprocessing.managers.DictProxy.__bases__[0].__name__=='_BaseDictProxy'; multiprocessing.managers.DictProxy.__mro__.__len__()==4 ([DictProxy, _BaseDictProxy, BaseProxy, object]); multiprocessing.managers.ListProxy.__module__=='multiprocessing.managers'; multiprocessing.managers.ListProxy.__bases__[0].__name__=='BaseListProxy'; multiprocessing.managers.ListProxy.__mro__.__len__()==4 ([ListProxy, BaseListProxy, BaseProxy, object]); multiprocessing.managers.NamespaceProxy.__module__=='multiprocessing.managers'; multiprocessing.managers.NamespaceProxy.__bases__[0].__name__=='BaseProxy'; multiprocessing.managers.NamespaceProxy.__mro__.__len__()==3 ([NamespaceProxy, BaseProxy, object]); multiprocessing.managers.BaseProxy.__module__=='multiprocessing.managers'; BaseProxy.__mro__.__len__()==2. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "multiprocessing.managers.DictProxy.__bases__[0].__name__ == '_BaseDictProxy'. DictProxy extends _BaseDictProxy (underscore-prefixed internal class) which itself extends BaseProxy; the full MRO is [DictProxy, _BaseDictProxy, BaseProxy, object] (length=4). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "multiprocessing.managers.ListProxy.__bases__[0].__name__ == 'BaseListProxy'. ListProxy extends BaseListProxy (without underscore, unlike _BaseDictProxy) which extends BaseProxy; the full MRO is [ListProxy, BaseListProxy, BaseProxy, object] (length=4). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "multiprocessing.managers.NamespaceProxy.__mro__.__len__() == 3. NamespaceProxy extends BaseProxy directly (no intermediate class), giving MRO [NamespaceProxy, BaseProxy, object] (length=3), shorter than DictProxy and ListProxy (both length=4). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All three proxies share __module__ == 'multiprocessing.managers' (len=24: 'multiprocessing'=15+'.managers'=9). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.managers DictProxy and ListProxy class identity — extra267
#
# multiprocessing.managers.DictProxy.__module__             == 'multiprocessing.managers'
# multiprocessing.managers.DictProxy.__name__               == 'DictProxy'
# multiprocessing.managers.DictProxy.__bases__[0].__name__  == '_BaseDictProxy'
# multiprocessing.managers.DictProxy.__mro__.__len__()      == 4
# multiprocessing.managers.ListProxy.__module__             == 'multiprocessing.managers'
# multiprocessing.managers.ListProxy.__name__               == 'ListProxy'
# multiprocessing.managers.ListProxy.__bases__[0].__name__  == 'BaseListProxy'
# multiprocessing.managers.ListProxy.__mro__.__len__()      == 4
# ---------------------------------------------------------------------------

table multiprocessing_extra267.mp_managers_dict_list_proxy_identity:
  description: "multiprocessing.managers DictProxy and ListProxy class identity checks in mpmgrproxy267 namespace — DictProxy and ListProxy are manager proxy classes defined in Lib/multiprocessing/managers.py; both share __module__ 'multiprocessing.managers' (len=24: 'multiprocessing'=15+'.managers'=9); DictProxy.__name__.__eq__('DictProxy')==True; DictProxy.__module__.__eq__('multiprocessing.managers')==True; DictProxy.__bases__[0].__name__.__eq__('_BaseDictProxy')==True (DictProxy inherits from internal _BaseDictProxy which inherits from BaseProxy); DictProxy.__mro__.__len__()==4 ([DictProxy, _BaseDictProxy, BaseProxy, object]); DictProxy.__qualname__.__eq__('DictProxy')==True; ListProxy.__name__.__eq__('ListProxy')==True; ListProxy.__module__.__eq__('multiprocessing.managers')==True (same module); ListProxy.__bases__[0].__name__.__eq__('BaseListProxy')==True (ListProxy inherits from BaseListProxy, not _BaseDictProxy); ListProxy.__mro__.__len__()==4 ([ListProxy, BaseListProxy, BaseProxy, object]); ListProxy.__qualname__.__eq__('ListProxy')==True; both _BaseDictProxy and BaseListProxy are intermediate classes that extend BaseProxy; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmgrproxy267

  columns: [id, function, args, expected, description]
  rows:
    - [dp_name_eq,    multiprocessing.managers.DictProxy.__name__.__eq__,                   ["DictProxy"],                    true, "multiprocessing.managers.DictProxy.__name__ == 'DictProxy'; verified with Python 3.14.3"]
    - [dp_mod_eq,     multiprocessing.managers.DictProxy.__module__.__eq__,                 ["multiprocessing.managers"],     true, "multiprocessing.managers.DictProxy.__module__ == 'multiprocessing.managers' (len=24); verified with Python 3.14.3"]
    - [dp_base0_eq,   "multiprocessing.managers.DictProxy.__bases__[0].__name__.__eq__",    ["_BaseDictProxy"],               true, "multiprocessing.managers.DictProxy.__bases__[0].__name__ == '_BaseDictProxy'; verified with Python 3.14.3"]
    - [dp_mro_len,    multiprocessing.managers.DictProxy.__mro__.__len__,                   [],                               4,    "multiprocessing.managers.DictProxy.__mro__.__len__() == 4 — [DictProxy, _BaseDictProxy, BaseProxy, object]; verified with Python 3.14.3"]
    - [dp_qn_eq,      multiprocessing.managers.DictProxy.__qualname__.__eq__,               ["DictProxy"],                    true, "multiprocessing.managers.DictProxy.__qualname__ == 'DictProxy' (module-level class); verified with Python 3.14.3"]
    - [lp_name_eq,    multiprocessing.managers.ListProxy.__name__.__eq__,                   ["ListProxy"],                    true, "multiprocessing.managers.ListProxy.__name__ == 'ListProxy'; verified with Python 3.14.3"]
    - [lp_mod_eq,     multiprocessing.managers.ListProxy.__module__.__eq__,                 ["multiprocessing.managers"],     true, "multiprocessing.managers.ListProxy.__module__ == 'multiprocessing.managers' (same as DictProxy); verified with Python 3.14.3"]
    - [lp_base0_eq,   "multiprocessing.managers.ListProxy.__bases__[0].__name__.__eq__",    ["BaseListProxy"],                true, "multiprocessing.managers.ListProxy.__bases__[0].__name__ == 'BaseListProxy'; verified with Python 3.14.3"]
    - [lp_mro_len,    multiprocessing.managers.ListProxy.__mro__.__len__,                   [],                               4,    "multiprocessing.managers.ListProxy.__mro__.__len__() == 4 — [ListProxy, BaseListProxy, BaseProxy, object]; verified with Python 3.14.3"]
    - [lp_qn_eq,      multiprocessing.managers.ListProxy.__qualname__.__eq__,               ["ListProxy"],                    true, "multiprocessing.managers.ListProxy.__qualname__ == 'ListProxy' (module-level class); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.managers NamespaceProxy and BaseProxy class identity — extra267
#
# multiprocessing.managers.NamespaceProxy.__module__             == 'multiprocessing.managers'
# multiprocessing.managers.NamespaceProxy.__name__               == 'NamespaceProxy'
# multiprocessing.managers.NamespaceProxy.__bases__[0].__name__  == 'BaseProxy'
# multiprocessing.managers.NamespaceProxy.__mro__.__len__()      == 3
# multiprocessing.managers.BaseProxy.__module__                  == 'multiprocessing.managers'
# multiprocessing.managers.BaseProxy.__bases__[0].__name__       == 'object'
# multiprocessing.managers.BaseProxy.__mro__.__len__()           == 2
# ---------------------------------------------------------------------------

table multiprocessing_extra267.mp_managers_namespace_base_proxy_identity:
  description: "multiprocessing.managers NamespaceProxy and BaseProxy class identity checks in mpmgrproxy267a namespace — NamespaceProxy inherits directly from BaseProxy (no intermediate class), unlike DictProxy (_BaseDictProxy→BaseProxy) and ListProxy (BaseListProxy→BaseProxy); NamespaceProxy.__name__.__eq__('NamespaceProxy')==True; NamespaceProxy.__module__.__eq__('multiprocessing.managers')==True (shared with DictProxy, ListProxy, and BaseProxy); NamespaceProxy.__bases__[0].__name__.__eq__('BaseProxy')==True; NamespaceProxy.__mro__.__len__()==3 ([NamespaceProxy, BaseProxy, object]); NamespaceProxy.__qualname__.__eq__('NamespaceProxy')==True; BaseProxy is the root proxy class in multiprocessing.managers; BaseProxy.__name__.__eq__('BaseProxy')==True; BaseProxy.__module__.__eq__('multiprocessing.managers')==True; BaseProxy.__bases__[0].__name__.__eq__('object')==True (direct subclass of object, root of proxy hierarchy); BaseProxy.__mro__.__len__()==2 ([BaseProxy, object]); compare MRO depths: BaseProxy=2, NamespaceProxy=3, DictProxy=4, ListProxy=4; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmgrproxy267a

  columns: [id, function, args, expected, description]
  rows:
    - [np_name_eq,    multiprocessing.managers.NamespaceProxy.__name__.__eq__,                  ["NamespaceProxy"],             true, "multiprocessing.managers.NamespaceProxy.__name__ == 'NamespaceProxy'; verified with Python 3.14.3"]
    - [np_mod_eq,     multiprocessing.managers.NamespaceProxy.__module__.__eq__,                ["multiprocessing.managers"],   true, "multiprocessing.managers.NamespaceProxy.__module__ == 'multiprocessing.managers'; verified with Python 3.14.3"]
    - [np_base0_eq,   "multiprocessing.managers.NamespaceProxy.__bases__[0].__name__.__eq__",   ["BaseProxy"],                  true, "multiprocessing.managers.NamespaceProxy.__bases__[0].__name__ == 'BaseProxy' (direct subclass of BaseProxy, no intermediate); verified with Python 3.14.3"]
    - [np_mro_len,    multiprocessing.managers.NamespaceProxy.__mro__.__len__,                  [],                             3,    "multiprocessing.managers.NamespaceProxy.__mro__.__len__() == 3 — [NamespaceProxy, BaseProxy, object]; verified with Python 3.14.3"]
    - [np_qn_eq,      multiprocessing.managers.NamespaceProxy.__qualname__.__eq__,              ["NamespaceProxy"],             true, "multiprocessing.managers.NamespaceProxy.__qualname__ == 'NamespaceProxy'; verified with Python 3.14.3"]
    - [bp_name_eq,    multiprocessing.managers.BaseProxy.__name__.__eq__,                       ["BaseProxy"],                  true, "multiprocessing.managers.BaseProxy.__name__ == 'BaseProxy'; verified with Python 3.14.3"]
    - [bp_mod_eq,     multiprocessing.managers.BaseProxy.__module__.__eq__,                     ["multiprocessing.managers"],   true, "multiprocessing.managers.BaseProxy.__module__ == 'multiprocessing.managers'; verified with Python 3.14.3"]
    - [bp_base0_eq,   "multiprocessing.managers.BaseProxy.__bases__[0].__name__.__eq__",        ["object"],                     true, "multiprocessing.managers.BaseProxy.__bases__[0].__name__ == 'object' — root proxy, direct subclass; verified with Python 3.14.3"]
    - [bp_mro_len,    multiprocessing.managers.BaseProxy.__mro__.__len__,                       [],                             2,    "multiprocessing.managers.BaseProxy.__mro__.__len__() == 2 — [BaseProxy, object]; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra267
# ---------------------------------------------------------------------------

invariant multiprocessing_extra267.DictProxy_module_is_multiprocessing_managers:
  description: "multiprocessing.managers.DictProxy.__module__.__eq__('multiprocessing.managers') returns True — DictProxy is defined in Lib/multiprocessing/managers.py; its __module__ is 'multiprocessing.managers' (len=24: 'multiprocessing'=15+'.managers'=9); DictProxy, ListProxy, NamespaceProxy, and BaseProxy all share this __module__; DictProxy inherits from _BaseDictProxy (underscore-prefixed internal class) which inherits from BaseProxy; DictProxy's full MRO is [DictProxy, _BaseDictProxy, BaseProxy, object] (length=4); _BaseDictProxy.__module__ is also 'multiprocessing.managers'; DictProxy provides a dict-like proxy interface for sharing dict objects across processes via a Manager; NEW in extra267: first standalone DictProxy.__module__ invariant in mpmgrproxy267 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.DictProxy.__module__.__eq__
  args: ["multiprocessing.managers"]
  expected: true

invariant multiprocessing_extra267.ListProxy_module_is_multiprocessing_managers:
  description: "multiprocessing.managers.ListProxy.__module__.__eq__('multiprocessing.managers') returns True — ListProxy is defined in Lib/multiprocessing/managers.py; its __module__ is 'multiprocessing.managers' (len=24, same as DictProxy); ListProxy inherits from BaseListProxy (no underscore prefix, unlike DictProxy's _BaseDictProxy) which inherits from BaseProxy; ListProxy's full MRO is [ListProxy, BaseListProxy, BaseProxy, object] (length=4, same as DictProxy's length); BaseListProxy.__module__ is 'multiprocessing.managers'; ListProxy provides a list-like proxy for sharing list objects across processes; the naming asymmetry between _BaseDictProxy (underscore) and BaseListProxy (no underscore) is a CPython implementation detail; NEW in extra267: first standalone ListProxy.__module__ invariant in mpmgrproxy267 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.ListProxy.__module__.__eq__
  args: ["multiprocessing.managers"]
  expected: true

invariant multiprocessing_extra267.NamespaceProxy_module_is_multiprocessing_managers:
  description: "multiprocessing.managers.NamespaceProxy.__module__.__eq__('multiprocessing.managers') returns True — NamespaceProxy is defined in Lib/multiprocessing/managers.py; its __module__ is 'multiprocessing.managers' (len=24, shared with DictProxy, ListProxy, and BaseProxy); NamespaceProxy.__bases__[0].__name__ is 'BaseProxy' (direct subclass of BaseProxy, no intermediate class); NamespaceProxy.__mro__.__len__() is 3 ([NamespaceProxy, BaseProxy, object]), shorter than DictProxy and ListProxy (both 4); NamespaceProxy provides attribute-based access to a shared namespace object; it differs from DictProxy and ListProxy by having MRO depth 3 instead of 4, reflecting its simpler single-level inheritance from BaseProxy; NEW in extra267: first standalone NamespaceProxy.__module__ invariant in mpmgrproxy267 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.NamespaceProxy.__module__.__eq__
  args: ["multiprocessing.managers"]
  expected: true

invariant multiprocessing_extra267.DictProxy_mro_len_is_4:
  description: "multiprocessing.managers.DictProxy.__mro__.__len__() == 4 — DictProxy's MRO is [DictProxy, _BaseDictProxy, BaseProxy, object] (length=4); the 4-element chain arises from DictProxy inheriting from _BaseDictProxy which in turn inherits from BaseProxy; compare MRO depths in this spec: BaseProxy=2, NamespaceProxy=3, DictProxy=4, ListProxy=4; DictProxy and ListProxy both have depth 4 because they each have one intermediate class (_BaseDictProxy and BaseListProxy respectively); the length-4 chain is one of the deepest manager proxy hierarchies; _BaseDictProxy.__module__ is 'multiprocessing.managers'; DictProxy.__bases__[0].__name__ is '_BaseDictProxy' (underscore prefix signals internal implementation class); NEW in extra267: first standalone DictProxy MRO length invariant in mpmgrproxy267 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.DictProxy.__mro__.__len__
  args: []
  expected: 4

invariant multiprocessing_extra267.NamespaceProxy_base_is_BaseProxy:
  description: "multiprocessing.managers.NamespaceProxy.__bases__[0].__name__.__eq__('BaseProxy') returns True — NamespaceProxy inherits from BaseProxy directly as its sole direct base; this makes NamespaceProxy simpler than DictProxy (which inherits from _BaseDictProxy) and ListProxy (which inherits from BaseListProxy); NamespaceProxy.__mro__.__len__() is 3 ([NamespaceProxy, BaseProxy, object]); BaseProxy is the root of the proxy hierarchy: BaseProxy.__bases__[0].__name__ is 'object' and BaseProxy.__mro__.__len__() is 2; BaseProxy.__module__ is 'multiprocessing.managers'; NamespaceProxy.__qualname__ is 'NamespaceProxy'; NamespaceProxy.__name__.__len__() is 14 ('NamespaceProxy'=14); NEW in extra267: first standalone NamespaceProxy base class invariant in mpmgrproxy267 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.managers.NamespaceProxy.__bases__[0].__name__.__eq__"
  args: ["BaseProxy"]
  expected: true

invariant multiprocessing_extra267.BaseProxy_mro_len_is_2:
  description: "multiprocessing.managers.BaseProxy.__mro__.__len__() == 2 — BaseProxy's MRO is [BaseProxy, object] (length=2); BaseProxy is the root of all manager proxy classes; its direct subclass of object with no intermediate base gives the minimal 2-element MRO; all manager proxies ultimately inherit from BaseProxy: NamespaceProxy (depth=3), DictProxy (depth=4), ListProxy (depth=4); BaseProxy.__module__ is 'multiprocessing.managers'; BaseProxy.__bases__[0].__name__ is 'object'; BaseProxy defines the core RPC-style proxy mechanism that forwards method calls to the managed object in the manager process; NEW in extra267: first standalone BaseProxy MRO length invariant in mpmgrproxy267 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.BaseProxy.__mro__.__len__
  args: []
  expected: 2
