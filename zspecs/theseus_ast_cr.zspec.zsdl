spec: theseus_ast_cr
version: ">=3.8"
backend: python_cleanroom(theseus_ast_cr)
blocks: ast

docs: https://docs.python.org/3/library/ast.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/ast.html"
  not_derived_from:
    - "CPython source: Lib/ast.py"
  notes:
    - "Clean-room ast module. Do NOT import ast."

error_model: python_exceptions

invariant theseus_ast_cr.ast2_parse:
  description: "parse() returns an AST Module node for a simple expression"
  category: behavior
  kind: python_call_eq
  function: ast2_parse
  args: []
  expected: true

invariant theseus_ast_cr.ast2_dump:
  description: "dump() produces a string representation of an AST"
  category: behavior
  kind: python_call_eq
  function: ast2_dump
  args: []
  expected: true

invariant theseus_ast_cr.ast2_walk:
  description: "walk() yields all nodes in an AST"
  category: behavior
  kind: python_call_eq
  function: ast2_walk
  args: []
  expected: true
