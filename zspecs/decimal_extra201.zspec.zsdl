spec: decimal_extra201
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra200.zspec.zsdl — covers previous decimal module invariants"
    - "decimal_extra.zspec.zsdl — covers Decimal and Context class metadata"
  notes:
    - "decimal.Decimal.__mro__ is a tuple; len == 2; MRO is [Decimal, object]; confirmed Python 3.14.3 macOS."
    - "decimal.Context.__mro__ is a tuple; len == 2; MRO is [Context, object]; confirmed Python 3.14.3 macOS."
    - "decimal.DecimalException.__mro__ is a tuple; len == 5; MRO is [DecimalException, ArithmeticError, Exception, BaseException, object]; confirmed Python 3.14.3 macOS."
    - "Both Decimal and Context are direct subclasses of object with no intermediate abstract base classes."
    - "DecimalException inherits from ArithmeticError, making it a proper arithmetic exception in the standard hierarchy."
    - "Index access on __mro__ uses bracket notation — function paths containing '[' must be double-quoted."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal.Decimal.__mro__ type identity and length
# __class__.__name__ == 'tuple', __len__() == 2
# ---------------------------------------------------------------------------

table decimal_extra201.decimal_mro_type_and_len:
  description: "decimal.Decimal.__mro__ type identity and length"
  kind: python_call_eq
  category: mro_identity
  id_prefix: decimalmro201

  columns: [id, function, args, expected, description]
  rows:
    - [decimal_mro_class_name_eq,  Decimal.__mro__.__class__.__name__.__eq__,  ["tuple"], true,  "decimal.Decimal.__mro__.__class__.__name__ == 'tuple'; MRO is always a tuple; confirmed Python 3.14.3 macOS"]
    - [decimal_mro_class_name_len, Decimal.__mro__.__class__.__name__.__len__,  [],        5,     "decimal.Decimal.__mro__.__class__.__name__.__len__() == 5; 'tuple' has 5 characters; confirmed Python 3.14.3 macOS"]
    - [decimal_mro_len_eq,         Decimal.__mro__.__len__,                    [],        2,     "decimal.Decimal.__mro__.__len__() == 2; MRO is [Decimal, object]; confirmed Python 3.14.3 macOS"]
    - [decimal_mro0_name_eq,       "Decimal.__mro__[0].__name__.__eq__",       ["Decimal"], true, "decimal.Decimal.__mro__[0].__name__ == 'Decimal'; the class itself is first in its own MRO; confirmed Python 3.14.3 macOS"]
    - [decimal_mro1_name_eq,       "Decimal.__mro__[1].__name__.__eq__",       ["object"],  true, "decimal.Decimal.__mro__[1].__name__ == 'object'; Decimal directly inherits from object; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: decimal.Context.__mro__ type identity and length
# __class__.__name__ == 'tuple', __len__() == 2
# ---------------------------------------------------------------------------

table decimal_extra201.context_mro_type_and_len:
  description: "decimal.Context.__mro__ type identity and length"
  kind: python_call_eq
  category: mro_identity
  id_prefix: decimalmro201

  columns: [id, function, args, expected, description]
  rows:
    - [context_mro_class_name_eq,  Context.__mro__.__class__.__name__.__eq__,  ["tuple"], true,  "decimal.Context.__mro__.__class__.__name__ == 'tuple'; MRO is always a tuple; confirmed Python 3.14.3 macOS"]
    - [context_mro_class_name_len, Context.__mro__.__class__.__name__.__len__,  [],        5,     "decimal.Context.__mro__.__class__.__name__.__len__() == 5; 'tuple' has 5 characters; confirmed Python 3.14.3 macOS"]
    - [context_mro_len_eq,         Context.__mro__.__len__,                    [],        2,     "decimal.Context.__mro__.__len__() == 2; MRO is [Context, object]; confirmed Python 3.14.3 macOS"]
    - [context_mro0_name_eq,       "Context.__mro__[0].__name__.__eq__",       ["Context"], true, "decimal.Context.__mro__[0].__name__ == 'Context'; the class itself is first in its own MRO; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: decimal.DecimalException.__mro__ length and element names
# len == 5; [0] == 'DecimalException', [1] == 'ArithmeticError', [2] == 'Exception'
# ---------------------------------------------------------------------------

table decimal_extra201.decimalexception_mro:
  description: "decimal.DecimalException.__mro__ length and element names"
  kind: python_call_eq
  category: mro_members
  id_prefix: decimalmro201

  columns: [id, function, args, expected, description]
  rows:
    - [decimalexc_mro_len_eq,    DecimalException.__mro__.__len__,                          [],                    5,     "decimal.DecimalException.__mro__.__len__() == 5; MRO is [DecimalException, ArithmeticError, Exception, BaseException, object]; confirmed Python 3.14.3 macOS"]
    - [decimalexc_mro0_name_eq,  "DecimalException.__mro__[0].__name__.__eq__",              ["DecimalException"],  true,  "decimal.DecimalException.__mro__[0].__name__ == 'DecimalException'; the class itself is first; confirmed Python 3.14.3 macOS"]
    - [decimalexc_mro1_name_eq,  "DecimalException.__mro__[1].__name__.__eq__",              ["ArithmeticError"],   true,  "decimal.DecimalException.__mro__[1].__name__ == 'ArithmeticError'; DecimalException inherits from ArithmeticError; confirmed Python 3.14.3 macOS"]
    - [decimalexc_mro2_name_eq,  "DecimalException.__mro__[2].__name__.__eq__",              ["Exception"],         true,  "decimal.DecimalException.__mro__[2].__name__ == 'Exception'; Exception is the third ancestor; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra201.decimal_mro_class_name_eq:
  description: "decimal.Decimal.__mro__.__class__.__name__ == 'tuple' — MRO is always a tuple; confirmed Python 3.14.3 macOS"
  category: mro_identity
  kind: python_call_eq
  function: Decimal.__mro__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant decimal_extra201.decimal_mro_len_eq:
  description: "decimal.Decimal.__mro__.__len__() == 2 — MRO is [Decimal, object]; confirmed Python 3.14.3 macOS"
  category: mro_identity
  kind: python_call_eq
  function: Decimal.__mro__.__len__
  args: []
  expected: 2

invariant decimal_extra201.decimal_mro0_name_eq:
  description: "decimal.Decimal.__mro__[0].__name__ == 'Decimal' — the class itself is first in its own MRO; confirmed Python 3.14.3 macOS"
  category: mro_members
  kind: python_call_eq
  function: "Decimal.__mro__[0].__name__.__eq__"
  args: ["Decimal"]
  expected: true

invariant decimal_extra201.decimal_mro1_name_eq:
  description: "decimal.Decimal.__mro__[1].__name__ == 'object' — Decimal directly inherits from object; confirmed Python 3.14.3 macOS"
  category: mro_members
  kind: python_call_eq
  function: "Decimal.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant decimal_extra201.context_mro_len_eq:
  description: "decimal.Context.__mro__.__len__() == 2 — MRO is [Context, object]; confirmed Python 3.14.3 macOS"
  category: mro_identity
  kind: python_call_eq
  function: Context.__mro__.__len__
  args: []
  expected: 2

invariant decimal_extra201.context_mro0_name_eq:
  description: "decimal.Context.__mro__[0].__name__ == 'Context' — the class itself is first in its own MRO; confirmed Python 3.14.3 macOS"
  category: mro_members
  kind: python_call_eq
  function: "Context.__mro__[0].__name__.__eq__"
  args: ["Context"]
  expected: true

invariant decimal_extra201.decimalexception_mro_len_eq:
  description: "decimal.DecimalException.__mro__.__len__() == 5 — MRO is [DecimalException, ArithmeticError, Exception, BaseException, object]; confirmed Python 3.14.3 macOS"
  category: mro_identity
  kind: python_call_eq
  function: DecimalException.__mro__.__len__
  args: []
  expected: 5

invariant decimal_extra201.decimalexception_mro1_name_eq:
  description: "decimal.DecimalException.__mro__[1].__name__ == 'ArithmeticError' — DecimalException inherits from ArithmeticError; confirmed Python 3.14.3 macOS"
  category: mro_members
  kind: python_call_eq
  function: "DecimalException.__mro__[1].__name__.__eq__"
  args: ["ArithmeticError"]
  expected: true
