spec: theseus_bdb_cr
version: ">=3.0"
backend: python_cleanroom(theseus_bdb_cr)
blocks: bdb

docs: https://docs.python.org/3/library/bdb.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/bdb.html"
  not_derived_from:
    - "CPython source: Lib/bdb.py"
  notes:
    - "Clean-room bdb module. Do NOT import bdb."

error_model: python_exceptions

invariant theseus_bdb_cr.bdb2_bdbquit:
  description: "BdbQuit exception class exists"
  category: behavior
  kind: python_call_eq
  function: bdb2_bdbquit
  args: []
  expected: true

invariant theseus_bdb_cr.bdb2_bdb:
  description: "Bdb class exists and is instantiatable"
  category: behavior
  kind: python_call_eq
  function: bdb2_bdb
  args: []
  expected: true

invariant theseus_bdb_cr.bdb2_breakpoint:
  description: "Breakpoint class exists with bpbynumber dict"
  category: behavior
  kind: python_call_eq
  function: bdb2_breakpoint
  args: []
  expected: true
