spec: threading_extra135
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.Condition class identity and method qualnames (__init__, __enter__, __exit__, notify, notify_all, wait, wait_for) plus code attributes (Wave 262)."
    - "threading.Condition.__name__ == 'Condition' (len 9) — Condition class defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Condition.__module__ == 'threading'. Verified with Python 3.14.3."
    - "threading.Condition.__class__.__name__ == 'type' — Condition is a Python class. Verified with Python 3.14.3."
    - "threading.Condition.__qualname__ == 'Condition' (len 9). Verified with Python 3.14.3."
    - "len(threading.Condition.__mro__) == 2 — MRO is [Condition, object]. Verified with Python 3.14.3."
    - "threading.Condition.__init__.__qualname__ == 'Condition.__init__' (len 18). Verified with Python 3.14.3."
    - "threading.Condition.__init__.__code__.co_argcount == 2 — takes self and lock. Verified with Python 3.14.3."
    - "len(threading.Condition.__init__.__code__.co_varnames) == 2. Verified with Python 3.14.3."
    - "threading.Condition.__enter__.__qualname__ == 'Condition.__enter__' (len 19). Verified with Python 3.14.3."
    - "threading.Condition.__enter__.__code__.co_argcount == 1 — takes only self. Verified with Python 3.14.3."
    - "threading.Condition.__exit__.__qualname__ == 'Condition.__exit__' (len 18). Verified with Python 3.14.3."
    - "threading.Condition.__exit__.__code__.co_argcount == 1 — takes only self (args is *args). Verified with Python 3.14.3."
    - "threading.Condition.notify.__qualname__ == 'Condition.notify' (len 16). Verified with Python 3.14.3."
    - "threading.Condition.notify.__code__.co_argcount == 2 — takes self and n. Verified with Python 3.14.3."
    - "len(threading.Condition.notify.__code__.co_varnames) == 4 — self, n, waiters, waiter. Verified with Python 3.14.3."
    - "threading.Condition.notify_all.__qualname__ == 'Condition.notify_all' (len 20). Verified with Python 3.14.3."
    - "threading.Condition.notify_all.__code__.co_argcount == 1 — takes only self. Verified with Python 3.14.3."
    - "threading.Condition.wait.__qualname__ == 'Condition.wait' (len 14). Verified with Python 3.14.3."
    - "threading.Condition.wait.__code__.co_argcount == 2 — takes self and timeout. Verified with Python 3.14.3."
    - "len(threading.Condition.wait.__code__.co_varnames) == 5 — self, timeout, waiter, saved_state, gotit. Verified with Python 3.14.3."
    - "threading.Condition.wait_for.__qualname__ == 'Condition.wait_for' (len 18). Verified with Python 3.14.3."
    - "threading.Condition.wait_for.__code__.co_argcount == 3 — takes self, predicate, timeout. Verified with Python 3.14.3."
    - "len(threading.Condition.wait_for.__code__.co_varnames) == 6 — self, predicate, timeout, endtime, waittime, result. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

