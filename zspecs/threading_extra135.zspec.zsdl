table threading_extra135.condition_class_identity:
  description: "threading.Condition class identity: __name__ len 9, __module__=='threading', __class__.__name__=='type', __qualname__ len 9, MRO len 2; wave 262; new to extra135"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingcond135

  columns: [id, function, args, expected, description]
  rows:
    - [condition_name_eq,
       "Condition.__name__.__eq__",
       ["Condition"],
       true,
       "threading.Condition.__name__.__eq__('Condition') == True — Condition is a Python class defined in Lib/threading.py; its __name__ attribute is 'Condition'; str.__eq__('Condition') returns True; new to extra135"]
    - [condition_name_len_eq_9,
       "Condition.__name__.__len__",
