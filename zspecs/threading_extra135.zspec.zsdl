       "Condition.__module__.__eq__",
       ["threading"],
       true,
       "threading.Condition.__module__.__eq__('threading') == True — Condition is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra135"]
    - [condition_class_name_eq_type,
       "Condition.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.Condition.__class__.__name__.__eq__('type') == True — Condition is a Python class; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra135"]
    - [condition_qualname_eq,
       "Condition.__qualname__.__eq__",
       ["Condition"],
       true,
       "threading.Condition.__qualname__.__eq__('Condition') == True — Condition is defined at module scope in Lib/threading.py; __qualname__ equals the class name; str.__eq__('Condition') returns True; new to extra135"]
    - [condition_qualname_len_eq_9,
       "Condition.__qualname__.__len__",
       [],
       9,
       "threading.Condition.__qualname__.__len__() == 9 — __qualname__ is 'Condition' which has 9 characters; len('Condition') == 9; new to extra135"]
    - [condition_mro_len_eq_2,
       "Condition.__mro__.__len__",
       [],
       2,
       "threading.Condition.__mro__.__len__() == 2 — Condition's MRO is [Condition, object]; it inherits only from object; len(__mro__) is 2; new to extra135"]
    - [condition_bases_first_eq_object,
       "Condition.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Condition.__bases__[0].__name__.__eq__('object') == True — Condition inherits only from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra135"]

