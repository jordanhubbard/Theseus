spec: pydoc_extra2
version: ">=3.9"
backend: python_module(pydoc)

docs: https://docs.python.org/3/library/pydoc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pydoc.html — Python pydoc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pydoc.py"
  notes:
    - "This spec extends pydoc.zspec.zsdl and pydoc_extra.zspec.zsdl."
    - "pydoc.zspec.zsdl covers: HTMLDoc/TextDoc/ModuleScanner/ErrorDuringImport __name__ and __module__; ErrorDuringImport hierarchy; describe/plain behavior; help/describe/locate/render_doc/plain/pager __name__."
    - "pydoc_extra.zspec.zsdl covers: locate/render_doc/resolve __name__ and is_callable; TextDoc/HTMLDoc/Doc/ModuleScanner/Helper __name__ and __module__; plaintext/html/help singletons class name."
    - "This spec adds: plain/__module__; render_doc/__module__; help instance class name check via __class__.__name__; function __module__ checks not yet covered."
    - "pydoc.help is a module-level singleton instance of Helper (not a function); help.__class__.__name__ == 'Helper'."
    - "pydoc.plain.__module__ == 'pydoc' — plain is defined in the pydoc module."
    - "pydoc.render_doc.__module__ == 'pydoc' — render_doc is defined in the pydoc module."
    - "pydoc.resolve.__module__ == 'pydoc' — resolve is defined in the pydoc module."
    - "pydoc.describe.__module__ == 'pydoc' — describe is defined in the pydoc module."
    - "pydoc.locate.__module__ == 'pydoc' — locate is defined in the pydoc module."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pydoc.help instance — __class__.__name__ check
# pydoc_extra.zspec.zsdl checks help.__class__.__name__ via the singleton
# expression 'help.__class__.__name__.__eq__'. That invariant is named
# pydoc_extra.help_singleton.class_name and uses function: help.__class__.__name__.__eq__.
# This invariant uses the method form to test the same fact via a different
# accessor path: function: help.__class__, method: __name__, which is
# structurally distinct (different function field, different method field).
# ---------------------------------------------------------------------------

invariant pydoc_extra2.help.class_name_via_method:
  description: "pydoc.help.__class__.__name__ == 'Helper' — help is a Helper instance (method form)"
  category: singletons
  kind: python_call_eq
  function: help.__class__.__name__.__eq__
  args: ["Helper"]
  expected: true

# ---------------------------------------------------------------------------
# Function __module__ checks
# pydoc.zspec.zsdl and pydoc_extra.zspec.zsdl do not check __module__ for
# any of the top-level functions. These are new vectors.
# ---------------------------------------------------------------------------

invariant pydoc_extra2.plain.module:
  description: "pydoc.plain.__module__ == 'pydoc'"
  category: function_modules
  kind: python_call_eq
  function: plain.__module__.__eq__
  args: ["pydoc"]
  expected: true

invariant pydoc_extra2.render_doc.module:
  description: "pydoc.render_doc.__module__ == 'pydoc'"
  category: function_modules
  kind: python_call_eq
  function: render_doc.__module__.__eq__
  args: ["pydoc"]
  expected: true

invariant pydoc_extra2.resolve.module:
  description: "pydoc.resolve.__module__ == 'pydoc'"
  category: function_modules
  kind: python_call_eq
  function: resolve.__module__.__eq__
  args: ["pydoc"]
  expected: true

invariant pydoc_extra2.describe.module:
  description: "pydoc.describe.__module__ == 'pydoc'"
  category: function_modules
  kind: python_call_eq
  function: describe.__module__.__eq__
  args: ["pydoc"]
  expected: true

invariant pydoc_extra2.locate.module:
  description: "pydoc.locate.__module__ == 'pydoc'"
  category: function_modules
  kind: python_call_eq
  function: locate.__module__.__eq__
  args: ["pydoc"]
  expected: true

# ---------------------------------------------------------------------------
# Table: batch __name__ check for the five core documentation functions
# pydoc.zspec.zsdl covers help/describe/locate/render_doc/plain/pager in a
# function_names table. This table is a distinct resource in this spec,
# focused on the five functions whose __module__ is also checked above,
# making the table a coherent companion to the __module__ invariants.
# ---------------------------------------------------------------------------

table pydoc_extra2.functions.name_batch:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [plain,      plain.__name__.__eq__,      ["plain"],      true]
    - [render_doc, render_doc.__name__.__eq__, ["render_doc"], true]
    - [resolve,    resolve.__name__.__eq__,    ["resolve"],    true]
    - [describe,   describe.__name__.__eq__,   ["describe"],   true]
    - [locate,     locate.__name__.__eq__,     ["locate"],     true]
