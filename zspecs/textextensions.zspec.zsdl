spec: textextensions
version: ">=6.0.0"
backend: node(textextensions)
esm: true

docs: https://github.com/bevry/textextensions#readme

provenance:
  derived_from:
    - "textextensions README — https://github.com/bevry/textextensions#readme"
    - "Test vectors verified with textextensions via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "textextensions source"
  notes:
    - "Curated list of file extensions that should be treated as text."
    - "Install: npm install textextensions"
    - "v6 ESM only; default export IS an array of extensions (with bare-name entries like 'Dockerfile')."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Static data array; no runtime errors."
  stderr: "null"
  stickiness: "N/A — read-only data."
  codes: {}

invariant textextensions.default_export_is_array:
  description: "Default export is an Array"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.constructor.name"}
  expected: "Array"

invariant textextensions.includes_md:
  description: "List includes 'md'"
  category: contains
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {method: includes, args: ["md"]}
  expected: true

invariant textextensions.includes_js:
  description: "List includes 'js'"
  category: contains
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {method: includes, args: ["js"]}
  expected: true

invariant textextensions.includes_dockerfile:
  description: "List includes the bare-name 'Dockerfile'"
  category: contains
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {method: includes, args: ["Dockerfile"]}
  expected: true

invariant textextensions.excludes_png:
  description: "List does not include 'png' (binary)"
  category: contains
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {method: includes, args: ["png"]}
  expected: false

invariant textextensions.has_many_entries:
  description: "List has more than 100 entries (the full text-file curation)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.length"}
    - {method: toString, args: []}
    - {method: charAt, args: [0]}
  expected: "2"

invariant textextensions.includes_html:
  description: "List includes 'html'"
  category: contains
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {method: includes, args: ["html"]}
  expected: true
