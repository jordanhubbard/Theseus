spec: struct_extra1486
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "_struct C extension source"
  notes:
    - "Wave 546 extra1486: context manager protocol checks for struct classes."
    - "struct.Struct is a C-level type (from _struct); it has no __enter__ or __exit__ in its __dict__."
    - "struct.error is a plain Exception subclass; it also lacks __enter__ and __exit__."
    - "Neither struct.Struct nor struct.error supports the context manager protocol."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra1486.struct_class_context_manager:
  description: "struct.Struct has no context manager protocol (__enter__/__exit__ absent from __dict__)"
  kind: python_call_eq
  category: context_manager_protocol
  id_prefix: st1486sx
  columns: [id, function, args, expected]
  rows:
    - [st1486sx001, struct.Struct.__dict__.__contains__, ["__enter__"],      false]
    - [st1486sx002, struct.Struct.__dict__.__contains__, ["__exit__"],       false]
    - [st1486sx003, struct.Struct.__name__.__eq__,       ["Struct"],         true]
    - [st1486sx004, struct.Struct.__module__.__eq__,     ["_struct"],        true]
    - [st1486sx005, struct.Struct.__qualname__.__eq__,   ["Struct"],         true]
    - [st1486sx006, struct.Struct.__class__.__name__.__eq__, ["type"],       true]

table struct_extra1486.struct_error_context_manager:
  description: "struct.error has no context manager protocol (__enter__/__exit__ absent from __dict__)"
  kind: python_call_eq
  category: context_manager_protocol
  id_prefix: st1486ex
  columns: [id, function, args, expected]
  rows:
    - [st1486ex001, struct.error.__dict__.__contains__, ["__enter__"],       false]
    - [st1486ex002, struct.error.__dict__.__contains__, ["__exit__"],        false]
    - [st1486ex003, struct.error.__name__.__eq__,       ["error"],           true]
    - [st1486ex004, struct.error.__module__.__eq__,     ["struct"],          true]
    - [st1486ex005, struct.error.__qualname__.__eq__,   ["error"],           true]
    - [st1486ex006, struct.error.__class__.__name__.__eq__, ["type"],        true]

table struct_extra1486.struct_no_enter_exit_combined:
  description: "Consolidated negative check: neither struct.Struct nor struct.error carry __enter__/__exit__"
  kind: python_call_eq
  category: context_manager_protocol
  id_prefix: st1486nx
  columns: [id, function, args, expected]
  rows:
    - [st1486nx001, struct.Struct.__dict__.__contains__,  ["__enter__"],    false]
    - [st1486nx002, struct.Struct.__dict__.__contains__,  ["__exit__"],     false]
    - [st1486nx003, struct.error.__dict__.__contains__,   ["__enter__"],    false]
    - [st1486nx004, struct.error.__dict__.__contains__,   ["__exit__"],     false]
    - [st1486nx005, struct.Struct.__bases__.__class__.__name__.__eq__,   ["tuple"], true]
    - [st1486nx006, struct.error.__bases__.__class__.__name__.__eq__,    ["tuple"], true]
    - [st1486nx007, struct.Struct.__module__.__class__.__name__.__eq__,  ["str"],   true]
