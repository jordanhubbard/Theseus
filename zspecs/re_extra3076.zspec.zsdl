spec: re3076
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 652 (re3076): __get__, __set__, __delete__ dict-presence checks for re types."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "None of the re types define the descriptor protocol in their own __dict__: __get__, __set__, and __delete__ are all absent."
    - "re.Pattern and re.Match are C-level extension types from _sre; re.RegexFlag is an IntFlag enum — none implement the descriptor protocol."
    - "re.Pattern.__dict__ is accessed directly (not via type(re.compile(...)).__dict__) per wave 652 convention."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __get__ dict-presence — operator.contains(Cls.__dict__, '__get__')
#
# No re type defines __get__ in its own __dict__; all false.
# re.Pattern and re.Match are C-level types; re.RegexFlag is an IntFlag enum.
# None implement the descriptor protocol.
# ---------------------------------------------------------------------------

table re3076.get:
  description: "re types __get__ dict-presence checks; wave 652"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3076

  columns: [id, function, args, expected]
  rows:
    - ["re3076001", operator.contains, [re.Pattern.__dict__,  "__get__"], false]
    - ["re3076002", operator.contains, [re.Match.__dict__,    "__get__"], false]
    - ["re3076003", operator.contains, [re.RegexFlag.__dict__, "__get__"], false]

