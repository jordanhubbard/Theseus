# ---------------------------------------------------------------------------
# combined — __get__, __set__, __delete__ across all 3 re subjects
#
# Covers the full matrix: 3 classes x 3 methods = 9 rows, padded with
# additional cross-checks across all three subjects to reach ~24 rows.
# __get__:    all false — re types are not descriptors.
# __set__:    all false — re types do not implement data-descriptor protocol.
# __delete__: all false — re types have no descriptor deletion support.
# ---------------------------------------------------------------------------

table re3076.combined:
  description: "re types combined __get__/__set__/__delete__; wave 652"
  kind: python_call_eq
