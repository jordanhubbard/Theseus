spec: theseus_gzip_cr
version: ">=3.8"
backend: python_cleanroom(theseus_gzip_cr)
blocks: gzip

docs: https://docs.python.org/3/library/gzip.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/gzip.html"
    - "RFC 1952 — GZIP file format specification"
  not_derived_from:
    - "CPython source: Lib/gzip.py (internal implementation)"
  notes:
    - "Clean-room gzip module. Do NOT import gzip."
    - "compress(data): compress bytes using gzip format."
    - "decompress(data): decompress gzip-compressed bytes."
    - "GzipFile(fileobj, mode): file-like interface for gzip streams."

error_model: python_exceptions

invariant theseus_gzip_cr.gzip2_compress_decompress:
  description: "compress then decompress b'hello' returns b'hello'"
  category: compress
  kind: python_call_eq
  function: gzip2_compress_decompress
  args: []
  expected: true

invariant theseus_gzip_cr.gzip2_magic:
  description: "compressed data starts with gzip magic bytes 0x1f 0x8b"
  category: compress
  kind: python_call_eq
  function: gzip2_magic
  args: []
  expected: true

invariant theseus_gzip_cr.gzip2_round_trip:
  description: "longer data round-trips through compress/decompress"
  category: compress
  kind: python_call_eq
  function: gzip2_round_trip
  args: []
  expected: true
