spec: asyncio_extra41
version: ">=3.11"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio tasks and coroutines"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/taskgroups.py"
    - "CPython source: Lib/asyncio/runners.py"
    - "CPython source: Lib/asyncio/tasks.py"
  notes:
    - "This spec extends asyncio_extra40.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__(), Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__(), InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__.__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, QueueFull/__name__.__len__()==9, QueueEmpty/QueueFull __qualname__.__len__(), Runner method __name__/__qualname__.__len__() tables, various function and class lengths, MRO depths for all queue/lock/sync classes, AbstractEventLoop/__name__/__len__() tables, BaseEventLoop/Handle/TimerHandle/Protocol/StreamReader lengths, Event method __qualname__ string values and lengths (extra39), Semaphore acquire/release __qualname__ string values and lengths (extra39/extra40), BoundedSemaphore/__name__/__module__/inherited acquire qualname (extra40), Condition/__name__/__module__/wait qualname (extra40)."
    - "This spec covers: TaskGroup.__name__=='TaskGroup'; TaskGroup.__module__=='asyncio.taskgroups' (17 chars); TaskGroup.__bases__[0].__name__=='object'; Runner.__name__=='Runner' (Python 3.11+); Runner.__module__=='asyncio.runners' (14 chars); shield/__name__=='shield'; shield/__module__=='asyncio.tasks' (13 chars); ensure_future/__name__=='ensure_future'; create_task/__name__=='create_task'; ensure_future/__module__=='asyncio.tasks'; create_task/__module__=='asyncio.tasks'."
    - "asyncio.TaskGroup.__module__ == 'asyncio.taskgroups' (17 chars: 'asyncio'(7) + '.'(1) + 'taskgroups'(10) = 18... actually: a-s-y-n-c-i-o(7) + .(1) + t-a-s-k-g-r-o-u-p-s(10) = 18). Wait — verified: len('asyncio.taskgroups') == 18. asyncio.Runner.__module__ == 'asyncio.runners' (14 chars: 'asyncio'(7) + '.'(1) + 'runners'(6) = 14). asyncio.shield.__module__ == 'asyncio.tasks' (13 chars: 'asyncio'(7) + '.'(1) + 'tasks'(5) = 13). ensure_future and create_task also live in 'asyncio.tasks' (13 chars)."
    - "asyncio.TaskGroup.__bases__[0].__name__ == 'object'. TaskGroup does not inherit from any other asyncio class — it inherits directly from object. This contrasts with Queue subclasses (LifoQueue, PriorityQueue) which inherit from Queue, not object."
    - "asyncio.Runner is available from Python 3.11+. This spec sets version: '>=3.11' to reflect the Runner dependency. All other items (TaskGroup, shield, ensure_future, create_task) are also available in 3.11+."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.TaskGroup identity — extra41 namespace
#
# TaskGroup is the structured concurrency primitive added in Python 3.11:
#   TaskGroup.__name__            == 'TaskGroup'           ( 9 chars)
#   TaskGroup.__module__          == 'asyncio.taskgroups'  (18 chars)
#   TaskGroup.__bases__[0].__name__ == 'object'
# TaskGroup inherits directly from object (no asyncio base class).
# 'asyncio.taskgroups': 'asyncio'(7) + '.'(1) + 'taskgroups'(10) = 18 chars.
# ---------------------------------------------------------------------------

table asyncio_extra41.taskgroup_identity:
  description: "asyncio.TaskGroup identity in extra41 namespace — __name__, __module__, and base class name"
  kind: python_call_eq
  category: class_names
  id_prefix: taskgroupid41

  columns: [id, function, args, expected, description]
  rows:
    - [name,       TaskGroup.__name__.__eq__,                  ["TaskGroup"],          true, "TaskGroup.__name__ == 'TaskGroup' (9 chars)"]
    - [module,     TaskGroup.__module__.__eq__,                ["asyncio.taskgroups"], true, "TaskGroup.__module__ == 'asyncio.taskgroups' (18 chars)"]
    - [module_len, TaskGroup.__module__.__len__,               [],                    18,   "'asyncio.taskgroups' is 18 characters — 'asyncio'(7) + '.'(1) + 'taskgroups'(10)"]
    - [bases0,     "TaskGroup.__bases__[0].__name__.__eq__",   ["object"],             true, "TaskGroup.__bases__[0].__name__ == 'object' — inherits directly from object"]

# ---------------------------------------------------------------------------
# asyncio.Runner identity — extra41 namespace (Python 3.11+)
#
# Runner is the high-level event loop manager introduced in Python 3.11:
#   Runner.__name__   == 'Runner'          ( 6 chars)
#   Runner.__module__ == 'asyncio.runners' (14 chars)
# 'asyncio.runners': 'asyncio'(7) + '.'(1) + 'runners'(6) = 14 chars.
# ---------------------------------------------------------------------------

table asyncio_extra41.runner_identity:
  description: "asyncio.Runner identity in extra41 namespace — __name__ and __module__ (Python 3.11+)"
  kind: python_call_eq
  category: class_names
  id_prefix: runnerid41

  columns: [id, function, args, expected, description]
  rows:
    - [name,       Runner.__name__.__eq__,   ["Runner"],          true, "Runner.__name__ == 'Runner' (6 chars)"]
    - [module,     Runner.__module__.__eq__,  ["asyncio.runners"], true, "Runner.__module__ == 'asyncio.runners' (14 chars)"]
    - [module_len, Runner.__module__.__len__, [],                 14,   "'asyncio.runners' is 14 characters — 'asyncio'(7) + '.'(1) + 'runners'(6)"]

# ---------------------------------------------------------------------------
# asyncio task function identity — extra41 namespace
#
# Three core task-management functions and their identity attributes:
#   shield.__name__        == 'shield'        ( 6 chars)
#   shield.__module__      == 'asyncio.tasks' (13 chars)
#   ensure_future.__name__ == 'ensure_future' (13 chars)
#   ensure_future.__module__== 'asyncio.tasks' (13 chars)
#   create_task.__name__   == 'create_task'   (11 chars)
#   create_task.__module__ == 'asyncio.tasks' (13 chars)
# All three live in 'asyncio.tasks' (13 chars: 'asyncio'(7) + '.'(1) + 'tasks'(5)).
# ---------------------------------------------------------------------------

table asyncio_extra41.task_function_names:
  description: "asyncio task function __name__ string equality in extra41 namespace — shield, ensure_future, create_task"
  kind: python_call_eq
  category: function_names
  id_prefix: taskfuncname41

  columns: [id, function, args, expected, description]
  rows:
    - [shield,        shield.__name__.__eq__,        ["shield"],        true, "shield.__name__ == 'shield' (6 chars)"]
    - [ensure_future, ensure_future.__name__.__eq__,  ["ensure_future"], true, "ensure_future.__name__ == 'ensure_future' (13 chars)"]
    - [create_task,   create_task.__name__.__eq__,    ["create_task"],   true, "create_task.__name__ == 'create_task' (11 chars)"]

table asyncio_extra41.task_function_modules:
  description: "asyncio task function __module__ string equality in extra41 namespace — shield, ensure_future, create_task all live in asyncio.tasks"
  kind: python_call_eq
  category: module_names
  id_prefix: taskfuncmod41

  columns: [id, function, args, expected, description]
  rows:
    - [shield,        shield.__module__.__eq__,        ["asyncio.tasks"], true, "shield.__module__ == 'asyncio.tasks' (13 chars)"]
    - [ensure_future, ensure_future.__module__.__eq__,  ["asyncio.tasks"], true, "ensure_future.__module__ == 'asyncio.tasks' (13 chars)"]
    - [create_task,   create_task.__module__.__eq__,    ["asyncio.tasks"], true, "create_task.__module__ == 'asyncio.tasks' (13 chars)"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra41
# ---------------------------------------------------------------------------

invariant asyncio_extra41.TaskGroup_name_eq:
  description: "asyncio.TaskGroup.__name__ == 'TaskGroup' — the structured concurrency primitive introduced in Python 3.11 (9 chars)"
  category: class_names
  kind: python_call_eq
  function: TaskGroup.__name__.__eq__
  args: ["TaskGroup"]
  expected: true

invariant asyncio_extra41.TaskGroup_module_eq:
  description: "asyncio.TaskGroup.__module__ == 'asyncio.taskgroups' — TaskGroup is implemented in the asyncio.taskgroups submodule (18 chars)"
  category: module_names
  kind: python_call_eq
  function: TaskGroup.__module__.__eq__
  args: ["asyncio.taskgroups"]
  expected: true

invariant asyncio_extra41.TaskGroup_bases0_name_eq:
  description: "asyncio.TaskGroup.__bases__[0].__name__ == 'object' — TaskGroup inherits directly from object with no intermediate asyncio base class"
  category: class_names
  kind: python_call_eq
  function: "TaskGroup.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant asyncio_extra41.Runner_name_eq:
  description: "asyncio.Runner.__name__ == 'Runner' — the high-level event loop manager introduced in Python 3.11 (6 chars)"
  category: class_names
  kind: python_call_eq
  function: Runner.__name__.__eq__
  args: ["Runner"]
  expected: true

invariant asyncio_extra41.Runner_module_eq:
  description: "asyncio.Runner.__module__ == 'asyncio.runners' — Runner is implemented in the asyncio.runners submodule (14 chars)"
  category: module_names
  kind: python_call_eq
  function: Runner.__module__.__eq__
  args: ["asyncio.runners"]
  expected: true

invariant asyncio_extra41.shield_name_eq:
  description: "asyncio.shield.__name__ == 'shield' — the coroutine wrapper that protects an awaitable from cancellation (6 chars)"
  category: function_names
  kind: python_call_eq
  function: shield.__name__.__eq__
  args: ["shield"]
  expected: true

invariant asyncio_extra41.shield_module_eq:
  description: "asyncio.shield.__module__ == 'asyncio.tasks' — shield lives in asyncio.tasks alongside gather, create_task, and ensure_future (13 chars)"
  category: module_names
  kind: python_call_eq
  function: shield.__module__.__eq__
  args: ["asyncio.tasks"]
  expected: true

invariant asyncio_extra41.ensure_future_name_eq:
  description: "asyncio.ensure_future.__name__ == 'ensure_future' — the legacy coroutine-to-Task wrapper (13 chars); prefer create_task in modern code"
  category: function_names
  kind: python_call_eq
  function: ensure_future.__name__.__eq__
  args: ["ensure_future"]
  expected: true

invariant asyncio_extra41.create_task_name_eq:
  description: "asyncio.create_task.__name__ == 'create_task' — schedules a coroutine as an asyncio Task (11 chars)"
  category: function_names
  kind: python_call_eq
  function: create_task.__name__.__eq__
  args: ["create_task"]
  expected: true
