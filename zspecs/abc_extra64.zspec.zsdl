spec: abc_extra64
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#inspect — Python code object and method documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra63.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__/__name__/__qualname__.__len__() for all abc exports, abstractproperty/abstractclassmethod/abstractstaticmethod lengths/qualnames/bases, ABCMeta.register qualname lengths/equality, ABCMeta method __qualname__.__len__() tables, __mro__.__len__() for ABCMeta/ABC/abstractproperty/abstractclassmethod/abstractstaticmethod, __bases__[0].__name__.__len__(), __dict__.__class__.__name__/__len__() tables, ABCMeta/__dict__.__class__.__name__/__qualname__, ABC/__dict__.__class__.__name__/__qualname__, abstractproperty/abstractclassmethod/abstractstaticmethod __dict__.__class__.__name__, abc module __dict__.__class__.__name__/__qualname__, abstractmethod/__class__.__name__=='function', abstractproperty/__class__.__name__=='type', ABC/__class__.__name__=='ABCMeta', __class__.__qualname__ string equality, abstractmethod/__class__.__module__=='builtins', abstractproperty/__class__.__module__=='builtins', ABC/__class__.__module__=='abc', ABCMeta/__class__.__module__=='builtins', abstractclassmethod/abstractstaticmethod __class__.__module__=='builtins', abstractproperty/__init__.__class__.__name__=='wrapper_descriptor', abstractmethod/__init__.__class__.__name__=='method-wrapper', __class__.__module__.__len__() cross-checks, __repr__.__class__.__name__ for all abc objects, __weakref__.__class__.__name__, ABCMeta.__instancecheck__/__subclasscheck__.__class__.__name__.__eq__('function'), ABC/ABCMeta __eq__.__class__.__name__.__eq__('wrapper_descriptor'), abc.__package__.__eq__(''), ABC/ABCMeta/abstractmethod/get_cache_token __doc__.__class__.__name__.__eq__('str'), ABCMeta.__instancecheck__.__qualname__.__eq__, __loader__.__class__.__name__/__name__, __spec__/__file__ class names, __spec__ attributes, ABCMeta.register/__instancecheck__/__subclasscheck__/update_abstractmethods __qualname__.__eq__, abstractproperty.__init__.__qualname__.__eq__, abstractmethod/__annotations__/__globals__ class identity, ABCMeta/__doc__.__contains__('Abstract'), get_cache_token/__class__.__name__.__eq__('builtin_function_or_method'), abstractmethod/__defaults__/__code__/__closure__/__class__.__name__ checks, update_abstractmethods/__defaults__/__code__/__class__.__name__ checks (extra58), abstractmethod/update_abstractmethods/ABCMeta.__instancecheck__ __code__.co_name equality and co_argcount values (extra59), abstractmethod/update_abstractmethods/ABCMeta.__instancecheck__ co_varnames/co_filename/co_flags attribute chains (extra60), abstractmethod/update_abstractmethods/ABCMeta.__instancecheck__ co_consts/co_nlocals/co_stacksize type identity (extra61), abstractmethod/update_abstractmethods/ABCMeta.__instancecheck__/ABCMeta.__subclasscheck__ __defaults__.__class__.__name__=='NoneType', ABCMeta.__subclasscheck__ code attribute type chains, update_abstractmethods code attribute type chains, ABCMeta/__bases__[0].__name__=='type', ABC/__bases__[0].__name__=='object' (extra62 and extra63)."
    - "This spec covers (abcid64 namespace): wave 235 theme — ABCMeta method __qualname__ string equality, ABCMeta.register code attribute type chains, abc module spec identity. NEW in extra64: ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__'); ABCMeta.__subclasscheck__.__qualname__.__eq__('ABCMeta.__subclasscheck__'); ABCMeta.register.__code__.co_varnames.__class__.__name__=='tuple'; ABCMeta.register.__code__.co_consts.__class__.__name__=='tuple'; ABCMeta.register.__code__.co_nlocals.__class__.__name__=='int'; ABCMeta.register.__code__.co_stacksize.__class__.__name__=='int'; abc.__spec__.__class__.__name__.__eq__('ModuleSpec'); abc.__spec__.name.__eq__('abc'); abc.__name__.__eq__('abc')."
    - "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__'. ABCMeta.__instancecheck__ is defined as a Python method in Lib/abc.py. Its qualified name is 'ABCMeta.__instancecheck'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__'. ABCMeta.__subclasscheck__ is defined as a Python method in Lib/abc.py. Its qualified name is 'ABCMeta.__subclasscheck__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.register.__code__.co_varnames.__class__.__name__ == 'tuple'. co_varnames is always a tuple of strings naming local variables. ABCMeta.register is a Python method in abc.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.register.__code__.co_consts.__class__.__name__ == 'tuple'. co_consts is a tuple of constants used by the bytecode. ABCMeta.register is a Python method in abc.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.register.__code__.co_nlocals.__class__.__name__ == 'int'. co_nlocals is the number of local variables stored as a Python int. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.register.__code__.co_stacksize.__class__.__name__ == 'int'. co_stacksize is the required stack size stored as a Python int. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__spec__.__class__.__name__ == 'ModuleSpec'. The __spec__ attribute of a module is a ModuleSpec instance. abc.__spec__.__class__.__name__ is 'ModuleSpec'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__spec__.name == 'abc'. The ModuleSpec.name for the abc module is 'abc'. abc.__spec__.name.__eq__('abc') returns True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__name__ == 'abc'. The __name__ attribute of the abc module is 'abc'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc ABCMeta method __qualname__ string equality checks — extra64
#
# Wave 235 theme: ABCMeta method qualified name identity.
#
# ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__'
# ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__'
# ---------------------------------------------------------------------------

table abc_extra64.ABCMeta_methods_qualnames:
  description: "abc ABCMeta.__instancecheck__/__qualname__.__eq__ and ABCMeta.__subclasscheck__/__qualname__.__eq__ string equality checks in abcid64 namespace — wave 235 theme: ABCMeta method qualified name identity; ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__'; ABCMeta.__subclasscheck__.__qualname__=='ABCMeta.__subclasscheck__'; both are Python methods defined in Lib/abc.py with unambiguous qualified names; NEW in extra64: first __qualname__.__eq__ string equality checks for ABCMeta.__instancecheck__ and ABCMeta.__subclasscheck__ in the abcid64 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcid64

  columns: [id, function, args, expected, description]
  rows:
    - [instancecheck_qualname,  ABCMeta.__instancecheck__.__qualname__.__eq__,  ["ABCMeta.__instancecheck__"],  true, "ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' — ABCMeta.__instancecheck__ is a Python method defined in Lib/abc.py; its qualified name reflects the enclosing class as 'ABCMeta.__instancecheck__'; __qualname__.__eq__('ABCMeta.__instancecheck__') returns True; NEW in extra64: first __qualname__.__eq__ string equality check for ABCMeta.__instancecheck__ in the abcid64 namespace; verified with Python 3.14.3"]
    - [subclasscheck_qualname,  ABCMeta.__subclasscheck__.__qualname__.__eq__,  ["ABCMeta.__subclasscheck__"],  true, "ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' — ABCMeta.__subclasscheck__ is a Python method defined in Lib/abc.py; its qualified name reflects the enclosing class as 'ABCMeta.__subclasscheck__'; __qualname__.__eq__('ABCMeta.__subclasscheck__') returns True; NEW in extra64: first __qualname__.__eq__ string equality check for ABCMeta.__subclasscheck__ in the abcid64 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc ABCMeta.register code attribute type chains — extra64
#
# Wave 235 theme: code object attribute type identity chains.
#
# ABCMeta.register.__code__.co_varnames.__class__.__name__ == 'tuple'
# ABCMeta.register.__code__.co_consts.__class__.__name__ == 'tuple'
# ABCMeta.register.__code__.co_nlocals.__class__.__name__ == 'int'
# ABCMeta.register.__code__.co_stacksize.__class__.__name__ == 'int'
# ---------------------------------------------------------------------------

table abc_extra64.ABCMeta_register_code:
  description: "abc ABCMeta.register code attribute type identity chain checks in abcid64 namespace — wave 235 theme: code object attribute type identity; co_varnames.__class__.__name__=='tuple'; co_consts.__class__.__name__=='tuple'; co_nlocals.__class__.__name__=='int'; co_stacksize.__class__.__name__=='int'; ABCMeta.register is a Python method in Lib/abc.py; NEW in extra64: first co_varnames/co_consts/co_nlocals/co_stacksize type identity chain checks for ABCMeta.register in the abcid64 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: abcid64a

  columns: [id, function, args, expected, description]
  rows:
    - [register_co_varnames_class,  ABCMeta.register.__code__.co_varnames.__class__.__name__.__eq__,  ["tuple"], true, "ABCMeta.register.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is a tuple of strings naming all local variables (parameters first, then locals); the type of co_varnames is always tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra64: first co_varnames.__class__.__name__.__eq__ check for ABCMeta.register in the abcid64 namespace; verified with Python 3.14.3"]
    - [register_co_consts_class,    ABCMeta.register.__code__.co_consts.__class__.__name__.__eq__,   ["tuple"], true, "ABCMeta.register.__code__.co_consts.__class__.__name__ == 'tuple' — co_consts is a tuple of constants used by the bytecode; the type of co_consts is always tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra64: first co_consts.__class__.__name__.__eq__ check for ABCMeta.register in the abcid64 namespace; verified with Python 3.14.3"]
    - [register_co_nlocals_class,   ABCMeta.register.__code__.co_nlocals.__class__.__name__.__eq__,  ["int"],   true, "ABCMeta.register.__code__.co_nlocals.__class__.__name__ == 'int' — co_nlocals is the total number of local variables; it is always a Python int; int.__class__.__name__ is 'int'; NEW in extra64: first co_nlocals.__class__.__name__.__eq__ check for ABCMeta.register in the abcid64 namespace; verified with Python 3.14.3"]
    - [register_co_stacksize_class, ABCMeta.register.__code__.co_stacksize.__class__.__name__.__eq__, ["int"],   true, "ABCMeta.register.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is the required stack size for the code object; it is always a Python int; int.__class__.__name__ is 'int'; NEW in extra64: first co_stacksize.__class__.__name__.__eq__ check for ABCMeta.register in the abcid64 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc module __spec__ identity checks — extra64
#
# Wave 235 theme: module spec identity.
#
# abc.__spec__.__class__.__name__ == 'ModuleSpec'
# abc.__spec__.name == 'abc'
# abc.__name__ == 'abc'
# ---------------------------------------------------------------------------

table abc_extra64.abc_module_spec:
  description: "abc module __spec__.__class__.__name__, __spec__.name, and __name__ string equality checks in abcid64 namespace — wave 235 theme: module spec identity; abc.__spec__.__class__.__name__=='ModuleSpec' (the __spec__ attribute is a ModuleSpec instance); abc.__spec__.name=='abc' (the module's fully-qualified name in its spec); abc.__name__=='abc' (the module's __name__ attribute); NEW in extra64: first __spec__.__class__.__name__ and __spec__.name and __name__ equality checks for the abc module in the abcid64 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcid64b

  columns: [id, function, args, expected, description]
  rows:
    - [abc_spec_class, abc.__spec__.__class__.__name__.__eq__, ["ModuleSpec"], true, "abc.__spec__.__class__.__name__ == 'ModuleSpec' — the __spec__ attribute of the abc module is a ModuleSpec instance (importlib.machinery.ModuleSpec); its __class__.__name__ is 'ModuleSpec'; NEW in extra64: first __spec__.__class__.__name__.__eq__('ModuleSpec') check for the abc module in the abcid64 namespace; verified with Python 3.14.3"]
    - [abc_spec_name,  abc.__spec__.name.__eq__,               ["abc"],       true, "abc.__spec__.name == 'abc' — the ModuleSpec for the abc module stores the fully-qualified module name; abc.__spec__.name is 'abc'; __eq__('abc') returns True; NEW in extra64: first __spec__.name.__eq__('abc') check for the abc module in the abcid64 namespace; verified with Python 3.14.3"]
    - [abc_name,       abc.__name__.__eq__,                    ["abc"],       true, "abc.__name__ == 'abc' — the __name__ attribute of the abc module is the module's name 'abc'; __name__.__eq__('abc') returns True; NEW in extra64: first __name__.__eq__('abc') check for the abc module in the abcid64 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra64
# ---------------------------------------------------------------------------

invariant abc_extra64.ABCMeta_instancecheck_qualname:
  description: "abc.ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__') returns True — ABCMeta.__instancecheck__ is a Python method defined in Lib/abc.py; its qualified name is 'ABCMeta.__instancecheck__'; __qualname__.__eq__('ABCMeta.__instancecheck__') returns True; NEW in extra64: first standalone __qualname__.__eq__ invariant for ABCMeta.__instancecheck__ in the abcid64 namespace; wave 235 first qualified name invariant for ABCMeta.__instancecheck__; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__instancecheck__.__qualname__.__eq__
  args: ["ABCMeta.__instancecheck__"]
  expected: true

invariant abc_extra64.ABCMeta_subclasscheck_qualname:
  description: "abc.ABCMeta.__subclasscheck__.__qualname__.__eq__('ABCMeta.__subclasscheck__') returns True — ABCMeta.__subclasscheck__ is a Python method defined in Lib/abc.py; its qualified name is 'ABCMeta.__subclasscheck__'; __qualname__.__eq__('ABCMeta.__subclasscheck__') returns True; NEW in extra64: first standalone __qualname__.__eq__ invariant for ABCMeta.__subclasscheck__ in the abcid64 namespace; wave 235 first qualified name invariant for ABCMeta.__subclasscheck__; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__subclasscheck__.__qualname__.__eq__
  args: ["ABCMeta.__subclasscheck__"]
  expected: true

invariant abc_extra64.ABCMeta_register_co_nlocals_int:
  description: "abc.ABCMeta.register.__code__.co_nlocals.__class__.__name__.__eq__('int') returns True — co_nlocals is the total number of local variables; it is always a Python int; int.__class__.__name__ is 'int'; NEW in extra64: first standalone co_nlocals type identity invariant for ABCMeta.register in the abcid64 namespace; wave 235 first co_nlocals type invariant for ABCMeta.register; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: ABCMeta.register.__code__.co_nlocals.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant abc_extra64.abc_spec_name_abc:
  description: "abc.__spec__.name.__eq__('abc') returns True — the ModuleSpec for the abc module stores the fully-qualified module name as 'abc'; abc.__spec__.name is 'abc'; __eq__('abc') returns True; NEW in extra64: first standalone __spec__.name.__eq__('abc') invariant for the abc module in the abcid64 namespace; wave 235 first module spec name identity invariant for abc; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.__spec__.name.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra64.abc_name_abc:
  description: "abc.__name__.__eq__('abc') returns True — the __name__ attribute of the abc module is the module's name 'abc'; __name__.__eq__('abc') returns True; NEW in extra64: first standalone __name__.__eq__('abc') invariant for the abc module in the abcid64 namespace; wave 235 first module name identity invariant for abc; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.__name__.__eq__
  args: ["abc"]
  expected: true
