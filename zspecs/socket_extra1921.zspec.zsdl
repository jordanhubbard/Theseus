spec: socket_extra1921
version: ">=3.9"
backend: python_module(socket)

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/socket.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 575 (_extra1921): __slots__ inheritance checks, __abstractmethods__ set membership, __subclasshook__ dict presence, __init_subclass__ dict presence."
    - "socket.socket is a Python class wrapping a C-level socket fd; it defines __slots__ = ['__weakref__', '_io_refs', '_closed']; __slots__ is True in its __dict__."
    - "socket.error is an alias for OSError; socket.timeout is an alias for TimeoutError — both are built-in exception classes with no __slots__ in their own __dict__."
    - "socket.gaierror and socket.herror are Python-defined exception subclasses; they define __weakref__ and __module__ in their own __dict__ but not __slots__."
    - "None of the socket types define __abstractmethods__, __subclasshook__, or __init_subclass__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

table socket_extra1921.slots_protocol:
  description: "socket types __slots__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1921

  columns: [id, function, args, expected]
  rows:
    - ["sk1921001", "socket.socket.__dict__.__contains__", ["__slots__"], true]
    - ["sk1921002", "socket.error.__dict__.__contains__", ["__slots__"], false]
    - ["sk1921003", "socket.timeout.__dict__.__contains__", ["__slots__"], false]
    - ["sk1921004", "socket.gaierror.__dict__.__contains__", ["__slots__"], false]
    - ["sk1921005", "socket.herror.__dict__.__contains__", ["__slots__"], false]
    - ["sk1921006", "socket.socket.__dict__.__contains__", ["__weakref__"], true]
    - ["sk1921007", "socket.error.__dict__.__contains__", ["__weakref__"], false]
    - ["sk1921008", "socket.gaierror.__dict__.__contains__", ["__weakref__"], true]
    - ["sk1921009", "socket.herror.__dict__.__contains__", ["__weakref__"], true]
    - ["sk1921010", "socket.timeout.__dict__.__contains__", ["__weakref__"], false]

