spec: asyncio_extra220
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queues documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "asyncio.Queue(maxsize=-1) does NOT raise — negative maxsize is treated as-is (no validation), effectively unbounded."
    - "asyncio.Queue.__module__ == 'asyncio.queues'; __bases__[0].__name__ == '_LoopBoundMixin'."
    - "asyncio.LifoQueue.__module__ == 'asyncio.queues'; __bases__[0].__name__ == 'Queue'."
    - "asyncio.PriorityQueue.__module__ == 'asyncio.queues'; __bases__[0].__name__ == 'Queue'."
    - "asyncio.Semaphore.__module__ == 'asyncio.locks'; __bases__[0].__name__ == '_ContextManagerMixin'."
    - "asyncio.Lock.__module__ == 'asyncio.locks'; __bases__[0].__name__ == '_ContextManagerMixin'."
    - "asyncio.Event.__module__ == 'asyncio.locks'; __bases__[0].__name__ == '_LoopBoundMixin'."
    - "asyncio.Condition.__module__ == 'asyncio.locks'; __bases__[0].__name__ == '_ContextManagerMixin'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Queue class identity — extra220 namespace
#
# asyncio.Queue(maxsize=-1) does NOT raise on Python 3.14.3 — negative
# maxsize passes through without validation.  Queue(maxsize=0).__class__
# is Queue as expected.
# ---------------------------------------------------------------------------

table asyncio_extra220.queue_class_identity:
  description: "asyncio.Queue class __name__ and __module__ checks in extra220 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio220queueident

  columns: [id, function, args, expected, description]
  rows:
    - [queue_name,   Queue.__name__.__eq__,   ["Queue"],         true, "asyncio.Queue.__name__ == 'Queue'"]
    - [queue_module, Queue.__module__.__eq__, ["asyncio.queues"], true, "asyncio.Queue.__module__ == 'asyncio.queues'"]

invariant asyncio_extra220.queue_base_name:
  description: "asyncio.Queue.__bases__[0].__name__ == '_LoopBoundMixin'"
  category: class_hierarchy
  kind: python_call_eq
  function: "asyncio.Queue.__bases__[0].__name__.__eq__"
  args: ["_LoopBoundMixin"]
  expected: true

invariant asyncio_extra220.queue_maxsize0_class_name:
  description: "asyncio.Queue(maxsize=0).__class__.__name__ == 'Queue'"
  category: identity
  kind: python_call_eq
  function: Queue.__class__.__name__.__eq__
  args: ["type"]
  expected: true

