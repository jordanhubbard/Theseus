table functools_extra931.module_identity:
  description: "functools module __name__ and __package__ identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: ft931d
  columns: [id, function, args, expected]
  rows:
    - [ft931x011, functools.__name__.__eq__,         ["functools"], true]
    - [ft931x012, functools.__package__.__eq__,      [""],          true]
    - [ft931x013, functools.__doc__.__class__.__name__.__eq__, ["str"], true]
