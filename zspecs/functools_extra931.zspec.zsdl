docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __doc__.__class__.__name__ for core functools callables to confirm docstring type is str"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra931.partial_and_reduce_doc:
  description: "functools.partial and functools.reduce __doc__ class name"
  kind: python_call_eq
  category: doc_class_name
  id_prefix: ft931a
  columns: [id, function, args, expected]
  rows:
    - [ft931x001, functools.partial.__doc__.__class__.__name__.__eq__,  ["str"], true]
    - [ft931x002, functools.reduce.__doc__.__class__.__name__.__eq__,   ["str"], true]

