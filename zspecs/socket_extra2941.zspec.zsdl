spec: sk2941
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket: Low-level networking interface"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 643 (sk2941): __neg__, __pos__, __abs__ dict-presence checks for socket types."
    - "socket.AddressFamily, socket.SocketKind, socket.AddressInfo, and socket.MsgFlag are IntFlag subclasses; despite inheriting numeric behaviour from int, none override __neg__, __pos__, or __abs__ in their own __dict__."
    - "socket.socket is a networking file descriptor wrapper; socket.error, socket.herror, socket.gaierror, and socket.timeout are exception classes — none are numeric types."
    - "Verified types: socket.socket, socket.AddressFamily, socket.SocketKind, socket.AddressInfo, socket.MsgFlag, socket.error, socket.herror, socket.gaierror, socket.timeout."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table sk2941.neg:
  description: "socket types __neg__ dict-presence checks; wave 643"
  kind: python_call_eq
  category: dict_contains
