spec: hl3376
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 672 (hl3376): __trunc__, __round__, __index__ dict-presence checks for hashlib types."
    - "Theme: __trunc__/__round__/__index__ dict-presence (math.trunc(x), round(x), operator.index(x))."
    - "All values False — hash objects do not define truncation, rounding, or integer-conversion protocol methods in their own __dict__."
    - "type(hashlib.md5()), type(hashlib.sha1()), type(hashlib.sha256()), type(hashlib.sha512()) all resolve to the same C-level _hashlib.HASH type."
    - "type(hashlib.blake2b(b'')) is _blake2.blake2b — distinct from HASH."
    - "None of the hashlib types define __trunc__, __round__, or __index__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl3376.trunc:
  description: "hashlib types __trunc__ dict-presence checks; wave 672"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: hl3376
  columns: [id, function, args, expected]
  rows:
    - ["hl3376001", operator.contains, [type(hashlib.md5()).__dict__,        "__trunc__"], false]
    - ["hl3376002", operator.contains, [type(hashlib.sha1()).__dict__,       "__trunc__"], false]
    - ["hl3376003", operator.contains, [type(hashlib.sha256()).__dict__,     "__trunc__"], false]
    - ["hl3376004", operator.contains, [type(hashlib.sha512()).__dict__,     "__trunc__"], false]
    - ["hl3376005", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__trunc__"], false]

