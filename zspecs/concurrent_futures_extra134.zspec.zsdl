    - [qn_len,  concurrent.futures.Executor.map.__qualname__.__len__,  [],                          12,   "concurrent.futures.Executor.map.__qualname__.__len__() == 12; verified with Python 3.14.3"]
    - [mod_eq,  concurrent.futures.Executor.map.__module__.__eq__,    ["concurrent.futures._base"], true, "concurrent.futures.Executor.map.__module__ == 'concurrent.futures._base' (len=24); verified with Python 3.14.3"]
    - [mod_len, concurrent.futures.Executor.map.__module__.__len__,    [],                          24,   "concurrent.futures.Executor.map.__module__.__len__() == 24; verified with Python 3.14.3"]

