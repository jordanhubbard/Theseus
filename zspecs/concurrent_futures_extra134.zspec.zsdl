spec: concurrent_futures_extra134
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: concurrent.futures.Executor.map, Executor.submit, and Executor.shutdown method qualnames, modules, and code object attributes. Executor.map.__qualname__=='Executor.map' (len=12); Executor.map.__module__=='concurrent.futures._base' (len=24); Executor.map.__code__.co_argcount==2 (self, fn — iterables and timeout/chunksize/buffersize are keyword-only); Executor.map.__code__.co_varnames.__len__()==8; Executor.submit.__qualname__=='Executor.submit' (len=15); Executor.submit has __code__ (NOT abstract at the Python level); Executor.shutdown.__qualname__=='Executor.shutdown' (len=17); Executor.shutdown.__code__.co_argcount==2 (self, wait). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "Executor.submit does have __code__ in Python 3.14 — it is a regular method that raises NotImplementedError rather than being an abstractmethod decorated function. Executor.submit.__code__.co_argcount==2 (self, fn); co_varnames has len 4 ('self', 'fn', 'args', 'kwargs'). Executor.map.__code__.co_kwonlyargcount==3 ('timeout', 'chunksize', 'buffersize'). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

