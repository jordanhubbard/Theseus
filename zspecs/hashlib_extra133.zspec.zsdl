spec: hashlib_extra133
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra132.zspec.zsdl — covers hashlib.__all__ tuple membership (pbkdf2_hmac/new/file_digest/algorithms_guaranteed/sha256/md5/sha512/sha1/sha224/sha384/blake2b/sha3_256/shake_128) / pbkdf2_hmac function identity (__name__/__qualname__/__module__/__class__.__name__) (table + invariants)."
    - "hashlib_extra131.zspec.zsdl — covers hashlib._hashlib.HASH class-level method_descriptor identity — update/digest/hexdigest/copy __name__ equality / __objclass__.__name__ equality / __class__.__name__ equality via md5().__class__ traversal (table + invariants)."
    - "hashlib_extra130.zspec.zsdl — covers hashlib.pbkdf2_hmac/__class__.__name__/__module__/__qualname__/__name__ equality / scrypt/__class__.__name__/__module__/__qualname__/__name__ equality / pbkdf2_hmac and scrypt name/qualname lengths (table + invariants)."
    - "hashlib_extra129.zspec.zsdl — covers sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512/sha3_224/sha3_384/shake_128/shake_256 constructor __qualname__.__len__() values (table + invariants)."
    - "hashlib_extra126.zspec.zsdl — covers md5().digest/__qualname__.__len__()==11 / hexdigest/__qualname__.__len__()==14 / copy/__qualname__.__len__()==9 / md5().digest_size/__class__.__name__=='int' / md5().block_size/__class__.__name__=='int' / md5().name/__class__.__name__=='str' / md5().digest_size==16 / sha256().digest_size==32 (table + invariants)."
    - "hashlib_extra125.zspec.zsdl — covers md5()/sha256()/sha1().__class__.__name__.__eq__('HASH') / md5().__class__.__module__.__eq__('_hashlib') / md5().__class__.__qualname__.__eq__('HASH') / md5().update/digest/hexdigest/copy __class__.__name__ and __qualname__ equality (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 __class__.__name__=='builtin_function_or_method' and __name__ equality / blake2b/blake2s class identity and __module__=='_blake2' / algorithms_guaranteed.__len__()==14 (table + invariants)."
    - "hashlib_extra98.zspec.zsdl — covers sha3_*/shake_* constructor __qualname__ and __module__ equality / sha3_*/shake_* __class__.__name__=='builtin_function_or_method' / file_digest function identity / hashlib.__all__ class name and length (table + invariants)."
    - "hashlib_extra95.zspec.zsdl — covers hashlib.new/__qualname__ / sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__ and __module__ equality (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior hashlib spec files."
    - "Wave 303 theme: sha3 variant block_size values and class MRO — sha3_256/sha3_512/sha3_224/sha3_384 block_size (Keccak rate bytes) / blake2b/blake2s block_size / sha3_256().__class__.__mro__.__len__()==2 / sha3_256().__class__.__bases__[0].__name__=='object' / sha3_256().__class__.__module__=='_hashlib'."
    - "hashlib.sha3_256().block_size == 136. Keccak rate = 1088 bits = 136 bytes (SHA3-256 rate). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512().block_size == 72. Keccak rate = 576 bits = 72 bytes (SHA3-512 rate). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_224().block_size == 144. Keccak rate = 1152 bits = 144 bytes (SHA3-224 rate). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_384().block_size == 104. Keccak rate = 832 bits = 104 bytes (SHA3-384 rate). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b().block_size == 128. BLAKE2b processes 128-byte blocks (1024-bit rate). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s().block_size == 64. BLAKE2s processes 64-byte blocks (512-bit rate). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_128().block_size == 168. Keccak rate = 1344 bits = 168 bytes (SHAKE128 XOF rate). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_256().block_size == 136. Keccak rate = 1088 bits = 136 bytes (same rate as SHA3-256). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256().__class__.__mro__.__len__() == 2. sha3_256 instances are HASH objects with MRO (HASH, object). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256().__class__.__bases__[0].__name__ == 'object'. HASH directly inherits from object. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256().__class__.__module__ == '_hashlib'. sha3_256 returns a _hashlib.HASH instance; the HASH class lives in the _hashlib extension module. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256().__class__.__name__ == 'HASH'. All sha3_*/shake_* variants produce HASH instances (same as md5/sha256). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: sha3_256().block_size and shake_256().block_size are both 136 bytes (same Keccak rate). The SHA-3 Keccak rate formula is: rate = 1600 - 2*capacity. For SHA3-256 and SHAKE256: capacity=256 bits, rate=1088 bits=136 bytes."
    - "Note: block_size values for sha3 variants differ from md5 (64) and sha256 (64) which use Merkle-Damgard with 512-bit blocks. SHA-3 uses sponge construction with Keccak-1600."
    - "Note: blake2b().block_size==128 and blake2s().block_size==64 reflect BLAKE2b and BLAKE2s internal block sizes (not Keccak rate). blake2b is 1024-bit (128-byte), blake2s is 512-bit (64-byte) block."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha3_256().block_size.__eq__(136)
# hashlib.sha3_512().block_size.__eq__(72)
# hashlib.sha3_224().block_size.__eq__(144)
# hashlib.sha3_384().block_size.__eq__(104)
# hashlib.blake2b().block_size.__eq__(128)
#
# Wave 303 theme: sha3 variant block_size values (Keccak absorption rate).
#
# block_size reflects the Keccak sponge absorption rate in bytes. The rate is
# 1600 - 2*capacity bits. SHA3-256: capacity=256 bits, rate=1088 bits=136 bytes.
# SHA3-512: capacity=512 bits, rate=576 bits=72 bytes. SHA3-224: capacity=224 bits,
# rate=1152 bits=144 bytes. SHA3-384: capacity=384 bits, rate=832 bits=104 bytes.
# blake2b uses 1024-bit (128-byte) blocks internally — not Keccak. No prior hashlib
# spec anchors any sha3_*/blake2 block_size value under hashsha3bs133.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra133.sha3_block_sizes:
  description: "sha3_256().block_size.__eq__(136)==True / sha3_512().block_size.__eq__(72)==True / sha3_224().block_size.__eq__(144)==True / sha3_384().block_size.__eq__(104)==True / blake2b().block_size.__eq__(128)==True — Keccak sponge rates: sha3_256 rate=1088b=136B, sha3_512 rate=576b=72B, sha3_224 rate=1152b=144B, sha3_384 rate=832b=104B; blake2b 128-byte block; first hashsha3bs133 anchor for sha3 block_size values"
  kind: python_call_eq
  category: algorithm_properties
  id_prefix: hashsha3bs133

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_block_size, "sha3_256().block_size.__eq__", [136], true, "sha3_256 block_size=136 (Keccak rate 1088 bits, capacity 256 bits)"]
    - [sha3_512_block_size, "sha3_512().block_size.__eq__", [72],  true, "sha3_512 block_size=72 (Keccak rate 576 bits, capacity 512 bits)"]
    - [sha3_224_block_size, "sha3_224().block_size.__eq__", [144], true, "sha3_224 block_size=144 (Keccak rate 1152 bits, capacity 224 bits)"]
    - [sha3_384_block_size, "sha3_384().block_size.__eq__", [104], true, "sha3_384 block_size=104 (Keccak rate 832 bits, capacity 384 bits)"]
    - [blake2b_block_size,  "blake2b().block_size.__eq__",  [128], true, "blake2b block_size=128 (BLAKE2b 1024-bit block, not Keccak sponge)"]

# ---------------------------------------------------------------------------
# hashlib.blake2s().block_size.__eq__(64)
# hashlib.shake_128().block_size.__eq__(168)
# hashlib.shake_256().block_size.__eq__(136)
# hashlib.sha3_256().__class__.__mro__.__len__()==2
# hashlib.sha3_256().__class__.__bases__[0].__name__.__eq__('object')
#
# Wave 303 theme: blake2s/shake block_size and sha3_256 class MRO structure.
#
# blake2s uses 512-bit (64-byte) blocks — half the size of blake2b. shake_128 has
# the same Keccak rate as SHA3-256 rotated: capacity=128 bits, rate=1344 bits=168 bytes.
# shake_256: capacity=256 bits, rate=1088 bits=136 bytes (same rate as sha3_256).
# sha3_256().__class__ is the HASH type from _hashlib. Its MRO has 2 entries:
# (HASH, object). HASH directly inherits from object, so __bases__[0].__name__=='object'.
# No prior hashlib spec anchors these values under hashsha3bs133.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra133.shake_block_sizes_and_mro:
  description: "blake2s().block_size.__eq__(64)==True / shake_128().block_size.__eq__(168)==True / shake_256().block_size.__eq__(136)==True / sha3_256().__class__.__mro__.__len__()==2 / sha3_256().__class__.__bases__[0].__name__.__eq__('object')==True — blake2s is 64-byte block (512-bit); shake_128 rate=1344b=168B (capacity 128b); shake_256 rate=1088b=136B (same as sha3_256); HASH MRO=(HASH,object) depth 2; first hashsha3bs133 anchor"
  kind: python_call_eq
  category: algorithm_properties
  id_prefix: hashsha3bs133

  columns: [id, function, args, expected, description]
  rows:
    - [blake2s_block_size,   "blake2s().block_size.__eq__",                            [64],      true, "blake2s block_size=64 (BLAKE2s 512-bit block, half of blake2b)"]
    - [shake_128_block_size, "shake_128().block_size.__eq__",                          [168],     true, "shake_128 block_size=168 (Keccak rate 1344 bits, capacity 128 bits)"]
    - [shake_256_block_size, "shake_256().block_size.__eq__",                          [136],     true, "shake_256 block_size=136 (Keccak rate 1088 bits, same as sha3_256)"]
    - [sha3_256_mro_len,     "sha3_256().__class__.__mro__.__len__",                   [],        2,    "sha3_256().__class__ MRO length is 2: (HASH, object) from _hashlib"]
    - [sha3_256_bases_name,  "sha3_256().__class__.__bases__[0].__name__.__eq__",      ["object"],true, "sha3_256().__class__.__bases__[0] is object (HASH directly inherits from object)"]

# ---------------------------------------------------------------------------
# hashlib.sha3_256().__class__.__module__.__eq__('_hashlib')
# hashlib.sha3_256().__class__.__name__.__eq__('HASH')
# hashlib.sha3_512().__class__.__name__.__eq__('HASH')
# hashlib.sha3_256().digest_size.__eq__(32)
# hashlib.sha3_512().digest_size.__eq__(64)
#
# Wave 303 theme: sha3_256 class module/name identity and sha3 digest sizes.
#
# sha3_256().__class__ is the HASH type from _hashlib extension module.
# __module__=='_hashlib' and __name__=='HASH' (same as for md5().__class__, anchored
# in extra125). sha3_256 and sha3_512 share the HASH class — their instances have
# different digest_size values. sha3_256 produces 32-byte (256-bit) digests.
# sha3_512 produces 64-byte (512-bit) digests. These digest sizes differ from
# the block_size values. No prior hashlib spec anchors sha3 digest_size values
# under hashsha3bs133. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra133.sha3_class_and_digest_size:
  description: "sha3_256().__class__.__module__.__eq__('_hashlib')==True / sha3_256().__class__.__name__.__eq__('HASH')==True / sha3_512().__class__.__name__.__eq__('HASH')==True / sha3_256().digest_size.__eq__(32)==True / sha3_512().digest_size.__eq__(64)==True — sha3_256/sha3_512 instances are _hashlib.HASH objects; HASH module is '_hashlib' (C extension); digest_size: sha3_256=32B (256-bit), sha3_512=64B (512-bit); first hashsha3bs133 anchor for sha3 digest sizes"
  kind: python_call_eq
  category: algorithm_properties
  id_prefix: hashsha3bs133

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_class_module, "sha3_256().__class__.__module__.__eq__", ["_hashlib"], true, "sha3_256().__class__.__module__ is '_hashlib' (C extension, same as md5/sha256)"]
    - [sha3_256_class_name,   "sha3_256().__class__.__name__.__eq__",   ["HASH"],     true, "sha3_256().__class__.__name__ is 'HASH' (extra125 anchors md5().__class__.__name__)"]
    - [sha3_512_class_name,   "sha3_512().__class__.__name__.__eq__",   ["HASH"],     true, "sha3_512().__class__.__name__ is 'HASH' (all sha3 variants produce HASH instances)"]
    - [sha3_256_digest_size,  "sha3_256().digest_size.__eq__",          [32],         true, "sha3_256 digest_size=32 (SHA3-256 produces 256-bit=32-byte output)"]
    - [sha3_512_digest_size,  "sha3_512().digest_size.__eq__",          [64],         true, "sha3_512 digest_size=64 (SHA3-512 produces 512-bit=64-byte output)"]

# ---------------------------------------------------------------------------
# hashlib.sha3_256().block_size.__eq__(136) — standalone
#
# hashlib.sha3_256().block_size is 136. SHA3-256 uses the Keccak sponge
# construction with capacity=256 bits and rate=1600-512=1088 bits=136 bytes.
# The block_size attribute exposes the rate as the number of bytes absorbed per
# Keccak permutation round. This is also the 'rate' in the sponge model. No prior
# hashlib spec anchors sha3_256().block_size as a standalone under hashsha3bs133.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra133.sha3_256_block_size_136:
  description: "hashlib.sha3_256().block_size.__eq__(136) == True — SHA3-256 Keccak sponge rate = 1600-2*256=1088 bits=136 bytes; block_size is the rate (bytes absorbed per permutation); contrasts with md5/sha256 (block_size=64, Merkle-Damgard 512-bit block); first standalone under hashsha3bs133"
  category: algorithm_properties
  kind: python_call_eq
  function: "sha3_256().block_size.__eq__"
  args: [136]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_512().block_size.__eq__(72) — standalone
#
# hashlib.sha3_512().block_size is 72. SHA3-512 uses Keccak with capacity=512 bits
# and rate=1600-1024=576 bits=72 bytes. SHA3-512 has the smallest block_size
# (rate) of the four SHA-3 variants because its higher security level (512-bit
# capacity) requires a larger portion of the 1600-bit state to be hidden.
# No prior hashlib spec anchors sha3_512().block_size as a standalone under
# hashsha3bs133. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra133.sha3_512_block_size_72:
  description: "hashlib.sha3_512().block_size.__eq__(72) == True — SHA3-512 Keccak rate = 1600-2*512=576 bits=72 bytes; smallest rate among the four SHA-3 variants because 512-bit capacity maximizes security margin; no prior hashlib spec anchors sha3_512 block_size as standalone; first standalone under hashsha3bs133"
  category: algorithm_properties
  kind: python_call_eq
  function: "sha3_512().block_size.__eq__"
  args: [72]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_256().__class__.__module__.__eq__('_hashlib') — standalone
#
# hashlib.sha3_256().__class__.__module__ is '_hashlib'. sha3_256 is implemented
# in the _hashlib C extension module via OpenSSL's SHA-3 implementation. Unlike
# blake2b and blake2s (which live in the _blake2 extension), all SHA-3 variants
# and the legacy SHA-2/MD5 algorithms share the same HASH class from _hashlib.
# extra125 first anchors md5().__class__.__module__.__eq__('_hashlib'); this spec
# first anchors the same for sha3_256().__class__ under hashsha3bs133.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra133.sha3_256_class_module_hashlib:
  description: "hashlib.sha3_256().__class__.__module__.__eq__('_hashlib') == True — sha3_256 instances use HASH class from _hashlib (OpenSSL SHA-3); contrasts with blake2b/blake2s which use _blake2 module; extra125 anchors md5().__class__.__module__ but not sha3_256; first standalone under hashsha3bs133"
  category: type_identity
  kind: python_call_eq
  function: "sha3_256().__class__.__module__.__eq__"
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.shake_128().block_size.__eq__(168) — standalone
#
# hashlib.shake_128().block_size is 168. SHAKE128 is an extendable-output function
# (XOF) using Keccak with capacity=128 bits and rate=1600-256=1344 bits=168 bytes.
# Its lower capacity (128 bits) results in the highest rate among all SHA-3/SHAKE
# variants — 168 bytes per Keccak permutation. This makes SHAKE128 the fastest
# SHA-3 based function for long outputs. No prior hashlib spec anchors
# shake_128().block_size as a standalone under hashsha3bs133.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra133.shake_128_block_size_168:
  description: "hashlib.shake_128().block_size.__eq__(168) == True — SHAKE128 XOF Keccak rate = 1600-2*128=1344 bits=168 bytes; highest rate among all SHA-3/SHAKE variants (lowest capacity=128 bits); extra129 anchors shake_128 constructor __qualname__.__len__(); first standalone for shake_128 block_size under hashsha3bs133"
  category: algorithm_properties
  kind: python_call_eq
  function: "shake_128().block_size.__eq__"
  args: [168]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_256().__class__.__mro__.__len__()==2 — standalone
#
# hashlib.sha3_256().__class__.__mro__.__len__() is 2. sha3_256 instances are
# of the HASH type (from _hashlib). The HASH C extension class has a 2-entry MRO:
# (HASH, object). HASH directly inherits from object — there are no intermediate
# Python base classes. This is the same MRO depth as C extension types like
# struct.Struct (anchored in extra93: Struct.__mro__.__len__()==2). No prior
# hashlib spec anchors sha3_256().__class__.__mro__.__len__() as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra133.sha3_256_class_mro_len_2:
  description: "hashlib.sha3_256().__class__.__mro__.__len__() == 2 — HASH class MRO is (HASH, object); 2-entry MRO means HASH directly inherits from object with no intermediate base classes; same MRO depth as struct.Struct (also 2); no prior hashlib spec anchors sha3_256().__class__.__mro__.__len__() as standalone; first standalone under hashsha3bs133"
  category: type_identity
  kind: python_call_eq
  function: "sha3_256().__class__.__mro__.__len__"
  args: []
  expected: 2

