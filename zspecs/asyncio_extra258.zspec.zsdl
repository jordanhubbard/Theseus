table asyncio_extra258.task_class_identity:
  description: "asyncio.Task(len=4) class identity — inherits from Future(len=6); defined in _asyncio(len=8) C extension; cancel/result share qualname length 11; cancelled/exception share qualname length 14; done is shortest qualname (len=9); add_done_callback is longest (len=22); verified with Python 3.14.3"
