    - [t_name_eq,          Task.__name__.__eq__,                             ["Task"],                    true, "asyncio.Task.__name__ == 'Task'; verified with Python 3.14.3"]
    - [t_name_len,         Task.__name__.__len__,                            [],                          4,    "asyncio.Task.__name__.__len__() == 4; verified with Python 3.14.3"]
    - [t_mod_eq,           Task.__module__.__eq__,                           ["_asyncio"],                true, "asyncio.Task.__module__ == '_asyncio' — Task is in the C extension module; verified with Python 3.14.3"]
