spec: asyncio_extra258
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-task.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Task and Future documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_asynciomodule.c"
  notes:
    - "asyncio.Task.__name__ == 'Task' (len=4); __module__ == '_asyncio' (len=8) — Task is implemented in the C extension module _asyncio, not asyncio.tasks."
    - "asyncio.Task.__bases__[0].__name__ == 'Future' (len=6) — Task inherits directly from Future."
    - "asyncio.Future.__name__ == 'Future' (len=6); __module__ == '_asyncio' (len=8); __bases__[0].__name__ == 'object' (len=6) — Future inherits from object."
    - "Task.cancel.__qualname__ == 'Task.cancel' (len=11); Task.cancelled.__qualname__ == 'Task.cancelled' (len=14); Task.done.__qualname__ == 'Task.done' (len=9)."
    - "Task.result.__qualname__ == 'Task.result' (len=11); Task.exception.__qualname__ == 'Task.exception' (len=14); Task.add_done_callback.__qualname__ == 'Task.add_done_callback' (len=22)."
    - "cancel and result share qualname length 11; cancelled and exception share qualname length 14; done is shortest (len=9); add_done_callback is longest (len=22)."
    - "Both Task and Future have __module__ == '_asyncio' — both are implemented in the same C extension."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

