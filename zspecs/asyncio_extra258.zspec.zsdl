    - [t_base_eq,          "Task.__bases__[0].__name__.__eq__",              ["Future"],                  true, "asyncio.Task.__bases__[0].__name__ == 'Future' — Task inherits from Future; verified with Python 3.14.3"]
    - [t_base_len,         "Task.__bases__[0].__name__.__len__",             [],                          6,    "asyncio.Task.__bases__[0].__name__.__len__() == 6; verified with Python 3.14.3"]
    - [t_cancel_name_eq,   Task.cancel.__name__.__eq__,                      ["cancel"],                  true, "asyncio.Task.cancel.__name__ == 'cancel'; verified with Python 3.14.3"]
    - [t_cancel_name_len,  Task.cancel.__name__.__len__,                     [],                          6,    "asyncio.Task.cancel.__name__.__len__() == 6; verified with Python 3.14.3"]
    - [t_cancel_qn_eq,     Task.cancel.__qualname__.__eq__,                  ["Task.cancel"],             true, "asyncio.Task.cancel.__qualname__ == 'Task.cancel'; verified with Python 3.14.3"]
    - [t_cancel_qn_len,    Task.cancel.__qualname__.__len__,                 [],                          11,   "asyncio.Task.cancel.__qualname__.__len__() == 11 — same as result qualname length; verified with Python 3.14.3"]
    - [t_cled_name_eq,     Task.cancelled.__name__.__eq__,                   ["cancelled"],               true, "asyncio.Task.cancelled.__name__ == 'cancelled'; verified with Python 3.14.3"]
