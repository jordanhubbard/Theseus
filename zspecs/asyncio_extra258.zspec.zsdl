table asyncio_extra258.future_class_identity:
  description: "asyncio.Future(len=6) class identity — inherits from object(len=6); defined in _asyncio(len=8) — same C extension module as Task; Future.__name__ and Future.__bases__[0].__name__ both have len=6; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: async258f

  columns: [id, function, args, expected, description]
  rows:
    - [f_name_eq,    Future.__name__.__eq__,                   ["Future"],    true, "asyncio.Future.__name__ == 'Future'; verified with Python 3.14.3"]
    - [f_name_len,   Future.__name__.__len__,                  [],            6,    "asyncio.Future.__name__.__len__() == 6; verified with Python 3.14.3"]
    - [f_mod_eq,     Future.__module__.__eq__,                 ["_asyncio"],  true, "asyncio.Future.__module__ == '_asyncio' — Future is in the same C extension module as Task; verified with Python 3.14.3"]
    - [f_mod_len,    Future.__module__.__len__,                [],            8,    "asyncio.Future.__module__.__len__() == 8 — same module length as Task.__module__; verified with Python 3.14.3"]
    - [f_base_eq,    "Future.__bases__[0].__name__.__eq__",    ["object"],    true, "asyncio.Future.__bases__[0].__name__ == 'object' — Future inherits directly from object; verified with Python 3.14.3"]
    - [f_base_len,   "Future.__bases__[0].__name__.__len__",   [],            6,    "asyncio.Future.__bases__[0].__name__.__len__() == 6 — same length as Future.__name__ itself; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra258
