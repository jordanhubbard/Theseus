invariant asyncio_extra258.task_base_is_future:
  description: "asyncio.Task.__bases__[0].__name__.__eq__('Future') returns True — Task inherits directly from Future(len=6); the full inheritance chain is Task -> Future -> object; both Task and Future are implemented in the _asyncio C extension module; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Task.__bases__[0].__name__.__eq__"
  args: ["Future"]
  expected: true

invariant asyncio_extra258.task_add_done_callback_longest_qualname:
  description: "asyncio.Task.add_done_callback.__qualname__.__len__() == 22 — 'Task.add_done_callback' (len=22) is the longest method qualname among all six Task methods; cancelled and exception tie at 14; cancel and result tie at 11; done is shortest at 9; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Task.add_done_callback.__qualname__.__len__
  args: []
  expected: 22
