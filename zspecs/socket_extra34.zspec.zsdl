spec: socket_extra34
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra33.zspec.zsdl — covers htonl/htons/ntohl/ntohs __name__.__len__()==5; create_server/gethostbyname __name__.__len__()==13; socket.__dict__['family'/'type'] descriptor class name len (8)."
    - "socket_extra32.zspec.zsdl — covers recvfrom/sendto/makefile/recvfrom_into/recv_into/connect_ex __qualname__.__len__(); getaddrinfo/getnameinfo/setdefaulttimeout/getdefaulttimeout/create_connection __name__.__len__()."
    - "socket_extra31.zspec.zsdl — covers close/setblocking/getsockname __qualname__/__qualname__.__len__(); fileno/detach/shutdown/sendall __qualname__.__len__()."
    - "socket_extra29.zspec.zsdl — covers setsockopt/getsockopt/settimeout/getpeername __qualname__.__len__()/__name__.__len__()."
    - "socket_extra28.zspec.zsdl — covers bind/connect/listen/accept/send/recv __qualname__/__qualname__.__len__()/__name__.__len__()."
  notes:
    - "This spec extends socket through socket_extra33; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: __name__.__len__() for bind(4)/connect(7)/listen(6)/accept(6)/send(4)/recv(4) (extra28); for setsockopt(10)/getsockopt(10)/settimeout(10)/getpeername(11) (extra29); all __qualname__.__len__() for close/setblocking/getsockname/fileno/detach/shutdown/sendall (extra31); all __qualname__.__len__() for recvfrom/sendto/makefile/recvfrom_into/recv_into/connect_ex (extra32)."
    - "This spec covers: socket.socket.close.__name__.__len__() (NOVEL — extra31 covers close.__qualname__.__len__()==12 but not __name__.__len__(); 'close' is 5 chars); socket.socket.setblocking/__name__.__len__() (NOVEL — extra31 covers qualname only; 'setblocking' is 11 chars); socket.socket.getsockname/__name__.__len__() (NOVEL — extra31 covers qualname only; 'getsockname' is 11 chars); socket.socket.fileno/__name__.__len__() (NOVEL — extra31 covers qualname only; 'fileno' is 6 chars); socket.socket.detach/__name__.__len__() (NOVEL — extra31 covers qualname only; 'detach' is 6 chars); socket.socket.shutdown/__name__.__len__() (NOVEL — extra31 covers qualname only; 'shutdown' is 8 chars); socket.socket.sendall/__name__.__len__() (NOVEL — extra31 covers qualname only; 'sendall' is 7 chars)."
    - "socket.socket.close.__name__ == 'close' (len 5). extra31 covers close.__qualname__.__len__()==12 ('socket.close') but no prior spec checks close.__name__.__len__(). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.setblocking.__name__ == 'setblocking' (len 11). extra31 covers setblocking.__qualname__.__len__()==18 but not __name__.__len__(). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.getsockname.__name__ == 'getsockname' (len 11). extra31 covers getsockname.__qualname__.__len__()==18 but not __name__.__len__(). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.fileno.__name__ == 'fileno' (len 6). extra31 covers fileno.__qualname__.__len__()==13 but not __name__.__len__(). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.detach.__name__ == 'detach' (len 6). extra31 covers detach.__qualname__.__len__()==13 but not __name__.__len__(). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.shutdown.__name__ == 'shutdown' (len 8). extra31 covers shutdown.__qualname__.__len__()==15 but not __name__.__len__(). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.sendall.__name__ == 'sendall' (len 7). extra31 covers sendall.__qualname__.__len__()==14 but not __name__.__len__(). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket method __name__.__len__() for close/setblocking/getsockname
#
# extra31 covers __qualname__.__len__() for close(12)/setblocking(18)/
# getsockname(18) but does NOT check __name__.__len__(). The __name__ of a
# method_descriptor is the bare method name without the class prefix:
#   close.__name__       == 'close'       (len 5)
#   setblocking.__name__ == 'setblocking' (len 11)
#   getsockname.__name__ == 'getsockname' (len 11)
# ---------------------------------------------------------------------------

table socket_extra34.socket_method_name_lens_set1:
  description: "socket.socket close/setblocking/getsockname __name__.__len__() — novel; extra31 covers qualname lens only for these methods"
  kind: python_call_eq
  category: function_names
  id_prefix: smnl34a

  columns: [id, function, args, expected]
  rows:
    - [close_name_len,       "socket.close.__name__.__len__",       [], 5]
    - [setblocking_name_len, "socket.setblocking.__name__.__len__", [], 11]
    - [getsockname_name_len, "socket.getsockname.__name__.__len__", [], 11]

# ---------------------------------------------------------------------------
# socket.socket method __name__.__len__() for fileno/detach/shutdown/sendall
#
# extra31 covers __qualname__.__len__() for fileno(13)/detach(13)/
# shutdown(15)/sendall(14) but does NOT check __name__.__len__().
#   fileno.__name__   == 'fileno'   (len 6)
#   detach.__name__   == 'detach'   (len 6)
#   shutdown.__name__ == 'shutdown' (len 8)
#   sendall.__name__  == 'sendall'  (len 7)
# ---------------------------------------------------------------------------

table socket_extra34.socket_method_name_lens_set2:
  description: "socket.socket fileno/detach/shutdown/sendall __name__.__len__() — novel; extra31 covers qualname lens only for these methods"
  kind: python_call_eq
  category: function_names
  id_prefix: smnl34b

  columns: [id, function, args, expected]
  rows:
    - [fileno_name_len,   "socket.fileno.__name__.__len__",   [], 6]
    - [detach_name_len,   "socket.detach.__name__.__len__",   [], 6]
    - [shutdown_name_len, "socket.shutdown.__name__.__len__", [], 8]
    - [sendall_name_len,  "socket.sendall.__name__.__len__",  [], 7]
