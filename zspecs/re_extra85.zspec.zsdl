spec: re_extra85
version: ">=3.13"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends all prior re specs through re_extra84."
    - "Prior specs covered: Pattern/Match class identity; Pattern/Match __dict__ membership; Pattern/Match method qualnames; re.error/__name__; re module-level function __code__ co_name and co_argcount; Pattern/Match method __qualname__ values and lengths; PatternError hierarchy; re.compile/__qualname__/__module__; re.match/sub/findall/split __qualname__; Match.start/end class name and qualname; re module function __module__ values; Pattern/Match method __doc__.__class__.__name__; Match method __qualname__ values and lengths; re module function __code__ attributes; Pattern/Match identity (__name__/__module__/__bases__/__mro__); Pattern/Match __dict__.__class__.__name__; Pattern/Match __qualname__ and length; PatternError __name__ and __module__; Pattern/Match method __qualname__ string equality."
    - "This spec covers: re.PatternError.__name__; re.PatternError.__module__; re.PatternError.__qualname__; re.PatternError.__bases__[0].__name__; re.PatternError.__mro__.__len__(); re.error.__name__ (same object as PatternError — aliases to 'PatternError' in Python 3.13+); re.PatternError.__qualname__.__len__(); re.PatternError.__name__.__len__(); re.PatternError.__module__.__len__(); re.IGNORECASE.__class__.__name__; re.MULTILINE.__class__.__name__; re.DOTALL.__class__.__name__; re.RegexFlag.__name__; re.RegexFlag.__module__."
    - "re.PatternError was introduced in Python 3.13 as the canonical name; re.error is now an alias for the same class."
    - "re.PatternError.__name__ == 'PatternError' — length 12."
    - "re.PatternError.__module__ == 're' — length 2."
    - "re.PatternError.__qualname__ == 'PatternError' — length 12."
    - "re.PatternError.__bases__[0].__name__ == 'Exception' — single base."
    - "re.PatternError.__mro__.__len__() == 4 — [PatternError, Exception, BaseException, object]."
    - "re.error.__name__ == 'PatternError' — re.error is the same object as re.PatternError (verified: re.error is re.PatternError == True)."
    - "re.IGNORECASE.__class__.__name__ == 'RegexFlag' — IntFlag member."
    - "re.MULTILINE.__class__.__name__ == 'RegexFlag' — IntFlag member."
    - "re.DOTALL.__class__.__name__ == 'RegexFlag' — IntFlag member."
    - "re.RegexFlag.__name__ == 'RegexFlag' — the IntFlag subclass name."
    - "re.RegexFlag.__module__ == 're' — defined in the re module."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.PatternError class identity: __name__, __module__, __qualname__
# PatternError is the canonical name since Python 3.13; re.error is an alias.
# All three are simple strings on this exception class.
# Not covered in any prior re spec at this specific table.
# ---------------------------------------------------------------------------

table re_extra85.PatternError_identity:
  description: "re.PatternError __name__, __module__, __qualname__ string equality"
  kind: python_call_eq
  category: class_identity
  id_prefix: reextra85

  columns: [id, function, args, expected]
  rows:
    - [pe_name,     PatternError.__name__.__eq__,     ["PatternError"], true]
    - [pe_module,   PatternError.__module__.__eq__,   ["re"],           true]
    - [pe_qualname, PatternError.__qualname__.__eq__, ["PatternError"], true]
    - [pe_base0,    "PatternError.__bases__[0].__name__.__eq__", ["Exception"], true]

# ---------------------------------------------------------------------------
# re.PatternError hierarchy: __mro__.__len__() and string lengths
# MRO length == 4: [PatternError, Exception, BaseException, object].
# __qualname__ and __name__ both have length 12; __module__ has length 2.
# Not covered in any prior re spec at this specific table.
# ---------------------------------------------------------------------------

table re_extra85.PatternError_mro_and_lengths:
  description: "re.PatternError __mro__.__len__() and attribute string lengths"
  kind: python_call_eq
  category: class_identity
  id_prefix: reextra85

  columns: [id, function, args, expected]
  rows:
    - [pe_mro_len,    PatternError.__mro__.__len__,      [],  4]
    - [pe_qn_len,     PatternError.__qualname__.__len__, [],  12]
    - [pe_name_len,   PatternError.__name__.__len__,     [],  12]
    - [pe_module_len, PatternError.__module__.__len__,   [],  2]

# ---------------------------------------------------------------------------
# re.error alias identity: re.error.__name__ == 'PatternError'
# re.error is the same object as re.PatternError in Python 3.13+.
# Verifying via __name__ confirms the alias points to the renamed class.
# Also covers re.IGNORECASE and re.MULTILINE __class__.__name__.
# Not covered in any prior re spec at this specific table.
# ---------------------------------------------------------------------------

table re_extra85.error_alias_and_flags:
  description: "re.error.__name__ (alias check); re.IGNORECASE/MULTILINE __class__.__name__"
  kind: python_call_eq
  category: class_identity
  id_prefix: reextra85

  columns: [id, function, args, expected]
  rows:
    - [error_name,        error.__name__.__eq__,                      ["PatternError"], true]
    - [ignorecase_cls,    IGNORECASE.__class__.__name__.__eq__,       ["RegexFlag"],    true]
    - [multiline_cls,     MULTILINE.__class__.__name__.__eq__,        ["RegexFlag"],    true]
    - [dotall_cls,        DOTALL.__class__.__name__.__eq__,           ["RegexFlag"],    true]

# ---------------------------------------------------------------------------
# re.RegexFlag class identity: __name__, __module__
# RegexFlag is the IntFlag subclass for all re module flag constants.
# Not covered in any prior re spec at this specific table.
# ---------------------------------------------------------------------------

table re_extra85.RegexFlag_identity:
  description: "re.RegexFlag __name__ and __module__"
  kind: python_call_eq
  category: class_identity
  id_prefix: reextra85

  columns: [id, function, args, expected]
  rows:
    - [rgf_name,   RegexFlag.__name__.__eq__,   ["RegexFlag"], true]
    - [rgf_module, RegexFlag.__module__.__eq__, ["re"],        true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra85.PatternError.name:
  description: "re.PatternError.__name__ == 'PatternError' (canonical name since Python 3.13)"
  category: class_identity
  kind: python_call_eq
  function: PatternError.__name__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra85.PatternError.mro_len:
  description: "re.PatternError.__mro__.__len__() == 4 ([PatternError, Exception, BaseException, object])"
  category: class_identity
  kind: python_call_eq
  function: PatternError.__mro__.__len__
  args: []
  expected: 4

invariant re_extra85.PatternError.qualname_len:
  description: "re.PatternError.__qualname__.__len__() == 12 ('PatternError' has 12 chars)"
  category: class_identity
  kind: python_call_eq
  function: PatternError.__qualname__.__len__
  args: []
  expected: 12

invariant re_extra85.error_alias.name:
  description: "re.error.__name__ == 'PatternError' (re.error is re.PatternError in Python 3.13+)"
  category: class_identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra85.RegexFlag.name:
  description: "re.RegexFlag.__name__ == 'RegexFlag' (IntFlag subclass for re flag constants)"
  category: class_identity
  kind: python_call_eq
  function: RegexFlag.__name__.__eq__
  args: ["RegexFlag"]
  expected: true
