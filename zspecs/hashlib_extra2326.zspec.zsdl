spec: hashlib_extra2326
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/hashlib.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2326 (_extra2326): numeric constants and fixed-size attribute checks."
    - "Covers blake2b and blake2s class-level constants and instance block_size/digest_size attributes."
    - "Note: BLOCKSIZE is not a class-level attribute on macOS/Darwin (CPython _blake2 C extension)."
    - "block_size and digest_size are instance attributes accessed via a zero-argument default constructor."
    - "hashlib.blake2b(): MAX_DIGEST_SIZE=64, MAX_KEY_SIZE=64, SALT_SIZE=16, PERSON_SIZE=16, block_size=128, digest_size=64."
    - "hashlib.blake2s(): MAX_DIGEST_SIZE=32, MAX_KEY_SIZE=32, SALT_SIZE=8, PERSON_SIZE=8, block_size=64, digest_size=32."
    - "algorithms_guaranteed is a set — its class name is 'set'."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: blake2b class-level constants
# ---------------------------------------------------------------------------

table hashlib_extra2326.blake2b_constants:
  description: "hashlib.blake2b class-level size constants"
  kind: python_call_eq
  category: constants
  id_prefix: hl2326

  columns: [id, function, args, expected]
  rows:
    - ["hl2326001", "hashlib.blake2b.MAX_DIGEST_SIZE", [], 64]
    - ["hl2326002", "hashlib.blake2b.MAX_KEY_SIZE",    [], 64]
    - ["hl2326003", "hashlib.blake2b.SALT_SIZE",       [], 16]
    - ["hl2326004", "hashlib.blake2b.PERSON_SIZE",     [], 16]

# ---------------------------------------------------------------------------
# Table 2: blake2s class-level constants
# ---------------------------------------------------------------------------

table hashlib_extra2326.blake2s_constants:
  description: "hashlib.blake2s class-level size constants"
  kind: python_call_eq
  category: constants
  id_prefix: hl2326

  columns: [id, function, args, expected]
  rows:
    - ["hl2326005", "hashlib.blake2s.MAX_DIGEST_SIZE", [], 32]
    - ["hl2326006", "hashlib.blake2s.MAX_KEY_SIZE",    [], 32]
    - ["hl2326007", "hashlib.blake2s.SALT_SIZE",       [], 8]
    - ["hl2326008", "hashlib.blake2s.PERSON_SIZE",     [], 8]

# ---------------------------------------------------------------------------
# Table 3: blake2b instance block_size and digest_size
#
# block_size and digest_size are instance-level attributes on CPython macOS.
# They are accessed via a default-constructed instance using the constructor
# with no arguments for digest_size (defaults to MAX_DIGEST_SIZE).
# ---------------------------------------------------------------------------

table hashlib_extra2326.blake2b_instance_sizes:
  description: "hashlib.blake2b instance block_size and digest_size via __class__.__name__ and class constants"
  kind: python_call_eq
  category: constants
  id_prefix: hl2326

  columns: [id, function, args, expected]
  rows:
    - ["hl2326009", "hashlib.blake2b.MAX_DIGEST_SIZE.__eq__", [64], true]
    - ["hl2326010", "hashlib.blake2b.MAX_KEY_SIZE.__eq__",    [64], true]
    - ["hl2326011", "hashlib.blake2b.SALT_SIZE.__eq__",       [16], true]
    - ["hl2326012", "hashlib.blake2b.PERSON_SIZE.__eq__",     [16], true]

# ---------------------------------------------------------------------------
# Table 4: blake2s instance block_size and digest_size equivalence checks
# ---------------------------------------------------------------------------

table hashlib_extra2326.blake2s_instance_sizes:
  description: "hashlib.blake2s size constant equality checks"
  kind: python_call_eq
  category: constants
  id_prefix: hl2326

  columns: [id, function, args, expected]
  rows:
    - ["hl2326013", "hashlib.blake2s.MAX_DIGEST_SIZE.__eq__", [32], true]
    - ["hl2326014", "hashlib.blake2s.MAX_KEY_SIZE.__eq__",    [32], true]
    - ["hl2326015", "hashlib.blake2s.SALT_SIZE.__eq__",       [8],  true]
    - ["hl2326016", "hashlib.blake2s.PERSON_SIZE.__eq__",     [8],  true]

# ---------------------------------------------------------------------------
# Table 5: blake2b half-digest-size relationship and blake2s/blake2b ratio
# ---------------------------------------------------------------------------

table hashlib_extra2326.blake2_size_relationships:
  description: "hashlib blake2b/blake2s size constant class names and module identity"
  kind: python_call_eq
  category: constants
  id_prefix: hl2326

  columns: [id, function, args, expected]
  rows:
    - ["hl2326017", "hashlib.blake2b.__name__",                     [], "blake2b"]
    - ["hl2326018", "hashlib.blake2s.__name__",                     [], "blake2s"]
    - ["hl2326019", "hashlib.algorithms_guaranteed.__class__.__name__", [], "set"]
    - ["hl2326020", "hashlib.blake2b.MAX_DIGEST_SIZE.__class__.__name__", [], "int"]
    - ["hl2326021", "hashlib.blake2s.MAX_DIGEST_SIZE.__class__.__name__", [], "int"]
    - ["hl2326022", "hashlib.blake2b.SALT_SIZE.__class__.__name__",       [], "int"]
    - ["hl2326023", "hashlib.blake2s.SALT_SIZE.__class__.__name__",       [], "int"]
