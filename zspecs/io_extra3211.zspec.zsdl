spec: io3211
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io: Core tools for working with streams"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 661 (io3211): __and__, __or__, __xor__ dict-presence checks for io types."
    - "Classes covered: io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.FileIO, io.BytesIO, io.StringIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.BufferedRWPair, io.TextIOWrapper."
    - "No io class defines __and__ in its own __dict__: stream I/O classes are not integer types and do not implement the bitwise AND operator."
    - "No io class defines __or__ in its own __dict__: stream I/O classes are not integer types and do not implement the bitwise OR operator."
    - "No io class defines __xor__ in its own __dict__: stream I/O classes are not integer types and do not implement the bitwise XOR operator."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __and__ dict-presence — operator.contains(Cls.__dict__, '__and__')
#
# No io class defines __and__ in its own __dict__; all false.
# io stream classes are sequential I/O abstractions, not integer types.
# ---------------------------------------------------------------------------

