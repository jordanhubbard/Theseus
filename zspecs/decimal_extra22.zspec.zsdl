spec: decimal_extra22
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec extends decimal_extra through decimal_extra21."
    - "decimal_extra21 covers __qualname__ for Decimal.from_float, sqrt, ln, log10, exp, __add__, __mul__, __str__."
    - "No prior spec covers __qualname__ for Decimal.__sub__, __truediv__, __neg__, __abs__, quantize, to_eng_string."
    - "All Decimal class methods are defined directly on Decimal; __qualname__ takes the form 'Decimal.<method>'."
    - "Focus: decimal.Decimal class method __qualname__ values for arithmetic and formatting methods not yet covered."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal class method __qualname__ values
#
# decimal_extra21 recorded qualname for from_float, sqrt, ln, log10, exp,
# __add__, __mul__, __str__.  The following six methods are not yet covered:
# __sub__, __truediv__, __neg__, __abs__, quantize, to_eng_string.
# All are defined directly on the Decimal class; qualname is 'Decimal.<name>'.
# ---------------------------------------------------------------------------

table decimal_extra22.method_qualnames:
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [sub,          Decimal.__sub__.__qualname__.__eq__,       ["Decimal.__sub__"],       true, "Decimal.__sub__.__qualname__ == 'Decimal.__sub__'"]
    - [truediv,      Decimal.__truediv__.__qualname__.__eq__,   ["Decimal.__truediv__"],   true, "Decimal.__truediv__.__qualname__ == 'Decimal.__truediv__'"]
    - [neg,          Decimal.__neg__.__qualname__.__eq__,       ["Decimal.__neg__"],       true, "Decimal.__neg__.__qualname__ == 'Decimal.__neg__'"]
    - [abs,          Decimal.__abs__.__qualname__.__eq__,       ["Decimal.__abs__"],       true, "Decimal.__abs__.__qualname__ == 'Decimal.__abs__'"]
    - [quantize,     Decimal.quantize.__qualname__.__eq__,      ["Decimal.quantize"],      true, "Decimal.quantize.__qualname__ == 'Decimal.quantize'"]
    - [to_eng_string, Decimal.to_eng_string.__qualname__.__eq__, ["Decimal.to_eng_string"], true, "Decimal.to_eng_string.__qualname__ == 'Decimal.to_eng_string'"]

# ---------------------------------------------------------------------------
# Method __qualname__ length invariants
# ---------------------------------------------------------------------------

invariant decimal_extra22.sub.qualname_len:
  description: "len(decimal.Decimal.__sub__.__qualname__) == 15 — 'Decimal.__sub__' is 15 chars"
  category: method_identity
  kind: python_call_eq
  function: Decimal.__sub__.__qualname__.__len__
  args: []
  expected: 15

invariant decimal_extra22.truediv.qualname_len:
  description: "len(decimal.Decimal.__truediv__.__qualname__) == 19 — 'Decimal.__truediv__' is 19 chars"
  category: method_identity
  kind: python_call_eq
  function: Decimal.__truediv__.__qualname__.__len__
  args: []
  expected: 19

invariant decimal_extra22.neg.qualname_len:
  description: "len(decimal.Decimal.__neg__.__qualname__) == 15 — 'Decimal.__neg__' is 15 chars"
  category: method_identity
  kind: python_call_eq
  function: Decimal.__neg__.__qualname__.__len__
  args: []
  expected: 15

invariant decimal_extra22.abs.qualname_len:
  description: "len(decimal.Decimal.__abs__.__qualname__) == 15 — 'Decimal.__abs__' is 15 chars"
  category: method_identity
  kind: python_call_eq
  function: Decimal.__abs__.__qualname__.__len__
  args: []
  expected: 15

invariant decimal_extra22.quantize.qualname_len:
  description: "len(decimal.Decimal.quantize.__qualname__) == 16 — 'Decimal.quantize' is 16 chars"
  category: method_identity
  kind: python_call_eq
  function: Decimal.quantize.__qualname__.__len__
  args: []
  expected: 16

invariant decimal_extra22.to_eng_string.qualname_len:
  description: "len(decimal.Decimal.to_eng_string.__qualname__) == 21 — 'Decimal.to_eng_string' is 21 chars"
  category: method_identity
  kind: python_call_eq
  function: Decimal.to_eng_string.__qualname__.__len__
  args: []
  expected: 21
