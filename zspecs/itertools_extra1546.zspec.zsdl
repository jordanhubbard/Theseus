spec: itertools_extra1546
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "Wave 550 theme: bitwise operator dict-presence checks via __dict__.__contains__ for itertools classes."
    - "itertools.chain.__dict__.__contains__ returns False for all bitwise dunder methods. chain is a C extension type; it is an iterator combiner with no bitwise semantics. Verified with Python 3.14."
    - "itertools.count.__dict__.__contains__ returns False for all bitwise dunder methods. count is a C extension type that produces arithmetic sequences; it does not define bitwise operators. Verified with Python 3.14."
    - "itertools.cycle.__dict__.__contains__ returns False for all bitwise dunder methods. cycle is a C extension type; it defines no bitwise operators. Verified with Python 3.14."
    - "itertools.accumulate.__dict__.__contains__ returns False for all bitwise dunder methods. accumulate is a C extension type; bitwise operators are not in its own __dict__. Verified with Python 3.14."
    - "itertools.combinations.__dict__.__contains__ returns False for all bitwise dunder methods. combinations is a C extension type; no bitwise operators in its __dict__. Verified with Python 3.14."
    - "Bitwise dunders checked: __and__, __or__, __xor__, __invert__, __lshift__, __rshift__, __rand__, __ror__, __rxor__, __rlshift__, __rrshift__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.chain — bitwise operator dict-presence checks
#
# Wave 550 theme: chain is a C extension type (Modules/itertoolsmodule.c).
# Its own __dict__ does not contain any bitwise dunder methods. chain is
# a sequence combiner; bitwise operations are semantically inapplicable.
# ---------------------------------------------------------------------------

table itertools_extra1546.chain_bitwise_dict_contains:
  description: "itertools.chain.__dict__.__contains__ returns False for all bitwise dunder methods; wave 550; new to extra1546"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1546ch

  columns: [id, function, args, expected, description]
  rows:
    - ["it1546ch001",
       "chain.__dict__.__contains__",
       ["__and__"],
       false,
       "itertools.chain.__dict__.__contains__('__and__') == False — chain is a C extension type; its __dict__ does not define __and__; wave 550; new to extra1546"]
    - ["it1546ch002",
       "chain.__dict__.__contains__",
       ["__or__"],
       false,
       "itertools.chain.__dict__.__contains__('__or__') == False — chain does not define __or__ in its own class __dict__; wave 550; new to extra1546"]
    - ["it1546ch003",
       "chain.__dict__.__contains__",
       ["__xor__"],
       false,
       "itertools.chain.__dict__.__contains__('__xor__') == False — chain does not define __xor__ in its own class __dict__; wave 550; new to extra1546"]
    - ["it1546ch004",
       "chain.__dict__.__contains__",
       ["__invert__"],
       false,
       "itertools.chain.__dict__.__contains__('__invert__') == False — chain does not define __invert__ in its own class __dict__; wave 550; new to extra1546"]
    - ["it1546ch005",
       "chain.__dict__.__contains__",
       ["__lshift__"],
       false,
       "itertools.chain.__dict__.__contains__('__lshift__') == False — chain does not define __lshift__ in its own class __dict__; wave 550; new to extra1546"]
    - ["it1546ch006",
       "chain.__dict__.__contains__",
       ["__rshift__"],
       false,
       "itertools.chain.__dict__.__contains__('__rshift__') == False — chain does not define __rshift__ in its own class __dict__; wave 550; new to extra1546"]
    - ["it1546ch007",
       "chain.__dict__.__contains__",
       ["__rand__"],
       false,
       "itertools.chain.__dict__.__contains__('__rand__') == False — chain does not define __rand__ in its own class __dict__; wave 550; new to extra1546"]
    - ["it1546ch008",
       "chain.__dict__.__contains__",
       ["__ror__"],
       false,
       "itertools.chain.__dict__.__contains__('__ror__') == False — chain does not define __ror__ in its own class __dict__; wave 550; new to extra1546"]
    - ["it1546ch009",
       "chain.__dict__.__contains__",
       ["__rxor__"],
       false,
       "itertools.chain.__dict__.__contains__('__rxor__') == False — chain does not define __rxor__ in its own class __dict__; wave 550; new to extra1546"]
    - ["it1546ch010",
       "chain.__dict__.__contains__",
       ["__rlshift__"],
       false,
       "itertools.chain.__dict__.__contains__('__rlshift__') == False — chain does not define __rlshift__ in its own class __dict__; wave 550; new to extra1546"]
    - ["it1546ch011",
       "chain.__dict__.__contains__",
       ["__rrshift__"],
       false,
       "itertools.chain.__dict__.__contains__('__rrshift__') == False — chain does not define __rrshift__ in its own class __dict__; wave 550; new to extra1546"]

# ---------------------------------------------------------------------------
# Table 2: itertools.count — bitwise operator dict-presence checks
#
# Wave 550 theme: count is a C extension type that produces an unbounded
# arithmetic counting sequence (count(start, step)). Although count works
# with numeric values, it does not define bitwise operators in its own
# __dict__; it is an iterator type, not an integer subclass.
# ---------------------------------------------------------------------------

table itertools_extra1546.count_bitwise_dict_contains:
  description: "itertools.count.__dict__.__contains__ returns False for all bitwise dunder methods; wave 550; new to extra1546"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1546co

  columns: [id, function, args, expected, description]
  rows:
    - ["it1546co001",
       "count.__dict__.__contains__",
       ["__and__"],
       false,
