spec: hashlib_extra143
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra142.zspec.zsdl — covers hashlib.blake2b and blake2s class constants (SALT_SIZE, MAX_DIGEST_SIZE, MAX_KEY_SIZE, PERSON_SIZE) / blake2b/blake2s __doc__ identity and length / sha3/shake constructor __doc__ lengths (table + invariants)."
    - "hashlib_extra141.zspec.zsdl — covers hashlib SHA constructor __doc__.__class__.__name__ and __doc__.__len__() / hashlib.__spec__ attribute identity / hashlib.new.__doc__.__len__()==147 / hashlib.file_digest.__doc__.__len__()==417."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 constructor __class__.__name__ and __name__ equality / blake2b/blake2s class identity / new/__class__.__name__=='function' / algorithms_guaranteed.__len__()==14."
    - "hashlib_extra98.zspec.zsdl — covers hashlib.sha3_*/shake_* constructor __qualname__ and __module__ equality / sha3_*/shake_* __class__.__name__=='builtin_function_or_method' / file_digest function identity."
    - "hashlib_extra97.zspec.zsdl — covers hashlib.algorithms_guaranteed membership / algorithms_available membership / new/__qualname__/__len__()."
    - "hashlib_extra96.zspec.zsdl — covers hashlib.__name__/__package__/__spec__/__loader__/__doc__ module identity / sha256/sha512/sha1/md5 __module__ cross-checks."
    - "hashlib_extra95.zspec.zsdl — covers hashlib.new/__qualname__ / sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__ and __module__."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra142."
    - "Wave 289 theme: hashlib.md5/sha1/sha224/sha384 __doc__ lengths and identity / pbkdf2_hmac/scrypt __doc__ lengths / md5/sha1/sha224/sha384/pbkdf2_hmac/scrypt __qualname__ lengths / __module__ equality across constructor groups."
    - "hashlib.md5.__doc__.__len__() == 63. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__doc__.__len__() == 64. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha224.__doc__.__len__() == 66. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha384.__doc__.__len__() == 66. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__doc__.__len__() == 66. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__doc__.__len__() == 66. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__doc__.__len__() == 91. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__doc__.__len__() == 46. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__qualname__ == 'openssl_md5' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__qualname__ == 'openssl_sha1' (len 12). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha224.__qualname__ == 'openssl_sha224' (len 14). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha384.__qualname__ == 'openssl_sha384' (len 14). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__qualname__ == 'scrypt' (len 6). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__module__ == hashlib.sha1.__module__ == '_hashlib' (True). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha224.__module__ == hashlib.sha384.__module__ == '_hashlib' (True). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__module__ == hashlib.scrypt.__module__ == '_hashlib' (True). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: md5 and sha1 have different doc lengths (63 vs 64): 'md5' is 3 chars, 'sha1' is 4 chars, so the template 'Returns a {name} hash object; optionally initialized with a string' produces 63 vs 64 chars. sha224/sha256/sha384/sha512 all share 66-char docstrings (each is a 6-char name)."
    - "Note: pbkdf2_hmac.__doc__ (91 chars) describes the PKCS #5 v2.0 standard reference. scrypt.__doc__ (46 chars) is very short — it does not describe parameters inline."
    - "Note: md5/sha1/sha224/sha384/sha256/sha512/pbkdf2_hmac/scrypt all have __module__ == '_hashlib' — all are implemented in the _hashlib C extension backed by OpenSSL."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.md5.__doc__.__len__()==63
# hashlib.sha1.__doc__.__len__()==64
# hashlib.sha224.__doc__.__len__()==66
# hashlib.sha384.__doc__.__len__()==66
# hashlib.sha256.__doc__.__len__()==66
# hashlib.sha512.__doc__.__len__()==66
#
# Wave 289 theme: md5/sha1/sha224/sha384/sha256/sha512 __doc__ lengths.
#
# The docstring template is 'Returns a {name} hash object; optionally
# initialized with a string'. md5 (3-char name) → 63; sha1 (4-char name) → 64;
# sha224/sha256/sha384/sha512 (6-char names) → 66. No prior hashlib spec anchors
# md5.__doc__.__len__() or sha1.__doc__.__len__() under hashdoc143.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra143.sha_constructor_doc_lengths:
  description: "hashlib.md5/__doc__/__len__()==63 / sha1/__doc__/__len__()==64 / sha224/__doc__/__len__()==66 / sha384/__doc__/__len__()==66 / sha256/__doc__/__len__()==66 / sha512/__doc__/__len__()==66 — template 'Returns a {name} hash object; optionally initialized with a string'; md5 (3-char name) gives 63; sha1 (4-char) gives 64; 6-char names give 66; sha224/sha256/sha384/sha512 all share 66-char docs; no prior hashlib spec anchors md5 or sha1 __doc__.__len__() under hashdoc143"
  kind: python_call_eq
  category: doc_lengths
  id_prefix: hashdoc143

  columns: [id, function, args, expected, description]
  rows:
    - [md5_doc_len,    md5.__doc__.__len__,    [], 63, "hashlib.md5.__doc__.__len__() is 63 (3-char name 'md5' in template)"]
    - [sha1_doc_len,   sha1.__doc__.__len__,   [], 64, "hashlib.sha1.__doc__.__len__() is 64 (4-char name 'sha1' in template)"]
    - [sha224_doc_len, sha224.__doc__.__len__, [], 66, "hashlib.sha224.__doc__.__len__() is 66 (6-char name 'sha224' in template)"]
    - [sha384_doc_len, sha384.__doc__.__len__, [], 66, "hashlib.sha384.__doc__.__len__() is 66 (6-char name 'sha384' in template, same as sha224)"]
    - [sha256_doc_len, sha256.__doc__.__len__, [], 66, "hashlib.sha256.__doc__.__len__() is 66 (6-char name 'sha256' in template)"]
    - [sha512_doc_len, sha512.__doc__.__len__, [], 66, "hashlib.sha512.__doc__.__len__() is 66 (6-char name 'sha512' in template)"]

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__doc__.__len__()==91
# hashlib.scrypt.__doc__.__len__()==46
# hashlib.pbkdf2_hmac.__doc__.__class__.__name__.__eq__('str')
# hashlib.scrypt.__doc__.__class__.__name__.__eq__('str')
#
# Wave 289 theme: pbkdf2_hmac and scrypt __doc__ lengths.
#
# pbkdf2_hmac.__doc__ (91 chars) references PKCS #5 v2.0 by name and uses HMAC
# as the pseudorandom function. scrypt.__doc__ (46 chars) is extremely short
# relative to the function's complexity — it does not describe the N/r/p/maxmem
# parameters inline. No prior hashlib spec anchors these lengths under hashdoc143.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra143.kdf_doc_lengths:
  description: "hashlib.pbkdf2_hmac/__doc__/__class__.__name__.__eq__('str')==True / pbkdf2_hmac/__doc__/__len__()==91 / scrypt/__doc__/__class__.__name__.__eq__('str')==True / scrypt/__doc__/__len__()==46 — pbkdf2_hmac.__doc__ (91 chars) names PKCS #5 v2.0; scrypt.__doc__ (46 chars) is unusually short for its complexity; both are from the _hashlib C extension; no prior hashlib spec anchors these under hashdoc143"
  kind: python_call_eq
  category: doc_lengths
  id_prefix: hashdoc143

  columns: [id, function, args, expected, description]
  rows:
    - [pbkdf2_doc_class, pbkdf2_hmac.__doc__.__class__.__name__.__eq__, ["str"], true, "hashlib.pbkdf2_hmac.__doc__ is a str (C-level docstring from _hashlib extension)"]
    - [pbkdf2_doc_len,   pbkdf2_hmac.__doc__.__len__,                   [],      91,   "hashlib.pbkdf2_hmac.__doc__.__len__() is 91 (references PKCS #5 v2.0 and HMAC)"]
    - [scrypt_doc_class, scrypt.__doc__.__class__.__name__.__eq__,      ["str"], true, "hashlib.scrypt.__doc__ is a str (C-level docstring from _hashlib extension)"]
    - [scrypt_doc_len,   scrypt.__doc__.__len__,                        [],      46,   "hashlib.scrypt.__doc__.__len__() is 46 (very short relative to function complexity; no inline parameter descriptions)"]

# ---------------------------------------------------------------------------
# hashlib.md5.__qualname__.__len__()==11 ('openssl_md5')
# hashlib.sha1.__qualname__.__len__()==12 ('openssl_sha1')
# hashlib.sha224.__qualname__.__len__()==14 ('openssl_sha224')
# hashlib.sha384.__qualname__.__len__()==14 ('openssl_sha384')
# hashlib.pbkdf2_hmac.__qualname__.__len__()==11 ('pbkdf2_hmac')
# hashlib.scrypt.__qualname__.__len__()==6 ('scrypt')
#
# Wave 289 theme: __qualname__ lengths for md5/sha1/sha224/sha384/pbkdf2_hmac/scrypt.
#
# hashlib.md5/__qualname__ is 'openssl_md5' (11 chars) — the openssl_ prefix
# distinguishes these from legacy pure-Python implementations. sha224 and sha384
# share 14-char qualnames. pbkdf2_hmac.__qualname__ ('pbkdf2_hmac', 11) matches
# the exported name. scrypt.__qualname__ ('scrypt', 6) is the shortest.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra143.constructor_qualname_lengths:
  description: "hashlib.md5/__qualname__.__len__()==11 / sha1/__qualname__.__len__()==12 / sha224/__qualname__.__len__()==14 / sha384/__qualname__.__len__()==14 / pbkdf2_hmac/__qualname__.__len__()==11 / scrypt/__qualname__.__len__()==6 — md5/sha1/sha224/sha384 qualnames use 'openssl_' prefix from _hashlib extension; pbkdf2_hmac and scrypt qualnames match their exported names; sha224 and sha384 share 14-char qualnames; no prior hashlib spec anchors these under hashdoc143"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: hashdoc143

  columns: [id, function, args, expected, description]
  rows:
    - [md5_qualname_len,      md5.__qualname__.__len__,      [], 11, "hashlib.md5.__qualname__.__len__() is 11 ('openssl_md5' from _hashlib C extension)"]
    - [sha1_qualname_len,     sha1.__qualname__.__len__,     [], 12, "hashlib.sha1.__qualname__.__len__() is 12 ('openssl_sha1' from _hashlib C extension)"]
    - [sha224_qualname_len,   sha224.__qualname__.__len__,   [], 14, "hashlib.sha224.__qualname__.__len__() is 14 ('openssl_sha224')"]
    - [sha384_qualname_len,   sha384.__qualname__.__len__,   [], 14, "hashlib.sha384.__qualname__.__len__() is 14 ('openssl_sha384', same as sha224)"]
    - [pbkdf2_qualname_len,   pbkdf2_hmac.__qualname__.__len__, [], 11, "hashlib.pbkdf2_hmac.__qualname__.__len__() is 11 ('pbkdf2_hmac' matches exported name)"]
    - [scrypt_qualname_len,   scrypt.__qualname__.__len__,   [], 6,  "hashlib.scrypt.__qualname__.__len__() is 6 ('scrypt' — shortest qualname in this group)"]

# ---------------------------------------------------------------------------
# hashlib.md5.__doc__.__len__()==63 — standalone
#
# hashlib.md5.__doc__.__len__() is 63. The md5 constructor docstring follows the
# template 'Returns a md5 hash object; optionally initialized with a string'
# where 'md5' is 3 chars. The 3-char name makes this the shortest of the six
# main hash constructor docstrings (md5=63, sha1=64, sha224/sha256/sha384/sha512=66).
# No prior hashlib spec anchors md5.__doc__.__len__() as a standalone under hashdoc143.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra143.md5_doc_len_63:
  description: "hashlib.md5.__doc__.__len__() == 63 — md5 constructor docstring is 63 chars; template 'Returns a md5 hash object; optionally initialized with a string'; 3-char name 'md5' makes this the shortest of the six main hash constructor docstrings; no prior hashlib spec anchors this as a standalone; first standalone under hashdoc143"
  category: doc_lengths
  kind: python_call_eq
  function: md5.__doc__.__len__
  args: []
  expected: 63

# ---------------------------------------------------------------------------
# hashlib.sha1.__doc__.__len__()==64 — standalone
#
# hashlib.sha1.__doc__.__len__() is 64. The sha1 constructor docstring is
# 'Returns a sha1 hash object; optionally initialized with a string' — one
# char longer than md5 because 'sha1' is 4 chars vs 'md5' is 3 chars.
# sha1 (64) is the second-shortest after md5 (63). No prior hashlib spec
# anchors sha1.__doc__.__len__() as a standalone under hashdoc143.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra143.sha1_doc_len_64:
  description: "hashlib.sha1.__doc__.__len__() == 64 — sha1 constructor docstring is 64 chars; 'sha1' is 4 chars (one more than 'md5'), making this one char longer than md5.__doc__; second-shortest of the six main hash constructor docstrings; no prior hashlib spec anchors this as a standalone; first standalone under hashdoc143"
  category: doc_lengths
  kind: python_call_eq
  function: sha1.__doc__.__len__
  args: []
  expected: 64

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__doc__.__len__()==91 — standalone
#
# hashlib.pbkdf2_hmac.__doc__.__len__() is 91. The full docstring is
# 'Password based key derivation function 2 (PKCS #5 v2.0) with HMAC as
# pseudorandom function.' This is the longest of the KDF function docstrings
# and explicitly references the PKCS standard. No prior hashlib spec anchors
# pbkdf2_hmac.__doc__.__len__() as a standalone under hashdoc143.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra143.pbkdf2_hmac_doc_len_91:
  description: "hashlib.pbkdf2_hmac.__doc__.__len__() == 91 — pbkdf2_hmac docstring is 91 chars ('Password based key derivation function 2 (PKCS #5 v2.0) with HMAC as pseudorandom function.'); explicitly references PKCS #5 v2.0; longest of the KDF function docstrings; no prior hashlib spec anchors this as a standalone; first standalone under hashdoc143"
  category: doc_lengths
  kind: python_call_eq
  function: pbkdf2_hmac.__doc__.__len__
  args: []
  expected: 91

# ---------------------------------------------------------------------------
# hashlib.scrypt.__doc__.__len__()==46 — standalone
#
# hashlib.scrypt.__doc__.__len__() is 46. The full docstring is
# 'scrypt password-based key derivation function.' — a single sentence that
# does not enumerate the N, r, p, or maxmem parameters inline. This brevity
# is striking given scrypt's complexity relative to other KDFs. No prior
# hashlib spec anchors scrypt.__doc__.__len__() as a standalone under hashdoc143.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra143.scrypt_doc_len_46:
  description: "hashlib.scrypt.__doc__.__len__() == 46 — scrypt docstring is 46 chars ('scrypt password-based key derivation function.'); does not enumerate N/r/p/maxmem parameters; unusually short for a function with 4+ complex parameters; no prior hashlib spec anchors this as a standalone; first standalone under hashdoc143"
  category: doc_lengths
  kind: python_call_eq
  function: scrypt.__doc__.__len__
  args: []
  expected: 46

