spec: decimal_extra32
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra31.zspec.zsdl — covers Decimal.to_integral_value(25)/as_integer_ratio(24)/as_tuple(16) __qualname__.__len__(); Decimal.is_nan(14)/is_zero(15)/is_finite(17)/is_signed(17)/is_normal(17)/is_infinite(19)/is_subnormal(20) __qualname__.__len__()."
    - "decimal_extra30.zspec.zsdl — covers Context method __qualname__.__len__() for a second batch: min/max/copy/plus/minus/divmod/quantize/remainder/normalize/to_sci_string/to_eng_string/logical_and/fma/exp/ln/log10."
    - "decimal_extra29.zspec.zsdl — covers Context method __qualname__.__len__() for add/subtract/multiply/divide/sqrt/power/compare/abs; Decimal.compare/sqrt/ln/log10/normalize/fma/exp/remainder_near __qualname__.__len__()."
    - "decimal_extra26.zspec.zsdl — covers decimal.MAX_PREC.__class__.__name__ == 'int' and MAX_EMAX.__class__.__name__ == 'int' (equality checks, not __len__())."
  notes:
    - "This spec extends decimal_extra31.zspec.zsdl."
    - "Prior specs collectively covered: Decimal/Context/__module__/__name__/__qualname__ and all lengths; exception class __name__/__qualname__/__module__/__mro__.__len__(); getcontext/setcontext/localcontext __name__/__qualname__/__module__ and lengths; all Decimal method __qualname__.__len__() for all arithmetic/comparison/predicate/utility methods; all Context method __qualname__.__len__() for all batches (add/abs/sqrt/power/divide/compare/subtract/multiply in extra29; min/max/copy/plus/minus/divmod/quantize/remainder/normalize/to_sci_string/to_eng_string/logical_and/fma/exp/ln/log10 in extra30); exception __name__.__len__() for all major exceptions."
    - "This spec covers: Context.to_integral_value/__qualname__.__len__()==25 (NOVEL — extra30 covers quantize/remainder/normalize/to_sci_string/to_eng_string but NOT to_integral_value; no prior decimal spec checks Context.to_integral_value/__qualname__.__len__()); Context.to_integral_exact/__qualname__.__len__()==25 (NOVEL — same reasoning; tied with to_integral_value at 25, the longest Context method qualnames); Context.is_nan(14)/is_zero(15)/is_finite(17)/is_signed(17)/is_normal(17)/is_infinite(19)/is_subnormal(20) __qualname__.__len__() (NOVEL — decimal_extra31 covers the Decimal.is_* predicate qualname lengths but NOT Context.is_* qualname lengths; no prior decimal spec checks any Context.is_* qualname length); decimal.MAX_PREC.__class__.__name__.__len__()==3 (NOVEL — extra26 checks MAX_PREC.__class__.__name__=='int' via equality but not __len__()); decimal.MAX_EMAX.__class__.__name__.__len__()==3 (NOVEL); decimal.MIN_EMIN.__class__.__name__.__len__()==3 (NOVEL)."
    - "Context.to_integral_value.__qualname__ == 'Context.to_integral_value' — len 25. extra30 covers Context.quantize(16)/remainder(17)/normalize(17) but NOT to_integral_value. Tied with to_integral_exact at 25, the longest Context method qualname. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Context.to_integral_exact.__qualname__ == 'Context.to_integral_exact' — len 25. Tied with to_integral_value (25). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Context.is_nan.__qualname__ == 'Context.is_nan' — len 14. decimal_extra31 covers Decimal.is_nan (14) but NOT Context.is_nan. Both have len 14 (same method, different class prefix). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Context.is_zero.__qualname__ == 'Context.is_zero' — len 15. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Context.is_finite.__qualname__ == 'Context.is_finite' — len 17. Equals Context.is_signed/is_normal (17). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Context.is_signed.__qualname__ == 'Context.is_signed' — len 17. Equals Context.is_finite/is_normal (17). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Context.is_normal.__qualname__ == 'Context.is_normal' — len 17. Equals Context.is_finite/is_signed (17). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Context.is_infinite.__qualname__ == 'Context.is_infinite' — len 19. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Context.is_subnormal.__qualname__ == 'Context.is_subnormal' — len 20. Longest Context.is_* method qualname. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "decimal.MAX_PREC.__class__.__name__.__len__() == 3 — MAX_PREC is an int; 'int' has 3 characters. extra26 verifies __class__.__name__=='int' (equality) but not __len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "decimal.MAX_EMAX.__class__.__name__.__len__() == 3 — same reasoning as MAX_PREC. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "decimal.MIN_EMIN.__class__.__name__.__len__() == 3 — MIN_EMIN is also an int. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Context.to_integral_value and Context.to_integral_exact __qualname__.__len__()
#
# decimal_extra30 covers Context.quantize(16)/remainder(17)/normalize(17)
# but does NOT cover to_integral_value or to_integral_exact. Both have
# qualnames of length 25 — the longest Context method qualnames, matching
# Decimal.to_integral_value (25) from decimal_extra31 in length but with
# the 'Context.' prefix (8 chars) instead of 'Decimal.' (8 chars).
#
#   Context.to_integral_value  -> 'Context.to_integral_value'  -> 25
#   Context.to_integral_exact  -> 'Context.to_integral_exact'  -> 25
#
# Both novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant decimal_extra32.Context.to_integral_value_qualname_len:
  description: "len(decimal.Context.to_integral_value.__qualname__) == 25 — 'Context.to_integral_value' has 25 characters; tied for longest Context method qualname; novel (extra30 covers quantize/remainder/normalize but not to_integral_value)"
  category: method_qualname_lengths
  kind: python_call_eq
  function: Context.to_integral_value.__qualname__.__len__
  args: []
  expected: 25

invariant decimal_extra32.Context.to_integral_exact_qualname_len:
  description: "len(decimal.Context.to_integral_exact.__qualname__) == 25 — 'Context.to_integral_exact' has 25 characters; tied with to_integral_value at 25; novel"
  category: method_qualname_lengths
  kind: python_call_eq
  function: Context.to_integral_exact.__qualname__.__len__
  args: []
  expected: 25

# ---------------------------------------------------------------------------
# Context.is_* predicate method __qualname__.__len__()
#
# decimal_extra31 covers Decimal.is_* predicate qualname lengths (is_nan(14),
# is_zero(15), is_finite(17), is_signed(17), is_normal(17), is_infinite(19),
# is_subnormal(20)) but no prior decimal spec checks any Context.is_* qualname
# length. Context mirrors these predicates but with the 'Context.' prefix.
#
# Note: 'Context.' is 8 chars and 'Decimal.' is 8 chars — the prefix lengths
# are equal, so all Context.is_* qualnames are the same length as their
# Decimal.is_* counterparts. They are novel as Context-level checks.
#
#   Context.is_nan       -> 'Context.is_nan'       -> 14
#   Context.is_zero      -> 'Context.is_zero'      -> 15
#   Context.is_finite    -> 'Context.is_finite'    -> 17
#   Context.is_signed    -> 'Context.is_signed'    -> 17
#   Context.is_normal    -> 'Context.is_normal'    -> 17
#   Context.is_infinite  -> 'Context.is_infinite'  -> 19
#   Context.is_subnormal -> 'Context.is_subnormal' -> 20 (longest)
#
# All novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra32.Context_is_predicate_qualname_lens:
  description: "decimal.Context is_* predicate method __qualname__.__len__(): is_nan(14)/is_zero(15)/is_finite(17)/is_signed(17)/is_normal(17)/is_infinite(19)/is_subnormal(20) — all novel; extra31 covers Decimal.is_* lengths but not Context.is_* lengths"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: dcipq32

  columns: [id, function, args, expected]
  rows:
    - [is_nan,       Context.is_nan.__qualname__.__len__,       [], 14]
    - [is_zero,      Context.is_zero.__qualname__.__len__,      [], 15]
    - [is_finite,    Context.is_finite.__qualname__.__len__,    [], 17]
    - [is_signed,    Context.is_signed.__qualname__.__len__,    [], 17]
    - [is_normal,    Context.is_normal.__qualname__.__len__,    [], 17]
    - [is_infinite,  Context.is_infinite.__qualname__.__len__,  [], 19]
    - [is_subnormal, Context.is_subnormal.__qualname__.__len__, [], 20]

# ---------------------------------------------------------------------------
# decimal.MAX_PREC, MAX_EMAX, MIN_EMIN __class__.__name__.__len__()
#
# decimal_extra26 verifies MAX_PREC.__class__.__name__ == 'int' and
# MAX_EMAX.__class__.__name__ == 'int' via equality checks, but no prior
# decimal spec checks __class__.__name__.__len__() for any of these module
# constants. All three (MAX_PREC, MAX_EMAX, MIN_EMIN) are plain Python ints,
# so their type name 'int' has 3 characters. MIN_EMIN has not been checked
# for its class name at all in any prior spec. All three length checks are novel.
#
#   MAX_PREC.__class__.__name__.__len__()  == 3  ('int')
#   MAX_EMAX.__class__.__name__.__len__()  == 3  ('int')
#   MIN_EMIN.__class__.__name__.__len__()  == 3  ('int')
#
# All novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra32.module_constant_class_name_lens:
  description: "decimal.MAX_PREC/MAX_EMAX/MIN_EMIN __class__.__name__.__len__() == 3 — all are plain int instances; 'int' has 3 chars; novel (extra26 checks equality == 'int' but not __len__())"
  kind: python_call_eq
  category: module_constants
  id_prefix: dccnl32

  columns: [id, function, args, expected]
  rows:
    - [MAX_PREC, MAX_PREC.__class__.__name__.__len__, [], 3]
    - [MAX_EMAX, MAX_EMAX.__class__.__name__.__len__, [], 3]
    - [MIN_EMIN, MIN_EMIN.__class__.__name__.__len__, [], 3]
