spec: struct_extra286
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module __all__ and function class names"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c, Lib/struct.py"
  notes:
    - "struct.__all__ has exactly 8 members: calcsize, pack, unpack, pack_into, unpack_from, iter_unpack, Struct, error"
    - "struct pack/unpack/calcsize/pack_into/unpack_from/iter_unpack are builtin_function_or_method"
    - "struct.Struct and struct.error are type objects"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table struct_extra286.struct_function_class_names:
  description: "struct function __class__.__name__ for pack, unpack, calcsize, pack_into, unpack_from, iter_unpack"
  kind: python_call_eq
  category: identity
  id_prefix: struct286a

  columns: [id, function, args, expected, description]
  rows:
    - [struct286a001, struct.pack.__class__.__name__, [], "builtin_function_or_method", "struct.pack is builtin_function_or_method"]
    - [struct286a002, struct.unpack.__class__.__name__, [], "builtin_function_or_method", "struct.unpack is builtin_function_or_method"]
    - [struct286a003, struct.calcsize.__class__.__name__, [], "builtin_function_or_method", "struct.calcsize is builtin_function_or_method"]
    - [struct286a004, struct.pack_into.__class__.__name__, [], "builtin_function_or_method", "struct.pack_into is builtin_function_or_method"]
    - [struct286a005, struct.unpack_from.__class__.__name__, [], "builtin_function_or_method", "struct.unpack_from is builtin_function_or_method"]
    - [struct286a006, struct.iter_unpack.__class__.__name__, [], "builtin_function_or_method", "struct.iter_unpack is builtin_function_or_method"]

table struct_extra286.struct_all_membership_and_types:
  description: "struct.__all__ membership checks and Struct/error class names"
  kind: python_call_eq
  category: identity
  id_prefix: struct286b

  columns: [id, function, args, expected, description]
  rows:
    - [struct286b001, struct.__all__.__contains__, ["calcsize"], true, "calcsize in struct.__all__"]
    - [struct286b002, struct.__all__.__contains__, ["pack"], true, "pack in struct.__all__"]
    - [struct286b003, struct.__all__.__contains__, ["unpack"], true, "unpack in struct.__all__"]
    - [struct286b004, struct.__all__.__contains__, ["pack_into"], true, "pack_into in struct.__all__"]
    - [struct286b005, struct.__all__.__contains__, ["unpack_from"], true, "unpack_from in struct.__all__"]
    - [struct286b006, struct.__all__.__contains__, ["iter_unpack"], true, "iter_unpack in struct.__all__"]
    - [struct286b007, struct.__all__.__contains__, ["Struct"], true, "Struct in struct.__all__"]
    - [struct286b008, struct.__all__.__contains__, ["error"], true, "error in struct.__all__"]
    - [struct286b009, struct.Struct.__class__.__name__, [], "type", "struct.Struct is a type"]
    - [struct286b010, struct.error.__class__.__name__, [], "type", "struct.error is a type"]

invariant struct_extra286.struct_all_len:
  description: "struct.__all__ has exactly 8 elements"
  category: identity
  kind: python_call_eq
  function: struct.__all__.__len__
  args: []
  expected: 8

invariant struct_extra286.struct_doc_class:
  description: "struct.Struct.__doc__ is a str"
  category: identity
  kind: python_call_eq
  function: struct.Struct.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant struct_extra286.struct_pack_class:
  description: "struct.pack is a builtin_function_or_method"
  category: identity
  kind: python_call_eq
  function: struct.pack.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant struct_extra286.struct_calcsize_class:
  description: "struct.calcsize is a builtin_function_or_method"
  category: identity
  kind: python_call_eq
  function: struct.calcsize.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
