spec: io_extra269
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/textio.c"
  notes:
    - "IncrementalNewlineDecoder.__module__ is '_io' (the C extension), not 'io'."
    - "TextIOBase.__bases__ contains _io._TextIOBase first, then io.IOBase; __name__ of the first base is '_TextIOBase'."
    - "TextIOBase.read.__qualname__ and readline.__qualname__ are '_TextIOBase.read' and '_TextIOBase.readline' — the C extension defines them."
    - "UnsupportedOperation inherits from both OSError and ValueError (in that order)."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# IncrementalNewlineDecoder — class identity
# ---------------------------------------------------------------------------

invariant io_extra269.IncrementalNewlineDecoder.name:
  description: "IncrementalNewlineDecoder.__name__ == 'IncrementalNewlineDecoder'"
  category: identity
  kind: python_call_eq
  function: IncrementalNewlineDecoder.__name__.__eq__
  args: ["IncrementalNewlineDecoder"]
  expected: true

invariant io_extra269.IncrementalNewlineDecoder.module:
  description: "IncrementalNewlineDecoder.__module__ == '_io' (C extension)"
  category: identity
  kind: python_call_eq
  function: IncrementalNewlineDecoder.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra269.IncrementalNewlineDecoder.base:
  description: "IncrementalNewlineDecoder sole base is object"
  category: identity
  kind: python_call_eq
  function: IncrementalNewlineDecoder.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# TextIOBase — class identity and method qualnames
# ---------------------------------------------------------------------------

invariant io_extra269.TextIOBase.name:
  description: "TextIOBase.__name__ == 'TextIOBase'"
  category: identity
  kind: python_call_eq
  function: TextIOBase.__name__.__eq__
  args: ["TextIOBase"]
  expected: true

invariant io_extra269.TextIOBase.module:
  description: "TextIOBase.__module__ == 'io'"
  category: identity
  kind: python_call_eq
  function: TextIOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra269.TextIOBase.base0_name:
  description: "TextIOBase first base class __name__ is '_TextIOBase' (from _io C extension)"
  category: identity
  kind: python_call_eq
  function: TextIOBase.__bases__[0].__name__.__eq__
  args: ["_TextIOBase"]
  expected: true

invariant io_extra269.TextIOBase.read_qualname:
  description: "TextIOBase.read.__qualname__ == '_TextIOBase.read'"
  category: identity
  kind: python_call_eq
  function: TextIOBase.read.__qualname__.__eq__
  args: ["_TextIOBase.read"]
  expected: true

invariant io_extra269.TextIOBase.readline_qualname:
  description: "TextIOBase.readline.__qualname__ == '_TextIOBase.readline'"
  category: identity
  kind: python_call_eq
  function: TextIOBase.readline.__qualname__.__eq__
  args: ["_TextIOBase.readline"]
  expected: true

# ---------------------------------------------------------------------------
# UnsupportedOperation — exception identity
# ---------------------------------------------------------------------------

invariant io_extra269.UnsupportedOperation.name:
  description: "UnsupportedOperation.__name__ == 'UnsupportedOperation'"
  category: identity
  kind: python_call_eq
  function: UnsupportedOperation.__name__.__eq__
  args: ["UnsupportedOperation"]
  expected: true

invariant io_extra269.UnsupportedOperation.module:
  description: "UnsupportedOperation.__module__ == 'io'"
  category: identity
  kind: python_call_eq
  function: UnsupportedOperation.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra269.UnsupportedOperation.base0_name:
  description: "UnsupportedOperation first base class is OSError"
  category: identity
  kind: python_call_eq
  function: UnsupportedOperation.__bases__[0].__name__.__eq__
  args: ["OSError"]
  expected: true

invariant io_extra269.UnsupportedOperation.base1_name:
  description: "UnsupportedOperation second base class is ValueError"
  category: identity
  kind: python_call_eq
  function: UnsupportedOperation.__bases__[1].__name__.__eq__
  args: ["ValueError"]
  expected: true
