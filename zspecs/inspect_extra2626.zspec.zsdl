spec: inspect_extra2626
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 622 (_extra2626): __length_hint__, __missing__, and __reversed__ dict-presence checks for inspect module types."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
    - "__length_hint__ is absent from all inspect types tested (Parameter, BoundArguments, Signature, FullArgSpec). These are introspection helper classes, not iterators — all False."
    - "__missing__ is a dict-subclass hook; none of the inspect types subclass dict, so all return False."
    - "__reversed__ enables custom reversed() iteration; none of the inspect types define it in their own __dict__ — all False."
    - "inspect.FullArgSpec is a namedtuple subclass; namedtuples inherit from tuple and do not define __length_hint__, __missing__, or __reversed__ in their own __dict__."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __length_hint__ dict-presence for inspect introspection types
#
# __length_hint__ provides an estimated length for iterators. inspect types
# (Parameter, BoundArguments, Signature, FullArgSpec) are introspection
# helpers — not iterators — and none define __length_hint__ in their own
# __dict__. All return False.
# ---------------------------------------------------------------------------

table inspect_extra2626.length_hint_absent:
  description: "inspect types do not define __length_hint__ in their own __dict__ — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2626

  columns: [id, function, args, expected]
  rows:
    - ["in2626001", "inspect.Parameter.__dict__.__contains__",      ["__length_hint__"], false]
    - ["in2626002", "inspect.BoundArguments.__dict__.__contains__", ["__length_hint__"], false]
    - ["in2626003", "inspect.Signature.__dict__.__contains__",      ["__length_hint__"], false]
    - ["in2626004", "inspect.FullArgSpec.__dict__.__contains__",    ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# Table 2: __missing__ dict-presence for inspect introspection types
#
# __missing__ is called by dict.__getitem__ when a key is absent; it is
# only meaningful for dict subclasses. inspect.Parameter, BoundArguments,
# Signature, and FullArgSpec are not dict subclasses, so none define
# __missing__ in their own __dict__. All return False.
# ---------------------------------------------------------------------------

table inspect_extra2626.missing_absent:
  description: "inspect types do not define __missing__ in their own __dict__ — none are dict subclasses"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2626

  columns: [id, function, args, expected]
  rows:
    - ["in2626005", "inspect.Parameter.__dict__.__contains__",      ["__missing__"], false]
    - ["in2626006", "inspect.BoundArguments.__dict__.__contains__", ["__missing__"], false]
    - ["in2626007", "inspect.Signature.__dict__.__contains__",      ["__missing__"], false]
    - ["in2626008", "inspect.FullArgSpec.__dict__.__contains__",    ["__missing__"], false]

# ---------------------------------------------------------------------------
# Table 3: __reversed__ dict-presence for inspect introspection types
#
# __reversed__ enables custom reversed() iteration for bidirectional
# sequence types. inspect types are not sequences; none define __reversed__
# in their own __dict__ — all False.
# ---------------------------------------------------------------------------

table inspect_extra2626.reversed_absent:
  description: "inspect types do not define __reversed__ in their own __dict__ — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2626

  columns: [id, function, args, expected]
  rows:
    - ["in2626009",  "inspect.Parameter.__dict__.__contains__",      ["__reversed__"], false]
    - ["in2626010", "inspect.BoundArguments.__dict__.__contains__", ["__reversed__"], false]
    - ["in2626011", "inspect.Signature.__dict__.__contains__",      ["__reversed__"], false]
    - ["in2626012", "inspect.FullArgSpec.__dict__.__contains__",    ["__reversed__"], false]

# ---------------------------------------------------------------------------
# Table 4: Combined absence summary — all three dunders absent from all types
#
# Cross-check confirming that none of the four inspect types define any of
# the three container-protocol dunders. Assigns a unique dunder per type
# in a first pass, then cross-checks the remaining combinations to confirm
# the pattern holds across the full set.
# ---------------------------------------------------------------------------

table inspect_extra2626.container_protocol_absent_summary:
  description: "inspect types define none of __length_hint__, __missing__, __reversed__ — cross-type summary"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2626

  columns: [id, function, args, expected]
  rows:
    - ["in2626013", "inspect.Parameter.__dict__.__contains__",      ["__length_hint__"], false]
    - ["in2626014", "inspect.BoundArguments.__dict__.__contains__", ["__missing__"],     false]
    - ["in2626015", "inspect.Signature.__dict__.__contains__",      ["__reversed__"],    false]
    - ["in2626016", "inspect.FullArgSpec.__dict__.__contains__",    ["__length_hint__"], false]
    - ["in2626017", "inspect.Parameter.__dict__.__contains__",      ["__missing__"],     false]
    - ["in2626018", "inspect.BoundArguments.__dict__.__contains__", ["__reversed__"],    false]
    - ["in2626019", "inspect.Signature.__dict__.__contains__",      ["__length_hint__"], false]
    - ["in2626020", "inspect.FullArgSpec.__dict__.__contains__",    ["__missing__"],     false]
