spec: inspect_extra97
version: ">=3.9"
backend: python_module(inspect)
extends: inspect_extra96

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra96.zspec.zsdl."
    - "This spec covers: inspect stack/trace/getouterframes/getinnerframes function code attrs; CO_* flag constants values and class names (Wave 254)."
    - "inspect.stack.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.trace.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.getouterframes.__code__.co_argcount == 2. Verified with Python 3.14.3."
    - "inspect.getinnerframes.__code__.co_argcount == 2. Verified with Python 3.14.3."
    - "inspect.stack.__code__.co_name == 'stack'. Verified with Python 3.14.3."
    - "inspect.trace.__code__.co_name == 'trace'. Verified with Python 3.14.3."
    - "inspect.stack.__qualname__ == 'stack'. Verified with Python 3.14.3."
    - "inspect.CO_OPTIMIZED == 1. Verified with Python 3.14.3."
    - "inspect.CO_NEWLOCALS == 2. Verified with Python 3.14.3."
    - "inspect.CO_VARARGS == 4. Verified with Python 3.14.3."
    - "inspect.CO_VARKEYWORDS == 8. Verified with Python 3.14.3."
    - "inspect.CO_NESTED == 16. Verified with Python 3.14.3."
    - "inspect.CO_GENERATOR == 32. Verified with Python 3.14.3."
    - "inspect.CO_NOFREE == 64. Verified with Python 3.14.3."
    - "inspect.CO_COROUTINE == 128. Verified with Python 3.14.3."
    - "inspect.CO_ITERABLE_COROUTINE == 256. Verified with Python 3.14.3."
    - "inspect.CO_ASYNC_GENERATOR == 512. Verified with Python 3.14.3."
    - "All CO_* constants have __class__.__name__ == 'int'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: stack/trace/getouterframes/getinnerframes co_argcount values
#
# Wave 254 theme: inspect stack-related functions co_argcount.
#
# inspect.stack.__code__.co_argcount == 1
# inspect.trace.__code__.co_argcount == 1
# inspect.getouterframes.__code__.co_argcount == 2
# inspect.getinnerframes.__code__.co_argcount == 2
#
# stack(context=1) and trace(context=1) take one arg (context lines).
# getouterframes/getinnerframes take two args (frame, context).
# New to extra97.
# ---------------------------------------------------------------------------

table inspect_extra97.stack_fn_co_argcount:
  description: "inspect.stack/trace co_argcount == 1; getouterframes/getinnerframes co_argcount == 2; stack-frame functions; wave 254; new to extra97"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectcoflags97

  columns: [id, function, args, expected, description]
  rows:
    - [stack_co_argcount_eq_1,
       "stack.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.stack.__code__.co_argcount.__eq__(1) == True — stack(context=1) takes one positional argument (the number of lines of context to return); co_argcount is 1; int.__eq__(1) returns True; new to extra97"]
    - [trace_co_argcount_eq_1,
       "trace.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.trace.__code__.co_argcount.__eq__(1) == True — trace(context=1) takes one positional argument (the number of lines of context to return); co_argcount is 1; int.__eq__(1) returns True; new to extra97"]
    - [getouterframes_co_argcount_eq_2,
       "getouterframes.__code__.co_argcount.__eq__",
       [2],
       true,
       "inspect.getouterframes.__code__.co_argcount.__eq__(2) == True — getouterframes(frame, context=1) takes two positional arguments (the frame and the context line count); co_argcount is 2; int.__eq__(2) returns True; new to extra97"]
    - [getinnerframes_co_argcount_eq_2,
       "getinnerframes.__code__.co_argcount.__eq__",
       [2],
       true,
       "inspect.getinnerframes.__code__.co_argcount.__eq__(2) == True — getinnerframes(tb, context=1) takes two positional arguments (the traceback and the context line count); co_argcount is 2; int.__eq__(2) returns True; new to extra97"]

# ---------------------------------------------------------------------------
# Table 2: CO_OPTIMIZED, CO_NEWLOCALS, CO_VARARGS, CO_VARKEYWORDS values
#
# Wave 254 theme: inspect CO_* flag constants — first group (bits 0-3).
#
# inspect.CO_OPTIMIZED == 1  (0x01)
# inspect.CO_NEWLOCALS == 2  (0x02)
# inspect.CO_VARARGS == 4    (0x04)
# inspect.CO_VARKEYWORDS == 8 (0x08)
#
# These are the four lowest-order code flags, corresponding to bit positions
# 0-3. New to extra97.
# ---------------------------------------------------------------------------

table inspect_extra97.co_flags_group1:
  description: "inspect.CO_OPTIMIZED/1, CO_NEWLOCALS/2, CO_VARARGS/4, CO_VARKEYWORDS/8; code flag constants bits 0-3; wave 254; new to extra97"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectcoflags97

  columns: [id, function, args, expected, description]
  rows:
    - [co_optimized_eq_1,
       "CO_OPTIMIZED.__eq__",
       [1],
       true,
       "inspect.CO_OPTIMIZED.__eq__(1) == True — CO_OPTIMIZED (0x01) indicates the code object uses fast locals (LOAD_FAST/STORE_FAST) rather than a dict; its integer value is 1; int.__eq__(1) returns True; new to extra97"]
    - [co_newlocals_eq_2,
       "CO_NEWLOCALS.__eq__",
       [2],
       true,
       "inspect.CO_NEWLOCALS.__eq__(2) == True — CO_NEWLOCALS (0x02) indicates the code object creates a new dict for its locals; its integer value is 2; int.__eq__(2) returns True; new to extra97"]
    - [co_varargs_eq_4,
       "CO_VARARGS.__eq__",
       [4],
       true,
       "inspect.CO_VARARGS.__eq__(4) == True — CO_VARARGS (0x04) indicates the code object accepts a variable number of positional arguments (*args); its integer value is 4; int.__eq__(4) returns True; new to extra97"]
    - [co_varkeywords_eq_8,
       "CO_VARKEYWORDS.__eq__",
       [8],
       true,
       "inspect.CO_VARKEYWORDS.__eq__(8) == True — CO_VARKEYWORDS (0x08) indicates the code object accepts a variable number of keyword arguments (**kwargs); its integer value is 8; int.__eq__(8) returns True; new to extra97"]

# ---------------------------------------------------------------------------
# Table 3: CO_NESTED, CO_GENERATOR, CO_NOFREE, CO_COROUTINE values
#
# Wave 254 theme: inspect CO_* flag constants — second group (bits 4-7).
#
# inspect.CO_NESTED == 16    (0x10)
# inspect.CO_GENERATOR == 32 (0x20)
# inspect.CO_NOFREE == 64    (0x40)
# inspect.CO_COROUTINE == 128 (0x80)
#
# These four flags occupy bit positions 4-7. New to extra97.
# ---------------------------------------------------------------------------

table inspect_extra97.co_flags_group2:
  description: "inspect.CO_NESTED/16, CO_GENERATOR/32, CO_NOFREE/64, CO_COROUTINE/128; code flag constants bits 4-7; wave 254; new to extra97"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectcoflags97

  columns: [id, function, args, expected, description]
  rows:
    - [co_nested_eq_16,
       "CO_NESTED.__eq__",
       [16],
       true,
       "inspect.CO_NESTED.__eq__(16) == True — CO_NESTED (0x10) indicates the code object is defined inside another function (nested function); its integer value is 16; int.__eq__(16) returns True; new to extra97"]
    - [co_generator_eq_32,
       "CO_GENERATOR.__eq__",
       [32],
       true,
       "inspect.CO_GENERATOR.__eq__(32) == True — CO_GENERATOR (0x20) indicates the code object is a generator function (uses yield); its integer value is 32; int.__eq__(32) returns True; new to extra97"]
    - [co_nofree_eq_64,
       "CO_NOFREE.__eq__",
       [64],
       true,
       "inspect.CO_NOFREE.__eq__(64) == True — CO_NOFREE (0x40) indicates the code object has no free variables and no cell variables (no closure); its integer value is 64; int.__eq__(64) returns True; new to extra97"]
    - [co_coroutine_eq_128,
       "CO_COROUTINE.__eq__",
       [128],
       true,
       "inspect.CO_COROUTINE.__eq__(128) == True — CO_COROUTINE (0x80) indicates the code object is a coroutine function (defined with 'async def'); its integer value is 128; int.__eq__(128) returns True; new to extra97"]

# ---------------------------------------------------------------------------
# Table 4: CO_* constants __class__.__name__ (all 'int')
#
# Wave 254 theme: inspect CO_* constants are all plain Python int objects.
#
# All ten CO_* constants have __class__.__name__ == 'int'.
#
# These constants are simple integer values exported from the inspect module.
# New to extra97.
# ---------------------------------------------------------------------------

table inspect_extra97.co_flags_class_names:
  description: "inspect CO_OPTIMIZED/CO_NEWLOCALS/CO_VARARGS/CO_VARKEYWORDS/CO_NESTED/CO_GENERATOR/CO_NOFREE/CO_COROUTINE __class__.__name__ == 'int'; all plain int; wave 254; new to extra97"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectcoflags97

  columns: [id, function, args, expected, description]
  rows:
    - [co_optimized_class_name_eq_int,
       "CO_OPTIMIZED.__class__.__name__.__eq__",
       ["int"],
       true,
       "inspect.CO_OPTIMIZED.__class__.__name__.__eq__('int') == True — CO_OPTIMIZED is a plain Python int constant; __class__.__name__ is 'int'; str.__eq__('int') returns True; new to extra97"]
    - [co_newlocals_class_name_eq_int,
       "CO_NEWLOCALS.__class__.__name__.__eq__",
       ["int"],
       true,
       "inspect.CO_NEWLOCALS.__class__.__name__.__eq__('int') == True — CO_NEWLOCALS is a plain Python int constant; __class__.__name__ is 'int'; str.__eq__('int') returns True; new to extra97"]
    - [co_varargs_class_name_eq_int,
       "CO_VARARGS.__class__.__name__.__eq__",
       ["int"],
       true,
       "inspect.CO_VARARGS.__class__.__name__.__eq__('int') == True — CO_VARARGS is a plain Python int constant; __class__.__name__ is 'int'; str.__eq__('int') returns True; new to extra97"]
    - [co_varkeywords_class_name_eq_int,
       "CO_VARKEYWORDS.__class__.__name__.__eq__",
       ["int"],
       true,
       "inspect.CO_VARKEYWORDS.__class__.__name__.__eq__('int') == True — CO_VARKEYWORDS is a plain Python int constant; __class__.__name__ is 'int'; str.__eq__('int') returns True; new to extra97"]
    - [co_nested_class_name_eq_int,
       "CO_NESTED.__class__.__name__.__eq__",
       ["int"],
       true,
       "inspect.CO_NESTED.__class__.__name__.__eq__('int') == True — CO_NESTED is a plain Python int constant; __class__.__name__ is 'int'; str.__eq__('int') returns True; new to extra97"]
    - [co_generator_class_name_eq_int,
       "CO_GENERATOR.__class__.__name__.__eq__",
       ["int"],
       true,
       "inspect.CO_GENERATOR.__class__.__name__.__eq__('int') == True — CO_GENERATOR is a plain Python int constant; __class__.__name__ is 'int'; str.__eq__('int') returns True; new to extra97"]
    - [co_nofree_class_name_eq_int,
       "CO_NOFREE.__class__.__name__.__eq__",
       ["int"],
       true,
       "inspect.CO_NOFREE.__class__.__name__.__eq__('int') == True — CO_NOFREE is a plain Python int constant; __class__.__name__ is 'int'; str.__eq__('int') returns True; new to extra97"]
    - [co_coroutine_class_name_eq_int,
       "CO_COROUTINE.__class__.__name__.__eq__",
       ["int"],
       true,
       "inspect.CO_COROUTINE.__class__.__name__.__eq__('int') == True — CO_COROUTINE is a plain Python int constant; __class__.__name__ is 'int'; str.__eq__('int') returns True; new to extra97"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra97
# ---------------------------------------------------------------------------

invariant inspect_extra97.stack_co_argcount_eq_1:
  description: "inspect.stack.__code__.co_argcount == 1 — stack(context=1) takes one argument; wave 254; new to extra97"
  kind: python_call_eq
  function: stack.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra97.getouterframes_co_argcount_eq_2:
  description: "inspect.getouterframes.__code__.co_argcount == 2 — takes frame and context arguments; wave 254; new to extra97"
  kind: python_call_eq
  function: getouterframes.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant inspect_extra97.co_optimized_eq_1:
  description: "inspect.CO_OPTIMIZED == 1 — bit 0 code flag for fast locals; wave 254; new to extra97"
  kind: python_call_eq
  function: CO_OPTIMIZED.__eq__
  args: [1]
  expected: true

invariant inspect_extra97.co_coroutine_eq_128:
  description: "inspect.CO_COROUTINE == 128 — bit 7 code flag for async def coroutines; wave 254; new to extra97"
  kind: python_call_eq
  function: CO_COROUTINE.__eq__
  args: [128]
  expected: true

invariant inspect_extra97.co_generator_class_name_eq_int:
  description: "inspect.CO_GENERATOR.__class__.__name__ == 'int' — CO_* constants are plain Python int objects; wave 254; new to extra97"
  kind: python_call_eq
  function: CO_GENERATOR.__class__.__name__.__eq__
  args: ["int"]
  expected: true
