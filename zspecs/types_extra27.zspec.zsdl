spec: types_extra27
version: ">=3.9"
backend: python_module(types)

docs: https://docs.python.org/3/library/types.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/types.html — Python types module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/types.py"
  notes:
    - "This spec extends types_extra26.zspec.zsdl."
    - "Prior specs covered: FunctionType/LambdaType/MethodType/GeneratorType/CodeType/ModuleType/__name__/__module__/__qualname__, SimpleNamespace/__name__/__module__/__qualname__, MappingProxyType/__name__, DynamicClassAttribute/__name__, GenericAlias/__name__, UnionType/__name__, various __bases__[0].__name__ checks, NoneType/EllipsisType/NotImplementedType, __module__.__len__() and __name__.__len__() for many types and for CoroutineType/AsyncGeneratorType/BuiltinFunctionType/TracebackType/FrameType/CellType/MappingProxyType, __module__.__len__() and __name__.__len__() for resolve_bases/prepare_class/new_class."
    - "This spec covers: __qualname__.__len__() for SimpleNamespace.__init__/__repr__/__eq__; __qualname__.__len__() for ModuleType.__init__/__repr__; __mro__.__len__() for MappingProxyType/NoneType; __module__.__len__() for NoneType; new_class.__qualname__.__len__()."
    - "types.SimpleNamespace.__init__.__qualname__ == 'SimpleNamespace.__init__' (length 24)."
    - "types.SimpleNamespace.__repr__.__qualname__ == 'SimpleNamespace.__repr__' (length 24)."
    - "types.SimpleNamespace.__eq__.__qualname__ == 'SimpleNamespace.__eq__' (length 22)."
    - "types.ModuleType.__init__.__qualname__ == 'module.__init__' (length 15); the C-level internal name 'module' is used, not 'ModuleType'."
    - "types.ModuleType.__repr__.__qualname__ == 'module.__repr__' (length 15)."
    - "types.MappingProxyType.__mro__ == (mappingproxy, object) — length 2."
    - "types.NoneType.__mro__ == (NoneType, object) — length 2; NoneType.__module__ == 'builtins' (length 8)."
    - "types.EllipsisType.__mro__ == (ellipsis, object) — length 2; EllipsisType directly subclasses object."
    - "types.new_class.__qualname__ == 'new_class' (length 9)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() for SimpleNamespace methods
#
# SimpleNamespace is a Python class; its methods carry __qualname__ values
# of the form 'SimpleNamespace.<method>'. __init__ and __repr__ share the
# pattern 'SimpleNamespace.__init__'/'SimpleNamespace.__repr__' (24 chars each);
# __eq__ is 'SimpleNamespace.__eq__' (22 chars). No prior types spec records
# __qualname__.__len__() for any SimpleNamespace method.
# ---------------------------------------------------------------------------

table types_extra27.simplenamespace_method_qualname_lens:
  description: "__qualname__.__len__() for SimpleNamespace methods — __init__/__repr__ share length 24, __eq__ has length 22"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [__init__, SimpleNamespace.__init__.__qualname__.__len__, [], 24]
    - [__repr__, SimpleNamespace.__repr__.__qualname__.__len__, [], 24]
    - [__eq__,   SimpleNamespace.__eq__.__qualname__.__len__,   [], 22]

# ---------------------------------------------------------------------------
# __qualname__.__len__() for ModuleType methods and __mro__.__len__() for
# MappingProxyType/NoneType
#
# ModuleType's C-level methods use the internal type name 'module', not
# 'ModuleType', so their qualnames are 'module.__init__'/'module.__repr__'
# (15 chars each). MappingProxyType and NoneType both have __mro__ of length 2
# (each directly subclasses object).
# ---------------------------------------------------------------------------

table types_extra27.moduletype_method_qualname_lens:
  description: "__qualname__.__len__() for ModuleType methods — both 'module.__init__' and 'module.__repr__' have length 15 (C internal name 'module')"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [__init__, ModuleType.__init__.__qualname__.__len__, [], 15]
    - [__repr__, ModuleType.__repr__.__qualname__.__len__, [], 15]

table types_extra27.mro_lens:
  description: "__mro__.__len__() for MappingProxyType and NoneType — both are direct object subclasses (depth 2)"
  kind: python_call_eq
  category: mro_lengths
  id_prefix: mro_len

  columns: [id, function, args, expected]
  rows:
    - [MappingProxyType, MappingProxyType.__mro__.__len__, [], 2]
    - [NoneType,         NoneType.__mro__.__len__,         [], 2]
    - [EllipsisType,     EllipsisType.__mro__.__len__,     [], 2]

# ---------------------------------------------------------------------------
# types.SimpleNamespace.__init__.__qualname__.__len__() == 24 — standalone
#
# 'SimpleNamespace.__init__' has 24 characters: the 15-character class name
# plus a dot plus the 8-character method name. This is the longest qualname
# among all SimpleNamespace methods recorded here.
# ---------------------------------------------------------------------------

invariant types_extra27.SimpleNamespace.init.qualname_len:
  description: "types.SimpleNamespace.__init__.__qualname__.__len__() == 24 — 'SimpleNamespace.__init__' is 15 + 1 + 8 = 24 characters"
  category: method_qualname_lengths
  kind: python_call_eq
  function: SimpleNamespace.__init__.__qualname__.__len__
  args: []
  expected: 24

# ---------------------------------------------------------------------------
# types.ModuleType.__init__.__qualname__.__len__() == 15 — standalone
#
# ModuleType's C-level methods use the internal type name 'module' rather than
# the Python attribute name 'ModuleType'. 'module.__init__' has 15 characters:
# 6 + 1 + 8. This illustrates how C-level type names diverge from the
# public attribute names exposed in the types module.
# ---------------------------------------------------------------------------

invariant types_extra27.ModuleType.init.qualname_len:
  description: "types.ModuleType.__init__.__qualname__.__len__() == 15 — 'module.__init__' uses C internal name 'module' (6), giving 6 + 1 + 8 = 15 characters"
  category: method_qualname_lengths
  kind: python_call_eq
  function: ModuleType.__init__.__qualname__.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# types.NoneType.__module__.__len__() == 8 — standalone
#
# types.NoneType.__module__ is 'builtins' (length 8), matching all other C-level
# types in the types module. extra26 recorded NoneType.__name__ == 'NoneType'
# but not the module length. This invariant closes that gap.
# ---------------------------------------------------------------------------

invariant types_extra27.NoneType.module_len:
  description: "types.NoneType.__module__.__len__() == 8 — '__module__' is 'builtins' (8), consistent with all C-level types in the types module"
  category: module_attr_lengths
  kind: python_call_eq
  function: NoneType.__module__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# types.new_class.__qualname__.__len__() == 9 — standalone
#
# types.new_class is a Python-level helper function; its __qualname__ is
# 'new_class' (length 9), equal to its __name__. extra26 recorded
# new_class.__name__.__len__() == 9 and __module__.__len__() == 5 but not the
# qualname length. This invariant confirms __name__ == __qualname__ for
# new_class (both length 9).
# ---------------------------------------------------------------------------

invariant types_extra27.new_class.qualname_len:
  description: "types.new_class.__qualname__.__len__() == 9 — 'new_class' has length 9; qualname equals name for this top-level function"
  category: qualname_attr_lengths
  kind: python_call_eq
  function: new_class.__qualname__.__len__
  args: []
  expected: 9
