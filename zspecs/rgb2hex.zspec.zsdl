spec: rgb2hex
version: ">=0.2.5"
backend: node(rgb2hex)

docs: https://www.npmjs.com/package/rgb2hex

provenance:
  derived_from:
    - "rgb2hex README — https://www.npmjs.com/package/rgb2hex"
    - "Test vectors verified with rgb2hex via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "rgb2hex source"
  notes:
    - "rgb2hex is an npm package. Install: npm install rgb2hex"
    - "Converts a CSS rgb() or rgba() string to an object with hex and alpha properties."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an object with hex (string) and alpha (number) properties."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table rgb2hex.convert:
  kind: node_module_call_eq
  function: ~
  category: color
  id_prefix: r2hex

  columns: [id, args, expected]
  rows:
    - [red,    ["rgb(255, 0, 0)"],     {"hex": "#ff0000", "alpha": 1}]
    - [blue,   ["rgb(0, 0, 255)"],     {"hex": "#0000ff", "alpha": 1}]
    - [white,  ["rgb(255, 255, 255)"], {"hex": "#ffffff", "alpha": 1}]

