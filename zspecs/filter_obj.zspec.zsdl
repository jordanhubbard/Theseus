spec: filter_obj
version: ">=6.1.0"
backend: node(filter-obj)

docs: https://www.npmjs.com/package/filter-obj

provenance:
  derived_from:
    - "filter-obj README — https://www.npmjs.com/package/filter-obj"
    - "Test vectors verified with filter-obj via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "filter-obj source"
  notes:
    - "filter-obj is an npm package. Install: npm install filter-obj"
    - "includeKeys: returns a copy of the object with only the specified keys."
    - "excludeKeys: returns a copy of the object with the specified keys removed."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table filter_obj.includeKeys:
  kind: node_module_call_eq
  function: includeKeys
  category: object
  id_prefix: finc

  columns: [id, args, expected]
  rows:
    - [two_of_three,  [{"a": 1, "b": 2, "c": 3}, ["a", "c"]],  {"a": 1, "c": 3}]
    - [one_of_two,    [{"x": 10, "y": 20}, ["x"]],              {"x": 10}]
    - [all,           [{"a": 1, "b": 2}, ["a", "b"]],           {"a": 1, "b": 2}]

table filter_obj.excludeKeys:
  kind: node_module_call_eq
  function: excludeKeys
  category: object
  id_prefix: fexc

  columns: [id, args, expected]
  rows:
    - [one_key,   [{"a": 1, "b": 2, "c": 3}, ["b"]],       {"a": 1, "c": 3}]
    - [two_keys,  [{"x": 1, "y": 2, "z": 3}, ["x", "z"]], {"y": 2}]
    - [none,      [{"a": 1, "b": 2}, []],                  {"a": 1, "b": 2}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T18:14:40Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
