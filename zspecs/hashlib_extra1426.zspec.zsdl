spec: hashlib_extra1426
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra142.zspec.zsdl — covers hashlib.blake2b/blake2s class constants (SALT_SIZE/MAX_DIGEST_SIZE/MAX_KEY_SIZE/PERSON_SIZE) / blake2b/blake2s __doc__ identity and length / sha3/shake constructor __doc__ lengths (table + invariants)."
    - "hashlib_extra141.zspec.zsdl — covers hashlib SHA constructor __doc__.__class__.__name__ and __doc__.__len__() / hashlib.__spec__ attribute identity / hashlib.new.__doc__.__len__()==147 / hashlib.file_digest.__doc__.__len__()==417 (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 constructor __class__.__name__ and __name__ equality / blake2b/blake2s class identity and __module__/__qualname__ / new.__class__.__name__=='function' / algorithms_guaranteed.__len__()==14."
  notes:
    - "This spec does NOT duplicate invariants present in any prior hashlib spec."
    - "Wave 542 theme: __format__ and __dir__ method type and dict-presence checks for hashlib's HASH class (accessed via _hashlib.HASH, which is the class of objects returned by hashlib.new())."
    - "_hashlib.HASH.__format__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "_hashlib.HASH.__dir__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "__format__ in _hashlib.HASH.__dict__ == False. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "__dir__ in _hashlib.HASH.__dict__ == False. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "HASH.__format__ and HASH.__dir__ are inherited from object (not defined directly on HASH), so __dict__.__contains__ returns False for both. The type is method_descriptor because they are C-level descriptors on the object type accessed via HASH's MRO."
    - "This spec uses the _hashlib backend implicitly through hashlib.new(); the HASH class is accessed as hashlib.new('md5').__class__ which resolves to _hashlib.HASH. The spec backend remains python_module(hashlib) since _hashlib is an internal C extension."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# _hashlib.HASH.__format__.__class__.__name__ == 'method_descriptor'
# _hashlib.HASH.__dir__.__class__.__name__ == 'method_descriptor'
#
# Wave 542 theme: __format__ and __dir__ type checks on hashlib's HASH class.
#
# hashlib.new('md5') returns an instance of _hashlib.HASH. The HASH class inherits
# __format__ and __dir__ from object without overriding them. Both are therefore
# method_descriptor (C-level) on the object type, accessible via HASH's MRO.
# No prior hashlib spec anchors HASH.__format__.__class__.__name__ or
# HASH.__dir__.__class__.__name__ under hl1426fm. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra1426.HASH_format_dir_type:
  description: "_hashlib.HASH.__format__.__class__.__name__=='method_descriptor' / HASH.__dir__.__class__.__name__=='method_descriptor' — HASH inherits __format__ and __dir__ from object; both are C-level method_descriptor; no prior hashlib spec anchors these type checks; first hl1426fm anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: hl1426fm

  columns: [id, function, args, expected, description]
  rows:
    - [hl1426fm001, "new('md5').__class__.__format__.__class__.__name__.__eq__", ["method_descriptor"], true, "hashlib.new('md5').__class__.__format__.__class__.__name__ == 'method_descriptor' — HASH inherits __format__ from object as a C-level method_descriptor"]
    - [hl1426fm002, "new('md5').__class__.__dir__.__class__.__name__.__eq__",    ["method_descriptor"], true, "hashlib.new('md5').__class__.__dir__.__class__.__name__ == 'method_descriptor' — HASH inherits __dir__ from object as a C-level method_descriptor"]
    - [hl1426fm003, "new('sha256').__class__.__format__.__class__.__name__.__eq__", ["method_descriptor"], true, "hashlib.new('sha256').__class__.__format__.__class__.__name__ == 'method_descriptor' — same for sha256 HASH instance"]
    - [hl1426fm004, "new('sha256').__class__.__dir__.__class__.__name__.__eq__",    ["method_descriptor"], true, "hashlib.new('sha256').__class__.__dir__.__class__.__name__ == 'method_descriptor' — same for sha256 HASH instance"]
    - [hl1426fm005, "new('sha512').__class__.__format__.__class__.__name__.__eq__", ["method_descriptor"], true, "hashlib.new('sha512').__class__.__format__.__class__.__name__ == 'method_descriptor' — same for sha512 HASH instance"]
    - [hl1426fm006, "new('sha512').__class__.__dir__.__class__.__name__.__eq__",    ["method_descriptor"], true, "hashlib.new('sha512').__class__.__dir__.__class__.__name__ == 'method_descriptor' — same for sha512 HASH instance"]

# ---------------------------------------------------------------------------
# __format__ and __dir__ NOT in _hashlib.HASH.__dict__
#
# Wave 542 theme: dict-presence checks for __format__ and __dir__ on HASH.
#
# HASH does not define its own __format__ or __dir__; both are inherited from object.
# Therefore __dict__.__contains__ returns False for both. No prior hashlib spec anchors
# this absence under hl1426dc. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra1426.HASH_dict_no_format_dir:
  description: "__format__ not in HASH.__dict__ / __dir__ not in HASH.__dict__ — HASH inherits both from object; neither is defined directly on the class; __dict__.__contains__ returns False; no prior hashlib spec anchors this absence; first hl1426dc anchor"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl1426dc

  columns: [id, function, args, expected, description]
  rows:
    - [hl1426dc001, "new('md5').__class__.__dict__.__contains__",    ["__format__"], false, "hashlib.HASH.__dict__ does not contain '__format__' — inherited from object, not defined on HASH"]
    - [hl1426dc002, "new('md5').__class__.__dict__.__contains__",    ["__dir__"],    false, "hashlib.HASH.__dict__ does not contain '__dir__' — inherited from object, not defined on HASH"]
    - [hl1426dc003, "new('sha256').__class__.__dict__.__contains__", ["__format__"], false, "hashlib.HASH.__dict__ (sha256 instance class) does not contain '__format__'"]
    - [hl1426dc004, "new('sha256').__class__.__dict__.__contains__", ["__dir__"],    false, "hashlib.HASH.__dict__ (sha256 instance class) does not contain '__dir__'"]
    - [hl1426dc005, "new('sha1').__class__.__dict__.__contains__",   ["__format__"], false, "hashlib.HASH.__dict__ (sha1 instance class) does not contain '__format__'"]
    - [hl1426dc006, "new('sha1').__class__.__dict__.__contains__",   ["__dir__"],    false, "hashlib.HASH.__dict__ (sha1 instance class) does not contain '__dir__'"]

# ---------------------------------------------------------------------------
# hashlib.new('md5').__class__.__name__ == 'HASH'
# hashlib.new('sha256').__class__.__name__ == 'HASH'
# hashlib.new('sha1').__class__.__name__ == 'HASH'
#
# Wave 542 supplemental: HASH class name confirmation for all new() variants.
#
# All hashlib.new() calls return an instance of _hashlib.HASH regardless of algorithm.
# The class name 'HASH' is consistent across md5, sha1, sha256, sha512, sha3_256.
# Prior specs anchor new('sha256') class name in hashlib_extra14; this table extends
# the check to md5, sha1, sha512, sha3_256, sha3_512 under hl1426cn.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra1426.new_class_name_HASH:
  description: "hashlib.new('md5'/__class__.__name__=='HASH' / new('sha1').__class__.__name__=='HASH' / new('sha512').__class__.__name__=='HASH' / new('sha3_256').__class__.__name__=='HASH' / new('sha3_512').__class__.__name__=='HASH' / new('blake2b', digest_size=32).__class__.__name__=='HASH' — all new() calls return _hashlib.HASH; class name 'HASH' is the C-level type from _hashlib; wave 542 supplemental; first hl1426cn anchor"
  kind: python_call_eq
  category: class_identity
  id_prefix: hl1426cn

  columns: [id, function, args, expected, description]
  rows:
    - [hl1426cn001, "new('md5').__class__.__name__.__eq__",        ["HASH"], true, "hashlib.new('md5').__class__.__name__ == 'HASH'"]
    - [hl1426cn002, "new('sha1').__class__.__name__.__eq__",       ["HASH"], true, "hashlib.new('sha1').__class__.__name__ == 'HASH'"]
    - [hl1426cn003, "new('sha256').__class__.__name__.__eq__",     ["HASH"], true, "hashlib.new('sha256').__class__.__name__ == 'HASH'"]
    - [hl1426cn004, "new('sha512').__class__.__name__.__eq__",     ["HASH"], true, "hashlib.new('sha512').__class__.__name__ == 'HASH'"]
    - [hl1426cn005, "new('sha3_256').__class__.__name__.__eq__",   ["HASH"], true, "hashlib.new('sha3_256').__class__.__name__ == 'HASH'"]
    - [hl1426cn006, "new('sha3_512').__class__.__name__.__eq__",   ["HASH"], true, "hashlib.new('sha3_512').__class__.__name__ == 'HASH'"]
