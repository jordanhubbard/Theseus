# __init__.__class__.__name__ — decimal C extension types
# ---------------------------------------------------------------------------

table decimal_extra2356.ctype_init_class_name:
  kind: python_call_eq
  category: impl_type
  id_prefix: dc2356

  columns: [id, function, args, expected]
  rows:
    - ["dc2356001", Decimal.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - ["dc2356002", Context.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]

