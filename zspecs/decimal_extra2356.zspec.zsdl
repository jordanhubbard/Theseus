spec: decimal_extra2356
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "Python 3 decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal_extra.zspec.zsdl — covers class names, arithmetic, rounding modes"
  notes:
    - "Wave 2356, theme: __init__ and __new__ implementation type classification."
    - "decimal.Decimal and decimal.Context are C extension types (_decimal accelerator)."
    - "decimal.DecimalException and all its subclasses are Python exception classes."
    - "decimal.Decimal.__init__.__class__.__name__ == 'wrapper_descriptor' (C extension type)."
    - "decimal.Context.__init__.__class__.__name__ == 'wrapper_descriptor' (C extension type)."
    - "decimal.DecimalException.__init__.__class__.__name__ == 'wrapper_descriptor' — inherits from ArithmeticError."
    - "decimal.InvalidOperation.__init__.__class__.__name__ == 'wrapper_descriptor' (verified Python 3.13)."
    - "decimal.DivisionByZero.__init__.__class__.__name__ == 'wrapper_descriptor' (verified Python 3.13)."
    - "decimal.Overflow.__init__.__class__.__name__ == 'wrapper_descriptor' (verified Python 3.13)."
    - "All exception subclasses inherit __init__ from BaseException via ArithmeticError; none define custom __init__."
    - "decimal.Decimal.__new__.__class__.__name__ == 'builtin_function_or_method' (C tp_new slot)."
    - "decimal.Context.__new__.__class__.__name__ == 'builtin_function_or_method' (C tp_new slot)."
    - "All expected values verified by running Python 3.13 decimal module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

