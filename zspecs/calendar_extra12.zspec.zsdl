spec: calendar_extra12
version: ">=3.9"
backend: python_module(calendar)

docs: https://docs.python.org/3/library/calendar.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/calendar.html — Python calendar module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/calendar.py"
    - "calendar_extra7.zspec.zsdl — covers Calendar/__qualname__; TextCalendar/__name__/__bases__; HTMLCalendar/__name__/__bases__; isleap; leapdays; monthrange; firstweekday/__module__; timegm/__module__"
    - "calendar_extra10.zspec.zsdl — covers Calendar/TextCalendar/HTMLCalendar __qualname__ standalone; Calendar.__module__; base class checks; isleap truth-table"
    - "calendar_extra11.zspec.zsdl — covers Calendar/TextCalendar/HTMLCalendar __name__ table; month_name/month_abbr/day_name class names; MONDAY/SUNDAY constants"
  notes:
    - "This spec extends calendar.zspec.zsdl and prior extras through calendar_extra11.zspec.zsdl."
    - "NEW in extra12 — Axis 1: class hierarchy table confirming __bases__[0].__name__ for Calendar/TextCalendar/HTMLCalendar in the extra12 namespace."
    - "NEW in extra12 — Axis 2: Calendar.__bases__[0].__name__ == 'object' as standalone extra12-namespace invariant."
    - "NEW in extra12 — Axis 3: TextCalendar.__bases__[0].__name__ == 'Calendar' as standalone extra12-namespace invariant."
    - "NEW in extra12 — Axis 4: __module__ table for isleap/monthrange/weekday in extra12 namespace."
    - "calendar.Calendar.__bases__[0].__name__ == 'object' — verified Python 3.12."
    - "calendar.TextCalendar.__bases__[0].__name__ == 'Calendar' — verified Python 3.12."
    - "calendar.HTMLCalendar.__bases__[0].__name__ == 'Calendar' — verified Python 3.12."
    - "calendar.isleap.__module__ == 'calendar' — verified Python 3.12."
    - "calendar.monthrange.__module__ == 'calendar' — verified Python 3.12."
    - "calendar.weekday.__module__ == 'calendar' — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class hierarchy: __bases__[0].__name__ for Calendar, TextCalendar, HTMLCalendar
#
# calendar_extra7 and calendar_extra10 cover base class checks for
# TextCalendar and HTMLCalendar. This spec consolidates all three calendar
# classes into a single hierarchy table in the extra12 namespace.
# ---------------------------------------------------------------------------

table calendar_extra12.class_bases:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: base

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [Calendar,      Calendar.__bases__.__getitem__,      [0], "__name__.__eq__", ["object"],   true]
    - [TextCalendar,  TextCalendar.__bases__.__getitem__,  [0], "__name__.__eq__", ["Calendar"], true]
    - [HTMLCalendar,  HTMLCalendar.__bases__.__getitem__,  [0], "__name__.__eq__", ["Calendar"], true]

# ---------------------------------------------------------------------------
# Calendar.__bases__[0].__name__ == 'object'
#
# calendar.Calendar is the root calendar class and inherits directly from
# object. This standalone invariant anchors that fact in the extra12 namespace.
# ---------------------------------------------------------------------------

invariant calendar_extra12.Calendar.base_name:
  description: "calendar.Calendar.__bases__[0].__name__ == 'object' — Calendar directly inherits from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Calendar.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# TextCalendar.__bases__[0].__name__ == 'Calendar'
#
# calendar.TextCalendar is a subclass of Calendar that produces plain-text
# calendar output. This standalone invariant anchors its parent class name
# in the extra12 namespace.
# ---------------------------------------------------------------------------

invariant calendar_extra12.TextCalendar.base_name:
  description: "calendar.TextCalendar.__bases__[0].__name__ == 'Calendar' — TextCalendar directly subclasses Calendar"
  category: class_hierarchy
  kind: python_call_eq
  function: TextCalendar.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Calendar"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ for isleap, monthrange, weekday
#
# calendar_extra7 covers isleap and monthrange __module__. This spec anchors
# all three utility functions together in a table in the extra12 namespace.
# ---------------------------------------------------------------------------

table calendar_extra12.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: mod

  columns: [id, function, args, expected]
  rows:
    - [isleap,      isleap.__module__.__eq__,      ["calendar"], true]
    - [monthrange,  monthrange.__module__.__eq__,  ["calendar"], true]
    - [weekday,     weekday.__module__.__eq__,     ["calendar"], true]
