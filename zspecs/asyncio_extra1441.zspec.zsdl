spec: asyncio_extra1441
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/, Modules/_asynciomodule.c"
  notes:
    - "Wave 543 (_extra1441): focuses on __subclasshook__ and __instancecheck__ checks for asyncio classes."
    - "asyncio.Queue, Task, Future, Lock, Event, Semaphore, Barrier, and TaskGroup all use plain 'type' as metaclass (not ABCMeta)."
    - "Therefore __subclasshook__ is inherited from the ABCMeta machinery on 'type'; its __class__.__name__ is 'builtin_function_or_method'."
    - "__instancecheck__ is inherited from 'type'; its __class__.__name__ is 'builtin_function_or_method'."
    - "None of the asyncio classes define __subclasshook__ or __instancecheck__ in their own __dict__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table asyncio_extra1441.subclasshook_class_name:
  description: "asyncio class __subclasshook__.__class__.__name__ identity — all asyncio classes use plain 'type' as metaclass so __subclasshook__ is inherited and has __class__.__name__ == 'builtin_function_or_method'; verified with Python 3.14.3"
  kind: python_call_eq
  category: subclasshook_class_name
  id_prefix: as1441sh
  columns: [id, function, args, expected]
  rows:
    - [as1441sh001, asyncio.Queue.__subclasshook__.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - [as1441sh002, asyncio.Task.__subclasshook__.__class__.__name__.__eq__,      ["builtin_function_or_method"], true]
    - [as1441sh003, asyncio.Future.__subclasshook__.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
    - [as1441sh004, asyncio.Lock.__subclasshook__.__class__.__name__.__eq__,      ["builtin_function_or_method"], true]
    - [as1441sh005, asyncio.Event.__subclasshook__.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - [as1441sh006, asyncio.Semaphore.__subclasshook__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [as1441sh007, asyncio.Barrier.__subclasshook__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [as1441sh008, asyncio.TaskGroup.__subclasshook__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

table asyncio_extra1441.subclasshook_not_in_dict:
  description: "asyncio class __subclasshook__ absence from own __dict__ — none of the asyncio classes define __subclasshook__ in their own __dict__; all inherit it; __dict__.__contains__('__subclasshook__') is False for each; verified with Python 3.14.3"
  kind: python_call_eq
  category: subclasshook_dict_membership
  id_prefix: as1441sd
  columns: [id, function, args, expected]
  rows:
    - [as1441sd001, asyncio.Queue.__dict__.__contains__,     ["__subclasshook__"], false]
    - [as1441sd002, asyncio.Task.__dict__.__contains__,      ["__subclasshook__"], false]
    - [as1441sd003, asyncio.Future.__dict__.__contains__,    ["__subclasshook__"], false]
    - [as1441sd004, asyncio.Lock.__dict__.__contains__,      ["__subclasshook__"], false]
    - [as1441sd005, asyncio.Event.__dict__.__contains__,     ["__subclasshook__"], false]
    - [as1441sd006, asyncio.Semaphore.__dict__.__contains__,  ["__subclasshook__"], false]
    - [as1441sd007, asyncio.Barrier.__dict__.__contains__,   ["__subclasshook__"], false]
    - [as1441sd008, asyncio.TaskGroup.__dict__.__contains__,  ["__subclasshook__"], false]

