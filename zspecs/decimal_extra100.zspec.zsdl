spec: decimal_extra100
version: ">=3.9"
backend: python_module(decimal)
extends: decimal_extra99

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal_extra99.zspec.zsdl."
    - "This spec covers: decimal.Context and decimal.Decimal method __name__ string values."
    - "decimal.Context.quantize.__name__ = 'quantize'."
    - "decimal.Context.sqrt.__name__ = 'sqrt'."
    - "decimal.Context.copy_abs.__name__ = 'copy_abs'."
    - "decimal.Context.create_decimal.__name__ = 'create_decimal'."
    - "decimal.Context.clear_flags.__name__ = 'clear_flags'."
    - "decimal.Context.add.__name__ = 'add'."
    - "decimal.Context.subtract.__name__ = 'subtract'."
    - "decimal.Context.divide.__name__ = 'divide'."
    - "decimal.Decimal.quantize.__name__ = 'quantize'."
    - "decimal.Decimal.sqrt.__name__ = 'sqrt'."
    - "decimal.Decimal.normalize.__name__ = 'normalize'."
    - "decimal.Decimal.compare.__name__ = 'compare'."
    - "decimal.Decimal.ln.__name__ = 'ln'."
    - "decimal.Decimal.log10.__name__ = 'log10'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Context method __name__ string values
# Context methods are wrapper functions around GDA arithmetic operations.
# Each method's __name__ equals its bare function name (no class prefix).
# quantize='quantize', sqrt='sqrt', copy_abs='copy_abs',
# create_decimal='create_decimal', clear_flags='clear_flags',
# add='add', subtract='subtract', divide='divide'.
# ---------------------------------------------------------------------------

table decimal_extra100.Context_method_names:
  description: "decimal.Context method __name__ values: quantize, sqrt, copy_abs, create_decimal, clear_flags, add, subtract, divide"
  kind: python_call_eq
  category: class_names
  id_prefix: decmethname100a

  columns: [id, function, args, expected, description]
  rows:
    - [ctx_quantize_name,       Context.quantize.__name__.__eq__,       ["quantize"],       true,  "decimal.Context.quantize.__name__ == 'quantize'"]
    - [ctx_sqrt_name,           Context.sqrt.__name__.__eq__,           ["sqrt"],           true,  "decimal.Context.sqrt.__name__ == 'sqrt'"]
    - [ctx_copy_abs_name,       Context.copy_abs.__name__.__eq__,       ["copy_abs"],       true,  "decimal.Context.copy_abs.__name__ == 'copy_abs'"]
    - [ctx_create_decimal_name, Context.create_decimal.__name__.__eq__, ["create_decimal"], true,  "decimal.Context.create_decimal.__name__ == 'create_decimal'"]
    - [ctx_clear_flags_name,    Context.clear_flags.__name__.__eq__,    ["clear_flags"],    true,  "decimal.Context.clear_flags.__name__ == 'clear_flags'"]
    - [ctx_add_name,            Context.add.__name__.__eq__,            ["add"],            true,  "decimal.Context.add.__name__ == 'add'"]
    - [ctx_subtract_name,       Context.subtract.__name__.__eq__,       ["subtract"],       true,  "decimal.Context.subtract.__name__ == 'subtract'"]
    - [ctx_divide_name,         Context.divide.__name__.__eq__,         ["divide"],         true,  "decimal.Context.divide.__name__ == 'divide'"]
    - [ctx_add_not_ctx,         Context.add.__name__.__eq__,            ["Context.add"],    false, "decimal.Context.add.__name__ != 'Context.add' (bare method name, no class prefix)"]

# ---------------------------------------------------------------------------
# decimal.Decimal method __name__ string values
# Decimal methods implement GDA arithmetic on individual Decimal values.
# Each method's __name__ equals its bare function name.
# quantize='quantize', sqrt='sqrt', normalize='normalize',
# compare='compare', ln='ln', log10='log10'.
# ---------------------------------------------------------------------------

table decimal_extra100.Decimal_method_names:
  description: "decimal.Decimal method __name__ values: quantize, sqrt, normalize, compare, ln, log10"
  kind: python_call_eq
  category: class_names
  id_prefix: decmethname100b

  columns: [id, function, args, expected, description]
  rows:
    - [dec_quantize_name,  Decimal.quantize.__name__.__eq__,  ["quantize"],  true,  "decimal.Decimal.quantize.__name__ == 'quantize'"]
    - [dec_sqrt_name,      Decimal.sqrt.__name__.__eq__,      ["sqrt"],      true,  "decimal.Decimal.sqrt.__name__ == 'sqrt'"]
    - [dec_normalize_name, Decimal.normalize.__name__.__eq__, ["normalize"], true,  "decimal.Decimal.normalize.__name__ == 'normalize'"]
    - [dec_compare_name,   Decimal.compare.__name__.__eq__,   ["compare"],   true,  "decimal.Decimal.compare.__name__ == 'compare'"]
    - [dec_ln_name,        Decimal.ln.__name__.__eq__,        ["ln"],        true,  "decimal.Decimal.ln.__name__ == 'ln'"]
    - [dec_log10_name,     Decimal.log10.__name__.__eq__,     ["log10"],     true,  "decimal.Decimal.log10.__name__ == 'log10'"]
    - [dec_sqrt_not_cbrt,  Decimal.sqrt.__name__.__eq__,      ["cbrt"],      false, "decimal.Decimal.sqrt.__name__ != 'cbrt' (sqrt returns square root, not cube root)"]
    - [dec_ln_not_log,     Decimal.ln.__name__.__eq__,        ["log"],       false, "decimal.Decimal.ln.__name__ != 'log' (natural log is 'ln', not 'log')"]

# ---------------------------------------------------------------------------
# Cross-check: Context and Decimal share some method names (quantize, sqrt)
# Both Context.quantize.__name__ == 'quantize' and
# Decimal.quantize.__name__ == 'quantize'. Same for sqrt.
# ---------------------------------------------------------------------------

table decimal_extra100.shared_method_names:
  description: "decimal.Context and decimal.Decimal share method names for quantize and sqrt; __name__ is the same bare string for both"
  kind: python_call_eq
  category: class_names
  id_prefix: decmethname100c

  columns: [id, function, args, expected, description]
  rows:
    - [ctx_qz_name,  Context.quantize.__name__.__eq__,  ["quantize"], true,  "decimal.Context.quantize.__name__ == 'quantize'"]
    - [dec_qz_name,  Decimal.quantize.__name__.__eq__,  ["quantize"], true,  "decimal.Decimal.quantize.__name__ == 'quantize' (same bare name as Context.quantize)"]
    - [ctx_sq_name,  Context.sqrt.__name__.__eq__,      ["sqrt"],     true,  "decimal.Context.sqrt.__name__ == 'sqrt'"]
    - [dec_sq_name,  Decimal.sqrt.__name__.__eq__,      ["sqrt"],     true,  "decimal.Decimal.sqrt.__name__ == 'sqrt' (same bare name as Context.sqrt)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra100.Context.quantize_name_is_quantize:
  description: "decimal.Context.quantize.__name__ == 'quantize' (Context.quantize adjusts a Decimal to the exponent of another; its __name__ is the bare method name with no class prefix)"
  category: class_names
  kind: python_call_eq
  function: Context.quantize.__name__.__eq__
  args: ["quantize"]
  expected: true

invariant decimal_extra100.Context.create_decimal_name_is_create_decimal:
  description: "decimal.Context.create_decimal.__name__ == 'create_decimal' (creates a new Decimal using the context's precision and rounding settings; the longest __name__ among the Context methods tested here)"
  category: class_names
  kind: python_call_eq
  function: Context.create_decimal.__name__.__eq__
  args: ["create_decimal"]
  expected: true

invariant decimal_extra100.Decimal.ln_name_is_ln:
  description: "decimal.Decimal.ln.__name__ == 'ln' (natural logarithm method; 'ln' is the shortest __name__ among Decimal's math methods, with length 2)"
  category: class_names
  kind: python_call_eq
  function: Decimal.ln.__name__.__eq__
  args: ["ln"]
  expected: true

invariant decimal_extra100.Decimal.normalize_name_is_normalize:
  description: "decimal.Decimal.normalize.__name__ == 'normalize' (reduces trailing zeros per GDA specification; __name__ is the bare method name 'normalize')"
  category: class_names
  kind: python_call_eq
  function: Decimal.normalize.__name__.__eq__
  args: ["normalize"]
  expected: true

invariant decimal_extra100.Decimal.log10_name_is_log10:
  description: "decimal.Decimal.log10.__name__ == 'log10' (base-10 logarithm; distinct from Decimal.ln which is the natural logarithm)"
  category: class_names
  kind: python_call_eq
  function: Decimal.log10.__name__.__eq__
  args: ["log10"]
  expected: true
