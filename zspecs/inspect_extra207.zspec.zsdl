invariant inspect_extra207.isfunction_co_flags_class_int:
  description: "inspect.isfunction.__code__.co_flags.__class__.__name__ == 'int' — co_flags is an integer bitmask; isfunction is a Python-level function; co_flags==67108867; new to extra207; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: inspect.isfunction.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant inspect_extra207.signature_co_flags_value:
  description: "inspect.signature.__code__.co_flags == 67108867 — exact bitmask value; same value as functools Python-level functions; new to extra207; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  function: inspect.signature.__code__.co_flags.__eq__
