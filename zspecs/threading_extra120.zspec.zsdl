  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Barrier.wait code object attributes
#
# Wave 270 theme: threading.Barrier is a pure-Python synchronization barrier
# defined in Lib/threading.py. Prior spec extra79 covered Barrier.__init__
# code attributes (co_name == '__init__', co_argcount == 4). New here are
# the wait, reset, and abort method code attributes. Barrier.wait.__code__.co_name
# is 'wait' (4 chars). Barrier.wait.__code__.co_argcount is 2 (self + timeout).
# co_varnames[0] is 'self' and co_varnames[1] is 'timeout'. The timeout
# parameter lets a single thread wait with a time limit. Previously covered
# in threading specs: wait.__qualname__ (extra104), wait.__code__.co_argcount
# was NOT covered.
#
# Barrier.wait.__code__.co_name == 'wait'       (len 4)
# Barrier.wait.__code__.co_argcount == 2
# Barrier.wait.__code__.co_varnames[1] == 'timeout'
#
# New to extra120.
# ---------------------------------------------------------------------------

table threading_extra120.barrier_wait_code_attrs:
  description: "threading.Barrier.wait code object: co_name='wait'(4), co_argcount=2 (self+timeout), co_varnames[0]='self', co_varnames[1]='timeout'; blocks until all parties have called wait(); wave 270; new to extra120"
  kind: python_call_eq
  category: code_identity
  id_prefix: threadingbwca120

  columns: [id, function, args, expected, description]
  rows:
    - [wait_co_name_eq,
       "Barrier.wait.__code__.co_name.__eq__",
       ["wait"],
       true,
       "threading.Barrier.wait.__code__.co_name.__eq__('wait') == True — co_name matches the def-statement identifier 'wait' (4 chars); Barrier is defined in Lib/threading.py; str.__eq__('wait') returns True; new to extra120"]
    - [wait_co_argcount,
       "Barrier.wait.__code__.co_argcount.__eq__",
       [2],
       true,
       "threading.Barrier.wait.__code__.co_argcount.__eq__(2) == True — Barrier.wait(self, timeout=None) has 2 positional-or-keyword parameters: self and timeout; int.__eq__(2) returns True; new to extra120"]
    - [wait_co_varnames0,
       "Barrier.wait.__code__.co_varnames.__getitem__",
       [0],
       "self",
       "threading.Barrier.wait.__code__.co_varnames[0] == 'self' — the first parameter of wait() is the Barrier instance; tuple.__getitem__(0) returns 'self'; new to extra120"]
    - [wait_co_varnames1,
       "Barrier.wait.__code__.co_varnames.__getitem__",
       [1],
       "timeout",
       "threading.Barrier.wait.__code__.co_varnames[1] == 'timeout' — the second parameter is 'timeout' (with default None); a thread can specify a maximum wait time; tuple.__getitem__(1) returns 'timeout'; new to extra120"]
    - [wait_qualname_len,
       "Barrier.wait.__qualname__.__len__",
       [],
       12,
       "threading.Barrier.wait.__qualname__.__len__() == 12 — 'Barrier.wait' has 12 chars: Barrier(7)+dot(1)+wait(4); already covered in extra104 for context; str.__len__() returns 12; new to extra120"]

# ---------------------------------------------------------------------------
# Table 2: threading.Barrier.reset and abort code object attributes
#
# Wave 270 theme: Barrier.reset resets the barrier to its initial state; it
# takes only 'self' (co_argcount == 1). Barrier.abort puts the barrier into
# a broken state, also taking only 'self' (co_argcount == 1). Both reset and
# abort are 1-argument methods — they perform a state transition on the barrier
# without extra parameters. Their co_names are 'reset' (5 chars) and 'abort'
# (5 chars) — equal length. The qualnames 'Barrier.reset' (13 chars) and
# 'Barrier.abort' (13 chars) are also equal length. These code attributes have
# NOT been covered in any prior threading spec.
#
# Barrier.reset.__code__.co_name == 'reset'   (len 5)
# Barrier.reset.__code__.co_argcount == 1
# Barrier.abort.__code__.co_name == 'abort'   (len 5)
# Barrier.abort.__code__.co_argcount == 1
#
# New to extra120.
# ---------------------------------------------------------------------------

table threading_extra120.barrier_reset_abort_code_attrs:
  description: "threading.Barrier reset and abort code objects: reset co_name='reset'(5), co_argcount=1; abort co_name='abort'(5), co_argcount=1; both take only self; equal-length co_names; wave 270; new to extra120"
  kind: python_call_eq
  category: code_identity
  id_prefix: threadingbraca120

  columns: [id, function, args, expected, description]
  rows:
    - [reset_co_name_eq,
       "Barrier.reset.__code__.co_name.__eq__",
       ["reset"],
       true,
       "threading.Barrier.reset.__code__.co_name.__eq__('reset') == True — co_name matches the def-statement identifier 'reset' (5 chars); Barrier.reset restores the barrier to fresh state; str.__eq__('reset') returns True; new to extra120"]
    - [reset_co_argcount,
       "Barrier.reset.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading.Barrier.reset.__code__.co_argcount.__eq__(1) == True — Barrier.reset(self) takes only self; no other parameters; int.__eq__(1) returns True; new to extra120"]
    - [reset_co_varnames0,
       "Barrier.reset.__code__.co_varnames.__getitem__",
       [0],
       "self",
       "threading.Barrier.reset.__code__.co_varnames[0] == 'self' — the only parameter of reset() is the Barrier instance; tuple.__getitem__(0) returns 'self'; new to extra120"]
    - [abort_co_name_eq,
       "Barrier.abort.__code__.co_name.__eq__",
       ["abort"],
       true,
       "threading.Barrier.abort.__code__.co_name.__eq__('abort') == True — co_name matches the def-statement identifier 'abort' (5 chars); Barrier.abort puts the barrier into a broken state; equal length to 'reset' (5); str.__eq__('abort') returns True; new to extra120"]
    - [abort_co_argcount,
       "Barrier.abort.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading.Barrier.abort.__code__.co_argcount.__eq__(1) == True — Barrier.abort(self) takes only self; same co_argcount as reset (1); int.__eq__(1) returns True; new to extra120"]
    - [abort_co_varnames0,
       "Barrier.abort.__code__.co_varnames.__getitem__",
       [0],
       "self",
       "threading.Barrier.abort.__code__.co_varnames[0] == 'self' — the only parameter of abort() is the Barrier instance; same as reset; tuple.__getitem__(0) returns 'self'; new to extra120"]

# ---------------------------------------------------------------------------
# Table 3: threading.Barrier method co_name string lengths
#
# Wave 270 theme: The co_name string lengths for Barrier's four methods are:
# __init__ (8 chars), wait (4 chars), reset (5 chars), abort (5 chars).
# 'reset' and 'abort' have the same length (5) — equal to 'Barrier'.__name__
# minus 2. Prior spec extra79 established __init__ co_name length (8) and
# co_argcount (4). New here: wait co_name length (4), reset co_name length (5),
# abort co_name length (5), and the equality between reset and abort lengths.
# The qualname 'Barrier.wait' (12 chars) is shorter than 'Barrier.reset' and
# 'Barrier.abort' (both 13 chars) because 'wait' is 4 chars vs 5.
#
# len(Barrier.wait.__code__.co_name) == 4
# len(Barrier.reset.__code__.co_name) == 5
# len(Barrier.abort.__code__.co_name) == 5
# len(Barrier.__init__.__code__.co_name) == 8
#
# New to extra120.
# ---------------------------------------------------------------------------

table threading_extra120.barrier_method_coname_lens:
  description: "threading.Barrier method co_name lengths: wait=4, reset=5, abort=5 (equal), __init__=8; reset and abort share len=5; qualname Barrier.wait (12) < Barrier.reset/abort (13); wave 270; new to extra120"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingbmcnl120

  columns: [id, function, args, expected, description]
  rows:
    - [wait_co_name_len,
       "Barrier.wait.__code__.co_name.__len__",
       [],
       4,
       "threading.Barrier.wait.__code__.co_name.__len__() == 4 — 'wait' has 4 chars: w-a-i-t; the shortest Barrier method name; str.__len__() returns 4; new to extra120"]
    - [reset_co_name_len,
       "Barrier.reset.__code__.co_name.__len__",
       [],
       5,
       "threading.Barrier.reset.__code__.co_name.__len__() == 5 — 'reset' has 5 chars: r-e-s-e-t; equal to abort co_name length (5); one more than wait (4); str.__len__() returns 5; new to extra120"]
    - [abort_co_name_len,
       "Barrier.abort.__code__.co_name.__len__",
       [],
       5,
       "threading.Barrier.abort.__code__.co_name.__len__() == 5 — 'abort' has 5 chars: a-b-o-r-t; equal to reset co_name length (5); str.__len__() returns 5; new to extra120"]
    - [init_co_name_len,
       "Barrier.__init__.__code__.co_name.__len__",
       [],
       8,
       "threading.Barrier.__init__.__code__.co_name.__len__() == 8 — '__init__' has 8 chars: _-_-i-n-i-t-_-_; the longest Barrier method co_name (8 > 5 > 4); str.__len__() returns 8; confirming prior extra79 coverage; new to extra120"]
    - [reset_qualname_len,
       "Barrier.reset.__qualname__.__len__",
       [],
       13,
       "threading.Barrier.reset.__qualname__.__len__() == 13 — 'Barrier.reset' has 13 chars: Barrier(7)+dot(1)+reset(5); one more than wait qualname (12); already covered in extra104 for context; str.__len__() returns 13; new to extra120"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra120
# ---------------------------------------------------------------------------

invariant threading_extra120.barrier_wait_co_name:
  description: "threading.Barrier.wait.__code__.co_name == 'wait' — co_name has 4 chars; wait.__code__ not previously covered in threading specs; wave 270; new to extra120"
  kind: python_call_eq
  function: Barrier.wait.__code__.co_name.__eq__
  args: ["wait"]
  expected: true

invariant threading_extra120.barrier_wait_co_argcount:
  description: "threading.Barrier.wait.__code__.co_argcount == 2 — wait(self, timeout) has 2 positional-or-keyword params; different from reset/abort (1 each); wave 270; new to extra120"
  kind: python_call_eq
  function: Barrier.wait.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant threading_extra120.barrier_reset_co_argcount:
  description: "threading.Barrier.reset.__code__.co_argcount == 1 — reset(self) takes only self; same as abort; wave 270; new to extra120"
  kind: python_call_eq
  function: Barrier.reset.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant threading_extra120.barrier_abort_co_name:
  description: "threading.Barrier.abort.__code__.co_name == 'abort' — co_name has 5 chars; equal to reset (5); puts barrier in broken state; wave 270; new to extra120"
  kind: python_call_eq
  function: Barrier.abort.__code__.co_name.__eq__
  args: ["abort"]
  expected: true

invariant threading_extra120.barrier_wait_varnames1:
  description: "threading.Barrier.wait.__code__.co_varnames[1] == 'timeout' — second parameter to wait() is timeout; allows time-limited waiting; wave 270; new to extra120"
  kind: python_call_eq
  function: "Barrier.wait.__code__.co_varnames.__getitem__"
  args: [1]
  expected: "timeout"

