spec: theseus_modulefinder_cr
version: ">=3.0"
backend: python_cleanroom(theseus_modulefinder_cr)
blocks: modulefinder

docs: https://docs.python.org/3/library/modulefinder.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/modulefinder.html"
  not_derived_from:
    - "CPython source: Lib/modulefinder.py"
  notes:
    - "Clean-room modulefinder module. Do NOT import modulefinder."

error_model: python_exceptions

invariant theseus_modulefinder_cr.mf2_create:
  description: "ModuleFinder can be instantiated"
  category: behavior
  kind: python_call_eq
  function: mf2_create
  args: []
  expected: true

invariant theseus_modulefinder_cr.mf2_modules:
  description: "ModuleFinder.modules dict is accessible"
  category: behavior
  kind: python_call_eq
  function: mf2_modules
  args: []
  expected: true

invariant theseus_modulefinder_cr.mf2_MISSING:
  description: "MISSING and Module class exist"
  category: behavior
  kind: python_call_eq
  function: mf2_missing
  args: []
  expected: true
