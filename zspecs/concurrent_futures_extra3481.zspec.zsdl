spec: cf3481
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 679 (cf3481): __enter__, __exit__, __call__ dict-presence checks for concurrent.futures types."
    - "Theme: __enter__/__exit__/__call__ dict-presence (context manager and callable protocols)."
    - "concurrent.futures.ThreadPoolExecutor defines __enter__ and __exit__ (true): ThreadPoolExecutor is a context manager — 'with ThreadPoolExecutor() as ex:' is valid."
    - "concurrent.futures.ProcessPoolExecutor does NOT define __enter__ or __exit__ in its own __dict__ (false): it inherits them from Executor."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: concurrent.futures.Future, concurrent.futures.ThreadPoolExecutor, concurrent.futures.ProcessPoolExecutor."
    - "Key finding (__enter__): ThreadPoolExecutor defines __enter__ in its own __dict__ (true). 'with ThreadPoolExecutor() as ex:' is a common and idiomatic pattern — ThreadPoolExecutor directly defines __enter__ in its own class __dict__ to support this. ProcessPoolExecutor does NOT define __enter__ in its own __dict__ (false) — it inherits context manager support from Executor. concurrent.futures.Future does NOT define __enter__ in its own __dict__ (false) — Future objects are result handles and are not used as context managers."
    - "Key finding (__exit__): ThreadPoolExecutor defines __exit__ in its own __dict__ (true). The __exit__ implementation calls shutdown(wait=True) to clean up the thread pool. ProcessPoolExecutor does NOT define __exit__ in its own __dict__ (false) — it inherits context manager support from Executor. concurrent.futures.Future does NOT define __exit__ in its own __dict__ (false)."
    - "Key finding (__call__): all 3 concurrent.futures classes return false for __call__. Executors are not callable as function-like objects — they are lifecycle managers. Future result handles are not callable. None define __call__ in their own __dict__."
    - "Inheritance note: Executor is the base class for both ThreadPoolExecutor and ProcessPoolExecutor. Executor defines __enter__ and __exit__ in its own __dict__. ThreadPoolExecutor overrides both by defining them in its own __dict__. ProcessPoolExecutor does NOT override them — it relies on Executor's definitions, which are absent from ProcessPoolExecutor.__dict__."
    - "Cross-wave summary for cf subjects:"
    - "  Wave 658 (cf3166): __add__/__sub__/__mul__ — all false for all 3."
    - "  Wave 659 (cf3181): __truediv__/__floordiv__/__mod__ — all false for all 3."
    - "  Wave 660 (cf3196): __pow__/__lshift__/__rshift__ — all false for all 3."
    - "  Wave 661 (cf3211): __and__/__or__/__xor__ — all false for all 3."
    - "  Wave 662 (cf3226): __radd__/__rsub__/__rmul__ — all false for all 3."
    - "  Wave 663 (cf3241): __rtruediv__/__rfloordiv__/__rmod__ — all false for all 3."
    - "  Wave 664 (cf3256): __rpow__/__rlshift__/__rrshift__ — all false for all 3."
    - "  Wave 665 (cf3271): __rand__/__ror__/__rxor__ — all false for all 3."
    - "  Wave 666 (cf3286): __iadd__/__isub__/__imul__ — all false for all 3."
    - "  Wave 667 (cf3301): __itruediv__/__ifloordiv__/__imod__ — all false for all 3."
    - "  Wave 668 (cf3316): __ipow__/__ilshift__/__irshift__ — all false for all 3."
    - "  Wave 669 (cf3331): __iand__/__ior__/__ixor__ — all false for all 3."
    - "  Wave 670 (cf3346): __neg__/__pos__/__abs__ — all false for all 3."
    - "  Wave 671 (cf3361): __invert__/__floor__/__ceil__ — all false for all 3."
    - "  Wave 672 (cf3376): __trunc__/__round__/__index__ — all false for all 3."
    - "  Wave 673 (cf3391): __int__/__float__/__complex__ — all false for all 3."
    - "  Wave 674 (cf3406): __bool__/__str__/__repr__ — all false for all 3."
    - "  Wave 675 (cf3421): __hash__/__eq__/__lt__ — all false for all 3."
    - "  Wave 676 (cf3436): __le__/__gt__/__ge__ — all false for all 3."
    - "  Wave 677 (cf3451): __getitem__/__setitem__/__delitem__ — all false for all 3."
    - "  Wave 678 (cf3466): __iter__/__next__/__len__ — all false for all 3."
    - "  Wave 679 (cf3481): __enter__/__exit__/__call__ — ThreadPoolExecutor __enter__=true, __exit__=true; all others false."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __enter__ dict-presence — operator.contains(Cls.__dict__, '__enter__')
#
# ThreadPoolExecutor defines __enter__ in its own __dict__ (true).
# 'with ThreadPoolExecutor() as ex:' is idiomatic Python for managing a thread
#   pool lifetime. ThreadPoolExecutor directly defines __enter__ in its class
#   __dict__ to support this pattern.
# ProcessPoolExecutor does NOT define __enter__ in its own __dict__ (false).
#   ProcessPoolExecutor inherits context manager support from Executor, whose
#   __enter__ is NOT copied into ProcessPoolExecutor.__dict__.
# concurrent.futures.Future does NOT define __enter__ in its own __dict__ (false).
#   Future objects are result handles — they are not used as context managers.
# ---------------------------------------------------------------------------

table cf3481.enter:
  description: "concurrent.futures types __enter__ dict-presence checks; wave 679"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3481

  columns: [id, function, args, expected]
  rows:
    - ["cf3481001", operator.contains, [concurrent.futures.Future.__dict__,              "__enter__"], false]
    - ["cf3481002", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__enter__"], true]
    - ["cf3481003", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__enter__"], false]

# ---------------------------------------------------------------------------
# __exit__ dict-presence — operator.contains(Cls.__dict__, '__exit__')
#
# ThreadPoolExecutor defines __exit__ in its own __dict__ (true).
# The __exit__ implementation calls self.shutdown(wait=True) to ensure all
#   submitted futures complete and threads are cleaned up before exiting the
#   'with' block. This is defined directly in ThreadPoolExecutor.__dict__.
# ProcessPoolExecutor does NOT define __exit__ in its own __dict__ (false).
#   It inherits __exit__ from Executor — the definition lives in Executor.__dict__,
#   not ProcessPoolExecutor.__dict__.
# concurrent.futures.Future does NOT define __exit__ in its own __dict__ (false).
#   Future objects are not context managers.
# ---------------------------------------------------------------------------

table cf3481.exit:
  description: "concurrent.futures types __exit__ dict-presence checks; wave 679"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3481

  columns: [id, function, args, expected]
  rows:
    - ["cf3481004", operator.contains, [concurrent.futures.Future.__dict__,              "__exit__"], false]
    - ["cf3481005", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__exit__"], true]
    - ["cf3481006", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__exit__"], false]

# ---------------------------------------------------------------------------
# __call__ dict-presence — operator.contains(Cls.__dict__, '__call__')
#
# All 3 concurrent.futures classes return false for __call__.
# Executors (ThreadPoolExecutor, ProcessPoolExecutor) are lifecycle managers;
#   work is dispatched via submit(fn, *args) and map(fn, *iterables), not
#   by calling the executor directly. No __call__ defined in their own __dict__.
# concurrent.futures.Future: a state-machine result handle. Futures are
#   retrieved and inspected via result(), exception(), done(), running(),
#   cancelled(), add_done_callback() — not by being called. No __call__ in
#   Future.__dict__.
# ---------------------------------------------------------------------------

table cf3481.call:
  description: "concurrent.futures types __call__ dict-presence checks; wave 679"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3481

  columns: [id, function, args, expected]
  rows:
    - ["cf3481007", operator.contains, [concurrent.futures.Future.__dict__,              "__call__"], false]
    - ["cf3481008", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__call__"], false]
    - ["cf3481009", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__call__"], false]

# ---------------------------------------------------------------------------
# combined — __enter__, __exit__, __call__ across all 3 cf subjects
#
# Covers the full matrix: 3 classes x 3 methods = 9 rows.
# __enter__: true for ThreadPoolExecutor; false for Future and ProcessPoolExecutor.
# __exit__:  true for ThreadPoolExecutor; false for Future and ProcessPoolExecutor.
# __call__:  false for all 3.
# Total true values: 2 (ThreadPoolExecutor __enter__ and __exit__).
# Total false values: 7.
# concurrent.futures.ThreadPoolExecutor is the first cf type across waves 658–679
#   to define any dunder in its own __dict__. This reflects ThreadPoolExecutor's
#   design as a concrete context manager — 'with ThreadPoolExecutor() as ex:'
#   is a standard Python idiom for managing thread pool lifetime.
# concurrent.futures.ProcessPoolExecutor inherits __enter__ and __exit__ from
#   Executor but does NOT define them in its own __dict__. This is the canonical
#   dict-contains distinction: inherited dunders do not appear in the subclass __dict__.
# concurrent.futures.Future: the result handle is not a context manager and not
#   callable. It exposes only state-inspection and callback registration methods.
# ---------------------------------------------------------------------------

table cf3481.combined:
  description: "concurrent.futures types combined __enter__/__exit__/__call__; wave 679"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3481

  columns: [id, function, args, expected]
  rows:
    - ["cf3481010", operator.contains, [concurrent.futures.Future.__dict__,              "__enter__"], false]
    - ["cf3481011", operator.contains, [concurrent.futures.Future.__dict__,              "__exit__"],  false]
    - ["cf3481012", operator.contains, [concurrent.futures.Future.__dict__,              "__call__"],  false]
    - ["cf3481013", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__enter__"], true]
    - ["cf3481014", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__exit__"],  true]
    - ["cf3481015", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__call__"],  false]
    - ["cf3481016", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__enter__"], false]
    - ["cf3481017", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__exit__"],  false]
    - ["cf3481018", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__call__"],  false]
