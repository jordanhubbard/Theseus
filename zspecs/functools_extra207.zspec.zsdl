  notes:
    - "This spec covers module-level dunder attributes of functools: __name__, __package__, __spec__.name, __loader__.__class__.__name__, __builtins__.__class__.__name__."
    - "functools.__name__ == 'functools' — module identity attribute. Verified with Python 3.14.3."
    - "functools.__package__ == '' — top-level module; __package__ is empty string. Verified with Python 3.14.3."
    - "functools.__spec__.name == 'functools' — ModuleSpec.name attribute equals module name. Verified with Python 3.14.3."
    - "functools.__loader__.__class__.__name__ == 'SourceFileLoader' — functools is a .py source file; loader is SourceFileLoader. Verified with Python 3.14.3."
    - "functools.__builtins__.__class__.__name__ == 'dict' — in a module context __builtins__ is a dict. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

