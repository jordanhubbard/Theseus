spec: numbers_extra17
version: ">=3.9"
backend: python_module(numbers)

docs: https://docs.python.org/3/library/numbers.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/numbers.html — Python numbers module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/numbers.py"
  notes:
    - "This spec extends numbers_extra through numbers_extra16."
    - "numbers_extra16 covers __qualname__, __module__, __bases__[0].__name__, __abstractmethods__ type and count for all 5 ABCs."
    - "No prior spec records __dict__.__class__.__name__ for Number or Complex (both are 'mappingproxy')."
    - "No prior spec records membership of specific method names in Complex.__abstractmethods__."
    - "No prior spec records __qualname__ for __subclasshook__ on Number, Complex, Real, or Integral."
    - "Complex.__abstractmethods__ contains 16 names; __add__, __mul__, __truediv__, __pow__, __abs__, __neg__, __pos__ are all present."
    - "__sub__ is NOT in Complex.__abstractmethods__ — subtraction is provided via __add__ + __neg__ by default."
    - "All __subclasshook__ methods follow 'ClassName.__subclasshook__' __qualname__ pattern."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __dict__.__class__.__name__ for ABC classes
#
# No prior spec records that the __dict__ attribute of Number or Complex
# is a mappingproxy.  Class __dict__ objects are always mappingproxy instances.
# ---------------------------------------------------------------------------

invariant numbers_extra17.Number.dict_class_name:
  description: "numbers.Number.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is a mappingproxy"
  category: type_identity
  kind: python_call_eq
  function: Number.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant numbers_extra17.Complex.dict_class_name:
  description: "numbers.Complex.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is a mappingproxy"
  category: type_identity
  kind: python_call_eq
  function: Complex.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant numbers_extra17.mappingproxy_name_len:
  description: "len('mappingproxy') == 12 — the string 'mappingproxy' is 12 chars"
  category: type_identity
  kind: python_call_eq
  function: Number.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# Abstract method membership in Complex.__abstractmethods__
#
# No prior spec verifies which specific names are present (or absent) in
# Complex.__abstractmethods__.  The frozenset has 16 members; key arithmetic
# operators are abstract while __sub__ is intentionally absent (subtraction
# is derived from __add__ + __neg__ by default).
# ---------------------------------------------------------------------------

table numbers_extra17.complex_abstractmethods_present:
  kind: python_call_eq
  category: class_identity
  id_prefix: in_abstractmethods

  columns: [id, function, args, expected, description]
  rows:
    - [add,       Complex.__abstractmethods__.__contains__, ["__add__"],      true, "'__add__' is abstract in numbers.Complex"]
    - [mul,       Complex.__abstractmethods__.__contains__, ["__mul__"],      true, "'__mul__' is abstract in numbers.Complex"]
    - [truediv,   Complex.__abstractmethods__.__contains__, ["__truediv__"],  true, "'__truediv__' is abstract in numbers.Complex"]
    - [pow,       Complex.__abstractmethods__.__contains__, ["__pow__"],      true, "'__pow__' is abstract in numbers.Complex"]
    - [abs,       Complex.__abstractmethods__.__contains__, ["__abs__"],      true, "'__abs__' is abstract in numbers.Complex"]
    - [neg,       Complex.__abstractmethods__.__contains__, ["__neg__"],      true, "'__neg__' is abstract in numbers.Complex"]
    - [pos,       Complex.__abstractmethods__.__contains__, ["__pos__"],      true, "'__pos__' is abstract in numbers.Complex"]
    - [eq,        Complex.__abstractmethods__.__contains__, ["__eq__"],       true, "'__eq__' is abstract in numbers.Complex"]
    - [complex,   Complex.__abstractmethods__.__contains__, ["__complex__"],  true, "'__complex__' is abstract in numbers.Complex"]
    - [conjugate, Complex.__abstractmethods__.__contains__, ["conjugate"],    true, "'conjugate' is abstract in numbers.Complex"]
    - [real,      Complex.__abstractmethods__.__contains__, ["real"],         true, "'real' is abstract in numbers.Complex"]
    - [imag,      Complex.__abstractmethods__.__contains__, ["imag"],         true, "'imag' is abstract in numbers.Complex"]

# ---------------------------------------------------------------------------
# __sub__ is NOT in Complex.__abstractmethods__
#
# Subtraction is not declared abstract on Complex; it is provided via the
# default mixin implementation using __add__ and __neg__.
# ---------------------------------------------------------------------------

invariant numbers_extra17.Complex.sub_not_abstract:
  description: "'__sub__' is NOT in numbers.Complex.__abstractmethods__ — subtraction is a mixin method"
  category: class_identity
  kind: python_call_eq
  function: Complex.__abstractmethods__.__contains__
  args: ["__sub__"]
  expected: false

# ---------------------------------------------------------------------------
# __subclasshook__ __qualname__ values
#
# No prior spec records __qualname__ for __subclasshook__ on any of the ABCs.
# Each ABC defines its own __subclasshook__; qualname follows 'ClassName.__subclasshook__'.
# ---------------------------------------------------------------------------

table numbers_extra17.subclasshook_qualnames:
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [Number,   Number.__subclasshook__.__qualname__.__eq__,   ["Number.__subclasshook__"],   true, "numbers.Number.__subclasshook__.__qualname__ == 'Number.__subclasshook__'"]
    - [Complex,  Complex.__subclasshook__.__qualname__.__eq__,  ["Complex.__subclasshook__"],  true, "numbers.Complex.__subclasshook__.__qualname__ == 'Complex.__subclasshook__'"]
    - [Real,     Real.__subclasshook__.__qualname__.__eq__,     ["Real.__subclasshook__"],     true, "numbers.Real.__subclasshook__.__qualname__ == 'Real.__subclasshook__'"]
    - [Integral, Integral.__subclasshook__.__qualname__.__eq__, ["Integral.__subclasshook__"], true, "numbers.Integral.__subclasshook__.__qualname__ == 'Integral.__subclasshook__'"]

# ---------------------------------------------------------------------------
# __subclasshook__ __qualname__ length invariants
# ---------------------------------------------------------------------------

invariant numbers_extra17.Number.subclasshook_qualname_len:
  description: "len(numbers.Number.__subclasshook__.__qualname__) == 23 — 'Number.__subclasshook__' is 23 chars"
  category: method_identity
  kind: python_call_eq
  function: Number.__subclasshook__.__qualname__.__len__
  args: []
  expected: 23

invariant numbers_extra17.Complex.subclasshook_qualname_len:
  description: "len(numbers.Complex.__subclasshook__.__qualname__) == 24 — 'Complex.__subclasshook__' is 24 chars"
  category: method_identity
  kind: python_call_eq
  function: Complex.__subclasshook__.__qualname__.__len__
  args: []
  expected: 24
