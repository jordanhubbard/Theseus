spec: statistics_extra20
version: ">=3.9"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html — Python statistics module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
  notes:
    - "This spec extends statistics_extra through statistics_extra19."
    - "statistics_extra17 covers NormalDist.__qualname__.__eq__ == 'NormalDist' (class-level)."
    - "statistics_extra19 covers __qualname__.__len__ for top-level functions and NormalDist/StatisticsError class names."
    - "No prior spec covers __qualname__ for individual NormalDist instance methods (__init__, pdf, cdf, inv_cdf, __add__, __mul__, overlap)."
    - "All NormalDist methods are defined directly on the class; __qualname__ follows 'NormalDist.<name>' pattern."
    - "Focus: statistics.NormalDist class method __qualname__ values."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# NormalDist method __qualname__ values
#
# Prior specs record __qualname__ for the NormalDist class itself.
# No prior spec records __qualname__ for individual methods on NormalDist.
# All methods are defined directly on the class, giving qualname 'NormalDist.<name>'.
# ---------------------------------------------------------------------------

table statistics_extra20.normaldist_method_qualnames:
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [init,    NormalDist.__init__.__qualname__.__eq__,   ["NormalDist.__init__"],   true, "NormalDist.__init__.__qualname__ == 'NormalDist.__init__'"]
    - [pdf,     NormalDist.pdf.__qualname__.__eq__,        ["NormalDist.pdf"],        true, "NormalDist.pdf.__qualname__ == 'NormalDist.pdf'"]
    - [cdf,     NormalDist.cdf.__qualname__.__eq__,        ["NormalDist.cdf"],        true, "NormalDist.cdf.__qualname__ == 'NormalDist.cdf'"]
    - [inv_cdf, NormalDist.inv_cdf.__qualname__.__eq__,    ["NormalDist.inv_cdf"],    true, "NormalDist.inv_cdf.__qualname__ == 'NormalDist.inv_cdf'"]
    - [add,     NormalDist.__add__.__qualname__.__eq__,    ["NormalDist.__add__"],    true, "NormalDist.__add__.__qualname__ == 'NormalDist.__add__'"]
    - [mul,     NormalDist.__mul__.__qualname__.__eq__,    ["NormalDist.__mul__"],    true, "NormalDist.__mul__.__qualname__ == 'NormalDist.__mul__'"]
    - [overlap, NormalDist.overlap.__qualname__.__eq__,    ["NormalDist.overlap"],    true, "NormalDist.overlap.__qualname__ == 'NormalDist.overlap'"]

# ---------------------------------------------------------------------------
# NormalDist method __qualname__ length invariants
# ---------------------------------------------------------------------------

invariant statistics_extra20.init.qualname_len:
  description: "len(statistics.NormalDist.__init__.__qualname__) == 19 — 'NormalDist.__init__' is 19 chars"
  category: method_identity
  kind: python_call_eq
  function: NormalDist.__init__.__qualname__.__len__
  args: []
  expected: 19

invariant statistics_extra20.pdf.qualname_len:
  description: "len(statistics.NormalDist.pdf.__qualname__) == 14 — 'NormalDist.pdf' is 14 chars"
  category: method_identity
  kind: python_call_eq
  function: NormalDist.pdf.__qualname__.__len__
  args: []
  expected: 14

invariant statistics_extra20.cdf.qualname_len:
  description: "len(statistics.NormalDist.cdf.__qualname__) == 14 — 'NormalDist.cdf' is 14 chars"
  category: method_identity
  kind: python_call_eq
  function: NormalDist.cdf.__qualname__.__len__
  args: []
  expected: 14

invariant statistics_extra20.inv_cdf.qualname_len:
  description: "len(statistics.NormalDist.inv_cdf.__qualname__) == 18 — 'NormalDist.inv_cdf' is 18 chars"
  category: method_identity
  kind: python_call_eq
  function: NormalDist.inv_cdf.__qualname__.__len__
  args: []
  expected: 18

invariant statistics_extra20.overlap.qualname_len:
  description: "len(statistics.NormalDist.overlap.__qualname__) == 18 — 'NormalDist.overlap' is 18 chars"
  category: method_identity
  kind: python_call_eq
  function: NormalDist.overlap.__qualname__.__len__
  args: []
  expected: 18
