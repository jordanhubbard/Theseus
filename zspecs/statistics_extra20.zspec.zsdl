spec: statistics_extra20
version: ">=3.9"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html — Python statistics module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
  notes:
    - "This spec extends statistics_extra through statistics_extra19."
    - "statistics_extra19 covers __qualname__.__len__ for mean/median/mode/stdev/pstdev/variance/pvariance/fmean/harmonic_mean/geometric_mean + multimode/median_low/median_high/median_grouped + NormalDist/StatisticsError class qualname lens."
    - "No prior spec records __qualname__.__len__ for correlation, linear_regression, covariance, or quantiles."
    - "No prior spec records __qualname__.__len__ for NormalDist instance methods (pdf, cdf, overlap, inv_cdf, zscore, from_samples, __init__, __add__, __mul__)."
    - "No prior spec records __dict__.__class__.__name__.__len__ for StatisticsError or NormalDist."
    - "No prior spec records __all__.__len__ or StatisticsError.__mro__.__len__."
    - "No prior spec records __bases__[0].__name__.__len__ for StatisticsError or NormalDist."
    - "statistics.__all__.__len__() == 22; 'list' has 4 characters."
    - "StatisticsError.__bases__[0].__name__ == 'ValueError', len 10."
    - "NormalDist.__bases__[0].__name__ == 'object', len 6."
    - "NormalDist.mean/stdev/variance are properties, not functions — they have no __qualname__."
    - "StatisticsError.__mro__ == [StatisticsError, ValueError, Exception, BaseException, object], len 5."
    - "linear_regression.__qualname__ == 'linear_regression', len 17 (not 16 as might be guessed)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Additional top-level function __qualname__.__len__ — analytics functions
#
# statistics_extra19 covers qualname lengths for the central-tendency and
# spread functions. No prior spec covers correlation, linear_regression,
# covariance, or quantiles via __qualname__.__len__.
# ---------------------------------------------------------------------------

table statistics_extra20.analytics_fn_qualname_len:
  description: "__qualname__.__len__ for statistics analytics functions not covered in extra19"
  kind: python_call_eq
  category: function_identity
  id_prefix: aqlen

  columns: [id, function, args, expected, description]
  rows:
    - [correlation,        correlation.__qualname__.__len__,        [], 11, "len('correlation') == 11"]
    - [linear_regression,  linear_regression.__qualname__.__len__,  [], 17, "len('linear_regression') == 17"]
    - [covariance,         covariance.__qualname__.__len__,         [], 10, "len('covariance') == 10"]
    - [quantiles,          quantiles.__qualname__.__len__,          [], 9,  "len('quantiles') == 9"]

# ---------------------------------------------------------------------------
# NormalDist method __qualname__.__len__
#
# No prior spec records the character length of any NormalDist method's
# __qualname__. NormalDist.mean/stdev/variance are properties (no __qualname__);
# pdf/cdf/overlap/inv_cdf/zscore/from_samples/__init__/__add__/__mul__ are
# plain functions or classmethods with __qualname__ = 'NormalDist.<name>'.
# ---------------------------------------------------------------------------

table statistics_extra20.normaldist_method_qualname_len:
  description: "__qualname__.__len__ for NormalDist methods"
  kind: python_call_eq
  category: method_identity
  id_prefix: ndmqlen

  columns: [id, function, args, expected, description]
  rows:
    - [init,         NormalDist.__init__.__qualname__.__len__,        [], 19, "len('NormalDist.__init__') == 19"]
    - [pdf,          NormalDist.pdf.__qualname__.__len__,             [], 14, "len('NormalDist.pdf') == 14"]
    - [cdf,          NormalDist.cdf.__qualname__.__len__,             [], 14, "len('NormalDist.cdf') == 14"]
    - [overlap,      NormalDist.overlap.__qualname__.__len__,         [], 18, "len('NormalDist.overlap') == 18"]
    - [inv_cdf,      NormalDist.inv_cdf.__qualname__.__len__,         [], 18, "len('NormalDist.inv_cdf') == 18"]
    - [zscore,       NormalDist.zscore.__qualname__.__len__,          [], 17, "len('NormalDist.zscore') == 17"]
    - [from_samples, NormalDist.from_samples.__qualname__.__len__,    [], 23, "len('NormalDist.from_samples') == 23"]
    - [add,          NormalDist.__add__.__qualname__.__len__,         [], 18, "len('NormalDist.__add__') == 18"]
    - [mul,          NormalDist.__mul__.__qualname__.__len__,         [], 18, "len('NormalDist.__mul__') == 18"]

# ---------------------------------------------------------------------------
# Class __dict__.__class__.__name__.__len__ for StatisticsError and NormalDist
#
# No prior statistics spec records __dict__.__class__.__name__.__len__ for
# either class. Both return 'mappingproxy' (12 characters).
# ---------------------------------------------------------------------------

invariant statistics_extra20.StatisticsError.dict_type_name_len:
  description: "statistics.StatisticsError.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has 12 characters"
  category: class_metadata
  kind: python_call_eq
  function: StatisticsError.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

invariant statistics_extra20.NormalDist.dict_type_name_len:
  description: "statistics.NormalDist.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has 12 characters"
  category: class_metadata
  kind: python_call_eq
  function: NormalDist.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# statistics.__all__ length and type
#
# No prior spec records __all__.__len__ or __all__.__class__.__name__.__len__
# for the statistics module. statistics.__all__ is a list of 22 names.
# ---------------------------------------------------------------------------

invariant statistics_extra20.all_len:
  description: "statistics.__all__.__len__() == 22 — the public API exports 22 names"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 22

invariant statistics_extra20.all_class_name_len:
  description: "statistics.__all__.__class__.__name__.__len__() == 4 — __all__ is a list, 'list' has 4 characters"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Exception and class base __name__.__len__
#
# No prior spec records __bases__[0].__name__.__len__ for StatisticsError or NormalDist.
# StatisticsError inherits from ValueError (len 10); NormalDist from object (len 6).
# ---------------------------------------------------------------------------

invariant statistics_extra20.StatisticsError.base_name_len:
  description: "statistics.StatisticsError.__bases__[0].__name__.__len__() == 10 — 'ValueError' has 10 characters"
  category: class_hierarchy
  kind: python_call_eq
  function: "StatisticsError.__bases__[0].__name__.__len__"
  args: []
  expected: 10

invariant statistics_extra20.NormalDist.base_name_len:
  description: "statistics.NormalDist.__bases__[0].__name__.__len__() == 6 — 'object' has 6 characters"
  category: class_hierarchy
  kind: python_call_eq
  function: "NormalDist.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# StatisticsError.__mro__.__len__
#
# StatisticsError.__mro__ == [StatisticsError, ValueError, Exception,
# BaseException, object] — five entries total. No prior spec records this.
# ---------------------------------------------------------------------------

invariant statistics_extra20.StatisticsError.mro_len:
  description: "statistics.StatisticsError.__mro__.__len__() == 5 — MRO has 5 entries: StatisticsError, ValueError, Exception, BaseException, object"
  category: class_hierarchy
  kind: python_call_eq
  function: StatisticsError.__mro__.__len__
  args: []
  expected: 5
