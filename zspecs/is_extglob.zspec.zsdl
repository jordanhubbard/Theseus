spec: is_extglob
version: ">=2.1.1"
backend: node(is-extglob)

docs: https://www.npmjs.com/package/is-extglob

provenance:
  derived_from:
    - "is-extglob README — https://www.npmjs.com/package/is-extglob"
    - "Test vectors verified with is-extglob via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-extglob source"
  notes:
    - "is-extglob is an npm package. Install: npm install is-extglob"
    - "Returns true if the string contains extglob pattern syntax (+(p), *(p), ?(p), @(p), !(p))."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_extglob.check:
  kind: node_module_call_eq
  function: ~
  category: path
  id_prefix: isext

  columns: [id, args, expected]
  rows:
    - [plus,   ["+(foo)"],  true]
    - [star,   ["*(foo)"],  true]
    - [plain,  ["foo"],     false]

