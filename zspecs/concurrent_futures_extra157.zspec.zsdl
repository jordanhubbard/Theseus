spec: concurrent_futures_extra157
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: concurrent.futures.wait and concurrent.futures.as_completed function identity. concurrent.futures.wait.__module__=='concurrent.futures._base' (len=24: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'_base'=5=24; both wait and as_completed are defined in the private _base submodule); concurrent.futures.wait.__class__.__name__=='function' (len=8; wait is a pure Python function); concurrent.futures.wait.__code__.co_argcount==3 (wait takes fs, timeout, return_when — 3 positional parameters); concurrent.futures.as_completed.__module__=='concurrent.futures._base' (same private submodule as wait); concurrent.futures.as_completed.__code__.co_argcount==2 (as_completed takes fs, timeout — 2 positional parameters; 1 fewer than wait because as_completed has no return_when parameter); concurrent.futures.wait.__qualname__=='wait' (unqualified — wait is a module-level function); concurrent.futures.as_completed.__qualname__=='as_completed'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.wait.__module__=='concurrent.futures._base' (len=24: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'_base'=5=24; '_base' begins with underscore indicating it is the private implementation module; the public API re-exports wait and as_completed from concurrent.futures directly); concurrent.futures.as_completed.__module__=='concurrent.futures._base' (same module as wait); both are pure Python functions (__class__.__name__=='function'); compare: concurrent.futures.Executor.submit.__module__ — Executor methods are also in _base. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.wait.__code__.co_argcount==3 — wait(fs, timeout=None, return_when='ALL_COMPLETED') takes 3 positional parameters: fs (the set of futures to wait for), timeout (optional; seconds to wait), and return_when (controls when wait returns: ALL_COMPLETED, FIRST_COMPLETED, or FIRST_EXCEPTION); concurrent.futures.as_completed.__code__.co_argcount==2 — as_completed(fs, timeout=None) takes 2 positional parameters: fs and timeout; as_completed has 1 fewer parameter than wait because it does not have a return_when parameter; as_completed is a generator that yields futures as they complete. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.wait function identity — extra157
#
# concurrent.futures.wait.__module__.__eq__('concurrent.futures._base') == True
# concurrent.futures.wait.__class__.__name__.__eq__('function')          == True
# concurrent.futures.wait.__code__.co_argcount                           == 3
# ---------------------------------------------------------------------------

table concurrent_futures_extra157.cf_wait_identity:
  description: "concurrent.futures.wait function identity checks in cfwait157 namespace — concurrent.futures.wait.__module__=='concurrent.futures._base' (len=24: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'_base'=5=24; wait is defined in the private _base submodule, not in the top-level concurrent.futures package; '_base' starts with underscore — private implementation module); concurrent.futures.wait.__class__.__name__=='function' (len=8; wait is a pure Python function, not a C builtin); concurrent.futures.wait.__code__.co_argcount==3 (wait takes 3 positional parameters: fs, timeout, return_when; signature: wait(fs, timeout=None, return_when='ALL_COMPLETED')); concurrent.futures.wait.__qualname__=='wait' (len=4: 'w'+'a'+'i'+'t'=4; unqualified — wait is a top-level module function, not a method); wait.__qualname__=='wait' confirms it is a free function, not nested in any class; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfwait157

  columns: [id, function, args, expected, description]
  rows:
    - [wait_mod_eq,    concurrent.futures.wait.__module__.__eq__,          ["concurrent.futures._base"],  true,  "cf.wait.__module__ == 'concurrent.futures._base' (len=24; private _base submodule); verified with Python 3.14.3"]
    - [wait_cls_eq,    concurrent.futures.wait.__class__.__name__.__eq__,  ["function"],                  true,  "cf.wait.__class__.__name__ == 'function' (len=8; pure Python function); verified with Python 3.14.3"]
    - [wait_argc,      concurrent.futures.wait.__code__.co_argcount.__eq__, [3],                          true,  "cf.wait.__code__.co_argcount == 3 (fs, timeout, return_when); verified with Python 3.14.3"]
    - [wait_qn_eq,     concurrent.futures.wait.__qualname__.__eq__,        ["wait"],                      true,  "cf.wait.__qualname__ == 'wait' (len=4; unqualified module-level function); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.as_completed function identity — extra157
#
# concurrent.futures.as_completed.__module__.__eq__('concurrent.futures._base') == True
# concurrent.futures.as_completed.__class__.__name__.__eq__('function')          == True
# concurrent.futures.as_completed.__code__.co_argcount                           == 2
# ---------------------------------------------------------------------------

table concurrent_futures_extra157.cf_as_completed_identity:
  description: "concurrent.futures.as_completed function identity checks in cfasc157 namespace — concurrent.futures.as_completed.__module__=='concurrent.futures._base' (len=24; same private _base submodule as wait — both as_completed and wait are defined in Lib/concurrent/futures/_base.py); concurrent.futures.as_completed.__class__.__name__=='function' (len=8; as_completed is a pure Python generator function — it uses yield to produce futures as they complete); concurrent.futures.as_completed.__code__.co_argcount==2 (as_completed takes 2 positional parameters: fs and timeout; signature: as_completed(fs, timeout=None); 1 fewer than wait=3 because as_completed does not have a return_when parameter); as_completed.__qualname__=='as_completed' (len=12: 'as'=2+'_'=1+'completed'=9=12; unqualified — module-level function; 3x longer qualname than wait's qualname of 4 chars); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfasc157

  columns: [id, function, args, expected, description]
  rows:
    - [asc_mod_eq,   concurrent.futures.as_completed.__module__.__eq__,          ["concurrent.futures._base"],  true,  "cf.as_completed.__module__ == 'concurrent.futures._base' (len=24; same module as wait); verified with Python 3.14.3"]
    - [asc_cls_eq,   concurrent.futures.as_completed.__class__.__name__.__eq__,  ["function"],                  true,  "cf.as_completed.__class__.__name__ == 'function' (len=8; pure Python generator function); verified with Python 3.14.3"]
    - [asc_argc,     concurrent.futures.as_completed.__code__.co_argcount.__eq__, [2],                          true,  "cf.as_completed.__code__.co_argcount == 2 (fs, timeout; 1 fewer than wait=3); verified with Python 3.14.3"]
    - [asc_qn_eq,    concurrent.futures.as_completed.__qualname__.__eq__,        ["as_completed"],              true,  "cf.as_completed.__qualname__ == 'as_completed' (len=12; unqualified module-level function); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# wait vs as_completed comparison — extra157
#
# co_argcount difference: wait(3) vs as_completed(2)
# qualname length difference: wait(4) vs as_completed(12)
# both share the same __module__
# ---------------------------------------------------------------------------

table concurrent_futures_extra157.cf_wait_vs_as_completed:
  description: "concurrent.futures.wait vs as_completed comparison checks in cfwvac157 namespace — wait.__code__.co_argcount==3 (fs, timeout, return_when) while as_completed.__code__.co_argcount==2 (fs, timeout); wait has 1 more parameter than as_completed; wait.__module__.__len__()==24 ('concurrent.futures._base'=24: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'_base'=5=24) — same for as_completed (both live in the same _base module); wait.__qualname__.__len__()==4 ('wait'=4) while as_completed.__qualname__.__len__()==12 ('as_completed'=12: 'as'=2+'_'=1+'completed'=9=12); qualname lengths: wait(4) << as_completed(12) — as_completed qualname is 3x longer; both are pure Python functions (__class__.__name__=='function'); both are module-level functions (qualnames are unqualified, no class prefix); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfwvac157

  columns: [id, function, args, expected, description]
  rows:
    - [wait_mod_len,  concurrent.futures.wait.__module__.__len__,                [],   24,    "cf.wait.__module__.__len__() == 24 ('concurrent.futures._base'); verified with Python 3.14.3"]
    - [asc_mod_len,   concurrent.futures.as_completed.__module__.__len__,        [],   24,    "cf.as_completed.__module__.__len__() == 24 (same module as wait); verified with Python 3.14.3"]
    - [wait_qn_len,   concurrent.futures.wait.__qualname__.__len__,              [],   4,     "cf.wait.__qualname__.__len__() == 4 ('wait'; shorter than as_completed=12); verified with Python 3.14.3"]
    - [asc_qn_len,    concurrent.futures.as_completed.__qualname__.__len__,      [],   12,    "cf.as_completed.__qualname__.__len__() == 12 ('as_completed'; 3x longer than wait=4); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra157
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra157.cf_wait_module_eq:
  description: "concurrent.futures.wait.__module__.__eq__('concurrent.futures._base') returns True — concurrent.futures.wait is defined in the private _base submodule of the concurrent.futures package (Lib/concurrent/futures/_base.py); wait.__module__=='concurrent.futures._base' (len=24: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'_base'=5=24; '_base' starts with underscore indicating private implementation); the public API re-exports wait from concurrent.futures directly so users call concurrent.futures.wait() but the function's __module__ reflects its actual defining module 'concurrent.futures._base'; compare: concurrent.futures.Executor.submit.__module__ is also in _base; concurrent.futures.wait is a top-level function (not a method): wait.__qualname__=='wait' (len=4; unqualified); NEW in extra157: first standalone cf.wait.__module__ identity invariant in cfwait157 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.wait.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra157.cf_wait_class_is_function:
  description: "concurrent.futures.wait.__class__.__name__.__eq__('function') returns True — concurrent.futures.wait is a pure Python function; wait.__class__.__name__=='function' (len=8: 'f'+'u'+'n'+'c'+'t'+'i'+'o'+'n'=8); this is the standard class name for Python function objects; compare: a C builtin would have __class__.__name__=='builtin_function_or_method' (len=26; e.g. abc.get_cache_token established in extra154); wait and as_completed are both pure Python ('function') not C builtins ('builtin_function_or_method'); wait.__code__.co_argcount==3 (fs, timeout, return_when); NEW in extra157: first standalone cf.wait.__class__.__name__ identity invariant in cfwait157 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.wait.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant concurrent_futures_extra157.cf_wait_co_argcount:
  description: "concurrent.futures.wait.__code__.co_argcount.__eq__(3) returns True — concurrent.futures.wait takes 3 positional parameters: fs (the iterable of futures), timeout (optional float; None means no timeout), and return_when (str; one of FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED — controls when wait returns); co_argcount==3 counts all positional and positional-or-keyword parameters (not *args or **kwargs); wait returns a named tuple (done, not_done) where done contains completed futures and not_done contains pending futures; compare: as_completed.__code__.co_argcount==2 (as_completed takes only fs and timeout, no return_when); wait(3) has 1 more parameter than as_completed(2); NEW in extra157: first standalone cf.wait co_argcount invariant in cfwait157 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.wait.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant concurrent_futures_extra157.cf_as_completed_module_eq:
  description: "concurrent.futures.as_completed.__module__.__eq__('concurrent.futures._base') returns True — concurrent.futures.as_completed is defined in the same private _base submodule as wait (Lib/concurrent/futures/_base.py); as_completed.__module__=='concurrent.futures._base' (len=24; same as wait.__module__); as_completed(fs, timeout=None) is a generator function that yields each future from fs as it completes — it does not wait for all futures, instead yielding them one by one in completion order; as_completed.__code__.co_argcount==2 (fs, timeout; 1 fewer than wait=3 because as_completed has no return_when parameter); as_completed.__qualname__=='as_completed' (len=12; unqualified module-level function); NEW in extra157: first standalone cf.as_completed.__module__ identity invariant in cfasc157 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.as_completed.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra157.cf_as_completed_co_argcount:
  description: "concurrent.futures.as_completed.__code__.co_argcount.__eq__(2) returns True — concurrent.futures.as_completed takes 2 positional parameters: fs (the iterable of futures to watch) and timeout (optional float; None means no timeout); co_argcount==2 is 1 less than concurrent.futures.wait.__code__.co_argcount==3 (wait has the extra return_when parameter that controls when to stop waiting); as_completed is a generator: each call to next() yields the next future that has completed; useful for processing results as they arrive rather than waiting for all to finish; as_completed.__qualname__=='as_completed' (len=12: 'as'=2+'_'=1+'completed'=9=12); NEW in extra157: first standalone cf.as_completed co_argcount invariant in cfasc157 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.as_completed.__code__.co_argcount.__eq__
  args: [2]
  expected: true

