spec: uuid_extra254
version: ">=3.2"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid documentation"
    - "RFC 9562 — Universally Unique IDentifiers (UUID)"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra251.zspec.zsdl — covers NAMESPACE_DNS/URL/OID/X500 version/variant and bytes_le class/len."
    - "uuid_extra.zspec.zsdl — covers UUID class name/module; uuid1/3/4/5 function names; uuid4 return class and version; NAMESPACE_* class names; UUID.int and hex class names."
  notes:
    - "uuid.UUID raises ValueError for any string that is not a valid 32-hex-digit UUID representation."
    - "An empty string raises ValueError: 'badly formed hexadecimal UUID string'."
    - "A too-short hyphenated string (35 chars instead of 36) raises ValueError: 'badly formed hexadecimal UUID string'."
    - "The string 'invalid' raises ValueError: 'badly formed hexadecimal UUID string'."
    - "uuid4().version == 4 — the version nibble in bits 12-15 of time_hi_and_version is always 4 for v4 UUIDs."
    - "uuid4().variant == 'specified in RFC 4122' — the variant string returned by the UUID.variant property for RFC 4122 UUIDs."
    - "uuid4().hex is a 32-character lowercase hex string (no hyphens); its __class__.__name__ == 'str'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UUID error conditions — invalid strings raise ValueError
# ---------------------------------------------------------------------------

table uuid_extra254.UUID_invalid_inputs:
  description: "uuid.UUID raises ValueError for invalid, empty, and too-short UUID strings; verified with Python 3.14.3"
  kind: python_call_raises
  category: errors
  id_prefix: uuiderr254

  columns: [id, function, args, raises, description]
  rows:
    - [invalid_string, UUID, ["invalid"],                             ValueError, "uuid.UUID('invalid') raises ValueError — not a valid hex UUID string"]
    - [short_string,   UUID, ["12345678-1234-5678-1234-56781234567"], ValueError, "uuid.UUID with 35-char hyphenated string raises ValueError — too short by one character"]
    - [empty_string,   UUID, [""],                                    ValueError, "uuid.UUID('') raises ValueError — empty string is not a valid UUID"]

# ---------------------------------------------------------------------------
# uuid4() — version, variant, hex type, hex length
# ---------------------------------------------------------------------------

invariant uuid_extra254.uuid4.version:
  description: "uuid4().version == 4 — version nibble is always 4 for v4 UUIDs"
  category: uuid4
  kind: python_call_eq
  function: uuid4
  args: []
  method: version.__eq__
  method_args: [4]
  expected: true

invariant uuid_extra254.uuid4.variant:
  description: "uuid4().variant == 'specified in RFC 4122'"
  category: uuid4
  kind: python_call_eq
  function: uuid4
  args: []
  method: variant.__eq__
  method_args: ["specified in RFC 4122"]
  expected: true

invariant uuid_extra254.uuid4.hex_class:
  description: "uuid4().hex.__class__.__name__ == 'str' — .hex attribute is always a str"
  category: uuid4
  kind: python_call_eq
  function: uuid4
  args: []
  method: hex.__class__.__name__.__eq__
  method_args: ["str"]
  expected: true

invariant uuid_extra254.uuid4.hex_len:
  description: "len(uuid4().hex) == 32 — hex is 32 lowercase hex digits with no hyphens"
  category: uuid4
  kind: python_call_eq
  function: uuid4
  args: []
  method: hex.__len__.__eq__
  method_args: [32]
  expected: true
