spec: atexit_extra3
version: ">=3.9"
backend: python_module(atexit)

docs: https://docs.python.org/3/library/atexit.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/atexit.html — Python atexit module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/atexitmodule.c"
  notes:
    - "Extends atexit.zspec.zsdl, atexit_extra.zspec.zsdl, and atexit_extra2.zspec.zsdl."
    - "atexit.zspec.zsdl covers: __name__ table for register/unregister/_ncallbacks/_clear; module __name__; _ncallbacks() == 0; _ncallbacks return type; register/clear callable checks."
    - "atexit_extra.zspec.zsdl covers: register/__name__/__module__/type; unregister/__name__/type; _clear/__name__/type; _ncallbacks/__name__; _run_exitfuncs/__name__/type; module __name__; function_names table."
    - "atexit_extra2.zspec.zsdl covers: unregister/__module__; _clear/__module__; _run_exitfuncs/__module__; register/__qualname__; unregister/__qualname__; function_qualnames table."
    - "This spec adds __qualname__ for _clear, _run_exitfuncs, and _ncallbacks — not covered in any prior atexit spec."
    - "For C-level builtins __qualname__ == __name__ (no enclosing class scope)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for _clear, _run_exitfuncs, _ncallbacks
# atexit_extra2.zspec.zsdl covers register and unregister __qualname__.
# This spec adds the remaining internal functions not yet checked.
# For C builtins __qualname__ == __name__.
# ---------------------------------------------------------------------------

table atexit_extra3.internal_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [_clear,          _clear.__qualname__.__eq__,          ["_clear"],          true]
    - [_run_exitfuncs,  _run_exitfuncs.__qualname__.__eq__,  ["_run_exitfuncs"],  true]
    - [_ncallbacks,     _ncallbacks.__qualname__.__eq__,     ["_ncallbacks"],     true]
