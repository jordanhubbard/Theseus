spec: struct_extra279
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "This spec extends struct.zspec.zsdl through struct_extra278.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "struct_extra278.zspec.zsdl covers: unpack_from with and without offset; pack_into returns None; unpack_from buffer-too-small and offset-overflow errors; calcsize for '!H' and '!I'; iter_unpack class name; pack('!H', 256)."
    - "This spec focuses on: struct.error class identity (__name__, __module__, base class); struct.pack function identity (__name__, __module__); struct.calcsize with native-size format chars (i, l, f, d, p); struct.Struct class name."
    - "struct.error.__name__ == 'error'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.error.__module__ == 'struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.error.__bases__[0].__name__ == 'Exception' — struct.error is a direct subclass of Exception. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.pack.__module__ == 'struct' or '_struct' — pack is a built-in function from the C extension. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('>f') == 4 — big-endian float32 is 4 bytes (IEEE 754 single). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('>d') == 8 — big-endian float64 is 8 bytes (IEEE 754 double). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('>i') == 4 — big-endian signed int32 is 4 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('>l') == 4 — big-endian signed long is 4 bytes in standard size mode. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.Struct.__name__ == 'Struct' — the Struct compiled-struct class name. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.Struct.__module__ == 'struct' — Struct is exposed from the struct module. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model:
  semantics: "struct.error is raised for mismatched buffer sizes and invalid format strings. It is a direct subclass of Exception."
  stderr: "null"
  stickiness: "N/A — struct functions are pure; Struct objects are immutable after construction."
  codes: {}

# ---------------------------------------------------------------------------
# struct.error — exception class identity
# struct.error.__name__ == 'error' — the class is named 'error' (lowercase).
# struct.error.__module__ == 'struct' — defined in the struct module.
# struct.error.__bases__[0].__name__ == 'Exception' — direct subclass of Exception.
# ---------------------------------------------------------------------------

invariant struct_extra279.error.class_name:
  description: "struct.error.__name__ == 'error' — exception class name is lowercase 'error'; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: class_identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

invariant struct_extra279.error.module:
  description: "struct.error.__module__ == 'struct' — struct.error is defined in the struct module; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: class_identity
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["struct"]
  expected: true

invariant struct_extra279.error.base_class:
  description: "struct.error.__bases__[0].__name__ == 'Exception' — struct.error is a direct subclass of Exception; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: class_identity
  kind: python_call_eq
  function: error.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# struct.Struct — class identity
# struct.Struct.__name__ == 'Struct' (the compiled struct class).
# struct.Struct.__module__ == 'struct'.
# ---------------------------------------------------------------------------

invariant struct_extra279.Struct.class_name:
  description: "struct.Struct.__name__ == 'Struct' — compiled struct class name; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: class_identity
  kind: python_call_eq
  function: Struct.__name__.__eq__
  args: ["Struct"]
  expected: true

invariant struct_extra279.Struct.module:
  description: "struct.Struct.__module__ == 'struct' — Struct is exposed from the struct module; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: class_identity
  kind: python_call_eq
  function: Struct.__module__.__eq__
  args: ["struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack — function name identity
# struct.pack.__name__ == 'pack' — confirms the function is accessible by the
# expected name and has not been wrapped or renamed.
# ---------------------------------------------------------------------------

invariant struct_extra279.pack.function_name:
  description: "struct.pack.__name__ == 'pack' — function name attribute; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: function_identity
  kind: python_call_eq
  function: pack.__name__.__eq__
  args: ["pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.calcsize — additional format characters
# (struct.zspec.zsdl covers H, I, Q, HI, HIQ, q, h, b, ?, e.
#  struct_extra.zspec.zsdl covers f, d, B, 4s, BHI.
#  This spec covers i (signed int32) and l (signed long32) in big-endian mode.)
# ---------------------------------------------------------------------------

table struct_extra279.calcsize_extra:
  description: "struct.calcsize() for signed int, signed long, and multi-field formats; verified with Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: calcsize
  function: calcsize
  id_prefix: csx279

  columns: [id, args, expected, description]
  rows:
    - [big_endian_i,  [">i"],   4, "calcsize('>i') == 4 — big-endian signed int32"]
    - [big_endian_l,  [">l"],   4, "calcsize('>l') == 4 — big-endian signed long (standard size = 4)"]
    - [big_endian_IH, [">IH"],  6, "calcsize('>IH') == 6 — big-endian uint32 + uint16"]
    - [big_endian_Qi, [">Qi"],  12, "calcsize('>Qi') == 12 — big-endian uint64 + int32"]

# ---------------------------------------------------------------------------
# struct.pack / struct.unpack — signed int32 round-trip
# pack('>i', -1) == b'\xff\xff\xff\xff'; unpack('>i', b'\xff\xff\xff\xff') == (-1,)
# This exercises the signed interpretation of the all-ones 32-bit pattern.
# ---------------------------------------------------------------------------

invariant struct_extra279.pack.signed_int32_minus1:
  description: "struct.pack('>i', -1) == b'\\xff\\xff\\xff\\xff' — two's complement signed int32; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: pack_vector
  kind: python_call_eq
  function: pack
  args: [">i", -1]
  expected: !hex ffffffff

invariant struct_extra279.unpack.signed_int32_minus1:
  description: "struct.unpack('>i', b'\\xff\\xff\\xff\\xff') == (-1,) — two's complement signed int32 decode; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: unpack_vector
  kind: python_call_eq
  function: unpack
  args: [">i", !hex ffffffff]
  expected: [-1]

# ---------------------------------------------------------------------------
# struct.pack — invalid value raises struct.error
# Packing a value out of range for the format raises struct.error.
# struct.pack('>B', 256) — 256 does not fit in an unsigned byte (0–255).
# ---------------------------------------------------------------------------

invariant struct_extra279.pack.overflow_raises:
  description: "struct.pack('>B', 256) raises struct.error — 256 overflows an unsigned byte; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: error
  kind: python_call_raises
  function: pack
  args: [">B", 256]
  raises: error
