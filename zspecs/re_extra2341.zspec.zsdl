spec: re_extra2341
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python 3 re documentation — https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
    - "re_extra.zspec.zsdl — covers Pattern/Match/error class names, flag constants"
    - "re_extra1771.zspec.zsdl — covers async protocol absence, function class names, NOFLAG"
  notes:
    - "Theme: __slots__ contents. re.Pattern and re.Match are C extension types (from _sre module)."
    - "C extension types do not expose Python-level __slots__ in their __dict__, even though they expose method descriptors."
    - "Pattern.__dict__ contains method descriptors (match, search, findall, etc.) and property descriptors (pattern, flags) but no __slots__ key."
    - "Match.__dict__ contains method descriptors (group, groups, etc.) and member descriptors (string, pos, etc.) but no __slots__ key."
    - "re.error (re.PatternError in Python 3.13+) is a Python exception subclass. Its __dict__ holds __module__, __init__, __weakref__ but no __slots__."
    - "re.RegexFlag is an IntFlag enum subclass. No __slots__ key is in its __dict__."
    - "All expected values verified by running Python 3.14 re module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# re C types — Pattern and Match have no Python __slots__ key
# Even though Pattern and Match are C types with method descriptors in __dict__,
# they do not expose a '__slots__' entry the way Python slotted classes do.
# ---------------------------------------------------------------------------

table re_extra2341.c_type_no_slots:
  kind: python_call_eq
  category: slots
  id_prefix: re2341

  columns: [id, function, args, expected]
  rows:
    - ["re2341001", Pattern.__dict__.__contains__, ["__slots__"],   false]
    - ["re2341002", Match.__dict__.__contains__,   ["__slots__"],   false]

# ---------------------------------------------------------------------------
# re.Pattern — C type descriptors present in __dict__ (contrast: slots absent)
# Pattern exposes its methods and properties as C descriptors, not __slots__.
# ---------------------------------------------------------------------------

table re_extra2341.pattern_dict_members:
  kind: python_call_eq
  category: slots
  id_prefix: re2341

  columns: [id, function, args, expected]
  rows:
    - ["re2341003", Pattern.__dict__.__contains__, ["match"],    true]
    - ["re2341004", Pattern.__dict__.__contains__, ["search"],   true]
    - ["re2341005", Pattern.__dict__.__contains__, ["findall"],  true]
    - ["re2341006", Pattern.__dict__.__contains__, ["pattern"],  true]
    - ["re2341007", Pattern.__dict__.__contains__, ["flags"],    true]
    - ["re2341008", Pattern.__dict__.__contains__, ["split"],    true]

# ---------------------------------------------------------------------------
# re.Match — C type member descriptors present in __dict__ (contrast: slots absent)
# ---------------------------------------------------------------------------

table re_extra2341.match_dict_members:
  kind: python_call_eq
  category: slots
  id_prefix: re2341

  columns: [id, function, args, expected]
  rows:
    - ["re2341009",  Match.__dict__.__contains__, ["group"],      true]
    - ["re2341010",  Match.__dict__.__contains__, ["groups"],     true]
    - ["re2341011",  Match.__dict__.__contains__, ["groupdict"],  true]
    - ["re2341012",  Match.__dict__.__contains__, ["string"],     true]
    - ["re2341013",  Match.__dict__.__contains__, ["pos"],        true]

# ---------------------------------------------------------------------------
# re.error — Python exception subclass, no __slots__ defined
# __dict__ contains __module__, __init__, __weakref__ but not __slots__
# ---------------------------------------------------------------------------

table re_extra2341.error_no_slots:
  kind: python_call_eq
  category: slots
  id_prefix: re2341

  columns: [id, function, args, expected]
  rows:
    - ["re2341014", error.__dict__.__contains__, ["__slots__"],   false]
    - ["re2341015", error.__dict__.__contains__, ["__init__"],    true]
    - ["re2341016", error.__dict__.__contains__, ["__weakref__"], true]
    - ["re2341017", error.__dict__.__contains__, ["pattern"],     false]

# ---------------------------------------------------------------------------
# re.RegexFlag — IntFlag enum subclass, no __slots__ key in its own __dict__
# ---------------------------------------------------------------------------

table re_extra2341.regexflag_no_slots:
  kind: python_call_eq
  category: slots
  id_prefix: re2341

  columns: [id, function, args, expected]
  rows:
    - ["re2341018", RegexFlag.__dict__.__contains__, ["__slots__"],          false]
    - ["re2341019", RegexFlag.__dict__.__contains__, ["_member_names_"],     true]
    - ["re2341020", RegexFlag.__dict__.__contains__, ["_value2member_map_"], true]
