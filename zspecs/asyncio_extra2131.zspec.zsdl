spec: asyncio_extra2131
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/asyncio-exceptions.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/exceptions.py"
  notes:
    - "Wave (_extra2131): exception protocol dict-presence — checking __cause__, __context__, __traceback__, __suppress_context__, __notes__, args, with_traceback in class __dict__."
    - "Exception protocol attributes (__cause__, __context__, __traceback__, __suppress_context__, __notes__) are instance attributes set by the interpreter at raise time, not class-level descriptors."
    - "Therefore ClassName.__dict__.__contains__('__cause__') is False even for genuine exception subclasses."
    - "args and with_traceback are also inherited from BaseException and not redefined in asyncio exception class __dict__ entries."
    - "asyncio.IncompleteReadError and asyncio.LimitOverrunError define custom __init__ but still do not place protocol attrs in __dict__."
    - "Non-exception types (Task, Future, Event, Lock, Queue) also return False for all protocol attrs — confirmed by inspection."
    - "All values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table asyncio_extra2131.cancelledError_exception_protocol:
  description: "asyncio.CancelledError.__dict__ exception protocol dict-presence — exception type, all attrs absent from class dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2131

  columns: [id, function, args, expected]
  rows:
    - ["as2131001", "asyncio.CancelledError.__dict__.__contains__", ["__cause__"], false]
    - ["as2131002", "asyncio.CancelledError.__dict__.__contains__", ["__context__"], false]
    - ["as2131003", "asyncio.CancelledError.__dict__.__contains__", ["__traceback__"], false]
    - ["as2131004", "asyncio.CancelledError.__dict__.__contains__", ["__suppress_context__"], false]
    - ["as2131005", "asyncio.CancelledError.__dict__.__contains__", ["__notes__"], false]
    - ["as2131006", "asyncio.CancelledError.__dict__.__contains__", ["args"], false]
    - ["as2131007", "asyncio.CancelledError.__dict__.__contains__", ["with_traceback"], false]

