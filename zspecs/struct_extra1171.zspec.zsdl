spec: struct_extra1171
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks struct.Struct.size/__doc__ and struct.Struct.format/__doc__ class names, struct.pack/__doc__ and struct.error/__doc__ class names, struct.__doc__ class name and str identity, struct.error.__bases__ class name, struct.Struct.__doc__ class name"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra1171.struct_size_format_doc_class_names:
  description: "struct.Struct.size and struct.Struct.format __doc__ class names, and struct.Struct.__doc__ class name"
  kind: python_call_eq
  category: struct_size_format_doc_class_names
  id_prefix: st1171sf
  columns: [id, function, args, expected]
  rows:
    - [st1171sf001, struct.Struct.size.__doc__.__class__.__name__.__eq__,          ["str"],       true]
    - [st1171sf002, struct.Struct.size.__doc__.__class__.__qualname__.__eq__,       ["str"],       true]
    - [st1171sf003, struct.Struct.size.__doc__.__class__.__module__.__eq__,         ["builtins"],  true]
    - [st1171sf004, struct.Struct.format.__doc__.__class__.__name__.__eq__,        ["str"],       true]
    - [st1171sf005, struct.Struct.format.__doc__.__class__.__qualname__.__eq__,     ["str"],       true]
    - [st1171sf006, struct.Struct.format.__doc__.__class__.__module__.__eq__,       ["builtins"],  true]
    - [st1171sf007, struct.Struct.__doc__.__class__.__name__.__eq__,               ["str"],       true]
    - [st1171sf008, struct.Struct.__doc__.__class__.__qualname__.__eq__,            ["str"],       true]
    - [st1171sf009, struct.Struct.__doc__.__class__.__module__.__eq__,              ["builtins"],  true]
    - [st1171sf010, struct.Struct.size.__class__.__name__.__eq__,                  ["member_descriptor"], true]

