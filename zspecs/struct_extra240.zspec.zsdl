spec: struct_extra240
version: ">=3.5"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "This spec covers struct.pack_into, struct.unpack_from, and struct.iter_unpack function identity; it does NOT duplicate invariants already present in struct.zspec.zsdl or earlier extras."
    - "struct.pack_into.__name__ == 'pack_into' — the function name."
    - "struct.pack_into.__module__ == '_struct' — pack_into is implemented in the _struct C extension."
    - "struct.pack_into.__qualname__ == 'pack_into' — top-level function, qualname equals name."
    - "struct.unpack_from.__name__ == 'unpack_from' — the function name."
    - "struct.unpack_from.__module__ == '_struct' — unpack_from is implemented in the _struct C extension."
    - "struct.unpack_from.__qualname__ == 'unpack_from' — top-level function, qualname equals name."
    - "struct.iter_unpack.__name__ == 'iter_unpack' — the function name."
    - "struct.iter_unpack.__module__ == '_struct' — iter_unpack is implemented in the _struct C extension."
    - "struct.iter_unpack.__qualname__ == 'iter_unpack' — top-level function, qualname equals name."
    - "All three functions are builtin_function_or_method (C builtin, not pure Python)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model:
  semantics: "struct.error is raised for mismatched buffer sizes and invalid format strings. It is a subclass of Exception."
  stderr: "null"
  stickiness: "N/A — struct functions are pure; all tested invariants are attribute accesses."
  codes: {}

# ---------------------------------------------------------------------------
# struct.pack_into function identity
# pack_into is a C builtin from _struct; __name__ == __qualname__ == 'pack_into'
# ---------------------------------------------------------------------------

table struct_extra240.pack_into.identity:
  kind: python_call_eq
  category: function_identity
  id_prefix: struct240fns

  columns: [id, function, args, expected]
  rows:
    - [name,     pack_into.__name__.__eq__,     ["pack_into"], true]
    - [module,   pack_into.__module__.__eq__,   ["_struct"],   true]
    - [qualname, pack_into.__qualname__.__eq__,  ["pack_into"], true]

# ---------------------------------------------------------------------------
# struct.unpack_from function identity
# unpack_from is a C builtin from _struct; __name__ == __qualname__ == 'unpack_from'
# ---------------------------------------------------------------------------

table struct_extra240.unpack_from.identity:
  kind: python_call_eq
  category: function_identity
  id_prefix: struct240fns

  columns: [id, function, args, expected]
  rows:
    - [name,     unpack_from.__name__.__eq__,     ["unpack_from"], true]
    - [module,   unpack_from.__module__.__eq__,   ["_struct"],     true]
    - [qualname, unpack_from.__qualname__.__eq__,  ["unpack_from"], true]

# ---------------------------------------------------------------------------
# struct.iter_unpack function identity
# iter_unpack is a C builtin from _struct; __name__ == __qualname__ == 'iter_unpack'
# ---------------------------------------------------------------------------

table struct_extra240.iter_unpack.identity:
  kind: python_call_eq
  category: function_identity
  id_prefix: struct240fns

  columns: [id, function, args, expected]
  rows:
    - [name,     iter_unpack.__name__.__eq__,     ["iter_unpack"], true]
    - [module,   iter_unpack.__module__.__eq__,   ["_struct"],     true]
    - [qualname, iter_unpack.__qualname__.__eq__,  ["iter_unpack"], true]

# ---------------------------------------------------------------------------
# Standalone invariants: pack_into function identity
# ---------------------------------------------------------------------------

invariant struct_extra240.pack_into.name:
  description: "struct.pack_into.__name__ == 'pack_into' — C builtin from _struct extension"
  category: function_identity
  kind: python_call_eq
  function: pack_into.__name__.__eq__
  args: ["pack_into"]
  expected: true

invariant struct_extra240.pack_into.module:
  description: "struct.pack_into.__module__ == '_struct' — pack_into is implemented in the _struct C extension"
  category: function_identity
  kind: python_call_eq
  function: pack_into.__module__.__eq__
  args: ["_struct"]
  expected: true

invariant struct_extra240.unpack_from.name:
  description: "struct.unpack_from.__name__ == 'unpack_from' — C builtin from _struct extension"
  category: function_identity
  kind: python_call_eq
  function: unpack_from.__name__.__eq__
  args: ["unpack_from"]
  expected: true

invariant struct_extra240.unpack_from.module:
  description: "struct.unpack_from.__module__ == '_struct' — unpack_from is implemented in the _struct C extension"
  category: function_identity
  kind: python_call_eq
  function: unpack_from.__module__.__eq__
  args: ["_struct"]
  expected: true

invariant struct_extra240.iter_unpack.name:
  description: "struct.iter_unpack.__name__ == 'iter_unpack' — C builtin from _struct extension"
  category: function_identity
  kind: python_call_eq
  function: iter_unpack.__name__.__eq__
  args: ["iter_unpack"]
  expected: true

invariant struct_extra240.iter_unpack.module:
  description: "struct.iter_unpack.__module__ == '_struct' — iter_unpack is implemented in the _struct C extension"
  category: function_identity
  kind: python_call_eq
  function: iter_unpack.__module__.__eq__
  args: ["_struct"]
  expected: true
