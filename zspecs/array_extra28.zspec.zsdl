spec: array_extra28
version: ">=3.9"
backend: python_module(array)

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/array.html — Python array module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/arraymodule.c"
    - "array_extra27.zspec.zsdl — covers array.array class __module__/__name__/__qualname__ lengths (all 5); __name__.__len__() for append/extend/pop/reverse/tolist/frombytes/tobytes; tobytes.__name__/__qualname__ standalone."
    - "array_extra26.zspec.zsdl — covers __name__.__len__() for append/extend/pop/reverse/tolist/frombytes; array.__init__.__qualname__."
    - "array_extra21.zspec.zsdl — covers __qualname__ for append/extend/pop/insert/remove/reverse/tolist/tobytes/frombytes."
  notes:
    - "This spec extends array_extra27.zspec.zsdl."
    - "Prior specs covered: array.array class __module__/__name__/__qualname__ lengths; __name__ and __qualname__ for all major array.array methods; __name__.__len__() for the seven core methods."
    - "This spec covers: array.array method __qualname__.__len__() for append/extend/pop/reverse/tolist/frombytes/tobytes; also insert/remove __qualname__.__len__(). These are the first __qualname__.__len__() checks for array.array methods in any spec."
    - "array.array.append.__qualname__ == 'array.append', __qualname__.__len__() == 12. Verified."
    - "array.array.extend.__qualname__ == 'array.extend', __qualname__.__len__() == 12. Verified."
    - "array.array.pop.__qualname__ == 'array.pop', __qualname__.__len__() == 9. Verified."
    - "array.array.reverse.__qualname__ == 'array.reverse', __qualname__.__len__() == 13. Verified."
    - "array.array.tolist.__qualname__ == 'array.tolist', __qualname__.__len__() == 12. Verified."
    - "array.array.frombytes.__qualname__ == 'array.frombytes', __qualname__.__len__() == 15. Verified."
    - "array.array.tobytes.__qualname__ == 'array.tobytes', __qualname__.__len__() == 13. Verified."
    - "array.array.insert.__qualname__ == 'array.insert', __qualname__.__len__() == 12. Verified."
    - "array.array.remove.__qualname__ == 'array.remove', __qualname__.__len__() == 12. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __qualname__.__len__() for core array.array mutation/conversion methods
#
# No prior spec covers __qualname__.__len__() for array.array methods.
# The qualname pattern is 'array.METHOD': len = 6 (for 'array.') + len(method).
# Verified: append=12, extend=12, pop=9, reverse=13, tolist=12, frombytes=15,
# tobytes=13.
# ---------------------------------------------------------------------------

table array_extra28.method_qualname_lengths_core:
  description: "array.array method __qualname__.__len__() for seven core methods — lengths 12/12/9/13/12/15/13"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: mqlen28

  columns: [id, function, args, expected]
  rows:
    - [append,    "array.append.__qualname__.__len__",    [], 12]
    - [extend,    "array.extend.__qualname__.__len__",    [], 12]
    - [pop,       "array.pop.__qualname__.__len__",       [], 9]
    - [reverse,   "array.reverse.__qualname__.__len__",   [], 13]
    - [tolist,    "array.tolist.__qualname__.__len__",    [], 12]
    - [frombytes, "array.frombytes.__qualname__.__len__", [], 15]
    - [tobytes,   "array.tobytes.__qualname__.__len__",   [], 13]

# ---------------------------------------------------------------------------
# Table: __qualname__.__len__() for insert and remove
#
# No prior spec covers __qualname__.__len__() for insert or remove.
# Both follow the 'array.METHOD' pattern: insert=12, remove=12.
# Verified: array.array.insert.__qualname__ == 'array.insert', len=12;
# array.array.remove.__qualname__ == 'array.remove', len=12.
# ---------------------------------------------------------------------------

table array_extra28.method_qualname_lengths_mutators:
  description: "array.array.insert and remove __qualname__.__len__() — both equal 12"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: mqlen28m

  columns: [id, function, args, expected]
  rows:
    - [insert, "array.insert.__qualname__.__len__", [], 12]
    - [remove, "array.remove.__qualname__.__len__", [], 12]

# ---------------------------------------------------------------------------
# Standalone: array.array.append.__qualname__.__len__() == 12
#
# 'array.append' has 12 characters. No prior array spec covers
# __qualname__.__len__() for append as a standalone invariant.
# Verified: array.array.append.__qualname__ == 'array.append', len=12.
# ---------------------------------------------------------------------------

invariant array_extra28.append.qualname_len:
  description: "array.array.append.__qualname__.__len__() == 12 — 'array.append' has 12 characters"
  category: method_qualnames
  kind: python_call_eq
  function: "array.append.__qualname__.__len__"
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# Standalone: array.array.frombytes.__qualname__.__len__() == 15
#
# 'array.frombytes' has 15 characters — the longest qualname among the seven
# core methods (frombytes is 9 chars; 6 + 9 = 15). No prior array spec covers
# __qualname__.__len__() for frombytes as a standalone invariant.
# Verified: array.array.frombytes.__qualname__ == 'array.frombytes', len=15.
# ---------------------------------------------------------------------------

invariant array_extra28.frombytes.qualname_len:
  description: "array.array.frombytes.__qualname__.__len__() == 15 — 'array.frombytes' has 15 characters"
  category: method_qualnames
  kind: python_call_eq
  function: "array.frombytes.__qualname__.__len__"
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# Standalone: array.array.pop.__qualname__.__len__() == 9
#
# 'array.pop' has 9 characters — the shortest qualname among the seven core
# methods (pop is 3 chars; 6 + 3 = 9). No prior array spec covers
# __qualname__.__len__() for pop as a standalone invariant.
# Verified: array.array.pop.__qualname__ == 'array.pop', len=9.
# ---------------------------------------------------------------------------

invariant array_extra28.pop.qualname_len:
  description: "array.array.pop.__qualname__.__len__() == 9 — 'array.pop' has 9 characters"
  category: method_qualnames
  kind: python_call_eq
  function: "array.pop.__qualname__.__len__"
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# Standalone: array.array.tobytes.__qualname__.__len__() == 13
#
# 'array.tobytes' has 13 characters. No prior array spec covers
# __qualname__.__len__() for tobytes as a standalone invariant.
# Verified: array.array.tobytes.__qualname__ == 'array.tobytes', len=13.
# ---------------------------------------------------------------------------

invariant array_extra28.tobytes.qualname_len:
  description: "array.array.tobytes.__qualname__.__len__() == 13 — 'array.tobytes' has 13 characters"
  category: method_qualnames
  kind: python_call_eq
  function: "array.tobytes.__qualname__.__len__"
  args: []
  expected: 13
