# ---------------------------------------------------------------------------
# Table 1: itertools infinite iterator __module__ values
#
# itertools.count.__module__   == 'itertools' (len=9)
# itertools.cycle.__module__   == 'itertools' (len=9)
# itertools.repeat.__module__  == 'itertools' (len=9)
#
# count, cycle, and repeat are the three infinite iterators in itertools.
# All are C extension types implemented in Modules/itertoolsmodule.c and
# all report __module__ == 'itertools'. New to extra191.
# ---------------------------------------------------------------------------

table itertools_extra191.infinite_iterator_modules:
  description: "itertools infinite iterator __module__ values: count/cycle/repeat all have __module__=='itertools'(len=9); all are C extension types; new to extra191"
  kind: python_call_eq
  category: identity
  id_prefix: itermodule191

  columns: [id, function, args, expected, description]
  rows:
    - [count_module_eq,
       count.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.count.__module__.__eq__('itertools') == True — count is a C extension type implementing the infinite counter iterator; __module__ is 'itertools' (len=9: i-t-e-r-t-o-o-l-s); str.__eq__('itertools') returns True; verified with Python 3.14.3; new to extra191"]
    - [count_module_len,
       count.__module__.__len__,
       [],
       9,
       "itertools.count.__module__.__len__() == 9 — 'itertools' has 9 characters: i-t-e-r-t-o-o-l-s; str.__len__() returns 9; verified with Python 3.14.3; new to extra191"]
    - [cycle_module_eq,
       cycle.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.cycle.__module__.__eq__('itertools') == True — cycle is a C extension type that cycles through a finite iterable indefinitely; __module__ is 'itertools' (len=9); str.__eq__('itertools') returns True; verified with Python 3.14.3; new to extra191"]
    - [cycle_module_len,
       cycle.__module__.__len__,
       [],
       9,
       "itertools.cycle.__module__.__len__() == 9 — 'itertools' has 9 characters: i-t-e-r-t-o-o-l-s; str.__len__() returns 9; verified with Python 3.14.3; new to extra191"]
    - [repeat_module_eq,
       repeat.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.repeat.__module__.__eq__('itertools') == True — repeat is a C extension type that repeats a value indefinitely (or a fixed number of times); __module__ is 'itertools' (len=9); str.__eq__('itertools') returns True; verified with Python 3.14.3; new to extra191"]
    - [repeat_module_len,
       repeat.__module__.__len__,
       [],
       9,
       "itertools.repeat.__module__.__len__() == 9 — 'itertools' has 9 characters: i-t-e-r-t-o-o-l-s; str.__len__() returns 9; verified with Python 3.14.3; new to extra191"]

