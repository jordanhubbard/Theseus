spec: enum_flags
version: ">=3.11"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "Python enum documentation — https://docs.python.org/3/library/enum.html"
    - "PEP 663 — Standardize Enum str(), format(), and repr()"
    - "Test vectors verified by running Python 3.14.3 enum module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec covers Flag, IntFlag, auto(), unique(), and EnumMeta/EnumType — not covered in enum.zspec.zsdl."
    - "Flag members support bitwise OR, AND, XOR operations and can represent compound permissions."
    - "IntFlag is like Flag but members are also int subclasses; bitwise operations return IntFlag values."
    - "auto() inside a class body generates sequential values starting at 1 for Enum and powers of two for Flag."
    - "unique() is a class decorator that raises ValueError if any two members share the same value."
    - "EnumType (formerly EnumMeta) is the metaclass for all enum classes in Python 3.11+."
    - "EnumMeta is an alias for EnumType maintained for backward compatibility."
    - "The metaclass of enum.Enum is EnumType; type(Enum).__name__ == 'EnumType' in Python 3.11+."
    - "Flag.__mro__ contains Flag, Enum, and object."
    - "IntFlag.__bases__[0].__name__ is 'int' — IntFlag inherits from int before Flag."
    - "auto.__module__ == 'enum'; unique.__module__ == 'enum'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# EnumType / EnumMeta — the metaclass for all enum classes
#
# In Python 3.11+ the canonical name is EnumType; EnumMeta is an alias.
# type(Enum).__name__ reveals which name the runtime uses.
# ---------------------------------------------------------------------------

invariant enum_flags.EnumType.name:
  description: "enum.EnumType.__name__ == 'EnumType'"
  category: enumtype
  kind: python_call_eq
  function: EnumType.__name__.__eq__
  args: ["EnumType"]
  expected: true

invariant enum_flags.EnumType.module:
  description: "enum.EnumType.__module__ == 'enum'"
  category: enumtype
  kind: python_call_eq
  function: EnumType.__module__.__eq__
  args: ["enum"]
  expected: true

invariant enum_flags.EnumType.base_is_type:
  description: "enum.EnumType.__bases__[0].__name__ == 'type' — EnumType inherits from type"
  category: enumtype
  kind: python_call_eq
  function: EnumType.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "type"

invariant enum_flags.Enum_metaclass:
  description: "type(enum.Enum).__name__ == 'EnumType' — Enum's metaclass is EnumType"
  category: enumtype
  kind: python_call_eq
  function: Enum.__class__.__name__.__eq__
  args: ["EnumType"]
  expected: true

# ---------------------------------------------------------------------------
# auto() — module and type checks
#
# enum.auto is a class; auto() returns an auto instance that generates values.
# We verify the exported symbol lives in the enum module and is a type.
# ---------------------------------------------------------------------------

invariant enum_flags.auto.module:
  description: "enum.auto.__module__ == 'enum'"
  category: auto
  kind: python_call_eq
  function: auto.__module__.__eq__
  args: ["enum"]
  expected: true

invariant enum_flags.auto.is_class:
  description: "type(enum.auto).__name__ == 'EnumType' — auto is an Enum class"
  category: auto
  kind: python_call_eq
  function: auto.__class__.__name__.__eq__
  args: ["EnumType"]
  expected: true

# ---------------------------------------------------------------------------
# unique() — module and type checks
#
# enum.unique is a plain decorator function. We verify its module and that
# it is a Python function.
# ---------------------------------------------------------------------------

invariant enum_flags.unique.module:
  description: "enum.unique.__module__ == 'enum'"
  category: unique
  kind: python_call_eq
  function: unique.__module__.__eq__
  args: ["enum"]
  expected: true

invariant enum_flags.unique.is_function:
  description: "type(enum.unique).__name__ == 'function'"
  category: unique
  kind: python_call_eq
  function: unique.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# Flag class — module and hierarchy
#
# Flag was covered by name in enum.zspec.zsdl; here we verify its module and
# that its metaclass is EnumType, which was not checked previously.
# ---------------------------------------------------------------------------

invariant enum_flags.Flag.module:
  description: "enum.Flag.__module__ == 'enum'"
  category: flag_class
  kind: python_call_eq
  function: Flag.__module__.__eq__
  args: ["enum"]
  expected: true

invariant enum_flags.Flag.metaclass:
  description: "type(enum.Flag).__name__ == 'EnumType' — Flag's metaclass is EnumType"
  category: flag_class
  kind: python_call_eq
  function: Flag.__class__.__name__.__eq__
  args: ["EnumType"]
  expected: true

# ---------------------------------------------------------------------------
# IntFlag class — module and first base
#
# IntFlag was covered by name in enum.zspec.zsdl; here we verify its module
# and that it inherits from int (int is its first base in the MRO).
# ---------------------------------------------------------------------------

invariant enum_flags.IntFlag.module:
  description: "enum.IntFlag.__module__ == 'enum'"
  category: intflag_class
  kind: python_call_eq
  function: IntFlag.__module__.__eq__
  args: ["enum"]
  expected: true

invariant enum_flags.IntFlag.base_is_int:
  description: "enum.IntFlag.__bases__[0].__name__ == 'int' — IntFlag inherits from int"
  category: intflag_class
  kind: python_call_eq
  function: IntFlag.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "int"

# ---------------------------------------------------------------------------
# IntFlag functional API — member count and names
#
# enum.IntFlag('Access', 'R W X') creates an IntFlag with three members.
# Member values are powers of two; we verify member count and names list.
# ---------------------------------------------------------------------------

invariant enum_flags.IntFlag.access_len:
  description: "len(enum.IntFlag('Access', 'R W X')) == 3"
  category: intflag_functional
  kind: python_call_eq
  function: IntFlag
  args: ["Access", "R W X"]
  method: __len__
  expected: 3

invariant enum_flags.IntFlag.access_member_names:
  description: "enum.IntFlag('Access', 'R W X')._member_names_ == ['R', 'W', 'X']"
  category: intflag_functional
  kind: python_call_eq
  function: IntFlag
  args: ["Access", "R W X"]
  method: _member_names_
  expected: ["R", "W", "X"]

