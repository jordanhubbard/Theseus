spec: struct_extra2
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified by running Python 3.12 struct module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "This spec extends struct.zspec.zsdl and struct_extra.zspec.zsdl; it does NOT duplicate invariants present in either."
    - "struct.zspec.zsdl covers: pack/unpack vectors for B/b/H/h/I/i/Q/q/f/d/?/e/x; calcsize for H/I/Q/HI/HIQ/q/h/b/?/e; roundtrip for >q/>Q/>H/<I/>BHI; error cases."
    - "struct_extra.zspec.zsdl covers: Struct class format/size attrs, calcsize for f/d/B/4s/>BHI, pack_into method name, unpack_from with offset, iter_unpack, error class name/bases."
    - "'>I' is big-endian unsigned 32-bit integer (4 bytes). '>H' is big-endian unsigned 16-bit integer (2 bytes)."
    - "'<I' is little-endian unsigned 32-bit integer: bytes are in reversed order vs. big-endian."
    - "'>4B' packs four unsigned bytes sequentially; each value must be in 0..255."
    - "'!IHH' uses network byte order (same as big-endian): I=4 bytes, H=2 bytes, H=2 bytes; total = 8 bytes."
    - "All hex expected values verified by running struct.pack() in Python 3.12 on macOS/Darwin 25.4.0."
    - "pack('>I', 0)  == b'\\x00\\x00\\x00\\x00'  (hex: 00000000)"
    - "pack('>I', 1)  == b'\\x00\\x00\\x00\\x01'  (hex: 00000001)"
    - "pack('<I', 1)  == b'\\x01\\x00\\x00\\x00'  (hex: 01000000)"
    - "pack('>H', 256) == b'\\x01\\x00'           (hex: 0100)"
    - "pack('>4B', 1, 2, 3, 4) == b'\\x01\\x02\\x03\\x04' (hex: 01020304)"
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "struct.error is raised for mismatched buffer sizes and invalid format strings. It is a subclass of Exception."
  stderr: "null"
  stickiness: "N/A — struct functions are pure; Struct objects are immutable after construction."
  codes: {}

# ---------------------------------------------------------------------------
# pack() — big-endian unsigned 32-bit integer vectors
# ---------------------------------------------------------------------------

invariant struct_extra2.pack.big_endian_uint32_zero:
  description: "pack('>I', 0) == b'\\x00\\x00\\x00\\x00'"
  category: pack
  kind: python_call_eq
  function: pack
  args: [">I", 0]
  expected: !hex 00000000

invariant struct_extra2.pack.big_endian_uint32_one:
  description: "pack('>I', 1) == b'\\x00\\x00\\x00\\x01'"
  category: pack
  kind: python_call_eq
  function: pack
  args: [">I", 1]
  expected: !hex 00000001

# ---------------------------------------------------------------------------
# pack() — little-endian unsigned 32-bit integer
# ---------------------------------------------------------------------------

invariant struct_extra2.pack.little_endian_uint32_one:
  description: "pack('<I', 1) == b'\\x01\\x00\\x00\\x00' — little-endian byte reversal"
  category: pack
  kind: python_call_eq
  function: pack
  args: ["<I", 1]
  expected: !hex 01000000

# ---------------------------------------------------------------------------
# pack() — big-endian unsigned 16-bit integer
# ---------------------------------------------------------------------------

invariant struct_extra2.pack.big_endian_uint16_256:
  description: "pack('>H', 256) == b'\\x01\\x00'"
  category: pack
  kind: python_call_eq
  function: pack
  args: [">H", 256]
  expected: !hex 0100

# ---------------------------------------------------------------------------
# pack() — four unsigned bytes
# ---------------------------------------------------------------------------

invariant struct_extra2.pack.four_bytes_sequential:
  description: "pack('>4B', 1, 2, 3, 4) == b'\\x01\\x02\\x03\\x04'"
  category: pack
  kind: python_call_eq
  function: pack
  args: [">4B", 1, 2, 3, 4]
  expected: !hex 01020304

# ---------------------------------------------------------------------------
# unpack() — big-endian unsigned 32-bit integer
# ---------------------------------------------------------------------------

invariant struct_extra2.unpack.big_endian_uint32_one:
  description: "unpack('>I', b'\\x00\\x00\\x00\\x01') == (1,)"
  category: unpack
  kind: python_call_eq
  function: unpack
  args: [">I", !hex 00000001]
  expected: [1]

# ---------------------------------------------------------------------------
# unpack() — big-endian unsigned 16-bit integer
# ---------------------------------------------------------------------------

invariant struct_extra2.unpack.big_endian_uint16_256:
  description: "unpack('>H', b'\\x01\\x00') == (256,)"
  category: unpack
  kind: python_call_eq
  function: unpack
  args: [">H", !hex 0100]
  expected: [256]

# ---------------------------------------------------------------------------
# calcsize() — network byte order multi-field format
# ---------------------------------------------------------------------------

invariant struct_extra2.calcsize.network_IHH:
  description: "calcsize('!IHH') == 8 — network byte order: I=4, H=2, H=2 bytes, no padding"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["!IHH"]
  expected: 8
