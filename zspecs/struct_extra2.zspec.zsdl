spec: struct_extra2
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "This spec extends struct.zspec.zsdl and struct_extra.zspec.zsdl."
    - "struct.zspec.zsdl covers: pack/unpack vectors for B/b/H/h/I/i/Q/q/f/d/?/e/x; calcsize for H/I/Q/HI/HIQ/q/h/b/?/e; roundtrip for >q/>Q/>H/<I/>BHI; error cases."
    - "struct_extra.zspec.zsdl covers: Struct class format/size attrs, calcsize for f/d/B/4s/>BHI, pack_into method name, unpack_from with offset, iter_unpack, error class name/bases."
    - "This spec adds: __module__ attributes for pack/unpack/calcsize/pack_into/unpack_from/iter_unpack/error/Struct; __name__ for pack/unpack/calcsize; pack('>H', 256)==b'\\x01\\x00'; unpack('>H', b'\\x01\\x00')==(256,); calcsize('>HHH')==6; Struct.__bases__[0].__name__=='object'."
    - "struct.pack.__module__ == 'struct' — pack is a builtin_function_or_method from the struct C extension."
    - "struct.unpack.__module__ == 'struct' — unpack is a builtin_function_or_method from the struct C extension."
    - "struct.calcsize.__module__ == 'struct' — calcsize is a builtin_function_or_method from the struct C extension."
    - "struct.Struct.__module__ == 'struct' — the Struct class is defined in the struct C extension."
    - "struct.error.__module__ == 'struct' — the error exception class is defined in the struct module."
    - "struct.pack('>H', 256) == b'\\x01\\x00' — big-endian 16-bit encoding of 256."
    - "struct.unpack('>H', b'\\x01\\x00') == (256,) — big-endian 16-bit decoding."
    - "struct.calcsize('>HHH') == 6 — three big-endian 2-byte unsigned short fields."
    - "struct.Struct.__bases__[0].__name__ == 'object' — Struct inherits directly from object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ attributes
# ---------------------------------------------------------------------------

invariant struct_extra2.pack.name:
  description: "struct.pack.__name__ == 'pack'"
  category: function_names
  kind: python_call_eq
  function: pack.__name__.__eq__
  args: ["pack"]
  expected: true

invariant struct_extra2.unpack.name:
  description: "struct.unpack.__name__ == 'unpack'"
  category: function_names
  kind: python_call_eq
  function: unpack.__name__.__eq__
  args: ["unpack"]
  expected: true

invariant struct_extra2.calcsize.name:
  description: "struct.calcsize.__name__ == 'calcsize'"
  category: function_names
  kind: python_call_eq
  function: calcsize.__name__.__eq__
  args: ["calcsize"]
  expected: true

# ---------------------------------------------------------------------------
# Function __module__ attributes
# ---------------------------------------------------------------------------

invariant struct_extra2.pack.module:
  description: "struct.pack.__module__ == 'struct'"
  category: function_modules
  kind: python_call_eq
  function: pack.__module__.__eq__
  args: ["struct"]
  expected: true

invariant struct_extra2.unpack.module:
  description: "struct.unpack.__module__ == 'struct'"
  category: function_modules
  kind: python_call_eq
  function: unpack.__module__.__eq__
  args: ["struct"]
  expected: true

invariant struct_extra2.calcsize.module:
  description: "struct.calcsize.__module__ == 'struct'"
  category: function_modules
  kind: python_call_eq
  function: calcsize.__module__.__eq__
  args: ["struct"]
  expected: true

invariant struct_extra2.pack_into.module:
  description: "struct.pack_into.__module__ == 'struct'"
  category: function_modules
  kind: python_call_eq
  function: pack_into.__module__.__eq__
  args: ["struct"]
  expected: true

invariant struct_extra2.unpack_from.module:
  description: "struct.unpack_from.__module__ == 'struct'"
  category: function_modules
  kind: python_call_eq
  function: unpack_from.__module__.__eq__
  args: ["struct"]
  expected: true

invariant struct_extra2.iter_unpack.module:
  description: "struct.iter_unpack.__module__ == 'struct'"
  category: function_modules
  kind: python_call_eq
  function: iter_unpack.__module__.__eq__
  args: ["struct"]
  expected: true

invariant struct_extra2.error.module:
  description: "struct.error.__module__ == 'struct'"
  category: function_modules
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["struct"]
  expected: true

invariant struct_extra2.Struct.module:
  description: "struct.Struct.__module__ == 'struct'"
  category: function_modules
  kind: python_call_eq
  function: Struct.__module__.__eq__
  args: ["struct"]
  expected: true

# ---------------------------------------------------------------------------
# pack() correctness — big-endian 16-bit unsigned integer encoding
# ---------------------------------------------------------------------------

invariant struct_extra2.pack.big_endian_uint16_256:
  description: "struct.pack('>H', 256) == b'\\x01\\x00' — big-endian encoding of 256"
  category: pack_values
  kind: python_call_eq
  function: pack
  args: [">H", 256]
  expected: !hex 0100

# ---------------------------------------------------------------------------
# unpack() correctness — big-endian 16-bit unsigned integer decoding
# ---------------------------------------------------------------------------

invariant struct_extra2.unpack.big_endian_uint16_256:
  description: "struct.unpack('>H', b'\\x01\\x00') == (256,)"
  category: unpack_values
  kind: python_call_eq
  function: unpack
  args: [">H", !hex 0100]
  expected: [256]

# ---------------------------------------------------------------------------
# calcsize() — three 2-byte fields ('>HHH' is not in struct.zspec.zsdl)
# ---------------------------------------------------------------------------

invariant struct_extra2.calcsize.three_shorts:
  description: "struct.calcsize('>HHH') == 6 — three big-endian 2-byte unsigned short fields"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: [">HHH"]
  expected: 6

# ---------------------------------------------------------------------------
# Struct base class hierarchy
# ---------------------------------------------------------------------------

invariant struct_extra2.Struct.base_is_object:
  description: "struct.Struct.__bases__[0].__name__ == 'object' — Struct inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Struct.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"
