spec: cmath_extra5
version: ">=3.9"
backend: python_module(cmath)

docs: https://docs.python.org/3/library/cmath.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/cmath.html — Python cmath documentation"
    - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/cmathmodule.c"
  notes:
    - "This spec extends cmath.zspec.zsdl, cmath_extra.zspec.zsdl, cmath_extra2.zspec.zsdl, cmath_extra3.zspec.zsdl, and cmath_extra4.zspec.zsdl."
    - "cmath.zspec: isfinite/isinf/isnan with 1.0/0.0/inf/nan; phase(1.0/-1.0/0.0); polar(5.0); sqrt(4.0/9.0/-1.0)."
    - "cmath_extra2: __module__ for phase; polar(1.0)[0] and [1]; rect(1.0, 0.0)."
    - "cmath_extra3: __qualname__ table for all functions; __class__.__name__ for constants."
    - "cmath_extra4: sin/cos/tan/sqrt at zero; tau bounds; log(1+0j); infj/nanj real parts."
    - "No prior spec covers cmath.phase(-1) == pi with integer argument (-1 not -1.0)."
    - "No prior spec covers cmath.sqrt(-4).real == 0.0 or cmath.sqrt(-4).imag == 2.0."
    - "No prior spec covers cmath.polar(1) with integer 1 (vs float 1.0 in cmath_extra2)."
    - "No prior spec covers cmath.isnan(0) == False or cmath.isinf(0) == False (integer zero)."
    - "No prior spec covers cmath.isfinite(-1) == True (negative integer input)."
    - "No prior spec covers cmath.asin(0).real == 0.0 or cmath.asin(0).imag == 0.0."
    - "No prior spec covers cmath.atan(0).real == 0.0 or cmath.atan(0).imag == 0.0."
    - "No prior spec covers cmath.atan(1).real == pi/4 == 0.7853981633974483."
    - "No prior spec covers cmath.__name__ == 'cmath' (module-level __name__)."
    - "cmath.phase(-1) == 3.141592653589793 — phase of -1 (integer) equals pi."
    - "cmath.sqrt(-4).real == 0.0 — sqrt of -4 has zero real part."
    - "cmath.sqrt(-4).imag == 2.0 — sqrt of -4 has imaginary part 2."
    - "cmath.polar(1)[0] == 1.0 — magnitude of 1 is 1.0."
    - "cmath.polar(1)[1] == 0.0 — phase of positive real 1 is 0.0."
    - "cmath.isnan(0) == False — integer zero is not NaN."
    - "cmath.isinf(0) == False — integer zero is not infinite."
    - "cmath.isfinite(-1) == True — negative integer is finite."
    - "cmath.asin(0).real == 0.0 — asin(0) has zero real part."
    - "cmath.asin(0).imag == 0.0 — asin(0) has zero imaginary part."
    - "cmath.atan(0).real == 0.0 — atan(0) has zero real part."
    - "cmath.atan(1).real == 0.7853981633974483 — atan(1) == pi/4."
    - "cmath.__name__ == 'cmath' — module-level name attribute."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# cmath.phase(-1) — integer argument yields pi
#
# cmath.zspec covers phase(-1.0) == pi using float -1.0. No prior spec covers
# phase(-1) with an integer argument. The result is the same: pi.
# ---------------------------------------------------------------------------

invariant cmath_extra5.phase.negative_one_int:
  description: "cmath.phase(-1) == pi — phase of integer -1 equals pi"
  category: phase
  kind: python_call_eq
  function: phase
  args: [-1]
  expected: 3.141592653589793

# ---------------------------------------------------------------------------
# cmath.sqrt(-4) — square root of -4 gives 2j
#
# cmath.zspec covers sqrt(-1.0) giving imag==1.0. No prior spec covers sqrt(-4)
# which gives 2j: real == 0.0, imag == 2.0.
# ---------------------------------------------------------------------------

invariant cmath_extra5.sqrt.neg_four_real:
  description: "cmath.sqrt(-4).real == 0.0 — sqrt of -4 has zero real part"
  category: sqrt
  kind: python_call_eq
  function: sqrt
  args: [-4]
  method: real
  expected: 0.0

invariant cmath_extra5.sqrt.neg_four_imag:
  description: "cmath.sqrt(-4).imag == 2.0 — sqrt of -4 has imaginary part 2"
  category: sqrt
  kind: python_call_eq
  function: sqrt
  args: [-4]
  method: imag
  expected: 2.0

# ---------------------------------------------------------------------------
# cmath.polar(1) — integer input, component access
#
# cmath.zspec covers polar(5.0) with float; cmath_extra2 covers polar(1.0).
# No prior spec uses integer argument polar(1); result is (1.0, 0.0).
# Components are accessed via __getitem__.
# ---------------------------------------------------------------------------

invariant cmath_extra5.polar.one_int_magnitude:
  description: "cmath.polar(1)[0] == 1.0 — magnitude of integer 1 as complex is 1.0"
  category: polar
  kind: python_call_eq
  function: polar
  args: [1]
  method: __getitem__
  method_args: [0]
  expected: 1.0

invariant cmath_extra5.polar.one_int_phase:
  description: "cmath.polar(1)[1] == 0.0 — phase of positive real integer 1 is 0.0"
  category: polar
  kind: python_call_eq
  function: polar
  args: [1]
  method: __getitem__
  method_args: [1]
  expected: 0.0

# ---------------------------------------------------------------------------
# isnan / isinf / isfinite — integer zero input
#
# cmath.zspec covers isnan(1.0)==False, isinf(0.0)==False, isfinite(0.0)==True.
# No prior spec covers these predicates with integer zero (0 rather than 0.0).
# Integer 0 is auto-promoted to complex; it is neither nan nor infinite.
# ---------------------------------------------------------------------------

invariant cmath_extra5.isnan.zero_int:
  description: "cmath.isnan(0) == False — integer zero is not NaN"
  category: predicates
  kind: python_call_eq
  function: isnan
  args: [0]
  expected: false

invariant cmath_extra5.isinf.zero_int:
  description: "cmath.isinf(0) == False — integer zero is not infinite"
  category: predicates
  kind: python_call_eq
  function: isinf
  args: [0]
  expected: false

invariant cmath_extra5.isfinite.negative_one_int:
  description: "cmath.isfinite(-1) == True — negative integer -1 is finite"
  category: predicates
  kind: python_call_eq
  function: isfinite
  args: [-1]
  expected: true

# ---------------------------------------------------------------------------
# cmath.asin(0) — arcsine at zero
#
# No prior spec covers asin value vectors. asin(0) == 0+0j.
# ---------------------------------------------------------------------------

invariant cmath_extra5.asin.zero_real:
  description: "cmath.asin(0).real == 0.0 — asin of zero has zero real part"
  category: inverse_trig
  kind: python_call_eq
  function: asin
  args: [0]
  method: real
  expected: 0.0

invariant cmath_extra5.asin.zero_imag:
  description: "cmath.asin(0).imag == 0.0 — asin of zero has zero imaginary part"
  category: inverse_trig
  kind: python_call_eq
  function: asin
  args: [0]
  method: imag
  expected: 0.0

# ---------------------------------------------------------------------------
# cmath.atan — arctangent value vectors
#
# No prior spec covers atan value vectors.
# atan(0) == 0+0j; atan(1).real == pi/4 == 0.7853981633974483.
# ---------------------------------------------------------------------------

invariant cmath_extra5.atan.zero_real:
  description: "cmath.atan(0).real == 0.0 — atan of zero has zero real part"
  category: inverse_trig
  kind: python_call_eq
  function: atan
  args: [0]
  method: real
  expected: 0.0

invariant cmath_extra5.atan.one_real:
  description: "cmath.atan(1).real == 0.7853981633974483 — atan(1) == pi/4"
  category: inverse_trig
  kind: python_call_eq
  function: atan
  args: [1]
  method: real
  expected: 0.7853981633974483

# ---------------------------------------------------------------------------
# cmath.__name__ — module-level name attribute
#
# No prior spec checks the cmath module's own __name__ attribute.
# Function __name__ attrs (e.g. sin.__name__) were covered in cmath_extra.
# cmath.__name__ == 'cmath' confirms the module identity string.
# ---------------------------------------------------------------------------

invariant cmath_extra5.module.name:
  description: "cmath.__name__ == 'cmath' — module-level name attribute identifies the module"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["cmath"]
  expected: true
