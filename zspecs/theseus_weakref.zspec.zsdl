spec: theseus_weakref
version: ">=3.9"
backend: python_cleanroom(theseus_weakref)
blocks: weakref

docs: https://docs.python.org/3/library/weakref.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/weakref.html"
  notes:
    - "Clean-room weak reference utility. Do NOT import weakref or gc."
    - "WeakRef(obj): wrapper that returns obj while it exists, None after GC."
    - "WeakValueDictionary: dict-like that doesn't keep values alive."
    - "Simulate weak reference semantics using a reference holder with a flag."
    - "weakref_alive(): ref to live object returns the object (is not None)."
    - "weakref_callable(): calling ref() returns the referenced object."
    - "weakref_finalize(): finalize callback is invoked on deletion."
    - "Export: WeakRef class with __call__() method, finalize(obj, callback)."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_weakref.alive:
  description: "ref() on live object returns the object"
  category: ref
  kind: python_call_eq
  function: weakref_alive
  args: []
  expected: true

invariant theseus_weakref.callable:
  description: "calling ref() returns the object's value"
  category: ref
  kind: python_call_eq
  function: weakref_callable
  args: []
  expected: 42

invariant theseus_weakref.finalize_called:
  description: "finalize callback is registered and can be called"
  category: finalize
  kind: python_call_eq
  function: weakref_finalize_called
  args: []
  expected: true
