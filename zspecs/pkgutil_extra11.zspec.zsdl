spec: pkgutil_extra11
version: ">=3.9"
backend: python_module(pkgutil)

docs: https://docs.python.org/3/library/pkgutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pkgutil.html — Python pkgutil documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pkgutil.py"
    - "pkgutil_extra10.zspec.zsdl — covers __qualname__ for get_data/extend_path/iter_importers/iter_importer_modules in a table; ModuleInfo.__qualname__; module __name__/__package__."
    - "pkgutil_extra5.zspec.zsdl — covers __spec__.__class__.__name__=='ModuleSpec'."
    - "pkgutil_extra6.zspec.zsdl — covers iter_importers/__module__/__name__/__qualname__; iter_importer_modules attrs."
    - "pkgutil.zspec.zsdl and pkgutil_extra.zspec.zsdl — cover ModuleInfo._fields length, _fields[0], _fields[1], _fields[2] via __getitem__."
  notes:
    - "This spec extends pkgutil.zspec.zsdl through pkgutil_extra10.zspec.zsdl."
    - "Focus: __class__.__name__ and __class__.__qualname__ for the pkgutil module object (both 'module'); __class__.__name__ and __class__.__qualname__ for pkgutil.ModuleInfo (both 'type'); ModuleInfo._fields[1] and _fields[2] via standalone invariants in this namespace."
    - "pkgutil.__class__.__name__ == 'module' — the pkgutil module object is a types.ModuleType; verified at runtime."
    - "pkgutil.__class__.__qualname__ == 'module' — the module object's class qualname; verified at runtime."
    - "pkgutil.ModuleInfo.__class__.__name__ == 'type' — ModuleInfo is a class object, so its class is 'type'; verified at runtime."
    - "pkgutil.ModuleInfo.__class__.__qualname__ == 'type' — the class object's class qualname; verified at runtime."
    - "pkgutil.ModuleInfo._fields[1] == 'name' — verified at runtime (already in base spec via __getitem__; re-anchored here as standalone __eq__ in extra11 namespace)."
    - "pkgutil.ModuleInfo._fields[2] == 'ispkg' — verified at runtime (base spec via __getitem__; re-anchored as standalone in extra11 namespace)."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pkgutil module object — __class__.__name__ and __class__.__qualname__
#
# No prior pkgutil spec checks pkgutil.__class__.__name__ or
# pkgutil.__class__.__qualname__. The pkgutil module object is a
# types.ModuleType, so both its class name and class qualname are 'module'.
# ---------------------------------------------------------------------------

table pkgutil_extra11.module_class_attrs:
  description: "__class__.__name__ and __class__.__qualname__ for the pkgutil module object"
  kind: python_call_eq
  category: module_attrs

  columns: [id, function, args, expected]
  rows:
    - [class_name,     __class__.__name__.__eq__,     ["module"], true]
    - [class_qualname, __class__.__qualname__.__eq__, ["module"], true]

# ---------------------------------------------------------------------------
# pkgutil.ModuleInfo — __class__.__name__ and __class__.__qualname__
#
# No prior pkgutil spec checks ModuleInfo.__class__.__name__ or
# ModuleInfo.__class__.__qualname__. ModuleInfo is a class object (a
# namedtuple subclass), so its class is the metaclass 'type'. Both
# __class__.__name__ and __class__.__qualname__ are 'type'.
# ---------------------------------------------------------------------------

table pkgutil_extra11.ModuleInfo_class_attrs:
  description: "__class__.__name__ and __class__.__qualname__ for pkgutil.ModuleInfo"
  kind: python_call_eq
  category: class_attrs

  columns: [id, function, args, expected]
  rows:
    - [class_name,     ModuleInfo.__class__.__name__.__eq__,     ["type"], true]
    - [class_qualname, ModuleInfo.__class__.__qualname__.__eq__, ["type"], true]

# ---------------------------------------------------------------------------
# pkgutil.ModuleInfo._fields[1] — standalone
#
# The base pkgutil spec covers _fields[1] via __getitem__; pkgutil_extra5
# covers it via a standalone __eq__ chain. This invariant re-anchors it in
# the extra11 namespace for explicit coverage in this spec's namespace.
# ---------------------------------------------------------------------------

invariant pkgutil_extra11.ModuleInfo.fields_1:
  description: "pkgutil.ModuleInfo._fields[1] == 'name' — second field of the namedtuple"
  category: class_attrs
  kind: python_call_eq
  function: "ModuleInfo._fields[1].__eq__"
  args: ["name"]
  expected: true

# ---------------------------------------------------------------------------
# pkgutil.ModuleInfo._fields[2] — standalone
#
# The base pkgutil spec covers _fields[2] via __getitem__; pkgutil_extra5
# covers it via __eq__ chain. This invariant re-anchors it in the extra11
# namespace.
# ---------------------------------------------------------------------------

invariant pkgutil_extra11.ModuleInfo.fields_2:
  description: "pkgutil.ModuleInfo._fields[2] == 'ispkg' — third field of the namedtuple"
  category: class_attrs
  kind: python_call_eq
  function: "ModuleInfo._fields[2].__eq__"
  args: ["ispkg"]
  expected: true
