spec: just_compact
version: ">=3.2.0"
backend: node(just-compact)

docs: https://www.npmjs.com/package/just-compact

provenance:
  derived_from:
    - "just-compact README — https://www.npmjs.com/package/just-compact"
    - "Test vectors verified with just-compact via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "just-compact source"
  notes:
    - "just-compact is an npm package. Install: npm install just-compact"
    - "The module exports a single function that removes falsy values from an array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a new array with falsy values removed."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_compact.compact:
  kind: node_module_call_eq
  function: ~
  category: filter
  id_prefix: jcmpct

  columns: [id, args, expected]
  rows:
    - [mixed_falsy, [[1, null, 0, false, 2, "", 3]], [1, 2, 3]]
    - [all_truthy,  [[1, 2, 3]],                                [1, 2, 3]]
    - [all_falsy,   [[null, 0, false, ""]],                     []]

