spec: profile_extra5
version: ">=3.3"
backend: python_module(profile)

docs: https://docs.python.org/3/library/profile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/profile.html — Python profile documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/profile.py"
    - "profile.zspec.zsdl — covers Profile/__name__/__module__/__bases__[0]/__name__, Profile methods __name__ (run/runcall/runctx/print_stats/dump_stats), Profile instantiation, profile.__name__"
    - "profile_extra.zspec.zsdl — covers Profile/__name__/__module__, run/__name__, runctx/__name__"
    - "profile_extra2.zspec.zsdl — pstats backend; SortKey values, Stats.dump_stats/__name__, Stats.add/__name__"
    - "profile_extra3.zspec.zsdl — covers Profile/__qualname__, run/__module__, runctx/__module__, run/__name__/runctx/__name__ table, Profile/__qualname__/__class__/__name__"
    - "profile_extra4.zspec.zsdl — covers Profile method __qualname__ and __module__ (run/runcall/runctx/print_stats/dump_stats), Profile/__bases__.__len__, Profile method type checks, run/__qualname__, runctx/__qualname__"
  notes:
    - "This spec extends profile.zspec.zsdl through profile_extra4.zspec.zsdl."
    - "Focus: Profile.calibrate and Profile.simulate_call method __name__ (not covered by any prior profile spec); Profile.__bases__[0].__qualname__; Profile.calibrate/__class__/__name__ type check; Profile.__dict__.__contains__ checks for method presence."
    - "profile.Profile.calibrate is a method used to calibrate the overhead of the profiler; __name__ == 'calibrate'."
    - "profile.Profile.simulate_call is an internal method; __name__ == 'simulate_call'."
    - "Profile.__bases__[0].__qualname__ == 'object' — the base class (object) has qualname 'object'."
    - "Profile.calibrate is a plain Python function: __class__.__name__ == 'function'."
    - "Profile.simulate_call is a plain Python function: __class__.__name__ == 'function'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Profile.calibrate and Profile.simulate_call — method __name__ checks
# profile.zspec.zsdl covers run/runcall/runctx/print_stats/dump_stats only.
# calibrate and simulate_call are not covered in any prior profile spec.
# ---------------------------------------------------------------------------

invariant profile_extra5.Profile.calibrate.name:
  description: "profile.Profile.calibrate.__name__ == 'calibrate'"
  category: method_names
  kind: python_call_eq
  function: Profile.calibrate.__name__.__eq__
  args: ["calibrate"]
  expected: true

invariant profile_extra5.Profile.simulate_call.name:
  description: "profile.Profile.simulate_call.__name__ == 'simulate_call'"
  category: method_names
  kind: python_call_eq
  function: Profile.simulate_call.__name__.__eq__
  args: ["simulate_call"]
  expected: true

# ---------------------------------------------------------------------------
# Profile.calibrate and Profile.simulate_call — method type checks
# Not covered in any prior profile spec.
# ---------------------------------------------------------------------------

invariant profile_extra5.Profile.calibrate.type:
  description: "profile.Profile.calibrate.__class__.__name__ == 'function' — calibrate is a plain Python function"
  category: method_types
  kind: python_call_eq
  function: Profile.calibrate.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant profile_extra5.Profile.simulate_call.type:
  description: "profile.Profile.simulate_call.__class__.__name__ == 'function' — simulate_call is a plain Python function"
  category: method_types
  kind: python_call_eq
  function: Profile.simulate_call.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# Profile.calibrate and Profile.simulate_call — __qualname__
# profile_extra4 covers run/runcall/runctx/print_stats/dump_stats qualnames.
# calibrate and simulate_call are absent from all prior qualname checks.
# ---------------------------------------------------------------------------

invariant profile_extra5.Profile.calibrate.qualname:
  description: "profile.Profile.calibrate.__qualname__ == 'Profile.calibrate'"
  category: method_qualnames
  kind: python_call_eq
  function: Profile.calibrate.__qualname__.__eq__
  args: ["Profile.calibrate"]
  expected: true

invariant profile_extra5.Profile.simulate_call.qualname:
  description: "profile.Profile.simulate_call.__qualname__ == 'Profile.simulate_call'"
  category: method_qualnames
  kind: python_call_eq
  function: Profile.simulate_call.__qualname__.__eq__
  args: ["Profile.simulate_call"]
  expected: true

# ---------------------------------------------------------------------------
# Profile.__bases__[0].__qualname__
# profile.zspec.zsdl and all extras cover __bases__[0].__name__ == 'object'.
# No prior spec checks __bases__[0].__qualname__ — a distinct attribute of the base class.
# ---------------------------------------------------------------------------

invariant profile_extra5.Profile.base_qualname:
  description: "profile.Profile.__bases__[0].__qualname__ == 'object' — base class object has qualname 'object'"
  category: hierarchy
  kind: python_call_eq
  function: Profile.__bases__.__getitem__
  args: [0]
  method: __qualname__
  expected: "object"

# ---------------------------------------------------------------------------
# Profile.__dict__.__contains__ — method presence verification
# No prior profile spec uses __dict__ membership as a test axis.
# This is a distinct invariant category from __name__ and __qualname__ checks.
# ---------------------------------------------------------------------------

table profile_extra5.Profile_dict_contains:
  description: "Profile.__dict__ contains the expected method names"
  kind: python_call_eq
  category: dict_membership
  id_prefix: Profile_dict

  columns: [id, function, args, expected]
  rows:
    - [run,           Profile.__dict__.__contains__, ["run"],           true]
    - [runcall,       Profile.__dict__.__contains__, ["runcall"],       true]
    - [calibrate,     Profile.__dict__.__contains__, ["calibrate"],     true]
    - [simulate_call, Profile.__dict__.__contains__, ["simulate_call"], true]
