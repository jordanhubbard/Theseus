spec: socket_extra321
version: ">=3.5"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "This spec covers socket.socket method __qualname__ attributes."
    - "socket.socket methods are C extension wrappers; their __qualname__ is 'socket.<method_name>'."
    - "All nine methods tested here have qualname of the form 'socket.<method_name>' — verified on Python 3.14.3."
    - "socket.socket.connect.__qualname__ == 'socket.connect' (not 'socket.socket.connect')."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket method __qualname__ checks
# These are C extension wrappers; qualname is 'socket.<method>' on Python 3.14.
# ---------------------------------------------------------------------------

invariant socket_extra321.socket.connect_qualname:
  description: "socket.socket.connect.__qualname__ == 'socket.connect'"
  category: qualnames
  kind: python_call_eq
  function: socket.connect.__qualname__.__eq__
  args: ["socket.connect"]
  expected: true

invariant socket_extra321.socket.bind_qualname:
  description: "socket.socket.bind.__qualname__ == 'socket.bind'"
  category: qualnames
  kind: python_call_eq
  function: socket.bind.__qualname__.__eq__
  args: ["socket.bind"]
  expected: true

invariant socket_extra321.socket.listen_qualname:
  description: "socket.socket.listen.__qualname__ == 'socket.listen'"
  category: qualnames
  kind: python_call_eq
  function: socket.listen.__qualname__.__eq__
  args: ["socket.listen"]
  expected: true

invariant socket_extra321.socket.accept_qualname:
  description: "socket.socket.accept.__qualname__ == 'socket.accept'"
  category: qualnames
  kind: python_call_eq
  function: socket.accept.__qualname__.__eq__
  args: ["socket.accept"]
  expected: true

invariant socket_extra321.socket.send_qualname:
  description: "socket.socket.send.__qualname__ == 'socket.send'"
  category: qualnames
  kind: python_call_eq
  function: socket.send.__qualname__.__eq__
  args: ["socket.send"]
  expected: true

invariant socket_extra321.socket.recv_qualname:
  description: "socket.socket.recv.__qualname__ == 'socket.recv'"
  category: qualnames
  kind: python_call_eq
  function: socket.recv.__qualname__.__eq__
  args: ["socket.recv"]
  expected: true

invariant socket_extra321.socket.close_qualname:
  description: "socket.socket.close.__qualname__ == 'socket.close'"
  category: qualnames
  kind: python_call_eq
  function: socket.close.__qualname__.__eq__
  args: ["socket.close"]
  expected: true

invariant socket_extra321.socket.settimeout_qualname:
  description: "socket.socket.settimeout.__qualname__ == 'socket.settimeout'"
  category: qualnames
  kind: python_call_eq
  function: socket.settimeout.__qualname__.__eq__
  args: ["socket.settimeout"]
  expected: true

invariant socket_extra321.socket.getsockname_qualname:
  description: "socket.socket.getsockname.__qualname__ == 'socket.getsockname'"
  category: qualnames
  kind: python_call_eq
  function: socket.getsockname.__qualname__.__eq__
  args: ["socket.getsockname"]
  expected: true
