spec: decimal_extra2656
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra.zspec.zsdl — covers existing decimal invariants"
    - "decimal_extra2641.zspec.zsdl — covers __copy__/__deepcopy__/__sizeof__ dict-presence"
  notes:
    - "Wave 624 (decimal_extra2656) theme: __contains__, __add__, and __mul__ dict-presence checks."
    - "decimal.Decimal defines __add__ AND __mul__ in its own __dict__ — Decimal is a full arithmetic type."
    - "decimal.Decimal does NOT define __contains__ in its own __dict__ — Decimal is not a container type."
    - "decimal.Context and decimal.DecimalException define none of __contains__, __add__, or __mul__ in their own __dict__."
    - "decimal.Context.__add__ is absent because Context is a configuration object, not a numeric value."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __contains__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2656.no_contains_in_decimal_classes:
  description: "__contains__ is absent from all decimal class __dict__s — Decimal, Context, and DecimalException are not container types"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2656

  columns: [id, function, args, expected]
  rows:
    - ["dc2656001", "decimal.Decimal.__dict__.__contains__",          ["__contains__"], false]
    - ["dc2656002", "decimal.Context.__dict__.__contains__",          ["__contains__"], false]
    - ["dc2656003", "decimal.DecimalException.__dict__.__contains__", ["__contains__"], false]

# ---------------------------------------------------------------------------
# __add__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2656.add_in_decimal_classes:
  description: "__add__ IS defined in decimal.Decimal __dict__ but absent from decimal.Context and decimal.DecimalException — only Decimal implements arithmetic addition"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2656

  columns: [id, function, args, expected]
  rows:
    - ["dc2656004", "decimal.Decimal.__dict__.__contains__",          ["__add__"], true]
    - ["dc2656005", "decimal.Context.__dict__.__contains__",          ["__add__"], false]
    - ["dc2656006", "decimal.DecimalException.__dict__.__contains__", ["__add__"], false]

# ---------------------------------------------------------------------------
# __mul__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2656.mul_in_decimal_classes:
  description: "__mul__ IS defined in decimal.Decimal __dict__ but absent from decimal.Context and decimal.DecimalException — only Decimal implements arithmetic multiplication"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2656

  columns: [id, function, args, expected]
  rows:
    - ["dc2656007", "decimal.Decimal.__dict__.__contains__",          ["__mul__"], true]
    - ["dc2656008", "decimal.Context.__dict__.__contains__",          ["__mul__"], false]
    - ["dc2656009", "decimal.DecimalException.__dict__.__contains__", ["__mul__"], false]

# ---------------------------------------------------------------------------
# Complementary: decimal.Decimal has full arithmetic protocol; Context has configuration methods only
# Confirms that __add__/__mul__ co-occur with other arithmetic hooks in Decimal but not Context
# ---------------------------------------------------------------------------

table decimal_extra2656.decimal_arithmetic_and_no_container_hooks:
  description: "decimal.Decimal defines __new__/__add__/__mul__/__abs__/__neg__ but NOT __contains__; decimal.Context defines prec/rounding/create_decimal but NOT __add__/__mul__/__contains__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2656

  columns: [id, function, args, expected]
  rows:
    - ["dc2656010", "decimal.Decimal.__dict__.__contains__", ["__new__"],      true]
    - ["dc2656011", "decimal.Decimal.__dict__.__contains__", ["__add__"],      true]
    - ["dc2656012", "decimal.Decimal.__dict__.__contains__", ["__mul__"],      true]
    - ["dc2656013", "decimal.Decimal.__dict__.__contains__", ["__abs__"],      true]
    - ["dc2656014", "decimal.Decimal.__dict__.__contains__", ["__neg__"],      true]
    - ["dc2656015", "decimal.Decimal.__dict__.__contains__", ["__contains__"], false]
    - ["dc2656016", "decimal.Context.__dict__.__contains__", ["prec"],         true]
    - ["dc2656017", "decimal.Context.__dict__.__contains__", ["rounding"],     true]
    - ["dc2656018", "decimal.Context.__dict__.__contains__", ["create_decimal"], true]
    - ["dc2656019", "decimal.Context.__dict__.__contains__", ["__add__"],      false]
    - ["dc2656020", "decimal.Context.__dict__.__contains__", ["__mul__"],      false]
    - ["dc2656021", "decimal.Context.__dict__.__contains__", ["__contains__"], false]
