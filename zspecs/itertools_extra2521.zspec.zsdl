spec: itertools_extra2521
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: __bool__, __index__, and __int__ dict-presence checks for itertools classes."
    - "Theme: truthiness, integer coercion, and indexing protocol dict-presence — checking whether classes define __bool__, __index__, or __int__ in their class __dict__."
    - "All itertools classes covered here are lazy iterator types implemented in C; none define __bool__, __index__, or __int__."
    - "itertools.chain lazily chains multiple iterables into a single sequence; it is a traversal type with no numeric or truthiness protocol. Verified with Python 3.14."
    - "itertools.cycle repeatedly cycles over an iterable's elements; it produces values indefinitely but defines no truthiness override or integer coercion. Verified with Python 3.14."
    - "itertools.count generates an infinite arithmetic sequence starting at a given value; despite its numeric nature, the class itself defines no __bool__, __index__, or __int__ in its __dict__ — it produces values, it is not a value. Verified with Python 3.14."
    - "itertools.islice slices an iterable lazily by position; it is a filtering iterator with no numeric semantics. Verified with Python 3.14."
    - "itertools.repeat yields a single value a fixed or infinite number of times; it is a source iterator, not a numeric type. Verified with Python 3.14."
    - "itertools.product, itertools.permutations, itertools.combinations, and itertools.combinations_with_replacement are combinatorial iterators; they enumerate structured sequences but define no numeric coercion protocol. Verified with Python 3.14."
    - "itertools.compress, itertools.dropwhile, itertools.takewhile, and itertools.filterfalse are filter-style iterators that select elements based on a condition; they carry no integer or truthiness protocol in their own __dict__. Verified with Python 3.14."
    - "itertools.groupby groups consecutive elements by a key function; itertools.starmap applies a function to argument tuples; itertools.accumulate produces running aggregates. None define __bool__, __index__, or __int__. Verified with Python 3.14."
    - "itertools.pairwise (Python 3.10+) yields consecutive overlapping pairs; it is a pure traversal type with no numeric protocol. Verified with Python 3.14."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.chain, itertools.cycle, itertools.count
#
# Theme: __bool__, __index__, __int__ absent from chain, cycle, count.__dict__.
# chain lazily chains iterables; cycle repeats them indefinitely; count produces
# an infinite arithmetic sequence. All three are C iterator types with no
# truthiness override or numeric coercion in their class __dict__.
# ---------------------------------------------------------------------------

table itertools_extra2521.chain_cycle_count_bool_index_int:
  description: "__bool__, __index__, __int__ absent from itertools.chain, cycle, count __dict__; wave 2521"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: it2521

  columns: [id, function, args, expected]
  rows:
    - ["it2521-001", "chain.__dict__.__contains__", ["__bool__"], false]
    - ["it2521-002", "chain.__dict__.__contains__", ["__index__"], false]
    - ["it2521-003", "chain.__dict__.__contains__", ["__int__"], false]
    - ["it2521-004", "cycle.__dict__.__contains__", ["__bool__"], false]
    - ["it2521-005", "cycle.__dict__.__contains__", ["__index__"], false]
    - ["it2521-006", "cycle.__dict__.__contains__", ["__int__"], false]
    - ["it2521-007", "count.__dict__.__contains__", ["__bool__"], false]
    - ["it2521-008", "count.__dict__.__contains__", ["__index__"], false]
    - ["it2521-009", "count.__dict__.__contains__", ["__int__"], false]

