spec: theseus_uuid_cr
version: ">=3.0"
backend: python_cleanroom(theseus_uuid_cr)
blocks: uuid

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/uuid.html"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "Clean-room uuid module. Do NOT import uuid."

error_model: python_exceptions

invariant theseus_uuid_cr.uuid2_uuid4:
  description: "uuid4() generates random UUIDs"
  category: behavior
  kind: python_call_eq
  function: uuid2_uuid4
  args: []
  expected: true

invariant theseus_uuid_cr.uuid2_uuid5:
  description: "uuid5() generates name-based UUIDs"
  category: behavior
  kind: python_call_eq
  function: uuid2_uuid5
  args: []
  expected: true

invariant theseus_uuid_cr.uuid2_class:
  description: "UUID class parses hex strings correctly"
  category: behavior
  kind: python_call_eq
  function: uuid2_class
  args: []
  expected: true
