spec: theseus_threading_cr
version: ">=3.9"
backend: python_cleanroom(theseus_threading_cr)
blocks: threading

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html"
  notes:
    - "Clean-room threading primitives. Do NOT import threading, _thread, or concurrent."
    - "Lock: mutual exclusion lock with acquire()/release() and context manager support."
    - "Event: synchronization flag with set()/clear()/is_set()/wait()."
    - "Semaphore(n): counting semaphore with acquire()/release()."
    - "threading_lock_acquire_release(): Lock() acquire then release works without error."
    - "threading_event_set_get(): Event().set(); is_set() == True."
    - "threading_semaphore_count(): Semaphore(3).acquire() returns True."
    - "Export: Lock, RLock, Event, Semaphore classes."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_threading_cr.lock_acquire_release:
  description: "Lock() acquire then release succeeds"
  category: lock
  kind: python_call_eq
  function: threading_lock_acquire_release
  args: []
  expected: true

invariant theseus_threading_cr.event_set:
  description: "Event().set(); is_set() == True"
  category: event
  kind: python_call_eq
  function: threading_event_set_get
  args: []
  expected: true

invariant theseus_threading_cr.semaphore_acquire:
  description: "Semaphore(3).acquire() returns True"
  category: semaphore
  kind: python_call_eq
  function: threading_semaphore_acquire
  args: []
  expected: true
