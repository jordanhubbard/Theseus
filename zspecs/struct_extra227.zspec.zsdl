spec: struct_extra227
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.pack.__name__ == 'pack' — module-level pack function name is 'pack' (4 characters)."
    - "struct.pack.__qualname__ == 'pack' — module-level function qualname equals name."
    - "struct.pack.__module__ == '_struct' — module-level pack is from the _struct C extension."
    - "struct.unpack.__name__ == 'unpack' — module-level unpack function name is 'unpack' (6 characters)."
    - "struct.unpack.__qualname__ == 'unpack' — module-level function qualname equals name."
    - "struct.unpack.__module__ == '_struct' — module-level unpack is from the _struct C extension."
    - "struct.calcsize.__name__ == 'calcsize' — module-level calcsize function name is 'calcsize' (8 characters)."
    - "struct.calcsize.__qualname__ == 'calcsize' — module-level function qualname equals name."
    - "struct.calcsize.__module__ == '_struct' — module-level calcsize is from the _struct C extension."
    - "struct.pack_into.__name__ == 'pack_into' — module-level pack_into name is 'pack_into' (9 characters)."
    - "struct.iter_unpack.__name__ == 'iter_unpack' — module-level iter_unpack name is 'iter_unpack' (11 characters)."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct module-level pack/unpack/calcsize function identity contracts
#
# struct.pack.__name__      == 'pack'
# struct.pack.__qualname__  == 'pack'
# struct.pack.__module__    == '_struct'
# struct.unpack.__name__    == 'unpack'
# struct.unpack.__qualname__ == 'unpack'
# struct.unpack.__module__  == '_struct'
# struct.calcsize.__name__  == 'calcsize'
# struct.calcsize.__module__ == '_struct'
#
# struct.pack, unpack, and calcsize are module-level C-extension functions.
# They are top-level functions, so __qualname__ equals __name__. All three
# are implemented in the _struct C extension, so __module__ is '_struct'.
# pack() packs values into bytes; unpack() unpacks bytes to a tuple;
# calcsize() returns the size in bytes for a format string.
# ---------------------------------------------------------------------------

table struct_extra227.struct_pack_identity:
  description: "struct.pack.__name__=='pack'; __qualname__=='pack'; __module__=='_struct'; pack function identity; new to extra227"
  kind: python_call_eq
  category: identity
  id_prefix: struct227

  columns: [id, function, args, expected, description]
  rows:
    - [pack_name_eq,
       "pack.__name__.__eq__",
       ["pack"],
       true,
       "struct.pack.__name__.__eq__('pack') == True — struct.pack packs values into bytes according to a format string; __name__ is 'pack' (4 characters); new anchor in extra227 namespace; verified Python 3.14.3"]
    - [pack_qualname_eq,
       "pack.__qualname__.__eq__",
       ["pack"],
       true,
       "struct.pack.__qualname__.__eq__('pack') == True — struct.pack is a top-level function so __qualname__ equals __name__; both are 'pack' (4 characters); new anchor in extra227 namespace; verified Python 3.14.3"]
    - [pack_module_eq,
       "pack.__module__.__eq__",
       ["_struct"],
       true,
       "struct.pack.__module__.__eq__('_struct') == True — struct.pack is implemented in the _struct C extension; __module__ is '_struct' not 'struct'; new anchor in extra227 namespace; verified Python 3.14.3"]
    - [pack_name_len_4,
       "pack.__name__.__len__",
       [],
       4,
       "struct.pack.__name__.__len__() == 4 — the string 'pack' has 4 characters; portable length anchor; new anchor in extra227 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.unpack and struct.calcsize function identity contracts
#
# struct.unpack.__name__     == 'unpack'
# struct.unpack.__qualname__ == 'unpack'
# struct.unpack.__module__   == '_struct'
# struct.calcsize.__name__   == 'calcsize'
# struct.calcsize.__qualname__ == 'calcsize'
# struct.calcsize.__module__ == '_struct'
#
# unpack() extracts values from a bytes object as a tuple;
# calcsize() computes the size in bytes a format string would use.
# ---------------------------------------------------------------------------

table struct_extra227.struct_unpack_calcsize_identity:
  description: "struct.unpack.__name__=='unpack'; __module__=='_struct'; struct.calcsize.__name__=='calcsize'; __module__=='_struct'; unpack and calcsize identity; new to extra227"
  kind: python_call_eq
  category: identity
  id_prefix: struct227a

  columns: [id, function, args, expected, description]
  rows:
    - [unpack_name_eq,
       "unpack.__name__.__eq__",
       ["unpack"],
       true,
       "struct.unpack.__name__.__eq__('unpack') == True — struct.unpack extracts values from bytes into a tuple; __name__ is 'unpack' (6 characters); new anchor in extra227 namespace; verified Python 3.14.3"]
    - [unpack_qualname_eq,
       "unpack.__qualname__.__eq__",
       ["unpack"],
       true,
       "struct.unpack.__qualname__.__eq__('unpack') == True — struct.unpack is a top-level function so __qualname__ equals __name__; both are 'unpack'; new anchor in extra227 namespace; verified Python 3.14.3"]
    - [unpack_module_eq,
       "unpack.__module__.__eq__",
       ["_struct"],
       true,
       "struct.unpack.__module__.__eq__('_struct') == True — struct.unpack is implemented in the _struct C extension; new anchor in extra227 namespace; verified Python 3.14.3"]
    - [calcsize_name_eq,
       "calcsize.__name__.__eq__",
       ["calcsize"],
       true,
       "struct.calcsize.__name__.__eq__('calcsize') == True — calcsize returns the size in bytes of a struct format string; __name__ is 'calcsize' (8 characters); new anchor in extra227 namespace; verified Python 3.14.3"]
    - [calcsize_qualname_eq,
       "calcsize.__qualname__.__eq__",
       ["calcsize"],
       true,
       "struct.calcsize.__qualname__.__eq__('calcsize') == True — struct.calcsize is a top-level function so __qualname__ equals __name__; both are 'calcsize' (8 characters); new anchor in extra227 namespace; verified Python 3.14.3"]
    - [calcsize_module_eq,
       "calcsize.__module__.__eq__",
       ["_struct"],
       true,
       "struct.calcsize.__module__.__eq__('_struct') == True — struct.calcsize is implemented in the _struct C extension; same module as pack and unpack; new anchor in extra227 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct module-level function name length contracts
#
# len('pack')        == 4
# len('unpack')      == 6
# len('calcsize')    == 8
# len('pack_into')   == 9
# len('iter_unpack') == 11
#
# Length anchors for module-level struct function names.
# ---------------------------------------------------------------------------

table struct_extra227.struct_module_fn_name_lengths:
  description: "pack len==4; unpack len==6; calcsize len==8; pack_into len==9; iter_unpack len==11; module-level function name length contracts; new to extra227"
  kind: python_call_eq
  category: identity
  id_prefix: struct227b

  columns: [id, function, args, expected, description]
  rows:
    - [pack_name_len_4,
       "pack.__name__.__len__",
       [],
       4,
       "struct.pack.__name__.__len__() == 4 — 'pack' has 4 characters; shortest module-level struct function name; portable length anchor; new anchor in extra227 namespace; verified Python 3.14.3"]
    - [unpack_name_len_6,
       "unpack.__name__.__len__",
       [],
       6,
       "struct.unpack.__name__.__len__() == 6 — 'unpack' has 6 characters; 2 more than 'pack'; portable length anchor; new anchor in extra227 namespace; verified Python 3.14.3"]
    - [calcsize_name_len_8,
       "calcsize.__name__.__len__",
       [],
       8,
       "struct.calcsize.__name__.__len__() == 8 — 'calcsize' has 8 characters; 2 more than 'unpack'; portable length anchor; new anchor in extra227 namespace; verified Python 3.14.3"]
    - [pack_into_name_len_9,
       "pack_into.__name__.__len__",
       [],
       9,
       "struct.pack_into.__name__.__len__() == 9 — 'pack_into' has 9 characters including the underscore; portable length anchor; new anchor in extra227 namespace; verified Python 3.14.3"]
    - [iter_unpack_name_len_11,
       "iter_unpack.__name__.__len__",
       [],
       11,
       "struct.iter_unpack.__name__.__len__() == 11 — 'iter_unpack' has 11 characters; longest of the listed module-level function names; portable length anchor; new anchor in extra227 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant struct_extra227.pack_module_eq:
  description: "struct.pack.__module__.__eq__('_struct') == True — struct.pack is the module-level function that packs Python values into a bytes object according to the format string argument; it is implemented as a C-extension function in _struct (Modules/_struct.c); the module-level functions (pack, unpack, calcsize, pack_into, unpack_from, iter_unpack) all have __module__=='_struct', distinguishing them from the struct.Struct class methods; extra227 is the first namespace to anchor struct.pack.__module__ as a standalone for the module-level function; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "pack.__module__.__eq__"
  args: ["_struct"]
  expected: true

invariant struct_extra227.calcsize_name_eq:
  description: "struct.calcsize.__name__.__eq__('calcsize') == True — calcsize returns the number of bytes required to pack or unpack the given format string; __name__ is 'calcsize' (8 characters); useful for pre-computing buffer sizes; it is a module-level C-extension function with __module__=='_struct'; __qualname__ also equals 'calcsize' since it is top-level; extra227 is the first namespace to anchor struct.calcsize.__name__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "calcsize.__name__.__eq__"
  args: ["calcsize"]
  expected: true

invariant struct_extra227.unpack_qualname_eq:
  description: "struct.unpack.__qualname__.__eq__('unpack') == True — struct.unpack is the module-level function that unpacks bytes into a tuple of values; as a top-level C-extension function its __qualname__ equals its __name__ ('unpack', 6 characters); this differs from struct.Struct.unpack whose __qualname__ is 'Struct.unpack' (13 characters) with the class prefix; the contrast between module-level and Struct-method qualnames is an important identity anchor; extra227 is the first namespace to anchor struct.unpack.__qualname__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "unpack.__qualname__.__eq__"
  args: ["unpack"]
  expected: true
