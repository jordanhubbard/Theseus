spec: logging_extra30
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
    - "logging_extra29.zspec.zsdl — covers __module__.__len__()==7 for getLogger/basicConfig/warning/error/info/debug/critical (functions) and FileHandler/StreamHandler (classes); __name__.__len__() and __qualname__.__len__() for FileHandler/StreamHandler; __name__.__len__() for warning/error/info/debug/critical."
    - "logging_extra28.zspec.zsdl — covers __module__.__len__()==7 for Logger/Handler/Formatter/Filter/LogRecord; __name__.__len__() for Logger/Handler/Formatter/Filter/LogRecord; getLogger/__qualname__.__len__; basicConfig/__qualname__.__len__."
    - "logging_extra27.zspec.zsdl — covers Logger/Handler/Formatter/Filter/LogRecord __init__.__name__, NOTSET/WARN/FATAL values, Logger/Handler/Formatter/Filter __module__ cross-namespace anchors."
    - "logging_extra26.zspec.zsdl — covers Logger/__qualname__/__module__/__bases__[0].__name__, RootLogger qualname/module/bases, level constants."
    - "logging_extra25.zspec.zsdl — covers Handler/Formatter __qualname__/__module__, StreamHandler/FileHandler __qualname__/__bases__[0].__name__, LogRecord.__module__."
    - "logging_extra24.zspec.zsdl — covers __qualname__ for StreamHandler.emit, FileHandler.emit, NullHandler.emit, Filter.filter, LogRecord, getLogger/basicConfig/makeLogRecord."
    - "logging_extra23.zspec.zsdl — covers __qualname__ for Logger.debug/info/warning/error/critical/exception, Handler.emit/handle, Formatter.format."
  notes:
    - "This spec extends logging_extra29.zspec.zsdl."
    - "Prior specs covered: Logger/Handler/Formatter/Filter/LogRecord/FileHandler/StreamHandler __name__/__module__/__qualname__/__bases__[0].__name__, level constants, getLogger/basicConfig/warning/error/info/debug/critical __name__/__module__/__qualname__, Logger/Handler/Formatter/Filter __init__.__name__, all class __module__.__len__()==7."
    - "This spec covers: __mro__.__len__() for Logger (3), Handler (3), Formatter (2), LogRecord (2); __bases__[0].__name__.__len__() for Logger ('Filterer', 8), Handler ('Filterer', 8), LogRecord ('object', 6), Formatter ('object', 6); LogRecord.getMessage.__qualname__.__len__()==20; LogRecord.__init__.__qualname__.__len__()==18; Formatter.format.__qualname__.__len__()==16; Logger.debug.__qualname__.__len__()==12; Logger.info.__qualname__.__len__()==11; Logger.warning.__qualname__.__len__()==14; Handler.emit.__qualname__.__len__()==12."
    - "logging.Logger.__mro__.__len__() == 3 — (Logger, Filterer, object). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Handler.__mro__.__len__() == 3 — (Handler, Filterer, object). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Formatter.__mro__.__len__() == 2 — (Formatter, object). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.LogRecord.__mro__.__len__() == 2 — (LogRecord, object). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Logger.__bases__[0].__name__ == 'Filterer' (len 8). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Handler.__bases__[0].__name__ == 'Filterer' (len 8). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.LogRecord.__bases__[0].__name__ == 'object' (len 6). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Formatter.__bases__[0].__name__ == 'object' (len 6). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.LogRecord.getMessage.__qualname__ == 'LogRecord.getMessage' (len 20). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.LogRecord.__init__.__qualname__ == 'LogRecord.__init__' (len 18). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Formatter.format.__qualname__ == 'Formatter.format' (len 16). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Logger.debug.__qualname__ == 'Logger.debug' (len 12). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Logger.info.__qualname__ == 'Logger.info' (len 11). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Logger.warning.__qualname__ == 'Logger.warning' (len 14). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Handler.emit.__qualname__ == 'Handler.emit' (len 12). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __mro__.__len__() for Logger, Handler, Formatter, LogRecord
#
# No prior spec checks __mro__.__len__() for any logging class.
# Logger and Handler both extend Filterer: depth 3 (Class, Filterer, object).
# Formatter and LogRecord directly extend only object: depth 2.
# ---------------------------------------------------------------------------

invariant logging_extra30.Logger.mro.len:
  description: "logging.Logger.__mro__.__len__() == 3 — (Logger, Filterer, object)"
  category: class_hierarchy
  kind: python_call_eq
  function: Logger.__mro__.__len__
  args: []
  expected: 3

invariant logging_extra30.Handler.mro.len:
  description: "logging.Handler.__mro__.__len__() == 3 — (Handler, Filterer, object)"
  category: class_hierarchy
  kind: python_call_eq
  function: Handler.__mro__.__len__
  args: []
  expected: 3

invariant logging_extra30.Formatter.mro.len:
  description: "logging.Formatter.__mro__.__len__() == 2 — (Formatter, object)"
  category: class_hierarchy
  kind: python_call_eq
  function: Formatter.__mro__.__len__
  args: []
  expected: 2

invariant logging_extra30.LogRecord.mro.len:
  description: "logging.LogRecord.__mro__.__len__() == 2 — (LogRecord, object)"
  category: class_hierarchy
  kind: python_call_eq
  function: LogRecord.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__len__() for Logger, Handler, Formatter, LogRecord
#
# logging_extra26 covers Logger.__bases__[0].__name__ as an equality check.
# No prior spec checks __bases__[0].__name__.__len__() for any logging class.
# Logger and Handler both have base 'Filterer' (len 8).
# Formatter and LogRecord both have base 'object' (len 6).
# ---------------------------------------------------------------------------

invariant logging_extra30.Logger.bases0.name.len:
  description: "logging.Logger.__bases__[0].__name__.__len__() == 8 — base is 'Filterer'"
  category: class_hierarchy
  kind: python_call_eq
  function: "Logger.__bases__[0].__name__.__len__"
  args: []
  expected: 8

invariant logging_extra30.Handler.bases0.name.len:
  description: "logging.Handler.__bases__[0].__name__.__len__() == 8 — base is 'Filterer'"
  category: class_hierarchy
  kind: python_call_eq
  function: "Handler.__bases__[0].__name__.__len__"
  args: []
  expected: 8

invariant logging_extra30.LogRecord.bases0.name.len:
  description: "logging.LogRecord.__bases__[0].__name__.__len__() == 6 — base is 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: "LogRecord.__bases__[0].__name__.__len__"
  args: []
  expected: 6

invariant logging_extra30.Formatter.bases0.name.len:
  description: "logging.Formatter.__bases__[0].__name__.__len__() == 6 — base is 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: "Formatter.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# LogRecord method __qualname__.__len__() — getMessage and __init__
#
# No prior spec covers __qualname__.__len__() for LogRecord methods.
# getMessage: 'LogRecord.getMessage' (len 20)
# __init__: 'LogRecord.__init__' (len 18)
# ---------------------------------------------------------------------------

invariant logging_extra30.LogRecord.getMessage.qualname.len:
  description: "logging.LogRecord.getMessage.__qualname__.__len__() == 20 — 'LogRecord.getMessage' has 20 characters"
  category: string_length
  kind: python_call_eq
  function: LogRecord.getMessage.__qualname__.__len__
  args: []
  expected: 20

invariant logging_extra30.LogRecord.__init__.qualname.len:
  description: "logging.LogRecord.__init__.__qualname__.__len__() == 18 — 'LogRecord.__init__' has 18 characters"
  category: string_length
  kind: python_call_eq
  function: LogRecord.__init__.__qualname__.__len__
  args: []
  expected: 18

# ---------------------------------------------------------------------------
# Table: __mro__.__len__() for Logger, Handler, Formatter, LogRecord
#
# Groups MRO depth checks for the four main logging classes. Logger and Handler
# share depth 3 (via Filterer); Formatter and LogRecord share depth 2.
# No prior spec groups these measurements together.
# ---------------------------------------------------------------------------

table logging_extra30.class_mro_depths:
  description: "logging class __mro__.__len__() — Logger (3), Handler (3), Formatter (2), LogRecord (2)"
  kind: python_call_eq
  category: class_hierarchy

  columns: [id, function, args, expected, description]
  rows:
    - [Logger_mro_len,
       Logger.__mro__.__len__,
       [],
       3,
       "len(Logger.__mro__) == 3"]
    - [Handler_mro_len,
       Handler.__mro__.__len__,
       [],
       3,
       "len(Handler.__mro__) == 3"]
    - [Formatter_mro_len,
       Formatter.__mro__.__len__,
       [],
       2,
       "len(Formatter.__mro__) == 2"]
    - [LogRecord_mro_len,
       LogRecord.__mro__.__len__,
       [],
       2,
       "len(LogRecord.__mro__) == 2"]

# ---------------------------------------------------------------------------
# Table: method __qualname__.__len__() for LogRecord, Formatter, Logger,
# Handler
#
# No prior spec covers __qualname__.__len__() for LogRecord/Formatter/Logger/
# Handler methods together. Groups these into a single verifiable table.
# LogRecord.getMessage=20, LogRecord.__init__=18, Formatter.format=16,
# Logger.debug=12, Logger.info=11, Logger.warning=14, Handler.emit=12.
# ---------------------------------------------------------------------------

table logging_extra30.method_qualname_lengths:
  description: "logging method __qualname__.__len__() — LogRecord.getMessage (20), LogRecord.__init__ (18), Formatter.format (16), Logger.debug (12), Logger.info (11), Logger.warning (14), Handler.emit (12)"
  kind: python_call_eq
  category: string_length

  columns: [id, function, args, expected, description]
  rows:
    - [LogRecord_getMessage_qualname_len,
       LogRecord.getMessage.__qualname__.__len__,
       [],
       20,
       "len('LogRecord.getMessage') == 20"]
    - [LogRecord_init_qualname_len,
       LogRecord.__init__.__qualname__.__len__,
       [],
       18,
       "len('LogRecord.__init__') == 18"]
    - [Formatter_format_qualname_len,
       Formatter.format.__qualname__.__len__,
       [],
       16,
       "len('Formatter.format') == 16"]
    - [Logger_debug_qualname_len,
       Logger.debug.__qualname__.__len__,
       [],
       12,
       "len('Logger.debug') == 12"]
    - [Logger_info_qualname_len,
       Logger.info.__qualname__.__len__,
       [],
       11,
       "len('Logger.info') == 11"]
    - [Logger_warning_qualname_len,
       Logger.warning.__qualname__.__len__,
       [],
       14,
       "len('Logger.warning') == 14"]
    - [Handler_emit_qualname_len,
       Handler.emit.__qualname__.__len__,
       [],
       12,
       "len('Handler.emit') == 12"]
