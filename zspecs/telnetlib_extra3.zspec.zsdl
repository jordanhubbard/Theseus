spec: telnetlib_extra3
version: ">=3.9,<3.13"
backend: python_module(telnetlib)

docs: https://docs.python.org/3.12/library/telnetlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/telnetlib.html — Python telnetlib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/telnetlib.py"
  notes:
    - "This spec extends telnetlib.zspec.zsdl and prior extras."
    - "telnetlib was deprecated in Python 3.11 (PEP 594) and removed in Python 3.13; this spec applies to >=3.9,<3.13."
    - "telnetlib.zspec.zsdl covers: Telnet.__name__, Telnet.__module__, TELNET_PORT==23, IAC/DO/DONT/WILL/WONT/SB/SE values, method names."
    - "telnetlib_extra.zspec.zsdl covers: Telnet.__name__/__module__, DEBUGLEVEL type/value, method names (read_all/write/open/close/read_until/read_very_eager/read_eager/read_lazy/read_some/interact)."
    - "telnetlib_extra2.zspec.zsdl covers: Telnet.__bases__[0]=='object', Telnet.__qualname__, TELNET_PORT type, IAC/WILL/WONT/DO/DONT type checks as 'bytes'."
    - "This spec adds: SB/SE type checks as 'bytes' (only IAC/WILL/WONT/DO/DONT were in extra2); Telnet.__class__.__name__=='type'; Telnet method qualnames table."
    - "SB and SE are bytes objects of length 1, as are all telnetlib protocol byte constants."
    - "Telnet.__class__.__name__ == 'type' — Telnet is a regular Python class (metaclass is type)."
    - "Telnet method __qualname__ values follow the pattern 'Telnet.method_name'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SB and SE type checks as 'bytes'
# telnetlib_extra2 covers IAC, WILL, WONT, DO, DONT as bytes.
# SB (subnegotiation begin) and SE (subnegotiation end) were not included there.
# ---------------------------------------------------------------------------

table telnetlib_extra3.subneg_byte_types:
  kind: python_call_eq
  category: constants
  id_prefix: subneg

  columns: [id, function, args, expected]
  rows:
    - [SB, SB.__class__.__name__.__eq__, ["bytes"], true]
    - [SE, SE.__class__.__name__.__eq__, ["bytes"], true]

# ---------------------------------------------------------------------------
# Telnet metaclass check — __class__.__name__ == 'type'
# Not covered in any prior telnetlib spec.
# ---------------------------------------------------------------------------

invariant telnetlib_extra3.Telnet.metaclass_is_type:
  description: "telnetlib.Telnet.__class__.__name__ == 'type' — Telnet is a regular Python class"
  category: class_types
  kind: python_call_eq
  function: Telnet.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# Telnet method qualnames
# For methods defined on a top-level class, __qualname__ == 'Telnet.method_name'.
# Not covered in any prior telnetlib spec.
# ---------------------------------------------------------------------------

table telnetlib_extra3.method_qualnames:
  kind: python_call_eq
  category: method_qualnames
  id_prefix: mqualname

  columns: [id, function, args, expected]
  rows:
    - [read_until,      Telnet.read_until.__qualname__.__eq__,      ["Telnet.read_until"],      true]
    - [write,           Telnet.write.__qualname__.__eq__,           ["Telnet.write"],           true]
    - [interact,        Telnet.interact.__qualname__.__eq__,        ["Telnet.interact"],        true]
    - [open,            Telnet.open.__qualname__.__eq__,            ["Telnet.open"],            true]
    - [close,           Telnet.close.__qualname__.__eq__,           ["Telnet.close"],           true]
    - [read_all,        Telnet.read_all.__qualname__.__eq__,        ["Telnet.read_all"],        true]
    - [read_some,       Telnet.read_some.__qualname__.__eq__,       ["Telnet.read_some"],       true]
    - [read_very_eager, Telnet.read_very_eager.__qualname__.__eq__, ["Telnet.read_very_eager"], true]
