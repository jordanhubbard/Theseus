spec: threading_extra631
version: ">=3.9"
backend: python_module(threading)
docs: "threading.Timer subclass identity and threading module-level function identity checks."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers threading.Timer __qualname__, __module__, __doc__ type, cancel/run qualnames, and module-level function identity"
  created_at: "2026-04-12T00:00:00Z"

table threading_extra631.timer_identity:
  description: "Identity checks for threading.Timer class and its methods"
  kind: python_call_eq
  category: threading_timer
  id_prefix: th631qn
  columns: [id, function, args, expected]
  rows:
    - [th631qn001, threading.Timer.__qualname__.__eq__, ["Timer"], true]
    - [th631qn002, threading.Timer.__module__.__eq__, ["threading"], true]
    - [th631qn003, threading.Timer.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [th631qn004, threading.Timer.cancel.__qualname__.__eq__, ["Timer.cancel"], true]
    - [th631qn005, threading.Timer.run.__qualname__.__eq__, ["Timer.run"], true]

table threading_extra631.module_functions_qualname:
  description: "__qualname__ checks for threading module-level functions"
  kind: python_call_eq
  category: threading_functions
  id_prefix: th631dc
  columns: [id, function, args, expected]
  rows:
    - [th631dc001, threading.current_thread.__qualname__.__eq__, ["current_thread"], true]
    - [th631dc002, threading.main_thread.__qualname__.__eq__, ["main_thread"], true]
    - [th631dc003, threading.active_count.__qualname__.__eq__, ["active_count"], true]
    - [th631dc004, threading.enumerate.__qualname__.__eq__, ["enumerate"], true]
    - [th631dc005, threading.settrace.__qualname__.__eq__, ["settrace"], true]
    - [th631dc006, threading.setprofile.__qualname__.__eq__, ["setprofile"], true]
    - [th631dc007, threading.stack_size.__qualname__.__eq__, ["stack_size"], true]

table threading_extra631.module_functions_module:
  description: "__module__ checks for threading module-level functions"
  kind: python_call_eq
  category: threading_functions
  id_prefix: th631md
  columns: [id, function, args, expected]
  rows:
    - [th631md001, threading.current_thread.__module__.__eq__, ["threading"], true]
    - [th631md002, threading.main_thread.__module__.__eq__, ["threading"], true]
