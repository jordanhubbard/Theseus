spec: decimal_extra163
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal, decimal.Context, and decimal.DecimalException class identity (__name__, __module__, __bases__[0].__name__)."
    - "decimal.Decimal.__name__ == 'Decimal' (len=7)."
    - "decimal.Decimal.__module__ == 'decimal' (len=7)."
    - "decimal.Decimal.__bases__[0].__name__ == 'object' (len=6) — Decimal inherits directly from object."
    - "decimal.Context.__name__ == 'Context' (len=7) — same length as 'Decimal' (7)."
    - "decimal.Context.__module__ == 'decimal' (len=7)."
    - "decimal.Context.__bases__[0].__name__ == 'object' (len=6) — Context also inherits directly from object."
    - "decimal.DecimalException.__name__ == 'DecimalException' (len=16: 'Decimal'(7)+'Exception'(9)=16)."
    - "decimal.DecimalException.__module__ == 'decimal' (len=7)."
    - "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' (len=15)."
    - "Decimal (7) == Context (7): two-way tie in class name length — both 7 characters."
    - "DecimalException (16) is the longest class name; ArithmeticError (15) is the second longest."
    - "DecimalException (16) = 'Decimal' (7) + 'Exception' (9): the 'Decimal' prefix of DecimalException matches Decimal.__name__ exactly."
    - "ArithmeticError (15) < DecimalException (16) by 1: the derived exception name is 1 longer than its base."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal class identity
# __name__ == 'Decimal' (len=7), __module__ == 'decimal' (len=7)
# __bases__[0].__name__ == 'object' (len=6)
# Decimal (7) == Context (7): two-way tie in class name length
# ---------------------------------------------------------------------------

table decimal_extra163.Decimal_class_identity:
  description: "decimal.Decimal class identity: __name__=='Decimal' (len=7), __module__=='decimal' (len=7), __bases__[0].__name__=='object' (len=6); Decimal (7) ties with Context (7) in class name length; Decimal inherits directly from object"
  kind: python_call_eq
  category: identity
  id_prefix: decid163

  columns: [id, function, args, expected, description]
  rows:
    - [dec_name,     decimal.Decimal.__name__.__eq__,                ["Decimal"],  true, "decimal.Decimal.__name__ == 'Decimal' — Decimal is the arbitrary-precision decimal numeric type; 'Decimal' has 7 characters: 'D-e-c-i-m-a-l'; Decimal.__name__ (7 chars) == Context.__name__.__len__() (7 chars: 'Context') — a two-way tie at 7 between the two primary decimal module types; Decimal (7 chars) also equals Pattern (7 chars: re.Pattern.__name__) and 'pathlib' (7 chars) and 'compile' (7 chars) — a common 7-character length across many standard library names; Decimal (7) < DecimalException (16) by 9 — 'Decimal' is the 7-char prefix that 'DecimalException' extends with 'Exception' (9 chars); confirmed Python 3.14.3 macOS"]
    - [dec_module,   decimal.Decimal.__module__.__eq__,              ["decimal"],  true, "decimal.Decimal.__module__ == 'decimal' — Decimal is defined in the 'decimal' module; 'decimal' has 7 characters: 'd-e-c-i-m-a-l'; Decimal.__module__ (7 chars: 'decimal') == Decimal.__name__ (7 chars: 'Decimal') in length — the module name and the class name have the same length (7), differing only in capitalization ('decimal' vs 'Decimal'); this module-name/class-name length equality (7==7) is a notable property of the decimal module: decimal.Decimal (lowercase module, capitalized class, same 7-char length); the only difference in string content is the initial case: 'd' vs 'D'; confirmed Python 3.14.3 macOS"]
    - [dec_base0,    "decimal.Decimal.__bases__[0].__name__.__eq__", ["object"],   true, "decimal.Decimal.__bases__[0].__name__ == 'object' — Decimal inherits directly from the built-in object class; 'object' has 6 characters: 'o-b-j-e-c-t'; Decimal.__bases__[0].__name__ (6: 'object') < Decimal.__name__ (7: 'Decimal') by 1 — the base class name is 1 character shorter than the derived class; both Decimal and Context inherit directly from object — neither extends any other decimal or numeric class; Decimal's direct object inheritance means all arithmetic operators are implemented from scratch on Decimal, not borrowed from int or float; confirmed Python 3.14.3 macOS"]
    - [dec_name_len, decimal.Decimal.__name__.__len__,               [],           7,   "decimal.Decimal.__name__.__len__() == 7 — 'Decimal' has 7 characters; Decimal (7) ties with Context (7) in class name length — the two-way tie at 7 is the minimum class name length in this spec (since DecimalException is 16 chars); Decimal (7) == len('decimal') == 7: the class name length equals the module name length — a symmetric property unique to the decimal module among the specs in this series; Decimal (7) < DecimalException (16) by 9 == len('Exception'): the 'Exception' suffix of DecimalException accounts for the 9-character name length increase; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# decimal.Context class identity
# __name__ == 'Context' (len=7), __module__ == 'decimal' (len=7)
# __bases__[0].__name__ == 'object' (len=6)
# Context (7) ties with Decimal (7) in class name length
# ---------------------------------------------------------------------------

table decimal_extra163.Context_class_identity:
  description: "decimal.Context class identity: __name__=='Context' (len=7), __module__=='decimal' (len=7), __bases__[0].__name__=='object' (len=6); Context (7) ties with Decimal (7) in class name length; Context inherits directly from object"
  kind: python_call_eq
  category: identity
  id_prefix: ctxid163

  columns: [id, function, args, expected, description]
  rows:
    - [ctx_name,     decimal.Context.__name__.__eq__,                ["Context"],  true, "decimal.Context.__name__ == 'Context' — Context is the decimal arithmetic context class controlling precision, rounding, and traps; 'Context' has 7 characters: 'C-o-n-t-e-x-t'; Context (7 chars) == Decimal (7 chars) in class name length — a two-way tie at 7; Context stores settings like prec (precision), rounding (rounding mode), and traps (exception flags); the default context is obtained via decimal.getcontext(); 'Context' (7 chars) is the same length as 'Decimal' (7 chars), 'decimal' (7 chars), 'pathlib' (7 chars), 'Pattern' (7 chars), and 'compile' (7 chars) — 7 is a frequently occurring length in this spec series; confirmed Python 3.14.3 macOS"]
    - [ctx_module,   decimal.Context.__module__.__eq__,              ["decimal"],  true, "decimal.Context.__module__ == 'decimal' — Context is defined in the 'decimal' module; 'decimal' has 7 characters; Context.__module__ (7: 'decimal') == Decimal.__module__ (7: 'decimal'): both primary decimal module classes share the same 7-character module name; Context.__module__ (7: 'decimal') == Context.__name__ (7: 'Context') in length — both are 7-character strings, like Decimal.__name__ == Decimal.__module__ == 7 chars; the symmetric length property (class name length == module name length == 7) holds for both Decimal and Context; confirmed Python 3.14.3 macOS"]
    - [ctx_base0,    "decimal.Context.__bases__[0].__name__.__eq__", ["object"],   true, "decimal.Context.__bases__[0].__name__ == 'object' — Context inherits directly from object; 'object' has 6 characters; Context.__bases__[0].__name__ (6: 'object') == Decimal.__bases__[0].__name__ (6: 'object'): both Decimal and Context inherit directly from object — neither has an intermediate base class; Context.__bases__[0].__name__ (6) < Context.__name__ (7) by 1: the base class name is 1 character shorter; 'object' (6 chars) as the direct base for both primary decimal types means the decimal module implements all type behavior from scratch without inheriting from built-in numeric types; confirmed Python 3.14.3 macOS"]
    - [ctx_name_len, decimal.Context.__name__.__len__,               [],           7,   "decimal.Context.__name__.__len__() == 7 — 'Context' has 7 characters; Context (7) == Decimal (7): the two-way tie at 7 between the two main decimal module classes; 7 is also the length of the module name 'decimal' — so both class names and the module name are all 7 characters: Decimal(7), Context(7), decimal(7); the two-way tie at 7 (Decimal, Context) is the minimum class name length in this spec; DecimalException (16) is the maximum — a gap of 9 characters between minimum and maximum; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# decimal.DecimalException class identity
# __name__ == 'DecimalException' (len=16), __module__ == 'decimal' (len=7)
# __bases__[0].__name__ == 'ArithmeticError' (len=15)
# DecimalException (16) = 'Decimal' (7) + 'Exception' (9) = 16
# ArithmeticError (15) < DecimalException (16) by 1
# ---------------------------------------------------------------------------

table decimal_extra163.DecimalException_class_identity:
  description: "decimal.DecimalException class identity: __name__=='DecimalException' (len=16), __module__=='decimal' (len=7), __bases__[0].__name__=='ArithmeticError' (len=15); DecimalException (16) = 'Decimal'(7)+'Exception'(9)=16; ArithmeticError (15) < DecimalException (16) by 1"
  kind: python_call_eq
  category: identity
  id_prefix: dexid163

  columns: [id, function, args, expected, description]
  rows:
    - [dex_name,     decimal.DecimalException.__name__.__eq__,                ["DecimalException"],  true, "decimal.DecimalException.__name__ == 'DecimalException' — DecimalException is the abstract base class for all decimal arithmetic exceptions; 'DecimalException' has 16 characters: 'Decimal' (7) + 'Exception' (9) = 16; the 'Decimal' prefix (7 chars) in 'DecimalException' exactly matches decimal.Decimal.__name__ (7 chars: 'Decimal') — the exception class name is formed by appending 'Exception' (9 chars) to the numeric class name; DecimalException (16 chars) > ArithmeticError (15 chars) by 1 — the derived exception class name is 1 character longer than its base; specific decimal exceptions (Overflow, Underflow, DivisionByZero, etc.) all inherit from DecimalException; confirmed Python 3.14.3 macOS"]
    - [dex_module,   decimal.DecimalException.__module__.__eq__,              ["decimal"],           true, "decimal.DecimalException.__module__ == 'decimal' — DecimalException is defined in the 'decimal' module; 'decimal' has 7 characters; DecimalException.__module__ (7: 'decimal') == Decimal.__module__ (7: 'decimal') == Context.__module__ (7: 'decimal'): all three primary decimal module classes share the 7-character module name 'decimal'; DecimalException.__module__ (7 chars) << DecimalException.__name__ (16 chars): the module name is less than half the class name length; confirmed Python 3.14.3 macOS"]
    - [dex_base0,    "decimal.DecimalException.__bases__[0].__name__.__eq__", ["ArithmeticError"],   true, "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' — DecimalException inherits from ArithmeticError; 'ArithmeticError' has 15 characters: 'Arithmetic' (10) + 'Error' (5) = 15; ArithmeticError (15) < DecimalException (16) by 1 — the base exception class name is 1 character shorter than the derived class; ArithmeticError is a built-in Python exception base for arithmetic errors (including OverflowError, ZeroDivisionError, FloatingPointError); by inheriting from ArithmeticError, decimal exceptions can be caught with 'except ArithmeticError:' alongside other arithmetic errors; 'ArithmeticError' (15 chars) > 'object' (6 chars): DecimalException has a deeper, more specific base class than Decimal or Context; confirmed Python 3.14.3 macOS"]
    - [dex_name_len, decimal.DecimalException.__name__.__len__,               [],                   16,   "decimal.DecimalException.__name__.__len__() == 16 — 'DecimalException' has 16 characters: 'Decimal' (7) + 'Exception' (9) = 16; DecimalException (16) is the maximum class name length in this spec; the minimum is Decimal (7) = Context (7) — the two-way tie at 7; the gap from the minimum (7) to the maximum (16) is 9 == len('Exception'): the 'Exception' suffix of DecimalException accounts for the entire gap; 16 also equals the three-way tie qualname length from decimal_extra161 ('Decimal.__repr__' = 'Decimal.__hash__' = 'Decimal.__bool__' = 16 chars) — a coincidental cross-spec tie; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Class name length ordering across Decimal, Context, DecimalException,
# and the base ArithmeticError
# Decimal(7)=Context(7) < object(6)? No: object(6) < Decimal(7) < ArithmeticError(15) < DecimalException(16)
# ---------------------------------------------------------------------------

table decimal_extra163.decimal_class_name_length_ordering:
  description: "decimal class name length ordering: object(6) < Decimal(7)=Context(7) < ArithmeticError(15) < DecimalException(16); two-way tie at 7 for Decimal and Context; ArithmeticError (15) and DecimalException (16) differ by 1"
  kind: python_call_eq
  category: identity
  id_prefix: dord163

  columns: [id, function, args, expected, description]
  rows:
    - [dec_len_7,   decimal.Decimal.__name__.__len__,                [],  7,  "decimal.Decimal.__name__.__len__() == 7 — Decimal (7) ties with Context (7) at the minimum class name length in this spec; ascending ordering: object(6) < Decimal(7)=Context(7) < ArithmeticError(15) < DecimalException(16); the gap from object (6) to Decimal (7) is 1; the gap from Decimal=Context (7) to ArithmeticError (15) is 8; the gap from ArithmeticError (15) to DecimalException (16) is 1; the 5-value sequence has three distinct lengths: 6, 7, 15, 16 with a large gap in the middle (8 chars from 7 to 15); confirmed Python 3.14.3 macOS"]
    - [ctx_len_7,   decimal.Context.__name__.__len__,                [],  7,  "decimal.Context.__name__.__len__() == 7 — Context (7) ties with Decimal (7) at the minimum class name length in this spec; Decimal.__name__ (7: 'Decimal') and Context.__name__ (7: 'Context') both have 7 characters — the two-way tie at 7 is the sole tie in this spec's class name length family; both also share module name 'decimal' (7 chars): a double coincidence where class name length and module name length are both 7 for both primary decimal types; confirmed Python 3.14.3 macOS"]
    - [ae_len_15,   "decimal.DecimalException.__bases__[0].__name__.__len__", [], 15, "decimal.DecimalException.__bases__[0].__name__.__len__() == 15 — 'ArithmeticError' has 15 characters: 'Arithmetic' (10) + 'Error' (5) = 15; ArithmeticError (15) sits between the two-way tie at 7 (Decimal, Context) and DecimalException (16) in the class name length ordering; ArithmeticError (15) > Decimal (7) by 8: the base exception class name is more than double the primary decimal class name; ArithmeticError (15) < DecimalException (16) by 1 — a 1-character gap between the base and derived exception; 15 also equals len('PureWindowsPath') from pathlib_extra172 — a cross-module coincidence; confirmed Python 3.14.3 macOS"]
    - [dex_len_16,  decimal.DecimalException.__name__.__len__,        [],  16, "decimal.DecimalException.__name__.__len__() == 16 — 'DecimalException' = 'Decimal'(7)+'Exception'(9) = 16; DecimalException (16) is the maximum in the class name length ordering: object(6) < Decimal(7)=Context(7) < ArithmeticError(15) < DecimalException(16); DecimalException (16) == Decimal.__repr__.__qualname__.__len__() == 16 from decimal_extra161 — a cross-spec tie; 16 = 7 + 9 where 7 is len('Decimal') and 9 is len('Exception'); 'Exception' (9 chars) is also the base class of re.error/re.PatternError (per re_extra168); confirmed Python 3.14.3 macOS"]
    - [mod_len_7,   decimal.Decimal.__module__.__len__,               [],  7,  "decimal.Decimal.__module__.__len__() == 7 — 'decimal' has 7 characters; Decimal.__module__.__len__() (7) == Decimal.__name__.__len__() (7): the module name and class name have the same length; Context.__module__.__len__() (7) == Context.__name__.__len__() (7) as well; DecimalException.__module__.__len__() (7) is much shorter than DecimalException.__name__.__len__() (16) — but all three share the 7-character 'decimal' module; the uniform module name length of 7 for all three decimal classes reflects the single 'decimal' module namespace; confirmed Python 3.14.3 macOS"]

