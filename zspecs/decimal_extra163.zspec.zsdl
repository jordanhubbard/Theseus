invariant decimal_extra163.Decimal_name_is_Decimal:
  description: "decimal.Decimal.__name__ == 'Decimal' — Decimal is the arbitrary-precision decimal numeric type; 'Decimal' has 7 characters; Decimal (7) ties with Context (7) in class name length — the two-way tie at 7 is the minimum in this spec; decimal.Decimal.__module__ == 'decimal' (also 7 chars): class name length equals module name length — both are 7; Decimal inherits from object (6 chars): the base name is 1 character shorter; Decimal (7) < DecimalException (16) by 9 == len('Exception'): the exception class adds 'Exception' to 'Decimal'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__name__.__eq__
  args: ["Decimal"]
  expected: true

invariant decimal_extra163.Decimal_module_is_decimal:
  description: "decimal.Decimal.__module__ == 'decimal' — Decimal is defined in the 'decimal' module; 'decimal' has 7 characters; decimal.Decimal.__module__ (7: 'decimal') and decimal.Decimal.__name__ (7: 'Decimal') have the same length — differing only in the initial 'd' vs 'D'; this class-name/module-name length equality (both 7 chars) is symmetric and holds for both Decimal and Context; all three primary decimal classes (Decimal, Context, DecimalException) share __module__ == 'decimal' (7 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra163.Decimal_base_is_object:
  description: "decimal.Decimal.__bases__[0].__name__ == 'object' — Decimal inherits directly from object (6 chars); Decimal.__bases__[0].__name__ (6: 'object') == Context.__bases__[0].__name__ (6: 'object'): both primary decimal types inherit directly from object; 'object' (6 chars) < 'Decimal' (7 chars) by 1; Decimal's direct object inheritance means all decimal arithmetic operations are implemented from scratch — Decimal does not inherit from int, float, or any other numeric type; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "decimal.Decimal.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant decimal_extra163.Context_name_is_Context:
  description: "decimal.Context.__name__ == 'Context' — Context is the decimal arithmetic context controlling precision, rounding mode, and exception traps; 'Context' has 7 characters; Context (7) == Decimal (7) in class name length: the two primary decimal module classes form a two-way tie at 7; Context.__module__ == 'decimal' (also 7 chars): the module name, Decimal class name, and Context class name all have length 7; Context.__bases__[0].__name__ == 'object' (6 chars): Context inherits directly from object just like Decimal; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Context.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra163.Context_base_is_object:
  description: "decimal.Context.__bases__[0].__name__ == 'object' — Context inherits directly from object; 'object' has 6 characters; Context.__bases__[0].__name__ (6: 'object') == Decimal.__bases__[0].__name__ (6: 'object'): both Decimal and Context share 'object' as their immediate base — a parallel inheritance structure at the root; 'object' (6 chars) < 'Context' (7 chars) by 1 — the base is 1 character shorter than the derived class; context objects hold a prec (precision) and rounding (mode string) among other settings; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "decimal.Context.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant decimal_extra163.DecimalException_name_is_DecimalException:
  description: "decimal.DecimalException.__name__ == 'DecimalException' — DecimalException is the base class for all decimal arithmetic exceptions; 'DecimalException' has 16 characters: 'Decimal' (7) + 'Exception' (9) = 16; the 'Decimal' prefix (7 chars) matches decimal.Decimal.__name__ exactly; DecimalException (16) is the longest class name in this spec — the maximum; DecimalException (16) > ArithmeticError (15) by 1: derived exception name is 1 longer than its base; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.DecimalException.__name__.__eq__
  args: ["DecimalException"]
  expected: true

invariant decimal_extra163.DecimalException_base_is_ArithmeticError:
  description: "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' — DecimalException inherits from ArithmeticError (15 chars); 'ArithmeticError' has 15 characters: 'Arithmetic' (10) + 'Error' (5) = 15; ArithmeticError (15) < DecimalException (16) by 1 — the base class name is 1 character shorter than the derived class; ArithmeticError is a built-in exception in the 'builtins' module (decimal.DecimalException.__bases__[0].__module__ == 'builtins'); inheriting from ArithmeticError means decimal exceptions can be caught by 'except ArithmeticError:' handlers alongside OverflowError and ZeroDivisionError; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "decimal.DecimalException.__bases__[0].__name__.__eq__"
  args: ["ArithmeticError"]
  expected: true

invariant decimal_extra163.DecimalException_module_is_decimal:
  description: "decimal.DecimalException.__module__ == 'decimal' — DecimalException is defined in the 'decimal' module; 'decimal' has 7 characters; DecimalException.__module__ (7: 'decimal') is the same as Decimal.__module__ (7) and Context.__module__ (7) — all three decimal module classes share the 7-character module name; 'decimal' (7 chars) << 'DecimalException' (16 chars): the module name is less than half the class name length for DecimalException; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
