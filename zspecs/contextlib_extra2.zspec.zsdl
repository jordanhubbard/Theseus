spec: contextlib_extra2
version: ">=3.10"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "Python contextlib documentation — https://docs.python.org/3/library/contextlib.html"
    - "PEP 343 — The 'with' Statement"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
  notes:
    - "Complements contextlib.zspec.zsdl, contextlib_extra.zspec.zsdl, and contextlib_suppress.zspec.zsdl."
    - "contextlib.zspec.zsdl covers __name__ for: contextmanager, suppress, ExitStack, closing, redirect_stdout, redirect_stderr, nullcontext, AsyncExitStack, AbstractContextManager, asynccontextmanager."
    - "contextlib_suppress.zspec.zsdl covers AbstractAsyncContextManager.__name__ and __module__ for suppress/ExitStack/AsyncExitStack/redirect_*/AbstractContextManager/AbstractAsyncContextManager."
    - "contextlib_extra.zspec.zsdl covers __module__ for contextmanager/asynccontextmanager/closing/nullcontext; aclosing; is_function/is_type checks."
    - "This spec provides a consolidated __name__ table for all 10 named symbols in the task specification."
    - "contextmanager.__name__ == 'contextmanager'."
    - "asynccontextmanager.__name__ == 'asynccontextmanager'."
    - "closing.__name__ == 'closing'."
    - "nullcontext.__name__ == 'nullcontext'."
    - "ExitStack.__name__ == 'ExitStack'."
    - "AsyncExitStack.__name__ == 'AsyncExitStack'."
    - "AbstractContextManager.__name__ == 'AbstractContextManager'."
    - "AbstractAsyncContextManager.__name__ == 'AbstractAsyncContextManager'."
    - "redirect_stdout.__name__ == 'redirect_stdout'."
    - "redirect_stderr.__name__ == 'redirect_stderr'."
    - "ExitStack, AsyncExitStack, AbstractContextManager, AbstractAsyncContextManager, redirect_stdout, redirect_stderr are ABCMeta instances (classes with ABCMeta as metaclass)."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ checks for all 10 contextlib symbols in this spec
# ---------------------------------------------------------------------------

table contextlib_extra2.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: classname

  columns: [id, function, args, expected]
  rows:
    - [contextmanager,              contextmanager.__name__.__eq__,              ["contextmanager"],              true]
    - [asynccontextmanager,         asynccontextmanager.__name__.__eq__,         ["asynccontextmanager"],         true]
    - [closing,                     closing.__name__.__eq__,                     ["closing"],                     true]
    - [nullcontext,                 nullcontext.__name__.__eq__,                 ["nullcontext"],                 true]
    - [ExitStack,                   ExitStack.__name__.__eq__,                   ["ExitStack"],                   true]
    - [AsyncExitStack,              AsyncExitStack.__name__.__eq__,              ["AsyncExitStack"],              true]
    - [AbstractContextManager,      AbstractContextManager.__name__.__eq__,      ["AbstractContextManager"],      true]
    - [AbstractAsyncContextManager, AbstractAsyncContextManager.__name__.__eq__, ["AbstractAsyncContextManager"], true]
    - [redirect_stdout,             redirect_stdout.__name__.__eq__,             ["redirect_stdout"],             true]
    - [redirect_stderr,             redirect_stderr.__name__.__eq__,             ["redirect_stderr"],             true]

# ---------------------------------------------------------------------------
# Metaclass checks — ABCMeta-based classes have __class__.__name__ == 'ABCMeta'
# ---------------------------------------------------------------------------

table contextlib_extra2.metaclass_checks:
  kind: python_call_eq
  category: metaclass
  id_prefix: metaclass

  columns: [id, function, args, expected]
  rows:
    - [ExitStack,                   ExitStack.__class__.__name__.__eq__,                   ["ABCMeta"], true]
    - [AsyncExitStack,              AsyncExitStack.__class__.__name__.__eq__,              ["ABCMeta"], true]
    - [AbstractContextManager,      AbstractContextManager.__class__.__name__.__eq__,      ["ABCMeta"], true]
    - [AbstractAsyncContextManager, AbstractAsyncContextManager.__class__.__name__.__eq__, ["ABCMeta"], true]
    - [redirect_stdout,             redirect_stdout.__class__.__name__.__eq__,             ["ABCMeta"], true]
    - [redirect_stderr,             redirect_stderr.__class__.__name__.__eq__,             ["ABCMeta"], true]
