spec: itertools_extra1036
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __sizeof__.__qualname__ for itertools iterator types; pairwise requires Python 3.10+"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table itertools_extra1036.accumulate_compress_qualnames:
  description: "itertools.accumulate and itertools.compress __sizeof__.__qualname__ checks"
  kind: python_call_eq
  category: sizeof_qualnames
  id_prefix: it1036ac
  columns: [id, function, args, expected]
  rows:
    - [it1036ac001, itertools.accumulate.__sizeof__.__qualname__.__eq__,  ["accumulate.__sizeof__"],  true]
    - [it1036ac002, itertools.compress.__sizeof__.__qualname__.__eq__,    ["compress.__sizeof__"],    true]
    - [it1036ac003, itertools.dropwhile.__sizeof__.__qualname__.__eq__,   ["dropwhile.__sizeof__"],   true]
    - [it1036ac004, itertools.filterfalse.__sizeof__.__qualname__.__eq__, ["filterfalse.__sizeof__"], true]
    - [it1036ac005, itertools.starmap.__sizeof__.__qualname__.__eq__,     ["starmap.__sizeof__"],     true]

table itertools_extra1036.takewhile_groupby_qualnames:
  description: "itertools.takewhile, groupby, islice, and zip_longest __sizeof__.__qualname__ checks"
  kind: python_call_eq
  category: sizeof_qualnames
  id_prefix: it1036tg
  columns: [id, function, args, expected]
  rows:
    - [it1036tg001, itertools.takewhile.__sizeof__.__qualname__.__eq__,   ["takewhile.__sizeof__"],   true]
    - [it1036tg002, itertools.zip_longest.__sizeof__.__qualname__.__eq__, ["zip_longest.__sizeof__"], true]
    - [it1036tg003, itertools.groupby.__sizeof__.__qualname__.__eq__,     ["groupby.__sizeof__"],     true]
    - [it1036tg004, itertools.islice.__sizeof__.__qualname__.__eq__,      ["islice.__sizeof__"],      true]
    - [it1036tg005, itertools.chain.__sizeof__.__qualname__.__eq__,       ["chain.__sizeof__"],       true]

table itertools_extra1036.pairwise_and_module_attrs:
  description: "itertools.pairwise __sizeof__.__qualname__ (3.10+) and module-level attribute checks"
  kind: python_call_eq
  category: sizeof_qualnames_and_module
  id_prefix: it1036pm
  columns: [id, function, args, expected]
  rows:
    - [it1036pm001, itertools.pairwise.__sizeof__.__qualname__.__eq__,    ["pairwise.__sizeof__"],    true]
    - [it1036pm002, itertools.cycle.__sizeof__.__qualname__.__eq__,       ["cycle.__sizeof__"],       true]
    - [it1036pm003, itertools.count.__sizeof__.__qualname__.__eq__,       ["count.__sizeof__"],       true]
    - [it1036pm004, itertools.__name__.__eq__,                            ["itertools"],              true]
    - [it1036pm005, itertools.__doc__.__class__.__name__.__eq__,          ["str"],                    true]
    - [it1036pm006, itertools.repeat.__sizeof__.__qualname__.__eq__,      ["repeat.__sizeof__"],      true]
