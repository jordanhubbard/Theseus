spec: re_extra2011
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2011 (_extra2011): __add__/__radd__/__iadd__, __mul__/__rmul__/__imul__, __sub__/__rsub__/__isub__ dict-presence checks."
    - "re.Pattern and re.Match are C extension types for compiled regex and match objects — no arithmetic operators."
    - "re.error (aliased as re.PatternError in Python 3.13+) is an Exception subclass — inherits from BaseException, not a numeric type."
    - "re.RegexFlag is an IntFlag enum; while IntFlag provides bitwise ops (__or__, __and__, etc.), it does NOT define __add__, __mul__, or __sub__ in its own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table re_extra2011.add_protocol:
  description: "re module types __add__/__radd__/__iadd__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2011

  columns: [id, function, args, expected]
  rows:
    - ["re2011001", "re.Pattern.__dict__.__contains__",   ["__add__"],  false]
    - ["re2011002", "re.Pattern.__dict__.__contains__",   ["__radd__"], false]
    - ["re2011003", "re.Pattern.__dict__.__contains__",   ["__iadd__"], false]
    - ["re2011004", "re.Match.__dict__.__contains__",     ["__add__"],  false]
    - ["re2011005", "re.Match.__dict__.__contains__",     ["__radd__"], false]
    - ["re2011006", "re.Match.__dict__.__contains__",     ["__iadd__"], false]
    - ["re2011007", "re.error.__dict__.__contains__",     ["__add__"],  false]
    - ["re2011008", "re.error.__dict__.__contains__",     ["__radd__"], false]
    - ["re2011009", "re.error.__dict__.__contains__",     ["__iadd__"], false]
    - ["re2011010", "re.RegexFlag.__dict__.__contains__", ["__add__"],  false]
    - ["re2011011", "re.RegexFlag.__dict__.__contains__", ["__radd__"], false]
    - ["re2011012", "re.RegexFlag.__dict__.__contains__", ["__iadd__"], false]

