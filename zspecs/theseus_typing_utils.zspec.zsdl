spec: theseus_typing_utils
version: ">=3.9"
backend: python_cleanroom(theseus_typing_utils)
blocks: typing

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html"
  notes:
    - "Clean-room typing utilities for runtime type checking. Do NOT import typing."
    - "get_type_hints equivalent: introspect __annotations__."
    - "is_optional(tp): returns True if tp is Optional[X] (i.e., Union[X, None])."
    - "NamedTuple-like: typed_namedtuple(name, fields) creates a class with named fields."
    - "typing_is_list_instance(): isinstance([1,2], list) == True."
    - "typing_namedtuple_fields(): Point = typed_namedtuple('Point', ['x','y']); p.x works."
    - "typing_get_annotations(): class with annotations returns annotation dict."
    - "Export: typed_namedtuple(name, fields), get_annotations(cls)."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_typing_utils.namedtuple_access:
  description: "typed_namedtuple Point; Point(1,2).x == 1"
  category: namedtuple
  kind: python_call_eq
  function: typing_namedtuple_x
  args: []
  expected: 1

invariant theseus_typing_utils.namedtuple_fields:
  description: "Point._fields == ('x', 'y')"
  category: namedtuple
  kind: python_call_eq
  function: typing_namedtuple_fields
  args: []
  expected: ["x", "y"]

invariant theseus_typing_utils.get_annotations:
  description: "get_annotations returns dict of field names"
  category: annotations
  kind: python_call_eq
  function: typing_get_annotations
  args: []
  expected: true
