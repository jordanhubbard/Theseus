spec: os_extra36
version: ">=3.9"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
    - "os_extra35.zspec.zsdl — covers __module__.__len__() for getcwd/listdir/mkdir/remove/rename/stat/getpid (all 5, 'posix') and makedirs (2, 'os'); __name__.__len__() for getcwd/listdir/mkdir/makedirs."
  notes:
    - "This spec extends os_extra35.zspec.zsdl."
    - "Prior specs covered: __module__.__len__() for getcwd/listdir/mkdir/remove/rename/stat/getpid ('posix', len 5) and makedirs ('os', len 2); __name__.__len__() for getcwd/listdir/mkdir/makedirs; __qualname__/__module__/__name__ values for various os functions; environ/__class__.__name__, sep/linesep/curdir string attributes."
    - "This spec covers: __module__.__len__() and __name__.__len__() for scandir/walk/urandom; os.environ.__class__.__name__.__len__()==8 ('_Environ'); __class__.__name__ for os.sep/os.linesep/os.curdir (all 'str')."
    - "QUIRK: os.walk is a pure-Python generator in os.py so __module__=='os' (len 2). os.scandir and os.urandom are C-level posix wrappers so __module__=='posix' (len 5)."
    - "os.scandir.__module__=='posix' (len 5). Verified."
    - "os.walk.__module__=='os' (len 2). Verified."
    - "os.urandom.__module__=='posix' (len 5). Verified."
    - "os.scandir.__name__=='scandir' (len 7). Verified."
    - "os.walk.__name__=='walk' (len 4). Verified."
    - "os.urandom.__name__=='urandom' (len 7). Verified."
    - "os.environ.__class__.__name__=='_Environ' (len 8). Verified."
    - "os.sep/__class__.__name__=='str'. Verified."
    - "os.linesep/__class__.__name__=='str'. Verified."
    - "os.curdir/__class__.__name__=='str'. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __module__.__len__() for scandir/walk/urandom
#
# os_extra35 covers getcwd/listdir/mkdir/remove/rename/stat/getpid/__module__.__len__().
# No prior os spec checks __module__.__len__() for scandir, walk, or urandom.
# QUIRK: walk is pure-Python (os.py) so __module__=='os' (len 2); scandir and
# urandom are C-level posix wrappers so __module__=='posix' (len 5).
# Verified: scandir=5, walk=2, urandom=5.
# ---------------------------------------------------------------------------

table os_extra36.extra_function_module_lengths:
  description: "__module__.__len__() for scandir/walk/urandom — walk is 'os' (len 2), scandir/urandom are 'posix' (len 5)"
  kind: python_call_eq
  category: function_attrs
  id_prefix: extmodlen36

  columns: [id, function, args, expected]
  rows:
    - [scandir, scandir.__module__.__len__, [], 5]
    - [walk,    walk.__module__.__len__,    [], 2]
    - [urandom, urandom.__module__.__len__, [], 5]

# ---------------------------------------------------------------------------
# Table: __name__.__len__() for scandir/walk/urandom
#
# os_extra35 covers __name__.__len__() for getcwd/listdir/mkdir/makedirs.
# No prior os spec checks __len__() on __name__ for scandir, walk, or urandom.
# Lengths: scandir=7, walk=4, urandom=7.
# Verified: scandir=7, walk=4, urandom=7.
# ---------------------------------------------------------------------------

table os_extra36.extra_function_name_lengths:
  description: "__name__.__len__() for scandir/walk/urandom — lengths 7/4/7 respectively"
  kind: python_call_eq
  category: function_attrs
  id_prefix: extnlen36

  columns: [id, function, args, expected]
  rows:
    - [scandir, scandir.__name__.__len__, [], 7]
    - [walk,    walk.__name__.__len__,    [], 4]
    - [urandom, urandom.__name__.__len__, [], 7]

# ---------------------------------------------------------------------------
# Standalone: os.environ.__class__.__name__.__len__() == 8
#
# os.environ.__class__.__name__ == '_Environ'. len('_Environ') == 8.
# Prior os specs confirm __class__.__name__ == '_Environ' but no spec checks
# __len__() on that string.
# Verified: 8.
# ---------------------------------------------------------------------------

invariant os_extra36.environ.class_name_len:
  description: "os.environ.__class__.__name__.__len__() == 8 — '_Environ' has 8 characters"
  category: type_attrs
  kind: python_call_eq
  function: environ.__class__.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# Standalone: os.sep.__class__.__name__.__eq__('str') == True
#
# os.sep is a str on all platforms. No prior os spec checks
# __class__.__name__.__eq__() on sep.
# Verified: True.
# ---------------------------------------------------------------------------

invariant os_extra36.sep.class_name_eq:
  description: "os.sep.__class__.__name__.__eq__('str') == True — sep is a str object"
  category: type_attrs
  kind: python_call_eq
  function: sep.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: os.linesep.__class__.__name__.__eq__('str') == True
#
# os.linesep is a str on all platforms. No prior os spec checks
# __class__.__name__.__eq__() on linesep.
# Verified: True.
# ---------------------------------------------------------------------------

invariant os_extra36.linesep.class_name_eq:
  description: "os.linesep.__class__.__name__.__eq__('str') == True — linesep is a str object"
  category: type_attrs
  kind: python_call_eq
  function: linesep.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: os.curdir.__class__.__name__.__eq__('str') == True
#
# os.curdir is a str on all platforms. No prior os spec checks
# __class__.__name__.__eq__() on curdir.
# Verified: True.
# ---------------------------------------------------------------------------

invariant os_extra36.curdir.class_name_eq:
  description: "os.curdir.__class__.__name__.__eq__('str') == True — curdir is a str object"
  category: type_attrs
  kind: python_call_eq
  function: curdir.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: os.walk.__module__.__len__() == 2 (pure-Python quirk)
#
# os_extra35 documents that makedirs.__module__.__len__()==2 because makedirs
# is defined in os.py. os.walk is also defined in os.py so its __module__=='os'
# (len 2). This standalone invariant emphasizes the walk quirk in isolation,
# distinct from the scandir/urandom posix wrappers (len 5).
# Verified: 2.
# ---------------------------------------------------------------------------

invariant os_extra36.walk.module_len:
  description: "os.walk.__module__.__len__() == 2 — 'os' has 2 characters (pure-Python generator, not a posix C wrapper)"
  category: function_attrs
  kind: python_call_eq
  function: walk.__module__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# Standalone: os.environ.__class__.__name__.__eq__('_Environ') == True
#
# Confirms the exact class name via string equality. No prior os spec checks
# __class__.__name__.__eq__() on environ.
# Verified: True.
# ---------------------------------------------------------------------------

invariant os_extra36.environ.class_name_eq:
  description: "os.environ.__class__.__name__.__eq__('_Environ') == True — environ class is exactly '_Environ'"
  category: type_attrs
  kind: python_call_eq
  function: environ.__class__.__name__.__eq__
  args: ["_Environ"]
  expected: true
