spec: concurrent_futures_extra212
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec covers concurrent.futures exception class identity and Future exception-raising behavior."
    - "concurrent.futures.CancelledError.__module__ == 'concurrent.futures._base'; base == Error (cf._base.Error)."
    - "concurrent.futures.TimeoutError is builtins.TimeoutError — __module__ == 'builtins'; base == OSError."
    - "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base'; base == RuntimeError."
    - "concurrent.futures.InvalidStateError.__module__ == 'concurrent.futures._base'; base == Error (cf._base.Error)."
    - "The internal Error base class inherits from Exception."
    - "Future.result() on a cancelled future raises CancelledError."
    - "Future.result(timeout=0) on an unfinished future raises TimeoutError."
    - "Future.set_result() called twice raises InvalidStateError — future is already in FINISHED state."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures exception class __name__ string equality — extra212
#
# CancelledError, BrokenExecutor, and InvalidStateError are defined in
# concurrent.futures._base. TimeoutError is the built-in TimeoutError
# re-exported from builtins.
# ---------------------------------------------------------------------------

table concurrent_futures_extra212.exception_names:
  description: "concurrent.futures exception class __name__ string equality in extra212 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cfexcname212

  columns: [id, function, args, expected, description]
  rows:
    - [CancelledError_name,  CancelledError.__name__.__eq__,  ["CancelledError"],  true, "concurrent.futures.CancelledError.__name__ == 'CancelledError'"]
    - [TimeoutError_name,    TimeoutError.__name__.__eq__,    ["TimeoutError"],    true, "concurrent.futures.TimeoutError.__name__ == 'TimeoutError' — alias for builtins.TimeoutError"]
    - [BrokenExecutor_name,  BrokenExecutor.__name__.__eq__,  ["BrokenExecutor"],  true, "concurrent.futures.BrokenExecutor.__name__ == 'BrokenExecutor'"]
    - [InvalidStateError_name, InvalidStateError.__name__.__eq__, ["InvalidStateError"], true, "concurrent.futures.InvalidStateError.__name__ == 'InvalidStateError'"]

# ---------------------------------------------------------------------------
# concurrent.futures exception class __module__ string equality — extra212
#
# CancelledError, BrokenExecutor, and InvalidStateError live in the private
# _base submodule. TimeoutError is the built-in exception — module 'builtins'.
# ---------------------------------------------------------------------------

table concurrent_futures_extra212.exception_modules:
  description: "concurrent.futures exception class __module__ string equality in extra212 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cfexcmod212

  columns: [id, function, args, expected, description]
  rows:
    - [CancelledError_module,    CancelledError.__module__.__eq__,    ["concurrent.futures._base"], true, "concurrent.futures.CancelledError.__module__ == 'concurrent.futures._base'"]
    - [TimeoutError_module,      TimeoutError.__module__.__eq__,      ["builtins"],                 true, "concurrent.futures.TimeoutError.__module__ == 'builtins' — is the built-in TimeoutError"]
    - [BrokenExecutor_module,    BrokenExecutor.__module__.__eq__,    ["concurrent.futures._base"], true, "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base'"]
    - [InvalidStateError_module, InvalidStateError.__module__.__eq__, ["concurrent.futures._base"], true, "concurrent.futures.InvalidStateError.__module__ == 'concurrent.futures._base'"]

# ---------------------------------------------------------------------------
# concurrent.futures exception class base class __name__ — extra212 namespace
#
# CancelledError and InvalidStateError both inherit from the internal Error
# base class (concurrent.futures._base.Error), which itself inherits from
# Exception. BrokenExecutor inherits from RuntimeError. TimeoutError inherits
# from OSError (built-in hierarchy).
# ---------------------------------------------------------------------------

table concurrent_futures_extra212.exception_bases:
  description: "concurrent.futures exception class __bases__[0].__name__ string equality in extra212 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cfexcbase212

  columns: [id, function, args, expected, description]
  rows:
    - [CancelledError_base,    "CancelledError.__bases__[0].__name__.__eq__",    ["Error"],       true, "concurrent.futures.CancelledError inherits from concurrent.futures._base.Error"]
    - [TimeoutError_base,      "TimeoutError.__bases__[0].__name__.__eq__",      ["OSError"],     true, "concurrent.futures.TimeoutError inherits from OSError (built-in hierarchy)"]
    - [BrokenExecutor_base,    "BrokenExecutor.__bases__[0].__name__.__eq__",    ["RuntimeError"], true, "concurrent.futures.BrokenExecutor inherits from RuntimeError"]
    - [InvalidStateError_base, "InvalidStateError.__bases__[0].__name__.__eq__", ["Error"],       true, "concurrent.futures.InvalidStateError inherits from concurrent.futures._base.Error"]

# ---------------------------------------------------------------------------
# Future.result() on cancelled future raises CancelledError — extra212
#
# A Future that has been cancelled (future.cancel() called before it is
# resolved) raises CancelledError when .result() is called. This is the
# primary exception path for cancelled work items.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra212.Future_result_cancelled_raises:
  description: "concurrent.futures.Future().result() raises CancelledError after cancel() — accessing result of a cancelled future"
  category: errors
  kind: python_call_raises
  function: Future
  args: []
  expected: CancelledError

# ---------------------------------------------------------------------------
# Future.result(timeout=0) on unfinished future raises TimeoutError — extra212
#
# A Future that has not yet completed raises TimeoutError when .result() is
# called with timeout=0. The timeout expires immediately since no result is
# available.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra212.Future_result_timeout_raises:
  description: "concurrent.futures.Future().result(timeout=0) raises TimeoutError — timeout expires before result is available"
  category: errors
  kind: python_call_raises
  function: Future
  args: []
  expected: TimeoutError

# ---------------------------------------------------------------------------
# Future.set_result() twice raises InvalidStateError — extra212
#
# Calling set_result() on a Future that is already in the FINISHED state
# raises InvalidStateError. A Future can only be resolved once.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra212.Future_set_result_twice_raises:
  description: "concurrent.futures.Future.set_result() called twice raises InvalidStateError — future is already in FINISHED state"
  category: errors
  kind: python_call_raises
  function: Future
  args: []
  expected: InvalidStateError

