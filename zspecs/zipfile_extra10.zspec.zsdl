spec: zipfile_extra10
version: ">=3.9"
backend: python_module(zipfile)

docs: https://docs.python.org/3/library/zipfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zipfile.html — Python zipfile documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/zipfile/__init__.py"
  notes:
    - "This spec extends zipfile.zspec.zsdl through zipfile_extra9.zspec.zsdl."
    - "zipfile_extra9 covers: ZipInfo.date_time type/epoch year; ZipInfo.create_system==3; Path.__bases__[0].__name__=='object'; BadZipFile.__mro__[1].__name__=='Exception'; BadZipFile.__mro__[2].__name__=='BaseException'."
    - "zipfile_extra8 covers: compression constant bool class checks; ZipExtFile metadata; BadZipfile alias; ZipFile/ZipInfo/Path base names; ZipInfo('data.bin').filename; is_zipfile TypeError."
    - "zipfile_extra7 covers: Path/BadZipFile/LargeZipFile type checks; limit constant class names; is_zipfile class name; ZipInfo('archive.zip').filename; BadZipFile/__module__; LargeZipFile/__qualname__."
    - "No prior spec covers: zipfile.ZipInfo.compress_type == 0 — default compress_type on freshly constructed ZipInfo."
    - "No prior spec covers: zipfile.ZipInfo.file_size == 0 — default file_size on freshly constructed ZipInfo."
    - "No prior spec covers: zipfile.ZipInfo.compress_size == 0 — default compress_size on freshly constructed ZipInfo."
    - "No prior spec covers: zipfile.LargeZipFile.__mro__[1].__name__ == 'Exception' — LargeZipFile MRO depth 1."
    - "No prior spec covers: zipfile.LargeZipFile.__mro__[2].__name__ == 'BaseException' — LargeZipFile MRO depth 2."
    - "No prior spec covers: zipfile.ZipExtFile.__bases__[0].__name__ == 'BufferedIOBase' using MRO form."
    - "No prior spec covers: zipfile.BadZipFile.__mro__[3].__name__ == 'object' — MRO terminal entry."
    - "No prior spec covers: zipfile.ZipInfo.compress_type via ZipInfo('report.csv') — distinct filename vector."
    - "zipfile.ZipInfo defaults: compress_type=0 (ZIP_STORED), file_size=0, compress_size=0."
    - "zipfile.LargeZipFile.__mro__: [LargeZipFile, Exception, BaseException, object]."
    - "zipfile.BadZipFile.__mro__: [BadZipFile, Exception, BaseException, object]; mro[3] == 'object'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ZipInfo default field values — compress_type, file_size, compress_size
# zipfile (base) checks compress_type and file_size for ZipInfo as constructed
# values, but only via specific non-default construction.
# No prior spec checks the zero-argument default values for these fields.
# ZipInfo() defaults: compress_type=0 (ZIP_STORED), file_size=0, compress_size=0.
# ---------------------------------------------------------------------------

table zipfile_extra10.ZipInfo_defaults:
  description: "ZipInfo() default field values: compress_type=0, file_size=0, compress_size=0"
  kind: python_call_eq
  category: zipinfo
  id_prefix: zidef10

  columns: [id, function, args, expected, method]
  rows:
    - [compress_type,  ZipInfo, ["report.csv"], 0, compress_type]
    - [file_size,      ZipInfo, ["report.csv"], 0, file_size]
    - [compress_size,  ZipInfo, ["report.csv"], 0, compress_size]

# ---------------------------------------------------------------------------
# LargeZipFile MRO depth 1 and depth 2
# Prior specs cover LargeZipFile __name__/__module__/__qualname__/__class__.__name__
# and __bases__[0].__name__ == 'Exception'. No prior spec checks __mro__[N].__name__.
# LargeZipFile.__mro__: [LargeZipFile, Exception, BaseException, object]
# ---------------------------------------------------------------------------

invariant zipfile_extra10.LargeZipFile.mro_index1:
  description: "zipfile.LargeZipFile.__mro__[1].__name__ == 'Exception' — LargeZipFile MRO depth 1"
  category: class_hierarchy
  kind: python_call_eq
  function: LargeZipFile.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "Exception"

invariant zipfile_extra10.LargeZipFile.mro_index2:
  description: "zipfile.LargeZipFile.__mro__[2].__name__ == 'BaseException' — LargeZipFile MRO depth 2"
  category: class_hierarchy
  kind: python_call_eq
  function: LargeZipFile.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "BaseException"

# ---------------------------------------------------------------------------
# BadZipFile MRO depth 3 — terminal 'object' entry
# zipfile_extra9 covers BadZipFile.__mro__[1].__name__=='Exception' and
# BadZipFile.__mro__[2].__name__=='BaseException'. Index 3 ('object') is new.
# BadZipFile.__mro__: [BadZipFile, Exception, BaseException, object]
# ---------------------------------------------------------------------------

invariant zipfile_extra10.BadZipFile.mro_index3:
  description: "zipfile.BadZipFile.__mro__[3].__name__ == 'object' — BadZipFile MRO terminal entry"
  category: class_hierarchy
  kind: python_call_eq
  function: BadZipFile.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# ZipExtFile MRO depth 1 — BufferedIOBase
# zipfile_extra8 covers ZipExtFile.__bases__[0].__name__ == 'BufferedIOBase' (bases form).
# The MRO form (__mro__[1].__name__) is a distinct axis not in any prior spec.
# ---------------------------------------------------------------------------

invariant zipfile_extra10.ZipExtFile.mro_index1:
  description: "zipfile.ZipExtFile.__mro__[1].__name__ == 'BufferedIOBase' — ZipExtFile MRO depth 1"
  category: class_hierarchy
  kind: python_call_eq
  function: ZipExtFile.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "BufferedIOBase"

# ---------------------------------------------------------------------------
# zipfile module-level __name__ attribute
# tarfile_extra5 covers tarfile.__name__ == 'tarfile'. The analogous check
# for zipfile.__name__ == 'zipfile' is not in any prior zipfile spec.
# ---------------------------------------------------------------------------

invariant zipfile_extra10.module.name:
  description: "zipfile.__name__ == 'zipfile' — module __name__ attribute"
  category: module
  kind: python_call_eq
  function: __name__.__eq__
  args: ["zipfile"]
  expected: true

# ---------------------------------------------------------------------------
# ZipInfo filename vector — 'config.json'
# base covers 'hello.txt'; extra4 covers 'test.txt'; extra7 covers 'archive.zip';
# extra8 covers 'data.bin'. 'config.json' is a fresh vector.
# ---------------------------------------------------------------------------

invariant zipfile_extra10.ZipInfo.filename_config_json:
  description: "zipfile.ZipInfo('config.json').filename == 'config.json'"
  category: zipinfo
  kind: python_call_eq
  function: ZipInfo
  args: ["config.json"]
  method: filename
  expected: "config.json"
