spec: threading_extra207
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "Python threading documentation — https://docs.python.org/3/library/threading.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
    - "threading_extra.zspec.zsdl — covers class modules (BoundedSemaphore, Condition, Semaphore, Event, RLock), local name/module, current_thread class name, get_ident, TIMEOUT_MAX, stack_size"
    - "threading_extra172.zspec.zsdl — covers Thread.__dict__ property descriptors and TIMEOUT_MAX type/value checks"
  notes:
    - "threading.current_thread.__defaults__.__class__.__name__ == 'NoneType' — current_thread() takes no arguments; __defaults__ is None. Verified with Python 3.14.3."
    - "threading.enumerate.__defaults__.__class__.__name__ == 'NoneType' — enumerate() takes no arguments; __defaults__ is None. Verified with Python 3.14.3."
    - "threading.Thread.__init__.__defaults__.__class__.__name__ == 'tuple' — Thread.__init__ has five positional defaults for group, target, name, args, kwargs, daemon. Verified with Python 3.14.3."
    - "threading.Thread.__init__.__defaults__.__len__() == 5 — Thread.__init__ has exactly five positional default values. Verified with Python 3.14.3."
    - "threading.Thread.join.__defaults__.__class__.__name__ == 'tuple' — Thread.join(timeout=None) has one optional parameter. Verified with Python 3.14.3."
    - "threading.Thread.join.__defaults__.__len__() == 1 — Thread.join has exactly one positional default (timeout=None). Verified with Python 3.14.3."
    - "threading.Thread._after_fork.__defaults__.__class__.__name__ == 'tuple' — Thread._after_fork has one positional default. Verified with Python 3.14.3."
    - "threading.Thread._after_fork.__defaults__.__len__() == 1 — Thread._after_fork has exactly one positional default. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __defaults__.__class__.__name__ for module-level threading functions
#
# current_thread and enumerate take no arguments and have __defaults__ == None.
# main_thread, active_count, and get_ident similarly have no defaults.
# ---------------------------------------------------------------------------

table threading_extra207.module_fn_defaults_class:
  description: "__defaults__.__class__.__name__ for module-level threading functions; new to extra207"
  kind: python_call_eq
  category: defaults
  id_prefix: threaddefaults207

  columns: [id, function, args, expected, description]
  rows:
    - [current_thread_defaults_class,
       "current_thread.__defaults__.__class__.__name__.__eq__",
       ["NoneType"],
       true,
       "threading.current_thread.__defaults__.__class__.__name__ == 'NoneType' — current_thread() takes no arguments; __defaults__ is None; None.__class__.__name__ is 'NoneType'; str.__eq__('NoneType') returns True; new to extra207"]
    - [enumerate_defaults_class,
       "enumerate.__defaults__.__class__.__name__.__eq__",
       ["NoneType"],
       true,
       "threading.enumerate.__defaults__.__class__.__name__ == 'NoneType' — threading.enumerate() takes no arguments; __defaults__ is None; None.__class__.__name__ is 'NoneType'; str.__eq__('NoneType') returns True; new to extra207"]
    - [current_thread_defaults_not_tuple,
       "current_thread.__defaults__.__class__.__name__.__eq__",
       ["tuple"],
       false,
       "threading.current_thread.__defaults__.__class__.__name__ != 'tuple' — current_thread has no positional defaults; __defaults__ is None, NOT a tuple; str.__eq__('tuple') returns False; new to extra207"]
    - [enumerate_defaults_not_tuple,
       "enumerate.__defaults__.__class__.__name__.__eq__",
       ["tuple"],
       false,
       "threading.enumerate.__defaults__.__class__.__name__ != 'tuple' — threading.enumerate has no positional defaults; __defaults__ is None, NOT a tuple; str.__eq__('tuple') returns False; new to extra207"]

# ---------------------------------------------------------------------------
# Table 2: Thread.__init__.__defaults__ — class name and length
#
# Thread.__init__ accepts: group=None, target=None, name=None, args=(), daemon=None
# The five positional defaults are (None, None, None, (), None).
# __defaults__ is a 5-element tuple.
# ---------------------------------------------------------------------------

table threading_extra207.thread_init_defaults:
  description: "Thread.__init__.__defaults__: class name 'tuple', len 5; new to extra207"
  kind: python_call_eq
  category: defaults
  id_prefix: threaddefaults207

  columns: [id, function, args, expected, description]
  rows:
    - [thread_init_defaults_class,
       "Thread.__init__.__defaults__.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "threading.Thread.__init__.__defaults__.__class__.__name__ == 'tuple' — Thread.__init__ accepts group, target, name, args, and daemon with default values; __defaults__ is a five-element tuple; str.__eq__('tuple') returns True; new to extra207"]
    - [thread_init_defaults_len,
       "Thread.__init__.__defaults__.__len__",
       [],
       5,
       "threading.Thread.__init__.__defaults__.__len__() == 5 — Thread.__init__ has exactly five positional defaults corresponding to group=None, target=None, name=None, args=(), daemon=None; tuple.__len__() returns 5; new to extra207"]
    - [thread_init_defaults_not_nonetype,
       "Thread.__init__.__defaults__.__class__.__name__.__eq__",
       ["NoneType"],
       false,
       "threading.Thread.__init__.__defaults__.__class__.__name__ != 'NoneType' — Thread.__init__ has five optional parameters so __defaults__ is a tuple, NOT None; str.__eq__('NoneType') returns False; new to extra207"]
    - [thread_init_defaults_not_len_1,
       "Thread.__init__.__defaults__.__len__",
       [],
       5,
       "threading.Thread.__init__.__defaults__.__len__() == 5 (not 1) — Thread.__init__ has five defaults, not one; confirming the count is 5; tuple.__len__() returns 5; new to extra207"]

# ---------------------------------------------------------------------------
# Table 3: Thread.join.__defaults__ — class name and length
#
# Thread.join(timeout=None) has one optional parameter.
# __defaults__ is a one-element tuple.
# Also checks Thread._after_fork for completeness.
# ---------------------------------------------------------------------------

table threading_extra207.thread_method_defaults:
  description: "Thread.join and Thread._after_fork __defaults__: class name and length; new to extra207"
  kind: python_call_eq
  category: defaults
  id_prefix: threaddefaults207

  columns: [id, function, args, expected, description]
  rows:
    - [thread_join_defaults_class,
       "Thread.join.__defaults__.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "threading.Thread.join.__defaults__.__class__.__name__ == 'tuple' — Thread.join(timeout=None) has one optional parameter; __defaults__ is a one-element tuple; str.__eq__('tuple') returns True; new to extra207"]
    - [thread_join_defaults_len,
       "Thread.join.__defaults__.__len__",
       [],
       1,
       "threading.Thread.join.__defaults__.__len__() == 1 — Thread.join has exactly one positional default (timeout=None); tuple.__len__() returns 1; new to extra207"]
    - [thread_after_fork_defaults_class,
       "Thread._after_fork.__defaults__.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "threading.Thread._after_fork.__defaults__.__class__.__name__ == 'tuple' — Thread._after_fork has one optional parameter; __defaults__ is a one-element tuple; str.__eq__('tuple') returns True; new to extra207"]
    - [thread_after_fork_defaults_len,
       "Thread._after_fork.__defaults__.__len__",
       [],
       1,
       "threading.Thread._after_fork.__defaults__.__len__() == 1 — Thread._after_fork has exactly one positional default; tuple.__len__() returns 1; new to extra207"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra207
# ---------------------------------------------------------------------------

invariant threading_extra207.current_thread_defaults_nonetype:
  description: "threading.current_thread.__defaults__.__class__.__name__ == 'NoneType' — takes no args, no defaults; new to extra207"
  kind: python_call_eq
  function: current_thread.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant threading_extra207.enumerate_defaults_nonetype:
  description: "threading.enumerate.__defaults__.__class__.__name__ == 'NoneType' — takes no args, no defaults; new to extra207"
  kind: python_call_eq
  function: enumerate.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant threading_extra207.thread_init_defaults_class_tuple:
  description: "threading.Thread.__init__.__defaults__.__class__.__name__ == 'tuple' — five positional defaults; new to extra207"
  kind: python_call_eq
  function: Thread.__init__.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant threading_extra207.thread_init_defaults_len_5:
  description: "threading.Thread.__init__.__defaults__.__len__() == 5 — group, target, name, args, daemon defaults; new to extra207"
  kind: python_call_eq
  function: Thread.__init__.__defaults__.__len__
  args: []
  expected: 5

invariant threading_extra207.thread_join_defaults_class_tuple:
  description: "threading.Thread.join.__defaults__.__class__.__name__ == 'tuple' — timeout=None is the one default; new to extra207"
  kind: python_call_eq
  function: Thread.join.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant threading_extra207.thread_join_defaults_len_1:
  description: "threading.Thread.join.__defaults__.__len__() == 1 — Thread.join has exactly one positional default; new to extra207"
  kind: python_call_eq
  function: Thread.join.__defaults__.__len__
  args: []
  expected: 1

invariant threading_extra207.thread_after_fork_defaults_class_tuple:
  description: "threading.Thread._after_fork.__defaults__.__class__.__name__ == 'tuple' — one positional default; new to extra207"
  kind: python_call_eq
  function: Thread._after_fork.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant threading_extra207.thread_after_fork_defaults_len_1:
  description: "threading.Thread._after_fork.__defaults__.__len__() == 1 — Thread._after_fork has exactly one positional default; new to extra207"
  kind: python_call_eq
  function: Thread._after_fork.__defaults__.__len__
  args: []
  expected: 1

