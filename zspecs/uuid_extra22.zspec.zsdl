spec: uuid_extra22
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "This spec extends uuid_extra21.zspec.zsdl."
    - "Prior specs covered: uuid4() type, UUID fields, UUID.__name__/__module__/__qualname__, uuid.__name__/__package__, uuid1/3/4/5 __name__/__module__, NAMESPACE_DNS/URL/OID/X500 class names, UUID.__bases__[0].__name__, UUID.__init__.__name__, UUID.hex length/urn prefix, UUID integer attributes, uuid1/3/4/5 __qualname__ (extra5), uuid1/3/4/5 __module__ (extra18), UUID.__name__/__qualname__/__module__ lengths (extra19), uuid1/3/4/5 __qualname__ standalone (extra20), UUID.__init__.__qualname__ (extra20), uuid1/3/4/5/UUID __module__.__len__() (extra20), NAMESPACE_DNS.__class__.__module__ (extra20), UUID.__qualname__.__len__() (extra20), uuid1/3/4/5 __name__.__len__() (extra21), UUID.__init__.__module__/__qualname__.__len__() (extra21), NAMESPACE_URL/OID/X500 __class__.__module__.__len__() (extra21), UUID.__name__.__len__() standalone (extra21)."
    - "This spec covers: uuid.UUID.__mro__.__len__(), uuid.UUID.__str__.__qualname__.__len__(), uuid.UUID.__repr__.__qualname__.__len__(), uuid.UUID.__hash__.__qualname__.__len__(), uuid.UUID.__eq__.__qualname__.__len__(), uuid.UUID.__slots__.__class__.__name__, uuid.UUID.__slots__.__len__(), uuid.UUID.hex.__class__.__name__, uuid.UUID.__bases__[0].__name__."
    - "uuid.UUID.__mro__.__len__() == 2 — UUID's MRO is [UUID, object] (len 2); UUID has no intermediate base classes; no prior uuid spec checks UUID.__mro__.__len__()."
    - "uuid.UUID.__str__.__qualname__.__len__() == 12 — UUID.__str__.__qualname__ == 'UUID.__str__' (len 12); no prior uuid spec checks UUID.__str__.__qualname__.__len__()."
    - "uuid.UUID.__repr__.__qualname__.__len__() == 13 — UUID.__repr__.__qualname__ == 'UUID.__repr__' (len 13); no prior uuid spec checks UUID.__repr__.__qualname__.__len__()."
    - "uuid.UUID.__hash__.__qualname__.__len__() == 13 — UUID.__hash__.__qualname__ == 'UUID.__hash__' (len 13); no prior uuid spec checks UUID.__hash__.__qualname__.__len__()."
    - "uuid.UUID.__eq__.__qualname__.__len__() == 11 — UUID.__eq__.__qualname__ == 'UUID.__eq__' (len 11); no prior uuid spec checks UUID.__eq__.__qualname__.__len__()."
    - "uuid.UUID.__slots__.__class__.__name__ == 'tuple' — __slots__ is stored as a tuple; no prior uuid spec checks UUID.__slots__.__class__.__name__."
    - "uuid.UUID.__slots__.__len__() == 3 — UUID defines 3 slot entries: 'int', 'is_safe', '__weakref__'; no prior uuid spec checks UUID.__slots__.__len__()."
    - "uuid.UUID.hex.__class__.__name__ == 'property' — UUID.hex is a property descriptor object; no prior uuid spec checks uuid.UUID.hex.__class__.__name__."
    - "uuid.UUID.__bases__[0].__name__ == 'object' — UUID directly subclasses object; extra_early specs check UUID.__bases__[0].__name__ in a table; this standalone invariant provides extra21-namespace regression coverage."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__mro__ depth
#
# uuid.UUID.__mro__ is [UUID, object], length 2. UUID has no intermediate
# base classes — it is a direct subclass of object. No prior uuid spec checks
# UUID.__mro__.__len__(). This is the shallowest possible non-trivial MRO.
# ---------------------------------------------------------------------------

invariant uuid_extra22.UUID.mro_len:
  description: "uuid.UUID.__mro__.__len__() == 2 — MRO is [UUID, object]; UUID directly subclasses object; no prior uuid spec checks UUID.__mro__.__len__()"
  category: class_hierarchy
  kind: python_call_eq
  function: UUID.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# uuid.UUID method __qualname__ string lengths
#
# No prior uuid spec checks __qualname__.__len__() on UUID.__str__, UUID.__repr__,
# UUID.__hash__, or UUID.__eq__. These four dunder methods are defined directly
# on UUID. Their qualnames follow the pattern 'UUID.<method>' with varying
# lengths: __str__ (12), __repr__ and __hash__ (13 each), __eq__ (11).
# ---------------------------------------------------------------------------

table uuid_extra22.method_qualname_lengths:
  description: "UUID.__str__/__repr__/__hash__/__eq__ __qualname__ string lengths — no prior uuid spec checks __qualname__.__len__() on these methods"
  kind: python_call_eq
  category: method_identity
  id_prefix: mqlen22

  columns: [id, function, args, expected]
  rows:
    - [str,  UUID.__str__.__qualname__.__len__,  [], 12]
    - [repr, UUID.__repr__.__qualname__.__len__, [], 13]
    - [hash, UUID.__hash__.__qualname__.__len__, [], 13]
    - [eq,   UUID.__eq__.__qualname__.__len__,   [], 11]

# ---------------------------------------------------------------------------
# uuid.UUID.__slots__ class name and length
#
# uuid.UUID uses __slots__ to restrict instance attributes and reduce memory
# usage. The __slots__ object is a tuple of 3 strings: 'int', 'is_safe',
# '__weakref__'. No prior uuid spec checks UUID.__slots__.__class__.__name__
# or UUID.__slots__.__len__().
# ---------------------------------------------------------------------------

invariant uuid_extra22.UUID_slots.class_name:
  description: "uuid.UUID.__slots__.__class__.__name__ == 'tuple' — __slots__ is stored as a tuple object; no prior uuid spec checks UUID.__slots__.__class__.__name__"
  category: class_structure
  kind: python_call_eq
  function: UUID.__slots__.__class__.__name__.__eq__
  args: [tuple]
  expected: true

invariant uuid_extra22.UUID_slots.len:
  description: "uuid.UUID.__slots__.__len__() == 3 — UUID defines 3 slots: 'int', 'is_safe', '__weakref__'; no prior uuid spec checks UUID.__slots__.__len__()"
  category: class_structure
  kind: python_call_eq
  function: UUID.__slots__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# uuid.UUID.hex property descriptor and UUID.__bases__[0].__name__
#
# uuid.UUID.hex accessed on the class (not an instance) yields a property
# descriptor object. Its __class__.__name__ is 'property'. No prior uuid spec
# checks UUID.hex.__class__.__name__. Separately, UUID.__bases__[0].__name__
# confirms UUID directly subclasses object; early specs check this in a table;
# this provides a standalone regression in the extra22 namespace.
# ---------------------------------------------------------------------------

table uuid_extra22.hex_property_and_bases:
  description: "UUID.hex property descriptor class name and UUID.__bases__[0].__name__ — verify descriptor type and direct inheritance from object"
  kind: python_call_eq
  category: class_structure
  id_prefix: hexprop22

  columns: [id, function, args, expected]
  rows:
    - [hex_class,   UUID.hex.__class__.__name__.__eq__,    [property], true]
    - [bases0_name, "UUID.__bases__[0].__name__.__eq__",   [object],   true]
