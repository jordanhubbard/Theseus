spec: decimal_extra2146
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "Wave extra2146, theme: numeric conversion protocol dict-presence."
    - "Checks __trunc__, __floor__, __ceil__, __index__, __complex__, __bool__, __int__ in decimal class __dict__."
    - "decimal.Decimal defines __trunc__, __floor__, __ceil__, __complex__, __bool__, __int__ in its own __dict__."
    - "decimal.Decimal does NOT define __index__ in its own __dict__ — Decimal is not losslessly convertible to int for index use."
    - "decimal.Context and decimal.DecimalException define none of the seven numeric conversion dunders in their __dict__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Numeric conversion protocol — decimal.Decimal
# Decimal IS a numeric type: it defines __trunc__, __floor__, __ceil__,
# __complex__, __bool__, and __int__ directly in its own __dict__.
# __index__ is absent — Decimal cannot serve as a lossless integer index.
# ---------------------------------------------------------------------------

table decimal_extra2146.decimal_numeric_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["dc2146001", "decimal.Decimal.__dict__.__contains__", ["__trunc__"],   true]
    - ["dc2146002", "decimal.Decimal.__dict__.__contains__", ["__floor__"],   true]
    - ["dc2146003", "decimal.Decimal.__dict__.__contains__", ["__ceil__"],    true]
    - ["dc2146004", "decimal.Decimal.__dict__.__contains__", ["__index__"],   false]
    - ["dc2146005", "decimal.Decimal.__dict__.__contains__", ["__complex__"], true]
    - ["dc2146006", "decimal.Decimal.__dict__.__contains__", ["__bool__"],    true]
    - ["dc2146007", "decimal.Decimal.__dict__.__contains__", ["__int__"],     true]

# ---------------------------------------------------------------------------
# Numeric conversion protocol — decimal.Context
# Context holds arithmetic configuration (precision, rounding, traps).
# It is not itself a number; none of the seven numeric dunders appear in __dict__.
# ---------------------------------------------------------------------------

table decimal_extra2146.context_numeric_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["dc2146008", "decimal.Context.__dict__.__contains__", ["__trunc__"],   false]
    - ["dc2146009", "decimal.Context.__dict__.__contains__", ["__floor__"],   false]
    - ["dc2146010", "decimal.Context.__dict__.__contains__", ["__ceil__"],    false]
    - ["dc2146011", "decimal.Context.__dict__.__contains__", ["__index__"],   false]
    - ["dc2146012", "decimal.Context.__dict__.__contains__", ["__complex__"], false]
    - ["dc2146013", "decimal.Context.__dict__.__contains__", ["__bool__"],    false]
    - ["dc2146014", "decimal.Context.__dict__.__contains__", ["__int__"],     false]

# ---------------------------------------------------------------------------
# Numeric conversion protocol — decimal.DecimalException
# DecimalException is the base exception for decimal arithmetic errors.
# As an exception class it has no numeric protocol in its own __dict__.
# ---------------------------------------------------------------------------

table decimal_extra2146.decimal_exception_numeric_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["dc2146015", "decimal.DecimalException.__dict__.__contains__", ["__trunc__"],   false]
    - ["dc2146016", "decimal.DecimalException.__dict__.__contains__", ["__floor__"],   false]
    - ["dc2146017", "decimal.DecimalException.__dict__.__contains__", ["__ceil__"],    false]
    - ["dc2146018", "decimal.DecimalException.__dict__.__contains__", ["__index__"],   false]
    - ["dc2146019", "decimal.DecimalException.__dict__.__contains__", ["__complex__"], false]
    - ["dc2146020", "decimal.DecimalException.__dict__.__contains__", ["__bool__"],    false]
    - ["dc2146021", "decimal.DecimalException.__dict__.__contains__", ["__int__"],     false]

# ---------------------------------------------------------------------------
# Cross-class summary — all three classes, all seven methods in one table
# Confirms the Decimal/non-Decimal split at a glance.
# ---------------------------------------------------------------------------

table decimal_extra2146.full_cross_class_summary:
  columns: [id, function, args, expected]
  rows:
    - ["dc2146022", "decimal.Decimal.__dict__.__contains__",          ["__trunc__"],   true]
    - ["dc2146023", "decimal.Decimal.__dict__.__contains__",          ["__floor__"],   true]
    - ["dc2146024", "decimal.Decimal.__dict__.__contains__",          ["__ceil__"],    true]
    - ["dc2146025", "decimal.Decimal.__dict__.__contains__",          ["__int__"],     true]
    - ["dc2146026", "decimal.Decimal.__dict__.__contains__",          ["__bool__"],    true]
    - ["dc2146027", "decimal.Decimal.__dict__.__contains__",          ["__complex__"], true]
    - ["dc2146028", "decimal.Decimal.__dict__.__contains__",          ["__index__"],   false]
    - ["dc2146029", "decimal.Context.__dict__.__contains__",          ["__trunc__"],   false]
    - ["dc2146030", "decimal.Context.__dict__.__contains__",          ["__int__"],     false]
    - ["dc2146031", "decimal.Context.__dict__.__contains__",          ["__bool__"],    false]
    - ["dc2146032", "decimal.DecimalException.__dict__.__contains__", ["__trunc__"],   false]
    - ["dc2146033", "decimal.DecimalException.__dict__.__contains__", ["__int__"],     false]
    - ["dc2146034", "decimal.DecimalException.__dict__.__contains__", ["__bool__"],    false]
