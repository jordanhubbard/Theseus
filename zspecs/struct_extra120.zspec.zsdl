# ---------------------------------------------------------------------------
# struct.Struct.pack.__doc__.__len__()==175
# struct.Struct.unpack.__doc__.__len__()==190
# struct.Struct.pack_into.__doc__.__len__()==277
#
# Wave 272 theme: Struct method __doc__ string lengths (first group).
#
# Struct.pack, Struct.unpack, and Struct.pack_into are C-level method_descriptor
# objects (from _struct.c). Each has a __doc__ string that describes the method's
# behavior with a signature and description. pack: 175 chars, unpack: 190 chars,
# pack_into: 277 chars (longest). These differ from the module-level function
# docstrings anchored in extra99 (pack: 176, pack_into: 274). No prior struct
# spec anchors Struct method __doc__.__len__() under structmethd120.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra120.Struct_method_doc_lengths_group1:
  description: "Struct.pack/__doc__/__len__()==175 / Struct.unpack/__doc__/__len__()==190 / Struct.pack_into/__doc__/__len__()==277 — C-level method_descriptor docstrings from _struct.c; distinct from module-level function docstrings (extra99 anchors pack/unpack/pack_into at 176/173/274); pack is shortest Struct method docstring (175); pack_into is longest (277); first structmethd120 anchor for Struct method __doc__ lengths"
  kind: python_call_eq
  category: doc_lengths
  id_prefix: structmethd120

  columns: [id, function, args, expected, description]
  rows:
    - [pack_doc_len,      Struct.pack.__doc__.__len__,      [], 175, "Struct.pack.__doc__ is 175 chars (C-level method_descriptor docstring from _struct.c)"]
    - [unpack_doc_len,    Struct.unpack.__doc__.__len__,    [], 190, "Struct.unpack.__doc__ is 190 chars (C-level method_descriptor docstring from _struct.c)"]
    - [pack_into_doc_len, Struct.pack_into.__doc__.__len__, [], 277, "Struct.pack_into.__doc__ is 277 chars (longest Struct method docstring)"]

