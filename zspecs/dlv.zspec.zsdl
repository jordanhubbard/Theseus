spec: dlv
version: ">=1.1.3"
backend: node(dlv)

docs: https://www.npmjs.com/package/dlv

provenance:
  derived_from:
    - "dlv README — https://www.npmjs.com/package/dlv"
    - "Test vectors verified with dlv via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "dlv source"
  notes:
    - "dlv is an npm package. Install: npm install dlv"
    - "Safely gets a dot-path value from a nested object, with an optional default."
    - "Signature: dlv(obj, key, defaultValue)"
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the value at the path, or the default if not found."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table dlv.get:
  kind: node_module_call_eq
  function: ~
  category: objects
  id_prefix: dlvget

  columns: [id, args, expected]
  rows:
    - [nested,          [{"a": {"b": 42}}, "a.b"],           42]
    - [deep,            [{"x": {"y": {"z": "hello"}}}, "x.y.z"], "hello"]
    - [top_level,       [{"a": 1, "b": 2}, "a"],             1]
    - [default_missing, [{"a": {"b": 42}}, "a.c", 99],       99]
    - [empty_default,   [{}, "a.b", "fallback"],              "fallback"]
