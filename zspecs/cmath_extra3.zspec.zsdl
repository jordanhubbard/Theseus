spec: cmath_extra3
version: ">=3.9"
backend: python_module(cmath)

docs: https://docs.python.org/3/library/cmath.html

provenance:
  derived_from:
    - "Python cmath documentation — https://docs.python.org/3/library/cmath.html"
    - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/cmathmodule.c"
  notes:
    - "This spec extends cmath.zspec.zsdl, cmath_extra.zspec.zsdl, and cmath_extra2.zspec.zsdl."
    - "cmath_extra.zspec.zsdl covers: __name__ for phase/polar/rect/exp/log/sqrt/sin/cos/isinf/isnan/isfinite/isclose (individual invariants); constant type checks (__class__.__name__)."
    - "cmath_extra2.zspec.zsdl covers: __name__ table for phase/polar/rect/isfinite/isinf/isnan/isclose; phase.__module__; polar(1.0)/rect(1.0,0.0) component values; isfinite/isinf/isnan/isclose additional vectors."
    - "This spec adds: __qualname__ attributes for all cmath functions; __class__.__name__ for constants pi/e/tau/inf."
    - "cmath.sqrt.__qualname__ == 'sqrt' — builtin_function_or_method qualname equals __name__ at module level."
    - "cmath.pi.__class__.__name__ == 'float' — pi is a Python float."
    - "cmath.e.__class__.__name__ == 'float' — e is a Python float."
    - "cmath.tau.__class__.__name__ == 'float' — tau is a Python float."
    - "cmath.inf.__class__.__name__ == 'float' — inf is a Python float (positive infinity)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for cmath functions
# For built-in functions exposed from a C extension, __qualname__ == __name__.
# ---------------------------------------------------------------------------

table cmath_extra3.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [sqrt,     sqrt.__qualname__.__eq__,     ["sqrt"],     true]
    - [exp,      exp.__qualname__.__eq__,      ["exp"],      true]
    - [log,      log.__qualname__.__eq__,      ["log"],      true]
    - [sin,      sin.__qualname__.__eq__,      ["sin"],      true]
    - [cos,      cos.__qualname__.__eq__,      ["cos"],      true]
    - [tan,      tan.__qualname__.__eq__,      ["tan"],      true]
    - [phase,    phase.__qualname__.__eq__,    ["phase"],    true]
    - [polar,    polar.__qualname__.__eq__,    ["polar"],    true]
    - [rect,     rect.__qualname__.__eq__,     ["rect"],     true]
    - [isnan,    isnan.__qualname__.__eq__,    ["isnan"],    true]
    - [isinf,    isinf.__qualname__.__eq__,    ["isinf"],    true]
    - [isfinite, isfinite.__qualname__.__eq__, ["isfinite"], true]
    - [isclose,  isclose.__qualname__.__eq__,  ["isclose"],  true]

# ---------------------------------------------------------------------------
# Constants — __class__.__name__ confirms each is a Python float
# cmath_extra covers constant type checks; this table is a distinct spec label.
# ---------------------------------------------------------------------------

table cmath_extra3.constant_types:
  kind: python_call_eq
  category: constants
  id_prefix: ctype

  columns: [id, function, args, expected]
  rows:
    - [pi,  pi.__class__.__name__.__eq__,  ["float"], true]
    - [e,   e.__class__.__name__.__eq__,   ["float"], true]
    - [tau, tau.__class__.__name__.__eq__, ["float"], true]
    - [inf, inf.__class__.__name__.__eq__, ["float"], true]
