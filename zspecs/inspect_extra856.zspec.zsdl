spec: inspect_extra856
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "Python standard library inspect module"
    - "CPython source: Lib/inspect.py"
  not_derived_from:
    - "Any third-party inspection or introspection library"
  notes:
    - "Covers __qualname__ and __module__ identity for async/generator predicate functions"
    - "Validates that inspect predicates are defined directly in the inspect module"
  created_at: "2026-04-12"

table inspect_extra856.predicate_qualnames:
  description: "Verify __qualname__ and __module__ for inspect async/generator predicate functions"
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: in856pq
  columns: [id, function, args, expected]
  rows:
    - [in856pq001, "inspect.iscoroutinefunction.__qualname__.__eq__", ["iscoroutinefunction"], true]
    - [in856pq002, "inspect.iscoroutinefunction.__module__.__eq__", ["inspect"], true]
    - [in856pq003, "inspect.isgeneratorfunction.__qualname__.__eq__", ["isgeneratorfunction"], true]
    - [in856pq004, "inspect.isgeneratorfunction.__module__.__eq__", ["inspect"], true]
    - [in856pq005, "inspect.isasyncgenfunction.__qualname__.__eq__", ["isasyncgenfunction"], true]
    - [in856pq006, "inspect.isasyncgenfunction.__module__.__eq__", ["inspect"], true]
    - [in856pq007, "inspect.isasyncgen.__qualname__.__eq__", ["isasyncgen"], true]
    - [in856pq008, "inspect.isasyncgen.__module__.__eq__", ["inspect"], true]
    - [in856pq009, "inspect.getattr_static.__qualname__.__eq__", ["getattr_static"], true]
    - [in856pq010, "inspect.getattr_static.__module__.__eq__", ["inspect"], true]
    - [in856pq011, "inspect.classify_class_attrs.__qualname__.__eq__", ["classify_class_attrs"], true]
    - [in856pq012, "inspect.classify_class_attrs.__module__.__eq__", ["inspect"], true]
