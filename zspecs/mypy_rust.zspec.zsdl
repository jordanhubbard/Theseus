spec: mypy_rust
version: ">=3.9"
backend: rust_module(mypy_rust)

docs: https://mypy.readthedocs.io/en/stable/

provenance:
  derived_from:
    - "https://mypy.readthedocs.io/en/stable/ — mypy documentation"
  not_derived_from:
    - "mypy source: mypy/__init__.py"
  notes:
    - "mypy is a static type checker for Python."
    - "mypy.__version__ is a non-empty string."
    - "mypy.version.__version__ is accessible."
    - "int(mypy.__version__.split('.')[0]) >= 1."
    - "Expose mypy_version_nonempty() -> bool: len(mypy.__version__) > 0."
    - "Expose mypy_version_major() -> int: int(mypy.__version__.split('.')[0])."
    - "Expose mypy_has_version_module() -> bool: hasattr(mypy, 'version')."
    - "All test vectors verified against mypy 1.15.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# mypy_version_nonempty — version non-empty
invariant mypy_rust.version.nonempty:
  description: "mypy.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: mypy_version_nonempty
  args: []
  expected: true

# mypy_version_major — major version >= 1
invariant mypy_rust.version.major_ge1:
  description: "mypy major version >= 1"
  category: version
  kind: python_call_eq
  function: mypy_version_major
  args: []
  expected: 1

# mypy_has_version_module — version module present
invariant mypy_rust.module.has_version:
  description: "mypy.version is available"
  category: module
  kind: python_call_eq
  function: mypy_has_version_module
  args: []
  expected: true

