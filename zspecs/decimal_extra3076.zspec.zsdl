spec: dc3076
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal: Decimal fixed-point and floating-point arithmetic"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 652 (dc3076): __get__, __set__, __delete__ dict-presence checks for decimal types."
    - "Classes covered: decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow."
    - "None of the decimal types define the descriptor protocol in their own __dict__: __get__, __set__, and __delete__ are all absent."
    - "decimal.Decimal and decimal.Context are arithmetic types; decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, and decimal.Underflow are exception classes — none implement the descriptor protocol."
    - "On CPython, the decimal module is backed by _decimal (C accelerator); class __dict__ contents are from the C extension."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __get__ dict-presence — operator.contains(Cls.__dict__, '__get__')
#
# No decimal type defines __get__ in its own __dict__; all false.
# decimal classes are arithmetic and exception types, not descriptor objects.
# ---------------------------------------------------------------------------

table dc3076.get:
  description: "decimal types __get__ dict-presence checks; wave 652"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3076

  columns: [id, function, args, expected]
  rows:
    - ["dc3076001", operator.contains, [decimal.Decimal.__dict__,          "__get__"], false]
    - ["dc3076002", operator.contains, [decimal.Context.__dict__,           "__get__"], false]
    - ["dc3076003", operator.contains, [decimal.DecimalException.__dict__,  "__get__"], false]
    - ["dc3076004", operator.contains, [decimal.InvalidOperation.__dict__,  "__get__"], false]
    - ["dc3076005", operator.contains, [decimal.Overflow.__dict__,          "__get__"], false]
    - ["dc3076006", operator.contains, [decimal.Underflow.__dict__,         "__get__"], false]

