spec: multiprocessing_extra435
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing class and function identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Queue, Lock, Pipe, Value, and Array are factory functions in multiprocessing, not classes"
    - "Process and Pool are proper classes; __bases__[0] checked for Process only"
    - "__bases__[0] function fields are double-quoted per ZSDL rules"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra435.class_name:
  description: "multiprocessing class __name__ checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: MPXN

  columns: [id, function, args, expected]
  rows:
    - [id001, multiprocessing.Process.__name__.__eq__, ["Process"], true]
    - [id002, multiprocessing.Pool.__name__.__eq__,    ["Pool"],    true]

table multiprocessing_extra435.class_module:
  description: "multiprocessing class __module__ checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: MPXM

  columns: [id, function, args, expected]
  rows:
    - [id001, multiprocessing.Process.__module__.__eq__, ["multiprocessing.process"], true]
    - [id002, multiprocessing.Pool.__module__.__eq__,    ["multiprocessing.pool"],    true]

table multiprocessing_extra435.class_bases:
  description: "multiprocessing class __bases__[0].__name__ checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: MPXB

  columns: [id, function, args, expected]
  rows:
    - [id001, "multiprocessing.Process.__bases__[0].__name__.__eq__", ["object"], true]

table multiprocessing_extra435.function_name:
  description: "multiprocessing factory function __name__ checks"
  kind: python_call_eq
  category: function_identity
  id_prefix: MPXF

  columns: [id, function, args, expected]
  rows:
    - [id001, multiprocessing.Queue.__name__.__eq__, ["Queue"], true]
    - [id002, multiprocessing.Lock.__name__.__eq__,  ["Lock"],  true]
    - [id003, multiprocessing.Pipe.__name__.__eq__,  ["Pipe"],  true]
    - [id004, multiprocessing.Value.__name__.__eq__, ["Value"], true]
    - [id005, multiprocessing.Array.__name__.__eq__, ["Array"], true]
