spec: decimal_extra60
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal_extra59.zspec.zsdl — covers decimal.__doc__.__contains__('arithmetic') and __contains__('floating'); Context.__doc__.__contains__('rounding') and __contains__('operations') and __contains__('Context'); Decimal/__doc__.__class__.__name__.__eq__('str') and Context/__doc__.__class__.__name__.__eq__('str')."
    - "decimal_extra58.zspec.zsdl — covers Decimal.__doc__.__contains__('Decimal') and __contains__('value'); ROUND_UP/ROUND_DOWN __class__.__name__.__eq__('str') and __contains__('ROUND')."
    - "decimal_extra54.zspec.zsdl — covers decimal.__spec__.name.__eq__('decimal') and __len__()==7; decimal.__spec__.__class__.__name__.__eq__('ModuleSpec')."
    - "decimal_extra25.zspec.zsdl — covers ROUND_HALF_EVEN/__class__.__name__.__eq__('str'); ROUND_HALF_UP/__class__.__name__.__eq__('str')."
    - "decimal_extra23.zspec.zsdl — covers ROUND_HALF_UP/__class__.__name__.__eq__('str') and ROUND_HALF_EVEN/__class__.__name__.__eq__('str')."
    - "decimal_extra6.zspec.zsdl — covers ROUND_HALF_EVEN.__eq__('ROUND_HALF_EVEN')."
    - "decimal_extra4.zspec.zsdl — covers ROUND_HALF_UP.__eq__('ROUND_HALF_UP') and ROUND_HALF_EVEN.__eq__('ROUND_HALF_EVEN')."
    - "decimal_extra2.zspec.zsdl — covers ROUND_HALF_UP.__eq__('ROUND_HALF_UP')."
    - "decimal_extra.zspec.zsdl — covers ROUND_HALF_UP.__eq__('ROUND_HALF_UP')."
  notes:
    - "This spec extends decimal_extra59.zspec.zsdl."
    - "Wave 230 theme: __code__ deep chains for Python functions + docstring content for C extension classes."
    - "Decimal and Context are C extensions — no __code__. decimal module-level functions (getcontext/setcontext/localcontext) are C built-in functions — no __code__ or __defaults__. Focus on novel __doc__ content anchors and string constant axis."
    - "Decimal.__doc__.__contains__('integer') — Decimal.__doc__ is 'Construct a new Decimal object. value can be an integer, string, tuple, or another Decimal object.' The word 'integer' appears. decimal_extra58 covered __contains__('Decimal') and __contains__('value') in decann58 namespace. 'integer' has not been checked in any prior decimal spec. Novel content anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Decimal.__doc__.__contains__('string') — same docstring also contains 'string' (as a value type). Novel content anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Decimal.__doc__ does NOT contain 'float' — the docstring mentions integer, string, tuple, and Decimal but not float. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "DecimalException.__doc__ is None — C extension; no docstring. Calling DecimalException.__doc__.__contains__('signal') raises AttributeError ('NoneType' object has no attribute '__contains__'). Use python_call_raises with AttributeError. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.__spec__.name.__class__.__name__.__eq__('str') — decimal.__spec__.name is the string 'decimal'; its class is str; __class__.__name__ is 'str'. decimal_extra54 covered __spec__.name.__eq__('decimal') and __len__()==7 but NOT __class__.__name__.__eq__('str'). Novel eq-form axis: verifying the type of the name attribute. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "ROUND_HALF_UP.__contains__('HALF') — ROUND_HALF_UP is the string 'ROUND_HALF_UP'; 'HALF' is a substring. Prior specs cover ROUND_HALF_UP.__eq__('ROUND_HALF_UP') (decimal_extra, extra2, extra4) and __class__.__name__.__eq__('str') (extra23, extra25) and ROUND_UP/ROUND_DOWN __contains__('ROUND') (extra58). No prior spec checks ROUND_HALF_UP.__contains__('HALF'). Novel __contains__ axis. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "ROUND_HALF_EVEN.__contains__('HALF') — ROUND_HALF_EVEN is the string 'ROUND_HALF_EVEN'; 'HALF' is a substring. Same novelty reasoning. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal.__doc__.__contains__ content checks
#
# Decimal.__doc__ is:
#   "Construct a new Decimal object. 'value' can be an integer, string, tuple,
#    or another Decimal object. If no value is given, return Decimal('0'). The
#    context does not affect the conversion and is only passed to determine if
#    the InvalidOperation trap is active."
#
# Decimal is a C extension. Its docstring contains 'integer' and 'string'
# (as value types). Note: 'float' does NOT appear.
# decimal_extra58 covered __contains__('Decimal') and __contains__('value').
# 'integer' and 'string' have not been checked in any prior decimal spec.
# Novel content anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra60.decimal_doc_contains:
  description: "Decimal.__doc__.__contains__('integer') and __contains__('string') — Decimal is a C extension; __doc__ is 'Construct a new Decimal object. value can be an integer, string, tuple, or another Decimal object.'; 'integer' and 'string' both appear (as valid value types); note 'float' does NOT appear; decimal_extra58 covered 'Decimal' and 'value' in decann58 namespace; 'integer' and 'string' not checked in any prior decimal spec; novel content anchors in decdoc2_60 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_doc_content
  id_prefix: decdoc2_60decdoc

  columns: [id, function, args, expected]
  rows:
    - [doc_contains_integer, Decimal.__doc__.__contains__, ["integer"], true]
    - [doc_contains_string,  Decimal.__doc__.__contains__, ["string"],  true]

# ---------------------------------------------------------------------------
# DecimalException.__doc__ is None — python_call_raises
#
# DecimalException is a C extension exception class. Its __doc__ attribute
# is None (no docstring). Calling __contains__('signal') on None raises
# AttributeError: 'NoneType' object has no attribute '__contains__'.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra60.decimal_exception_doc_raises:
  description: "DecimalException.__doc__.__contains__('signal') raises AttributeError — DecimalException is a C extension; __doc__ is None (no docstring); calling __contains__ on None raises AttributeError ('NoneType' object has no attribute '__contains__'); novel python_call_raises anchor in decdoc2_60 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_raises
  category: class_doc_none
  id_prefix: decdoc2_60excptraises

  columns: [id, function, args, expected]
  rows:
    - [doc_contains_signal_raises, DecimalException.__doc__.__contains__, ["signal"], AttributeError]

# ---------------------------------------------------------------------------
# decimal.__spec__.name.__class__.__name__.__eq__('str')
#
# decimal.__spec__.name is the string 'decimal'. Its type is str.
# __class__.__name__ is 'str'.
#
#   decimal.__spec__.name.__class__.__name__.__eq__('str') == True
#
# decimal_extra54 covered __spec__.name.__eq__('decimal') and __len__()==7
# but NOT __class__.__name__.__eq__('str'). Novel eq-form axis: verifying
# the runtime type of the name attribute itself.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra60.spec_name_class:
  description: "decimal.__spec__.name.__class__.__name__.__eq__('str') — decimal.__spec__.name is the string 'decimal'; its type is str; __class__.__name__ is 'str'; decimal_extra54 covered __spec__.name.__eq__('decimal') and __len__()==7 but not __class__.__name__.__eq__('str'); novel eq-form axis verifying runtime type of spec name attribute; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_spec_identity
  id_prefix: decdoc2_60specname

  columns: [id, function, args, expected]
  rows:
    - [spec_name_class_eq, decimal.__spec__.name.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# ROUND_HALF_UP and ROUND_HALF_EVEN __contains__('HALF')
#
# ROUND_HALF_UP  is the string 'ROUND_HALF_UP'.  'HALF' is a substring.
# ROUND_HALF_EVEN is the string 'ROUND_HALF_EVEN'. 'HALF' is a substring.
#
# Prior specs cover:
#   - ROUND_HALF_UP.__eq__('ROUND_HALF_UP') in decimal_extra, extra2, extra4
#   - ROUND_HALF_EVEN.__eq__('ROUND_HALF_EVEN') in decimal_extra4, extra6
#   - ROUND_HALF_UP/__class__.__name__.__eq__('str') in extra23, extra25
#   - ROUND_UP/ROUND_DOWN __contains__('ROUND') in extra58
# No prior spec checks ROUND_HALF_UP.__contains__('HALF') or
# ROUND_HALF_EVEN.__contains__('HALF'). Novel __contains__ axis.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra60.round_half_contains:
  description: "ROUND_HALF_UP.__contains__('HALF') and ROUND_HALF_EVEN.__contains__('HALF') — ROUND_HALF_UP value is 'ROUND_HALF_UP' and ROUND_HALF_EVEN value is 'ROUND_HALF_EVEN'; 'HALF' is a substring of both; prior specs cover __eq__ for these constants (decimal_extra/extra4/extra6) and __class__.__name__.__eq__('str') (extra23/extra25) and __contains__('ROUND') for ROUND_UP/ROUND_DOWN (extra58); no prior spec checks ROUND_HALF_UP or ROUND_HALF_EVEN __contains__('HALF'); novel __contains__ axis in decdoc2_60 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: rounding_constant_content
  id_prefix: decdoc2_60roundhalf

  columns: [id, function, args, expected]
  rows:
    - [half_up_contains_half,   ROUND_HALF_UP.__contains__,   ["HALF"], true]
    - [half_even_contains_half, ROUND_HALF_EVEN.__contains__, ["HALF"], true]

invariant decimal_extra60.decimal_doc_contains_integer:
  description: "Decimal.__doc__.__contains__('integer') == True — Decimal is a C extension; __doc__ is 'Construct a new Decimal object. value can be an integer, string, tuple, or another Decimal object.'; 'integer' appears as a valid value type; decimal_extra58 covered 'Decimal' and 'value'; 'integer' not checked in any prior decimal spec; novel __doc__ content anchor in decdoc2_60 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_content
  kind: python_call_eq
  function: Decimal.__doc__.__contains__
  args: ["integer"]
  expected: true

invariant decimal_extra60.decimal_doc_contains_string:
  description: "Decimal.__doc__.__contains__('string') == True — Decimal is a C extension; __doc__ is 'Construct a new Decimal object. value can be an integer, string, tuple, or another Decimal object.'; 'string' appears as a valid value type; decimal_extra58 covered 'Decimal' and 'value'; 'string' not checked in any prior decimal spec; novel __doc__ content anchor in decdoc2_60 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_content
  kind: python_call_eq
  function: Decimal.__doc__.__contains__
  args: ["string"]
  expected: true

invariant decimal_extra60.decimal_exception_doc_raises:
  description: "DecimalException.__doc__.__contains__('signal') raises AttributeError — DecimalException is a C extension exception; __doc__ is None; None has no __contains__ attribute; raises AttributeError; novel python_call_raises anchor in decdoc2_60 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_none
  kind: python_call_raises
  function: DecimalException.__doc__.__contains__
  args: ["signal"]
  expected: AttributeError

invariant decimal_extra60.spec_name_class_str:
  description: "decimal.__spec__.name.__class__.__name__.__eq__('str') == True — decimal.__spec__.name is the string 'decimal'; its runtime type is str; __class__.__name__ is 'str'; decimal_extra54 covered __spec__.name.__eq__('decimal') and __len__()==7 but not __class__.__name__.__eq__('str'); novel eq-form axis verifying type of spec name; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_spec_identity
  kind: python_call_eq
  function: decimal.__spec__.name.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant decimal_extra60.round_half_up_contains_half:
  description: "ROUND_HALF_UP.__contains__('HALF') == True — decimal.ROUND_HALF_UP value is 'ROUND_HALF_UP'; 'HALF' is a substring; prior specs cover __eq__('ROUND_HALF_UP') (decimal_extra/extra4) and __class__.__name__.__eq__('str') (extra23/extra25) and __contains__('ROUND') for ROUND_UP/ROUND_DOWN (extra58); no prior spec checks ROUND_HALF_UP.__contains__('HALF'); novel __contains__ axis in decdoc2_60 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: rounding_constant_content
  kind: python_call_eq
  function: ROUND_HALF_UP.__contains__
  args: ["HALF"]
  expected: true

invariant decimal_extra60.round_half_even_contains_half:
  description: "ROUND_HALF_EVEN.__contains__('HALF') == True — decimal.ROUND_HALF_EVEN value is 'ROUND_HALF_EVEN'; 'HALF' is a substring; prior specs cover __eq__('ROUND_HALF_EVEN') (decimal_extra4/extra6) and __class__.__name__.__eq__('str') (extra23/extra25); no prior spec checks ROUND_HALF_EVEN.__contains__('HALF'); novel __contains__ axis in decdoc2_60 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: rounding_constant_content
  kind: python_call_eq
  function: ROUND_HALF_EVEN.__contains__
  args: ["HALF"]
  expected: true
