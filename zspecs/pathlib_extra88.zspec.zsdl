spec: pathlib_extra88
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends all prior pathlib specs through pathlib_extra87."
    - "Prior specs covered: PurePath/Path class identity; Path method __name__/__qualname__; Path MRO; Path.__code__ attributes for many methods; PurePath/__dict__ membership; Path/__dict__ membership; Path properties as descriptors; Path method co_name and co_argcount for open/read_text/write_text/iterdir/mkdir/rmdir/stat/lstat/exists/unlink/rename/resolve/absolute/expanduser; PurePath/__name__/__module__/__bases__/__mro__; PosixPath identity; Path.__init__/__new__ co_name and co_argcount."
    - "This spec covers: Path.is_dir/__code__.co_name and co_argcount; Path.is_file/__code__.co_name and co_argcount; Path.is_symlink/__code__.co_name and co_argcount; Path.is_mount/__code__.co_name and co_argcount; Path.is_absolute/__code__.co_name and co_argcount; Path.is_relative_to/__code__.co_name and co_argcount; Path.exists/__code__.co_name and co_argcount; Path.samefile/__code__.co_name and co_argcount."
    - "Path.is_dir.__code__.co_argcount == 1 — self only (no follow_symlinks keyword in this Python version's signature)."
    - "Path.is_file.__code__.co_argcount == 1 — self only."
    - "Path.is_symlink.__code__.co_argcount == 1 — self only."
    - "Path.is_mount.__code__.co_argcount == 1 — self only."
    - "Path.is_absolute.__code__.co_argcount == 1 — self only."
    - "Path.is_relative_to.__code__.co_argcount == 2 — self, other."
    - "Path.exists.__code__.co_argcount == 1 — self only (follow_symlinks is keyword-only, not counted)."
    - "Path.samefile.__code__.co_argcount == 2 — self, other_path."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path.is_dir and Path.is_file __code__ attributes
# Both take only self (co_argcount == 1); co_name matches the method name.
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra88.Path_is_dir_is_file_code:
  description: "Path.is_dir and Path.is_file __code__.co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibextra88

  columns: [id, function, args, expected]
  rows:
    - [isdir_co_name,  Path.is_dir.__code__.co_name.__eq__,     ["is_dir"], true]
    - [isdir_co_argc,  Path.is_dir.__code__.co_argcount.__eq__,  [1],       true]
    - [isfile_co_name, Path.is_file.__code__.co_name.__eq__,    ["is_file"], true]
    - [isfile_co_argc, Path.is_file.__code__.co_argcount.__eq__, [1],        true]

# ---------------------------------------------------------------------------
# Path.is_symlink and Path.is_mount __code__ attributes
# Both take only self (co_argcount == 1).
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra88.Path_is_symlink_is_mount_code:
  description: "Path.is_symlink and Path.is_mount __code__.co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibextra88

  columns: [id, function, args, expected]
  rows:
    - [issymlink_co_name, Path.is_symlink.__code__.co_name.__eq__,     ["is_symlink"], true]
    - [issymlink_co_argc, Path.is_symlink.__code__.co_argcount.__eq__,  [1],           true]
    - [ismount_co_name,   Path.is_mount.__code__.co_name.__eq__,       ["is_mount"],   true]
    - [ismount_co_argc,   Path.is_mount.__code__.co_argcount.__eq__,    [1],           true]

# ---------------------------------------------------------------------------
# Path.is_absolute and Path.is_relative_to __code__ attributes
# is_absolute: co_argcount == 1 (self only).
# is_relative_to: co_argcount == 2 (self, other).
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra88.Path_is_absolute_is_relative_to_code:
  description: "Path.is_absolute and Path.is_relative_to __code__.co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibextra88

  columns: [id, function, args, expected]
  rows:
    - [isabsolute_co_name,    Path.is_absolute.__code__.co_name.__eq__,      ["is_absolute"],    true]
    - [isabsolute_co_argc,    Path.is_absolute.__code__.co_argcount.__eq__,   [1],               true]
    - [isrelativeto_co_name,  Path.is_relative_to.__code__.co_name.__eq__,   ["is_relative_to"], true]
    - [isrelativeto_co_argc,  Path.is_relative_to.__code__.co_argcount.__eq__, [2],              true]

# ---------------------------------------------------------------------------
# Path.exists and Path.samefile __code__ attributes
# exists: co_argcount == 1 (follow_symlinks is keyword-only, not in co_argcount).
# samefile: co_argcount == 2 (self, other_path).
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra88.Path_exists_samefile_code:
  description: "Path.exists and Path.samefile __code__.co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibextra88

  columns: [id, function, args, expected]
  rows:
    - [exists_co_name,   Path.exists.__code__.co_name.__eq__,      ["exists"],   true]
    - [exists_co_argc,   Path.exists.__code__.co_argcount.__eq__,   [1],         true]
    - [samefile_co_name, Path.samefile.__code__.co_name.__eq__,    ["samefile"], true]
    - [samefile_co_argc, Path.samefile.__code__.co_argcount.__eq__, [2],         true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra88.Path_is_dir.co_name:
  description: "pathlib.Path.is_dir.__code__.co_name == 'is_dir'"
  category: code_attrs
  kind: python_call_eq
  function: Path.is_dir.__code__.co_name.__eq__
  args: ["is_dir"]
  expected: true

invariant pathlib_extra88.Path_is_dir.co_argcount:
  description: "pathlib.Path.is_dir.__code__.co_argcount == 1 (self only)"
  category: code_attrs
  kind: python_call_eq
  function: Path.is_dir.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant pathlib_extra88.Path_is_relative_to.co_argcount:
  description: "pathlib.Path.is_relative_to.__code__.co_argcount == 2 (self, other)"
  category: code_attrs
  kind: python_call_eq
  function: Path.is_relative_to.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant pathlib_extra88.Path_samefile.co_argcount:
  description: "pathlib.Path.samefile.__code__.co_argcount == 2 (self, other_path)"
  category: code_attrs
  kind: python_call_eq
  function: Path.samefile.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant pathlib_extra88.Path_is_symlink.co_name:
  description: "pathlib.Path.is_symlink.__code__.co_name == 'is_symlink'"
  category: code_attrs
  kind: python_call_eq
  function: Path.is_symlink.__code__.co_name.__eq__
  args: ["is_symlink"]
  expected: true
