spec: types_extra9
version: ">=3.10"
backend: python_module(types)

docs: https://docs.python.org/3/library/types.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/types.html — Python types module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/types.py"
    - "types.zspec.zsdl — covers __name__ for FunctionType/MethodType/ModuleType/NoneType/GeneratorType/MappingProxyType/SimpleNamespace/LambdaType/CoroutineType/AsyncGeneratorType/UnionType"
    - "types_extra.zspec.zsdl — covers __name__ for CodeType/BuiltinFunctionType/TracebackType/FrameType"
    - "types_extra2.zspec.zsdl — covers __module__ for major types; __bases__[0].__name__ table"
    - "types_extra3.zspec.zsdl — covers EllipsisType/NotImplementedType/NoneType/MappingProxyType/SimpleNamespace __name__/__module__/__bases__"
    - "types_extra4.zspec.zsdl — covers __name__/__module__ table for FunctionType/CodeType/FrameType/TracebackType/ModuleType/MethodType/BuiltinFunctionType/MappingProxyType/CellType/NoneType"
    - "types_extra5.zspec.zsdl — covers __qualname__ for major types"
    - "types_extra6.zspec.zsdl — covers __qualname__ for CellType/CodeType/FrameType/TracebackType/NoneType/EllipsisType/NotImplementedType"
    - "types_extra7.zspec.zsdl — covers GenericAlias/__name__/__qualname__/__module__/__bases__[0]; UnionType/__qualname__/__module__; descriptor types __name__ and __qualname__"
    - "types_extra8.zspec.zsdl — covers descriptor types __module__ and __bases__[0]; CapsuleType; DynamicClassAttribute __name__/__module__; SimpleNamespace/__bases__[0]; UnionType/__bases__[0]"
  notes:
    - "This spec covers type class __name__ values via boolean __eq__ method chain invariants."
    - "types.FunctionType.__name__ == 'function' — the CPython function type name."
    - "types.LambdaType.__name__ == 'function' — LambdaType is an alias for FunctionType; same type object."
    - "types.GeneratorType.__name__ == 'generator' — generator iterator type."
    - "types.CoroutineType.__name__ == 'coroutine' — native coroutine type (Python 3.5+)."
    - "types.AsyncGeneratorType.__name__ == 'async_generator' — async generator type (Python 3.6+)."
    - "types.CodeType.__name__ == 'code' — compiled code object type."
    - "types.CellType.__name__ == 'cell' — closure cell type (Python 3.8+)."
    - "types.MethodType.__name__ == 'method' — bound method type."
    - "types.BuiltinFunctionType.__name__ == 'builtin_function_or_method' — C-level builtin type."
    - "types.BuiltinMethodType.__name__ == 'builtin_function_or_method' — alias for BuiltinFunctionType."
    - "types.WrapperDescriptorType.__name__ == 'wrapper_descriptor' — slot wrapper descriptor."
    - "types.MethodWrapperType.__name__ == 'method-wrapper' — bound slot wrapper (note the hyphen)."
    - "types.ModuleType.__name__ == 'module' — module object type."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Type class __name__ checks — all major types via __eq__ method chain
#
# types.zspec.zsdl and types_extra record __name__ values as direct expected
# string values. This spec asserts each via __name__.__eq__(expected) so the
# invariant is expressed as a boolean python_call_eq contract — a distinct
# representation that enables explicit pass/fail checking.
# ---------------------------------------------------------------------------

invariant types_extra9.FunctionType.name:
  description: "types.FunctionType.__name__.__eq__('function') == True — Python function type"
  category: class_names
  kind: python_call_eq
  function: FunctionType.__name__.__eq__
  args: ["function"]
  expected: true

invariant types_extra9.LambdaType.name:
  description: "types.LambdaType.__name__.__eq__('function') == True — LambdaType is an alias for FunctionType"
  category: class_names
  kind: python_call_eq
  function: LambdaType.__name__.__eq__
  args: ["function"]
  expected: true

invariant types_extra9.GeneratorType.name:
  description: "types.GeneratorType.__name__.__eq__('generator') == True — generator iterator type"
  category: class_names
  kind: python_call_eq
  function: GeneratorType.__name__.__eq__
  args: ["generator"]
  expected: true

invariant types_extra9.CoroutineType.name:
  description: "types.CoroutineType.__name__.__eq__('coroutine') == True — native coroutine type"
  category: class_names
  kind: python_call_eq
  function: CoroutineType.__name__.__eq__
  args: ["coroutine"]
  expected: true

invariant types_extra9.AsyncGeneratorType.name:
  description: "types.AsyncGeneratorType.__name__.__eq__('async_generator') == True — async generator type"
  category: class_names
  kind: python_call_eq
  function: AsyncGeneratorType.__name__.__eq__
  args: ["async_generator"]
  expected: true

invariant types_extra9.CodeType.name:
  description: "types.CodeType.__name__.__eq__('code') == True — compiled code object type"
  category: class_names
  kind: python_call_eq
  function: CodeType.__name__.__eq__
  args: ["code"]
  expected: true

invariant types_extra9.CellType.name:
  description: "types.CellType.__name__.__eq__('cell') == True — closure cell type"
  category: class_names
  kind: python_call_eq
  function: CellType.__name__.__eq__
  args: ["cell"]
  expected: true

invariant types_extra9.MethodType.name:
  description: "types.MethodType.__name__.__eq__('method') == True — bound method type"
  category: class_names
  kind: python_call_eq
  function: MethodType.__name__.__eq__
  args: ["method"]
  expected: true

invariant types_extra9.BuiltinFunctionType.name:
  description: "types.BuiltinFunctionType.__name__.__eq__('builtin_function_or_method') == True"
  category: class_names
  kind: python_call_eq
  function: BuiltinFunctionType.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant types_extra9.BuiltinMethodType.name:
  description: "types.BuiltinMethodType.__name__.__eq__('builtin_function_or_method') == True — alias for BuiltinFunctionType"
  category: class_names
  kind: python_call_eq
  function: BuiltinMethodType.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant types_extra9.WrapperDescriptorType.name:
  description: "types.WrapperDescriptorType.__name__.__eq__('wrapper_descriptor') == True"
  category: class_names
  kind: python_call_eq
  function: WrapperDescriptorType.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant types_extra9.MethodWrapperType.name:
  description: "types.MethodWrapperType.__name__.__eq__('method-wrapper') == True — note the hyphen"
  category: class_names
  kind: python_call_eq
  function: MethodWrapperType.__name__.__eq__
  args: ["method-wrapper"]
  expected: true

invariant types_extra9.ModuleType.name:
  description: "types.ModuleType.__name__.__eq__('module') == True — module object type"
  category: class_names
  kind: python_call_eq
  function: ModuleType.__name__.__eq__
  args: ["module"]
  expected: true
