spec: decimal_extra1681
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra1666.zspec.zsdl — covers __new__ and __init__ construction protocol"
    - "decimal_extra1651.zspec.zsdl — covers __init_subclass__, __class_getitem__, module attr presence"
  notes:
    - "Wave 559 (_extra1681): __call__ callable protocol — which decimal types define __call__ in their own __dict__."
    - "decimal.Decimal is a C extension type; Decimal instances are NOT callable — no __call__ in Decimal.__dict__."
    - "decimal.Context is a C extension type; Context instances are NOT callable — no __call__ in Context.__dict__."
    - "decimal.Decimal defines arithmetic operators: __abs__, __neg__, __pos__, __add__, __round__, __float__, __int__, __bool__."
    - "decimal.Decimal defines __float__ and __int__ for numeric conversion protocol in its own __dict__."
    - "decimal.Decimal defines __bool__ in its own __dict__ — zero is falsy, nonzero is truthy."
    - "decimal.Decimal does NOT define __iter__ or __contains__ — it is not iterable or a container."
    - "decimal.Context does NOT define __call__, __iter__, or arithmetic operators in its own __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table decimal_extra1681.callable_protocol
# __call__ is absent from every decimal type's own __dict__.
# Decimal and Context instances are not callable.
# ---------------------------------------------------------------------------

table decimal_extra1681.callable_protocol:
  description: "decimal types __call__ dict-presence checks — no decimal type defines __call__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1681

  columns: [id, function, args, expected]
  rows:
    - ["dc1681001", Decimal.__dict__.__contains__,          ["__call__"], false]
    - ["dc1681002", Context.__dict__.__contains__,          ["__call__"], false]
    - ["dc1681003", DecimalException.__dict__.__contains__,  ["__call__"], false]
    - ["dc1681004", InvalidOperation.__dict__.__contains__,  ["__call__"], false]
    - ["dc1681005", DivisionByZero.__dict__.__contains__,    ["__call__"], false]

# ---------------------------------------------------------------------------
# Table decimal_extra1681.arithmetic_operator_protocol
# Decimal defines arithmetic operators in its own __dict__:
#   __abs__, __neg__, __pos__, __add__, __round__, __float__, __int__, __bool__.
# These are C-level implementations exposed via tp_as_number.
# Context does NOT define these arithmetic operators in its own __dict__.
# ---------------------------------------------------------------------------

table decimal_extra1681.arithmetic_operator_protocol:
  description: "Decimal arithmetic operator dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1681

  columns: [id, function, args, expected]
  rows:
    - ["dc1681006",  Decimal.__dict__.__contains__,  ["__abs__"],   true]
    - ["dc1681007",  Decimal.__dict__.__contains__,  ["__neg__"],   true]
    - ["dc1681008",  Decimal.__dict__.__contains__,  ["__pos__"],   true]
    - ["dc1681009",  Decimal.__dict__.__contains__,  ["__add__"],   true]
    - ["dc1681010",  Decimal.__dict__.__contains__,  ["__round__"], true]
    - ["dc1681011",  Decimal.__dict__.__contains__,  ["__float__"], true]
    - ["dc1681012",  Decimal.__dict__.__contains__,  ["__int__"],   true]
    - ["dc1681013",  Decimal.__dict__.__contains__,  ["__bool__"],  true]
    - ["dc1681014",  Context.__dict__.__contains__,  ["__abs__"],   false]
    - ["dc1681015",  Context.__dict__.__contains__,  ["__neg__"],   false]
    - ["dc1681016",  Context.__dict__.__contains__,  ["__add__"],   false]
    - ["dc1681017",  Context.__dict__.__contains__,  ["__float__"], false]
    - ["dc1681018",  Context.__dict__.__contains__,  ["__bool__"],  false]

# ---------------------------------------------------------------------------
# Table decimal_extra1681.iteration_container_protocol
# Decimal and Context are not iterable or container types.
# Neither defines __iter__, __contains__, or __len__ in their own __dict__.
# ---------------------------------------------------------------------------

table decimal_extra1681.iteration_container_protocol:
  description: "Iteration and container protocol dict-presence checks for decimal types"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1681

  columns: [id, function, args, expected]
  rows:
    - ["dc1681019", Decimal.__dict__.__contains__,  ["__iter__"],     false]
    - ["dc1681020", Decimal.__dict__.__contains__,  ["__contains__"], false]
    - ["dc1681021", Decimal.__dict__.__contains__,  ["__len__"],      false]
    - ["dc1681022", Decimal.__dict__.__contains__,  ["__getitem__"],  false]
    - ["dc1681023", Context.__dict__.__contains__,  ["__iter__"],     false]
    - ["dc1681024", Context.__dict__.__contains__,  ["__contains__"], false]
    - ["dc1681025", Context.__dict__.__contains__,  ["__len__"],      false]
    - ["dc1681026", Context.__dict__.__contains__,  ["__getitem__"],  false]
    - ["dc1681027", Decimal.__dict__.__contains__,  ["__hash__"],     true]
    - ["dc1681028", Decimal.__dict__.__contains__,  ["__eq__"],       true]
    - ["dc1681029", Context.__dict__.__contains__,  ["__eq__"],       false]
    - ["dc1681030", Context.__dict__.__contains__,  ["__hash__"],     false]
