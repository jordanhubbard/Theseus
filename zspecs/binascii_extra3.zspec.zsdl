spec: binascii_extra3
version: ">=3.9"
backend: python_module(binascii)

docs: https://docs.python.org/3/library/binascii.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/binascii.html — Python binascii module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/binascii.c"
  notes:
    - "This spec extends prior binascii specs."
    - "Focus: __module__ and __name__ for binascii functions; crc32 and crc_hqx; additional hexlify/unhexlify."
    - "binascii.hexlify(b'hello') == b'68656c6c6f'."
    - "binascii.unhexlify(b'68656c6c6f') == b'hello'."
    - "binascii.crc32(b'hello') == 907060870 (verified on Darwin)."
    - "binascii.b2a_base64(b'hello') returns b'aGVsbG8=\\n' (with trailing newline)."
    - "binascii.a2b_base64(b'aGVsbG8=') == b'hello'."
    - "binascii.Error.__name__ == 'Error'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table binascii_extra3.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [hexlify,       hexlify.__name__.__eq__,       ["hexlify"],       true]
    - [unhexlify,     unhexlify.__name__.__eq__,     ["unhexlify"],     true]
    - [crc32,         crc32.__name__.__eq__,         ["crc32"],         true]
    - [b2a_base64,    b2a_base64.__name__.__eq__,    ["b2a_base64"],    true]
    - [a2b_base64,    a2b_base64.__name__.__eq__,    ["a2b_base64"],    true]
    - [b2a_hex,       b2a_hex.__name__.__eq__,       ["hexlify"],       true]
    - [a2b_hex,       a2b_hex.__name__.__eq__,       ["unhexlify"],     true]

invariant binascii_extra3.hexlify.hello:
  description: "binascii.hexlify(b'hello') == b'68656c6c6f'"
  category: hexlify
  kind: python_call_eq
  function: hexlify
  args: [!hex 68656c6c6f]
  expected: !ascii "68656c6c6f"

invariant binascii_extra3.unhexlify.hello:
  description: "binascii.unhexlify(b'68656c6c6f') == b'hello'"
  category: unhexlify
  kind: python_call_eq
  function: unhexlify
  args: [!ascii "68656c6c6f"]
  expected: !hex 68656c6c6f

invariant binascii_extra3.crc32.hello:
  description: "binascii.crc32(b'hello') == 907060870"
  category: crc32
  kind: python_call_eq
  function: crc32
  args: [!hex 68656c6c6f]
  expected: 907060870

invariant binascii_extra3.a2b_base64.hello:
  description: "binascii.a2b_base64(b'aGVsbG8=') == b'hello'"
  category: base64
  kind: python_call_eq
  function: a2b_base64
  args: [!ascii "aGVsbG8="]
  expected: !hex 68656c6c6f

invariant binascii_extra3.Error.class_name:
  description: "binascii.Error.__name__ == 'Error'"
  category: exceptions
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

invariant binascii_extra3.Error.base:
  description: "binascii.Error.__bases__[0].__name__ == 'ValueError'"
  category: exceptions
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ValueError"

invariant binascii_extra3.Incomplete.class_name:
  description: "binascii.Incomplete.__name__ == 'Incomplete'"
  category: exceptions
  kind: python_call_eq
  function: Incomplete.__name__.__eq__
  args: ["Incomplete"]
  expected: true
