spec: multiprocessing_extra261
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
  notes:
    - "multiprocessing.__name__ == 'multiprocessing' and __package__ == 'multiprocessing' (top-level package)."
    - "multiprocessing.__spec__.name == 'multiprocessing' and __spec__.parent == 'multiprocessing'."
    - "multiprocessing.__spec__.__class__.__name__ == 'ModuleSpec' (importlib.machinery.ModuleSpec)."
    - "multiprocessing.__loader__.__class__.__name__ == 'SourceFileLoader' (file-system package)."
    - "multiprocessing.context.__name__ == 'multiprocessing.context' and __package__ == 'multiprocessing'."
    - "multiprocessing.process.__name__ == 'multiprocessing.process'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing module __spec__ and __package__ identity — table
#
# Module-level attributes: __name__, __package__, __spec__.name,
# __spec__.parent, __spec__.__class__.__name__, __loader__.__class__.__name__.
# ---------------------------------------------------------------------------

table multiprocessing_extra261.mp_module_spec_identity:
  description: "multiprocessing module __spec__ and __package__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: mpspec

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,       multiprocessing.__name__.__eq__,                        ["multiprocessing"], true, "multiprocessing.__name__ == 'multiprocessing'"]
    - [pkg_eq,        multiprocessing.__package__.__eq__,                     ["multiprocessing"], true, "multiprocessing.__package__ == 'multiprocessing'"]
    - [spec_name_eq,  multiprocessing.__spec__.name.__eq__,                   ["multiprocessing"], true, "multiprocessing.__spec__.name == 'multiprocessing'"]
    - [spec_cls_eq,   multiprocessing.__spec__.__class__.__name__.__eq__,     ["ModuleSpec"],      true, "multiprocessing.__spec__.__class__.__name__ == 'ModuleSpec'"]
    - [loader_cls_eq, multiprocessing.__loader__.__class__.__name__.__eq__,   ["SourceFileLoader"], true, "multiprocessing.__loader__.__class__.__name__ == 'SourceFileLoader'"]

# ---------------------------------------------------------------------------
# multiprocessing submodule __name__ and __package__ — table
#
# multiprocessing.context and multiprocessing.process submodule identity.
# ---------------------------------------------------------------------------

table multiprocessing_extra261.mp_submodule_identity:
  description: "multiprocessing submodule __name__ and __package__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: mpsub

  columns: [id, function, args, expected, description]
  rows:
    - [ctx_name,  multiprocessing.context.__name__.__eq__,    ["multiprocessing.context"],  true, "multiprocessing.context.__name__ == 'multiprocessing.context'"]
    - [ctx_pkg,   multiprocessing.context.__package__.__eq__, ["multiprocessing"],           true, "multiprocessing.context.__package__ == 'multiprocessing'"]
    - [prc_name,  multiprocessing.process.__name__.__eq__,    ["multiprocessing.process"],  true, "multiprocessing.process.__name__ == 'multiprocessing.process'"]
    - [ctx_ldr,   multiprocessing.context.__loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true, "multiprocessing.context.__loader__.__class__.__name__ == 'SourceFileLoader'"]
    - [ctx_spec,  multiprocessing.context.__spec__.name.__eq__, ["multiprocessing.context"], true, "multiprocessing.context.__spec__.name == 'multiprocessing.context'"]

# ---------------------------------------------------------------------------
# multiprocessing.__spec__.parent — standalone invariant
# ---------------------------------------------------------------------------

invariant multiprocessing_extra261.mp_spec_parent:
  description: "multiprocessing.__spec__.parent == 'multiprocessing'"
  category: identity
  kind: python_call_eq
  function: multiprocessing.__spec__.parent.__eq__
  args: ["multiprocessing"]
  expected: true

# ---------------------------------------------------------------------------
# multiprocessing.process.__package__ — standalone invariant
# ---------------------------------------------------------------------------

invariant multiprocessing_extra261.mp_process_package:
  description: "multiprocessing.process.__package__ == 'multiprocessing'"
  category: identity
  kind: python_call_eq
  function: multiprocessing.process.__package__.__eq__
  args: ["multiprocessing"]
  expected: true

# ---------------------------------------------------------------------------
# multiprocessing.process.__spec__.name — standalone invariant
# ---------------------------------------------------------------------------

invariant multiprocessing_extra261.mp_process_spec_name:
  description: "multiprocessing.process.__spec__.name == 'multiprocessing.process'"
  category: identity
  kind: python_call_eq
  function: multiprocessing.process.__spec__.name.__eq__
  args: ["multiprocessing.process"]
  expected: true

# ---------------------------------------------------------------------------
# multiprocessing.__spec__.__class__.__name__ is ModuleSpec — standalone invariant
# ---------------------------------------------------------------------------

invariant multiprocessing_extra261.mp_spec_class_ModuleSpec:
  description: "multiprocessing.__spec__.__class__.__name__ == 'ModuleSpec'"
  category: identity
  kind: python_call_eq
  function: multiprocessing.__spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true
