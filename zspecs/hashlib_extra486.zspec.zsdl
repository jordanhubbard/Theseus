spec: hashlib_extra486
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — BLAKE2 hash objects"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "blake2b and blake2s expose the same HASH interface methods"
    - "digest_size, block_size, and name are getset_descriptor attributes on the class"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra486.blake2b_method_names:
  description: "hashlib.blake2b HASH method __name__ attributes"
  kind: python_call_eq
  category: method_identity
  id_prefix: b2b

  columns: [id, function, args, expected]
  rows:
    - [b2b001, blake2b.copy.__name__.__eq__,      ["copy"],      true]
    - [b2b002, blake2b.digest.__name__.__eq__,    ["digest"],    true]
    - [b2b003, blake2b.hexdigest.__name__.__eq__, ["hexdigest"], true]
    - [b2b004, blake2b.update.__name__.__eq__,    ["update"],    true]

table hashlib_extra486.blake2s_method_names:
  description: "hashlib.blake2s HASH method __name__ attributes"
  kind: python_call_eq
  category: method_identity
  id_prefix: b2s

  columns: [id, function, args, expected]
  rows:
    - [b2s001, blake2s.copy.__name__.__eq__,      ["copy"],      true]
    - [b2s002, blake2s.digest.__name__.__eq__,    ["digest"],    true]
    - [b2s003, blake2s.hexdigest.__name__.__eq__, ["hexdigest"], true]
    - [b2s004, blake2s.update.__name__.__eq__,    ["update"],    true]

table hashlib_extra486.blake2b_descriptor_types:
  description: "hashlib.blake2b class-level descriptor attributes are getset_descriptor"
  kind: python_call_eq
  category: attribute_type
  id_prefix: b2d

  columns: [id, function, args, expected]
  rows:
    - [b2d001, blake2b.digest_size.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [b2d002, blake2b.block_size.__class__.__name__.__eq__,  ["getset_descriptor"], true]
    - [b2d003, blake2b.name.__class__.__name__.__eq__,        ["getset_descriptor"], true]
