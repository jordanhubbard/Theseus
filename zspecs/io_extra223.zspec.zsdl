spec: io_extra223
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pyio.py"
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "BytesIO method __name__ and __qualname__ values verified with Python 3.14.3 on macOS/Darwin 25.4.0."
    - "StringIO method __name__ and __qualname__ values verified with Python 3.14.3 on macOS/Darwin 25.4.0."
    - "TextIOWrapper and BufferedReader method __name__ and __qualname__ values verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BytesIO method __name__ checks
# ---------------------------------------------------------------------------

table io_extra223.bytesio_method_names:
  description: "io.BytesIO method __name__ attribute checks — read, write, seek, tell, getvalue, close all return their simple name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ioextra223a

  columns: [id, function, args, expected, description]
  rows:
    - [bytesio_read_name,     io.BytesIO.read.__name__.__eq__,     ["read"],     true, "io.BytesIO.read.__name__ == 'read'; verified with Python 3.14.3"]
    - [bytesio_write_name,    io.BytesIO.write.__name__.__eq__,    ["write"],    true, "io.BytesIO.write.__name__ == 'write'; verified with Python 3.14.3"]
    - [bytesio_seek_name,     io.BytesIO.seek.__name__.__eq__,     ["seek"],     true, "io.BytesIO.seek.__name__ == 'seek'; verified with Python 3.14.3"]
    - [bytesio_tell_name,     io.BytesIO.tell.__name__.__eq__,     ["tell"],     true, "io.BytesIO.tell.__name__ == 'tell'; verified with Python 3.14.3"]
    - [bytesio_getvalue_name, io.BytesIO.getvalue.__name__.__eq__, ["getvalue"], true, "io.BytesIO.getvalue.__name__ == 'getvalue'; verified with Python 3.14.3"]
    - [bytesio_close_name,    io.BytesIO.close.__name__.__eq__,    ["close"],    true, "io.BytesIO.close.__name__ == 'close'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# BytesIO method __qualname__ checks
# ---------------------------------------------------------------------------

table io_extra223.bytesio_method_qualnames:
  description: "io.BytesIO method __qualname__ checks — each method qualname is 'BytesIO.<method>'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ioextra223b

  columns: [id, function, args, expected, description]
  rows:
    - [bytesio_read_qualname,     io.BytesIO.read.__qualname__.__eq__,     ["BytesIO.read"],     true, "io.BytesIO.read.__qualname__ == 'BytesIO.read'; verified with Python 3.14.3"]
    - [bytesio_write_qualname,    io.BytesIO.write.__qualname__.__eq__,    ["BytesIO.write"],    true, "io.BytesIO.write.__qualname__ == 'BytesIO.write'; verified with Python 3.14.3"]
    - [bytesio_seek_qualname,     io.BytesIO.seek.__qualname__.__eq__,     ["BytesIO.seek"],     true, "io.BytesIO.seek.__qualname__ == 'BytesIO.seek'; verified with Python 3.14.3"]
    - [bytesio_tell_qualname,     io.BytesIO.tell.__qualname__.__eq__,     ["BytesIO.tell"],     true, "io.BytesIO.tell.__qualname__ == 'BytesIO.tell'; verified with Python 3.14.3"]
    - [bytesio_getvalue_qualname, io.BytesIO.getvalue.__qualname__.__eq__, ["BytesIO.getvalue"], true, "io.BytesIO.getvalue.__qualname__ == 'BytesIO.getvalue'; verified with Python 3.14.3"]
    - [bytesio_close_qualname,    io.BytesIO.close.__qualname__.__eq__,    ["BytesIO.close"],    true, "io.BytesIO.close.__qualname__ == 'BytesIO.close'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# StringIO and TextIOWrapper/BufferedReader method name checks
# ---------------------------------------------------------------------------

table io_extra223.stringio_and_wrapper_method_names:
  description: "io StringIO, TextIOWrapper and BufferedReader method __name__ checks — each returns the simple method name string; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ioextra223c

  columns: [id, function, args, expected, description]
  rows:
    - [stringio_read_name,        io.StringIO.read.__name__.__eq__,             ["read"],     true, "io.StringIO.read.__name__ == 'read'; verified with Python 3.14.3"]
    - [stringio_write_name,       io.StringIO.write.__name__.__eq__,            ["write"],    true, "io.StringIO.write.__name__ == 'write'; verified with Python 3.14.3"]
    - [stringio_getvalue_name,    io.StringIO.getvalue.__name__.__eq__,         ["getvalue"], true, "io.StringIO.getvalue.__name__ == 'getvalue'; verified with Python 3.14.3"]
    - [stringio_truncate_name,    io.StringIO.truncate.__name__.__eq__,         ["truncate"], true, "io.StringIO.truncate.__name__ == 'truncate'; verified with Python 3.14.3"]
    - [textiow_read_name,         io.TextIOWrapper.read.__name__.__eq__,        ["read"],     true, "io.TextIOWrapper.read.__name__ == 'read'; verified with Python 3.14.3"]
    - [textiow_readline_name,     io.TextIOWrapper.readline.__name__.__eq__,    ["readline"], true, "io.TextIOWrapper.readline.__name__ == 'readline'; verified with Python 3.14.3"]
    - [textiow_write_name,        io.TextIOWrapper.write.__name__.__eq__,       ["write"],    true, "io.TextIOWrapper.write.__name__ == 'write'; verified with Python 3.14.3"]
    - [bufread_read1_name,        io.BufferedReader.read1.__name__.__eq__,      ["read1"],    true, "io.BufferedReader.read1.__name__ == 'read1'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra223.stringio_read_qualname:
  description: "io.StringIO.read.__qualname__ == 'StringIO.read' — qualname encodes the class context for the read method; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: io.StringIO.read.__qualname__.__eq__
  args: ["StringIO.read"]
  expected: true

invariant io_extra223.bufferedreader_peek_qualname:
  description: "io.BufferedReader.peek.__qualname__ == 'BufferedReader.peek' — peek is a BufferedReader-specific method that returns bytes without advancing position; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: io.BufferedReader.peek.__qualname__.__eq__
  args: ["BufferedReader.peek"]
  expected: true

invariant io_extra223.textiowrapper_readline_qualname:
  description: "io.TextIOWrapper.readline.__qualname__ == 'TextIOWrapper.readline' — qualname encodes class context for readline; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: io.TextIOWrapper.readline.__qualname__.__eq__
  args: ["TextIOWrapper.readline"]
  expected: true

invariant io_extra223.bufferedreader_read1_qualname:
  description: "io.BufferedReader.read1.__qualname__ == 'BufferedReader.read1' — read1 reads up to size bytes with at most one raw read call; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: io.BufferedReader.read1.__qualname__.__eq__
  args: ["BufferedReader.read1"]
  expected: true
