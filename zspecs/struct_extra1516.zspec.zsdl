spec: struct_extra1516
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra15.zspec.zsdl — covers calcsize('!BHI')==7; calcsize('!BHIQ')==15; pack('!B',255)==xff; pack('!I',16909060)==x01020304; unpack('!B',xff)==(255,)."
    - "struct_extra14.zspec.zsdl — covers pack('>I',0)/('>I',1)/('>H',256) exact bytes; unpack('>I',00000000)/('>H',0100) exact values."
    - "struct_extra9.zspec.zsdl — covers calcsize('c'/'P'); Struct method descriptor __qualname__/__name__ tables."
    - "struct_extra8.zspec.zsdl — covers function __module__ (all '_struct' except error 'struct'); pack return type/length; Struct('>IHB') format/size."
    - "struct_extra5.zspec.zsdl — covers Struct.__qualname__; Struct('>I'/'>H') format/size; pack('>B',255)."
    - "struct_extra4.zspec.zsdl — covers Struct.__name__; pack_into.__name__; function __qualname__ table; error.__qualname__."
    - "struct_extra2.zspec.zsdl — covers function __name__/__module__; Struct base class."
    - "struct_extra.zspec.zsdl — covers Struct format/size, calcsize extras, pack_into, unpack_from, iter_unpack, error name/bases."
  notes:
    - "This spec is wave 548 / suffix _extra1516. Theme: arithmetic/numeric operator dict-presence checks on struct.Struct."
    - "struct.Struct is a compiled binary layout descriptor. It is not numeric and has no arithmetic operators."
    - "Verified: struct.Struct.__dict__.__contains__('__add__') == False."
    - "Verified: struct.Struct.__dict__.__contains__('__mul__') == False."
    - "Verified: struct.Struct.__dict__.__contains__('__sub__') == False."
    - "Verified: struct.Struct.__dict__.__contains__('__truediv__') == False."
    - "Verified: struct.Struct.__dict__.__contains__('__floordiv__') == False."
    - "Verified: struct.Struct.__dict__.__contains__('__mod__') == False."
    - "Verified: struct.Struct.__dict__.__contains__('__pow__') == False."
    - "Verified True: pack, unpack, pack_into, unpack_from, iter_unpack, __new__, __init__, __repr__, size, format, __sizeof__, __module__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct — arithmetic operator absence checks
#
# struct.Struct is a C-extension type that describes a binary data layout.
# It exposes packing/unpacking methods and format/size attributes, but no
# arithmetic operators. The seven standard arithmetic dunders are all absent
# from its __dict__. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-12.
# ---------------------------------------------------------------------------

table struct_extra1516.Struct_arith_absent:
  description: "Arithmetic operator dunders absent from struct.Struct.__dict__ — Struct is not a numeric type"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st1516aa

  columns: [id, function, args, expected]
  rows:
    - ["st1516aa001", "Struct.__dict__.__contains__", ["__add__"],      false]
    - ["st1516aa002", "Struct.__dict__.__contains__", ["__mul__"],      false]
    - ["st1516aa003", "Struct.__dict__.__contains__", ["__sub__"],      false]
    - ["st1516aa004", "Struct.__dict__.__contains__", ["__truediv__"],  false]
    - ["st1516aa005", "Struct.__dict__.__contains__", ["__floordiv__"], false]
    - ["st1516aa006", "Struct.__dict__.__contains__", ["__mod__"],      false]
    - ["st1516aa007", "Struct.__dict__.__contains__", ["__pow__"],      false]

# ---------------------------------------------------------------------------
# struct.Struct — packing/unpacking method presence checks
#
# The core Struct API (pack, unpack, pack_into, unpack_from, iter_unpack)
# and lifecycle dunders (__new__, __init__, __repr__) are all present in
# Struct.__dict__. These True entries validate the dict-presence mechanism
# and contrast clearly with the False arithmetic entries.
# ---------------------------------------------------------------------------

table struct_extra1516.Struct_methods_present:
  description: "Core packing/unpacking methods and lifecycle dunders present in struct.Struct.__dict__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st1516mp

  columns: [id, function, args, expected]
  rows:
    - ["st1516mp001", "Struct.__dict__.__contains__", ["pack"],         true]
    - ["st1516mp002", "Struct.__dict__.__contains__", ["unpack"],       true]
    - ["st1516mp003", "Struct.__dict__.__contains__", ["pack_into"],    true]
    - ["st1516mp004", "Struct.__dict__.__contains__", ["unpack_from"],  true]
    - ["st1516mp005", "Struct.__dict__.__contains__", ["iter_unpack"],  true]
    - ["st1516mp006", "Struct.__dict__.__contains__", ["__new__"],      true]
    - ["st1516mp007", "Struct.__dict__.__contains__", ["__init__"],     true]
    - ["st1516mp008", "Struct.__dict__.__contains__", ["__repr__"],     true]
    - ["st1516mp009", "Struct.__dict__.__contains__", ["size"],         true]
    - ["st1516mp010", "Struct.__dict__.__contains__", ["format"],       true]

# ---------------------------------------------------------------------------
# struct.Struct — descriptor and meta-attribute presence checks
#
# struct.Struct stores additional implementation-level attributes in __dict__:
# __sizeof__ (memory size helper), __module__ (source module), and
# __getattribute__/__setattr__/__delattr__ (attribute access overrides).
# These confirm the full scope of what Struct __dict__ holds.
# ---------------------------------------------------------------------------

table struct_extra1516.Struct_meta_present:
  description: "Meta-attribute dunders present in struct.Struct.__dict__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st1516me

  columns: [id, function, args, expected]
  rows:
    - ["st1516me001", "Struct.__dict__.__contains__", ["__sizeof__"],       true]
    - ["st1516me002", "Struct.__dict__.__contains__", ["__module__"],       true]
    - ["st1516me003", "Struct.__dict__.__contains__", ["__getattribute__"], true]
    - ["st1516me004", "Struct.__dict__.__contains__", ["__setattr__"],      true]
    - ["st1516me005", "Struct.__dict__.__contains__", ["__delattr__"],      true]
    - ["st1516me006", "Struct.__dict__.__contains__", ["__doc__"],          true]
    - ["st1516me007", "Struct.__dict__.__contains__", ["__add__"],          false]
    - ["st1516me008", "Struct.__dict__.__contains__", ["__mul__"],          false]
