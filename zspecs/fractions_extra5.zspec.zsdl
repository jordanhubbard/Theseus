spec: fractions_extra5
version: ">=3.9"
backend: python_module(fractions)

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html — Python fractions documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fractions.py"
  notes:
    - "This spec extends fractions.zspec.zsdl and prior extras."
    - "fractions.zspec covers: Fraction.__name__, constructor, arithmetic, comparison, limit_denominator, error cases."
    - "fractions_extra covers: Fraction.__module__, Fraction.__bases__[0].__name__ == 'Rational', Fraction(3,6).numerator/denominator, instance class names."
    - "fractions_extra2 covers: Fraction.__module__, MRO[1].__name__, repr, limit_denominator, Fraction(6,4) reduction, subtraction, equals_integer."
    - "fractions_extra3 covers: Fraction.__qualname__, Fraction.__module__, bases, Fraction(1,3) instance, Fraction(2,4) reduction, Fraction('3/5') from string."
    - "fractions_extra4 covers: Fraction.__name__, Fraction.__module__, Fraction.__qualname__, Fraction(1,3).__class__.__name__, Fraction(1,3).numerator/denominator, Fraction(2,4) reduction, Fraction(0,5).numerator, Fraction(-1,3).numerator/denominator."
    - "This spec adds: Fraction.__bases__.__len__ == 1, Fraction.__mro__[2].__name__ == 'Real', and auto-reduction for new input vectors (4/8, 5/15, 9/12, 8/12)."
    - "Fraction(4, 8) auto-reduces to 1/2 — same GCD path as Fraction(2,4) but distinct constructor args."
    - "Fraction(5, 15) auto-reduces to 1/3 — GCD is 5."
    - "Fraction(9, 12) auto-reduces to 3/4 — GCD is 3."
    - "Fraction(8, 12) auto-reduces to 2/3 — GCD is 4."
    - "Fraction.__bases__ has length 1 — Fraction has a single direct base class (numbers.Rational)."
    - "Fraction.__mro__[2].__name__ == 'Real' — third entry in the MRO is numbers.Real."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class hierarchy — __bases__ length and MRO entry
# Not covered in prior specs: bases length for Fraction, MRO[2] entry.
# ---------------------------------------------------------------------------

invariant fractions_extra5.Fraction.bases_len:
  description: "fractions.Fraction.__bases__.__len__() == 1 — Fraction has a single direct base class"
  category: class_hierarchy
  kind: python_call_eq
  function: Fraction.__bases__.__len__
  args: []
  expected: 1

invariant fractions_extra5.Fraction.mro_real:
  description: "fractions.Fraction.__mro__[2].__name__ == 'Real' — third entry in MRO is numbers.Real"
  category: class_hierarchy
  kind: python_call_eq
  function: Fraction.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "Real"

# ---------------------------------------------------------------------------
# Auto-reduction: Fraction(4, 8) reduces to 1/2
# Distinct from fractions_extra (Fraction(3,6)) and fractions_extra2 (Fraction(2,4), Fraction(6,4)).
# ---------------------------------------------------------------------------

invariant fractions_extra5.Fraction_4_8.numerator:
  description: "fractions.Fraction(4, 8).numerator == 1 — 4/8 auto-reduces to 1/2 (GCD == 4)"
  category: reduction
  kind: python_call_eq
  function: Fraction
  args: [4, 8]
  method: numerator.__eq__
  method_args: [1]
  expected: true

invariant fractions_extra5.Fraction_4_8.denominator:
  description: "fractions.Fraction(4, 8).denominator == 2 — 4/8 auto-reduces to 1/2 (GCD == 4)"
  category: reduction
  kind: python_call_eq
  function: Fraction
  args: [4, 8]
  method: denominator.__eq__
  method_args: [2]
  expected: true

# ---------------------------------------------------------------------------
# Auto-reduction: Fraction(5, 15) reduces to 1/3
# ---------------------------------------------------------------------------

invariant fractions_extra5.Fraction_5_15.numerator:
  description: "fractions.Fraction(5, 15).numerator == 1 — 5/15 auto-reduces to 1/3 (GCD == 5)"
  category: reduction
  kind: python_call_eq
  function: Fraction
  args: [5, 15]
  method: numerator.__eq__
  method_args: [1]
  expected: true

invariant fractions_extra5.Fraction_5_15.denominator:
  description: "fractions.Fraction(5, 15).denominator == 3 — 5/15 auto-reduces to 1/3 (GCD == 5)"
  category: reduction
  kind: python_call_eq
  function: Fraction
  args: [5, 15]
  method: denominator.__eq__
  method_args: [3]
  expected: true

# ---------------------------------------------------------------------------
# Auto-reduction: Fraction(9, 12) reduces to 3/4
# ---------------------------------------------------------------------------

invariant fractions_extra5.Fraction_9_12.numerator:
  description: "fractions.Fraction(9, 12).numerator == 3 — 9/12 auto-reduces to 3/4 (GCD == 3)"
  category: reduction
  kind: python_call_eq
  function: Fraction
  args: [9, 12]
  method: numerator.__eq__
  method_args: [3]
  expected: true

invariant fractions_extra5.Fraction_9_12.denominator:
  description: "fractions.Fraction(9, 12).denominator == 4 — 9/12 auto-reduces to 3/4 (GCD == 3)"
  category: reduction
  kind: python_call_eq
  function: Fraction
  args: [9, 12]
  method: denominator.__eq__
  method_args: [4]
  expected: true

# ---------------------------------------------------------------------------
# Auto-reduction: Fraction(8, 12) reduces to 2/3
# ---------------------------------------------------------------------------

invariant fractions_extra5.Fraction_8_12.numerator:
  description: "fractions.Fraction(8, 12).numerator == 2 — 8/12 auto-reduces to 2/3 (GCD == 4)"
  category: reduction
  kind: python_call_eq
  function: Fraction
  args: [8, 12]
  method: numerator.__eq__
  method_args: [2]
  expected: true

invariant fractions_extra5.Fraction_8_12.denominator:
  description: "fractions.Fraction(8, 12).denominator == 3 — 8/12 auto-reduces to 2/3 (GCD == 4)"
  category: reduction
  kind: python_call_eq
  function: Fraction
  args: [8, 12]
  method: denominator.__eq__
  method_args: [3]
  expected: true

# ---------------------------------------------------------------------------
# Reduction table — __str__ form of auto-reduced fractions
# New input vectors not used in prior specs.
# ---------------------------------------------------------------------------

table fractions_extra5.reductions:
  kind: python_call_eq
  category: reduction
  id_prefix: reduced
  function: Fraction
  method: __str__
  method_args: []

  columns: [id, args, expected]
  rows:
    - [four_eighths,   [4,  8],  "1/2"]
    - [five_fifteenths,[5, 15],  "1/3"]
    - [nine_twelfths,  [9, 12],  "3/4"]
    - [eight_twelfths, [8, 12],  "2/3"]
