spec: unicodedata
version: ">=3.0"
backend: python_module(unicodedata)

docs: https://docs.python.org/3/library/unicodedata.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unicodedata.html — Python unicodedata module documentation"
    - "Unicode Standard — https://www.unicode.org/versions/latest/"
    - "Test vectors verified by running Python 3.14.3 unicodedata module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/unicodedata.c"
  notes:
    - "unicodedata.name(char) returns the Unicode name in ALL CAPS."
    - "unicodedata.lookup(name) is the inverse of name(); it accepts names in any case."
    - "unicodedata.category() returns a two-letter category code (e.g. Lu, Ll, Nd, Po, Zs)."
    - "unicodedata.bidirectional() returns the bidi class string (e.g. L, R, EN, AN, WS)."
    - "unicodedata.combining() returns an int in [0, 240]; 0 means non-combining."
    - "unicodedata.east_asian_width() returns one of: Na, N, W, F, H, A."
    - "unicodedata.decomposition() returns empty string for characters with no decomposition mapping."
    - "unicodedata.decimal() raises ValueError for characters that are not decimal digits."
    - "unicodedata.numeric() returns a float (e.g. 0.5 for VULGAR FRACTION ONE HALF U+00BD)."
    - "unicodedata.normalize() applies one of NFC, NFD, NFKC, NFKD normalization forms."
    - "unicodedata.is_normalized() returns bool; added in Python 3.11."
    - "unicodedata.unidata_version is a module-level string attribute (e.g. '15.0.0')."
    - "All expected values verified by running Python 3.14.3 on macOS Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# name() — Unicode character name
# ---------------------------------------------------------------------------

table unicodedata.name.vectors:
  kind: python_call_eq
  category: name
  id_prefix: name
  function: name

  columns: [id, args, expected]
  rows:
    - [capital_a,   ["A"],  "LATIN CAPITAL LETTER A"]
    - [small_a,     ["a"],  "LATIN SMALL LETTER A"]
    - [digit_zero,  ["0"],  "DIGIT ZERO"]
    - [euro_sign,   ["€"],  "EURO SIGN"]

# ---------------------------------------------------------------------------
# lookup() — character from Unicode name (inverse of name())
# ---------------------------------------------------------------------------

invariant unicodedata.lookup.capital_a:
  description: "unicodedata.lookup('LATIN CAPITAL LETTER A') == 'A'"
  category: lookup
  kind: python_call_eq
  function: lookup
  args: ["LATIN CAPITAL LETTER A"]
  expected: "A"

invariant unicodedata.lookup.digit_zero:
  description: "unicodedata.lookup('DIGIT ZERO') == '0'"
  category: lookup
  kind: python_call_eq
  function: lookup
  args: ["DIGIT ZERO"]
  expected: "0"

invariant unicodedata.lookup.unknown_raises:
  description: "unicodedata.lookup('NONEXISTENT NAME') raises KeyError"
  category: lookup
  kind: python_call_raises
  function: lookup
  args: ["NONEXISTENT NAME"]
  expected_exception: KeyError

# ---------------------------------------------------------------------------
# category() — Unicode general category
# ---------------------------------------------------------------------------

table unicodedata.category.vectors:
  kind: python_call_eq
  category: category
  id_prefix: category
  function: category

  columns: [id, args, expected]
  rows:
    - [uppercase_letter, ["A"],  "Lu"]
    - [lowercase_letter, ["a"],  "Ll"]
    - [decimal_digit,    ["0"],  "Nd"]
    - [other_punct,      ["!"],  "Po"]
    - [space_separator,  [" "],  "Zs"]

# ---------------------------------------------------------------------------
# bidirectional() — bidi class string
# ---------------------------------------------------------------------------

invariant unicodedata.bidirectional.latin_letter:
  description: "unicodedata.bidirectional('A') == 'L' (left-to-right)"
  category: bidirectional
  kind: python_call_eq
  function: bidirectional
  args: ["A"]
  expected: "L"

invariant unicodedata.bidirectional.digit:
  description: "unicodedata.bidirectional('0') == 'EN' (European number)"
  category: bidirectional
  kind: python_call_eq
  function: bidirectional
  args: ["0"]
  expected: "EN"

# ---------------------------------------------------------------------------
# combining() — combining class integer
# ---------------------------------------------------------------------------

invariant unicodedata.combining.ascii_letter:
  description: "unicodedata.combining('A') == 0 (non-combining)"
  category: combining
  kind: python_call_eq
  function: combining
  args: ["A"]
  expected: 0

invariant unicodedata.combining.digit:
  description: "unicodedata.combining('0') == 0 (non-combining)"
  category: combining
  kind: python_call_eq
  function: combining
  args: ["0"]
  expected: 0

# ---------------------------------------------------------------------------
# east_asian_width() — width classification
# ---------------------------------------------------------------------------

invariant unicodedata.east_asian_width.narrow:
  description: "unicodedata.east_asian_width('A') == 'Na' (narrow ASCII)"
  category: east_asian_width
  kind: python_call_eq
  function: east_asian_width
  args: ["A"]
  expected: "Na"

invariant unicodedata.east_asian_width.wide:
  description: "unicodedata.east_asian_width('中') == 'W' (wide CJK ideograph)"
  category: east_asian_width
  kind: python_call_eq
  function: east_asian_width
  args: ["中"]
  expected: "W"

# ---------------------------------------------------------------------------
# decomposition() — decomposition mapping string
# ---------------------------------------------------------------------------

invariant unicodedata.decomposition.ascii_no_decomp:
  description: "unicodedata.decomposition('A') == '' (ASCII has no decomposition)"
  category: decomposition
  kind: python_call_eq
  function: decomposition
  args: ["A"]
  expected: ""

# ---------------------------------------------------------------------------
# decimal() — decimal digit value
# ---------------------------------------------------------------------------

invariant unicodedata.decimal.zero:
  description: "unicodedata.decimal('0') == 0"
  category: decimal
  kind: python_call_eq
  function: decimal
  args: ["0"]
  expected: 0

invariant unicodedata.decimal.nine:
  description: "unicodedata.decimal('9') == 9"
  category: decimal
  kind: python_call_eq
  function: decimal
  args: ["9"]
  expected: 9

invariant unicodedata.decimal.letter_raises:
  description: "unicodedata.decimal('A') raises ValueError (not a decimal digit)"
  category: decimal
  kind: python_call_raises
  function: decimal
  args: ["A"]
  expected_exception: ValueError

# ---------------------------------------------------------------------------
# numeric() — numeric value as float
# ---------------------------------------------------------------------------

invariant unicodedata.numeric.half:
  description: "unicodedata.numeric('½') == 0.5 (VULGAR FRACTION ONE HALF)"
  category: numeric
  kind: python_call_eq
  function: numeric
  args: ["½"]
  expected: 0.5

invariant unicodedata.numeric.digit_five:
  description: "unicodedata.numeric('5') == 5.0"
  category: numeric
  kind: python_call_eq
  function: numeric
  args: ["5"]
  expected: 5.0

# ---------------------------------------------------------------------------
# normalize() — Unicode normalization
# ---------------------------------------------------------------------------

invariant unicodedata.normalize.nfc_ascii:
  description: "unicodedata.normalize('NFC', 'A') == 'A' (ASCII unchanged)"
  category: normalize
  kind: python_call_eq
  function: normalize
  args: ["NFC", "A"]
  expected: "A"

invariant unicodedata.normalize.nfd_ascii:
  description: "unicodedata.normalize('NFD', 'A') == 'A' (ASCII unchanged under NFD)"
  category: normalize
  kind: python_call_eq
  function: normalize
  args: ["NFD", "A"]
  expected: "A"

# ---------------------------------------------------------------------------
# unidata_version — module-level version string attribute
# ---------------------------------------------------------------------------

invariant unicodedata.version.gt_empty:
  description: "unicodedata.unidata_version > '' (non-empty string)"
  category: version
  kind: python_call_eq
  function: unidata_version.__gt__
  args: [""]
  expected: true
