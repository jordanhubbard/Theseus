  description: "functools.total_ordering.__name__ == 'total_ordering' (len=14); new to extra245"
  kind: python_call_eq
  function: total_ordering.__name__.__eq__
  args: ["total_ordering"]
  expected: true

invariant functools_extra245.totalord_name_len_14:
  description: "functools.total_ordering.__name__.__len__() == 14 — 'total_ordering' has 14 characters; new to extra245"
  kind: python_call_eq
