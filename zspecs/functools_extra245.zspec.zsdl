spec: functools_extra245
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "functools_extra244.zspec.zsdl — covers functools.reduce and functools.partial identity"
  notes:
    - "This spec covers functools.cached_property class identity and functools.total_ordering decorator identity."
    - "functools.cached_property.__name__ == 'cached_property' (len=15) — cached_property is a class in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.cached_property.__module__ == 'functools' (len=9) — cached_property is defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.cached_property.__bases__[0].__name__ == 'object' — cached_property inherits directly from object. Verified with Python 3.14.3."
    - "functools.cached_property.__class__.__name__ == 'type' — cached_property is a class; its metaclass is type. Verified with Python 3.14.3."
    - "functools.cached_property.__qualname__ == 'cached_property' (len=15) — same as __name__ for top-level class. Verified with Python 3.14.3."
    - "functools.cached_property.__doc__ is None — cached_property has no docstring in Python 3.14.3. Verified with Python 3.14.3."
    - "functools.total_ordering.__name__ == 'total_ordering' (len=14) — total_ordering is a decorator function in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.total_ordering.__module__ == 'functools' (len=9) — total_ordering is defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.total_ordering.__class__.__name__ == 'function' — total_ordering is a plain Python function used as a class decorator. Verified with Python 3.14.3."
    - "functools.total_ordering.__qualname__ == 'total_ordering' (len=14) — same as __name__ for top-level function. Verified with Python 3.14.3."
    - "functools.total_ordering.__doc__ == 'Class decorator that fills in missing ordering methods' (len=54). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.cached_property identity contracts
#
# functools.cached_property.__name__ == 'cached_property' (len=15)
# functools.cached_property.__module__ == 'functools' (len=9)
# functools.cached_property.__bases__[0].__name__ == 'object'
# functools.cached_property.__class__.__name__ == 'type'
# functools.cached_property.__qualname__ == 'cached_property' (len=15)
#
# cached_property is a class in Lib/functools.py. New to extra245.
# ---------------------------------------------------------------------------

table functools_extra245.cachedprop245_identity:
  description: "functools.cached_property identity: name, module, bases, class, qualname; new to extra245"
  kind: python_call_eq
  category: identity
  id_prefix: cachedprop245

  columns: [id, function, args, expected, description]
  rows:
    - [cachedprop_name_eq,
       cached_property.__name__.__eq__,
       ["cached_property"],
       true,
       "functools.cached_property.__name__.__eq__('cached_property') == True — cached_property is a class in Lib/functools.py; __name__ is 'cached_property' (len=15); new to extra245"]
    - [cachedprop_name_len_15,
       cached_property.__name__.__len__,
       [],
       15,
       "functools.cached_property.__name__.__len__() == 15 — 'cached_property' has exactly 15 characters; str.__len__() returns 15; new to extra245"]
    - [cachedprop_module_eq,
       cached_property.__module__.__eq__,
       ["functools"],
       true,
       "functools.cached_property.__module__.__eq__('functools') == True — cached_property is defined in Lib/functools.py; __module__ is 'functools' (len=9); new to extra245"]
    - [cachedprop_module_len_9,
       cached_property.__module__.__len__,
       [],
       9,
       "functools.cached_property.__module__.__len__() == 9 — 'functools' has exactly 9 characters; str.__len__() returns 9; new to extra245"]
    - [cachedprop_bases_0_is_object,
       "cached_property.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.cached_property.__bases__[0].__name__.__eq__('object') == True — cached_property inherits directly from object; __bases__[0] is object; new to extra245"]

# ---------------------------------------------------------------------------
# Table 2: functools.cached_property class and qualname contracts
#
# functools.cached_property.__class__.__name__ == 'type'
# functools.cached_property.__qualname__ == 'cached_property' (len=15)
# functools.cached_property.__doc__ is None (no docstring)
#
# New to extra245.
# ---------------------------------------------------------------------------

table functools_extra245.cachedprop245_class:
  description: "functools.cached_property class, qualname, doc-is-None checks; new to extra245"
  kind: python_call_eq
  category: identity
  id_prefix: cachedprop245cls

  columns: [id, function, args, expected, description]
  rows:
    - [cachedprop_class_is_type,
       cached_property.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.cached_property.__class__.__name__.__eq__('type') == True — cached_property is a class; its metaclass is the built-in type; new to extra245"]
    - [cachedprop_qualname_eq,
       cached_property.__qualname__.__eq__,
       ["cached_property"],
       true,
       "functools.cached_property.__qualname__.__eq__('cached_property') == True — __qualname__ is 'cached_property' (len=15); same as __name__ for top-level class; new to extra245"]
    - [cachedprop_qualname_len_15,
       cached_property.__qualname__.__len__,
       [],
       15,
       "functools.cached_property.__qualname__.__len__() == 15 — 'cached_property' has exactly 15 characters; str.__len__() returns 15; new to extra245"]
    - [cachedprop_doc_is_none,
       cached_property.__doc__.__eq__,
       [null],
       true,
       "functools.cached_property.__doc__.__eq__(None) == True — cached_property has no docstring in Python 3.14.3; __doc__ is None; new to extra245"]
    - [cachedprop_module_contains_functools,
       cached_property.__module__.__contains__,
       ["functools"],
       true,
       "functools.cached_property.__module__.__contains__('functools') == True — 'functools' contains the substring 'functools'; new to extra245"]

# ---------------------------------------------------------------------------
# Table 3: functools.total_ordering identity contracts
#
# functools.total_ordering.__name__ == 'total_ordering' (len=14)
# functools.total_ordering.__module__ == 'functools' (len=9)
# functools.total_ordering.__class__.__name__ == 'function'
# functools.total_ordering.__qualname__ == 'total_ordering' (len=14)
# functools.total_ordering.__doc__ == 'Class decorator that fills in missing ordering methods' (len=54)
#
# total_ordering is a decorator function in Lib/functools.py. New to extra245.
# ---------------------------------------------------------------------------

table functools_extra245.totalord245_identity:
  description: "functools.total_ordering identity: name, module, class, qualname, doc; new to extra245"
  kind: python_call_eq
  category: identity
  id_prefix: totalord245

  columns: [id, function, args, expected, description]
  rows:
    - [totalord_name_eq,
       total_ordering.__name__.__eq__,
       ["total_ordering"],
       true,
       "functools.total_ordering.__name__.__eq__('total_ordering') == True — total_ordering is a decorator function in Lib/functools.py; __name__ is 'total_ordering' (len=14); new to extra245"]
    - [totalord_name_len_14,
       total_ordering.__name__.__len__,
       [],
       14,
       "functools.total_ordering.__name__.__len__() == 14 — 'total_ordering' has exactly 14 characters; str.__len__() returns 14; new to extra245"]
    - [totalord_module_eq,
       total_ordering.__module__.__eq__,
       ["functools"],
       true,
       "functools.total_ordering.__module__.__eq__('functools') == True — total_ordering is defined in Lib/functools.py; __module__ is 'functools' (len=9); new to extra245"]
    - [totalord_module_len_9,
       total_ordering.__module__.__len__,
       [],
       9,
       "functools.total_ordering.__module__.__len__() == 9 — 'functools' has exactly 9 characters; str.__len__() returns 9; new to extra245"]
    - [totalord_class_is_function,
       total_ordering.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.total_ordering.__class__.__name__.__eq__('function') == True — total_ordering is a plain Python function; its __class__ is 'function'; new to extra245"]

# ---------------------------------------------------------------------------
# Table 4: functools.total_ordering qualname and doc contracts
#
# functools.total_ordering.__qualname__ == 'total_ordering' (len=14)
# functools.total_ordering.__doc__ contains 'decorator' == True
# functools.total_ordering.__doc__ contains 'ordering' == True
# functools.total_ordering.__doc__.__len__() == 54
#
# New to extra245.
# ---------------------------------------------------------------------------

table functools_extra245.totalord245_doc:
  description: "functools.total_ordering qualname and doc checks; new to extra245"
  kind: python_call_eq
  category: identity
  id_prefix: totalord245doc

  columns: [id, function, args, expected, description]
  rows:
    - [totalord_qualname_eq,
       total_ordering.__qualname__.__eq__,
       ["total_ordering"],
       true,
       "functools.total_ordering.__qualname__.__eq__('total_ordering') == True — __qualname__ is 'total_ordering' (len=14); same as __name__ for top-level function; new to extra245"]
    - [totalord_qualname_len_14,
       total_ordering.__qualname__.__len__,
       [],
       14,
       "functools.total_ordering.__qualname__.__len__() == 14 — 'total_ordering' has exactly 14 characters; str.__len__() returns 14; new to extra245"]
    - [totalord_doc_contains_decorator,
       total_ordering.__doc__.__contains__,
       ["decorator"],
       true,
       "functools.total_ordering.__doc__.__contains__('decorator') == True — docstring says 'Class decorator that fills in missing ordering methods'; new to extra245"]
    - [totalord_doc_contains_ordering,
       total_ordering.__doc__.__contains__,
       ["ordering"],
       true,
       "functools.total_ordering.__doc__.__contains__('ordering') == True — docstring says 'Class decorator that fills in missing ordering methods'; new to extra245"]
    - [totalord_doc_len_54,
       total_ordering.__doc__.__len__,
       [],
       54,
       "functools.total_ordering.__doc__.__len__() == 54 — 'Class decorator that fills in missing ordering methods' has exactly 54 characters; new to extra245"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra245
# ---------------------------------------------------------------------------

invariant functools_extra245.cachedprop_name_eq:
  description: "functools.cached_property.__name__ == 'cached_property' (len=15); new to extra245"
  kind: python_call_eq
  function: cached_property.__name__.__eq__
  args: ["cached_property"]
  expected: true

invariant functools_extra245.cachedprop_name_len_15:
  description: "functools.cached_property.__name__.__len__() == 15 — 'cached_property' has 15 characters; new to extra245"
  kind: python_call_eq
  function: cached_property.__name__.__len__
  args: []
  expected: 15

invariant functools_extra245.cachedprop_module_eq:
  description: "functools.cached_property.__module__ == 'functools' — defined in Lib/functools.py; new to extra245"
