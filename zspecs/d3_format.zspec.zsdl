spec: d3_format
version: ">=3.0.0"
backend: node(d3-format)

docs: https://d3js.org/d3-format

provenance:
  derived_from:
    - "d3-format docs — https://d3js.org/d3-format"
    - "Test vectors verified with d3-format via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "d3-format source"
  notes:
    - "Number formatting (printf-style with extras) — '$.2f', '.0%', '.3s', ',d', etc."
    - "Install: npm install d3-format"
    - "v3 ESM only; named exports format / formatPrefix / formatSpecifier / precisionFixed / etc."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "format(spec) throws on invalid spec strings."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant d3_format.dollar_two_decimal:
  description: "format('$.2f')(1234.5) is '$1234.50'"
  category: number
  kind: node_chain_eq
  entry: named
  function: format
  entry_args: ["$.2f"]
  chain:
    - {call: [1234.5]}
  expected: "$1234.50"

invariant d3_format.percent_no_decimal:
  description: "format('.0%')(0.42) is '42%'"
  category: percent
  kind: node_chain_eq
  entry: named
  function: format
  entry_args: [".0%"]
  chain:
    - {call: [0.42]}
  expected: "42%"

invariant d3_format.si_prefix:
  description: "format('.3s')(1234567) is '1.23M'"
  category: si
  kind: node_chain_eq
  entry: named
  function: format
  entry_args: [".3s"]
  chain:
    - {call: [1234567]}
  expected: "1.23M"

invariant d3_format.comma_grouping:
  description: "format(',d')(1234567) is '1,234,567'"
  category: grouping
  kind: node_chain_eq
  entry: named
  function: format
  entry_args: [",d"]
  chain:
    - {call: [1234567]}
  expected: "1,234,567"

invariant d3_format.hex_lower:
  description: "format('x')(255) is 'ff' (hex)"
  category: hex
  kind: node_chain_eq
  entry: named
  function: format
  entry_args: ["x"]
  chain:
    - {call: [255]}
  expected: "ff"

invariant d3_format.hex_upper:
  description: "format('X')(255) is 'FF'"
  category: hex
  kind: node_chain_eq
  entry: named
  function: format
  entry_args: ["X"]
  chain:
    - {call: [255]}
  expected: "FF"

invariant d3_format.percent_sign_with_decimal:
  description: "format('.1%')(0.123) is '12.3%'"
  category: percent
  kind: node_chain_eq
  entry: named
  function: format
  entry_args: [".1%"]
  chain:
    - {call: [0.123]}
  expected: "12.3%"

invariant d3_format.exponent:
  description: "format('e')(12345) is '1.234500e+4'"
  category: exponent
  kind: node_chain_eq
  entry: named
  function: format
  entry_args: ["e"]
  chain:
    - {call: [12345]}
  expected: "1.234500e+4"

invariant d3_format.fixed_point_zero_decimals:
  description: "format('.0f')(3.7) is '4' (rounds half-to-even)"
  category: number
  kind: node_chain_eq
  entry: named
  function: format
  entry_args: [".0f"]
  chain:
    - {call: [3.7]}
  expected: "4"
