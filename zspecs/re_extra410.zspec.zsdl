spec: re_extra410
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "re.Pattern.flags, re.Pattern.groups, re.Pattern.pattern are member_descriptor objects (fixed-offset C struct members)"
    - "re.Pattern.groupindex is a getset_descriptor object (computed get/set slot)"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern attribute descriptor types — member_descriptor attributes
# ---------------------------------------------------------------------------

table re_extra410.pattern_member_descriptors:
  description: "re.Pattern member_descriptor attributes — flags, groups, pattern; these are fixed-offset C struct members exposed via member_descriptor; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: repatternmem410

  columns: [id, function, args, expected]
  rows:
    - [flags_class,   re.Pattern.flags.__class__.__name__.__eq__,   ["member_descriptor"], true]
    - [groups_class,  re.Pattern.groups.__class__.__name__.__eq__,  ["member_descriptor"], true]
    - [pattern_class, re.Pattern.pattern.__class__.__name__.__eq__, ["member_descriptor"], true]

# ---------------------------------------------------------------------------
# re.Pattern attribute descriptor types — getset_descriptor attributes
# ---------------------------------------------------------------------------

table re_extra410.pattern_getset_descriptors:
  description: "re.Pattern getset_descriptor attributes — groupindex; this is a computed get/set slot exposed via getset_descriptor at the C level; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: repatterngs410

  columns: [id, function, args, expected]
  rows:
    - [groupindex_class, re.Pattern.groupindex.__class__.__name__.__eq__, ["getset_descriptor"], true]
