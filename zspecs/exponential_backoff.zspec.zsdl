spec: exponential_backoff
version: ">=3.0.0"
backend: node(exponential-backoff)

docs: https://github.com/coveooss/exponential-backoff#readme

provenance:
  derived_from:
    - "exponential-backoff README — https://github.com/coveooss/exponential-backoff#readme"
    - "Test vectors verified with exponential-backoff via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "exponential-backoff source"
  notes:
    - "Backoff retry helper — backOff(fn, options) returns a Promise."
    - "Install: npm install exponential-backoff"
    - "v3 CJS; named export backOff."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws the final error after retries exhausted."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant exponential_backoff.has_backOff:
  description: "backOff exported as a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "backOff.constructor.name"}
  expected: "Function"

invariant exponential_backoff.backOff_arity:
  description: "backOff takes (request, options) — function.length 2"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "backOff.length"}
  expected: 2
