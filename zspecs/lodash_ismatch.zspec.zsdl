spec: lodash_ismatch
version: ">=4.0.0"
backend: node(lodash.ismatch)

docs: https://lodash.com/docs/#isMatch

provenance:
  derived_from:
    - "lodash.ismatch README — https://www.npmjs.com/package/lodash.ismatch"
    - "Test vectors verified with lodash.ismatch@4.4.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.ismatch exports the _.isMatch function directly as module.exports."
    - "isMatch(object, source) checks if object contains all source properties with equal values."
    - "Performs deep partial comparison."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_ismatch.ismatch:
  kind: node_module_call_eq
  function: ~
  category: ismatch
  id_prefix: lism

  columns: [id, args, expected]
  rows:
    - [match,        [{"a": 1, "b": 2}, {"a": 1}],           true]
    - [exact,        [{"a": 1}, {"a": 1}],                    true]
    - [no_match,     [{"a": 1, "b": 2}, {"a": 2}],           false]
    - [deep_match,   [{"a": {"x": 1, "y": 2}}, {"a": {"x": 1}}], true]
    - [extra_source, [{"a": 1}, {"a": 1, "b": 2}],           false]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:30:47Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
