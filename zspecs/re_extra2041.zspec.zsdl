    - ["re2041032", "re.error.__dict__.__contains__",     ["__rand__"], false]
    - ["re2041033", "re.error.__dict__.__contains__",     ["__iand__"], false]
    - ["re2041034", "re.RegexFlag.__dict__.__contains__", ["__and__"],  true]
    - ["re2041035", "re.RegexFlag.__dict__.__contains__", ["__rand__"], true]
    - ["re2041036", "re.RegexFlag.__dict__.__contains__", ["__iand__"], false]

