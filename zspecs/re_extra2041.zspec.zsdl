    - ["re2041026", "re.Pattern.__dict__.__contains__",   ["__rand__"], false]
    - ["re2041027", "re.Pattern.__dict__.__contains__",   ["__iand__"], false]
    - ["re2041028", "re.Match.__dict__.__contains__",     ["__and__"],  false]
    - ["re2041029", "re.Match.__dict__.__contains__",     ["__rand__"], false]
