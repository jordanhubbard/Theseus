# ---------------------------------------------------------------------------
# __and__ / __rand__ / __iand__ — bitwise AND dict-presence
# re.RegexFlag defines __and__ and __rand__ (IntFlag protocol); __iand__ is not in its __dict__
# re.Pattern, re.Match, re.error — all False
# ---------------------------------------------------------------------------

