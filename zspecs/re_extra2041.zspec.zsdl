spec: re_extra2041
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/re.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 583 (_extra2041): __lshift__, __rlshift__, __ilshift__, __rshift__, __rrshift__, __irshift__, __and__, __rand__, __iand__, __or__, __ror__, __ior__, __xor__, __rxor__, __ixor__, __invert__ dict-presence checks."
    - "re.RegexFlag is an IntFlag subclass and defines __and__, __rand__, __or__, __ror__, __xor__, __rxor__, __invert__ in its own __dict__ as part of the Flag/IntFlag protocol."
    - "re.RegexFlag does NOT define __lshift__, __rlshift__, __ilshift__, __rshift__, __rrshift__, __irshift__, __iand__, __ior__, or __ixor__ in its own __dict__."
    - "re.Pattern and re.Match are C types from _sre; their __dict__ contains only string-matching methods, no bitwise operators."
    - "re.error is a Python exception subclass; no bitwise operators are defined in its own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __lshift__ / __rlshift__ / __ilshift__ — left shift dict-presence
# All False: shift operators not defined on any re type including RegexFlag
# ---------------------------------------------------------------------------

table re_extra2041.lshift_protocol:
  description: "re types __lshift__/__rlshift__/__ilshift__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2041

  columns: [id, function, args, expected]
  rows:
    - ["re2041001", "re.Pattern.__dict__.__contains__",   ["__lshift__"],  false]
    - ["re2041002", "re.Pattern.__dict__.__contains__",   ["__rlshift__"], false]
    - ["re2041003", "re.Pattern.__dict__.__contains__",   ["__ilshift__"], false]
    - ["re2041004", "re.Match.__dict__.__contains__",     ["__lshift__"],  false]
    - ["re2041005", "re.Match.__dict__.__contains__",     ["__rlshift__"], false]
    - ["re2041006", "re.Match.__dict__.__contains__",     ["__ilshift__"], false]
    - ["re2041007", "re.error.__dict__.__contains__",     ["__lshift__"],  false]
    - ["re2041008", "re.error.__dict__.__contains__",     ["__rlshift__"], false]
    - ["re2041009", "re.error.__dict__.__contains__",     ["__ilshift__"], false]
    - ["re2041010", "re.RegexFlag.__dict__.__contains__", ["__lshift__"],  false]
    - ["re2041011", "re.RegexFlag.__dict__.__contains__", ["__rlshift__"], false]
    - ["re2041012", "re.RegexFlag.__dict__.__contains__", ["__ilshift__"], false]

