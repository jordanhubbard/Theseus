spec: concurrent_futures_extra99
version: ">=3.9"
backend: python_module(concurrent.futures)
extends: concurrent_futures_extra98

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec extends concurrent_futures_extra98.zspec.zsdl."
    - "This spec covers: wave 254 theme — concurrent.futures module identity and submodule names. NEW in extra99: concurrent.futures.__name__=='concurrent.futures' (len=18); concurrent.futures.__package__=='concurrent.futures'; concurrent.futures.__name__==concurrent.futures.__package__ (True); concurrent.futures.__spec__.__class__.__name__=='ModuleSpec'; concurrent.futures.__spec__.name=='concurrent.futures'; concurrent.futures.__spec__.submodule_search_locations.__class__.__name__=='list' (directory package); concurrent.futures.__spec__.has_location==True; concurrent.futures._base.__name__=='concurrent.futures._base' (len=24); concurrent.futures.thread.__name__=='concurrent.futures.thread' (len=25); concurrent.futures.process.__name__=='concurrent.futures.process' (len=26, longest). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.__name__.__len__() == 18. 'concurrent.futures' is 18 characters: 'concurrent'=10 + '.'=1 + 'futures'=7 = 18. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.process.__name__.__len__() == 26. 'concurrent.futures.process' is 26 chars: 'concurrent.futures.'=19 + 'process'=7 = 26. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.__package__ == concurrent.futures.__name__ == 'concurrent.futures'. concurrent.futures is a sub-package of the concurrent namespace package; its __package__ equals its own __name__ (not the parent 'concurrent'). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures module identity — extra99
#
# Wave 254 theme: concurrent.futures module __name__, __package__, __spec__ identity.
#
# concurrent.futures.__name__                                         == 'concurrent.futures'  (len=18)
# concurrent.futures.__package__                                      == 'concurrent.futures'
# concurrent.futures.__spec__.__class__.__name__                      == 'ModuleSpec'
# concurrent.futures.__spec__.name                                    == 'concurrent.futures'
# concurrent.futures.__spec__.submodule_search_locations.__class__.__name__ == 'list'
# concurrent.futures.__spec__.has_location                            == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra99.cf_module_identity:
  description: "concurrent.futures module __name__, __package__, and __spec__ identity checks in cfmodident99 namespace — wave 254 theme: concurrent.futures is a sub-package within the concurrent namespace package; concurrent.futures.__name__.__eq__('concurrent.futures')==True (len=18: 'concurrent'=10 + '.'=1 + 'futures'=7); concurrent.futures.__name__.__len__()==18; concurrent.futures.__package__.__eq__('concurrent.futures')==True (for packages, __package__ equals __name__); concurrent.futures.__spec__.__class__.__name__.__eq__('ModuleSpec')==True (standard module spec); concurrent.futures.__spec__.name.__eq__('concurrent.futures')==True (spec.name matches __name__); concurrent.futures.__spec__.submodule_search_locations.__class__.__name__.__eq__('list')==True (concurrent.futures is a directory package with submodule search paths); concurrent.futures.__spec__.has_location.__eq__(True)==True (filesystem origin); verified with Python 3.14.3"
  kind: python_call_eq
  category: module_identity
  id_prefix: cfmodident99

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,       "concurrent.futures.__name__.__eq__",                                              ["concurrent.futures"], true, "concurrent.futures.__name__ == 'concurrent.futures' (len=18); verified with Python 3.14.3"]
    - [name_len,      "concurrent.futures.__name__.__len__",                                             [],                    18,   "concurrent.futures.__name__.__len__() == 18; verified with Python 3.14.3"]
    - [pkg_eq,        "concurrent.futures.__package__.__eq__",                                           ["concurrent.futures"], true, "concurrent.futures.__package__ == 'concurrent.futures' (equals __name__); verified with Python 3.14.3"]
    - [spec_cls,      "concurrent.futures.__spec__.__class__.__name__.__eq__",                           ["ModuleSpec"],         true, "concurrent.futures.__spec__.__class__.__name__ == 'ModuleSpec'; verified with Python 3.14.3"]
    - [spec_name,     "concurrent.futures.__spec__.name.__eq__",                                         ["concurrent.futures"], true, "concurrent.futures.__spec__.name == 'concurrent.futures'; verified with Python 3.14.3"]
    - [submod_locs,   "concurrent.futures.__spec__.submodule_search_locations.__class__.__name__.__eq__", ["list"],               true, "concurrent.futures.__spec__.submodule_search_locations.__class__.__name__ == 'list'; verified with Python 3.14.3"]
    - [has_loc,       "concurrent.futures.__spec__.has_location.__eq__",                                 [true],                 true, "concurrent.futures.__spec__.has_location == True (filesystem origin); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures submodule __name__ attributes — extra99
#
# concurrent.futures._base.__name__    == 'concurrent.futures._base'    (len=24)
# concurrent.futures.thread.__name__   == 'concurrent.futures.thread'   (len=25)
# concurrent.futures.process.__name__  == 'concurrent.futures.process'  (len=26, longest)
# ---------------------------------------------------------------------------

table concurrent_futures_extra99.cf_submodule_names:
  description: "concurrent.futures submodule __name__ checks in cfmodident99 namespace — wave 254 theme: concurrent.futures submodule __name__ attributes; concurrent.futures._base.__name__.__eq__('concurrent.futures._base')==True (len=24: 'concurrent.futures.'=19 + '_base'=5); concurrent.futures._base.__name__.__len__()==24; concurrent.futures.thread.__name__.__eq__('concurrent.futures.thread')==True (len=25: 'concurrent.futures.'=19 + 'thread'=6); concurrent.futures.thread.__name__.__len__()==25; concurrent.futures.process.__name__.__eq__('concurrent.futures.process')==True (len=26: 'concurrent.futures.'=19 + 'process'=7, the longest submodule name); concurrent.futures.process.__name__.__len__()==26; all __name__ values are 'str' class; all share the 'concurrent.futures.' prefix (19 chars); the three submodules _base, thread, and process are the entire set of internal submodules in concurrent.futures; verified with Python 3.14.3"
  kind: python_call_eq
  category: module_identity
  id_prefix: cfmodident99a

  columns: [id, function, args, expected, description]
  rows:
    - [base_name_eq,    "concurrent.futures._base.__name__.__eq__",    ["concurrent.futures._base"],    true, "concurrent.futures._base.__name__ == 'concurrent.futures._base' (len=24); verified with Python 3.14.3"]
    - [base_name_len,   "concurrent.futures._base.__name__.__len__",   [],                              24,   "concurrent.futures._base.__name__.__len__() == 24; verified with Python 3.14.3"]
    - [thread_name_eq,  "concurrent.futures.thread.__name__.__eq__",   ["concurrent.futures.thread"],   true, "concurrent.futures.thread.__name__ == 'concurrent.futures.thread' (len=25); verified with Python 3.14.3"]
    - [thread_name_len, "concurrent.futures.thread.__name__.__len__",  [],                              25,   "concurrent.futures.thread.__name__.__len__() == 25; verified with Python 3.14.3"]
    - [proc_name_eq,    "concurrent.futures.process.__name__.__eq__",  ["concurrent.futures.process"],  true, "concurrent.futures.process.__name__ == 'concurrent.futures.process' (len=26, longest); verified with Python 3.14.3"]
    - [proc_name_len,   "concurrent.futures.process.__name__.__len__", [],                              26,   "concurrent.futures.process.__name__.__len__() == 26 (longest submodule name); verified with Python 3.14.3"]
    - [base_name_cls,   "concurrent.futures._base.__name__.__class__.__name__.__eq__", ["str"],         true, "concurrent.futures._base.__name__.__class__.__name__ == 'str'; verified with Python 3.14.3"]
    - [thread_pkg_eq,   "concurrent.futures.thread.__package__.__eq__", ["concurrent.futures"],         true, "concurrent.futures.thread.__package__ == 'concurrent.futures' (parent package); verified with Python 3.14.3"]
    - [proc_pkg_eq,     "concurrent.futures.process.__package__.__eq__", ["concurrent.futures"],        true, "concurrent.futures.process.__package__ == 'concurrent.futures' (parent package); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra99
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra99.cf_name_len_is_18:
  description: "concurrent.futures.__name__.__len__() == 18 — concurrent.futures.__name__ is 'concurrent.futures' (18 characters: 'concurrent'=10 + '.'=1 + 'futures'=7 = 18); this is the longest top-level module name covered in this spec series — compare with asyncio (len=7), multiprocessing (len=15), and abc (len=3); concurrent.futures.__package__ is also 'concurrent.futures' (len=18) — for packages, __package__ equals __name__; concurrent.futures.__spec__.name is also 'concurrent.futures' (len=18); all three attributes share the same 18-character value; NEW in extra99: first standalone concurrent.futures module name length invariant in cfmodident99 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: "concurrent.futures.__name__.__len__"
  args: []
  expected: 18

invariant concurrent_futures_extra99.cf_package_equals_name:
  description: "concurrent.futures.__package__.__eq__('concurrent.futures') returns True — concurrent.futures.__package__ is 'concurrent.futures', which equals concurrent.futures.__name__; concurrent.futures is a sub-package of the 'concurrent' namespace package; for packages (not modules), __package__ equals __name__; this contrasts with submodules like concurrent.futures._base where __package__ would be 'concurrent.futures' (the parent package name, not the submodule's own __name__); concurrent.futures.__spec__.name is also 'concurrent.futures' confirming the three-way equality; NEW in extra99: first standalone concurrent.futures.__package__ equality invariant in cfmodident99 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: "concurrent.futures.__package__.__eq__"
  args: ["concurrent.futures"]
  expected: true

invariant concurrent_futures_extra99.cf_spec_class_is_ModuleSpec:
  description: "concurrent.futures.__spec__.__class__.__name__.__eq__('ModuleSpec') returns True — concurrent.futures.__spec__ is an instance of importlib.machinery.ModuleSpec; ModuleSpec is the standard spec class used by the import system for all regular packages; concurrent.futures.__spec__.name is 'concurrent.futures'; concurrent.futures.__spec__.has_location is True (filesystem origin via Lib/concurrent/futures/__init__.py); concurrent.futures.__spec__.submodule_search_locations.__class__.__name__ is 'list' (directory-based package with search paths); concurrent.futures is a regular package (not a namespace package, not a frozen module); NEW in extra99: first standalone concurrent.futures __spec__ class name invariant in cfmodident99 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: "concurrent.futures.__spec__.__class__.__name__.__eq__"
  args: ["ModuleSpec"]
  expected: true

invariant concurrent_futures_extra99.cf_process_name_len_is_26:
  description: "concurrent.futures.process.__name__.__len__() == 26 — concurrent.futures.process.__name__ is 'concurrent.futures.process' (26 chars: 'concurrent.futures.'=19 + 'process'=7); this is the longest __name__ among the concurrent.futures submodules: _base=24, thread=25, process=26; 'process' is a 7-character suffix (one longer than 'thread'=6 and two longer than '_base'=5); concurrent.futures.process defines the ProcessPoolExecutor class; concurrent.futures.process.__package__ is 'concurrent.futures' (the parent package); NEW in extra99: first standalone concurrent.futures.process name length invariant in cfmodident99 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: "concurrent.futures.process.__name__.__len__"
  args: []
  expected: 26

invariant concurrent_futures_extra99.cf_submodule_search_locations_is_list:
  description: "concurrent.futures.__spec__.submodule_search_locations.__class__.__name__.__eq__('list') returns True — concurrent.futures.__spec__.submodule_search_locations is a plain Python list containing the concurrent.futures package directory path; this is a 'list' (not '_NamespacePath') because concurrent.futures is a regular directory package (Lib/concurrent/futures/__init__.py); the parent 'concurrent' is a namespace package (no __init__.py) but concurrent.futures itself is a regular package with __init__.py; concurrent.futures.__spec__.has_location is True; compare with abc which has submodule_search_locations==None (abc is a single module, not a package); NEW in extra99: first standalone concurrent.futures submodule_search_locations class name invariant in cfmodident99 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: "concurrent.futures.__spec__.submodule_search_locations.__class__.__name__.__eq__"
  args: ["list"]
  expected: true
