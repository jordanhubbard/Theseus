spec: mime_match
version: ">=1.0.0"
backend: node(mime-match)

docs: https://github.com/lovell/mime-match#readme

provenance:
  derived_from:
    - "mime-match README — https://github.com/lovell/mime-match#readme"
    - "RFC 9110 §12 (Content negotiation) — wildcard matching"
    - "Test vectors verified with mime-match via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "mime-match source"
  notes:
    - "Wildcard matching for MIME content types — supports 'text/*' / '*/*' patterns."
    - "Install: npm install mime-match"
    - "v1 CJS; module export IS the match function (mime, pattern) → boolean."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant mime_match.exact_match:
  description: "match('application/json', 'application/json') is true"
  category: match
  kind: node_chain_eq
  entry: module
  entry_args: ["application/json", "application/json"]
  chain: []
  expected: true

invariant mime_match.text_wildcard:
  description: "match('text/html', 'text/*') is true"
  category: wildcard
  kind: node_chain_eq
  entry: module
  entry_args: ["text/html", "text/*"]
  chain: []
  expected: true

invariant mime_match.cross_type_no_match:
  description: "match('application/json', 'text/*') is false"
  category: wildcard
  kind: node_chain_eq
  entry: module
  entry_args: ["application/json", "text/*"]
  chain: []
  expected: false

invariant mime_match.universal_wildcard:
  description: "match('image/png', '*/*') is true"
  category: wildcard
  kind: node_chain_eq
  entry: module
  entry_args: ["image/png", "*/*"]
  chain: []
  expected: true

invariant mime_match.universal_wildcard_for_xml:
  description: "match('application/xml', '*/*') is true"
  category: wildcard
  kind: node_chain_eq
  entry: module
  entry_args: ["application/xml", "*/*"]
  chain: []
  expected: true

invariant mime_match.different_subtype:
  description: "match('text/html', 'text/plain') is false"
  category: match
  kind: node_chain_eq
  entry: module
  entry_args: ["text/html", "text/plain"]
  chain: []
  expected: false

invariant mime_match.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"
