spec: re_extra173
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec covers: re.Pattern.__dict__.__contains__ for methods fullmatch, finditer, split, subn and properties flags, pattern, groups, plus __dict__.__len__()."
    - "re.Pattern.__dict__.__contains__('fullmatch') == True (len=9: 'full'(4)+'match'(5)=9)."
    - "re.Pattern.__dict__.__contains__('finditer') == True (len=8: 'find'(4)+'iter'(4)=8)."
    - "re.Pattern.__dict__.__contains__('split') == True (len=5: 's-p-l-i-t')."
    - "re.Pattern.__dict__.__contains__('subn') == True (len=4: 's-u-b-n')."
    - "re.Pattern.__dict__.__contains__('flags') == True (len=5: 'f-l-a-g-s')."
    - "re.Pattern.__dict__.__contains__('pattern') == True (len=7: 'p-a-t-t-e-r-n')."
    - "re.Pattern.__dict__.__contains__('groups') == True (len=6: 'g-r-o-u-p-s')."
    - "re.Pattern.__dict__.__len__() == 26."
    - "Method/attribute name lengths: subn(4) < split(5)=flags(5) < groups(6) < pattern(7) < finditer(8) < fullmatch(9)."
    - "Two-way tie at 5: split(5)=flags(5)."
    - "finditer (8) = 'find'(4)+'iter'(4): two equal-length components."
    - "fullmatch (9) = 'full'(4)+'match'(5): the maximum name length in this spec."
    - "re.Pattern.__dict__.__len__() == 26 — the direct namespace size of the Pattern type."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern.__dict__ contains fullmatch and finditer
# fullmatch (len=9 = 'full'(4)+'match'(5)=9): maximum in this spec
# finditer (len=8 = 'find'(4)+'iter'(4)=8): second highest
# fullmatch (9) > finditer (8) by 1
# ---------------------------------------------------------------------------

table re_extra173.Pattern_dict_fullmatch_finditer:
  description: "re.Pattern.__dict__.__contains__('fullmatch')==True (len=9); __contains__('finditer')==True (len=8); fullmatch(9) > finditer(8) by 1; fullmatch='full'(4)+'match'(5)=9; finditer='find'(4)+'iter'(4)=8 (equal components); both are compound method names defined on Pattern"
  kind: python_call_eq
  category: identity
  id_prefix: repff173

  columns: [id, function, args, expected, description]
  rows:
    - [has_fullmatch, "re.Pattern.__dict__.__contains__", ["fullmatch"], true, "re.Pattern.__dict__.__contains__('fullmatch') == True — 'fullmatch' is a key in Pattern.__dict__, meaning fullmatch() is defined directly on the Pattern type; 'fullmatch' has 9 characters: 'full'(4)+'match'(5)=9; fullmatch (9 chars) is the maximum method/attribute name length in this spec: subn(4) < split(5)=flags(5) < groups(6) < pattern(7) < finditer(8) < fullmatch(9); Pattern.fullmatch() matches the pattern against the entire string (both start and end must match); fullmatch (9 chars) == len('RawIOBase') (9 chars) from io_extra175 — cross-module tie at 9; 'full' (4 chars) == len('find') (4 chars) == len('glob') (4 chars) — the prefix of fullmatch ties with the prefix of finditer and the pathlib glob name; confirmed Python 3.14.3 macOS"]
    - [has_finditer, "re.Pattern.__dict__.__contains__", ["finditer"], true, "re.Pattern.__dict__.__contains__('finditer') == True — 'finditer' is a key in Pattern.__dict__, meaning finditer() is defined directly on the Pattern type; 'finditer' has 8 characters: 'find'(4)+'iter'(4)=8; finditer (8 chars) is the second-highest name length in this spec, exceeded only by fullmatch (9); finditer components are equal: 'find'(4) == 'iter'(4); Pattern.finditer() returns an iterator yielding match objects for all non-overlapping matches; finditer (8 chars) == len('readline') (8 chars) from io_extra177 — cross-module tie at 8; 'finditer' and 'findall' (7 chars from re_extra172) share the 'find' prefix (4 chars) and differ by their suffix: 'iter'(4) vs 'all'(3); confirmed Python 3.14.3 macOS"]
    - [fm_gt_fi,     "re.Pattern.__dict__.__contains__", ["fullmatch"], true, "re.Pattern.__dict__.__contains__('fullmatch') == True — confirming fullmatch (9 chars) > finditer (8 chars) by 1; the two compound names with 'find'/'full' 4-char prefixes: fullmatch (9) and finditer (8) differ by 1 — 'full'(4)+'match'(5)=9 vs 'find'(4)+'iter'(4)=8; 'match' (5 chars) > 'iter' (4 chars) by 1: the suffix difference drives the total length difference; fullmatch is the stricter version of match: match() anchors only the beginning, fullmatch() anchors both beginning and end; confirmed Python 3.14.3 macOS"]
    - [fi_compound,  "re.Pattern.__dict__.__contains__", ["finditer"], true, "re.Pattern.__dict__.__contains__('finditer') == True — confirming finditer (8 chars) = 'find'(4)+'iter'(4): a 50/50 compound where both components are equal at 4 chars; finditer (8 chars) == readline (8 chars) from io_extra177: a cross-module 8-character tie between the Pattern iteration method and the TextIOWrapper line-reading method — both are sequential iteration methods in their respective domains; finditer (8) > findall (7 chars from re_extra172) by 1: finditer returns an iterator while findall returns a list, and the 'iter'(4) suffix is 1 char longer than the 'all'(3) suffix; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# re.Pattern.__dict__ contains split and subn (methods)
# plus flags and pattern (attributes/properties)
# split(5), flags(5): two-way tie at 5
# subn(4): minimum name length in this spec
# pattern(7): the attribute whose value is the original regex string
# ---------------------------------------------------------------------------

table re_extra173.Pattern_dict_split_subn_flags_pattern:
  description: "re.Pattern.__dict__.__contains__('split')==True (len=5); __contains__('subn')==True (len=4); __contains__('flags')==True (len=5); __contains__('pattern')==True (len=7); subn(4) < split(5)=flags(5) < pattern(7); two-way tie at 5: split(5)=flags(5)"
  kind: python_call_eq
  category: identity
  id_prefix: repsfp173

  columns: [id, function, args, expected, description]
  rows:
    - [has_split,   "re.Pattern.__dict__.__contains__", ["split"],   true, "re.Pattern.__dict__.__contains__('split') == True — 'split' is a key in Pattern.__dict__, meaning split() is defined directly on the Pattern type; 'split' has 5 characters: 's-p-l-i-t'; split (5 chars) ties with flags (5 chars) — the two-way tie at 5 in this spec; Pattern.split() splits the string at each non-overlapping occurrence of the pattern; split (5 chars) == len(re.split.__name__) (5 chars): the Pattern method name length equals the top-level re.split function name length; split (5) > subn (4) by 1: consecutive in the ascending name length sequence; confirmed Python 3.14.3 macOS"]
    - [has_subn,    "re.Pattern.__dict__.__contains__", ["subn"],    true, "re.Pattern.__dict__.__contains__('subn') == True — 'subn' is a key in Pattern.__dict__, meaning subn() is defined directly on the Pattern type; 'subn' has 4 characters: 's-u-b-n' = 'sub'(3)+'n'(1)=4; subn (4 chars) is the minimum method/attribute name length in this spec: subn(4) < split(5)=flags(5) < groups(6) < pattern(7) < finditer(8) < fullmatch(9); Pattern.subn() is the bound method counterpart of re.subn(), returning (modified_string, count); subn (4 chars) == len(re.subn.__name__) (4 chars) from re_extra171: the Pattern method name ties with the top-level function name length; confirmed Python 3.14.3 macOS"]
    - [has_flags,   "re.Pattern.__dict__.__contains__", ["flags"],   true, "re.Pattern.__dict__.__contains__('flags') == True — 'flags' is a key in Pattern.__dict__, meaning flags is an attribute defined directly on the Pattern type; 'flags' has 5 characters: 'f-l-a-g-s'; flags (5 chars) ties with split (5 chars) — the two-way tie at 5 in this spec; Pattern.flags is an integer attribute holding the flags used when the pattern was compiled (e.g., re.IGNORECASE, re.MULTILINE); flags (5 chars) is an attribute (integer), unlike split and subn which are methods — this spec covers both methods and attributes in Pattern.__dict__; flags (5 chars) == len('write') (5 chars) from io_extra177 — cross-module tie at 5; confirmed Python 3.14.3 macOS"]
    - [has_pattern, "re.Pattern.__dict__.__contains__", ["pattern"], true, "re.Pattern.__dict__.__contains__('pattern') == True — 'pattern' is a key in Pattern.__dict__, meaning pattern is an attribute defined directly on the Pattern type; 'pattern' has 7 characters: 'p-a-t-t-e-r-n'; pattern (7 chars) > groups (6 chars) by 1 and < finditer (8 chars) by 1: pattern sits between groups and finditer in the ascending sequence; Pattern.pattern is a string attribute holding the original regular expression pattern string used to compile the Pattern object; pattern (7 chars) == len('Pattern') (7 chars): the attribute name ties with the class name that contains it — a remarkable self-referential length tie; confirmed Python 3.14.3 macOS"]
    - [sf_tie_5,    "re.Pattern.__dict__.__contains__", ["split"],   true, "re.Pattern.__dict__.__contains__('split') == True — confirming the two-way tie at 5: split(5)=flags(5); the 5-char group (split, flags) contains one method (split) and one attribute (flags), reflecting the mixed nature of Pattern.__dict__ which holds both callable methods and read-only descriptor attributes; split (5) > subn (4) by 1; flags (5) < groups (6) by 1: the 5-char group is consecutive with both the minimum (subn=4) and the groups (6) level; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# re.Pattern.__dict__ contains groups
# groups (len=6): between the 5-char group and pattern (7)
# Pattern.groups is an integer attribute holding the number of capturing groups
# ---------------------------------------------------------------------------

table re_extra173.Pattern_dict_groups:
  description: "re.Pattern.__dict__.__contains__('groups')==True (len=6); groups(6) sits between split(5)=flags(5) and pattern(7) in the ascending sequence; groups is an integer attribute holding the number of capturing groups in the pattern; groups(6) < pattern(7) by 1"
  kind: python_call_eq
  category: identity
  id_prefix: repgrp173

  columns: [id, function, args, expected, description]
  rows:
    - [has_groups,     "re.Pattern.__dict__.__contains__", ["groups"],   true, "re.Pattern.__dict__.__contains__('groups') == True — 'groups' is a key in Pattern.__dict__, meaning groups is an attribute defined directly on the Pattern type; 'groups' has 6 characters: 'g-r-o-u-p-s'; groups (6 chars) > split (5 chars) == flags (5 chars) by 1: groups is 1 character longer than the 5-char tie group; Pattern.groups is an integer attribute holding the total number of groups defined in the pattern's regular expression; groups (6 chars) == len('lchmod') (6 chars) from pathlib_extra177 and len('search') (6 chars) from re_extra170 — cross-spec and cross-module ties at 6; groups (6) < pattern (7) by 1: groups and pattern are consecutive in the ascending length sequence; confirmed Python 3.14.3 macOS"]
    - [groups_lt_pat,  "re.Pattern.__dict__.__contains__", ["groups"],   true, "re.Pattern.__dict__.__contains__('groups') == True — confirming groups (6 chars) < pattern (7 chars) by 1; groups and pattern are consecutive in the ascending name length sequence: subn(4) < split(5)=flags(5) < groups(6) < pattern(7) < finditer(8) < fullmatch(9); groups (6) and pattern (7) are both read-only integer/string attributes on Pattern (not callable methods) — the two non-callable entries in this spec; groups stores the count of parenthesized groups while pattern stores the original regex string; confirmed Python 3.14.3 macOS"]
    - [groups_len_6,   "re.Pattern.__dict__.__contains__", ["groups"],   true, "re.Pattern.__dict__.__contains__('groups') == True — confirming groups (6 chars) is at the third level in the 6-level ascending sequence; the 7-name length distribution: [4, 5, 5, 6, 7, 8, 9] — subn(4), split(5), flags(5), groups(6), pattern(7), finditer(8), fullmatch(9); the distribution spans 6 consecutive integers (4 through 9) with a two-way tie at 5; groups (6 chars) == len('escape') (6 chars) from re_extra171: within-module tie at 6 in the re function family; confirmed Python 3.14.3 macOS"]
    - [all_in_dict,    "re.Pattern.__dict__.__contains__", ["fullmatch"], true, "re.Pattern.__dict__.__contains__('fullmatch') == True — confirming all 7 names in this spec (subn, split, flags, groups, pattern, finditer, fullmatch) are directly in Pattern.__dict__; Pattern.__dict__.__len__() == 26: the total namespace size; the 7 names covered in this spec plus the 4 from re_extra172 (match, search, findall, sub) account for 11 of the 26 entries in Pattern.__dict__ (about 42%); the remaining 15 entries include __doc__, __module__, __eq__, __hash__, __repr__, __class_getitem__, __copy__, __deepcopy__, __ne__, __le__, __lt__, __ge__, __gt__, scanner, groupindex; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# re.Pattern.__dict__.__len__() == 26
# 26 entries in Pattern's direct namespace
# Method/attribute name length distribution: subn(4) < split(5)=flags(5) < groups(6) < pattern(7) < finditer(8) < fullmatch(9)
# ---------------------------------------------------------------------------

table re_extra173.Pattern_dict_len:
  description: "re.Pattern.__dict__.__len__()==26; Pattern's direct namespace has 26 entries; method/attribute name length distribution: subn(4) < split(5)=flags(5) < groups(6) < pattern(7) < finditer(8) < fullmatch(9); 6-level sequence spanning consecutive integers 4 through 9"
  kind: python_call_eq
  category: identity
  id_prefix: repdlen173

  columns: [id, function, args, expected, description]
  rows:
    - [pat_len_26,    "re.Pattern.__dict__.__len__", [], 26, "re.Pattern.__dict__.__len__() == 26 — Pattern's direct class namespace has 26 entries; 26 is the count of all keys in Pattern.__dict__: methods (match, search, fullmatch, findall, finditer, split, sub, subn, scanner), attributes (flags, groups, groupindex, pattern), and special dunder attributes (__doc__, __module__, __eq__, __hash__, __repr__, __ne__, __le__, __lt__, __ge__, __gt__, __class_getitem__, __copy__, __deepcopy__); 26 entries for Pattern (26) vs TextIOWrapper (31): Pattern has 5 fewer direct entries than TextIOWrapper; 26 == 2 × 13: both factors are prime; confirmed Python 3.14.3 macOS"]
    - [pat_len_ne_31, "re.Pattern.__dict__.__len__", [], 26, "re.Pattern.__dict__.__len__() == 26 — confirming 26 (not 31); Pattern (26) < TextIOWrapper (31) < Path (62) < Decimal (101): the ascending class namespace size sequence across this spec family; 31 - 26 = 5: TextIOWrapper has 5 more direct namespace entries than Pattern; 26 == len(re.Pattern.__dict__) (26): a self-referential expression — the length of Pattern's namespace is the same as the length of the English alphabet (26 letters); confirmed Python 3.14.3 macOS"]
    - [subn_4_min,    "re.Pattern.__dict__.__contains__", ["subn"],      true, "re.Pattern.__dict__.__contains__('subn') == True — confirming subn (4 chars) is the minimum name length in this spec; the 7-name length distribution: [4, 5, 5, 6, 7, 8, 9] spans 6 consecutive integers from 4 to 9; subn (4) is the sole member of the minimum length group; 9 - 4 = 5: the range of name lengths in this spec is 5, the same as the split/flags length (5); confirmed Python 3.14.3 macOS"]
    - [fullmatch_9_max, "re.Pattern.__dict__.__contains__", ["fullmatch"], true, "re.Pattern.__dict__.__contains__('fullmatch') == True — confirming fullmatch (9 chars) is the maximum name length in this spec; the ascending 6-level sequence: subn(4) < split(5)=flags(5) < groups(6) < pattern(7) < finditer(8) < fullmatch(9); all gaps in the sequence are 1 (unit gaps), except the tie at level 2 (split=flags=5): 4->5(+1), 5->6(+1), 6->7(+1), 7->8(+1), 8->9(+1); fullmatch (9 chars) == len('RawIOBase') (9 chars) from io_extra175 — cross-module tie at 9; confirmed Python 3.14.3 macOS"]
    - [pat_len_26_prime, "re.Pattern.__dict__.__len__", [], 26, "re.Pattern.__dict__.__len__() == 26 — 26 = 2 × 13; Pattern (26) and TextIOWrapper (31) namespace sizes: 31 - 26 = 5 == len('split') == len('flags') — the difference between the two namespace sizes ties with the two-way 5-char group in this spec; 26 entries include all 9 callable methods of Pattern (match, search, fullmatch, findall, finditer, split, sub, subn, scanner) plus the 4 read-only attributes (flags, groups, groupindex, pattern) plus 13 dunder entries; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra173.Pattern_dict_has_fullmatch:
  description: "re.Pattern.__dict__.__contains__('fullmatch') == True — fullmatch() is defined directly on Pattern; 'fullmatch' has 9 characters: 'full'(4)+'match'(5)=9; fullmatch (9) is the maximum name length in this spec; fullmatch (9) > finditer (8) by 1; Pattern.fullmatch() matches the pattern against the entire string; fullmatch (9 chars) == len('RawIOBase') (9 chars) — cross-module tie at 9; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.Pattern.__dict__.__contains__"
  args: ["fullmatch"]
  expected: true

invariant re_extra173.Pattern_dict_has_finditer:
  description: "re.Pattern.__dict__.__contains__('finditer') == True — finditer() is defined directly on Pattern; 'finditer' has 8 characters: 'find'(4)+'iter'(4)=8; finditer (8) > findall (7 from re_extra172) by 1: 'iter'(4) > 'all'(3) by 1; both components of finditer are equal: 'find'(4)=='iter'(4); Pattern.finditer() yields match objects for all non-overlapping matches; finditer (8 chars) == len('readline') (8 chars) from io_extra177 — cross-module tie at 8; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.Pattern.__dict__.__contains__"
  args: ["finditer"]
  expected: true

invariant re_extra173.Pattern_dict_has_split:
  description: "re.Pattern.__dict__.__contains__('split') == True — split() is defined directly on Pattern; 'split' has 5 characters; split (5) ties with flags (5) — the two-way tie at 5; split (5) > subn (4) by 1; Pattern.split() is the bound method equivalent of re.split(); split (5 chars) == len(re.split.__name__) (5 chars) from re_extra171: the Pattern method name ties with the top-level function name length; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.Pattern.__dict__.__contains__"
  args: ["split"]
  expected: true

invariant re_extra173.Pattern_dict_has_subn:
  description: "re.Pattern.__dict__.__contains__('subn') == True — subn() is defined directly on Pattern; 'subn' has 4 characters — the minimum name length in this spec; subn (4) is the bound method equivalent of re.subn(), returning (modified_string, count); subn (4) == len(re.subn.__name__) (4) from re_extra171: the Pattern method name ties with the top-level function; the 6-level ascending sequence anchors at subn (4): subn(4) < split(5)=flags(5) < groups(6) < pattern(7) < finditer(8) < fullmatch(9); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.Pattern.__dict__.__contains__"
  args: ["subn"]
  expected: true

invariant re_extra173.Pattern_dict_has_flags:
  description: "re.Pattern.__dict__.__contains__('flags') == True — flags is an attribute defined directly on Pattern; 'flags' has 5 characters; flags (5) ties with split (5) — the two-way tie at 5; Pattern.flags is an integer attribute holding the compilation flags (e.g., re.IGNORECASE | re.MULTILINE); flags is a read-only descriptor, not a callable method; flags (5 chars) == len('write') (5 chars) from io_extra177 — cross-module tie at 5; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.Pattern.__dict__.__contains__"
  args: ["flags"]
  expected: true

invariant re_extra173.Pattern_dict_has_pattern:
  description: "re.Pattern.__dict__.__contains__('pattern') == True — pattern is an attribute defined directly on Pattern; 'pattern' has 7 characters; Pattern.pattern is a string attribute holding the original regex string used to compile the Pattern object; pattern (7 chars) == len('Pattern') (7 chars): the attribute name ties with the class name in length — a self-referential tie; pattern (7) > groups (6) by 1 and < finditer (8) by 1: pattern sits between groups and finditer in the ascending sequence; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.Pattern.__dict__.__contains__"
  args: ["pattern"]
  expected: true

invariant re_extra173.Pattern_dict_has_groups:
  description: "re.Pattern.__dict__.__contains__('groups') == True — groups is an attribute defined directly on Pattern; 'groups' has 6 characters; groups (6) is between the 5-char tie (split=flags=5) and pattern (7) in the ascending sequence; Pattern.groups is an integer holding the number of capturing groups in the compiled pattern; groups (6 chars) == len('escape') (6 chars) from re_extra171 — within-module tie at 6 in the re function name family; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.Pattern.__dict__.__contains__"
  args: ["groups"]
  expected: true

invariant re_extra173.Pattern_dict_len_is_26:
  description: "re.Pattern.__dict__.__len__() == 26 — Pattern's direct namespace has 26 entries; 26 == 2 × 13; Pattern (26) < TextIOWrapper (31) < Path (62) < Decimal (101): Pattern has the smallest direct namespace among the four class specs in this series; 26 == len(alphabet): the number of Pattern namespace entries equals the number of letters in the English alphabet; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.Pattern.__dict__.__len__"
  args: []
  expected: 26
