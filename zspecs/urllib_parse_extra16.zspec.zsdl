spec: urllib_parse_extra16
version: ">=3.9"
backend: python_module(urllib.parse)

docs: https://docs.python.org/3/library/urllib.parse.html
rfcs:
  - "RFC 3986 — Uniform Resource Identifier (URI): Generic Syntax"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.parse.html — Python urllib.parse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/parse.py"
    - "urllib_parse_extra4.zspec.zsdl — covers __qualname__.__eq__ for urlparse/urlsplit/urljoin/urlencode/quote/unquote and ParseResult/SplitResult/DefragResult."
    - "urllib_parse_extra5.zspec.zsdl — covers __qualname__.__eq__ for quote_plus/unquote_plus/parse_qs/parse_qsl."
    - "urllib_parse_extra14.zspec.zsdl — covers __qualname__.__len__() for urlparse/urlencode/quote/unquote/urljoin/urlsplit and result classes ParseResult/SplitResult."
    - "urllib_parse_extra15.zspec.zsdl — covers __qualname__.__eq__ and __len__() for urlunparse; __len__() for quote_plus/unquote_plus; cross-namespace anchors for quote_plus/unquote_plus."
  notes:
    - "This spec extends the urllib_parse chain through urllib_parse_extra15; it does NOT duplicate invariants in any prior spec."
    - "Focus: (1) __qualname__.__eq__ for ParseResult.geturl method — extra4 covers ParseResult class qualname but not its methods; (2) __qualname__.__len__() for DefragResult — extra14 covers ParseResult/SplitResult lengths but not DefragResult; (3) cross-namespace anchors for urldefrag/parse_qs/parse_qsl/urlencode from the extra16 namespace."
    - "urllib.parse.ParseResult.__qualname__ == 'ParseResult' — already covered by extra4; cross-namespace anchor provided here."
    - "urllib.parse.ParseResult.geturl.__qualname__ == 'ParseResult.geturl' — len 18. No prior spec checks any ParseResult method qualname. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.SplitResult.__qualname__ == 'SplitResult' — len 11. Already covered by extra4; cross-namespace anchor provided here."
    - "urllib.parse.DefragResult.__qualname__ == 'DefragResult' — len 12. Already covered by extra4; cross-namespace anchor and __len__() check provided here."
    - "urllib.parse.urldefrag.__qualname__ == 'urldefrag' — len 9. No prior spec checks urldefrag qualname. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.parse_qs.__qualname__ == 'parse_qs' — len 8. extra5 covers parse_qs in its __qualname__.__eq__ table; cross-namespace anchor provided here."
    - "urllib.parse.parse_qsl.__qualname__ == 'parse_qsl' — len 9. extra5 covers parse_qsl in its __qualname__.__eq__ table; cross-namespace anchor provided here."
    - "urllib.parse.urlencode.__qualname__ == 'urlencode' — len 9. extra4 covers urlencode in its __qualname__.__eq__ table; cross-namespace anchor provided here."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ParseResult.geturl __qualname__.__eq__
#
# urllib_parse_extra4 covers __qualname__.__eq__ for ParseResult the class
# ('ParseResult') but not for any of its methods.
# urllib.parse.ParseResult.geturl.__qualname__ == 'ParseResult.geturl'.
# len('ParseResult.geturl') == 18.
# No prior spec checks the __qualname__ of any ParseResult method.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra16.ParseResult.geturl_qualname_eq:
  description: "urllib.parse.ParseResult.geturl.__qualname__ == 'ParseResult.geturl' — no prior spec checks any ParseResult method qualname"
  category: class_qualnames
  kind: python_call_eq
  function: ParseResult.geturl.__qualname__.__eq__
  args: ["ParseResult.geturl"]
  expected: true

invariant urllib_parse_extra16.ParseResult.geturl_qualname_len:
  description: "len(urllib.parse.ParseResult.geturl.__qualname__) == 18 — len('ParseResult.geturl') == 18"
  category: class_qualnames
  kind: python_call_eq
  function: ParseResult.geturl.__qualname__.__len__
  args: []
  expected: 18

# ---------------------------------------------------------------------------
# urldefrag __qualname__.__eq__ and __len__()
#
# urllib_parse_extra4 covers urlparse/urlsplit/urljoin/urlencode/quote/unquote.
# urllib_parse_extra5 covers quote_plus/unquote_plus/parse_qs/parse_qsl.
# urllib_parse_extra15 covers urlunparse.
# urldefrag is not covered by any prior spec for __qualname__.__eq__.
# urllib.parse.urldefrag.__qualname__ == 'urldefrag' (len 9).
# ---------------------------------------------------------------------------

invariant urllib_parse_extra16.urldefrag.qualname_eq:
  description: "urllib.parse.urldefrag.__qualname__ == 'urldefrag' — no prior spec checks this attribute"
  category: function_qualnames
  kind: python_call_eq
  function: urldefrag.__qualname__.__eq__
  args: ["urldefrag"]
  expected: true

invariant urllib_parse_extra16.urldefrag.qualname_len:
  description: "len(urllib.parse.urldefrag.__qualname__) == 9 — len('urldefrag') == 9"
  category: function_qualnames
  kind: python_call_eq
  function: urldefrag.__qualname__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# DefragResult __qualname__.__len__()
#
# urllib_parse_extra4 covers DefragResult.__qualname__.__eq__ == 'DefragResult'.
# urllib_parse_extra14 covers __qualname__.__len__() for ParseResult and
# SplitResult but NOT DefragResult.
# len('DefragResult') == 12.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra16.DefragResult.qualname_len:
  description: "len(urllib.parse.DefragResult.__qualname__) == 12 — len('DefragResult') == 12; extra14 covers ParseResult/SplitResult lengths but not DefragResult"
  category: class_qualnames
  kind: python_call_eq
  function: DefragResult.__qualname__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# Cross-namespace anchors for parse_qs, parse_qsl, urlencode, ParseResult,
# SplitResult, DefragResult
#
# These qualnames are checked in earlier specs (extra4 for result classes and
# urlencode; extra5 for parse_qs/parse_qsl). The standalone invariants below
# anchor them from the extra16 namespace as cross-namespace regression
# checkpoints.
# ---------------------------------------------------------------------------

table urllib_parse_extra16.function_qualname_anchors:
  description: "Cross-namespace __qualname__.__eq__ anchors for parse_qs, parse_qsl, and urlencode"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqa16

  columns: [id, function, args, expected]
  rows:
    - [parse_qs,  parse_qs.__qualname__.__eq__,  ["parse_qs"],  true]
    - [parse_qsl, parse_qsl.__qualname__.__eq__, ["parse_qsl"], true]
    - [urlencode, urlencode.__qualname__.__eq__, ["urlencode"], true]

table urllib_parse_extra16.class_qualname_anchors:
  description: "Cross-namespace __qualname__.__eq__ anchors for ParseResult, SplitResult, DefragResult"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: cqa16

  columns: [id, function, args, expected]
  rows:
    - [ParseResult,  ParseResult.__qualname__.__eq__,  ["ParseResult"],  true]
    - [SplitResult,  SplitResult.__qualname__.__eq__,  ["SplitResult"],  true]
    - [DefragResult, DefragResult.__qualname__.__eq__, ["DefragResult"], true]
