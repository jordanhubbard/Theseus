spec: uuid_extra113
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra112.zspec.zsdl — covers UUID.__dict__.__class__.__module__.__eq__('builtins') / UUID.__weakref__.__class__.__module__.__eq__('builtins') / UUID.__weakref__.__class__.__name__.__len__()==17 / UUID.__init_subclass__.__name__.__len__()==17 (table + invariants)."
    - "uuid_extra99.zspec.zsdl — covers SafeUUID.__class__.__name__.__eq__('EnumType') / SafeUUID.__module__.__eq__('uuid') / SafeUUID.__mro__.__len__()==3 as table rows and standalone invariants."
    - "uuid_extra98.zspec.zsdl — covers SafeUUID.__name__.__eq__('SafeUUID') / SafeUUID.__name__.__len__()==8 / SafeUUID.__qualname__.__eq__('SafeUUID') / SafeUUID.__qualname__.__len__()==8 as table rows and standalone invariants."
    - "uuid_extra97.zspec.zsdl — covers SafeUUID.__bases__[0].__name__.__eq__('Enum') / SafeUUID.safe.value.__eq__(0) / SafeUUID.unsafe.value.__eq__(-1) as table rows and standalone invariants."
  notes:
    - "This spec extends uuid through uuid_extra112; it does NOT duplicate invariants present in those files."
    - "Wave 281 theme: SafeUUID metaclass module and MRO member names not yet covered — extra99 anchors SafeUUID.__class__.__name__.__eq__('EnumType'); extra98 anchors __name__/__qualname__ equality/length; extra97 anchors __bases__[0].__name__.__eq__('Enum'); NOT YET covered: SafeUUID.__class__.__module__.__eq__('enum') and len==4; SafeUUID.__class__.__name__.__len__()==8; SafeUUID.__bases__[0].__name__.__len__()==4; SafeUUID.__mro__[1].__name__.__eq__('Enum'); SafeUUID.__mro__[2].__name__.__eq__('object')."
    - "uuid.SafeUUID.__class__.__module__ == 'enum'. len('enum')==4. SafeUUID.__class__ is EnumType (the enum metaclass); EnumType is defined in Lib/enum.py and has __module__=='enum'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__class__.__name__.__len__() == 8. len('EnumType')==8. Same length as 'SafeUUID' itself (8 chars) — a coincidence: the enum class name and its metaclass name share the same character count. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__bases__[0].__name__.__len__() == 4. len('Enum')==4. SafeUUID's direct base is Enum (not IntEnum); the 4-char name matches len('uuid')==4 — the module name and the base class name share the same length. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__mro__[1].__name__ == 'Enum'. The MRO is (SafeUUID, Enum, object); mro[1] is Enum. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__mro__[2].__name__ == 'object'. mro[2] is object — the universal base class. len('object')==6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: SafeUUID is a Python enum.Enum subclass (not IntEnum as might be assumed). The MRO (SafeUUID, Enum, object) has depth 3. The metaclass is EnumType (introduced in Python 3.11, replacing EnumMeta). EnumType.__module__=='enum' because it is defined in Lib/enum.py. Notable length coincidences: len('SafeUUID')==len('EnumType')==8; len('Enum')==len('uuid')==4. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__class__.__module__.__eq__('enum') == True
# uuid.SafeUUID.__class__.__module__.__len__() == 4
# uuid.SafeUUID.__class__.__name__.__len__() == 8
# uuid.SafeUUID.__bases__[0].__name__.__len__() == 4
# uuid.SafeUUID.__mro__[1].__name__.__eq__('Enum') == True
#
# Wave 281 theme: SafeUUID metaclass module and length coincidences.
#
# SafeUUID.__class__ is EnumType — the metaclass for all Python enums since 3.11.
# EnumType is defined in Lib/enum.py with __module__=='enum' (4 chars). The 4-char
# module name 'enum' coincidentally matches the 4-char base class name 'Enum'
# (SafeUUID.__bases__[0].__name__). Also, the metaclass name 'EnumType' (8 chars)
# coincidentally matches the enum class name 'SafeUUID' (8 chars). These length
# coincidences make the SafeUUID type topology particularly rich for invariants.
# extra99 anchors __class__.__name__.__eq__('EnumType'); no prior uuid spec anchors
# the __class__.__module__ or any of these lengths. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table uuid_extra113.SafeUUID_metaclass_module_and_lengths:
  description: "SafeUUID.__class__.__module__.__eq__('enum')==True / SafeUUID.__class__.__module__.__len__()==4 / SafeUUID.__class__.__name__.__len__()==8 / SafeUUID.__bases__[0].__name__.__len__()==4 / SafeUUID.__mro__[1].__name__.__eq__('Enum')==True — EnumType metaclass module is 'enum' (4 chars); coincidences: len('enum')==len('Enum')==4 (module name and base class name same length); len('EnumType')==len('SafeUUID')==8 (metaclass name and enum name same length); no prior uuid spec anchors SafeUUID.__class__.__module__ or these lengths; first uuidsafe113 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidsafe113

  columns: [id, function, args, expected, description]
  rows:
    - [cls_mod_eq,         "SafeUUID.__class__.__module__.__eq__",      ["enum"],  true, "SafeUUID.__class__.__module__ is 'enum' (EnumType metaclass defined in Lib/enum.py; extra99 anchors __class__.__name__.__eq__('EnumType'); no prior spec anchors __module__)"]
    - [cls_mod_len,        "SafeUUID.__class__.__module__.__len__",      [],        4,    "SafeUUID.__class__.__module__.__len__() is 4 (len('enum')==4; coincidentally same as len('Enum')==4 — module name and base class name share length)"]
    - [cls_name_len,       "SafeUUID.__class__.__name__.__len__",        [],        8,    "SafeUUID.__class__.__name__.__len__() is 8 (len('EnumType')==8; coincidentally same as len('SafeUUID')==8 — metaclass name and enum class name share length)"]
    - [bases_name_len,     "SafeUUID.__bases__[0].__name__.__len__",     [],        4,    "SafeUUID.__bases__[0].__name__.__len__() is 4 (len('Enum')==4; coincidentally same as len('enum')==4 — base class name and module name share length; extra97 anchors __eq__('Enum'))"]
    - [mro1_name_eq,       "SafeUUID.__mro__[1].__name__.__eq__",        ["Enum"],  true, "SafeUUID.__mro__[1].__name__ is 'Enum' (mro[1] is the direct base class; MRO is (SafeUUID, Enum, object); no prior spec anchors mro[1] by index)"]

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__mro__[2].__name__.__eq__('object') == True
# uuid.SafeUUID.__mro__[1].__name__.__eq__('Enum') == True
# uuid.SafeUUID.__class__.__module__.__eq__('enum') == True
# uuid.SafeUUID.__class__.__module__.__len__() == 4
# uuid.SafeUUID.__bases__[0].__name__.__len__() == 4
#
# Wave 281 theme: SafeUUID MRO member names accessed by index.
#
# The MRO of SafeUUID is (SafeUUID, Enum, object). Accessing mro[1] yields Enum
# and mro[2] yields object. extra97 anchors __bases__[0].__name__.__eq__('Enum')
# (i.e., that Enum is the direct parent), but no prior uuid spec anchors the MRO
# by numeric index. The mro[2].__name__=='object' anchor confirms that SafeUUID's
# ultimate ancestor (before the MRO terminates) is the standard Python object base.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra113.SafeUUID_mro_index_access:
  description: "SafeUUID.__mro__[2].__name__.__eq__('object')==True / SafeUUID.__mro__[1].__name__.__eq__('Enum')==True / SafeUUID.__class__.__module__.__eq__('enum')==True / SafeUUID.__class__.__module__.__len__()==4 / SafeUUID.__bases__[0].__name__.__len__()==4 — MRO index access: mro[1]=='Enum', mro[2]=='object'; extra97 anchors __bases__[0].__name__.__eq__('Enum') but NOT mro index access; extra99 anchors __mro__.__len__()==3 but NOT individual mro entries; EnumType metaclass module 'enum'=4 chars; first uuidsafe113 MRO index anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidsafe113

  columns: [id, function, args, expected, description]
  rows:
    - [mro2_name_eq,       "SafeUUID.__mro__[2].__name__.__eq__",        ["object"], true, "SafeUUID.__mro__[2].__name__ is 'object' (mro[2] is the universal base; MRO terminates at object; no prior spec anchors mro[2] for SafeUUID)"]
    - [mro1_name_eq2,      "SafeUUID.__mro__[1].__name__.__eq__",        ["Enum"],   true, "SafeUUID.__mro__[1].__name__ is 'Enum' (cross-check; mro[1] is the direct base; confirms Enum is SafeUUID's parent)"]
    - [cls_mod_eq2,        "SafeUUID.__class__.__module__.__eq__",       ["enum"],   true, "SafeUUID.__class__.__module__ is 'enum' (cross-check; EnumType metaclass is from the enum module)"]
    - [cls_mod_len2,       "SafeUUID.__class__.__module__.__len__",       [],         4,    "SafeUUID.__class__.__module__.__len__() is 4 (cross-check; len('enum')==4; same as len('Enum')==4)"]
    - [bases_name_len2,    "SafeUUID.__bases__[0].__name__.__len__",      [],         4,    "SafeUUID.__bases__[0].__name__.__len__() is 4 (cross-check; len('Enum')==4; confirms 4-char coincidence)"]

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__class__.__module__.__eq__('enum') == True
# uuid.SafeUUID.__class__.__name__.__len__() == 8
# uuid.SafeUUID.__bases__[0].__name__.__len__() == 4
# uuid.SafeUUID.__mro__[1].__name__.__eq__('Enum') == True
# uuid.SafeUUID.__mro__[2].__name__.__eq__('object') == True
#
# Wave 281 theme: unified cross-check for SafeUUID metaclass and MRO topology.
#
# This table groups all five key new facts about SafeUUID's metaclass and MRO in
# a single cross-check view. Together they confirm: EnumType (metaclass) is from
# the 'enum' module (4 chars); 'EnumType' is 8 chars; SafeUUID's base Enum is 4
# chars; the MRO entries at positions 1 and 2 are Enum and object respectively.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra113.SafeUUID_metaclass_mro_unified_cross_check:
  description: "SafeUUID.__class__.__module__.__eq__('enum')==True / SafeUUID.__class__.__name__.__len__()==8 / SafeUUID.__bases__[0].__name__.__len__()==4 / SafeUUID.__mro__[1].__name__.__eq__('Enum')==True / SafeUUID.__mro__[2].__name__.__eq__('object')==True — unified cross-check: EnumType metaclass from 'enum' module (4 chars); metaclass name 'EnumType'=8 chars; base class 'Enum'=4 chars; MRO[1]=Enum, MRO[2]=object; extra97/extra98/extra99 cover eq assertions; this table adds first multi-axis cross-check; first uuidsafe113 unified anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidsafe113

  columns: [id, function, args, expected, description]
  rows:
    - [cls_mod_eq3,        "SafeUUID.__class__.__module__.__eq__",       ["enum"],   true, "SafeUUID.__class__.__module__ is 'enum' (unified cross-check; EnumType from Lib/enum.py)"]
    - [cls_name_len2,      "SafeUUID.__class__.__name__.__len__",         [],         8,    "SafeUUID.__class__.__name__.__len__() is 8 (unified cross-check; len('EnumType')==8; same as len('SafeUUID')==8)"]
    - [bases_name_len3,    "SafeUUID.__bases__[0].__name__.__len__",      [],         4,    "SafeUUID.__bases__[0].__name__.__len__() is 4 (unified cross-check; len('Enum')==4; same as len('enum')==4)"]
    - [mro1_name_eq3,      "SafeUUID.__mro__[1].__name__.__eq__",         ["Enum"],   true, "SafeUUID.__mro__[1].__name__ is 'Enum' (unified cross-check; mro[1] is direct base)"]
    - [mro2_name_eq2,      "SafeUUID.__mro__[2].__name__.__eq__",         ["object"], true, "SafeUUID.__mro__[2].__name__ is 'object' (unified cross-check; mro[2] is universal base)"]

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__class__.__module__.__eq__('enum') — standalone
#
# uuid.SafeUUID.__class__.__module__ is 'enum'. SafeUUID.__class__ is EnumType —
# the metaclass for Python enums introduced in Python 3.11 (replacing EnumMeta).
# EnumType is defined in Lib/enum.py and therefore has __module__=='enum'. This is
# the module where all the enum machinery lives: Enum, IntEnum, StrEnum, EnumType,
# etc. extra99 anchors SafeUUID.__class__.__name__.__eq__('EnumType') as a table row
# and standalone; no prior uuid spec anchors SafeUUID.__class__.__module__ in any form.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra113.SafeUUID_class_module_enum:
  description: "uuid.SafeUUID.__class__.__module__.__eq__('enum') == True — SafeUUID.__class__ is EnumType; EnumType is defined in Lib/enum.py with __module__=='enum'; extra99 anchors __class__.__name__.__eq__('EnumType') as table row and standalone; no prior uuid spec anchors SafeUUID.__class__.__module__ in any form; first standalone under uuidsafe113"
  category: type_identity
  kind: python_call_eq
  function: "SafeUUID.__class__.__module__.__eq__"
  args: ["enum"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__class__.__name__.__len__() == 8 — standalone
#
# uuid.SafeUUID.__class__.__name__.__len__() is 8. 'EnumType' has 8 chars:
# 'Enum'=4 + 'Type'=4 = 8. A notable coincidence: len('EnumType')==8 equals
# len('SafeUUID')==8 — the metaclass name and the enum class name have the same
# character count. The 4-char body 'Enum' in 'EnumType' also matches the 4-char
# names 'Enum' (base class) and 'uuid' (module). extra99 anchors
# SafeUUID.__class__.__name__.__eq__('EnumType'); no prior uuid spec anchors
# SafeUUID.__class__.__name__.__len__()==8 as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra113.SafeUUID_class_name_len_8:
  description: "uuid.SafeUUID.__class__.__name__.__len__() == 8 — len('EnumType')==8 ('Enum'=4 + 'Type'=4; metaclass name 8 chars; coincidentally same length as len('SafeUUID')==8 — metaclass and enum class share name length; extra99 anchors __eq__('EnumType'); no prior spec anchors __len__()==8 for SafeUUID class name; first standalone under uuidsafe113)"
  category: type_identity
  kind: python_call_eq
  function: "SafeUUID.__class__.__name__.__len__"
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__bases__[0].__name__.__len__() == 4 — standalone
#
# uuid.SafeUUID.__bases__[0].__name__.__len__() is 4. 'Enum' has 4 chars. The 4-char
# name 'Enum' coincidentally matches the 4-char module name 'uuid' and the 4-char
# metaclass module name 'enum'. extra97 anchors SafeUUID.__bases__[0].__name__.__eq__
# ('Enum') as a table row; no prior uuid spec anchors the LENGTH (__len__()==4) of
# the base class name as a standalone. The triple coincidence of 4-char names
# ('Enum', 'enum', 'uuid') around SafeUUID's identity is unusual.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra113.SafeUUID_bases_name_len_4:
  description: "uuid.SafeUUID.__bases__[0].__name__.__len__() == 4 — len('Enum')==4 (SafeUUID's direct base; triple 4-char coincidence: 'Enum'=4, 'enum'=4, 'uuid'=4 — base class name, metaclass module, and enum module all 4 chars; extra97 anchors __eq__('Enum') as table row; no prior spec anchors __len__()==4 for SafeUUID base name as standalone; first standalone under uuidsafe113)"
  category: type_identity
  kind: python_call_eq
  function: "SafeUUID.__bases__[0].__name__.__len__"
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__mro__[1].__name__.__eq__('Enum') — standalone
#
# uuid.SafeUUID.__mro__[1].__name__ is 'Enum'. The MRO of SafeUUID is the tuple
# (SafeUUID, Enum, object). mro[1] is the second element — the direct parent class
# Enum. extra99 anchors SafeUUID.__mro__.__len__()==3 (confirming MRO depth);
# extra97 anchors __bases__[0].__name__.__eq__('Enum') (confirming the base via
# __bases__). No prior uuid spec anchors any SafeUUID MRO entry by numeric index
# as a standalone. This standalone uses the mro[1] access path to confirm Enum
# as the intermediate class between SafeUUID and object.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra113.SafeUUID_mro1_name_Enum:
  description: "uuid.SafeUUID.__mro__[1].__name__.__eq__('Enum') == True — mro[1] is the direct base class Enum (MRO is (SafeUUID, Enum, object); extra99 anchors __mro__.__len__()==3; extra97 anchors __bases__[0].__name__.__eq__('Enum') via __bases__; no prior spec anchors SafeUUID MRO entry by numeric index as standalone; first mro-index standalone under uuidsafe113)"
  category: type_identity
  kind: python_call_eq
  function: "SafeUUID.__mro__[1].__name__.__eq__"
  args: ["Enum"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__mro__[2].__name__.__eq__('object') — standalone
#
# uuid.SafeUUID.__mro__[2].__name__ is 'object'. The MRO of SafeUUID is the tuple
# (SafeUUID, Enum, object). mro[2] is the third (last) element — the universal Python
# base class object. All Python classes ultimately inherit from object. In SafeUUID's
# 3-element MRO, object is at index 2. No prior uuid spec anchors SafeUUID.__mro__[2]
# by numeric index. The name 'object' (6 chars) confirms the canonical root of
# SafeUUID's inheritance chain. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra113.SafeUUID_mro2_name_object:
  description: "uuid.SafeUUID.__mro__[2].__name__.__eq__('object') == True — mro[2] is object (universal Python base class; MRO terminus for SafeUUID; MRO is (SafeUUID, Enum, object) depth 3; extra99 anchors __mro__.__len__()==3; no prior spec anchors SafeUUID.__mro__[2] by index as standalone; first mro[2] standalone under uuidsafe113)"
  category: type_identity
  kind: python_call_eq
  function: "SafeUUID.__mro__[2].__name__.__eq__"
  args: ["object"]
  expected: true
