spec: itertools_extra123
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra122.zspec.zsdl."
    - "This spec covers: itertools.zip_longest class slot qualname attributes not previously covered — zip_longest.__next__.__qualname__='zip_longest.__next__'(20), zip_longest.__iter__.__qualname__='zip_longest.__iter__'(20), zip_longest.__new__.__qualname__='zip_longest.__new__'(19); __init__.__qualname__='object.__init__'(15); slot class names; wave 274."
    - "Prior spec extra109 covered zip_longest.__new__.__class__.__name__=='builtin_function_or_method' and extra110 covered zip_longest.__init__.__class__.__name__=='wrapper_descriptor' and __init__.__qualname__=='object.__init__'. New here: zip_longest.__next__.__qualname__, zip_longest.__iter__.__qualname__, zip_longest.__new__.__qualname__ string values and lengths."
    - "itertools.zip_longest.__next__.__qualname__ == 'zip_longest.__next__' (len 20). Verified with Python 3.14.3."
    - "itertools.zip_longest.__iter__.__qualname__ == 'zip_longest.__iter__' (len 20). Verified with Python 3.14.3."
    - "itertools.zip_longest.__new__.__qualname__ == 'zip_longest.__new__' (len 19). Verified with Python 3.14.3."
    - "itertools.zip_longest.__init__.__qualname__ == 'object.__init__' (len 15). Verified with Python 3.14.3."
    - "zip_longest.__name__ == 'zip_longest' (len 11). zip_longest(11)+dot(1)+__next__(8)=20; zip_longest(11)+dot(1)+__new__(7)=19."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.zip_longest.__next__ and __iter__ slot qualname equality
#
# Wave 274 theme: itertools.zip_longest is a C-extension type that zips
# multiple iterables, padding shorter ones with a fillvalue. It exposes two
# iterator protocol slots: __next__ (tp_iternext) and __iter__ (tp_iter).
# Both are wrapper_descriptor objects. Their qualnames follow the pattern:
#   <classname>.<slotname>
# zip_longest(11) + dot(1) + __next__(8) = 20 chars
# zip_longest(11) + dot(1) + __iter__(8) = 20 chars
# Both qualnames have length 20 because '__next__' and '__iter__' each have
# 8 chars. This is 1 more than the accumulate slots (19, extra122) because
# 'zip_longest' (11) is 1 char longer than 'accumulate' (10).
#
# zip_longest.__next__.__qualname__ == 'zip_longest.__next__'  (len 20)
# zip_longest.__iter__.__qualname__ == 'zip_longest.__iter__'  (len 20)
#
# New to extra123.
# ---------------------------------------------------------------------------

table itertools_extra123.zip_longest_next_iter_qualname_eq:
  description: "itertools.zip_longest slot qualname equality: __next__='zip_longest.__next__'(20), __iter__='zip_longest.__iter__'(20); 11+1+8=20; 1 more than accumulate (19, extra122); both wrapper_descriptor; wave 274; new to extra123"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolszlniq123

  columns: [id, function, args, expected, description]
  rows:
    - [zl_next_qualname_eq,
       "zip_longest.__next__.__qualname__.__eq__",
       ["zip_longest.__next__"],
       true,
       "itertools.zip_longest.__next__.__qualname__.__eq__('zip_longest.__next__') == True — zip_longest exposes its tp_iternext slot as __next__; qualname is 'zip_longest.__next__' (20 chars = 11+1+8); str.__eq__('zip_longest.__next__') returns True; new to extra123"]
    - [zl_iter_qualname_eq,
       "zip_longest.__iter__.__qualname__.__eq__",
       ["zip_longest.__iter__"],
       true,
       "itertools.zip_longest.__iter__.__qualname__.__eq__('zip_longest.__iter__') == True — zip_longest exposes its tp_iter slot as __iter__; qualname is 'zip_longest.__iter__' (20 chars = 11+1+8); str.__eq__('zip_longest.__iter__') returns True; new to extra123"]
    - [zl_next_qualname_len,
       "zip_longest.__next__.__qualname__.__len__",
       [],
       20,
       "itertools.zip_longest.__next__.__qualname__.__len__() == 20 — 'zip_longest.__next__' = zip_longest(11)+dot(1)+__next__(8)=20; 1 more than accumulate.__next__ qualname (19, extra122); str.__len__() returns 20; new to extra123"]
    - [zl_iter_qualname_len,
       "zip_longest.__iter__.__qualname__.__len__",
       [],
       20,
       "itertools.zip_longest.__iter__.__qualname__.__len__() == 20 — 'zip_longest.__iter__' = zip_longest(11)+dot(1)+__iter__(8)=20; equal to __next__ qualname length because '__iter__' and '__next__' both have 8 chars; str.__len__() returns 20; new to extra123"]
    - [zl_next_class_name_eq,
       "zip_longest.__next__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.zip_longest.__next__.__class__.__name__.__eq__('wrapper_descriptor') == True — tp_iternext slot on zip_longest is a wrapper_descriptor; consistent with all itertools C-iterator __next__ slots; str.__eq__('wrapper_descriptor') returns True; new to extra123"]
    - [zl_iter_class_name_eq,
       "zip_longest.__iter__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.zip_longest.__iter__.__class__.__name__.__eq__('wrapper_descriptor') == True — tp_iter slot on zip_longest is a wrapper_descriptor; consistent with all itertools C-iterator __iter__ slots; str.__eq__('wrapper_descriptor') returns True; new to extra123"]

# ---------------------------------------------------------------------------
# Table 2: itertools.zip_longest.__new__ and __init__ slot qualnames
#
# Wave 274 theme: zip_longest.__new__.__qualname__ == 'zip_longest.__new__'
# (len 19): zip_longest(11) + dot(1) + __new__(7) = 19. This is 1 less than
# the __next__ and __iter__ qualnames (both 20) because '__new__' has 7 chars
# while '__next__' and '__iter__' both have 8 chars. The same 1-char gap
# holds for accumulate (18 vs 19, extra122). zip_longest.__init__.__qualname__
# == 'object.__init__' (len 15): zip_longest has no custom tp_init, so it
# inherits object.__init__; the qualname refers to 'object', not 'zip_longest'.
# This contrasts with __next__ and __iter__ whose qualnames name 'zip_longest'.
#
# zip_longest.__new__.__qualname__  == 'zip_longest.__new__'  (len 19)
# zip_longest.__init__.__qualname__ == 'object.__init__'      (len 15)
#
# New to extra123.
# ---------------------------------------------------------------------------

table itertools_extra123.zip_longest_new_init_qualname:
  description: "itertools.zip_longest.__new__ qualname: 'zip_longest.__new__'(19); 11+1+7=19, one less than __next__/__iter__ (20); __init__ qualname: 'object.__init__'(15) — inherited; prior extra110 covered __init__.__class__.__name__; wave 274; new to extra123"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolszlnwq123

  columns: [id, function, args, expected, description]
  rows:
    - [zl_new_qualname_eq,
       "zip_longest.__new__.__qualname__.__eq__",
       ["zip_longest.__new__"],
       true,
       "itertools.zip_longest.__new__.__qualname__.__eq__('zip_longest.__new__') == True — zip_longest exposes its tp_new slot as __new__; qualname is 'zip_longest.__new__' (19 chars); prior extra109 covered __new__.__class__.__name__; str.__eq__('zip_longest.__new__') returns True; new to extra123"]
    - [zl_new_qualname_len,
       "zip_longest.__new__.__qualname__.__len__",
       [],
       19,
       "itertools.zip_longest.__new__.__qualname__.__len__() == 19 — 'zip_longest.__new__' = zip_longest(11)+dot(1)+__new__(7)=19; one less than __next__/__iter__ (20) because '__new__' is 7 chars vs 8; str.__len__() returns 19; new to extra123"]
    - [zl_init_qualname_eq,
       "zip_longest.__init__.__qualname__.__eq__",
       ["object.__init__"],
       true,
       "itertools.zip_longest.__init__.__qualname__.__eq__('object.__init__') == True — zip_longest has no custom tp_init; it inherits object.__init__; qualname refers to the defining class 'object' not 'zip_longest'; str.__eq__('object.__init__') returns True; prior extra110 confirmed __init__.__class__.__name__=='wrapper_descriptor'; new to extra123"]
    - [zl_init_qualname_len,
       "zip_longest.__init__.__qualname__.__len__",
       [],
       15,
       "itertools.zip_longest.__init__.__qualname__.__len__() == 15 — 'object.__init__' has 15 chars: object(6)+dot(1)+__init__(8)=15; differs from __next__ qualname (20) and __new__ qualname (19) because __init__ is inherited from object; str.__len__() returns 15; new to extra123"]
    - [zl_init_qualname_ne_new,
       "zip_longest.__init__.__qualname__.__eq__",
       ["zip_longest.__init__"],
       false,
       "itertools.zip_longest.__init__.__qualname__.__eq__('zip_longest.__init__') == False — __init__ qualname is 'object.__init__' not 'zip_longest.__init__' because __init__ is inherited from object; str.__eq__('zip_longest.__init__') returns False; new to extra123"]

# ---------------------------------------------------------------------------
# Table 3: itertools.zip_longest slot qualname length cross-comparison
#
# Wave 274 theme: Comparing qualname lengths across zip_longest's slot types.
# __next__ and __iter__ share length 20 (both slot names are 8 chars);
# __new__ has length 19 (slot name is 7 chars); __init__ has length 15
# (inherits from 'object', so prefix is 'object' not 'zip_longest').
# This table confirms the arithmetic:
#   __next__: 11+1+8 = 20
#   __iter__: 11+1+8 = 20
#   __new__:  11+1+7 = 19
#   __init__:  6+1+8 = 15  (prefix is 'object', not 'zip_longest')
#
# New to extra123.
# ---------------------------------------------------------------------------

table itertools_extra123.zip_longest_slot_qualname_length_comparison:
  description: "itertools.zip_longest slot qualname lengths: __next__=20, __iter__=20, __new__=19, __init__=15 (inherited from object); __next__==__iter__ (8-char slot names); __new__ is 1 less; __init__ differs because it is inherited; wave 274; new to extra123"
  kind: python_call_eq
  category: type_identity
  id_prefix: itertoolszlslc123

  columns: [id, function, args, expected, description]
  rows:
    - [zl_next_len_20,
       "zip_longest.__next__.__qualname__.__len__",
       [],
       20,
       "itertools.zip_longest.__next__.__qualname__.__len__() == 20 — formula: 'zip_longest'(11)+dot(1)+'__next__'(8)=20; 1 more than accumulate.__next__ qualname (19, extra122) because 'zip_longest' is 1 char longer than 'accumulate'; str.__len__() returns 20; new to extra123"]
    - [zl_iter_len_20,
       "zip_longest.__iter__.__qualname__.__len__",
       [],
       20,
       "itertools.zip_longest.__iter__.__qualname__.__len__() == 20 — formula: 'zip_longest'(11)+dot(1)+'__iter__'(8)=20; equal to __next__ qualname length because '__iter__' and '__next__' share the same 8-char length; str.__len__() returns 20; new to extra123"]
    - [zl_new_len_19,
       "zip_longest.__new__.__qualname__.__len__",
       [],
       19,
       "itertools.zip_longest.__new__.__qualname__.__len__() == 19 — formula: 'zip_longest'(11)+dot(1)+'__new__'(7)=19; one less than __next__/__iter__ (20) because '__new__' is 7 chars; mirrors accumulate (18) offset by 1; str.__len__() returns 19; new to extra123"]
    - [zl_next_qualname_ne_new,
       "zip_longest.__next__.__qualname__.__eq__",
       ["zip_longest.__new__"],
       false,
       "itertools.zip_longest.__next__.__qualname__.__eq__('zip_longest.__new__') == False — __next__ qualname is 'zip_longest.__next__', not 'zip_longest.__new__'; they are different slot names; str.__eq__('zip_longest.__new__') returns False; new to extra123"]
    - [zl_next_iter_qualname_ne_each_other,
       "zip_longest.__next__.__qualname__.__eq__",
       ["zip_longest.__iter__"],
       false,
       "itertools.zip_longest.__next__.__qualname__.__eq__('zip_longest.__iter__') == False — __next__ qualname is 'zip_longest.__next__', not 'zip_longest.__iter__'; distinct slot qualnames despite equal lengths; str.__eq__('zip_longest.__iter__') returns False; new to extra123"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra123
# ---------------------------------------------------------------------------

invariant itertools_extra123.zl_next_qualname_eq:
  description: "itertools.zip_longest.__next__.__qualname__ == 'zip_longest.__next__' — tp_iternext slot; len=20; 11+1+8=20; 1 more than accumulate (19, extra122); wave 274; new to extra123"
  kind: python_call_eq
  function: "zip_longest.__next__.__qualname__.__eq__"
  args: ["zip_longest.__next__"]
  expected: true

invariant itertools_extra123.zl_iter_qualname_eq:
  description: "itertools.zip_longest.__iter__.__qualname__ == 'zip_longest.__iter__' — tp_iter slot; len=20; same length as __next__ qualname; both wrapper_descriptor; wave 274; new to extra123"
  kind: python_call_eq
  function: "zip_longest.__iter__.__qualname__.__eq__"
  args: ["zip_longest.__iter__"]
  expected: true

invariant itertools_extra123.zl_new_qualname_len:
  description: "itertools.zip_longest.__new__.__qualname__.__len__() == 19 — 'zip_longest.__new__' = 11+1+7=19; one less than __next__/__iter__ (20); wave 274; new to extra123"
  kind: python_call_eq
  function: "zip_longest.__new__.__qualname__.__len__"
  args: []
  expected: 19

invariant itertools_extra123.zl_init_qualname_eq:
  description: "itertools.zip_longest.__init__.__qualname__ == 'object.__init__' — inherited from object; qualname refers to defining class; len=15; differs from __next__/__iter__/__new__ which name 'zip_longest'; wave 274; new to extra123"
  kind: python_call_eq
  function: "zip_longest.__init__.__qualname__.__eq__"
  args: ["object.__init__"]
  expected: true

invariant itertools_extra123.zl_next_class_wrapper_descriptor:
  description: "itertools.zip_longest.__next__.__class__.__name__ == 'wrapper_descriptor' — tp_iternext slot type; consistent with all itertools C-iterator __next__ slots; wave 274; new to extra123"
  kind: python_call_eq
  function: "zip_longest.__next__.__class__.__name__.__eq__"
  args: ["wrapper_descriptor"]
  expected: true

