spec: re_extra616
version: ">=3.9"
backend: python_module(re)
docs: "Behavioral specs for re.Pattern and re.Match method qualnames."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module Pattern and Match objects"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __qualname__ attributes of re.Pattern and re.Match methods"
  created_at: "2026-04-12T00:00:00Z"

table re_extra616.pattern_method_qualnames:
  description: "re.Pattern method __qualname__ attributes"
  kind: python_call_eq
  category: method_metadata
  id_prefix: re616pt
  columns: [id, function, args, expected]
  rows:
    - [re616pt001, re.Pattern.match.__qualname__.__eq__, ["Pattern.match"], true]
    - [re616pt002, re.Pattern.search.__qualname__.__eq__, ["Pattern.search"], true]
    - [re616pt003, re.Pattern.fullmatch.__qualname__.__eq__, ["Pattern.fullmatch"], true]
    - [re616pt004, re.Pattern.findall.__qualname__.__eq__, ["Pattern.findall"], true]
    - [re616pt005, re.Pattern.finditer.__qualname__.__eq__, ["Pattern.finditer"], true]
    - [re616pt006, re.Pattern.sub.__qualname__.__eq__, ["Pattern.sub"], true]
    - [re616pt007, re.Pattern.subn.__qualname__.__eq__, ["Pattern.subn"], true]
    - [re616pt008, re.Pattern.split.__qualname__.__eq__, ["Pattern.split"], true]

table re_extra616.match_method_qualnames:
  description: "re.Match method __qualname__ attributes"
  kind: python_call_eq
  category: method_metadata
  id_prefix: re616mt
  columns: [id, function, args, expected]
  rows:
    - [re616mt001, re.Match.group.__qualname__.__eq__, ["Match.group"], true]
    - [re616mt002, re.Match.groups.__qualname__.__eq__, ["Match.groups"], true]
    - [re616mt003, re.Match.groupdict.__qualname__.__eq__, ["Match.groupdict"], true]
    - [re616mt004, re.Match.start.__qualname__.__eq__, ["Match.start"], true]
    - [re616mt005, re.Match.end.__qualname__.__eq__, ["Match.end"], true]
    - [re616mt006, re.Match.span.__qualname__.__eq__, ["Match.span"], true]
