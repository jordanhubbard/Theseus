spec: token_extra9
version: ">=3.12"
backend: python_module(token)

docs: https://docs.python.org/3/library/token.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/token.html — Python token module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/token.py"
    - "token.zspec.zsdl — covers ENDMARKER=0, NAME=1, NUMBER=2, STRING=3, NEWLINE=4, INDENT=5, DEDENT=6, OP=55, TYPE_COMMENT=57, SOFT_KEYWORD=58, COMMENT=65, NL=66, ERRORTOKEN=67, ENCODING=68; NT_OFFSET=256; tok_name lookups [0-6]; ISEOF/ISTERMINAL/ISNONTERMINAL predicates"
    - "token_extra.zspec.zsdl — covers int type checks for all major constants, tok_name/EXACT_TOKEN_TYPES is_dict, NAME/NUMBER/STRING/NEWLINE/ENDMARKER exact values"
    - "token_extra2.zspec.zsdl — covers EXACT_TYPE/ERRORTOKEN/ENCODING/TYPE_COMMENT is_int, tok_name is_dict, tok_name min_length>=50, tok_name[0-4], ENDMARKER==0"
    - "token_extra3.zspec.zsdl — covers int type checks via tables, tok_name/EXACT_TOKEN_TYPES is_dict, NAME>0/NUMBER>0/ENDMARKER==0, tok_name[1]=='NAME'"
    - "token_extra4.zspec.zsdl — covers INDENT==5, DEDENT==6, tok_name[2-6], EXACT_TOKEN_TYPES membership '='/'+'/':'"
    - "token_extra5.zspec.zsdl — covers SOFT_KEYWORD==58, FSTRING_START==59, FSTRING_END==61, tok_name[58/59], EXACT_TOKEN_TYPES len>=40 and membership '('/')'/'.'"
    - "token_extra6.zspec.zsdl — covers ISEOF/ISTERMINAL/ISNONTERMINAL false/true checks; tok_name.__contains__(0/1/65/66); EXACT_TOKEN_TYPES.__contains__('-'/'*'); EXACT_TOKEN_TYPES['='] is int"
    - "token_extra7.zspec.zsdl — covers ISEOF/ISTERMINAL/ISNONTERMINAL __module__=='token'; tok_name[65-68]; EXACT_TOKEN_TYPES.__contains__('/'/'%'/'**'/'//'); ISEOF/ISTERMINAL additional checks"
    - "token_extra8.zspec.zsdl — covers FSTRING_MIDDLE==60/TSTRING_START==62/TSTRING_MIDDLE==63/TSTRING_END==64; N_TOKENS==69; TYPE_IGNORE==56; tok_name[7-10](LPAR/RPAR/LSQB/RSQB); tok_name.__contains__(60); EXACT_TOKEN_TYPES.__contains__('!='/'==')"
  notes:
    - "This spec extends token_extra8.zspec.zsdl."
    - "tok_name[11-16] — COLON/COMMA/SEMI/PLUS/MINUS/STAR. Prior specs cover tok_name indices 0-10 and 58/59/65-68; indices 11-16 are new in token_extra9."
    - "EXACT_TOKEN_TYPES[':'] == 11 — token_extra4 covers ':' membership; exact value 11 is new in token_extra9."
    - "EXACT_TOKEN_TYPES[','] == 12 and EXACT_TOKEN_TYPES[';'] == 13 — not covered in any prior spec."
    - "EXACT_TOKEN_TYPES['~'] == 31 and EXACT_TOKEN_TYPES['^'] == 32 — not covered in any prior spec."
    - "EXACT_TOKEN_TYPES['|'] == 18 and EXACT_TOKEN_TYPES['&'] == 19 — not covered in any prior spec."
    - "EXACT_TOKEN_TYPES['<'] == 20 and EXACT_TOKEN_TYPES['>'] == 21 — not covered in any prior spec."
    - "ISEOF.__qualname__ == 'ISEOF' and ISTERMINAL.__qualname__ == 'ISTERMINAL' — token_extra7 covers __module__; __qualname__ standalone is new in token_extra9."
    - "tok_name.__class__.__name__ == 'dict' — covered in token_extra as is_dict check; __class__.__name__ equality as standalone invariant is new in token_extra9."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# tok_name lookups — indices 11 through 16
# (token_extra9 namespace)
#
# Prior specs cover tok_name indices 0-10 (extra2/3/4/8) and 58/59/65-68.
# Indices 11-16 (COLON/COMMA/SEMI/PLUS/MINUS/STAR) are new in token_extra9.
# ---------------------------------------------------------------------------

table token_extra9.tok_name_operator_lookups:
  kind: python_call_eq
  category: tok_name
  id_prefix: tok_name_op

  columns: [id, function, args, expected]
  rows:
    - [colon, tok_name.__getitem__, [11], "COLON"]
    - [comma, tok_name.__getitem__, [12], "COMMA"]
    - [semi,  tok_name.__getitem__, [13], "SEMI"]
    - [plus,  tok_name.__getitem__, [14], "PLUS"]
    - [minus, tok_name.__getitem__, [15], "MINUS"]
    - [star,  tok_name.__getitem__, [16], "STAR"]

# ---------------------------------------------------------------------------
# EXACT_TOKEN_TYPES exact values — punctuation operators
# (token_extra9 namespace)
#
# Prior specs cover '=', '+', ':', '-', '*', '/', '%', '**', '//', '(', ')',
# '.', '!=', '=='. The following exact values are new in token_extra9.
# ---------------------------------------------------------------------------

table token_extra9.exact_token_type_values:
  kind: python_call_eq
  category: dict_contents
  id_prefix: ett_val

  columns: [id, function, args, expected]
  rows:
    - [comma,  EXACT_TOKEN_TYPES.__getitem__, [","],  12]
    - [semi,   EXACT_TOKEN_TYPES.__getitem__, [";"],  13]
    - [tilde,  EXACT_TOKEN_TYPES.__getitem__, ["~"],  31]
    - [caret,  EXACT_TOKEN_TYPES.__getitem__, ["^"],  32]
    - [pipe,   EXACT_TOKEN_TYPES.__getitem__, ["|"],  18]
    - [amp,    EXACT_TOKEN_TYPES.__getitem__, ["&"],  19]
    - [lt,     EXACT_TOKEN_TYPES.__getitem__, ["<"],  20]
    - [gt,     EXACT_TOKEN_TYPES.__getitem__, [">"],  21]

# ---------------------------------------------------------------------------
# EXACT_TOKEN_TYPES class identity
# (token_extra9 namespace)
#
# token_extra covers is_dict via isinstance; __class__.__name__ equality
# as a standalone invariant in the token_extra9 namespace is new.
# ---------------------------------------------------------------------------

invariant token_extra9.EXACT_TOKEN_TYPES.class_is_dict:
  description: "token.EXACT_TOKEN_TYPES.__class__.__name__ == 'dict'"
  category: class_names
  kind: python_call_eq
  function: EXACT_TOKEN_TYPES.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# tok_name class identity
# (token_extra9 namespace)
#
# token_extra covers is_dict; __class__.__name__ equality standalone is new.
# ---------------------------------------------------------------------------

invariant token_extra9.tok_name.class_is_dict:
  description: "token.tok_name.__class__.__name__ == 'dict'"
  category: class_names
  kind: python_call_eq
  function: tok_name.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# Predicate __qualname__ — ISEOF, ISTERMINAL, ISNONTERMINAL
# (token_extra9 namespace)
#
# token_extra7 covers these functions' __module__. __qualname__ standalone
# is not covered in any prior token spec.
# ---------------------------------------------------------------------------

invariant token_extra9.ISEOF.qualname:
  description: "token.ISEOF.__qualname__ == 'ISEOF'"
  category: function_qualnames
  kind: python_call_eq
  function: ISEOF.__qualname__.__eq__
  args: ["ISEOF"]
  expected: true

invariant token_extra9.ISTERMINAL.qualname:
  description: "token.ISTERMINAL.__qualname__ == 'ISTERMINAL'"
  category: function_qualnames
  kind: python_call_eq
  function: ISTERMINAL.__qualname__.__eq__
  args: ["ISTERMINAL"]
  expected: true

invariant token_extra9.ISNONTERMINAL.qualname:
  description: "token.ISNONTERMINAL.__qualname__ == 'ISNONTERMINAL'"
  category: function_qualnames
  kind: python_call_eq
  function: ISNONTERMINAL.__qualname__.__eq__
  args: ["ISNONTERMINAL"]
  expected: true
