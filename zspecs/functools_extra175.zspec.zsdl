spec: functools_extra175
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.lru_cache.__name__ 'lru_cache'; functools.lru_cache.__qualname__ 'lru_cache'; functools.lru_cache.__class__.__name__ 'function'; functools.cache.__name__ 'cache'; functools.cache.__qualname__ 'cache'; functools.total_ordering.__name__ 'total_ordering'; functools.total_ordering.__qualname__ 'total_ordering'; functools.singledispatch.__name__ 'singledispatch'; functools.singledispatch.__qualname__ 'singledispatch' (Wave 299)."
    - "functools.lru_cache.__name__ == 'lru_cache' — functools.lru_cache is a Python decorator function defined in Lib/functools.py that wraps a function with a memoizing callable that saves up to maxsize recent calls; its __name__ is 'lru_cache'. Verified with Python 3.14.3."
    - "functools.lru_cache.__qualname__ == 'lru_cache' — lru_cache is a module-level function in Lib/functools.py so its __qualname__ equals its __name__ ('lru_cache'); there is no enclosing class or function to prefix. Verified with Python 3.14.3."
    - "functools.lru_cache.__class__.__name__ == 'function' — lru_cache is a regular Python function (defined with def); its __class__.__name__ is 'function'. Verified with Python 3.14.3."
    - "functools.cache.__name__ == 'cache' — functools.cache is a Python decorator function defined in Lib/functools.py (added in Python 3.9) as a simpler unbounded LRU cache (equivalent to lru_cache(maxsize=None)); its __name__ is 'cache'. Verified with Python 3.14.3."
    - "functools.cache.__qualname__ == 'cache' — cache is a module-level function in Lib/functools.py so its __qualname__ equals its __name__ ('cache'). Verified with Python 3.14.3."
    - "functools.total_ordering.__name__ == 'total_ordering' — functools.total_ordering is a Python class decorator defined in Lib/functools.py that fills in missing comparison methods given __eq__ and one of __lt__, __le__, __gt__, or __ge__; its __name__ is 'total_ordering'. Verified with Python 3.14.3."
    - "functools.total_ordering.__qualname__ == 'total_ordering' — total_ordering is a module-level function in Lib/functools.py so its __qualname__ equals its __name__ ('total_ordering'). Verified with Python 3.14.3."
    - "functools.singledispatch.__name__ == 'singledispatch' — functools.singledispatch is a Python decorator function defined in Lib/functools.py that transforms a function into a single-dispatch generic function; its __name__ is 'singledispatch'. Verified with Python 3.14.3."
    - "functools.singledispatch.__qualname__ == 'singledispatch' — singledispatch is a module-level function in Lib/functools.py so its __qualname__ equals its __name__ ('singledispatch'). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.lru_cache Python function identity — __name__, __qualname__,
# __class__.__name__
#
# Wave 299 theme: functools.lru_cache Python decorator function identity —
# __name__, __qualname__, and __class__.__name__.
#
# functools.lru_cache.__name__ == 'lru_cache'
# functools.lru_cache.__qualname__ == 'lru_cache'
# functools.lru_cache.__class__.__name__ == 'function'
# functools.lru_cache.__name__ != 'cache'
#
# functools.lru_cache(maxsize=128, typed=False) is a Python decorator defined in
# Lib/functools.py. It wraps a function with a memoizing callable that saves up to
# maxsize recent calls. When maxsize is None it is an unbounded cache. It is
# a regular Python function (not a C builtin, not a class), so its __class__.__name__
# is 'function'. Its __qualname__ equals __name__ since it is module-level. New
# to extra175.
# ---------------------------------------------------------------------------

table functools_extra175.lru_cache_identity:
  description: "functools.lru_cache: __name__ 'lru_cache', __qualname__ 'lru_cache', __class__.__name__ 'function'; wave 299; new to extra175"
  kind: python_call_eq
  category: identity
  id_prefix: functoolslci175

  columns: [id, function, args, expected, description]
  rows:
    - [lru_name_lru_cache,
       "lru_cache.__name__.__eq__",
       ["lru_cache"],
       true,
       "functools.lru_cache.__name__.__eq__('lru_cache') == True — functools.lru_cache is a Python decorator function defined in Lib/functools.py that wraps a function with a memoizing callable saving up to maxsize recent calls; its __name__ attribute is 'lru_cache'; str.__eq__('lru_cache') returns True; new to extra175"]
    - [lru_qualname_lru_cache,
       "lru_cache.__qualname__.__eq__",
       ["lru_cache"],
       true,
       "functools.lru_cache.__qualname__.__eq__('lru_cache') == True — lru_cache is a module-level function in Lib/functools.py with no enclosing class or function; its __qualname__ equals its __name__ ('lru_cache'); str.__eq__('lru_cache') returns True; new to extra175"]
    - [lru_class_name_function,
       "lru_cache.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.lru_cache.__class__.__name__.__eq__('function') == True — functools.lru_cache is a regular Python function defined with def in Lib/functools.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra175"]
    - [lru_name_ne_cache,
       "lru_cache.__name__.__eq__",
       ["cache"],
       false,
       "functools.lru_cache.__name__.__eq__('cache') == False — lru_cache.__name__ is 'lru_cache', not 'cache'; functools.cache is a distinct simpler unbounded LRU cache added in Python 3.9; they are separate decorator functions; str.__eq__('cache') returns False; new to extra175"]

# ---------------------------------------------------------------------------
# Table 2: functools.cache Python function identity — __name__, __qualname__,
# __class__.__name__
#
# Wave 299 theme: functools.cache Python decorator function identity —
# __name__, __qualname__, and __class__.__name__.
#
# functools.cache.__name__ == 'cache'
# functools.cache.__qualname__ == 'cache'
# functools.cache.__class__.__name__ == 'function'
# functools.cache.__name__ != 'lru_cache'
#
# functools.cache(user_function) — added in Python 3.9 — is a simpler unbounded
# cache. Equivalent to lru_cache(maxsize=None). Since results are stored
# indefinitely the cache can grow without bound. It is a module-level Python
# function in Lib/functools.py so __qualname__ == __name__ == 'cache'. New to
# extra175.
# ---------------------------------------------------------------------------

table functools_extra175.cache_identity:
  description: "functools.cache: __name__ 'cache', __qualname__ 'cache', __class__.__name__ 'function'; wave 299; new to extra175"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsci175

  columns: [id, function, args, expected, description]
  rows:
    - [cache_name_cache,
       "cache.__name__.__eq__",
       ["cache"],
       true,
       "functools.cache.__name__.__eq__('cache') == True — functools.cache is a Python decorator function added in Python 3.9 in Lib/functools.py; it is an unbounded LRU cache equivalent to lru_cache(maxsize=None); its __name__ attribute is 'cache'; str.__eq__('cache') returns True; new to extra175"]
    - [cache_qualname_cache,
       "cache.__qualname__.__eq__",
       ["cache"],
       true,
       "functools.cache.__qualname__.__eq__('cache') == True — cache is a module-level function in Lib/functools.py with no enclosing scope; its __qualname__ equals its __name__ ('cache'); str.__eq__('cache') returns True; new to extra175"]
    - [cache_class_name_function,
       "cache.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.cache.__class__.__name__.__eq__('function') == True — functools.cache is a regular Python function defined with def in Lib/functools.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra175"]
    - [cache_name_ne_lru_cache,
       "cache.__name__.__eq__",
       ["lru_cache"],
       false,
       "functools.cache.__name__.__eq__('lru_cache') == False — cache.__name__ is 'cache', not 'lru_cache'; they are distinct decorator functions in functools, with cache being the simpler unbounded variant; str.__eq__('lru_cache') returns False; new to extra175"]

# ---------------------------------------------------------------------------
# Table 3: functools.total_ordering Python function identity — __name__,
# __qualname__, __class__.__name__
#
# Wave 299 theme: functools.total_ordering Python class decorator identity —
# __name__, __qualname__, and __class__.__name__.
#
# functools.total_ordering.__name__ == 'total_ordering'
# functools.total_ordering.__qualname__ == 'total_ordering'
# functools.total_ordering.__class__.__name__ == 'function'
# functools.total_ordering.__name__ != 'singledispatch'
#
# functools.total_ordering is a class decorator defined in Lib/functools.py. Given
# a class that defines __eq__ and one ordering method (__lt__, __le__, __gt__, or
# __ge__), it fills in the remaining comparison methods. It is a module-level
# Python function (not a class), so __class__.__name__ is 'function' and
# __qualname__ == __name__. New to extra175.
# ---------------------------------------------------------------------------

table functools_extra175.total_ordering_identity:
  description: "functools.total_ordering: __name__ 'total_ordering', __qualname__ 'total_ordering', __class__.__name__ 'function'; wave 299; new to extra175"
  kind: python_call_eq
  category: identity
  id_prefix: functoolstoi175

  columns: [id, function, args, expected, description]
  rows:
    - [to_name_total_ordering,
       "total_ordering.__name__.__eq__",
       ["total_ordering"],
       true,
       "functools.total_ordering.__name__.__eq__('total_ordering') == True — functools.total_ordering is a Python class decorator defined in Lib/functools.py that fills in missing comparison methods given __eq__ and one ordering method; its __name__ attribute is 'total_ordering'; str.__eq__('total_ordering') returns True; new to extra175"]
    - [to_qualname_total_ordering,
       "total_ordering.__qualname__.__eq__",
       ["total_ordering"],
       true,
       "functools.total_ordering.__qualname__.__eq__('total_ordering') == True — total_ordering is a module-level function in Lib/functools.py; its __qualname__ equals its __name__ ('total_ordering'); str.__eq__('total_ordering') returns True; new to extra175"]
    - [to_class_name_function,
       "total_ordering.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.total_ordering.__class__.__name__.__eq__('function') == True — functools.total_ordering is a regular Python function defined with def in Lib/functools.py (it is a decorator function, not a class); its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra175"]
    - [to_name_ne_singledispatch,
       "total_ordering.__name__.__eq__",
       ["singledispatch"],
       false,
       "functools.total_ordering.__name__.__eq__('singledispatch') == False — total_ordering.__name__ is 'total_ordering', not 'singledispatch'; total_ordering fills in comparison methods on classes while singledispatch creates single-dispatch generic functions; they are distinct decorator functions; str.__eq__('singledispatch') returns False; new to extra175"]

# ---------------------------------------------------------------------------
# Table 4: functools.singledispatch Python function identity — __name__,
# __qualname__, __class__.__name__
#
# Wave 299 theme: functools.singledispatch Python decorator function identity —
# __name__, __qualname__, and __class__.__name__.
#
# functools.singledispatch.__name__ == 'singledispatch'
# functools.singledispatch.__qualname__ == 'singledispatch'
# functools.singledispatch.__class__.__name__ == 'function'
# functools.singledispatch.__name__ != 'total_ordering'
#
# functools.singledispatch transforms a function into a single-dispatch generic
# function. The type of the first argument determines which registered
# implementation is called. It is a module-level Python function in
# Lib/functools.py, so __qualname__ == __name__ and __class__.__name__ is
# 'function'. New to extra175.
# ---------------------------------------------------------------------------

table functools_extra175.singledispatch_identity:
  description: "functools.singledispatch: __name__ 'singledispatch', __qualname__ 'singledispatch', __class__.__name__ 'function'; wave 299; new to extra175"
  kind: python_call_eq
  category: identity
  id_prefix: functoolssdi175

  columns: [id, function, args, expected, description]
  rows:
    - [sd_name_singledispatch,
       "singledispatch.__name__.__eq__",
       ["singledispatch"],
       true,
       "functools.singledispatch.__name__.__eq__('singledispatch') == True — functools.singledispatch is a Python decorator function defined in Lib/functools.py that transforms a function into a single-dispatch generic function; the first argument's type selects which registered implementation is called; its __name__ attribute is 'singledispatch'; str.__eq__('singledispatch') returns True; new to extra175"]
    - [sd_qualname_singledispatch,
       "singledispatch.__qualname__.__eq__",
       ["singledispatch"],
       true,
       "functools.singledispatch.__qualname__.__eq__('singledispatch') == True — singledispatch is a module-level function in Lib/functools.py; its __qualname__ equals its __name__ ('singledispatch'); str.__eq__('singledispatch') returns True; new to extra175"]
    - [sd_class_name_function,
       "singledispatch.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.singledispatch.__class__.__name__.__eq__('function') == True — functools.singledispatch is a regular Python function defined with def in Lib/functools.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra175"]
    - [sd_name_ne_total_ordering,
       "singledispatch.__name__.__eq__",
       ["total_ordering"],
       false,
       "functools.singledispatch.__name__.__eq__('total_ordering') == False — singledispatch.__name__ is 'singledispatch', not 'total_ordering'; they are distinct decorator functions in functools with different purposes; str.__eq__('total_ordering') returns False; new to extra175"]

# ---------------------------------------------------------------------------
# Table 5: lru_cache, cache, total_ordering, singledispatch name length
# cross-checks
#
# Wave 299 theme: string length checks for the __name__ attributes of
# lru_cache, cache, total_ordering, and singledispatch.
#
# functools.lru_cache.__name__.__len__() == 9
# functools.cache.__name__.__len__() == 5
# functools.total_ordering.__name__.__len__() == 14
# functools.singledispatch.__name__.__len__() == 14
#
# 'lru_cache' is 9 characters. 'cache' is 5 characters. Both 'total_ordering'
# and 'singledispatch' are 14 characters each (they happen to share the same
# length despite being entirely different names and functions). New to extra175.
# ---------------------------------------------------------------------------

table functools_extra175.decorator_name_lengths:
  description: "functools: lru_cache name len 9, cache name len 5, total_ordering len 14, singledispatch len 14; wave 299; new to extra175"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsdnl175

  columns: [id, function, args, expected, description]
  rows:
    - [lru_name_len_9,
       "lru_cache.__name__.__len__",
       [],
       9,
       "functools.lru_cache.__name__.__len__() == 9 — the string 'lru_cache' has exactly 9 characters: l-r-u-_-c-a-c-h-e; str.__len__() returns 9; new to extra175"]
    - [cache_name_len_5,
       "cache.__name__.__len__",
       [],
       5,
       "functools.cache.__name__.__len__() == 5 — the string 'cache' has exactly 5 characters: c-a-c-h-e; str.__len__() returns 5; new to extra175"]
    - [to_name_len_14,
       "total_ordering.__name__.__len__",
       [],
       14,
       "functools.total_ordering.__name__.__len__() == 14 — the string 'total_ordering' has exactly 14 characters: t-o-t-a-l-_-o-r-d-e-r-i-n-g; str.__len__() returns 14; new to extra175"]
    - [sd_name_len_14,
       "singledispatch.__name__.__len__",
       [],
       14,
       "functools.singledispatch.__name__.__len__() == 14 — the string 'singledispatch' has exactly 14 characters: s-i-n-g-l-e-d-i-s-p-a-t-c-h; str.__len__() returns 14; coincidentally the same length as 'total_ordering'; new to extra175"]

