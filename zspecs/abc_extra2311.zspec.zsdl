spec: abc_extra2311
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#abstract-base-classes — Data model ABCs reference"
    - "Test vectors verified with Python 3.13.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 601 (_extra2311): __abstractmethods__ content checks for abc module classes."
    - "abc.ABC.__abstractmethods__ is frozenset() (empty) — ABC itself declares no abstract methods."
    - "abc.ABC.__abstractmethods__.__len__() == 0 — confirmed empty frozenset."
    - "abc.ABC.__dict__.__contains__('__abstractmethods__') is True — the attribute IS present, set to empty frozenset."
    - "abc.ABCMeta.__dict__.__contains__('__abstractmethods__') is False — ABCMeta is a metaclass (type subclass) with no __abstractmethods__ of its own."
    - "abc.abstractmethod is a plain function — __abstractmethods__ is absent from its __dict__."
    - "abc.ABC.__abstractmethods__.__contains__(any_name) is always False since the frozenset is empty."
    - "abc.ABCMeta.__abstractmethods__ raises AttributeError — metaclass inherits from type, not ABC."
    - "abc.abstractmethod.__abstractmethods__ raises AttributeError — plain function, not a class."
    - "ABCMeta has 'register', '__instancecheck__', '__subclasscheck__' in its __dict__ but NOT '__abstractmethods__'."
    - "All values verified with Python 3.13.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table abc_extra2311.abc_abstractmethods_len:
  description: "abc.ABC.__abstractmethods__ is an empty frozenset — len 0"
  kind: python_call_eq
  category: abstract_methods
  id_prefix: ab2311

  columns: [id, function, args, expected]
  rows:
    - ["ab2311001", "abc.ABC.__abstractmethods__.__len__", [], 0]

table abc_extra2311.abc_abstractmethods_contains:
  description: "abc.ABC.__abstractmethods__.__contains__ always False — frozenset is empty"
  kind: python_call_eq
  category: abstract_methods
  id_prefix: ab2311

  columns: [id, function, args, expected]
  rows:
    - ["ab2311002", "abc.ABC.__abstractmethods__.__contains__", ["run_forever"],    false]
    - ["ab2311003", "abc.ABC.__abstractmethods__.__contains__", ["submit"],         false]
    - ["ab2311004", "abc.ABC.__abstractmethods__.__contains__", ["start"],          false]
    - ["ab2311005", "abc.ABC.__abstractmethods__.__contains__", ["close"],          false]
    - ["ab2311006", "abc.ABC.__abstractmethods__.__contains__", ["__init__"],       false]
    - ["ab2311007", "abc.ABC.__abstractmethods__.__contains__", ["abstract_method"], false]
    - ["ab2311008", "abc.ABC.__abstractmethods__.__contains__", ["execute"],        false]
    - ["ab2311009", "abc.ABC.__abstractmethods__.__contains__", ["process"],        false]
    - ["ab2311010", "abc.ABC.__abstractmethods__.__contains__", ["register"],       false]
    - ["ab2311011", "abc.ABC.__abstractmethods__.__contains__", ["run"],            false]

table abc_extra2311.dict_contains_abstractmethods:
  description: "abc class __dict__ membership checks for __abstractmethods__ key"
  kind: python_call_eq
  category: abstract_methods
  id_prefix: ab2311

  columns: [id, function, args, expected]
  rows:
    - ["ab2311012", "abc.ABC.__dict__.__contains__",           ["__abstractmethods__"], true]
    - ["ab2311013", "abc.ABCMeta.__dict__.__contains__",       ["__abstractmethods__"], false]
    - ["ab2311014", "abc.abstractmethod.__dict__.__contains__", ["__abstractmethods__"], false]

table abc_extra2311.abcmeta_dict_checks:
  description: "abc.ABCMeta __dict__ has register/__instancecheck__/__subclasscheck__ but not __abstractmethods__"
  kind: python_call_eq
  category: abstract_methods
  id_prefix: ab2311

  columns: [id, function, args, expected]
  rows:
    - ["ab2311015", "abc.ABCMeta.__dict__.__contains__", ["register"],           true]
    - ["ab2311016", "abc.ABCMeta.__dict__.__contains__", ["__instancecheck__"],  true]
    - ["ab2311017", "abc.ABCMeta.__dict__.__contains__", ["__subclasscheck__"],  true]
    - ["ab2311018", "abc.ABCMeta.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["ab2311019", "abc.ABCMeta.__dict__.__contains__", ["__subclasshook__"],   false]

table abc_extra2311.abstractmethods_raises:
  description: "Direct .__abstractmethods__ access on abc.ABCMeta and abc.abstractmethod raises AttributeError"
  kind: python_call_raises
  category: abstract_methods
  id_prefix: ab2311

  columns: [id, function, args, expected]
  rows:
    - ["ab2311020", "abc.ABCMeta.__abstractmethods__.__len__",        [], "AttributeError"]
    - ["ab2311021", "abc.abstractmethod.__abstractmethods__.__len__",  [], "AttributeError"]
