spec: io_extra1651
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "Python io documentation — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra.zspec.zsdl — covers DEFAULT_BUFFER_SIZE, SEEK_* types, TextIOWrapper/BufferedRandom/UnsupportedOperation class identity"
  notes:
    - "Theme: __init_subclass__, __set_name__, __class_getitem__ — class creation and parameterization protocol."
    - "io C types (StringIO, BytesIO, TextIOWrapper, IOBase, BufferedIOBase) are implemented in C via _io; they do not own __init_subclass__ in their own __dict__."
    - "__init_subclass__ is defined on object and inherited; it is not present in the __dict__ of any C-implemented io type."
    - "Python 3.9+ supports generic alias syntax (list[int], dict[str,int]) but most io C types do not add __class_getitem__ to their own __dict__."
    - "io module-level attributes are verified via __dict__.__contains__ to confirm public API membership."
    - "io.__dict__.__contains__ uses the module's __dict__ mapping, which is a mappingproxy for C extension modules."
    - "DEFAULT_BUFFER_SIZE == 8192 on most POSIX platforms; SEEK_SET==0, SEEK_CUR==1, SEEK_END==2."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: no_init_subclass
# C-implemented io types do not define __init_subclass__ in their own __dict__.
# The dunder is inherited from object but not re-defined at the C type level.
# ---------------------------------------------------------------------------

table io_extra1651.no_init_subclass:
  description: "C-implemented io types do not own __init_subclass__ in their __dict__"
  kind: python_call_eq
  category: init_subclass
  id_prefix: io1651

  columns: [id, function, args, expected]
  rows:
    - ["io1651_stringio_no_init_subclass",     StringIO.__dict__.__contains__,     ["__init_subclass__"], false]
    - ["io1651_bytesio_no_init_subclass",      BytesIO.__dict__.__contains__,      ["__init_subclass__"], false]
    - ["io1651_textiowrapper_no_init_subclass", TextIOWrapper.__dict__.__contains__, ["__init_subclass__"], false]
    - ["io1651_iobase_no_init_subclass",       IOBase.__dict__.__contains__,       ["__init_subclass__"], false]
    - ["io1651_bufferediobase_no_init_subclass", BufferedIOBase.__dict__.__contains__, ["__init_subclass__"], false]
    - ["io1651_rawiobase_no_init_subclass",    RawIOBase.__dict__.__contains__,    ["__init_subclass__"], false]
    - ["io1651_textiobase_no_init_subclass",   TextIOBase.__dict__.__contains__,   ["__init_subclass__"], false]
    - ["io1651_bufferedreader_no_init_subclass", BufferedReader.__dict__.__contains__, ["__init_subclass__"], false]
    - ["io1651_bufferedwriter_no_init_subclass", BufferedWriter.__dict__.__contains__, ["__init_subclass__"], false]
    - ["io1651_fileio_no_init_subclass",       FileIO.__dict__.__contains__,       ["__init_subclass__"], false]

# ---------------------------------------------------------------------------
# Table 2: class_getitem_checks
# Verifies whether io C types expose __class_getitem__ in their own __dict__.
# Most io C types do NOT add __class_getitem__, so these return False.
# This probes the Python 3.9+ generic alias parameterization protocol.
# ---------------------------------------------------------------------------

table io_extra1651.class_getitem_checks:
  description: "io C types do not own __class_getitem__ — they are not generic types"
  kind: python_call_eq
  category: class_getitem
  id_prefix: io1651

  columns: [id, function, args, expected]
  rows:
    - ["io1651_stringio_class_getitem",      StringIO.__dict__.__contains__,      ["__class_getitem__"], false]
    - ["io1651_bytesio_class_getitem",       BytesIO.__dict__.__contains__,       ["__class_getitem__"], false]
    - ["io1651_textiowrapper_class_getitem", TextIOWrapper.__dict__.__contains__,  ["__class_getitem__"], false]
    - ["io1651_iobase_class_getitem",        IOBase.__dict__.__contains__,        ["__class_getitem__"], false]
    - ["io1651_bufferediobase_class_getitem", BufferedIOBase.__dict__.__contains__, ["__class_getitem__"], false]
    - ["io1651_rawiobase_class_getitem",     RawIOBase.__dict__.__contains__,     ["__class_getitem__"], false]
    - ["io1651_textiobase_class_getitem",    TextIOBase.__dict__.__contains__,    ["__class_getitem__"], false]
    - ["io1651_fileio_class_getitem",        FileIO.__dict__.__contains__,        ["__class_getitem__"], false]

# ---------------------------------------------------------------------------
# Table 3: module_attr_presence
# Verifies that all documented public names are present in io.__dict__.
# This exercises the class-creation protocol indirectly: each name was
# installed into the module namespace by the C extension loader at import time.
# ---------------------------------------------------------------------------

table io_extra1651.module_attr_presence:
  description: "All documented public names are present in io.__dict__"
  kind: python_call_eq
  category: module_attrs
  id_prefix: io1651

  columns: [id, function, args, expected]
  rows:
    - ["io1651_mod_StringIO",            __dict__.__contains__, ["StringIO"],            true]
    - ["io1651_mod_BytesIO",             __dict__.__contains__, ["BytesIO"],             true]
    - ["io1651_mod_TextIOWrapper",       __dict__.__contains__, ["TextIOWrapper"],       true]
    - ["io1651_mod_BufferedReader",      __dict__.__contains__, ["BufferedReader"],      true]
    - ["io1651_mod_BufferedWriter",      __dict__.__contains__, ["BufferedWriter"],      true]
    - ["io1651_mod_FileIO",              __dict__.__contains__, ["FileIO"],              true]
    - ["io1651_mod_IOBase",              __dict__.__contains__, ["IOBase"],              true]
    - ["io1651_mod_RawIOBase",           __dict__.__contains__, ["RawIOBase"],           true]
    - ["io1651_mod_BufferedIOBase",      __dict__.__contains__, ["BufferedIOBase"],      true]
    - ["io1651_mod_TextIOBase",          __dict__.__contains__, ["TextIOBase"],          true]
    - ["io1651_mod_DEFAULT_BUFFER_SIZE", __dict__.__contains__, ["DEFAULT_BUFFER_SIZE"], true]
    - ["io1651_mod_SEEK_SET",            __dict__.__contains__, ["SEEK_SET"],            true]
    - ["io1651_mod_SEEK_CUR",            __dict__.__contains__, ["SEEK_CUR"],            true]
    - ["io1651_mod_SEEK_END",            __dict__.__contains__, ["SEEK_END"],            true]
    - ["io1651_mod_open",                __dict__.__contains__, ["open"],                true]
    - ["io1651_mod_UnsupportedOperation", __dict__.__contains__, ["UnsupportedOperation"], true]
