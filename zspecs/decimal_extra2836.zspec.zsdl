# ---------------------------------------------------------------------------
# Table: full reflected division/modulo summary for decimal.Decimal
# Confirms all three reflected operators are present — Decimal participates
# fully in the reflected division and modulo protocol
# ---------------------------------------------------------------------------

table decimal_extra2836.decimal_reflected_ops_complete:
  description: "decimal.Decimal defines all three reflected division/modulo operators — complete reflected numeric protocol"
  kind: python_call_eq
