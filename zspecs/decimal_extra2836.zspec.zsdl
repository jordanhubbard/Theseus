  columns: [id, function, args, expected]
  rows:
    - ["dc2836010", "decimal.Decimal.__dict__.__contains__", ["__rtruediv__"],  true]
    - ["dc2836011", "decimal.Decimal.__dict__.__contains__", ["__rfloordiv__"], true]
