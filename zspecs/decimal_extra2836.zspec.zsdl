spec: decimal_extra2836
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "zspecs/decimal_extra2821.zspec.zsdl — wave 635 predecessor (covered __radd__, __rsub__, __rmul__)"
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "Wave 636 theme: __rtruediv__, __rfloordiv__, and __rmod__ dict-presence checks (reflected true division, floor division, modulo operators)."
    - "decimal.Decimal is a full numeric type and DOES define __rtruediv__, __rfloordiv__, and __rmod__ in its own __dict__."
    - "Reflected operators are needed so that expressions like '1 / Decimal(2)' work when int.__truediv__ returns NotImplemented."
    - "decimal.Context is a configuration object, not a numeric value — it does NOT define any of these reflected operators."
    - "decimal.DecimalException is an exception class — it does NOT define any reflected division or modulo operators."
    - "The asymmetry (Decimal: true, Context/DecimalException: false) mirrors the wave 635 pattern but for division/modulo."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __rtruediv__ dict-presence
# Decimal defines it; Context and DecimalException do not
# ---------------------------------------------------------------------------

table decimal_extra2836.rtruediv_protocol:
  description: "__rtruediv__ is present in decimal.Decimal.__dict__ (full numeric type) but absent from Context and DecimalException"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2836

  columns: [id, function, args, expected]
  rows:
    - ["dc2836001", "decimal.Decimal.__dict__.__contains__",          ["__rtruediv__"], true]
    - ["dc2836002", "decimal.Context.__dict__.__contains__",          ["__rtruediv__"], false]
    - ["dc2836003", "decimal.DecimalException.__dict__.__contains__", ["__rtruediv__"], false]

