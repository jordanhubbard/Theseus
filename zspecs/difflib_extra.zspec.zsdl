spec: difflib_extra
version: ">=3.2"
backend: python_module(difflib)

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "Python 3 difflib documentation — https://docs.python.org/3/library/difflib.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/difflib.py"
  notes:
    - "This spec covers aspects of the difflib module not in difflib.zspec.zsdl."
    - "SequenceMatcher.__name__ and __module__ are class-level attribute checks, not instance-level."
    - "unified_diff, context_diff, and ndiff are generator functions; their __name__ attributes are tested here."
    - "get_close_matches.__name__ == 'get_close_matches' — verifying the function name attribute."
    - "get_close_matches('appl', ['apple', 'application', 'orange']) == ['apple', 'application'] with default cutoff 0.6 and n=3."
    - "get_close_matches('xyz', ['apple', 'orange']) == [] — no close matches found."
    - "All expected values verified by running Python 3.14.3 difflib on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SequenceMatcher — class name and module
# ---------------------------------------------------------------------------

invariant difflib_extra.SequenceMatcher.class_name:
  description: "difflib.SequenceMatcher.__name__ == 'SequenceMatcher'"
  category: classnames
  kind: python_call_eq
  function: SequenceMatcher.__name__.__eq__
  args: ["SequenceMatcher"]
  expected: true

invariant difflib_extra.SequenceMatcher.module:
  description: "difflib.SequenceMatcher.__module__ == 'difflib'"
  category: classnames
  kind: python_call_eq
  function: SequenceMatcher.__module__.__eq__
  args: ["difflib"]
  expected: true

# ---------------------------------------------------------------------------
# Differ — class name
# ---------------------------------------------------------------------------

invariant difflib_extra.Differ.class_name:
  description: "difflib.Differ.__name__ == 'Differ'"
  category: classnames
  kind: python_call_eq
  function: Differ.__name__.__eq__
  args: ["Differ"]
  expected: true

# ---------------------------------------------------------------------------
# HtmlDiff — class name
# ---------------------------------------------------------------------------

invariant difflib_extra.HtmlDiff.class_name:
  description: "difflib.HtmlDiff.__name__ == 'HtmlDiff'"
  category: classnames
  kind: python_call_eq
  function: HtmlDiff.__name__.__eq__
  args: ["HtmlDiff"]
  expected: true

# ---------------------------------------------------------------------------
# Generator functions — __name__ attribute checks
#
# unified_diff, context_diff, and ndiff are generator functions; their
# __name__ attributes reflect the function name without calling them.
# ---------------------------------------------------------------------------

invariant difflib_extra.unified_diff.name:
  description: "difflib.unified_diff.__name__ == 'unified_diff'"
  category: funcnames
  kind: python_call_eq
  function: unified_diff.__name__.__eq__
  args: ["unified_diff"]
  expected: true

invariant difflib_extra.context_diff.name:
  description: "difflib.context_diff.__name__ == 'context_diff'"
  category: funcnames
  kind: python_call_eq
  function: context_diff.__name__.__eq__
  args: ["context_diff"]
  expected: true

invariant difflib_extra.ndiff.name:
  description: "difflib.ndiff.__name__ == 'ndiff'"
  category: funcnames
  kind: python_call_eq
  function: ndiff.__name__.__eq__
  args: ["ndiff"]
  expected: true

# ---------------------------------------------------------------------------
# get_close_matches — function name attribute
# ---------------------------------------------------------------------------

invariant difflib_extra.get_close_matches.name:
  description: "difflib.get_close_matches.__name__ == 'get_close_matches'"
  category: funcnames
  kind: python_call_eq
  function: get_close_matches.__name__.__eq__
  args: ["get_close_matches"]
  expected: true

# ---------------------------------------------------------------------------
# get_close_matches — behavioral tests
#
# Default n=3, cutoff=0.6. 'appl' is close to both 'apple' and 'application'.
# 'xyz' has no close matches in the given list.
# ---------------------------------------------------------------------------

invariant difflib_extra.get_close_matches.appl_matches:
  description: "get_close_matches('appl', ['apple', 'application', 'orange']) == ['apple', 'application']"
  category: close_matches
  kind: python_call_eq
  function: get_close_matches
  args: ["appl", ["apple", "application", "orange"]]
  expected: ["apple", "application"]

invariant difflib_extra.get_close_matches.xyz_no_matches:
  description: "get_close_matches('xyz', ['apple', 'orange']) == [] — no close matches found"
  category: close_matches
  kind: python_call_eq
  function: get_close_matches
  args: ["xyz", ["apple", "orange"]]
  expected: []
