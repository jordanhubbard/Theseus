spec: functools_extra1816
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/functools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 568 (_extra1816): __format__ string formatting protocol; __index__/__float__/__complex__ numeric conversion protocol; __reduce__/__reduce_ex__/__copy__/__deepcopy__ copy/pickle protocol dict-presence checks for functools types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table functools_extra1816.format_protocol:
  description: "functools types __format__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1816

  columns: [id, function, args, expected]
  rows:
    - ["fu1816001", "functools.partial.__dict__.__contains__", ["__format__"], false]
    - ["fu1816002", "functools.cached_property.__dict__.__contains__", ["__format__"], false]
    - ["fu1816003", "functools.partialmethod.__dict__.__contains__", ["__format__"], false]
    - ["fu1816004", "functools.lru_cache.__dict__.__contains__", ["__format__"], false]

table functools_extra1816.copy_protocol:
  description: "functools types __reduce__/__copy__/__deepcopy__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1816

  columns: [id, function, args, expected]
  rows:
    - ["fu1816101", "functools.partial.__dict__.__contains__", ["__reduce__"], true]
    - ["fu1816102", "functools.partial.__dict__.__contains__", ["__setstate__"], true]
    - ["fu1816103", "functools.partial.__dict__.__contains__", ["__copy__"], false]
    - ["fu1816104", "functools.partial.__dict__.__contains__", ["__deepcopy__"], false]
    - ["fu1816105", "functools.cached_property.__dict__.__contains__", ["__reduce__"], false]
    - ["fu1816106", "functools.cached_property.__dict__.__contains__", ["__copy__"], false]
    - ["fu1816107", "functools.partialmethod.__dict__.__contains__", ["__reduce__"], false]
    - ["fu1816108", "functools.partialmethod.__dict__.__contains__", ["__copy__"], false]

table functools_extra1816.numeric_conversion:
  description: "functools types __int__/__float__/__index__/__complex__/__trunc__ numeric conversion protocol dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1816

  columns: [id, function, args, expected]
  rows:
    - ["fu1816201", "functools.partial.__dict__.__contains__", ["__int__"], false]
    - ["fu1816202", "functools.partial.__dict__.__contains__", ["__float__"], false]
    - ["fu1816203", "functools.partial.__dict__.__contains__", ["__index__"], false]
    - ["fu1816204", "functools.partial.__dict__.__contains__", ["__complex__"], false]
    - ["fu1816205", "functools.partial.__dict__.__contains__", ["__trunc__"], false]
    - ["fu1816206", "functools.cached_property.__dict__.__contains__", ["__int__"], false]
    - ["fu1816207", "functools.cached_property.__dict__.__contains__", ["__float__"], false]
    - ["fu1816208", "functools.cached_property.__dict__.__contains__", ["__index__"], false]
