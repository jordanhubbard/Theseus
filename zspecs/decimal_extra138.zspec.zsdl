spec: decimal_extra138
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal.__doc__ length (260, str), decimal.Context.__doc__ length (406, str), and the rounding mode string constants: ROUND_HALF_UP ('ROUND_HALF_UP', len=13), ROUND_HALF_DOWN (len=15), ROUND_HALF_EVEN (len=15), ROUND_UP (len=8), ROUND_DOWN (len=10), ROUND_CEILING (len=13), ROUND_FLOOR (len=11), ROUND_05UP (len=10)."
    - "decimal.Decimal.__doc__ == 260 characters (begins: 'Construct a new Decimal object.'; covers integer, string, tuple, and other Decimal inputs)."
    - "decimal.Context.__doc__ == 406 characters (begins: 'The context affects almost all operations and controls rounding, Over/Underflow, raising of exceptions'; longer than Decimal.__doc__ by 146 chars)."
    - "All rounding mode constants are plain str instances (not enum members or symbolic constants): isinstance(decimal.ROUND_HALF_UP, str) is True."
    - "The rounding constant value equals the constant name: decimal.ROUND_HALF_UP == 'ROUND_HALF_UP' is True (the string IS the constant name)."
    - "ROUND_HALF_DOWN and ROUND_HALF_EVEN are both 15 chars (the longest rounding constant names)."
    - "ROUND_UP is the shortest rounding constant name at 8 characters."
    - "ROUND_DOWN and ROUND_05UP both have length 10."
    - "decimal.Decimal.__class__.__name__ == 'type'; decimal.Context.__class__.__name__ == 'type'."
    - "decimal.Decimal MRO: [Decimal, object] (length 2); decimal.Context MRO: [Context, object] (length 2)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal and decimal.Context __doc__ lengths
# Decimal.__doc__ == 260 characters (str).
# Context.__doc__ == 406 characters (str).
# Both are type (not ABCMeta); MRO length 2 for each.
# Decimal.__name__ == 'Decimal' (7 chars); Context.__name__ == 'Context' (7 chars).
# Both have __module__ == 'decimal' (7 chars).
# ---------------------------------------------------------------------------

table decimal_extra138.Decimal_Context_doc_and_identity:
  description: "decimal.Decimal.__doc__ len=260 (str), decimal.Context.__doc__ len=406 (str); both __class__.__name__='type', __module__='decimal', MRO length=2"
  kind: python_call_eq
  category: doc_identity
  id_prefix: decdoc138

  columns: [id, function, args, expected, description]
  rows:
    - [dec_doc_cls_eq,   Decimal.__doc__.__class__.__name__.__eq__,  ["str"],     true,  "decimal.Decimal.__doc__ is a str (non-None; documents the Decimal constructor's accepted input types)"]
    - [dec_doc_len,      Decimal.__doc__.__len__,                     [],         260,   "decimal.Decimal.__doc__.__len__() == 260 ('Construct a new Decimal object. ...' covering integer, string, tuple, and Decimal inputs)"]
    - [dec_name_len,     Decimal.__name__.__len__,                    [],         7,     "decimal.Decimal.__name__.__len__() == 7 ('Decimal' has 7 characters)"]
    - [dec_module_eq,    Decimal.__module__.__eq__,                   ["decimal"], true,  "decimal.Decimal.__module__ == 'decimal'"]
    - [dec_module_len,   Decimal.__module__.__len__,                  [],         7,     "decimal.Decimal.__module__.__len__() == 7 ('decimal' has 7 characters)"]
    - [dec_cls_eq,       Decimal.__class__.__name__.__eq__,           ["type"],   true,  "decimal.Decimal.__class__.__name__ == 'type' (a regular type, not an enum or ABC)"]
    - [dec_mro_len,      "Decimal.__mro__.__len__",                   [],         2,     "decimal.Decimal.__mro__.__len__() == 2 ([Decimal, object]; direct subclass of object)"]
    - [ctx_doc_cls_eq,   Context.__doc__.__class__.__name__.__eq__,   ["str"],    true,  "decimal.Context.__doc__ is a str (non-None; documents rounding, traps, and precision control)"]
    - [ctx_doc_len,      Context.__doc__.__len__,                     [],         406,   "decimal.Context.__doc__.__len__() == 406 (longest __doc__ among the core decimal classes; 146 chars longer than Decimal.__doc__)"]
    - [ctx_name_len,     Context.__name__.__len__,                    [],         7,     "decimal.Context.__name__.__len__() == 7 ('Context' has 7 characters; same length as 'Decimal')"]
    - [ctx_module_eq,    Context.__module__.__eq__,                   ["decimal"], true,  "decimal.Context.__module__ == 'decimal'"]
    - [ctx_cls_eq,       Context.__class__.__name__.__eq__,           ["type"],   true,  "decimal.Context.__class__.__name__ == 'type'"]
    - [ctx_mro_len,      "Context.__mro__.__len__",                   [],         2,     "decimal.Context.__mro__.__len__() == 2 ([Context, object])"]

# ---------------------------------------------------------------------------
# Rounding mode constant value lengths (ROUND_HALF_UP group)
# The rounding constants are plain str values that equal their own names.
# ROUND_HALF_UP == 'ROUND_HALF_UP' (len=13).
# ROUND_HALF_DOWN == 'ROUND_HALF_DOWN' (len=15).
# ROUND_HALF_EVEN == 'ROUND_HALF_EVEN' (len=15).
# All three are str instances.
# ---------------------------------------------------------------------------

table decimal_extra138.rounding_constants_half_group:
  description: "decimal rounding constants ROUND_HALF_UP (len=13), ROUND_HALF_DOWN (len=15), ROUND_HALF_EVEN (len=15); all are str; value equals the constant name"
  kind: python_call_eq
  category: constant_identity
  id_prefix: decround138

  columns: [id, function, args, expected, description]
  rows:
    - [rhup_cls_eq,   ROUND_HALF_UP.__class__.__name__.__eq__,   ["str"],           true, "decimal.ROUND_HALF_UP is a plain str instance (not an enum member)"]
    - [rhup_eq,       ROUND_HALF_UP.__eq__,                       ["ROUND_HALF_UP"],  true, "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP' (the string value equals the constant name)"]
    - [rhup_len,      ROUND_HALF_UP.__len__,                      [],               13,   "decimal.ROUND_HALF_UP.__len__() == 13 ('ROUND_HALF_UP' has 13 characters)"]
    - [rhdown_cls_eq, ROUND_HALF_DOWN.__class__.__name__.__eq__, ["str"],           true, "decimal.ROUND_HALF_DOWN is a plain str instance"]
    - [rhdown_eq,     ROUND_HALF_DOWN.__eq__,                     ["ROUND_HALF_DOWN"], true, "decimal.ROUND_HALF_DOWN == 'ROUND_HALF_DOWN'"]
    - [rhdown_len,    ROUND_HALF_DOWN.__len__,                    [],               15,   "decimal.ROUND_HALF_DOWN.__len__() == 15 (the longest rounding constant name along with ROUND_HALF_EVEN)"]
    - [rheven_cls_eq, ROUND_HALF_EVEN.__class__.__name__.__eq__, ["str"],           true, "decimal.ROUND_HALF_EVEN is a plain str instance"]
    - [rheven_eq,     ROUND_HALF_EVEN.__eq__,                     ["ROUND_HALF_EVEN"], true, "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN' (banker's rounding; the default rounding mode)"]
    - [rheven_len,    ROUND_HALF_EVEN.__len__,                    [],               15,   "decimal.ROUND_HALF_EVEN.__len__() == 15 (tied with ROUND_HALF_DOWN for longest name)"]

# ---------------------------------------------------------------------------
# Rounding mode constant value lengths (directional group)
# ROUND_UP == 'ROUND_UP' (len=8; shortest); ROUND_DOWN == 'ROUND_DOWN' (len=10).
# ROUND_CEILING == 'ROUND_CEILING' (len=13); ROUND_FLOOR == 'ROUND_FLOOR' (len=11).
# ROUND_05UP == 'ROUND_05UP' (len=10; same as ROUND_DOWN).
# ---------------------------------------------------------------------------

table decimal_extra138.rounding_constants_directional_group:
  description: "decimal rounding constants ROUND_UP (len=8), ROUND_DOWN (len=10), ROUND_CEILING (len=13), ROUND_FLOOR (len=11), ROUND_05UP (len=10); all are str"
  kind: python_call_eq
  category: constant_identity
  id_prefix: decround138

  columns: [id, function, args, expected, description]
  rows:
    - [rup_cls_eq,   ROUND_UP.__class__.__name__.__eq__,       ["str"],          true, "decimal.ROUND_UP is a plain str instance"]
    - [rup_eq,       ROUND_UP.__eq__,                           ["ROUND_UP"],     true, "decimal.ROUND_UP == 'ROUND_UP'"]
    - [rup_len,      ROUND_UP.__len__,                          [],              8,    "decimal.ROUND_UP.__len__() == 8 (the shortest rounding constant name: 'ROUND_UP' = 'ROUND_' (6) + 'UP' (2))"]
    - [rdown_eq,     ROUND_DOWN.__eq__,                         ["ROUND_DOWN"],   true, "decimal.ROUND_DOWN == 'ROUND_DOWN'"]
    - [rdown_len,    ROUND_DOWN.__len__,                        [],              10,   "decimal.ROUND_DOWN.__len__() == 10 ('ROUND_DOWN' has 10 characters; same length as ROUND_05UP)"]
    - [rceil_eq,     ROUND_CEILING.__eq__,                      ["ROUND_CEILING"], true, "decimal.ROUND_CEILING == 'ROUND_CEILING'"]
    - [rceil_len,    ROUND_CEILING.__len__,                     [],              13,   "decimal.ROUND_CEILING.__len__() == 13 ('ROUND_CEILING' has 13 characters; same length as ROUND_HALF_UP)"]
    - [rfloor_eq,    ROUND_FLOOR.__eq__,                        ["ROUND_FLOOR"],  true, "decimal.ROUND_FLOOR == 'ROUND_FLOOR'"]
    - [rfloor_len,   ROUND_FLOOR.__len__,                       [],              11,   "decimal.ROUND_FLOOR.__len__() == 11 ('ROUND_FLOOR' has 11 characters)"]
    - [r05up_eq,     ROUND_05UP.__eq__,                         ["ROUND_05UP"],   true, "decimal.ROUND_05UP == 'ROUND_05UP' (rounds toward zero unless the penultimate digit is 0 or 5)"]
    - [r05up_len,    ROUND_05UP.__len__,                        [],              10,   "decimal.ROUND_05UP.__len__() == 10 ('ROUND_05UP' has 10 characters; same as ROUND_DOWN)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra138.Decimal.doc_len_260:
  description: "decimal.Decimal.__doc__.__len__() == 260 (the docstring opens with 'Construct a new Decimal object.' and lists the accepted input types: integer, string, tuple, and another Decimal; at 260 characters it is shorter than decimal.Context.__doc__ (406) because Context has more configurable parameters to document)"
  category: doc_identity
  kind: python_call_eq
  function: Decimal.__doc__.__len__
  args: []
  expected: 260

invariant decimal_extra138.Context.doc_len_406:
  description: "decimal.Context.__doc__.__len__() == 406 (the longest __doc__ among the core decimal classes; Context's docstring covers rounding mode, Over/Underflow, exception traps, and precision control — more parameters than Decimal.__doc__ (260)); the Context controls the entire arithmetic environment"
  category: doc_identity
  kind: python_call_eq
  function: Context.__doc__.__len__
  args: []
  expected: 406

invariant decimal_extra138.ROUND_HALF_UP.is_str:
  description: "decimal.ROUND_HALF_UP.__class__.__name__ == 'str' (all eight rounding mode constants in the decimal module are plain Python str objects whose value equals their own name; they are not enum members, named constants, or sentinel objects — just strings used as symbolic identifiers)"
  category: constant_identity
  kind: python_call_eq
  function: ROUND_HALF_UP.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant decimal_extra138.ROUND_UP.len_8:
  description: "decimal.ROUND_UP.__len__() == 8 ('ROUND_UP' is the shortest of the eight rounding mode constant names: ROUND_UP=8, ROUND_DOWN=10, ROUND_05UP=10, ROUND_FLOOR=11, ROUND_HALF_UP=13, ROUND_CEILING=13, ROUND_HALF_DOWN=15, ROUND_HALF_EVEN=15)"
  category: constant_identity
  kind: python_call_eq
  function: ROUND_UP.__len__
  args: []
  expected: 8

invariant decimal_extra138.ROUND_HALF_EVEN.len_15:
  description: "decimal.ROUND_HALF_EVEN.__len__() == 15 (tied with ROUND_HALF_DOWN for the longest rounding constant name; ROUND_HALF_EVEN is the default rounding mode for the decimal module — also known as banker's rounding — and its full name has 15 characters)"
  category: constant_identity
  kind: python_call_eq
  function: ROUND_HALF_EVEN.__len__
  args: []
  expected: 15

invariant decimal_extra138.ROUND_HALF_UP.value_eq_name:
  description: "decimal.ROUND_HALF_UP.__eq__('ROUND_HALF_UP') is True (the decimal rounding constants are self-describing: the string value stored in each constant is exactly equal to the Python attribute name used to access it; this allows code to pass the constant directly as a string argument to Decimal.quantize() and Context() parameters)"
  category: constant_identity
  kind: python_call_eq
  function: ROUND_HALF_UP.__eq__
  args: ["ROUND_HALF_UP"]
  expected: true
