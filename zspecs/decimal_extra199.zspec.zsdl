spec: decimal_extra199
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra198.zspec.zsdl — covers decimal.__name__, decimal.__package__, decimal.__spec__.name, decimal.__loader__.__class__.__name__, decimal.__doc__.__class__.__name__"
  notes:
    - "This spec covers decimal.__spec__ deeper attributes: name, has_location, parent, __class__.__name__, and origin.__class__.__name__."
    - "decimal.__spec__.name == 'decimal'; the ModuleSpec name matches the module name; confirmed Python 3.14.3 macOS."
    - "decimal.__spec__.has_location == True; decimal is a pure-Python source file (decimal.py) loaded from disk; confirmed Python 3.14.3 macOS."
    - "decimal.__spec__.parent == ''; decimal is a top-level module with no parent package; confirmed Python 3.14.3 macOS."
    - "decimal.__spec__.__class__.__name__ == 'ModuleSpec'; all module specs are ModuleSpec instances; confirmed Python 3.14.3 macOS."
    - "decimal.__spec__.origin.__class__.__name__ == 'str'; the origin is a filesystem path string; confirmed Python 3.14.3 macOS."
    - "decimal is a pure-Python wrapper (decimal.py) with a SourceFileLoader; has_location is True and origin is a non-empty filesystem path."
    - "Unlike io (frozen) and like pathlib/re, decimal is loaded from a .py file and has_location is True."
    - "decimal.__spec__.parent == '' distinguishes it from packages like pathlib and re whose parent equals the package name."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal.__spec__.name identity
# name == 'decimal', length == 7
# ---------------------------------------------------------------------------

table decimal_extra199.spec_name:
  description: "decimal.__spec__.name attribute identity: value, equality, and length"
  kind: python_call_eq
  category: spec_identity
  id_prefix: decimalspec199

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,          decimal.__spec__.name.__eq__,   ["decimal"], true,  "decimal.__spec__.name == 'decimal'; the ModuleSpec name matches the module name; confirmed Python 3.14.3 macOS"]
    - [name_len,         decimal.__spec__.name.__len__,  [],          7,     "decimal.__spec__.name.__len__() == 7; 'decimal' has d(1)e(2)c(3)i(4)m(5)a(6)l(7); confirmed Python 3.14.3 macOS"]
    - [name_not_cdecimal, decimal.__spec__.name.__eq__,  ["_decimal"], false, "decimal.__spec__.name != '_decimal'; the public module name differs from the C accelerator; confirmed Python 3.14.3 macOS"]
    - [name_not_empty,   decimal.__spec__.name.__eq__,   [""],        false, "decimal.__spec__.name is not empty string; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: decimal.__spec__.has_location and decimal.__spec__.parent
# has_location == True (file-based module), parent == '' (top-level module)
# ---------------------------------------------------------------------------

table decimal_extra199.spec_has_location_and_parent:
  description: "decimal.__spec__.has_location and decimal.__spec__.parent attribute identity"
  kind: python_call_eq
  category: spec_identity
  id_prefix: decimalspec199

  columns: [id, function, args, expected, description]
  rows:
    - [has_location_true,      decimal.__spec__.has_location.__eq__,   [true],  true,  "decimal.__spec__.has_location == True; decimal is a pure-Python source file loaded from disk; confirmed Python 3.14.3 macOS"]
    - [has_location_not_false, decimal.__spec__.has_location.__eq__,   [false], false, "decimal.__spec__.has_location != False; decimal has a file location; confirmed Python 3.14.3 macOS"]
    - [parent_eq,              decimal.__spec__.parent.__eq__,         [""],    true,  "decimal.__spec__.parent == ''; decimal is a top-level module with no parent package; confirmed Python 3.14.3 macOS"]
    - [parent_len,             decimal.__spec__.parent.__len__,        [],      0,     "decimal.__spec__.parent.__len__() == 0; empty parent string has length zero; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: decimal.__spec__.__class__.__name__ and decimal.__spec__.origin.__class__.__name__
# __class__.__name__ == 'ModuleSpec', origin.__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

table decimal_extra199.spec_class_and_origin:
  description: "decimal.__spec__.__class__.__name__ and decimal.__spec__.origin.__class__.__name__ identity"
  kind: python_call_eq
  category: spec_identity
  id_prefix: decimalspec199

  columns: [id, function, args, expected, description]
  rows:
    - [class_name_eq,         decimal.__spec__.__class__.__name__.__eq__,          ["ModuleSpec"], true,  "decimal.__spec__.__class__.__name__ == 'ModuleSpec'; all module specs are ModuleSpec instances; confirmed Python 3.14.3 macOS"]
    - [class_name_len,        decimal.__spec__.__class__.__name__.__len__,         [],             10,    "decimal.__spec__.__class__.__name__.__len__() == 10; 'ModuleSpec' has 10 characters; confirmed Python 3.14.3 macOS"]
    - [origin_class_name_eq,  decimal.__spec__.origin.__class__.__name__.__eq__,   ["str"],        true,  "decimal.__spec__.origin.__class__.__name__ == 'str'; the origin is a filesystem path string; confirmed Python 3.14.3 macOS"]
    - [origin_class_name_len, decimal.__spec__.origin.__class__.__name__.__len__,  [],             3,     "decimal.__spec__.origin.__class__.__name__.__len__() == 3; 'str' has s(1)t(2)r(3); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra199.spec_name_eq:
  description: "decimal.__spec__.name == 'decimal' — the ModuleSpec name matches the module name; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: decimal.__spec__.name.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra199.spec_name_len:
  description: "decimal.__spec__.name.__len__() == 7 — 'decimal' has d(1)e(2)c(3)i(4)m(5)a(6)l(7); confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: decimal.__spec__.name.__len__
  args: []
  expected: 7

invariant decimal_extra199.spec_has_location_true:
  description: "decimal.__spec__.has_location == True — decimal is a pure-Python source file loaded from disk; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: decimal.__spec__.has_location.__eq__
  args: [true]
  expected: true

invariant decimal_extra199.spec_parent_eq:
  description: "decimal.__spec__.parent == '' — decimal is a top-level module with no parent package; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: decimal.__spec__.parent.__eq__
  args: [""]
  expected: true

invariant decimal_extra199.spec_parent_len:
  description: "decimal.__spec__.parent.__len__() == 0 — empty parent string has length zero; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: decimal.__spec__.parent.__len__
  args: []
  expected: 0

invariant decimal_extra199.spec_class_name_eq:
  description: "decimal.__spec__.__class__.__name__ == 'ModuleSpec' — all module specs are ModuleSpec instances; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: decimal.__spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant decimal_extra199.spec_class_name_len:
  description: "decimal.__spec__.__class__.__name__.__len__() == 10 — 'ModuleSpec' has 10 characters; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: decimal.__spec__.__class__.__name__.__len__
  args: []
  expected: 10

invariant decimal_extra199.spec_origin_class_name_eq:
  description: "decimal.__spec__.origin.__class__.__name__ == 'str' — the origin is a filesystem path string; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: decimal.__spec__.origin.__class__.__name__.__eq__
  args: ["str"]
  expected: true

