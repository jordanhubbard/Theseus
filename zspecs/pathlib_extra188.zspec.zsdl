spec: pathlib_extra188
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "pathlib.Path.open.__name__=='open' (len=4); read_text (len=9); write_text (len=10); read_bytes (len=10); write_bytes (len=11)."
    - "pathlib.Path.touch.__name__=='touch' (len=5); unlink.__name__=='unlink' (len=6); rename.__name__=='rename' (len=6)."
    - "All method __name__ values match the method's own name as a plain string."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib.Path file read/write method name lengths
# open (len=4), read_text (len=9), write_text (len=10)
# ---------------------------------------------------------------------------

table pathlib_extra188.path_read_write_method_names:
  description: "pathlib.Path file read/write method __name__ values: open (len=4); read_text (len=9); write_text (len=10); read_bytes (len=10); write_bytes (len=11)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibfileop188

  columns: [id, function, args, expected, description]
  rows:
    - [open_name,         Path.open.__name__.__eq__,         ["open"],        true,  "pathlib.Path.open.__name__ == 'open' — file open method name; len('open')==4; confirmed Python 3.14.3 macOS"]
    - [open_name_len,     Path.open.__name__.__len__,        [],              4,     "pathlib.Path.open.__name__.__len__() == 4 — 'open' has 4 characters: o(1)p(2)e(3)n(4); confirmed Python 3.14.3 macOS"]
    - [read_text_name,    Path.read_text.__name__.__eq__,    ["read_text"],   true,  "pathlib.Path.read_text.__name__ == 'read_text' — text file read method name; len('read_text')==9; confirmed Python 3.14.3 macOS"]
    - [write_text_name,   Path.write_text.__name__.__eq__,   ["write_text"],  true,  "pathlib.Path.write_text.__name__ == 'write_text' — text file write method name; len('write_text')==10; confirmed Python 3.14.3 macOS"]
    - [read_bytes_name,   Path.read_bytes.__name__.__eq__,   ["read_bytes"],  true,  "pathlib.Path.read_bytes.__name__ == 'read_bytes' — binary file read method name; len('read_bytes')==10; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: pathlib.Path method name lengths (continued)
# write_bytes (len=11), touch (len=5), unlink (len=6), rename (len=6)
# ---------------------------------------------------------------------------

table pathlib_extra188.path_write_and_fs_method_names:
  description: "pathlib.Path write_bytes and filesystem mutation method __name__ values: write_bytes (len=11); touch (len=5); unlink (len=6); rename (len=6)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibfileop188

  columns: [id, function, args, expected, description]
  rows:
    - [write_bytes_name,   Path.write_bytes.__name__.__eq__,   ["write_bytes"],  true,  "pathlib.Path.write_bytes.__name__ == 'write_bytes' — binary file write method name; len('write_bytes')==11; confirmed Python 3.14.3 macOS"]
    - [write_bytes_len,    Path.write_bytes.__name__.__len__,  [],               11,    "pathlib.Path.write_bytes.__name__.__len__() == 11 — 'write_bytes' has 11 characters: w(1)r(2)i(3)t(4)e(5)_(6)b(7)y(8)t(9)e(10)s(11); confirmed Python 3.14.3 macOS"]
    - [touch_name,         Path.touch.__name__.__eq__,         ["touch"],        true,  "pathlib.Path.touch.__name__ == 'touch' — file touch method name; len('touch')==5; confirmed Python 3.14.3 macOS"]
    - [unlink_name,        Path.unlink.__name__.__eq__,        ["unlink"],       true,  "pathlib.Path.unlink.__name__ == 'unlink' — file delete method name; len('unlink')==6; confirmed Python 3.14.3 macOS"]
    - [rename_name,        Path.rename.__name__.__eq__,        ["rename"],       true,  "pathlib.Path.rename.__name__ == 'rename' — file rename method name; len('rename')==6; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: pathlib.Path method name length values
# Explicit __len__ calls confirming character counts
# ---------------------------------------------------------------------------

table pathlib_extra188.path_method_name_lengths:
  description: "pathlib.Path file operation method __name__.__len__() values: read_text (9), write_text (10), read_bytes (10), touch (5), unlink (6), rename (6)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibfileop188

  columns: [id, function, args, expected, description]
  rows:
    - [read_text_len,    Path.read_text.__name__.__len__,    [],  9,   "pathlib.Path.read_text.__name__.__len__() == 9 — 'read_text': r(1)e(2)a(3)d(4)_(5)t(6)e(7)x(8)t(9); confirmed Python 3.14.3 macOS"]
    - [write_text_len,   Path.write_text.__name__.__len__,   [],  10,  "pathlib.Path.write_text.__name__.__len__() == 10 — 'write_text': w(1)r(2)i(3)t(4)e(5)_(6)t(7)e(8)x(9)t(10); confirmed Python 3.14.3 macOS"]
    - [read_bytes_len,   Path.read_bytes.__name__.__len__,   [],  10,  "pathlib.Path.read_bytes.__name__.__len__() == 10 — 'read_bytes': r(1)e(2)a(3)d(4)_(5)b(6)y(7)t(8)e(9)s(10); confirmed Python 3.14.3 macOS"]
    - [touch_len,        Path.touch.__name__.__len__,        [],  5,   "pathlib.Path.touch.__name__.__len__() == 5 — 'touch': t(1)o(2)u(3)c(4)h(5); confirmed Python 3.14.3 macOS"]
    - [unlink_rename_eq, Path.unlink.__name__.__len__,       [],  6,   "pathlib.Path.unlink.__name__.__len__() == 6 — 'unlink': u(1)n(2)l(3)i(4)n(5)k(6); same length as rename; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra188.path_open_name_is_open:
  description: "pathlib.Path.open.__name__ == 'open' — file open method name; len('open')==4: o(1)p(2)e(3)n(4); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.open.__name__.__eq__
  args: ["open"]
  expected: true

invariant pathlib_extra188.path_open_name_len_is_4:
  description: "pathlib.Path.open.__name__.__len__() == 4 — 'open' has 4 characters; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.open.__name__.__len__
  args: []
  expected: 4

invariant pathlib_extra188.path_read_text_name_is_read_text:
  description: "pathlib.Path.read_text.__name__ == 'read_text' — text file read method name; len('read_text')==9; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.read_text.__name__.__eq__
  args: ["read_text"]
  expected: true

invariant pathlib_extra188.path_write_text_name_is_write_text:
  description: "pathlib.Path.write_text.__name__ == 'write_text' — text file write method name; len('write_text')==10; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.write_text.__name__.__eq__
  args: ["write_text"]
  expected: true

invariant pathlib_extra188.path_read_bytes_name_is_read_bytes:
  description: "pathlib.Path.read_bytes.__name__ == 'read_bytes' — binary file read method name; len('read_bytes')==10; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.read_bytes.__name__.__eq__
  args: ["read_bytes"]
  expected: true

invariant pathlib_extra188.path_write_bytes_name_is_write_bytes:
  description: "pathlib.Path.write_bytes.__name__ == 'write_bytes' — binary file write method name; len('write_bytes')==11; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.write_bytes.__name__.__eq__
  args: ["write_bytes"]
  expected: true

invariant pathlib_extra188.path_touch_name_is_touch:
  description: "pathlib.Path.touch.__name__ == 'touch' — file touch method name; len('touch')==5: t(1)o(2)u(3)c(4)h(5); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.touch.__name__.__eq__
  args: ["touch"]
  expected: true

invariant pathlib_extra188.path_unlink_name_is_unlink:
  description: "pathlib.Path.unlink.__name__ == 'unlink' — file delete method name; len('unlink')==6: u(1)n(2)l(3)i(4)n(5)k(6); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.unlink.__name__.__eq__
  args: ["unlink"]
  expected: true

invariant pathlib_extra188.path_rename_name_is_rename:
  description: "pathlib.Path.rename.__name__ == 'rename' — file rename method name; len('rename')==6: r(1)e(2)n(3)a(4)m(5)e(6); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.rename.__name__.__eq__
  args: ["rename"]
  expected: true
