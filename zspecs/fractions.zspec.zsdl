spec: fractions
version: ">=3.2"
backend: python_module(fractions)

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "Python fractions documentation — https://docs.python.org/3/library/fractions.html"
    - "Test vectors verified by running Python 3.14.3 fractions module on macOS/Darwin 25.4.0, 2026-04-08"
  not_derived_from:
    - "CPython source: Lib/fractions.py"
  notes:
    - "Fraction objects are always stored in lowest terms (auto-reduced on construction)."
    - "Fraction(2, 4) == Fraction(1, 2) — the denominator is always positive after normalisation."
    - "Fraction from float: Fraction(0.5) == Fraction(1, 2) because 0.5 is exactly representable in binary."
    - "Fraction from string: Fraction('3/4') and Fraction('0.25') parse decimal and ratio forms."
    - "Arithmetic operators (__add__, __sub__, __mul__, __truediv__) accept int or Fraction operands; int operands are used in method_args since Fraction objects cannot be serialised as JSON."
    - "limit_denominator(max_denom) returns the closest Fraction whose denominator <= max_denom."
    - "numerator and denominator are read-only integer properties; accessible as non-callable method attributes."
    - "ZeroDivisionError is raised for Fraction(1, 0). ValueError is raised for Fraction('bad')."
    - "Arithmetic results are Fraction objects; __str__ is used via method_chain to get the string representation."
  created_at: "2026-04-08T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class metadata
# ---------------------------------------------------------------------------

invariant fractions.Fraction.class_name:
  description: "Fraction.__name__ == 'Fraction'"
  category: class_metadata
  kind: python_call_eq
  function: Fraction.__name__.__eq__
  args: ["Fraction"]
  expected: true

# ---------------------------------------------------------------------------
# Constructor — from two ints, with auto-reduction
# ---------------------------------------------------------------------------

table fractions.Fraction.constructor_two_ints:
  kind: python_call_eq
  category: constructor
  id_prefix: ctor_str
  function: Fraction
  method: __str__
  method_args: []

  columns: [id, args, expected]
  rows:
    - [one_third,       [1, 3],   "1/3" ]
    - [auto_reduced,    [2, 4],   "1/2" ]
    - [zero,            [0],      "0"   ]
    - [whole_number,    [5],      "5"   ]
    - [negative,        [-3, 4],  "-3/4"]

# ---------------------------------------------------------------------------
# Constructor — from string
# ---------------------------------------------------------------------------

invariant fractions.Fraction.from_ratio_string:
  description: "Fraction('3/4') produces string '3/4'"
  category: constructor
  kind: python_call_eq
  function: Fraction
  args: ["3/4"]
  method: __str__
  method_args: []
  expected: "3/4"

invariant fractions.Fraction.from_decimal_string:
  description: "Fraction('0.25') == Fraction(1, 4) → '1/4'"
  category: constructor
  kind: python_call_eq
  function: Fraction
  args: ["0.25"]
  method: __str__
  method_args: []
  expected: "1/4"

# ---------------------------------------------------------------------------
# Constructor — from float (exact binary fractions only)
# ---------------------------------------------------------------------------

invariant fractions.Fraction.from_float_half:
  description: "Fraction(0.5) == '1/2' — 0.5 is exactly representable in binary"
  category: constructor
  kind: python_call_eq
  function: Fraction
  args: [0.5]
  method: __str__
  method_args: []
  expected: "1/2"

# ---------------------------------------------------------------------------
# numerator and denominator properties (non-callable, accessed via method:)
# ---------------------------------------------------------------------------

invariant fractions.Fraction.numerator:
  description: "Fraction(1, 4).numerator == 1"
  category: properties
  kind: python_call_eq
  function: Fraction
  args: [1, 4]
  method: numerator
  expected: 1

invariant fractions.Fraction.denominator:
  description: "Fraction(1, 4).denominator == 4"
  category: properties
  kind: python_call_eq
  function: Fraction
  args: [1, 4]
  method: denominator
  expected: 4

# ---------------------------------------------------------------------------
# Arithmetic — __add__, __sub__, __mul__, __truediv__ with integer operands
# (Fraction supports mixed arithmetic with int; Fraction args cannot be
# serialised as JSON so integers are used for method_args here.)
# method_chain: __str__ converts the returned Fraction to its string form.
# ---------------------------------------------------------------------------

invariant fractions.Fraction.add_int:
  description: "Fraction(1, 4).__add__(1) == Fraction(5, 4) → '5/4'"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [1, 4]
  method: __add__
  method_args: [1]
  method_chain: __str__
  expected: "5/4"

invariant fractions.Fraction.sub_int:
  description: "Fraction(5, 4).__sub__(1) == Fraction(1, 4) → '1/4'"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [5, 4]
  method: __sub__
  method_args: [1]
  method_chain: __str__
  expected: "1/4"

invariant fractions.Fraction.mul_int:
  description: "Fraction(3, 4).__mul__(4) == 3 → '3'"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [3, 4]
  method: __mul__
  method_args: [4]
  method_chain: __str__
  expected: "3"

invariant fractions.Fraction.truediv_int:
  description: "Fraction(3, 4).__truediv__(3) == Fraction(1, 4) → '1/4'"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [3, 4]
  method: __truediv__
  method_args: [3]
  method_chain: __str__
  expected: "1/4"

invariant fractions.Fraction.neg:
  description: "Fraction(3, 4).__neg__() == '-3/4'"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [3, 4]
  method: __neg__
  method_args: []
  method_chain: __str__
  expected: "-3/4"

invariant fractions.Fraction.abs:
  description: "Fraction(-3, 4).__abs__() == '3/4'"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [-3, 4]
  method: __abs__
  method_args: []
  method_chain: __str__
  expected: "3/4"

# ---------------------------------------------------------------------------
# Comparison — __lt__, __le__, __eq__, __gt__ with integer operands
# ---------------------------------------------------------------------------

invariant fractions.Fraction.lt_int_true:
  description: "Fraction(1, 2).__lt__(1) == True — 1/2 < 1"
  category: comparison
  kind: python_call_eq
  function: Fraction
  args: [1, 2]
  method: __lt__
  method_args: [1]
  expected: true

invariant fractions.Fraction.le_equal:
  description: "Fraction(2, 4).__le__(1) == True — 2/4 = 1/2 ≤ 1"
  category: comparison
  kind: python_call_eq
  function: Fraction
  args: [2, 4]
  method: __le__
  method_args: [1]
  expected: true

invariant fractions.Fraction.eq_int:
  description: "Fraction(4, 2).__eq__(2) == True — auto-reduced 4/2 == 2"
  category: comparison
  kind: python_call_eq
  function: Fraction
  args: [4, 2]
  method: __eq__
  method_args: [2]
  expected: true

invariant fractions.Fraction.gt_int_true:
  description: "Fraction(3, 2).__gt__(1) == True — 3/2 > 1"
  category: comparison
  kind: python_call_eq
  function: Fraction
  args: [3, 2]
  method: __gt__
  method_args: [1]
  expected: true

invariant fractions.Fraction.lt_int_false:
  description: "Fraction(1, 2).__lt__(0) == False — 1/2 is not less than 0"
  category: comparison
  kind: python_call_eq
  function: Fraction
  args: [1, 2]
  method: __lt__
  method_args: [0]
  expected: false

# ---------------------------------------------------------------------------
# limit_denominator — best rational approximation within denominator bound
# ---------------------------------------------------------------------------

invariant fractions.Fraction.limit_denominator_fits:
  description: "Fraction(1, 3).limit_denominator(10) == '1/3' — already within the denominator limit"
  category: limit_denominator
  kind: python_call_eq
  function: Fraction
  args: [1, 3]
  method: limit_denominator
  method_args: [10]
  method_chain: __str__
  expected: "1/3"

invariant fractions.Fraction.limit_denominator_approx:
  description: "Fraction(355, 113).limit_denominator(10) == '22/7' — best rational approx of pi with denominator ≤ 10"
  category: limit_denominator
  kind: python_call_eq
  function: Fraction
  args: [355, 113]
  method: limit_denominator
  method_args: [10]
  method_chain: __str__
  expected: "22/7"

# ---------------------------------------------------------------------------
# Error cases
# ---------------------------------------------------------------------------

invariant fractions.Fraction.zero_denominator_raises:
  description: "Fraction(1, 0) raises ZeroDivisionError"
  category: error
  kind: python_call_raises
  function: Fraction
  args: [1, 0]
  expected_exception: ZeroDivisionError

invariant fractions.Fraction.invalid_string_raises:
  description: "Fraction('bad') raises ValueError — malformed string is rejected"
  category: error
  kind: python_call_raises
  function: Fraction
  args: ["bad"]
  expected_exception: ValueError

