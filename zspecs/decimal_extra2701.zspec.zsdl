spec: decimal_extra2701
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra.zspec.zsdl — covers existing decimal invariants"
    - "decimal_extra2686.zspec.zsdl — covers __and__/__or__/__xor__ dict-presence"
  notes:
    - "Wave 627 (decimal_extra2701) theme: __lshift__, __rshift__, and __invert__ dict-presence checks."
    - "decimal.Decimal does NOT define __lshift__, __rshift__, or __invert__ in its own __dict__ — Decimal has no bit-shift or bitwise-NOT operators."
    - "decimal.Decimal DOES define logical_and, logical_or, and logical_xor as named methods for digit-by-digit logical operations — these are NOT dunder bit-shift operators."
    - "decimal.Context also defines logical_and, logical_or, and logical_xor as methods (context-aware variants) — NOT dunder bit-shift or bitwise-NOT operators."
    - "decimal.Context and decimal.DecimalException also define none of __lshift__, __rshift__, or __invert__ in their own __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __lshift__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2701.no_lshift_in_decimal_classes:
  description: "__lshift__ is absent from decimal.Decimal, decimal.Context, and decimal.DecimalException __dict__s — Decimal arithmetic does not include bit-shift operations"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2701

  columns: [id, function, args, expected]
  rows:
    - ["dc2701001", "decimal.Decimal.__dict__.__contains__",          ["__lshift__"], false]
    - ["dc2701002", "decimal.Context.__dict__.__contains__",          ["__lshift__"], false]
    - ["dc2701003", "decimal.DecimalException.__dict__.__contains__", ["__lshift__"], false]

# ---------------------------------------------------------------------------
# __rshift__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2701.no_rshift_in_decimal_classes:
  description: "__rshift__ is absent from decimal.Decimal, decimal.Context, and decimal.DecimalException __dict__s — Decimal arithmetic does not include bit-shift operations"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2701

  columns: [id, function, args, expected]
  rows:
    - ["dc2701004", "decimal.Decimal.__dict__.__contains__",          ["__rshift__"], false]
    - ["dc2701005", "decimal.Context.__dict__.__contains__",          ["__rshift__"], false]
    - ["dc2701006", "decimal.DecimalException.__dict__.__contains__", ["__rshift__"], false]

# ---------------------------------------------------------------------------
# __invert__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2701.no_invert_in_decimal_classes:
  description: "__invert__ is absent from decimal.Decimal, decimal.Context, and decimal.DecimalException __dict__s — Decimal arithmetic does not include bitwise NOT"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2701

  columns: [id, function, args, expected]
  rows:
    - ["dc2701007", "decimal.Decimal.__dict__.__contains__",          ["__invert__"], false]
    - ["dc2701008", "decimal.Context.__dict__.__contains__",          ["__invert__"], false]
    - ["dc2701009", "decimal.DecimalException.__dict__.__contains__", ["__invert__"], false]

# ---------------------------------------------------------------------------
# Complementary: decimal.Decimal and decimal.Context have named logical methods (NOT dunder bit-shift)
# Contrasts the named logical_and/logical_or/logical_xor with the absent __lshift__/__rshift__/__invert__ dunders
# ---------------------------------------------------------------------------

table decimal_extra2701.decimal_has_named_logical_methods_not_shift_dunders:
  description: "decimal.Decimal defines logical_and/logical_or/logical_xor as named methods but NOT __lshift__/__rshift__/__invert__; decimal.Context likewise defines logical_and/logical_or/logical_xor but NOT __lshift__/__rshift__/__invert__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2701

  columns: [id, function, args, expected]
  rows:
    - ["dc2701010", "decimal.Decimal.__dict__.__contains__", ["logical_and"],  true]
    - ["dc2701011", "decimal.Decimal.__dict__.__contains__", ["logical_or"],   true]
    - ["dc2701012", "decimal.Decimal.__dict__.__contains__", ["logical_xor"],  true]
    - ["dc2701013", "decimal.Decimal.__dict__.__contains__", ["__lshift__"],   false]
    - ["dc2701014", "decimal.Decimal.__dict__.__contains__", ["__rshift__"],   false]
    - ["dc2701015", "decimal.Decimal.__dict__.__contains__", ["__invert__"],   false]
    - ["dc2701016", "decimal.Context.__dict__.__contains__", ["logical_and"],  true]
    - ["dc2701017", "decimal.Context.__dict__.__contains__", ["logical_or"],   true]
    - ["dc2701018", "decimal.Context.__dict__.__contains__", ["logical_xor"],  true]
    - ["dc2701019", "decimal.Context.__dict__.__contains__", ["__lshift__"],   false]
    - ["dc2701020", "decimal.Context.__dict__.__contains__", ["__rshift__"],   false]
    - ["dc2701021", "decimal.Context.__dict__.__contains__", ["__invert__"],   false]
