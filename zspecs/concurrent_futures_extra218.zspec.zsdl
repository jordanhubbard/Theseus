spec: concurrent_futures_extra218
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "concurrent.futures.Executor.__name__.__len__() == 8 ('Executor' = 8 chars)."
    - "concurrent.futures.ThreadPoolExecutor.__name__.__len__() == 18 ('ThreadPoolExecutor' = 18 chars)."
    - "concurrent.futures.ProcessPoolExecutor.__name__.__len__() == 19 ('ProcessPoolExecutor' = 19 chars)."
    - "concurrent.futures.Future.__name__.__len__() == 6 ('Future' = 6 chars)."
    - "concurrent.futures.CancelledError.__name__.__len__() == 14 ('CancelledError' = 14 chars)."
    - "concurrent.futures.TimeoutError.__name__.__len__() == 12 ('TimeoutError' = 12 chars)."
    - "concurrent.futures.BrokenExecutor.__name__.__len__() == 14 ('BrokenExecutor' = 14 chars)."
    - "concurrent.futures.InvalidStateError.__name__.__len__() == 17 ('InvalidStateError' = 17 chars)."
    - "concurrent.futures.ThreadPoolExecutor.__name__.__gt__('ProcessPoolExecutor') == True — alphabetically 'T' > 'P'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures executor class name lengths — extra218 namespace
# ---------------------------------------------------------------------------

table concurrent_futures_extra218.executor_name_lengths:
  description: "concurrent.futures executor class __name__.__len__() checks in extra218 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cf218execnamelen

  columns: [id, function, args, expected, description]
  rows:
    - [executor_name_len,         Executor.__name__.__len__,         [], 8,  "concurrent.futures.Executor.__name__.__len__() == 8 ('Executor'=8); verified with Python 3.14.3"]
    - [threadpool_name_len,       ThreadPoolExecutor.__name__.__len__, [], 18, "concurrent.futures.ThreadPoolExecutor.__name__.__len__() == 18 ('ThreadPoolExecutor'=18); verified with Python 3.14.3"]
    - [processpool_name_len,      ProcessPoolExecutor.__name__.__len__, [], 19, "concurrent.futures.ProcessPoolExecutor.__name__.__len__() == 19 ('ProcessPoolExecutor'=19); verified with Python 3.14.3"]
    - [future_name_len,           Future.__name__.__len__,           [], 6,  "concurrent.futures.Future.__name__.__len__() == 6 ('Future'=6); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures exception class name lengths — extra218 namespace
# ---------------------------------------------------------------------------

table concurrent_futures_extra218.exception_name_lengths:
  description: "concurrent.futures exception class __name__.__len__() checks in extra218 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cf218excnamelen

  columns: [id, function, args, expected, description]
  rows:
    - [cancelled_error_name_len,    CancelledError.__name__.__len__,    [], 14, "concurrent.futures.CancelledError.__name__.__len__() == 14 ('CancelledError'=14); verified with Python 3.14.3"]
    - [timeout_error_name_len,      TimeoutError.__name__.__len__,      [], 12, "concurrent.futures.TimeoutError.__name__.__len__() == 12 ('TimeoutError'=12); verified with Python 3.14.3"]
    - [broken_executor_name_len,    BrokenExecutor.__name__.__len__,    [], 14, "concurrent.futures.BrokenExecutor.__name__.__len__() == 14 ('BrokenExecutor'=14); verified with Python 3.14.3"]
    - [invalid_state_error_name_len, InvalidStateError.__name__.__len__, [], 17, "concurrent.futures.InvalidStateError.__name__.__len__() == 17 ('InvalidStateError'=17); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ThreadPoolExecutor.__name__ > ProcessPoolExecutor.__name__ — extra218
#
# Alphabetically 'T' > 'P', so 'ThreadPoolExecutor' > 'ProcessPoolExecutor'.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra218.threadpool_gt_processpool_name:
  description: "concurrent.futures.ThreadPoolExecutor.__name__.__gt__('ProcessPoolExecutor') == True — 'ThreadPoolExecutor' > 'ProcessPoolExecutor' alphabetically ('T' > 'P'); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.__name__.__gt__
  args: ["ProcessPoolExecutor"]
  expected: true
