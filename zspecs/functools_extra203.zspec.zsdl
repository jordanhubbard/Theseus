  category: string_identity
  id_prefix: functpartialmethods203

  columns: [id, function, args, expected, description]
  rows:
    - [partial_init_qualname_eq,
       partial.__init__.__qualname__.__eq__,
       ["object.__init__"],
       true,
       "functools.partial.__init__.__qualname__.__eq__('object.__init__') == True — partial does not define its own __init__; it inherits from object; the qualname carries the 'object.' prefix; str.__eq__('object.__init__') returns True; new to extra203"]
    - [partial_reduce_qualname_eq,
       partial.__reduce__.__qualname__.__eq__,
       ["partial.__reduce__"],
       true,
       "functools.partial.__reduce__.__qualname__.__eq__('partial.__reduce__') == True — partial defines its own C-level __reduce__ for pickle support; __qualname__ is 'partial.__reduce__'; str.__eq__('partial.__reduce__') returns True; new to extra203"]
    - [partial_setstate_qualname_eq,
       partial.__setstate__.__qualname__.__eq__,
       ["partial.__setstate__"],
       true,
       "functools.partial.__setstate__.__qualname__.__eq__('partial.__setstate__') == True — partial defines its own C-level __setstate__ for pickle support; __qualname__ is 'partial.__setstate__'; str.__eq__('partial.__setstate__') returns True; new to extra203"]

