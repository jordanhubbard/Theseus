spec: functools_extra203
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.partial method code objects — __init__, __reduce__, __setstate__, __repr__, __hash__, __eq__, __new__ __qualname__ and __class__.__name__."
    - "functools.partial is a C extension type defined in Modules/_functoolsmodule.c; its methods are C-level descriptors."
    - "partial.__init__.__qualname__ == 'object.__init__' — partial does not define its own __init__; it inherits from object. Verified with Python 3.14.3."
    - "partial.__init__.__class__.__name__ == 'wrapper_descriptor' — inherited C slot wrappers have type wrapper_descriptor, not method_descriptor. Verified with Python 3.14.3."
    - "partial.__reduce__.__qualname__ == 'partial.__reduce__' — partial defines its own __reduce__ method in C; __qualname__ includes the type prefix. Verified with Python 3.14.3."
    - "partial.__setstate__.__qualname__ == 'partial.__setstate__' — partial defines its own __setstate__ method in C for pickle support. Verified with Python 3.14.3."
    - "partial.__repr__.__qualname__ == 'partial.__repr__' — partial defines its own __repr__ in C; the qualname reflects this. Verified with Python 3.14.3."
    - "partial.__hash__.__qualname__ == 'object.__hash__' — partial inherits __hash__ from object; the qualname has the 'object.' prefix. Verified with Python 3.14.3."
    - "partial.__eq__.__qualname__ == 'object.__eq__' — partial inherits __eq__ from object; the qualname has the 'object.' prefix. Verified with Python 3.14.3."
    - "partial.__new__.__qualname__ == 'partial.__new__' — partial defines its own __new__ in C; __new__ is a builtin_function_or_method. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: partial.__init__, __reduce__, __setstate__ __qualname__
#
# partial.__init__.__qualname__.__eq__('object.__init__') == True
# partial.__reduce__.__qualname__.__eq__('partial.__reduce__') == True
# partial.__setstate__.__qualname__.__eq__('partial.__setstate__') == True
#
# partial.__init__ is inherited from object (wrapper_descriptor); __reduce__
# and __setstate__ are defined directly on partial (method_descriptor).
# New to extra203.
# ---------------------------------------------------------------------------

table functools_extra203.partial_init_reduce_setstate_qualnames:
  description: "functools.partial __init__, __reduce__, __setstate__ __qualname__; C extension type methods; __init__ inherited from object, __reduce__/__setstate__ defined on partial; new to extra203"
