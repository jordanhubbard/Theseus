spec: multiprocessing_extra166
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec covers: multiprocessing.Value and multiprocessing.Array bound method identity (__qualname__ and __name__); multiprocessing.current_process function name and module identity; multiprocessing.active_children function name and module identity. KEY FINDINGS: multiprocessing.Value and multiprocessing.Array are bound methods on the default context object (DefaultContext), not standalone functions or classes; their __qualname__ is 'BaseContext.Value' and 'BaseContext.Array' (len=17 each). current_process and active_children both have __module__=='multiprocessing.process' (len=23: 'multiprocessing'=15+'.'=1+'process'=7=23). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.Value is a bound method: type(multiprocessing.Value)=='method'; multiprocessing.Value.__qualname__=='BaseContext.Value' (len=17: 'BaseContext'=11+'.'=1+'Value'=5=17); multiprocessing.Value.__name__=='Value' (len=5: 'V'+'a'+'l'+'u'+'e'=5); Value creates a ctypes object in shared memory accessible by multiple processes — multiprocessing.Value(typecode_or_type, *args, lock=True); the underlying ctypes type is determined by the typecode (like 'i' for int, 'd' for double); Verified with Python 3.14.3."
    - "multiprocessing.Array is a bound method: type(multiprocessing.Array)=='method'; multiprocessing.Array.__qualname__=='BaseContext.Array' (len=17: 'BaseContext'=11+'.'=1+'Array'=5=17; same length as BaseContext.Value=17: 'Value'=5=='Array'=5); multiprocessing.Array.__name__=='Array' (len=5: 'A'+'r'+'r'+'a'+'y'=5; same name len as Value=5); Array creates a ctypes array in shared memory — multiprocessing.Array(typecode_or_type, size_or_initializer, lock=True). Verified with Python 3.14.3."
    - "multiprocessing.current_process.__name__=='current_process' (len=15: 'current'=7+'_'=1+'process'=7=15); __module__=='multiprocessing.process' (len=23: 'multiprocessing'=15+'.'=1+'process'=7=23); current_process() returns the Process object for the calling process (analogous to threading.current_thread()); multiprocessing.active_children.__name__=='active_children' (len=15: 'active'=6+'_'=1+'children'=8=15; same len as current_process=15); __module__=='multiprocessing.process' (len=23; same module as current_process). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Value bound method identity — extra166
#
# multiprocessing.Value.__qualname__.__eq__('BaseContext.Value') == True
# multiprocessing.Value.__qualname__.__len__()                  == 17
# multiprocessing.Value.__name__.__eq__('Value')                == True
# multiprocessing.Value.__name__.__len__()                      == 5
# ---------------------------------------------------------------------------

table multiprocessing_extra166.mp_value_identity:
  description: "multiprocessing.Value bound method name and qualname identity checks in mpvalid166 namespace — multiprocessing.Value.__qualname__.__eq__('BaseContext.Value')==True (KEY FINDING: multiprocessing.Value is a BOUND METHOD of the default context object, not a standalone function or class; Value.__qualname__=='BaseContext.Value' (len=17: 'BaseContext'=11+'.'=1+'Value'=5=17); the __qualname__ reflects the method's definition location in BaseContext; multiprocessing.Value(typecode_or_type, *args, lock=True) creates a ctypes shared-memory variable accessible by multiple processes; it returns a Value proxy wrapping the ctypes object in a Lock-protected container); multiprocessing.Value.__qualname__.__len__()==17 ('BaseContext.Value'=17: 'BaseContext'=11+'.'=1+'Value'=5=17); multiprocessing.Value.__name__.__eq__('Value')==True (the __name__ of the bound method is just 'Value' (len=5: 'V'+'a'+'l'+'u'+'e'=5) without the class qualifier); multiprocessing.Value.__name__.__len__()==5 ('Value'=5; same as asyncio.Queue.__name__='Queue'=5 from extra168 — coincidentally both are 5-char names); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpvalid166

  columns: [id, function, args, expected, description]
  rows:
    - [val_qualname_eq,  multiprocessing.Value.__qualname__.__eq__,  ["BaseContext.Value"],  true,  "Value.__qualname__ == 'BaseContext.Value' (bound method; len=17: BaseContext=11+.=1+Value=5=17); verified with Python 3.14.3"]
    - [val_qualname_len, multiprocessing.Value.__qualname__.__len__, [],                     17,    "Value.__qualname__.__len__() == 17 ('BaseContext.Value'=17); verified with Python 3.14.3"]
    - [val_name_eq,      multiprocessing.Value.__name__.__eq__,      ["Value"],              true,  "Value.__name__ == 'Value' (len=5: __name__ is just the method name without class); verified with Python 3.14.3"]
    - [val_name_len,     multiprocessing.Value.__name__.__len__,     [],                     5,     "Value.__name__.__len__() == 5 ('Value'=5; same len as asyncio.Queue name=5); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.Array bound method identity — extra166
#
# multiprocessing.Array.__qualname__.__eq__('BaseContext.Array') == True
# multiprocessing.Array.__qualname__.__len__()                  == 17
# multiprocessing.Array.__name__.__eq__('Array')                == True
# multiprocessing.Array.__name__.__len__()                      == 5
# ---------------------------------------------------------------------------

table multiprocessing_extra166.mp_array_identity:
  description: "multiprocessing.Array bound method name and qualname identity checks in mparray166 namespace — multiprocessing.Array.__qualname__.__eq__('BaseContext.Array')==True (multiprocessing.Array is also a BOUND METHOD of the default context object; Array.__qualname__=='BaseContext.Array' (len=17: 'BaseContext'=11+'.'=1+'Array'=5=17; same length as BaseContext.Value=17 because 'Array'=5=='Value'=5)); multiprocessing.Array.__qualname__.__len__()==17 ('BaseContext.Array'=17; same as Value qualname len=17 — KEY: both Value and Array have identical qualname lengths because 'Value'=5=='Array'=5); multiprocessing.Array.__name__.__eq__('Array')==True (Array.__name__=='Array' (len=5: 'A'+'r'+'r'+'a'+'y'=5; same length as Value.__name__='Value'=5)); multiprocessing.Array.__name__.__len__()==5 ('Array'=5; same as Value=5: both are 5-char method names); multiprocessing.Array(typecode_or_type, size_or_initializer, lock=True) creates a ctypes array in shared memory — a fixed-size array of a ctypes type accessible from multiple processes; KEY: Array.__qualname__ len(17)==Value.__qualname__ len(17) and Array.__name__ len(5)==Value.__name__ len(5); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mparray166

  columns: [id, function, args, expected, description]
  rows:
    - [arr_qualname_eq,  multiprocessing.Array.__qualname__.__eq__,  ["BaseContext.Array"],  true,  "Array.__qualname__ == 'BaseContext.Array' (bound method; len=17: same as BaseContext.Value=17); verified with Python 3.14.3"]
    - [arr_qualname_len, multiprocessing.Array.__qualname__.__len__, [],                     17,    "Array.__qualname__.__len__() == 17 ('BaseContext.Array'=17; same as Value qualname len=17); verified with Python 3.14.3"]
    - [arr_name_eq,      multiprocessing.Array.__name__.__eq__,      ["Array"],              true,  "Array.__name__ == 'Array' (len=5: same len as Value=5; both 5-char method names); verified with Python 3.14.3"]
    - [arr_name_len,     multiprocessing.Array.__name__.__len__,     [],                     5,     "Array.__name__.__len__() == 5 ('Array'=5; Value=5==Array=5 in name length); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.current_process function identity — extra166
#
# multiprocessing.current_process.__name__.__eq__('current_process')             == True
# multiprocessing.current_process.__name__.__len__()                             == 15
# multiprocessing.current_process.__module__.__eq__('multiprocessing.process')   == True
# multiprocessing.current_process.__module__.__len__()                           == 23
# ---------------------------------------------------------------------------

table multiprocessing_extra166.mp_current_process_identity:
  description: "multiprocessing.current_process function name and module identity checks in mpcurproc166 namespace — multiprocessing.current_process.__name__.__eq__('current_process')==True (current_process.__name__=='current_process' (len=15: 'current'=7+'_'=1+'process'=7=15); multiprocessing.current_process() returns the Process object representing the calling process — the main process or a child process; it is analogous to threading.current_thread() in the threading module; the returned Process object has attributes including .name, .pid, .exitcode, .daemon, .is_alive(), .authkey; current_process() always returns a Process object even for the main process); multiprocessing.current_process.__name__.__len__()==15 ('current_process'=15: 'current'=7+'_process'=8: '_'=1+'process'=7=8; 7+8=15); multiprocessing.current_process.__module__.__eq__('multiprocessing.process')==True (__module__=='multiprocessing.process' (len=23: 'multiprocessing'=15+'.'=1+'process'=7=23)); multiprocessing.current_process.__module__.__len__()==23 ('multiprocessing.process'=23; compare: 'multiprocessing.pool'=20 is 3 shorter; 'multiprocessing.managers'=24 is 1 longer than process=23); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpcurproc166

  columns: [id, function, args, expected, description]
  rows:
    - [cp_name_eq,  multiprocessing.current_process.__name__.__eq__,    ["current_process"],           true,  "current_process.__name__ == 'current_process' (len=15: 'current'=7+'_process'=8=15); verified with Python 3.14.3"]
    - [cp_name_len, multiprocessing.current_process.__name__.__len__,   [],                            15,    "current_process.__name__.__len__() == 15 ('current_process'=15; same as active_children=15); verified with Python 3.14.3"]
    - [cp_mod_eq,   multiprocessing.current_process.__module__.__eq__,  ["multiprocessing.process"],   true,  "current_process.__module__ == 'multiprocessing.process' (len=23; 'process'=7 submodule); verified with Python 3.14.3"]
    - [cp_mod_len,  multiprocessing.current_process.__module__.__len__, [],                            23,    "current_process.__module__.__len__() == 23 ('multiprocessing.process'=23; 3 longer than mp.pool=20); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.active_children function identity — extra166
#
# multiprocessing.active_children.__name__.__eq__('active_children')             == True
# multiprocessing.active_children.__name__.__len__()                             == 15
# multiprocessing.active_children.__module__.__eq__('multiprocessing.process')   == True
# multiprocessing.active_children.__module__.__len__()                           == 23
# ---------------------------------------------------------------------------

table multiprocessing_extra166.mp_active_children_identity:
  description: "multiprocessing.active_children function name and module identity checks in mpactchild166 namespace — multiprocessing.active_children.__name__.__eq__('active_children')==True (active_children.__name__=='active_children' (len=15: 'active'=6+'_'=1+'children'=8=15); multiprocessing.active_children() returns a list of all currently active child Process objects; it joins all completed processes first (equivalent to calling process.join() for each finished process) and then returns the list of still-running child processes; active_children() is commonly used to monitor the number of running worker processes and avoid creating more than needed); multiprocessing.active_children.__name__.__len__()==15 ('active_children'=15: 'active'=6+'_children'=9: '_'=1+'children'=8=9; 6+9=15; KEY: active_children(15)==current_process(15) in name length — a coincidence; both are 15-char function names in multiprocessing.process); multiprocessing.active_children.__module__.__eq__('multiprocessing.process')==True (__module__=='multiprocessing.process' (len=23; same module as current_process)); multiprocessing.active_children.__module__.__len__()==23 (same as current_process module len=23; both defined in Lib/multiprocessing/process.py); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpactchild166

  columns: [id, function, args, expected, description]
  rows:
    - [ac_name_eq,  multiprocessing.active_children.__name__.__eq__,    ["active_children"],          true,  "active_children.__name__ == 'active_children' (len=15: 'active'=6+'_children'=9=15); verified with Python 3.14.3"]
    - [ac_name_len, multiprocessing.active_children.__name__.__len__,   [],                           15,    "active_children.__name__.__len__() == 15 (same as current_process=15; both 15-char names); verified with Python 3.14.3"]
    - [ac_mod_eq,   multiprocessing.active_children.__module__.__eq__,  ["multiprocessing.process"],  true,  "active_children.__module__ == 'multiprocessing.process' (len=23; same module as current_process); verified with Python 3.14.3"]
    - [ac_mod_len,  multiprocessing.active_children.__module__.__len__, [],                           23,    "active_children.__module__.__len__() == 23 (same as current_process module=23); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra166
# ---------------------------------------------------------------------------

invariant multiprocessing_extra166.mp_Value_qualname_eq:
  description: "multiprocessing.Value.__qualname__.__eq__('BaseContext.Value') returns True — KEY FINDING: multiprocessing.Value is a BOUND METHOD of the default context object (DefaultContext), not a standalone function or class; Value.__qualname__=='BaseContext.Value' (len=17: 'BaseContext'=11+'.'=1+'Value'=5=17); the __qualname__ format 'ClassName.method_name' is the standard Python qualname for an instance method; multiprocessing uses a context/factory pattern where the top-level functions like multiprocessing.Value, multiprocessing.Array, multiprocessing.Process, multiprocessing.Queue are all bound methods dispatched through the default context (DefaultContext); this allows the multiprocessing start method (fork, spawn, forkserver) to be changed at runtime — different contexts provide different implementations of these methods; compare: multiprocessing.Array.__qualname__=='BaseContext.Array' (len=17; same length as BaseContext.Value=17 because 'Array'=5=='Value'=5); Value.__name__=='Value' (len=5; __name__ is just the method name without the class prefix; __qualname__ includes the class prefix 'BaseContext.'=12); NEW in extra166: first standalone Value.__qualname__ identity invariant in mpvalid166 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Value.__qualname__.__eq__
  args: ["BaseContext.Value"]
  expected: true

invariant multiprocessing_extra166.mp_Array_qualname_eq:
  description: "multiprocessing.Array.__qualname__.__eq__('BaseContext.Array') returns True — multiprocessing.Array is also a BOUND METHOD of the default context; Array.__qualname__=='BaseContext.Array' (len=17: 'BaseContext'=11+'.'=1+'Array'=5=17; same qualname length as BaseContext.Value=17 because 'Array'=5=='Value'=5 in length); multiprocessing.Array(typecode_or_type, size_or_initializer, lock=True) creates a ctypes array in shared memory; the array is accessible from multiple processes; the typecode specifies the ctypes type (e.g., 'i' for c_int, 'c' for c_char); size_or_initializer is either an integer giving the number of elements or an iterable of initial values; when lock=True (default) the array is wrapped in a Lock for process-safe access; compare: multiprocessing.Value.__qualname__=='BaseContext.Value' (len=17; identical structure: BaseContext prefix + method name; BOTH are bound methods on the same BaseContext class, giving matching qualname patterns); NEW in extra166: first standalone Array.__qualname__ identity invariant in mparray166 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Array.__qualname__.__eq__
  args: ["BaseContext.Array"]
  expected: true

invariant multiprocessing_extra166.mp_Value_name_eq:
  description: "multiprocessing.Value.__name__.__eq__('Value') returns True — multiprocessing.Value.__name__=='Value' (len=5: 'V'+'a'+'l'+'u'+'e'=5); Value.__name__ gives only the method name without the class prefix; compare: Value.__qualname__=='BaseContext.Value' (len=17) gives the full qualified name including the class; __name__='Value' (5 chars) is 12 chars shorter than __qualname__='BaseContext.Value' (17 chars) — the 'BaseContext.'=12 prefix accounts for the entire difference; Value.__name__.__len__()==5 coincidentally equals asyncio.Queue.__name__.__len__()==5 (from extra168 — both 'Value' and 'Queue' are 5-char names); multiprocessing.Value() creates a shared ctypes value (like a shared integer or float); it is commonly used for counters, flags, and simple shared state between processes; compare: multiprocessing.Array.__name__=='Array' (len=5; same length as Value.__name__=5 — both are 5-char method names); NEW in extra166: first standalone Value.__name__ identity invariant in mpvalid166 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Value.__name__.__eq__
  args: ["Value"]
  expected: true

invariant multiprocessing_extra166.mp_current_process_name_eq:
  description: "multiprocessing.current_process.__name__.__eq__('current_process') returns True — multiprocessing.current_process.__name__=='current_process' (len=15: 'current'=7+'_'=1+'process'=7=15); multiprocessing.current_process() returns the Process object for the currently executing process; it mirrors threading.current_thread() semantics; the returned Process object includes: .name (process name string), .pid (OS process ID), .exitcode (None if alive, exit code if terminated), .daemon (True/False), .is_alive() (True if the process is running); for the main process, current_process() returns the MainProcess object; for worker processes spawned by Process(), it returns the worker Process object; current_process.__module__=='multiprocessing.process' (len=23: 'multiprocessing'=15+'.'=1+'process'=7=23); compare: multiprocessing.active_children.__name__=='active_children' (len=15; same length as current_process=15 — a coincidence: 'current_process'=15 and 'active_children'=15 both have 15 chars); NEW in extra166: first standalone current_process.__name__ identity invariant in mpcurproc166 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.current_process.__name__.__eq__
  args: ["current_process"]
  expected: true

invariant multiprocessing_extra166.mp_current_process_module_eq:
  description: "multiprocessing.current_process.__module__.__eq__('multiprocessing.process') returns True — multiprocessing.current_process.__module__=='multiprocessing.process' (len=23: 'multiprocessing'=15+'.'=1+'process'=7=23); current_process is defined in Lib/multiprocessing/process.py — the same module that defines the Process class; the 'multiprocessing.process' submodule (len=23) has a distinctive property: the submodule name 'process'=7 is the same word as the last component of 'current_process'=15 and 'active_children' references child processes; compare module path lengths: 'multiprocessing.pool'=20 (4 shorter; 'pool'=4 < 'process'=7 by 3), 'multiprocessing.process'=23 (this module), 'multiprocessing.managers'=24 (1 longer; 'managers'=8 > 'process'=7 by 1); the ordering: pool(20) < process(23) < managers(24); current_process.__module__ == active_children.__module__ == 'multiprocessing.process' — both functions are co-located in process.py; NEW in extra166: first standalone current_process.__module__ identity invariant in mpcurproc166 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.current_process.__module__.__eq__
  args: ["multiprocessing.process"]
  expected: true

invariant multiprocessing_extra166.mp_active_children_name_eq:
  description: "multiprocessing.active_children.__name__.__eq__('active_children') returns True — multiprocessing.active_children.__name__=='active_children' (len=15: 'active'=6+'_'=1+'children'=8=15); multiprocessing.active_children() returns a list of all active (non-terminated) child Process objects created by the current process; it first joins any already-terminated processes (cleaning up zombie processes) and then returns the list of still-running ones; active_children() is thread-safe and process-safe; common use: len(multiprocessing.active_children()) to check how many workers are still running before spawning more; active_children.__name__.__len__()==15 == current_process.__name__.__len__()==15 (KEY COINCIDENCE: both function names have exactly 15 chars; 'active_children'=15: 'active'=6+'_children'=9 vs 'current_process'=15: 'current'=7+'_process'=8 — different prefixes and suffixes but same total length); NEW in extra166: first standalone active_children.__name__ identity invariant in mpactchild166 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.active_children.__name__.__eq__
  args: ["active_children"]
  expected: true

invariant multiprocessing_extra166.mp_active_children_module_eq:
  description: "multiprocessing.active_children.__module__.__eq__('multiprocessing.process') returns True — multiprocessing.active_children.__module__=='multiprocessing.process' (len=23: same module as current_process; both defined in Lib/multiprocessing/process.py); active_children and current_process are co-located in the same module because both deal with process lifecycle and state; active_children() joins terminated children before returning — it calls _cleanup() internally which removes dead children from the global _children set; active_children.__module__ == current_process.__module__ == 'multiprocessing.process' — module equality; compare: multiprocessing.managers.BaseManager.__module__=='multiprocessing.managers' (len=24; from extra165; 1 longer than multiprocessing.process=23 because 'managers'=8 > 'process'=7 by 1); module length ordering: pool(20) < process(23) < managers(24); NEW in extra166: first standalone active_children.__module__ identity invariant in mpactchild166 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.active_children.__module__.__eq__
  args: ["multiprocessing.process"]
  expected: true

