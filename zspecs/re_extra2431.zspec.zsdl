  rows:
    - ["re2431001", "re.Pattern.__dict__.__contains__", ["__aiter__"], false]
    - ["re2431002", "re.Match.__dict__.__contains__", ["__aiter__"], false]
    - ["re2431003", "re.error.__dict__.__contains__", ["__aiter__"], false]
    - ["re2431004", "re.RegexFlag.__dict__.__contains__", ["__aiter__"], false]
    - ["re2431005", "re.Scanner.__dict__.__contains__", ["__aiter__"], false]

