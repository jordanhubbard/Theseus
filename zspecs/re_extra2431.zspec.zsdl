spec: re_extra2431
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/re.html"
    - "CPython source — Modules/_sre.c, Lib/re/__init__.py"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2431: __aiter__ and __anext__ async iteration protocol dict-presence for re types."
    - "re.Pattern and re.Match are C-extension types; neither defines __aiter__ or __anext__ in its class __dict__."
    - "re.error (whose __name__ is 'PatternError' in Python 3.14) is an exception subclass; it does not define async iteration."
    - "re.RegexFlag is an enum.Flag subclass; it does not define __aiter__ or __anext__ in its own __dict__."
    - "re.Scanner is a pure-Python class; it does not define __aiter__ or __anext__."
    - "The re module provides pattern matching only; no type in the module participates in the async iteration protocol."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ===
# Table 1: __aiter__ in class __dict__ — core re types
# ===

table re_extra2431.aiter_in_dict:
  description: "__aiter__ dict-presence for re module types — Pattern, Match, error, RegexFlag, Scanner"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2431
