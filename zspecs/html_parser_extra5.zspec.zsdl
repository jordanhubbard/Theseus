spec: html_parser_extra5
version: ">=3.9"
backend: python_module(html.parser)

docs: https://docs.python.org/3/library/html.parser.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/html.parser.html — Python html.parser module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/html/parser.py"
    - "html_parser.zspec.zsdl — covers HTMLParser.__name__, __module__, convert_charrefs default, getpos(), method __name__ (feed/reset/close/getpos/handle_starttag/handle_endtag/handle_data/handle_comment/handle_charref/handle_entityref), reset/close return None"
    - "html_extra5.zspec.zsdl — covers HTMLParser.__qualname__, method __qualname__ for 8 core methods, HTMLParser.__class__.__name__, HTMLParser.__bases__[0].__name__ (NOTE: html_extra5 incorrectly records 'object'; the correct value is 'ParserBase')"
    - "html_parser_extra2.zspec.zsdl — covers handle_decl/handle_pi/unknown_decl __name__/__qualname__; CDATA_CONTENT_ELEMENTS type/membership; convert_charrefs=False"
    - "html_parser_extra3.zspec.zsdl — covers method __module__ for all HTMLParser methods"
    - "html_parser_extra4.zspec.zsdl — covers HTMLParser.__qualname__/__module__/__mro__/__bases__, ParserBase identity, feed/handle_starttag __name__, __dict__ membership for feed/handle_starttag"
  notes:
    - "This spec covers axes not yet in any prior html.parser spec."
    - "html.parser.__all__.__len__() == 1 — only 'HTMLParser' is exported; no prior spec checks __all__.__len__()."
    - "html.parser.__all__.__class__.__name__ == 'list' (len 4) — no prior spec checks __all__.__class__.__name__.__len__()."
    - "html.parser.HTMLParser.__dict__.__class__.__name__ == 'mappingproxy' (len 12) — no prior spec checks __dict__.__class__.__name__.__len__() on HTMLParser."
    - "HTMLParser method __qualname__.__len__() — html_extra5 records __qualname__.__eq__ for 8 core methods; no prior spec checks __qualname__.__len__() for any HTMLParser method."
    - "HTMLParser.feed.__qualname__ == 'HTMLParser.feed' (len 15)."
    - "HTMLParser.close.__qualname__ == 'HTMLParser.close' (len 16)."
    - "HTMLParser.reset.__qualname__ == 'HTMLParser.reset' (len 16)."
    - "HTMLParser.handle_starttag.__qualname__ == 'HTMLParser.handle_starttag' (len 26)."
    - "HTMLParser.handle_endtag.__qualname__ == 'HTMLParser.handle_endtag' (len 24)."
    - "HTMLParser.handle_data.__qualname__ == 'HTMLParser.handle_data' (len 22)."
    - "HTMLParser.handle_comment.__qualname__ == 'HTMLParser.handle_comment' (len 25)."
    - "HTMLParser.handle_charref.__qualname__ == 'HTMLParser.handle_charref' (len 25)."
    - "HTMLParser.handle_entityref.__qualname__ == 'HTMLParser.handle_entityref' (len 27)."
    - "HTMLParser.handle_decl.__qualname__ == 'HTMLParser.handle_decl' (len 22)."
    - "HTMLParser.handle_pi.__qualname__ == 'HTMLParser.handle_pi' (len 20)."
    - "HTMLParser.unknown_decl.__qualname__ == 'HTMLParser.unknown_decl' (len 23)."
    - "html.escape.__qualname__.__len__() == 6 (len('escape') == 6) — no prior spec checks html.escape.__qualname__.__len__()."
    - "html.unescape.__qualname__.__len__() == 8 (len('unescape') == 8) — no prior spec checks html.unescape.__qualname__.__len__()."
    - "html.__name__.__len__() == 4 (len('html') == 4) — no prior html.parser spec checks html.__name__.__len__()."
    - "html.parser.__name__.__len__() == 11 (len('html.parser') == 11) — no prior spec checks this."
    - "getpos is inherited from ParserBase — 'getpos' is NOT in HTMLParser.__dict__; HTMLParser.getpos.__qualname__ == 'ParserBase.getpos' (len 17)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# html.parser.__all__ length and class
#
# Only 'HTMLParser' is in html.parser.__all__ (__len__() == 1).
# No prior html.parser spec checks __all__.__len__() or __all__.__class__.__name__.
# ---------------------------------------------------------------------------

invariant html_parser_extra5.all_len:
  description: "html.parser.__all__.__len__() == 1 — only 'HTMLParser' is exported; no prior spec checks __all__.__len__()"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 1

invariant html_parser_extra5.all_class_name_len:
  description: "html.parser.__all__.__class__.__name__.__len__() == 4 — __all__ is a 'list' (len 4); no prior spec checks __all__.__class__.__name__.__len__()"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# HTMLParser.__dict__.__class__.__name__.__len__()
#
# HTMLParser's class __dict__ is a mappingproxy ('mappingproxy', len 12).
# No prior html.parser spec checks __dict__.__class__.__name__.__len__()
# on HTMLParser.
# ---------------------------------------------------------------------------

invariant html_parser_extra5.HTMLParser.dict_class_name_len:
  description: "html.parser.HTMLParser.__dict__.__class__.__name__.__len__() == 12 — class __dict__ is a 'mappingproxy' (len 12); no prior spec checks this"
  category: class_dict
  kind: python_call_eq
  function: HTMLParser.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# HTMLParser method __qualname__.__len__()
#
# html_extra5 records __qualname__.__eq__ for 8 core HTMLParser methods.
# No prior html.parser spec checks __qualname__.__len__() for any HTMLParser method.
# This table covers 12 methods. Note: getpos is inherited from ParserBase;
# its __qualname__ is 'ParserBase.getpos' (len 17), not 'HTMLParser.getpos'.
# ---------------------------------------------------------------------------

table html_parser_extra5.method_qualname_lens:
  description: "HTMLParser method __qualname__.__len__() — no prior spec checks __qualname__.__len__() for any HTMLParser method"
  kind: python_call_eq
  category: method_identity
  id_prefix: hpqlen5

  columns: [id, function, args, expected, description]
  rows:
    - [feed,             HTMLParser.feed.__qualname__.__len__,             [], 15, "len('HTMLParser.feed') == 15"]
    - [close,            HTMLParser.close.__qualname__.__len__,            [], 16, "len('HTMLParser.close') == 16"]
    - [reset,            HTMLParser.reset.__qualname__.__len__,            [], 16, "len('HTMLParser.reset') == 16"]
    - [handle_starttag,  HTMLParser.handle_starttag.__qualname__.__len__,  [], 26, "len('HTMLParser.handle_starttag') == 26"]
    - [handle_endtag,    HTMLParser.handle_endtag.__qualname__.__len__,    [], 24, "len('HTMLParser.handle_endtag') == 24"]
    - [handle_data,      HTMLParser.handle_data.__qualname__.__len__,      [], 22, "len('HTMLParser.handle_data') == 22"]
    - [handle_comment,   HTMLParser.handle_comment.__qualname__.__len__,   [], 25, "len('HTMLParser.handle_comment') == 25"]
    - [handle_charref,   HTMLParser.handle_charref.__qualname__.__len__,   [], 25, "len('HTMLParser.handle_charref') == 25"]
    - [handle_entityref, HTMLParser.handle_entityref.__qualname__.__len__, [], 27, "len('HTMLParser.handle_entityref') == 27"]
    - [handle_decl,      HTMLParser.handle_decl.__qualname__.__len__,      [], 22, "len('HTMLParser.handle_decl') == 22"]
    - [handle_pi,        HTMLParser.handle_pi.__qualname__.__len__,        [], 20, "len('HTMLParser.handle_pi') == 20"]
    - [unknown_decl,     HTMLParser.unknown_decl.__qualname__.__len__,     [], 23, "len('HTMLParser.unknown_decl') == 23"]

# ---------------------------------------------------------------------------
# getpos is inherited from ParserBase — qualname is 'ParserBase.getpos' (len 17)
#
# 'getpos' is NOT in HTMLParser.__dict__; it is defined on the ParserBase
# base class from _markupbase. HTMLParser.getpos.__qualname__ therefore
# equals 'ParserBase.getpos' (len 17), not 'HTMLParser.getpos' (len 18).
# No prior html.parser spec checks HTMLParser.getpos.__qualname__.__len__().
# ---------------------------------------------------------------------------

invariant html_parser_extra5.getpos.qualname_len:
  description: "HTMLParser.getpos.__qualname__.__len__() == 17 — getpos is inherited; qualname is 'ParserBase.getpos' (len 17), not 'HTMLParser.getpos'"
  category: method_identity
  kind: python_call_eq
  function: HTMLParser.getpos.__qualname__.__len__
  args: []
  expected: 17

invariant html_parser_extra5.HTMLParser.dict_lacks_getpos:
  description: "'getpos' not in html.parser.HTMLParser.__dict__ — getpos is inherited from ParserBase; no prior spec checks this absence"
  category: class_dict
  kind: python_call_eq
  function: HTMLParser.__dict__.__contains__
  args: ["getpos"]
  expected: false

# ---------------------------------------------------------------------------
# html.parser module __name__ and __package__ string lengths
#
# html.parser.__name__ == 'html.parser' (len 11). No prior spec checks
# __name__.__len__() on the html.parser module itself.
# html.parser.__package__ == 'html' (len 4) — the parent package name.
# No prior spec checks __package__.__len__() on html.parser.
# ---------------------------------------------------------------------------

invariant html_parser_extra5.module.name_len:
  description: "html.parser.__name__.__len__() == 11 — len('html.parser') == 11; no prior spec checks html.parser.__name__.__len__()"
  category: module_metadata
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 11

invariant html_parser_extra5.module.package_len:
  description: "html.parser.__package__.__len__() == 4 — __package__ == 'html' (len 4); no prior spec checks html.parser.__package__.__len__()"
  category: module_metadata
  kind: python_call_eq
  function: __package__.__len__
  args: []
  expected: 4
