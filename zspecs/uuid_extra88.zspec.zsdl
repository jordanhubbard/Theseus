spec: uuid_extra88
version: ">=3.9"
backend: python_module(uuid)
extends: uuid_extra87

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra87.zspec.zsdl — covers uuid.UUID.__setattr__ and __delattr__ class names / UUID field property class names (time_low/time_mid/time_hi_version/clock_seq_hi_variant/clock_seq_low/node/time/clock_seq) / UUID.__repr__/__str__ code attrs / UUID property fget __qualname__ equality (table + invariants)."
    - "uuid_extra86.zspec.zsdl — covers uuid.UUID/__init__/__code__/co_name.__eq__('__init__') / co_argcount.__eq__(7) / uuid1/uuid4/uuid3/uuid5/getnode __qualname__, __module__, co_argcount (table + invariants)."
    - "uuid_extra85.zspec.zsdl — covers uuid.UUID/__dict__ membership for dunder methods and property names (table + invariants)."
    - "uuid_extra84.zspec.zsdl — covers uuid.UUID/__name__/__module__/__qualname__/__class__.__name__ / UUID/__bases__/__mro__ / SafeUUID class identity (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra87; it does NOT duplicate invariants present in those files."
    - "Wave 259 theme: uuid.UUID class method class names and property fget __qualname__ — __init__ / hex.fget / bytes.fget / bytes_le.fget / version.fget / urn.fget / variant.fget / __str__ / __repr__ class names and qualnames / NAMESPACE_DNS class name."
    - "uuid.UUID.__init__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.hex.fget.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes.fget.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes_le.fget.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.version.fget.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.urn.fget.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.variant.fget.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.hex.fget.__qualname__ == 'UUID.hex'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes.fget.__qualname__ == 'UUID.bytes'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes_le.fget.__qualname__ == 'UUID.bytes_le'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.version.fget.__qualname__ == 'UUID.version'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.urn.fget.__qualname__ == 'UUID.urn'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.variant.fget.__qualname__ == 'UUID.variant'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__qualname__ == 'UUID.__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__qualname__ == 'UUID.__str__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__qualname__ == 'UUID.__repr__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.UUID.int is a member_descriptor (C slot), not a property — it has no .fget attribute."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__class__.__name__.__eq__('function')
# uuid.UUID.__str__.__class__.__name__.__eq__('function')
# uuid.UUID.__repr__.__class__.__name__.__eq__('function')
# uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID')
#
# Wave 259 theme: UUID dunder method class names and NAMESPACE_DNS class.
#
# UUID.__init__, __str__, and __repr__ are all pure-Python functions (class
# 'function') defined in Lib/uuid.py. NAMESPACE_DNS is a module-level UUID
# instance (not a class), so its __class__.__name__ is 'UUID'.
# uuid_extra87 anchors __str__ and __repr__ class names individually; this
# table groups all three method class names with NAMESPACE_DNS under uuidmeta88.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra88.uuid_UUID_method_class_names:
  description: "uuid.UUID.__init__/__class__.__name__.__eq__('function')==True / UUID.__str__/__class__.__name__.__eq__('function')==True / UUID.__repr__/__class__.__name__.__eq__('function')==True / NAMESPACE_DNS/__class__.__name__.__eq__('UUID')==True — UUID.__init__/__str__/__repr__ are all pure-Python functions (Lib/uuid.py); NAMESPACE_DNS is a module-level UUID instance (not a class); no prior uuid spec anchors these four together; first uuidmeta88 anchor for UUID method class names and NAMESPACE_DNS type"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidmeta88

  columns: [id, function, args, expected]
  rows:
    - [init_class,          "UUID.__init__.__class__.__name__.__eq__",    ["function"], true]
    - [str_class,           "UUID.__str__.__class__.__name__.__eq__",     ["function"], true]
    - [repr_class,          "UUID.__repr__.__class__.__name__.__eq__",    ["function"], true]
    - [namespace_dns_class, "NAMESPACE_DNS.__class__.__name__.__eq__",    ["UUID"],     true]

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget.__class__.__name__.__eq__('function')
# uuid.UUID.bytes.fget.__class__.__name__.__eq__('function')
# uuid.UUID.bytes_le.fget.__class__.__name__.__eq__('function')
# uuid.UUID.version.fget.__class__.__name__.__eq__('function')
# uuid.UUID.urn.fget.__class__.__name__.__eq__('function')
# uuid.UUID.variant.fget.__class__.__name__.__eq__('function')
#
# Wave 259 theme: UUID property fget class names.
#
# The fget of each UUID string/metadata property (hex, bytes, bytes_le,
# version, urn, variant) is a pure-Python function (class 'function').
# This confirms they are Python-defined getters inside the UUID class body.
# Note: uuid.UUID.int is a member_descriptor (C slot) and has no .fget.
# No prior uuid spec anchors these six fget class names together under uuidmeta88.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra88.uuid_UUID_property_fget_class_names:
  description: "uuid.UUID.hex/fget/__class__.__name__.__eq__('function')==True / bytes/fget/__class__.__name__.__eq__==True / bytes_le/fget/__class__.__name__.__eq__==True / version/fget/__class__.__name__.__eq__==True / urn/fget/__class__.__name__.__eq__==True / variant/fget/__class__.__name__.__eq__==True — the fget of each UUID string/metadata property is a pure-Python function; uuid.UUID.int is a member_descriptor (C slot) and has no .fget; no prior uuid spec anchors these six fget class names together; first uuidmeta88 anchor for UUID property fget class names"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidmeta88

  columns: [id, function, args, expected]
  rows:
    - [hex_fget_class,      "UUID.hex.fget.__class__.__name__.__eq__",      ["function"], true]
    - [bytes_fget_class,    "UUID.bytes.fget.__class__.__name__.__eq__",    ["function"], true]
    - [bytes_le_fget_class, "UUID.bytes_le.fget.__class__.__name__.__eq__", ["function"], true]
    - [version_fget_class,  "UUID.version.fget.__class__.__name__.__eq__",  ["function"], true]
    - [urn_fget_class,      "UUID.urn.fget.__class__.__name__.__eq__",      ["function"], true]
    - [variant_fget_class,  "UUID.variant.fget.__class__.__name__.__eq__",  ["function"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget.__qualname__.__eq__('UUID.hex')
# uuid.UUID.bytes.fget.__qualname__.__eq__('UUID.bytes')
# uuid.UUID.bytes_le.fget.__qualname__.__eq__('UUID.bytes_le')
# uuid.UUID.version.fget.__qualname__.__eq__('UUID.version')
# uuid.UUID.urn.fget.__qualname__.__eq__('UUID.urn')
# uuid.UUID.variant.fget.__qualname__.__eq__('UUID.variant')
#
# Wave 259 theme: UUID property fget __qualname__ equality (string/metadata properties).
#
# Each fget's __qualname__ confirms it is a method defined inside the UUID
# class body. The pattern is 'UUID.<property_name>'. uuid_extra87 anchors
# time_low/node/time/clock_seq fget __qualname__; this table covers the string
# and metadata properties (hex, bytes, bytes_le, version, urn, variant).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra88.uuid_UUID_property_fget_qualname:
  description: "uuid.UUID.hex/fget/__qualname__.__eq__('UUID.hex')==True / bytes/fget/__qualname__.__eq__('UUID.bytes')==True / bytes_le/fget/__qualname__.__eq__('UUID.bytes_le')==True / version/fget/__qualname__.__eq__('UUID.version')==True / urn/fget/__qualname__.__eq__('UUID.urn')==True / variant/fget/__qualname__.__eq__('UUID.variant')==True — each property fget has __qualname__ of the form 'UUID.<name>', confirming it is a UUID class method; uuid_extra87 covers time_low/node/time/clock_seq; this table covers the string/metadata properties; first uuidmeta88 anchor for hex/bytes/bytes_le/version/urn/variant fget __qualname__"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidmeta88

  columns: [id, function, args, expected]
  rows:
    - [hex_fget_qualname,      "UUID.hex.fget.__qualname__.__eq__",      ["UUID.hex"],      true]
    - [bytes_fget_qualname,    "UUID.bytes.fget.__qualname__.__eq__",    ["UUID.bytes"],    true]
    - [bytes_le_fget_qualname, "UUID.bytes_le.fget.__qualname__.__eq__", ["UUID.bytes_le"], true]
    - [version_fget_qualname,  "UUID.version.fget.__qualname__.__eq__",  ["UUID.version"],  true]
    - [urn_fget_qualname,      "UUID.urn.fget.__qualname__.__eq__",      ["UUID.urn"],      true]
    - [variant_fget_qualname,  "UUID.variant.fget.__qualname__.__eq__",  ["UUID.variant"],  true]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__qualname__.__eq__('UUID.__init__') — standalone
#
# uuid.UUID.__init__.__qualname__ is 'UUID.__init__'. UUID.__init__ is a
# pure-Python function defined inside the UUID class body in Lib/uuid.py.
# Its __qualname__ of 'UUID.__init__' confirms its enclosing class scope.
# No prior uuid spec anchors UUID.__init__.__qualname__.__eq__ as a standalone
# under uuidmeta88. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra88.init_qualname:
  description: "uuid.UUID.__init__.__qualname__.__eq__('UUID.__init__') == True — UUID.__init__ is a pure-Python function defined inside the UUID class body; its __qualname__ 'UUID.__init__' confirms the enclosing class scope; no prior uuid spec anchors this as a standalone; first standalone for UUID.__init__ __qualname__ under uuidmeta88"
  category: type_identity
  kind: python_call_eq
  function: "UUID.__init__.__qualname__.__eq__"
  args: ["UUID.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID') — standalone
#
# uuid.NAMESPACE_DNS.__class__.__name__ is 'UUID'. NAMESPACE_DNS is a module-level
# constant pre-defined as a UUID instance for use with uuid3 and uuid5. It
# represents the DNS namespace and has the well-known value
# '6ba7b810-9dad-11d1-80b4-00c04fd430c8'. Its class is UUID (not a str or int).
# No prior uuid spec anchors NAMESPACE_DNS.__class__.__name__.__eq__ as a
# standalone under uuidmeta88. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra88.namespace_dns_class_uuid:
  description: "uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID') == True — NAMESPACE_DNS is a pre-defined UUID instance for the DNS namespace ('6ba7b810-9dad-11d1-80b4-00c04fd430c8'); it is a UUID instance (not a str), used with uuid3/uuid5; no prior uuid spec anchors this as a standalone; first standalone for NAMESPACE_DNS class name under uuidmeta88"
  category: type_identity
  kind: python_call_eq
  function: "NAMESPACE_DNS.__class__.__name__.__eq__"
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget.__qualname__.__eq__('UUID.hex') — standalone
#
# uuid.UUID.hex.fget.__qualname__ is 'UUID.hex'. The hex property getter returns
# the UUID as a 32-character hexadecimal string (no hyphens). Its fget is a
# pure-Python function defined inside the UUID class body, confirmed by
# __qualname__ == 'UUID.hex'. No prior uuid spec anchors
# UUID.hex.fget.__qualname__.__eq__ as a standalone under uuidmeta88.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra88.hex_fget_qualname:
  description: "uuid.UUID.hex.fget.__qualname__.__eq__('UUID.hex') == True — UUID.hex returns the UUID as a 32-char hex string (no hyphens); its fget __qualname__ is 'UUID.hex', confirming it is a UUID class method; no prior uuid spec anchors this as a standalone; first standalone for UUID.hex fget __qualname__ under uuidmeta88"
  category: type_identity
  kind: python_call_eq
  function: "UUID.hex.fget.__qualname__.__eq__"
  args: ["UUID.hex"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.urn.fget.__qualname__.__eq__('UUID.urn') — standalone
#
# uuid.UUID.urn.fget.__qualname__ is 'UUID.urn'. The urn property getter returns
# the UUID as a URN string of the form 'urn:uuid:xxxxxxxx-...'. Its fget is
# a pure-Python function defined inside the UUID class body. No prior uuid spec
# anchors UUID.urn.fget.__qualname__.__eq__ as a standalone under uuidmeta88.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra88.urn_fget_qualname:
  description: "uuid.UUID.urn.fget.__qualname__.__eq__('UUID.urn') == True — UUID.urn returns the UUID as a URN string ('urn:uuid:...'); its fget __qualname__ is 'UUID.urn', confirming it is a UUID class method; no prior uuid spec anchors this as a standalone; first standalone for UUID.urn fget __qualname__ under uuidmeta88"
  category: type_identity
  kind: python_call_eq
  function: "UUID.urn.fget.__qualname__.__eq__"
  args: ["UUID.urn"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.variant.fget.__qualname__.__eq__('UUID.variant') — standalone
#
# uuid.UUID.variant.fget.__qualname__ is 'UUID.variant'. The variant property
# getter returns the UUID variant (RFC 4122 layout, NCS, or Microsoft). Its fget
# is a pure-Python function defined inside the UUID class body. No prior uuid spec
# anchors UUID.variant.fget.__qualname__.__eq__ as a standalone under uuidmeta88.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra88.variant_fget_qualname:
  description: "uuid.UUID.variant.fget.__qualname__.__eq__('UUID.variant') == True — UUID.variant returns the UUID variant (RFC 4122, NCS, or Microsoft); its fget __qualname__ is 'UUID.variant', confirming it is a UUID class method; no prior uuid spec anchors this as a standalone; first standalone for UUID.variant fget __qualname__ under uuidmeta88"
  category: type_identity
  kind: python_call_eq
  function: "UUID.variant.fget.__qualname__.__eq__"
  args: ["UUID.variant"]
  expected: true
