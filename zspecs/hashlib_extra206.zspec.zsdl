    - "hashlib.__dict__.__contains__('md5') == True — 'md5' is a top-level name exported from the hashlib module __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.__dict__.__contains__('sha1') == True — 'sha1' is a top-level name exported from the hashlib module __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.__dict__.__contains__('sha256') == True — 'sha256' is a top-level name exported from the hashlib module __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.__dict__.__contains__('sha512') == True — 'sha512' is a top-level name exported from the hashlib module __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.__dict__.__contains__('sha3_256') == True — 'sha3_256' is a top-level name exported from the hashlib module __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.__dict__.__contains__('blake2b') == True — 'blake2b' is a top-level name exported from the hashlib module __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.__dict__.__contains__('blake2s') == True — 'blake2s' is a top-level name exported from the hashlib module __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.__dict__.__contains__('new') == True — 'new' is a top-level name exported from the hashlib module __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.__dict__.__contains__('algorithms_available') == True — 'algorithms_available' is a top-level name exported from the hashlib module __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.__dict__.__contains__('algorithms_guaranteed') == True — 'algorithms_guaranteed' is a top-level name exported from the hashlib module __dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' — algorithms_guaranteed is a frozenset-backed set of algorithm name strings. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.algorithms_available.__class__.__name__ == 'set' — algorithms_available is a set of algorithm name strings available on the current platform. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib module __dict__.__contains__ for core hash constructors
# ---------------------------------------------------------------------------

table hashlib_extra206.module_dict_core_hashes:
  description: "hashlib.__dict__.__contains__ checks for md5, sha1, sha256, sha512 — core hash constructors exported at the top-level hashlib module namespace"
  kind: python_call_eq
  category: module_dict
  id_prefix: hashlibdict206

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_md5,    __dict__.__contains__, ["md5"],    true, "hashlib.__dict__.__contains__('md5') — md5 constructor is in hashlib module namespace"]
    - [dict_has_sha1,   __dict__.__contains__, ["sha1"],   true, "hashlib.__dict__.__contains__('sha1') — sha1 constructor is in hashlib module namespace"]
    - [dict_has_sha256, __dict__.__contains__, ["sha256"], true, "hashlib.__dict__.__contains__('sha256') — sha256 constructor is in hashlib module namespace"]
    - [dict_has_sha512, __dict__.__contains__, ["sha512"], true, "hashlib.__dict__.__contains__('sha512') — sha512 constructor is in hashlib module namespace"]

# ---------------------------------------------------------------------------
# hashlib module __dict__.__contains__ for SHA-3 and BLAKE2 constructors
# ---------------------------------------------------------------------------

table hashlib_extra206.module_dict_sha3_blake2:
  description: "hashlib.__dict__.__contains__ checks for sha3_256, blake2b, blake2s, new — SHA-3 and BLAKE2 constructors plus the generic 'new' factory function"
  kind: python_call_eq
  category: module_dict
  id_prefix: hashlibdict206

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_sha3_256, __dict__.__contains__, ["sha3_256"], true, "hashlib.__dict__.__contains__('sha3_256') — sha3_256 constructor is in hashlib module namespace"]
    - [dict_has_blake2b,  __dict__.__contains__, ["blake2b"],  true, "hashlib.__dict__.__contains__('blake2b') — blake2b constructor is in hashlib module namespace"]
    - [dict_has_blake2s,  __dict__.__contains__, ["blake2s"],  true, "hashlib.__dict__.__contains__('blake2s') — blake2s constructor is in hashlib module namespace"]
    - [dict_has_new,      __dict__.__contains__, ["new"],      true, "hashlib.__dict__.__contains__('new') — generic new() factory is in hashlib module namespace"]

# ---------------------------------------------------------------------------
# hashlib module __dict__.__contains__ for algorithm set names and class type
# ---------------------------------------------------------------------------

table hashlib_extra206.module_dict_algorithms_and_class:
  description: "hashlib.__dict__.__contains__ for algorithms_available and algorithms_guaranteed set names; plus class name checks confirming both are 'set' instances"
  kind: python_call_eq
  category: module_dict
  id_prefix: hashlibdict206

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_algorithms_available,    __dict__.__contains__,                            ["algorithms_available"],    true, "hashlib.__dict__.__contains__('algorithms_available') — the algorithms_available set is in hashlib module namespace"]
    - [dict_has_algorithms_guaranteed,   __dict__.__contains__,                            ["algorithms_guaranteed"],   true, "hashlib.__dict__.__contains__('algorithms_guaranteed') — the algorithms_guaranteed set is in hashlib module namespace"]
    - [alg_guaranteed_class_name,        algorithms_guaranteed.__class__.__name__.__eq__,  ["set"],                     true, "hashlib.algorithms_guaranteed.__class__.__name__ == 'set'"]
    - [alg_available_class_name,         algorithms_available.__class__.__name__.__eq__,   ["set"],                     true, "hashlib.algorithms_available.__class__.__name__ == 'set'"]

