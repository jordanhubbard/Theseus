spec: case
version: ">=1.6.0"
backend: node(case)

docs: https://github.com/nbubna/Case#readme

provenance:
  derived_from:
    - "Case README — https://github.com/nbubna/Case#readme"
    - "Test vectors verified with case via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "Case source"
  notes:
    - "Convert strings between case styles — camel/snake/kebab/pascal/upper/title/constant/sentence/header/lower/capital."
    - "Install: npm install case"
    - "v1 CJS; module export is an object with case-conversion functions; .of detects current case."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure functions; never throw on string input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant case.camel_simple:
  description: "camel('hello world') → 'helloWorld'"
  category: convert
  kind: node_chain_eq
  entry: named
  function: camel
  entry_args: ["hello world"]
  chain: []
  expected: "helloWorld"

invariant case.snake_from_camel:
  description: "snake('helloWorld') → 'hello_world'"
  category: convert
  kind: node_chain_eq
  entry: named
  function: snake
  entry_args: ["helloWorld"]
  chain: []
  expected: "hello_world"

invariant case.kebab_from_camel:
  description: "kebab('helloWorld') → 'hello-world'"
  category: convert
  kind: node_chain_eq
  entry: named
  function: kebab
  entry_args: ["helloWorld"]
  chain: []
  expected: "hello-world"

invariant case.pascal_simple:
  description: "pascal('hello world') → 'HelloWorld'"
  category: convert
  kind: node_chain_eq
  entry: named
  function: pascal
  entry_args: ["hello world"]
  chain: []
  expected: "HelloWorld"

invariant case.upper_simple:
  description: "upper('hello world') → 'HELLO WORLD'"
  category: convert
  kind: node_chain_eq
  entry: named
  function: upper
  entry_args: ["hello world"]
  chain: []
  expected: "HELLO WORLD"

invariant case.constant_from_camel:
  description: "constant('helloWorld') → 'HELLO_WORLD'"
  category: convert
  kind: node_chain_eq
  entry: named
  function: constant
  entry_args: ["helloWorld"]
  chain: []
  expected: "HELLO_WORLD"

invariant case.sentence_simple:
  description: "sentence('hello world') → 'Hello world'"
  category: convert
  kind: node_chain_eq
  entry: named
  function: sentence
  entry_args: ["hello world"]
  chain: []
  expected: "Hello world"

invariant case.of_detects_camel:
  description: "of('helloWorld') → 'camel'"
  category: detect
  kind: node_chain_eq
  entry: named
  function: of
  entry_args: ["helloWorld"]
  chain: []
  expected: "camel"

invariant case.of_detects_snake:
  description: "of('hello_world') → 'snake'"
  category: detect
  kind: node_chain_eq
  entry: named
  function: of
  entry_args: ["hello_world"]
  chain: []
  expected: "snake"

invariant case.of_detects_kebab:
  description: "of('hello-world') → 'kebab'"
  category: detect
  kind: node_chain_eq
  entry: named
  function: of
  entry_args: ["hello-world"]
  chain: []
  expected: "kebab"

invariant case.of_detects_pascal:
  description: "of('HelloWorld') → 'pascal'"
  category: detect
  kind: node_chain_eq
  entry: named
  function: of
  entry_args: ["HelloWorld"]
  chain: []
  expected: "pascal"
