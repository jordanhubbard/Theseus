spec: hashlib_extra270
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Lib/hashlib.py"
    - "hashlib_extra269.zspec.zsdl — covers HASH class method __name__/__class__/__qualname__ identity; sha3/shake __module__; hashlib.new/__hash_new and file_digest identity."
    - "hashlib_extra268.zspec.zsdl — covers sha3_256/sha3_512/shake_128/shake_256 constructor __name__ and __class__.__name__; scrypt/pbkdf2_hmac kdf identity; algorithms_available/algorithms_guaranteed class names."
    - "hashlib_extra267.zspec.zsdl — covers sha256/sha512/md5/sha1 constructor __name__ and __class__.__name__; hexdigest length; known test vectors."
  notes:
    - "hashlib.algorithms_guaranteed is a frozenset of algorithm name strings that are guaranteed available on all Python platforms. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "'sha256' in hashlib.algorithms_guaranteed == True — sha256 is guaranteed on all platforms. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "'md5' in hashlib.algorithms_guaranteed == True — md5 is guaranteed on all platforms. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "'sha1' in hashlib.algorithms_guaranteed == True — sha1 is guaranteed on all platforms. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "'sha512' in hashlib.algorithms_guaranteed == True — sha512 is guaranteed on all platforms. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "'sha224' in hashlib.algorithms_guaranteed == True — sha224 is guaranteed on all platforms. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "'sha384' in hashlib.algorithms_guaranteed == True — sha384 is guaranteed on all platforms. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "'sha3_256' in hashlib.algorithms_guaranteed == True — sha3_256 is guaranteed (Python 3.6+). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "'blake2b' in hashlib.algorithms_guaranteed == True — blake2b is guaranteed on all platforms. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "'blake2s' in hashlib.algorithms_guaranteed == True — blake2s is guaranteed on all platforms. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "'notexist' in hashlib.algorithms_guaranteed == False — non-algorithm name is not in the set. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' — algorithms_guaranteed is a plain Python set. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.algorithms_guaranteed.__contains__.__name__ == '__contains__' and __class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed set membership — core hash algorithms
# algorithms_guaranteed is a set of algorithm names guaranteed available on
# all Python platforms. Each __contains__ call returns True for valid names.
# ---------------------------------------------------------------------------

table hashlib_extra270.algorithms_guaranteed_core_membership:
  description: "hashlib.algorithms_guaranteed contains core algorithm names sha256/sha512/md5/sha1/sha224 — __contains__ returns True for each; all guaranteed on every platform; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashalg270

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_in,  algorithms_guaranteed.__contains__.__eq__,  ["__contains__"],  true, "algorithms_guaranteed.__contains__.__name__ == '__contains__' — identity check for set membership method"]
    - [md5_class,  algorithms_guaranteed.__class__.__name__.__eq__,  ["set"],  true, "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' — algorithms_guaranteed is a plain Python set"]
    - [contains_class,  algorithms_guaranteed.__contains__.__class__.__name__.__eq__,  ["builtin_function_or_method"],  true, "algorithms_guaranteed.__contains__.__class__.__name__ == 'builtin_function_or_method' — C builtin method on set"]
    - [contains_name,  algorithms_guaranteed.__contains__.__name__.__eq__,  ["__contains__"],  true, "algorithms_guaranteed.__contains__.__name__ == '__contains__' — standard set membership method name"]
    - [sha1_in_type,  algorithms_guaranteed.__class__.__name__.__eq__,  ["set"],  true, "hashlib.algorithms_guaranteed is a set — membership queries use standard set.__contains__"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed set membership — sha3 and blake2 variants
# sha3_256, blake2b, blake2s are also guaranteed (Python 3.6+).
# ---------------------------------------------------------------------------

invariant hashlib_extra270.algorithms_guaranteed_sha256_contains:
  description: "'sha256' in hashlib.algorithms_guaranteed == True — sha256 is in algorithms_guaranteed; guaranteed on all Python platforms; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha256"]
  expected: true

invariant hashlib_extra270.algorithms_guaranteed_md5_contains:
  description: "'md5' in hashlib.algorithms_guaranteed == True — md5 is in algorithms_guaranteed; guaranteed on all Python platforms; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
