spec: theseus_pprint_cr
version: ">=3.8"
backend: python_cleanroom(theseus_pprint_cr)
blocks: pprint

docs: https://docs.python.org/3/library/pprint.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/pprint.html"
  not_derived_from:
    - "CPython source: Lib/pprint.py"
  notes:
    - "Clean-room pprint module. Do NOT import pprint."

error_model: python_exceptions

invariant theseus_pprint_cr.pprint2_pformat:
  description: "pformat of a simple dict returns a string"
  category: behavior
  kind: python_call_eq
  function: pprint2_pformat
  args: []
  expected: true

invariant theseus_pprint_cr.pprint2_nested:
  description: "pformat of nested list returns a string"
  category: behavior
  kind: python_call_eq
  function: pprint2_nested
  args: []
  expected: true

invariant theseus_pprint_cr.pprint2_isreadable:
  description: "isreadable returns True for simple objects"
  category: behavior
  kind: python_call_eq
  function: pprint2_isreadable
  args: []
  expected: true
