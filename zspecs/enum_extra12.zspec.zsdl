spec: enum_extra12
version: ">=3.9"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum.zspec.zsdl through enum_extra11.zspec.zsdl and enum_flags.zspec.zsdl."
    - "enum_extra11 covers: IntEnum/__bases__.__len__ == 2; Flag/__bases__.__len__ == 1; IntFlag/__bases__.__len__ == 2; StrEnum/__bases__.__len__ == 2 (3.11+); EnumMeta/__bases__[0].__name__ == 'type'; EnumMeta/__bases__.__len__ == 1."
    - "enum_extra10 covers: Enum/__qualname__, IntEnum/__qualname__, auto/__qualname__; Enum/__mro__[0].__name__ == 'Enum'; auto/__bases__[0].__name__ == 'int'; Enum/__bases__.__len__ == 1."
    - "enum_extra9 covers: StrEnum/__mro__[1].__name__ == 'str'; nonmember/__name__, member/__name__, global_enum/__name__, show_flag_values/__name__, FlagBoundary/__name__/__module__."
    - "NOT yet covered: EnumMeta MRO length (== 3) and MRO[0].__name__; Flag MRO length; ReprEnum __qualname__ and __bases__.__len__; nonmember/__module__/__qualname__; member/__module__/__qualname__; global_enum/__qualname__; show_flag_values/__qualname__."
    - "enum.EnumMeta.__mro__.__len__() == 3 — [EnumType/EnumMeta, type, object]."
    - "enum.EnumMeta.__mro__[0].__name__ in ('EnumMeta', 'EnumType') — first MRO entry is EnumMeta itself."
    - "enum.Flag.__mro__.__len__() == 3 — [Flag, Enum, object]."
    - "enum.ReprEnum.__qualname__ == 'ReprEnum' (Python 3.11+)."
    - "enum.ReprEnum.__bases__.__len__() == 1 (Python 3.11+) — sole base is Enum."
    - "enum.nonmember.__module__ == 'enum' (Python 3.11+)."
    - "enum.nonmember.__qualname__ == 'nonmember' (Python 3.11+)."
    - "enum.member.__module__ == 'enum' (Python 3.11+)."
    - "enum.member.__qualname__ == 'member' (Python 3.11+)."
    - "enum.global_enum.__qualname__ == 'global_enum' (Python 3.11+)."
    - "enum.show_flag_values.__qualname__ == 'show_flag_values' (Python 3.11+)."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# EnumMeta.__mro__ — MRO length and first entry
#
# enum_extra11 verified EnumMeta.__bases__[0].__name__ == 'type' and
# EnumMeta.__bases__.__len__() == 1. Not yet verified: the full MRO.
# EnumMeta's MRO is [EnumType, type, object] — length 3.
# ---------------------------------------------------------------------------

invariant enum_extra12.EnumMeta.mro_len:
  description: "enum.EnumMeta.__mro__.__len__() == 3 — [EnumType/EnumMeta, type, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: EnumMeta.__mro__.__len__
  args: []
  expected: 3

invariant enum_extra12.EnumMeta.mro_second:
  description: "enum.EnumMeta.__mro__[1].__name__ == 'type' — type is second in EnumMeta's MRO"
  category: class_hierarchy
  kind: python_call_eq
  function: EnumMeta.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "type"

# ---------------------------------------------------------------------------
# Flag.__mro__ — MRO length
#
# enum_extra8 verified Flag.__mro__.__len__() >= 3. enum_extra11 verified
# Flag.__bases__.__len__() == 1. Not yet verified: the exact MRO length.
# Flag's MRO is [Flag, Enum, object] — length 3.
# ---------------------------------------------------------------------------

invariant enum_extra12.Flag.mro_len:
  description: "enum.Flag.__mro__.__len__() == 3 — [Flag, Enum, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: Flag.__mro__.__len__
  args: []
  expected: 3

invariant enum_extra12.Flag.mro_second:
  description: "enum.Flag.__mro__[1].__name__ == 'Enum' — Enum is second in Flag's MRO"
  category: class_hierarchy
  kind: python_call_eq
  function: Flag.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "Enum"

# ---------------------------------------------------------------------------
# ReprEnum — __qualname__ and __bases__.__len__ (Python 3.11+)
#
# enum_extra9 covered ReprEnum.__name__ and ReprEnum.__module__. Not yet
# covered: ReprEnum.__qualname__ and ReprEnum.__bases__.__len__.
# ReprEnum's sole base is Enum, so __bases__.__len__() == 1.
# ---------------------------------------------------------------------------

invariant enum_extra12.ReprEnum.qualname:
  description: "enum.ReprEnum.__qualname__ == 'ReprEnum' (Python 3.11+)"
  category: class_qualnames
  version: ">=3.11"
  kind: python_call_eq
  function: ReprEnum.__qualname__.__eq__
  args: ["ReprEnum"]
  expected: true

invariant enum_extra12.ReprEnum.bases_len:
  description: "enum.ReprEnum.__bases__.__len__() == 1 — ReprEnum has exactly one direct base (Enum) (Python 3.11+)"
  category: class_hierarchy
  version: ">=3.11"
  kind: python_call_eq
  function: ReprEnum.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# nonmember and member — __module__ and __qualname__ (Python 3.11+)
#
# enum_extra9 covered nonmember.__name__ and member.__name__. Not yet covered:
# their __module__ or __qualname__ attributes.
# ---------------------------------------------------------------------------

table enum_extra12.py311_modules_qualnames:
  kind: python_call_eq
  category: py311_attrs
  id_prefix: attr
  version: ">=3.11"

  columns: [id, function, args, expected]
  rows:
    - [nonmember_module,   nonmember.__module__.__eq__,   ["enum"], true]
    - [nonmember_qualname, nonmember.__qualname__.__eq__,  ["nonmember"], true]
    - [member_module,      member.__module__.__eq__,       ["enum"], true]
    - [member_qualname,    member.__qualname__.__eq__,     ["member"], true]

# ---------------------------------------------------------------------------
# global_enum and show_flag_values — __qualname__ (Python 3.11+)
#
# enum_extra9 covered global_enum.__name__ and show_flag_values.__name__.
# Not yet covered: their __qualname__ attributes.
# ---------------------------------------------------------------------------

invariant enum_extra12.global_enum.qualname:
  description: "enum.global_enum.__qualname__ == 'global_enum' (Python 3.11+)"
  category: function_qualnames
  version: ">=3.11"
  kind: python_call_eq
  function: global_enum.__qualname__.__eq__
  args: ["global_enum"]
  expected: true

invariant enum_extra12.show_flag_values.qualname:
  description: "enum.show_flag_values.__qualname__ == 'show_flag_values' (Python 3.11+)"
  category: function_qualnames
  version: ">=3.11"
  kind: python_call_eq
  function: show_flag_values.__qualname__.__eq__
  args: ["show_flag_values"]
  expected: true
