# ---------------------------------------------------------------------------
# count.__new__.__qualname__ — cross-check with count from itertools.zspec.zsdl
#
# count is covered in itertools.zspec.zsdl for __name__ and first_element.
# Here we verify the __new__.__qualname__ slot specifically.
# ---------------------------------------------------------------------------

invariant itertools_extra261.count.new_qualname:
  description: "itertools.count.__new__.__qualname__ == 'count.__new__'"
  category: identity
  kind: python_call_eq
  function: count.__new__.__qualname__.__eq__
  args: ["count.__new__"]
  expected: true

# ---------------------------------------------------------------------------
# class type checks — repeat, cycle, groupby are all class objects
#
# Their __class__.__name__ is 'type' because they are class objects, not instances.
# ---------------------------------------------------------------------------

table itertools_extra261.class_types:
  description: "repeat, cycle, groupby are all class objects (C-level types)"
  kind: python_call_eq
  category: identity
  id_prefix: ctype

  columns: [id, function, args, expected]
  rows:
    - [repeat,  repeat.__class__.__name__.__eq__,  ["type"], true]
    - [cycle,   cycle.__class__.__name__.__eq__,   ["type"], true]
    - [groupby, groupby.__class__.__name__.__eq__, ["type"], true]
