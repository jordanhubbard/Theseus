  category: identity
  kind: python_call_eq
  function: cycle.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

invariant itertools_extra261.cycle.new_qualname:
  description: "itertools.cycle.__new__.__qualname__ == 'cycle.__new__'"
  category: identity
  kind: python_call_eq
  function: cycle.__new__.__qualname__.__eq__
  args: ["cycle.__new__"]
