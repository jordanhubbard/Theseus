spec: itertools_extra261
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "itertools.zspec.zsdl — covers classnames and first_element for chain, islice, count, cycle, repeat, accumulate, compress, product, combinations, permutations, dropwhile, takewhile, zip_longest"
    - "itertools_extra.zspec.zsdl — covers filterfalse, chain length_hint, bounded repeat, islice length_hint"
    - "itertools_extra260.zspec.zsdl — covers combinations, permutations, combinations_with_replacement class identity"
  notes:
    - "itertools.repeat is a C-level type: __class__.__name__ == 'type'; __module__ == 'itertools'; __bases__[0].__name__ == 'object'."
    - "itertools.cycle is a C-level type: __class__.__name__ == 'type'; __module__ == 'itertools'; __bases__[0].__name__ == 'object'."
    - "itertools.groupby is a C-level type: __class__.__name__ == 'type'; __module__ == 'itertools'; __bases__[0].__name__ == 'object'."
    - "repeat.__new__.__qualname__ == 'repeat.__new__' — the __new__ slot carries the qualified name."
    - "cycle.__new__.__qualname__ == 'cycle.__new__'."
    - "groupby.__new__.__qualname__ == 'groupby.__new__'."
    - "count.__new__.__qualname__ == 'count.__new__'."
    - "All values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# repeat — class identity
#
# itertools.repeat is a C-level type. __name__, __module__, __bases__[0].__name__,
# and __new__.__qualname__ are verified.
# ---------------------------------------------------------------------------

invariant itertools_extra261.repeat.name:
  description: "itertools.repeat.__name__ == 'repeat'"
  category: identity
  kind: python_call_eq
  function: repeat.__name__.__eq__
  args: ["repeat"]
  expected: true

invariant itertools_extra261.repeat.module:
  description: "itertools.repeat.__module__ == 'itertools'"
  category: identity
  kind: python_call_eq
  function: repeat.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra261.repeat.base_name:
  description: "itertools.repeat.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: repeat.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

invariant itertools_extra261.repeat.new_qualname:
  description: "itertools.repeat.__new__.__qualname__ == 'repeat.__new__'"
  category: identity
  kind: python_call_eq
  function: repeat.__new__.__qualname__.__eq__
  args: ["repeat.__new__"]
  expected: true

