# ---------------------------------------------------------------------------
# groupby — class identity
# ---------------------------------------------------------------------------

invariant itertools_extra261.groupby.name:
  description: "itertools.groupby.__name__ == 'groupby'"
  category: identity
  kind: python_call_eq
  function: groupby.__name__.__eq__
  args: ["groupby"]
  expected: true

invariant itertools_extra261.groupby.module:
  description: "itertools.groupby.__module__ == 'itertools'"
  category: identity
  kind: python_call_eq
  function: groupby.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra261.groupby.base_name:
  description: "itertools.groupby.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: groupby.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

invariant itertools_extra261.groupby.new_qualname:
  description: "itertools.groupby.__new__.__qualname__ == 'groupby.__new__'"
