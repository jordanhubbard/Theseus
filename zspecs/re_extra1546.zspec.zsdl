spec: re_extra1546
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module Pattern, Match, error documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
    - "re_extra.zspec.zsdl — covers basic re class presence and method/attribute checks"
  notes:
    - "Wave 550 (_extra1546): bitwise operator __dict__ presence checks for re module classes."
    - "re.Pattern defines comparison operators (__eq__, __ne__, __lt__, __le__, __gt__, __ge__, __hash__) in its own __dict__, but does NOT define any bitwise operators (__and__, __or__, __xor__, __invert__, __lshift__, __rshift__, __rand__, __ror__, __rxor__)."
    - "re.Match defines no comparison operators and no bitwise operators in its own __dict__. Its __dict__ contains: __class_getitem__, __copy__, __deepcopy__, __doc__, __getitem__, __module__, __repr__, end, endpos, expand, group, groupdict, groups, lastgroup, lastindex, pos, re, regs, span, start, string."
    - "re.error is a minimal exception class; its own __dict__ contains only __doc__, __firstlineno__, __init__, __module__, __static_attributes__, __weakref__. No bitwise operators."
    - "The absence of bitwise operators from all re module classes is expected: regex patterns, match results, and exceptions are not integer-like numeric values."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra1546.pattern_bitwise_ops_absent:
  description: "re.Pattern bitwise operator absence — all bitwise operators absent from re.Pattern.__dict__; Pattern defines comparison operators (__eq__, __ne__, __lt__, __le__, __gt__, __ge__, __hash__) and I/O methods (match, search, findall, sub, split, fullmatch, finditer) but no bitwise operators; wave 550"
  kind: python_call_eq
  category: bitwise_ops
  id_prefix: re1546pt
  columns: [id, function, args, expected, description]
  rows:
    - [re1546pt001,
       re.Pattern.__dict__.__contains__,
       ["__and__"],
       false,
       "re.Pattern.__dict__.__contains__('__and__') == False — re.Pattern is the compiled regular expression object returned by re.compile(); it defines comparison operators and regex-matching methods but no bitwise AND; __and__ is absent from Pattern.__dict__; verified with Python 3.14.3"]
    - [re1546pt002,
       re.Pattern.__dict__.__contains__,
       ["__or__"],
       false,
       "re.Pattern.__dict__.__contains__('__or__') == False — re.Pattern does not define __or__ in its own __dict__; patterns cannot be combined with bitwise OR; combining regex patterns uses the | alternation syntax within the pattern string itself, not Python's | operator on Pattern objects; verified with Python 3.14.3"]
    - [re1546pt003,
       re.Pattern.__dict__.__contains__,
       ["__xor__"],
       false,
       "re.Pattern.__dict__.__contains__('__xor__') == False — re.Pattern does not define __xor__ in its own __dict__; verified with Python 3.14.3"]
    - [re1546pt004,
       re.Pattern.__dict__.__contains__,
       ["__invert__"],
       false,
       "re.Pattern.__dict__.__contains__('__invert__') == False — re.Pattern does not define __invert__ (unary ~) in its own __dict__; verified with Python 3.14.3"]
    - [re1546pt005,
       re.Pattern.__dict__.__contains__,
       ["__lshift__"],
       false,
       "re.Pattern.__dict__.__contains__('__lshift__') == False — re.Pattern does not define __lshift__ in its own __dict__; verified with Python 3.14.3"]
    - [re1546pt006,
       re.Pattern.__dict__.__contains__,
       ["__rshift__"],
       false,
       "re.Pattern.__dict__.__contains__('__rshift__') == False — re.Pattern does not define __rshift__ in its own __dict__; verified with Python 3.14.3"]
    - [re1546pt007,
       re.Pattern.__dict__.__contains__,
       ["__rand__"],
       false,
       "re.Pattern.__dict__.__contains__('__rand__') == False — re.Pattern does not define __rand__ (reflected bitwise AND) in its own __dict__; verified with Python 3.14.3"]
    - [re1546pt008,
       re.Pattern.__dict__.__contains__,
       ["__ror__"],
       false,
       "re.Pattern.__dict__.__contains__('__ror__') == False — re.Pattern does not define __ror__ (reflected bitwise OR) in its own __dict__; verified with Python 3.14.3"]
    - [re1546pt009,
       re.Pattern.__dict__.__contains__,
       ["__rxor__"],
       false,
       "re.Pattern.__dict__.__contains__('__rxor__') == False — re.Pattern does not define __rxor__ (reflected bitwise XOR) in its own __dict__; verified with Python 3.14.3"]
    - [re1546pt010,
       re.Pattern.__dict__.__contains__,
       ["match"],
       true,
       "re.Pattern.__dict__.__contains__('match') == True — positive anchor: re.Pattern defines 'match' in its own __dict__; Pattern.match() tries to match the pattern at the start of the string; the class dict contains regex methods but no bitwise operators; verified with Python 3.14.3"]
    - [re1546pt011,
       re.Pattern.__dict__.__contains__,
       ["search"],
       true,
       "re.Pattern.__dict__.__contains__('search') == True — positive anchor: re.Pattern defines 'search' in its own __dict__; Pattern.search() scans the string for a location where the pattern matches; verified with Python 3.14.3"]
    - [re1546pt012,
       re.Pattern.__dict__.__contains__,
       ["__eq__"],
       true,
       "re.Pattern.__dict__.__contains__('__eq__') == True — positive anchor: re.Pattern defines '__eq__' in its own __dict__; Pattern objects support equality comparison (same pattern string + same flags = equal); Pattern does define comparison operators but not bitwise operators; this distinguishes the two operator families; verified with Python 3.14.3"]

table re_extra1546.match_bitwise_ops_absent:
  description: "re.Match bitwise operator absence — all bitwise operators absent from re.Match.__dict__; Match contains positional and group-extraction attributes (group, groups, start, end, span, pos, endpos, re, string, expand) plus __copy__, __deepcopy__, __getitem__, __repr__, __class_getitem__; no bitwise operators; wave 550"
  kind: python_call_eq
  category: bitwise_ops
  id_prefix: re1546mt
  columns: [id, function, args, expected, description]
  rows:
    - [re1546mt001,
       re.Match.__dict__.__contains__,
       ["__and__"],
       false,
       "re.Match.__dict__.__contains__('__and__') == False — re.Match is the match object returned by Pattern.match(), Pattern.search(), and similar methods; it stores match position and captured groups; __and__ (bitwise AND) is absent from Match.__dict__; verified with Python 3.14.3"]
    - [re1546mt002,
       re.Match.__dict__.__contains__,
       ["__or__"],
       false,
       "re.Match.__dict__.__contains__('__or__') == False — re.Match does not define __or__ in its own __dict__; match objects hold positional and group data, not integer values; verified with Python 3.14.3"]
    - [re1546mt003,
       re.Match.__dict__.__contains__,
       ["__xor__"],
       false,
       "re.Match.__dict__.__contains__('__xor__') == False — re.Match does not define __xor__ in its own __dict__; verified with Python 3.14.3"]
    - [re1546mt004,
       re.Match.__dict__.__contains__,
       ["__invert__"],
       false,
       "re.Match.__dict__.__contains__('__invert__') == False — re.Match does not define __invert__ in its own __dict__; verified with Python 3.14.3"]
    - [re1546mt005,
       re.Match.__dict__.__contains__,
       ["__lshift__"],
       false,
       "re.Match.__dict__.__contains__('__lshift__') == False — re.Match does not define __lshift__ in its own __dict__; verified with Python 3.14.3"]
    - [re1546mt006,
       re.Match.__dict__.__contains__,
       ["__rshift__"],
       false,
       "re.Match.__dict__.__contains__('__rshift__') == False — re.Match does not define __rshift__ in its own __dict__; verified with Python 3.14.3"]
    - [re1546mt007,
       re.Match.__dict__.__contains__,
       ["__rand__"],
       false,
       "re.Match.__dict__.__contains__('__rand__') == False — re.Match does not define __rand__ in its own __dict__; verified with Python 3.14.3"]
    - [re1546mt008,
       re.Match.__dict__.__contains__,
       ["__ror__"],
       false,
       "re.Match.__dict__.__contains__('__ror__') == False — re.Match does not define __ror__ in its own __dict__; verified with Python 3.14.3"]
    - [re1546mt009,
       re.Match.__dict__.__contains__,
       ["__rxor__"],
       false,
       "re.Match.__dict__.__contains__('__rxor__') == False — re.Match does not define __rxor__ in its own __dict__; verified with Python 3.14.3"]
    - [re1546mt010,
       re.Match.__dict__.__contains__,
       ["group"],
       true,
       "re.Match.__dict__.__contains__('group') == True — positive anchor: re.Match defines 'group' in its own __dict__; Match.group() returns one or more subgroups of the match; the class dict contains group-extraction and positional methods, not bitwise operators; verified with Python 3.14.3"]
    - [re1546mt011,
       re.Match.__dict__.__contains__,
       ["span"],
       true,
       "re.Match.__dict__.__contains__('span') == True — positive anchor: re.Match defines 'span' in its own __dict__; Match.span() returns a tuple (start, end) of the match's extent; verified with Python 3.14.3"]
    - [re1546mt012,
       re.Match.__dict__.__contains__,
       ["start"],
       true,
       "re.Match.__dict__.__contains__('start') == True — positive anchor: re.Match defines 'start' in its own __dict__; Match.start() returns the start index of the match; no bitwise operators present in Match.__dict__; verified with Python 3.14.3"]

table re_extra1546.error_bitwise_ops_absent:
  description: "re.error bitwise operator absence — all bitwise operators absent from re.error.__dict__; re.error is the exception raised when a regular expression pattern is invalid; its own __dict__ is minimal (__doc__, __firstlineno__, __init__, __module__, __static_attributes__, __weakref__); wave 550"
  kind: python_call_eq
  category: bitwise_ops
  id_prefix: re1546er
  columns: [id, function, args, expected, description]
  rows:
    - [re1546er001,
       re.error.__dict__.__contains__,
       ["__and__"],
       false,
       "re.error.__dict__.__contains__('__and__') == False — re.error is the exception class raised when a pattern is invalid (e.g., re.compile('[')); it inherits from Exception; its own __dict__ is minimal; __and__ is absent; verified with Python 3.14.3"]
