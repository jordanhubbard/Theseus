spec: decimal_to_binary
version: ">=1.0.3"
backend: node(decimal-to-binary)

docs: https://www.npmjs.com/package/decimal-to-binary

provenance:
  derived_from:
    - "decimal-to-binary README — https://www.npmjs.com/package/decimal-to-binary"
    - "Test vectors verified with decimal-to-binary via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "decimal-to-binary source"
  notes:
    - "decimal-to-binary is an npm package. Install: npm install decimal-to-binary"
    - "convertToBinary converts a decimal integer to its binary string representation."
    - "convertToDecimal converts a binary string to its decimal integer value."
    - "convertToBinary(0) returns an empty string (quirk of this implementation)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string (convertToBinary) or number (convertToDecimal)."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table decimal_to_binary.convert_to_binary:
  kind: node_module_call_eq
  function: convertToBinary
  category: numbers
  id_prefix: d2bin

  columns: [id, args, expected]
  rows:
    - [two,        [2],   "10"]
    - [four,       [4],   "100"]
    - [eight,      [8],   "1000"]
    - [ten,        [10],  "1010"]
    - [twofiftyfive, [255], "11111111"]

table decimal_to_binary.convert_to_decimal:
  kind: node_module_call_eq
  function: convertToDecimal
  category: numbers
  id_prefix: d2dec

  columns: [id, args, expected]
  rows:
    - [ten,          ["1010"],     10]
    - [four,         ["100"],      4]
    - [twofiftyfive, ["11111111"], 255]

# ── Synthesis layer annotation ───────────────────────────────────────────────
