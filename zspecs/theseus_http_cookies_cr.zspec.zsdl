spec: theseus_http_cookies_cr
version: ">=3.0"
backend: python_cleanroom(theseus_http_cookies_cr)
blocks: http.cookies

docs: https://docs.python.org/3/library/http.cookies.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/http.cookies.html"
  not_derived_from:
    - "CPython source: Lib/http/cookies.py"
  notes:
    - "Clean-room http.cookies module. Do NOT import http.cookies."

error_model: python_exceptions

invariant theseus_http_cookies_cr.cookies2_simplecookie:
  description: "SimpleCookie can set and get a cookie"
  category: behavior
  kind: python_call_eq
  function: cookies2_simplecookie
  args: []
  expected: true

invariant theseus_http_cookies_cr.cookies2_output:
  description: "SimpleCookie.output() produces Set-Cookie header"
  category: behavior
  kind: python_call_eq
  function: cookies2_output
  args: []
  expected: true

invariant theseus_http_cookies_cr.cookies2_load:
  description: "SimpleCookie.load() parses a cookie string"
  category: behavior
  kind: python_call_eq
  function: cookies2_load
  args: []
  expected: true
