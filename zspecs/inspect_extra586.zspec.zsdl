spec: inspect_extra586
version: ">=3.9"
backend: python_module(inspect)
docs: "Identity invariants for inspect.Signature and inspect.Parameter class and method qualnames"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __qualname__ and __module__ identity for inspect.Signature and its methods"
    - "Covers __qualname__ and __module__ identity for inspect.Parameter and its methods"
  created_at: "2026-04-12T00:00:00Z"

table in586si:
  description: "inspect.Signature class and method qualname/module identity"
  columns: [id, function, args, expected]
  rows:
    - [in586si01, inspect.Signature.__qualname__.__eq__, ["Signature"], true]
    - [in586si02, inspect.Signature.__module__.__eq__, ["inspect"], true]
    - [in586si03, inspect.Signature.__init__.__qualname__.__eq__, ["Signature.__init__"], true]
    - [in586si04, inspect.Signature.__str__.__qualname__.__eq__, ["Signature.__str__"], true]
    - [in586si05, inspect.Signature.bind.__qualname__.__eq__, ["Signature.bind"], true]
    - [in586si06, inspect.Signature.bind_partial.__qualname__.__eq__, ["Signature.bind_partial"], true]

table in586fp:
  description: "inspect.Parameter class and method qualname/module identity"
  columns: [id, function, args, expected]
  rows:
    - [in586fp01, inspect.Parameter.__qualname__.__eq__, ["Parameter"], true]
    - [in586fp02, inspect.Parameter.__module__.__eq__, ["inspect"], true]
    - [in586fp03, inspect.Parameter.__init__.__qualname__.__eq__, ["Parameter.__init__"], true]
    - [in586fp04, inspect.Parameter.__str__.__qualname__.__eq__, ["Parameter.__str__"], true]
    - [in586fp05, inspect.Parameter.__repr__.__qualname__.__eq__, ["Parameter.__repr__"], true]
    - [in586fp06, inspect.Parameter.replace.__qualname__.__eq__, ["Parameter.replace"], true]
