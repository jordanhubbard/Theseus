spec: inspect_extra32
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra31.zspec.zsdl."
    - "Prior specs covered: ismodule/isclass/isfunction/ismethod/isbuiltin/isroutine/__name__, getmembers/signature/Parameter/Signature/BoundArguments identity, Parameter kind class names, empty sentinel class names, class __bases__[0].__name__ for Parameter/Signature/BoundArguments, various __qualname__ and __module__ checks, method __qualname__.__len__() for Parameter.replace/__init__, Signature.bind/bind_partial/replace, BoundArguments.apply_defaults/__init__/__repr__, __mro__.__len__() for Parameter/Signature/BoundArguments (all 2), Parameter.empty.__qualname__.__len__(), __all__.__len__() (107), __all__.__class__.__name__.__len__() (4), FrameInfo.__qualname__.__len__() (9), FrameInfo.__mro__.__len__() (4), _ParameterKind.__qualname__.__len__() (14), iscode/isframe/isgenerator/iscoroutine/isasyncgen __qualname__.__len__(), class __dict__.__class__.__name__.__len__() for Parameter/Signature/BoundArguments/FrameInfo."
    - "This spec covers: __qualname__.__len__() for isfunction (10), isbuiltin (9), ismethod (8), isroutine (9), getmembers (10), getfile (7), getsource (9), getsourcelines (14), signature (9), stack (5); Signature.from_callable.__qualname__.__len__() (23); isasyncgenfunction (18), isgeneratorfunction (19), iscoroutinefunction (19); getmodule (9), currentframe (12), ismodule (8), isclass (7); getfullargspec (14), getargs (7); inspect.__name__.__len__() (7); CO_OPTIMIZED.__class__.__name__.__len__() (3)."
    - "Key findings: inspect.__package__ is '' (empty string, len 0) — inspect is a top-level module. inspect.stack.__qualname__ is 'stack' (len 5) — notably short. Signature.from_callable.__qualname__ is 'Signature.from_callable' (len 23). The three *function predicates are longer: isasyncgenfunction (18), isgeneratorfunction (19), iscoroutinefunction (19). CO_OPTIMIZED is an int (class name len 3)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Core predicate __qualname__.__len__() table — isfunction/isbuiltin/ismethod/isroutine
#
# inspect.isfunction.__qualname__ is 'isfunction' (10 chars). inspect.isbuiltin.__qualname__
# is 'isbuiltin' (9 chars). inspect.ismethod.__qualname__ is 'ismethod' (8 chars).
# inspect.isroutine.__qualname__ is 'isroutine' (9 chars). These four predicates form
# the core routine-inspection API. No prior inspect spec records these four
# __qualname__.__len__() values together in a combined table in the extra32 namespace.
# ---------------------------------------------------------------------------

table inspect_extra32.core_predicate_qualname_lengths:
  description: "__qualname__.__len__() for core inspect predicates: isfunction/isbuiltin/ismethod/isroutine"
  kind: python_call_eq
  category: string_properties
  id_prefix: corepredqlen32

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction,
       isfunction.__qualname__.__len__,
       [],
       10,
       "len(inspect.isfunction.__qualname__) == 10 — 'isfunction'"]
    - [isbuiltin,
       isbuiltin.__qualname__.__len__,
       [],
       9,
       "len(inspect.isbuiltin.__qualname__) == 9 — 'isbuiltin'"]
    - [ismethod,
       ismethod.__qualname__.__len__,
       [],
       8,
       "len(inspect.ismethod.__qualname__) == 8 — 'ismethod'"]
    - [isroutine,
       isroutine.__qualname__.__len__,
       [],
       9,
       "len(inspect.isroutine.__qualname__) == 9 — 'isroutine'"]

# ---------------------------------------------------------------------------
# Source/member retrieval __qualname__.__len__() table — extra32 namespace
#
# inspect.getmembers.__qualname__ is 'getmembers' (10 chars). inspect.getfile.__qualname__
# is 'getfile' (7 chars). inspect.getsource.__qualname__ is 'getsource' (9 chars).
# inspect.getsourcelines.__qualname__ is 'getsourcelines' (14 chars). inspect.getmodule.__qualname__
# is 'getmodule' (9 chars). These five functions form the source/member retrieval API.
# No prior inspect spec records these five __qualname__.__len__() values together in a
# combined table in the extra32 namespace.
# ---------------------------------------------------------------------------

table inspect_extra32.source_retrieval_qualname_lengths:
  description: "__qualname__.__len__() for inspect source/member retrieval functions"
  kind: python_call_eq
  category: string_properties
  id_prefix: srcretrqlen32

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers,
       getmembers.__qualname__.__len__,
       [],
       10,
       "len(inspect.getmembers.__qualname__) == 10 — 'getmembers'"]
    - [getfile,
       getfile.__qualname__.__len__,
       [],
       7,
       "len(inspect.getfile.__qualname__) == 7 — 'getfile'"]
    - [getsource,
       getsource.__qualname__.__len__,
       [],
       9,
       "len(inspect.getsource.__qualname__) == 9 — 'getsource'"]
    - [getsourcelines,
       getsourcelines.__qualname__.__len__,
       [],
       14,
       "len(inspect.getsourcelines.__qualname__) == 14 — 'getsourcelines'"]
    - [getmodule,
       getmodule.__qualname__.__len__,
       [],
       9,
       "len(inspect.getmodule.__qualname__) == 9 — 'getmodule'"]

# ---------------------------------------------------------------------------
# Async/generator *function predicate __qualname__.__len__() table — extra32 namespace
#
# inspect.isasyncgenfunction.__qualname__ is 'isasyncgenfunction' (18 chars).
# inspect.isgeneratorfunction.__qualname__ is 'isgeneratorfunction' (19 chars).
# inspect.iscoroutinefunction.__qualname__ is 'iscoroutinefunction' (19 chars).
# These three long-form function predicates test for async generator, generator,
# and coroutine callables respectively — distinct from the shorter object predicates
# (isasyncgen/isgenerator/iscoroutine) covered in extra31. No prior inspect spec
# records these three __qualname__.__len__() values together in a combined table
# in the extra32 namespace.
# ---------------------------------------------------------------------------

table inspect_extra32.function_predicate_qualname_lengths:
  description: "__qualname__.__len__() for inspect *function predicates: isasyncgenfunction/isgeneratorfunction/iscoroutinefunction"
  kind: python_call_eq
  category: string_properties
  id_prefix: fnpredqlen32

  columns: [id, function, args, expected, description]
  rows:
    - [isasyncgenfunction,
       isasyncgenfunction.__qualname__.__len__,
       [],
       18,
       "len(inspect.isasyncgenfunction.__qualname__) == 18 — 'isasyncgenfunction'"]
    - [isgeneratorfunction,
       isgeneratorfunction.__qualname__.__len__,
       [],
       19,
       "len(inspect.isgeneratorfunction.__qualname__) == 19 — 'isgeneratorfunction'"]
    - [iscoroutinefunction,
       iscoroutinefunction.__qualname__.__len__,
       [],
       19,
       "len(inspect.iscoroutinefunction.__qualname__) == 19 — 'iscoroutinefunction'"]

# ---------------------------------------------------------------------------
# Signature.from_callable.__qualname__.__len__() — standalone invariant
#
# inspect.Signature.from_callable.__qualname__ is 'Signature.from_callable' (23 chars).
# This classmethod creates a Signature by introspecting any callable object. Its qualname
# is longer than any of the module-level function qualnames because it includes the class
# prefix 'Signature.'. No prior inspect spec records Signature.from_callable.__qualname__.__len__()
# as a standalone in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra32.Signature_from_callable_qualname_len:
  description: "len(inspect.Signature.from_callable.__qualname__) == 23 — 'Signature.from_callable'"
  category: string_properties
  kind: python_call_eq
  function: Signature.from_callable.__qualname__.__len__
  args: []
  expected: 23

# ---------------------------------------------------------------------------
# inspect.signature.__qualname__.__len__() — standalone invariant
#
# inspect.signature.__qualname__ is 'signature' (9 chars). This module-level function
# returns a Signature object for a given callable. Its 9-character qualname is the same
# length as getsource and isroutine. No prior inspect spec records
# signature.__qualname__.__len__() as a standalone in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra32.signature_qualname_len:
  description: "len(inspect.signature.__qualname__) == 9 — 'signature'"
  category: string_properties
  kind: python_call_eq
  function: signature.__qualname__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# inspect.stack.__qualname__.__len__() — standalone invariant
#
# inspect.stack.__qualname__ is 'stack' (5 chars). This is the shortest qualname
# among the major inspect API functions. stack returns the call stack as a list of
# FrameInfo objects. No prior inspect spec records stack.__qualname__.__len__() as
# a standalone in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra32.stack_qualname_len:
  description: "len(inspect.stack.__qualname__) == 5 — 'stack'"
  category: string_properties
  kind: python_call_eq
  function: stack.__qualname__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# inspect.currentframe.__qualname__.__len__() — standalone invariant
#
# inspect.currentframe.__qualname__ is 'currentframe' (12 chars). currentframe is a
# built-in function returning the current execution frame. Its qualname matches its
# simple name. No prior inspect spec records currentframe.__qualname__.__len__() as
# a standalone in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra32.currentframe_qualname_len:
  description: "len(inspect.currentframe.__qualname__) == 12 — 'currentframe'"
  category: string_properties
  kind: python_call_eq
  function: currentframe.__qualname__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# inspect.getfullargspec.__qualname__.__len__() — standalone invariant
#
# inspect.getfullargspec.__qualname__ is 'getfullargspec' (14 chars). getfullargspec
# retrieves the full argument specification of a function including annotations. Its
# 14-character qualname is the same length as getsourcelines. No prior inspect spec
# records getfullargspec.__qualname__.__len__() as a standalone in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra32.getfullargspec_qualname_len:
  description: "len(inspect.getfullargspec.__qualname__) == 14 — 'getfullargspec'"
  category: string_properties
  kind: python_call_eq
  function: getfullargspec.__qualname__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# inspect.__name__.__len__() — standalone invariant
#
# inspect.__name__ is 'inspect' (7 chars). inspect is a top-level module whose
# name matches its simple filename. inspect.__package__ is '' (empty string),
# consistent with it being a top-level module with no package namespace. No prior
# inspect spec records inspect.__name__.__len__() as a standalone in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra32.module_name_len:
  description: "len(inspect.__name__) == 7 — 'inspect'"
  category: module_metadata
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 7
