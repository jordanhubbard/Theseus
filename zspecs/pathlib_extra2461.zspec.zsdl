spec: pathlib_extra2461
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "Python pathlib documentation — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra.zspec.zsdl"
  notes:
    - "Wave 2461, theme: __len__ and __length_hint__ dict-presence — pathlib path classes do not define length protocol."
    - "Path objects represent filesystem paths and are not sequences; neither __len__ nor __length_hint__ appear in any path class __dict__."
    - "PurePath defines navigation and comparison methods (joinpath, with_segments, parser) but no length protocol."
    - "PurePosixPath and PureWindowsPath override parser but add no length protocol."
    - "Path adds stat, exists, is_dir, is_file and other fs methods — still no length protocol."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# pathlib.PurePath — length protocol NOT in own __dict__
# ---------------------------------------------------------------------------

table pathlib_extra2461.purepath_length_protocol:
  description: "pathlib.PurePath.__dict__ does not define __len__ or __length_hint__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2461

  columns: [id, function, args, expected]
  rows:
    - ["pp2461001", "pathlib.PurePath.__dict__.__contains__", ["__len__"],         false]
    - ["pp2461002", "pathlib.PurePath.__dict__.__contains__", ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# pathlib pure path subclasses — length protocol NOT in own __dict__
# ---------------------------------------------------------------------------

table pathlib_extra2461.pure_subclasses_length_protocol:
  description: "pathlib.PurePosixPath and PureWindowsPath do not define __len__ or __length_hint__ in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2461

  columns: [id, function, args, expected]
  rows:
    - ["pp2461003", "pathlib.PurePosixPath.__dict__.__contains__",   ["__len__"],         false]
    - ["pp2461004", "pathlib.PurePosixPath.__dict__.__contains__",   ["__length_hint__"], false]
    - ["pp2461005", "pathlib.PureWindowsPath.__dict__.__contains__", ["__len__"],         false]
    - ["pp2461006", "pathlib.PureWindowsPath.__dict__.__contains__", ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# pathlib.Path — length protocol NOT in own __dict__
# ---------------------------------------------------------------------------

table pathlib_extra2461.path_length_protocol:
  description: "pathlib.Path does not define __len__ or __length_hint__ in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2461

  columns: [id, function, args, expected]
  rows:
    - ["pp2461007", "pathlib.Path.__dict__.__contains__", ["__len__"],         false]
    - ["pp2461008", "pathlib.Path.__dict__.__contains__", ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# Complementary: methods that ARE in path class __dict__
# ---------------------------------------------------------------------------

table pathlib_extra2461.path_own_methods:
  description: "Methods that ARE present in pathlib class __dict__ (not length protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2461

  columns: [id, function, args, expected]
  rows:
    - ["pp2461009",  "pathlib.PurePath.__dict__.__contains__",        ["parser"],        true]
    - ["pp2461010",  "pathlib.PurePath.__dict__.__contains__",        ["with_segments"], true]
    - ["pp2461011",  "pathlib.PurePath.__dict__.__contains__",        ["joinpath"],      true]
    - ["pp2461012",  "pathlib.PurePosixPath.__dict__.__contains__",   ["parser"],        true]
    - ["pp2461013",  "pathlib.PureWindowsPath.__dict__.__contains__", ["parser"],        true]
    - ["pp2461014",  "pathlib.Path.__dict__.__contains__",            ["stat"],          true]
    - ["pp2461015",  "pathlib.Path.__dict__.__contains__",            ["exists"],        true]
    - ["pp2461016",  "pathlib.Path.__dict__.__contains__",            ["is_dir"],        true]
    - ["pp2461017",  "pathlib.Path.__dict__.__contains__",            ["is_file"],       true]
