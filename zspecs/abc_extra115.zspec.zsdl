spec: abc_extra115
version: ">=3.11"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra114.zspec.zsdl."
    - "This spec covers: wave 260 theme — abc module ABCMeta.__new__ co_varnames element equality and abstractclassmethod/abstractstaticmethod.__init__ co_varnames elements not previously covered. Prior specs covered: extra104 covered abstractclassmethod.__init__.__code__.co_argcount==2 and abstractstaticmethod.__init__.__code__.co_argcount==2; extra112 covered ABCMeta.__new__.__code__.co_varnames.__len__()==6 and ABCMeta.register/__instancecheck__/__subclasscheck__ co_varnames.__len__()==2; extra114 covered ABCMeta.register/__new__ co_varnames[0] equality and abstractmethod co_varnames[0]=='funcobj'. NOT previously covered: ABCMeta.__new__.__code__.co_varnames[1].__eq__('name'); co_varnames[2].__eq__('bases'); co_varnames[3].__eq__('namespace'); co_varnames[5].__eq__('cls'); abstractclassmethod.__init__.__code__.co_varnames[1].__eq__('callable'); abstractstaticmethod.__init__.__code__.co_varnames[1].__eq__('callable'). Note: abc has no __all__ in Python 3.14.3 (verified: hasattr(abc,'__all__')==False). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__new__.__code__.co_varnames == ('mcls','name','bases','namespace','kwargs','cls'): len=6 (covered in extra112); co_varnames[0]='mcls' covered in extra114. NOT covered: co_varnames[1]='name' (len=4), co_varnames[2]='bases' (len=5), co_varnames[3]='namespace' (len=9, longest), co_varnames[4]='kwargs' (len=6), co_varnames[5]='cls' (len=3, shortest). co_qualname=='ABCMeta.__new__' (len=15). co_argcount==4 (mcls,name,bases,namespace; kwargs is VAR_KEYWORD). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.abstractclassmethod.__init__.__code__.co_varnames == ('self','callable'): len=2. co_varnames[1]='callable' (len=8). abstractstaticmethod.__init__.__code__.co_varnames == ('self','callable'): len=2. co_varnames[1]='callable' (len=8; same as abstractclassmethod). Both deprecated classes use 'callable' as the parameter name (not 'fn' or 'func') because they wrap any callable, not just functions. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "Note: abc has no __all__ in Python 3.14.3: hasattr(abc,'__all__')==False (verified). abc module public members are discoverable via dir(abc) but are not constrained by __all__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta.__new__ co_varnames element equality — extra115
#
# Wave 260 theme: ABCMeta.__new__ co_varnames[1]-[5] element equality.
#
# ABCMeta.__new__.__code__.co_varnames[0] == 'mcls'      (len=4, covered in extra114)
# ABCMeta.__new__.__code__.co_varnames[1] == 'name'      (len=4)
# ABCMeta.__new__.__code__.co_varnames[2] == 'bases'     (len=5)
# ABCMeta.__new__.__code__.co_varnames[3] == 'namespace' (len=9, longest)
# ABCMeta.__new__.__code__.co_varnames[4] == 'kwargs'    (len=6)
# ABCMeta.__new__.__code__.co_varnames[5] == 'cls'       (len=3, shortest)
# ---------------------------------------------------------------------------

table abc_extra115.abc_abcmeta_new_co_varnames_elements:
  description: "abc.ABCMeta.__new__ co_varnames element equality checks in abcnew115 namespace — wave 260 theme: ABCMeta.__new__ co_varnames[1]-[5] element equality; co_varnames==('mcls','name','bases','namespace','kwargs','cls') len=6 (covered in extra112); co_varnames[0]='mcls' covered in extra114; co_varnames[1].__eq__('name')==True (len=4: name is the class name string passed to type.__new__; co_argcount==4 so name is the second positional param after mcls); co_varnames[2].__eq__('bases')==True (len=5: bases is the tuple of base classes; the third positional param); co_varnames[3].__eq__('namespace')==True (len=9: namespace is the class namespace dict populated during class body execution; the fourth positional param; longest element in co_varnames at 9 chars); co_varnames[4].__eq__('kwargs')==True (len=6: kwargs captures extra keyword args to the class statement, e.g. metaclass=; VAR_KEYWORD so not in co_argcount=4); co_varnames[5].__eq__('cls')==True (len=3: cls is a local variable holding the newly created class returned by super().__new__; it is not a parameter; shortest element in co_varnames); element length ordering: cls=3 (shortest local) < mcls==name=4 (tied) < bases=5 < kwargs=6 < namespace=9 (longest param); ABCMeta.__new__ is the metaclass constructor that intercepts class creation to build the ABC registry; it calls type.__new__(mcls,name,bases,namespace,**kwargs) then sets up __abstractmethods__; co_qualname=='ABCMeta.__new__' (len=15); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abcnew115

  columns: [id, function, args, expected, description]
  rows:
    - [v1_eq,   "abc.ABCMeta.__new__.__code__.co_varnames[1].__eq__",  ["name"],      true, "ABCMeta.__new__ co_varnames[1] == 'name' (len=4; class name string); verified with Python 3.14.3"]
    - [v1_len,  "abc.ABCMeta.__new__.__code__.co_varnames[1].__len__", [],            4,    "ABCMeta.__new__ co_varnames[1].__len__() == 4 ('name'=4; tied with mcls=4); verified with Python 3.14.3"]
    - [v2_eq,   "abc.ABCMeta.__new__.__code__.co_varnames[2].__eq__",  ["bases"],     true, "ABCMeta.__new__ co_varnames[2] == 'bases' (len=5; tuple of base classes); verified with Python 3.14.3"]
    - [v2_len,  "abc.ABCMeta.__new__.__code__.co_varnames[2].__len__", [],            5,    "ABCMeta.__new__ co_varnames[2].__len__() == 5 ('bases'=5); verified with Python 3.14.3"]
    - [v3_eq,   "abc.ABCMeta.__new__.__code__.co_varnames[3].__eq__",  ["namespace"], true, "ABCMeta.__new__ co_varnames[3] == 'namespace' (len=9, longest element); verified with Python 3.14.3"]
    - [v3_len,  "abc.ABCMeta.__new__.__code__.co_varnames[3].__len__", [],            9,    "ABCMeta.__new__ co_varnames[3].__len__() == 9 ('namespace'=9, longest in co_varnames); verified with Python 3.14.3"]
    - [v4_eq,   "abc.ABCMeta.__new__.__code__.co_varnames[4].__eq__",  ["kwargs"],    true, "ABCMeta.__new__ co_varnames[4] == 'kwargs' (len=6; VAR_KEYWORD extra keyword args); verified with Python 3.14.3"]
    - [v4_len,  "abc.ABCMeta.__new__.__code__.co_varnames[4].__len__", [],            6,    "ABCMeta.__new__ co_varnames[4].__len__() == 6 ('kwargs'=6); verified with Python 3.14.3"]
    - [v5_eq,   "abc.ABCMeta.__new__.__code__.co_varnames[5].__eq__",  ["cls"],       true, "ABCMeta.__new__ co_varnames[5] == 'cls' (len=3, shortest; local var for newly created class); verified with Python 3.14.3"]
    - [v5_len,  "abc.ABCMeta.__new__.__code__.co_varnames[5].__len__", [],            3,    "ABCMeta.__new__ co_varnames[5].__len__() == 3 ('cls'=3, shortest element in co_varnames); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.abstractclassmethod and abstractstaticmethod __init__ co_varnames — extra115
#
# Wave 260 theme: abstractclassmethod and abstractstaticmethod __init__ co_varnames[1] equality.
#
# abstractclassmethod.__init__.__code__.co_varnames[1] == 'callable' (len=8)
# abstractstaticmethod.__init__.__code__.co_varnames[1] == 'callable' (len=8, tied)
# Both deprecated classes use 'callable' (not 'fn') as their second parameter.
# ---------------------------------------------------------------------------

table abc_extra115.abc_deprecated_init_co_varnames:
  description: "abc.abstractclassmethod and abstractstaticmethod __init__ co_varnames element equality checks in abcnew115 namespace — wave 260 theme: abstractclassmethod and abstractstaticmethod both use 'callable' as their second parameter; abstractclassmethod.__init__.__code__.co_varnames[1].__eq__('callable')==True (len=8: abstractclassmethod.__init__ wraps the given callable as both a classmethod and an abstract method; uses 'callable' rather than 'fn' or 'func' to emphasize any callable is accepted; abstractclassmethod is deprecated since Python 3.3 — use ABCMeta+@classmethod+@abstractmethod instead; co_varnames==('self','callable') len=2; co_argcount==2); abstractclassmethod.__init__.__code__.co_varnames[1].__len__()==8; abstractstaticmethod.__init__.__code__.co_varnames[1].__eq__('callable')==True (len=8: tied with abstractclassmethod; abstractstaticmethod.__init__ wraps callable as both a staticmethod and abstract method; deprecated since Python 3.3 — use ABCMeta+@staticmethod+@abstractmethod instead; co_varnames==('self','callable') len=2; co_argcount==2); abstractstaticmethod.__init__.__code__.co_varnames[1].__len__()==8; compare: abstractmethod co_varnames[0]='funcobj' (len=7, 1 shorter than 'callable'=8; abstractmethod uses 'funcobj' not 'callable'; abstractclassmethod and abstractstaticmethod both consistently use 'callable'=8); the choice of 'callable' signals these decorators accept any callable object (function, method, lambda, etc.); ABCMeta.__new__ co_varnames[4]='kwargs' (len=6, 2 shorter); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abcnew115a

  columns: [id, function, args, expected, description]
  rows:
    - [acm_v1_eq,  "abc.abstractclassmethod.__init__.__code__.co_varnames[1].__eq__",   ["callable"], true, "abstractclassmethod.__init__ co_varnames[1] == 'callable' (len=8; any callable accepted); verified with Python 3.14.3"]
    - [acm_v1_len, "abc.abstractclassmethod.__init__.__code__.co_varnames[1].__len__",  [],           8,    "abstractclassmethod.__init__ co_varnames[1].__len__() == 8 ('callable'=8); verified with Python 3.14.3"]
    - [asm_v1_eq,  "abc.abstractstaticmethod.__init__.__code__.co_varnames[1].__eq__",  ["callable"], true, "abstractstaticmethod.__init__ co_varnames[1] == 'callable' (len=8, tied with abstractclassmethod); verified with Python 3.14.3"]
    - [asm_v1_len, "abc.abstractstaticmethod.__init__.__code__.co_varnames[1].__len__", [],           8,    "abstractstaticmethod.__init__ co_varnames[1].__len__() == 8 ('callable'=8; same as abstractclassmethod); verified with Python 3.14.3"]
    - [acm_vlen,   "abc.abstractclassmethod.__init__.__code__.co_varnames.__len__",     [],           2,    "abstractclassmethod.__init__ co_varnames.__len__() == 2 (('self','callable')); verified with Python 3.14.3"]
    - [asm_vlen,   "abc.abstractstaticmethod.__init__.__code__.co_varnames.__len__",    [],           2,    "abstractstaticmethod.__init__ co_varnames.__len__() == 2 (('self','callable')); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc module co_varnames element length ordering cross-checks — extra115
#
# Wave 260 theme: compare co_varnames element lengths across abc functions.
#
# ABCMeta.__new__ co_varnames[5] = 'cls'           len=3 (shortest element in spec)
# abstractclassmethod.__init__ co_varnames[0]='self' len=4
# ABCMeta.__new__ co_varnames[2] = 'bases'          len=5
# abstractclassmethod.__init__ co_varnames[1]='callable' len=8
# ABCMeta.__new__ co_varnames[3] = 'namespace'      len=9 (longest element in spec)
# ---------------------------------------------------------------------------

table abc_extra115.abc_co_varnames_element_ordering:
  description: "abc module co_varnames element length ordering cross-checks in abcnew115 namespace — wave 260 theme: comparing co_varnames element lengths across ABCMeta.__new__ and deprecated abstract decorator __init__ methods; ABCMeta.__new__ co_varnames[5]='cls' len=3 (shortest element in this spec: shorter even than 'mcls'=4; 'cls' is a local not a parameter); ABCMeta.__new__ co_varnames[1]='name' len=4 (tied with 'mcls'=4, 'self'=4); ABCMeta.__new__ co_varnames[2]='bases' len=5; abstractclassmethod.__init__ co_varnames[1]='callable' len=8 (tied with abstractstaticmethod co_varnames[1]='callable'=8; 'callable'=8 is 1 longer than 'funcobj'=7 covered in extra114); ABCMeta.__new__ co_varnames[3]='namespace' len=9 (longest element in spec: 1 more than 'callable'=8 and 'abstracts'=9 from extra114; 'namespace'=9 chars is the longest single-param element across all abc specs in this series); length ordering: cls=3 < mcls==name==self=4 (tied) < bases=5 < kwargs=6 < funcobj=7 (from extra114) < callable=8 (tied: acm/asm) < namespace==abstracts=9 (tied at longest: 'namespace' from ABCMeta.__new__ and 'abstracts' from update_abstractmethods covered in extra114); all elements are plain Python strings from the code object co_varnames tuple; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abcnew115b

  columns: [id, function, args, expected, description]
  rows:
    - [cls_3,       "abc.ABCMeta.__new__.__code__.co_varnames[5].__len__",               [], 3, "ABCMeta.__new__ co_varnames[5]='cls' len=3 (shortest element in spec); verified with Python 3.14.3"]
    - [name_4,      "abc.ABCMeta.__new__.__code__.co_varnames[1].__len__",               [], 4, "ABCMeta.__new__ co_varnames[1]='name' len=4 (tied with mcls=4); verified with Python 3.14.3"]
    - [bases_5,     "abc.ABCMeta.__new__.__code__.co_varnames[2].__len__",               [], 5, "ABCMeta.__new__ co_varnames[2]='bases' len=5; verified with Python 3.14.3"]
    - [kwargs_6,    "abc.ABCMeta.__new__.__code__.co_varnames[4].__len__",               [], 6, "ABCMeta.__new__ co_varnames[4]='kwargs' len=6; verified with Python 3.14.3"]
    - [callable_8,  "abc.abstractclassmethod.__init__.__code__.co_varnames[1].__len__",  [], 8, "abstractclassmethod.__init__ co_varnames[1]='callable' len=8 (tied with abstractstaticmethod); verified with Python 3.14.3"]
    - [namespace_9, "abc.ABCMeta.__new__.__code__.co_varnames[3].__len__",               [], 9, "ABCMeta.__new__ co_varnames[3]='namespace' len=9 (longest in spec, tied with 'abstracts'=9); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra115
# ---------------------------------------------------------------------------

invariant abc_extra115.ABCMeta_new_v3_namespace:
  description: "abc.ABCMeta.__new__.__code__.co_varnames[3].__eq__('namespace') returns True — ABCMeta.__new__ co_varnames[3]='namespace' (len=9; the longest element in ABCMeta.__new__ co_varnames); namespace is the class namespace dictionary that is populated during the execution of the class body; it is constructed by type.__prepare__() (or ABCMeta.__prepare__ if defined) and passed to ABCMeta.__new__ along with the class name and bases; in Python, the class body is executed in the namespace dict, and each name defined in the class body (methods, attributes) becomes a key in namespace; ABCMeta.__new__.__code__.co_varnames[3].__len__()==9 ('namespace'=9: 'name'=4+'space'=5=9); compare: co_varnames[2]='bases'=5 (4 shorter), co_varnames[4]='kwargs'=6 (3 shorter), co_varnames[5]='cls'=3 (6 shorter); 'namespace'=9 is tied with 'abstracts'=9 (from extra114: update_abstractmethods co_varnames[1]) as the joint-longest element name across abc specs; ABCMeta.__new__.__code__.co_qualname=='ABCMeta.__new__' (len=15); first standalone ABCMeta.__new__ co_varnames[3] equality invariant in abcnew115 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "abc.ABCMeta.__new__.__code__.co_varnames[3].__eq__"
  args: ["namespace"]
  expected: true

invariant abc_extra115.ABCMeta_new_v2_bases:
  description: "abc.ABCMeta.__new__.__code__.co_varnames[2].__eq__('bases') returns True — ABCMeta.__new__ co_varnames[2]='bases' (len=5); bases is the tuple of base classes passed to the class statement (e.g., class Foo(Bar, Baz): gives bases==(Bar, Baz)); ABCMeta.__new__ receives bases and passes it to type.__new__ to construct the class; ABCMeta.__new__.__code__.co_varnames[2].__len__()==5 ('bases'=5: between 'name'=4 and 'kwargs'=6); co_argcount==4 (mcls,name,bases,namespace are the 4 positional params; kwargs is VAR_KEYWORD at index 4 in co_varnames); ABCMeta.__new__ inspects all items in namespace to find abstract methods and sets cls.__abstractmethods__ to a frozenset of those names; ABCMeta.__new__.__code__.co_qualname=='ABCMeta.__new__' (len=15); compare: 'bases'=5 > 'name'=4 (1 more) < 'namespace'=9 (4 less than namespace); first standalone ABCMeta.__new__ co_varnames[2] equality invariant in abcnew115 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "abc.ABCMeta.__new__.__code__.co_varnames[2].__eq__"
  args: ["bases"]
  expected: true

invariant abc_extra115.abstractclassmethod_init_v1_callable:
  description: "abc.abstractclassmethod.__init__.__code__.co_varnames[1].__eq__('callable') returns True — abstractclassmethod.__init__ co_varnames[1]='callable' (len=8); co_varnames==('self','callable') len=2; 'callable' is used (not 'fn' or 'func') because abstractclassmethod wraps any callable object as a classmethod+abstract combination; abstractclassmethod is deprecated since Python 3.3: the recommended alternative is @classmethod combined with @abstractmethod in a class using ABCMeta; abstractclassmethod.__init__.__code__.co_qualname=='abstractclassmethod.__init__' (len=28: 'abstractclassmethod.'=20+'__init__'=8=28); co_argcount==2 (self and callable); compare: abstractstaticmethod.__init__ co_varnames[1] also =='callable' (len=8, same — both deprecated decorators use the same parameter name consistently); abstractmethod co_varnames[0]='funcobj' (len=7, 1 shorter than 'callable'=8; note abstractmethod uses index 0 while abstractclassmethod uses index 1 because 'self' is at index 0); abstractclassmethod.__name__='abstractclassmethod' (len=19); first standalone abstractclassmethod.__init__ co_varnames[1] equality invariant in abcnew115 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "abc.abstractclassmethod.__init__.__code__.co_varnames[1].__eq__"
  args: ["callable"]
  expected: true

invariant abc_extra115.abstractstaticmethod_init_v1_callable:
  description: "abc.abstractstaticmethod.__init__.__code__.co_varnames[1].__eq__('callable') returns True — abstractstaticmethod.__init__ co_varnames[1]='callable' (len=8); co_varnames==('self','callable') len=2; tied with abstractclassmethod.__init__ co_varnames[1]='callable' (both have the same parameter name 'callable' at the same index 1; this symmetric naming is intentional — both deprecated abstract decorators use 'callable' consistently); abstractstaticmethod is deprecated since Python 3.3: use @staticmethod combined with @abstractmethod instead; abstractstaticmethod.__init__.__code__.co_qualname=='abstractstaticmethod.__init__' (len=29: 'abstractstaticmethod.'=21+'__init__'=8=29; 1 more than abstractclassmethod=28: 'abstractstaticmethod'=20 vs 'abstractclassmethod'=19, diff=1); co_argcount==2 (self and callable); compare: ABCMeta.__new__ co_varnames[5]='cls' len=3 (5 shorter than 'callable'=8); ABCMeta.__new__ co_varnames[3]='namespace' len=9 (1 longer than 'callable'=8); abstractstaticmethod.__name__='abstractstaticmethod' (len=20); first standalone abstractstaticmethod.__init__ co_varnames[1] equality invariant in abcnew115 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "abc.abstractstaticmethod.__init__.__code__.co_varnames[1].__eq__"
  args: ["callable"]
  expected: true

invariant abc_extra115.ABCMeta_new_v5_cls:
  description: "abc.ABCMeta.__new__.__code__.co_varnames[5].__eq__('cls') returns True — ABCMeta.__new__ co_varnames[5]='cls' (len=3; the shortest element in ABCMeta.__new__ co_varnames and in this spec); cls is a local variable (index 5 is beyond co_argcount==4, so it is a local, not a parameter) that holds the newly created class after calling super().__new__(mcls,name,bases,namespace,**kwargs); ABCMeta.__new__ then sets cls.__abstractmethods__ to a frozenset of abstract method names found in the namespace; ABCMeta.__new__.__code__.co_varnames[5].__len__()==3 ('cls'=3: 3 chars, shorter even than 'mcls'=4 at index 0); compare: co_varnames[0]='mcls'=4 (1 more than 'cls'=3: 'mcls' adds 'm' prefix); co_varnames[1]='name'=4 (1 more than 'cls'=3); 'cls'=3 is the shortest element in co_varnames for ABCMeta.__new__ (and also shorter than 'abstracts'=9, 'namespace'=9, 'callable'=8 that appear in other abc specs); ABCMeta.__new__.__code__.co_qualname=='ABCMeta.__new__' (len=15); ABCMeta.__module__=='abc' (len=3); first standalone ABCMeta.__new__ co_varnames[5] equality invariant in abcnew115 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "abc.ABCMeta.__new__.__code__.co_varnames[5].__eq__"
  args: ["cls"]
  expected: true
