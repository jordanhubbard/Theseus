spec: figlet
version: ">=1.0.0"
backend: node(figlet)

docs: https://github.com/patorjk/figlet.js#readme

provenance:
  derived_from:
    - "figlet.js README — https://github.com/patorjk/figlet.js#readme"
    - "FIGfont specification — http://www.jave.de/figlet/figfont.html"
    - "Test vectors verified with figlet via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "figlet source"
  notes:
    - "figlet renders ASCII-art banner text using FIGfont definitions."
    - "Install: npm install figlet"
    - "textSync(text, options) is the synchronous variant; defaults to the 'Standard' font."
    - "Output is deterministic for a given font + text + layout settings."
    - "fontsSync() returns the alphabetized list of bundled fonts."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; throws when an unknown font is requested."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# textSync('A') with the default font — exact output equality
invariant figlet.textSync_letter_A_standard:
  description: "textSync('A') with Standard font produces a known 6-line banner"
  category: render
  kind: node_chain_eq
  entry: named
  function: textSync
  entry_args: ["A"]
  chain: []
  expected: "     _    \n    / \\   \n   / _ \\  \n  / ___ \\ \n /_/   \\_\\\n          "

invariant figlet.textSync_letter_A_height:
  description: "Standard font produces 6-line output (5 height + 1 trailing blank)"
  category: render
  kind: node_chain_eq
  entry: named
  function: textSync
  entry_args: ["A"]
  chain:
    - {method: split, args: ["\n"]}
    - {get: length}
  expected: 6

invariant figlet.textSync_letter_A_width_10:
  description: "Standard font for 'A' produces 10-column-wide rows"
  category: render
  kind: node_chain_eq
  entry: named
  function: textSync
  entry_args: ["A"]
  chain:
    - {method: split, args: ["\n"]}
    - {method: at, args: [0]}
    - {get: length}
  expected: 10

# textSync with explicit font option
invariant figlet.textSync_explicit_standard_matches_default:
  description: "textSync('A', {font:'Standard'}) matches default-font output"
  category: render
  kind: node_chain_eq
  entry: named
  function: textSync
  entry_args: ["A", {font: "Standard"}]
  chain: []
  expected: "     _    \n    / \\   \n   / _ \\  \n  / ___ \\ \n /_/   \\_\\\n          "

# fontsSync registry
invariant figlet.fontsSync_includes_standard:
  description: "fontsSync() includes 'Standard'"
  category: registry
  kind: node_chain_eq
  entry: named
  function: fontsSync
  entry_args: []
  chain:
    - {method: includes, args: ["Standard"]}
  expected: true

invariant figlet.fontsSync_includes_3d_diagonal:
  description: "fontsSync() includes '3D Diagonal'"
  category: registry
  kind: node_chain_eq
  entry: named
  function: fontsSync
  entry_args: []
  chain:
    - {method: includes, args: ["3D Diagonal"]}
  expected: true

# Multi-character text — 'Hi' in standard font
invariant figlet.textSync_Hi:
  description: "textSync('Hi') produces a known 6-line banner with 11-char width"
  category: render
  kind: node_chain_eq
  entry: named
  function: textSync
  entry_args: ["Hi"]
  chain: []
  expected: "  _   _ _ \n | | | (_)\n | |_| | |\n |  _  | |\n |_| |_|_|\n          "
