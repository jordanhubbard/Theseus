spec: selectors_extra2
version: ">=3.9"
backend: python_module(selectors)

docs: https://docs.python.org/3/library/selectors.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/selectors.html — Python selectors module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/selectors.py"
  notes:
    - "Extends selectors.zspec.zsdl and selectors_extra.zspec.zsdl with additional invariants."
    - "selectors.EVENT_READ == 1 and selectors.EVENT_WRITE == 2 are the correct CPython values."
    - "SelectorKey is a namedtuple with exactly 4 fields: fileobj, fd, events, data."
    - "SelectorKey._fields is a tuple of strings; each field name is accessible by index."
    - "SelectorKey.__module__ == 'selectors' — the namedtuple is defined in the selectors module."
    - "SelectSelector.__module__ == 'selectors' — module affiliation of the select()-based selector."
    - "BaseSelector is an abstract class; its __module__ == 'selectors'."
    - "EVENT_READ | EVENT_WRITE == 3 — combined read/write interest mask."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SelectorKey — module and namedtuple field count
# ---------------------------------------------------------------------------

invariant selectors_extra2.SelectorKey.module:
  description: "selectors.SelectorKey.__module__ == 'selectors'"
  category: classnames
  kind: python_call_eq
  function: SelectorKey.__module__.__eq__
  args: ["selectors"]
  expected: true

invariant selectors_extra2.SelectorKey.fields_len:
  description: "len(selectors.SelectorKey._fields) == 4 — SelectorKey has exactly 4 named fields"
  category: namedtuple_fields
  kind: python_call_eq
  function: SelectorKey._fields.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# SelectorKey._fields — field values by index
# ---------------------------------------------------------------------------

invariant selectors_extra2.SelectorKey.field0:
  description: "selectors.SelectorKey._fields[0] == 'fileobj'"
  category: namedtuple_fields
  kind: python_call_eq
  function: SelectorKey._fields.__getitem__
  args: [0]
  expected: "fileobj"

invariant selectors_extra2.SelectorKey.field1:
  description: "selectors.SelectorKey._fields[1] == 'fd'"
  category: namedtuple_fields
  kind: python_call_eq
  function: SelectorKey._fields.__getitem__
  args: [1]
  expected: "fd"

invariant selectors_extra2.SelectorKey.field2:
  description: "selectors.SelectorKey._fields[2] == 'events'"
  category: namedtuple_fields
  kind: python_call_eq
  function: SelectorKey._fields.__getitem__
  args: [2]
  expected: "events"

invariant selectors_extra2.SelectorKey.field3:
  description: "selectors.SelectorKey._fields[3] == 'data'"
  category: namedtuple_fields
  kind: python_call_eq
  function: SelectorKey._fields.__getitem__
  args: [3]
  expected: "data"

# ---------------------------------------------------------------------------
# SelectorKey — base class (namedtuple → tuple)
# ---------------------------------------------------------------------------

invariant selectors_extra2.SelectorKey.base_class:
  description: "selectors.SelectorKey.__bases__[0].__name__ == 'tuple' — SelectorKey is a namedtuple subclass"
  category: hierarchy
  kind: python_call_eq
  function: SelectorKey.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "tuple"

# ---------------------------------------------------------------------------
# SelectSelector — module affiliation
# ---------------------------------------------------------------------------

invariant selectors_extra2.SelectSelector.module:
  description: "selectors.SelectSelector.__module__ == 'selectors'"
  category: classnames
  kind: python_call_eq
  function: SelectSelector.__module__.__eq__
  args: ["selectors"]
  expected: true

# ---------------------------------------------------------------------------
# BaseSelector — class name and module (cross-check with selectors.zspec)
# ---------------------------------------------------------------------------

invariant selectors_extra2.BaseSelector.name:
  description: "selectors.BaseSelector.__name__ == 'BaseSelector'"
  category: classnames
  kind: python_call_eq
  function: BaseSelector.__name__.__eq__
  args: ["BaseSelector"]
  expected: true

invariant selectors_extra2.BaseSelector.module:
  description: "selectors.BaseSelector.__module__ == 'selectors'"
  category: classnames
  kind: python_call_eq
  function: BaseSelector.__module__.__eq__
  args: ["selectors"]
  expected: true

# ---------------------------------------------------------------------------
# DefaultSelector — class name (platform-specific alias)
# ---------------------------------------------------------------------------

invariant selectors_extra2.DefaultSelector.name:
  description: "selectors.DefaultSelector.__name__ == 'KqueueSelector' on macOS (platform alias)"
  category: classnames
  kind: python_call_eq
  function: DefaultSelector.__name__.__eq__
  args: ["KqueueSelector"]
  expected: true

# ---------------------------------------------------------------------------
# EVENT_READ and EVENT_WRITE — values
# ---------------------------------------------------------------------------

invariant selectors_extra2.EVENT_READ.value:
  description: "selectors.EVENT_READ == 1 — read-ready bitmask"
  category: constants
  kind: python_call_eq
  function: EVENT_READ.__eq__
  args: [1]
  expected: true

invariant selectors_extra2.EVENT_WRITE.value:
  description: "selectors.EVENT_WRITE == 2 — write-ready bitmask"
  category: constants
  kind: python_call_eq
  function: EVENT_WRITE.__eq__
  args: [2]
  expected: true
