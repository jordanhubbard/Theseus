spec: uuid_extra60
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra59.zspec.zsdl — covers uuid4/uuid1/uuid3/uuid5 __kwdefaults__/__class__/__name__=='NoneType' / UUID.__init__/__kwdefaults__/__class__/__name__=='dict' / UUID.__init__/__kwdefaults__/__len__()==1 / UUID.__init__/__code__.co_name=='__init__' / UUID.__init__/__code__.co_argcount==7 / UUID.__repr__/__qualname__=='UUID.__repr__' / UUID.__str__/__qualname__=='UUID.__str__' (table + invariants)."
    - "uuid_extra58.zspec.zsdl — covers uuid4/uuid3/uuid5 __defaults__/__class__/__name__=='NoneType' / uuid1/__defaults__/__class__/__name__=='tuple' / uuid1/__defaults__/__len__()==2 / uuid1/__defaults__[0]/__class__/__name__=='NoneType' / UUID.__init__/__defaults__/__class__/__name__=='tuple' / UUID.__init__/__defaults__/__len__()==6 (table + invariants)."
    - "uuid_extra57.zspec.zsdl — covers uuid4/__code__.co_consts/__class__/__name__=='tuple' / uuid1/__code__.co_consts/__class__/__name__=='tuple' / co_nlocals/__class__/__name__=='int' / co_stacksize/__class__/__name__=='int' / UUID.__name__=='UUID' / UUID.__module__=='uuid' / UUID.__qualname__=='UUID' / UUID.__bases__[0].__name__=='object' / UUID.__mro__.__len__()==2 (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra59; it does NOT duplicate invariants present in those files."
    - "Wave 235 theme: UUID method code object attributes (__repr__/__str__/__hash__/__eq__ co_name and co_argcount) + SafeUUID class identity and hierarchy."
    - "uuid.UUID.__repr__.__code__.co_name == '__repr__' — UUID.__repr__ is a Python function in Lib/uuid.py; the code object co_name reflects the function name '__repr__'. No prior uuid spec checks UUID.__repr__.__code__.co_name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__code__.co_argcount == 1 — UUID.__repr__(self) has one positional parameter; co_argcount is 1. No prior uuid spec checks UUID.__repr__.__code__.co_argcount. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__code__.co_name == '__str__' — UUID.__str__ is a Python function; co_name is '__str__'. No prior uuid spec checks UUID.__str__.__code__.co_name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__code__.co_argcount == 1 — UUID.__str__(self) has one positional parameter; co_argcount is 1. No prior uuid spec checks UUID.__str__.__code__.co_argcount. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__code__.co_name == '__hash__' — UUID.__hash__ is a Python function; co_name is '__hash__'. No prior uuid spec checks UUID.__hash__.__code__.co_name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__code__.co_argcount == 1 — UUID.__hash__(self) has one positional parameter; co_argcount is 1. No prior uuid spec checks UUID.__hash__.__code__.co_argcount. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__code__.co_name == '__eq__' — UUID.__eq__ is a Python function; co_name is '__eq__'. No prior uuid spec checks UUID.__eq__.__code__.co_name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__code__.co_argcount == 2 — UUID.__eq__(self, other) has two positional parameters; co_argcount is 2. No prior uuid spec checks UUID.__eq__.__code__.co_argcount. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__class__.__name__ == 'type' — SafeUUID is an IntEnum subclass defined in Lib/uuid.py; as a class (type) its __class__.__name__ is 'type'. No prior uuid spec checks SafeUUID.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__name__ == 'SafeUUID' — SafeUUID is the class name; __name__ is 'SafeUUID'. No prior uuid spec checks SafeUUID.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__module__ == 'uuid' — SafeUUID is defined in Lib/uuid.py; __module__ is 'uuid'. No prior uuid spec checks SafeUUID.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__qualname__ == 'SafeUUID' — SafeUUID is a top-level class; __qualname__ is 'SafeUUID'. No prior uuid spec checks SafeUUID.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__bases__[0].__name__ == 'IntEnum' — SafeUUID inherits from IntEnum; __bases__[0].__name__ is 'IntEnum'. The [0] subscript requires double-quoting in table rows. No prior uuid spec checks SafeUUID.__bases__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UUID.__repr__ / __str__ / __hash__ / __eq__ co_name values
#
# Wave 235 theme: UUID method code object co_name attributes.
#
# uuid.UUID is a pure-Python class in Lib/uuid.py. Its methods __repr__,
# __str__, __hash__, and __eq__ are Python functions. Each code object has
# co_name equal to the method name. No prior uuid spec checks co_name for
# any of these four methods. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra60.UUID_method_co_names:
  description: "uuid.UUID.__repr__/__code__.co_name=='__repr__' / UUID.__str__/__code__.co_name=='__str__' / UUID.__hash__/__code__.co_name=='__hash__' / UUID.__eq__/__code__.co_name=='__eq__' — UUID is a pure-Python class; all four methods have code objects with co_name equal to the method name; no prior uuid spec checks co_name for __repr__/__str__/__hash__/__eq__; first co_name anchor for UUID comparison and display methods"
  kind: python_call_eq
  category: code_attrs
  id_prefix: uuidmore60

  columns: [id, function, args, expected]
  rows:
    - [UUID_repr_code_co_name_repr,  UUID.__repr__.__code__.co_name.__eq__, ["__repr__"], true]
    - [UUID_str_code_co_name_str,    UUID.__str__.__code__.co_name.__eq__,  ["__str__"],  true]
    - [UUID_hash_code_co_name_hash,  UUID.__hash__.__code__.co_name.__eq__, ["__hash__"], true]
    - [UUID_eq_code_co_name_eq,      UUID.__eq__.__code__.co_name.__eq__,   ["__eq__"],   true]

# ---------------------------------------------------------------------------
# UUID.__repr__ / __str__ / __hash__ / __eq__ co_argcount values
#
# Wave 235 theme: UUID method code object co_argcount attributes.
#
# UUID.__repr__(self), __str__(self), and __hash__(self) each have one
# positional parameter; co_argcount is 1. UUID.__eq__(self, other) has two
# positional parameters; co_argcount is 2. No prior uuid spec checks
# co_argcount for these four methods. Verified Python 3.14.3 macOS/Darwin.
# ---------------------------------------------------------------------------

table uuid_extra60.UUID_method_co_argcounts:
  description: "uuid.UUID.__repr__/__code__.co_argcount==1 / UUID.__str__/__code__.co_argcount==1 / UUID.__hash__/__code__.co_argcount==1 / UUID.__eq__/__code__.co_argcount==2 — __repr__/__str__/__hash__ each take only self (co_argcount==1); __eq__ takes self and other (co_argcount==2); no prior uuid spec checks co_argcount for __repr__/__str__/__hash__/__eq__; first co_argcount anchor for UUID comparison and display methods"
  kind: python_call_eq
  category: code_attrs
  id_prefix: uuidmore60

  columns: [id, function, args, expected]
  rows:
    - [UUID_repr_code_co_argcount_1,  UUID.__repr__.__code__.co_argcount.__eq__, [1], true]
    - [UUID_str_code_co_argcount_1,   UUID.__str__.__code__.co_argcount.__eq__,  [1], true]
    - [UUID_hash_code_co_argcount_1,  UUID.__hash__.__code__.co_argcount.__eq__, [1], true]
    - [UUID_eq_code_co_argcount_2,    UUID.__eq__.__code__.co_argcount.__eq__,   [2], true]

# ---------------------------------------------------------------------------
# uuid.SafeUUID class identity — __class__.__name__, __name__, __module__, __qualname__
#
# Wave 235 theme: SafeUUID class identity attributes.
#
# uuid.SafeUUID is an IntEnum subclass defined at module level in Lib/uuid.py.
# As a class, its __class__.__name__ is 'type'. Its __name__ is 'SafeUUID',
# __module__ is 'uuid', and __qualname__ is 'SafeUUID'. No prior uuid spec
# checks any attribute of SafeUUID. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra60.SafeUUID_identity:
  description: "uuid.SafeUUID/__class__/__name__=='type' / SafeUUID/__name__=='SafeUUID' / SafeUUID/__module__=='uuid' / SafeUUID/__qualname__=='SafeUUID' — SafeUUID is an IntEnum subclass defined at module level in Lib/uuid.py; as a class its __class__.__name__ is 'type'; __name__/__module__/__qualname__ are 'SafeUUID'/'uuid'/'SafeUUID'; no prior uuid spec checks any attribute of SafeUUID; first identity anchor for uuid.SafeUUID"
  kind: python_call_eq
  category: class_identity
  id_prefix: uuidmore60

  columns: [id, function, args, expected]
  rows:
    - [SafeUUID_class_name_type,      SafeUUID.__class__.__name__.__eq__, ["type"],     true]
    - [SafeUUID_name_SafeUUID,        SafeUUID.__name__.__eq__,           ["SafeUUID"], true]
    - [SafeUUID_module_uuid,          SafeUUID.__module__.__eq__,         ["uuid"],     true]
    - [SafeUUID_qualname_SafeUUID,    SafeUUID.__qualname__.__eq__,       ["SafeUUID"], true]

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__bases__[0].__name__ == 'IntEnum'
#
# Wave 235 theme: SafeUUID inheritance hierarchy.
#
# uuid.SafeUUID inherits from IntEnum. Its __bases__ tuple has one element
# (IntEnum). __bases__[0].__name__ is 'IntEnum'. The [0] subscript in the
# function chain requires double-quoting in table rows. No prior uuid spec
# checks SafeUUID.__bases__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra60.SafeUUID_hierarchy:
  description: "uuid.SafeUUID/__bases__[0]/__name__=='IntEnum' — SafeUUID inherits from IntEnum; __bases__[0].__name__ is 'IntEnum'; the [0] subscript requires double-quoting of the function value in this table row; no prior uuid spec checks SafeUUID.__bases__; first hierarchy anchor for uuid.SafeUUID"
  kind: python_call_eq
  category: hierarchy
  id_prefix: uuidmore60

  columns: [id, function, args, expected]
  rows:
    - [SafeUUID_bases_0_name_IntEnum, "SafeUUID.__bases__[0].__name__.__eq__", ["IntEnum"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__repr__.__code__.co_name.__eq__('__repr__') — standalone
#
# uuid.UUID.__repr__ is a Python function in Lib/uuid.py. Its code object
# co_name is '__repr__'. No prior uuid spec checks UUID.__repr__.__code__.co_name.
# First co_name anchor for uuid.UUID.__repr__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra60.UUID_repr_co_name:
  description: "uuid.UUID.__repr__.__code__.co_name.__eq__('__repr__') == True — UUID.__repr__ is a Python function; co_name is '__repr__'; no prior uuid spec checks UUID.__repr__.__code__.co_name; first co_name anchor for uuid.UUID.__repr__"
  category: code_attrs
  kind: python_call_eq
  function: UUID.__repr__.__code__.co_name.__eq__
  args: ["__repr__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__repr__.__code__.co_argcount.__eq__(1) — standalone
#
# uuid.UUID.__repr__(self) has one positional parameter; co_argcount is 1.
# No prior uuid spec checks UUID.__repr__.__code__.co_argcount. First
# co_argcount anchor for uuid.UUID.__repr__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra60.UUID_repr_co_argcount_1:
  description: "uuid.UUID.__repr__.__code__.co_argcount.__eq__(1) == True — UUID.__repr__(self) has one positional parameter; co_argcount is 1; no prior uuid spec checks UUID.__repr__.__code__.co_argcount; first co_argcount anchor for uuid.UUID.__repr__"
  category: code_attrs
  kind: python_call_eq
  function: UUID.__repr__.__code__.co_argcount.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__eq__.__code__.co_argcount.__eq__(2) — standalone
#
# uuid.UUID.__eq__(self, other) has two positional parameters; co_argcount is
# 2. No prior uuid spec checks UUID.__eq__.__code__.co_argcount. First
# co_argcount anchor for uuid.UUID.__eq__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra60.UUID_eq_co_argcount_2:
  description: "uuid.UUID.__eq__.__code__.co_argcount.__eq__(2) == True — UUID.__eq__(self, other) has two positional parameters; co_argcount is 2; no prior uuid spec checks UUID.__eq__.__code__.co_argcount; first co_argcount anchor for uuid.UUID.__eq__"
  category: code_attrs
  kind: python_call_eq
  function: UUID.__eq__.__code__.co_argcount.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__class__.__name__.__eq__('type') — standalone
#
# uuid.SafeUUID is an IntEnum subclass. As a class, its __class__.__name__ is
# 'type'. No prior uuid spec checks SafeUUID.__class__.__name__. First class
# identity standalone for uuid.SafeUUID.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra60.SafeUUID_class_type:
  description: "uuid.SafeUUID.__class__.__name__.__eq__('type') == True — SafeUUID is an IntEnum subclass; as a class its __class__.__name__ is 'type'; no prior uuid spec checks SafeUUID.__class__.__name__; first class identity standalone for uuid.SafeUUID"
  category: class_identity
  kind: python_call_eq
  function: SafeUUID.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__module__.__eq__('uuid') — standalone
#
# uuid.SafeUUID is defined in Lib/uuid.py. Its __module__ is 'uuid'. No prior
# uuid spec checks SafeUUID.__module__. First module identity standalone for
# uuid.SafeUUID. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra60.SafeUUID_module_uuid:
  description: "uuid.SafeUUID.__module__.__eq__('uuid') == True — SafeUUID is defined in Lib/uuid.py; __module__ is 'uuid'; no prior uuid spec checks SafeUUID.__module__; first module identity standalone for uuid.SafeUUID"
  category: class_identity
  kind: python_call_eq
  function: SafeUUID.__module__.__eq__
  args: ["uuid"]
  expected: true
