table struct_extra1561.error_numeric_protocol:
  description: "struct.error defines no numeric conversion protocol methods in its own __dict__ — st1561en namespace. struct.error is the exception class raised by struct for format string errors and pack/unpack mismatches; it inherits from Exception; exception classes are not numeric types and define no numeric conversion protocol; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: numeric_protocol_presence
  id_prefix: st1561en

  columns: [id, function, args, expected, description]
  rows:
    - [st1561en001, struct.error.__dict__.__contains__, ["__bool__"],    false, "struct.error.__dict__.__contains__('__bool__')==False — struct.error is an exception class; no __bool__ in its __dict__; verified with Python 3.14.3"]
    - [st1561en002, struct.error.__dict__.__contains__, ["__int__"],     false, "struct.error.__dict__.__contains__('__int__')==False — struct.error defines no __int__ in its own __dict__; verified with Python 3.14.3"]
    - [st1561en003, struct.error.__dict__.__contains__, ["__float__"],   false, "struct.error.__dict__.__contains__('__float__')==False — struct.error defines no __float__ in its own __dict__; verified with Python 3.14.3"]
    - [st1561en004, struct.error.__dict__.__contains__, ["__index__"],   false, "struct.error.__dict__.__contains__('__index__')==False — struct.error defines no __index__ in its own __dict__; verified with Python 3.14.3"]
    - [st1561en005, struct.error.__dict__.__contains__, ["__trunc__"],   false, "struct.error.__dict__.__contains__('__trunc__')==False — math.trunc() not supported by struct.error; verified with Python 3.14.3"]
    - [st1561en006, struct.error.__dict__.__contains__, ["__floor__"],   false, "struct.error.__dict__.__contains__('__floor__')==False — math.floor() not supported by struct.error; verified with Python 3.14.3"]
    - [st1561en007, struct.error.__dict__.__contains__, ["__ceil__"],    false, "struct.error.__dict__.__contains__('__ceil__')==False — math.ceil() not supported by struct.error; verified with Python 3.14.3"]
    - [st1561en008, struct.error.__dict__.__contains__, ["__round__"],   false, "struct.error.__dict__.__contains__('__round__')==False — round() not supported by struct.error; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: struct.Struct — actual interface attribute presence (positive checks)
#
# Confirms: 'pack', 'unpack', 'pack_into', 'unpack_from', 'iter_unpack',
#           'size', 'format', '__new__', '__repr__' are in Struct.__dict__
# ---------------------------------------------------------------------------

table struct_extra1561.struct_interface_presence:
  description: "struct.Struct defines its binary packing interface in its own __dict__ — st1561si namespace. These positive checks confirm Struct owns: pack (packs values into bytes), unpack (unpacks bytes to tuple), pack_into (packs into a buffer), unpack_from (unpacks from a buffer offset), iter_unpack (iterator over repeated unpacks), size (byte size of one packed instance), format (the format string), __new__, __repr__; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st1561si

  columns: [id, function, args, expected, description]
  rows:
    - [st1561si001, struct.Struct.__dict__.__contains__, ["pack"],        true,  "struct.Struct.__dict__.__contains__('pack')==True — Struct.pack() packs values into bytes according to the format; verified with Python 3.14.3"]
    - [st1561si002, struct.Struct.__dict__.__contains__, ["unpack"],      true,  "struct.Struct.__dict__.__contains__('unpack')==True — Struct.unpack() unpacks bytes into a tuple of values; verified with Python 3.14.3"]
    - [st1561si003, struct.Struct.__dict__.__contains__, ["pack_into"],   true,  "struct.Struct.__dict__.__contains__('pack_into')==True — Struct.pack_into() packs values into a writable buffer at an offset; verified with Python 3.14.3"]
    - [st1561si004, struct.Struct.__dict__.__contains__, ["unpack_from"], true,  "struct.Struct.__dict__.__contains__('unpack_from')==True — Struct.unpack_from() unpacks from a buffer starting at an optional offset; verified with Python 3.14.3"]
    - [st1561si005, struct.Struct.__dict__.__contains__, ["iter_unpack"], true,  "struct.Struct.__dict__.__contains__('iter_unpack')==True — Struct.iter_unpack() returns an iterator yielding successive unpacked tuples; verified with Python 3.14.3"]
    - [st1561si006, struct.Struct.__dict__.__contains__, ["size"],        true,  "struct.Struct.__dict__.__contains__('size')==True — Struct.size is the number of bytes packed per call; verified with Python 3.14.3"]
    - [st1561si007, struct.Struct.__dict__.__contains__, ["format"],      true,  "struct.Struct.__dict__.__contains__('format')==True — Struct.format is the compiled format string; verified with Python 3.14.3"]
    - [st1561si008, struct.Struct.__dict__.__contains__, ["__new__"],     true,  "struct.Struct.__dict__.__contains__('__new__')==True — Struct.__new__ IS in Struct.__dict__; C-level constructor accepting the format string; verified with Python 3.14.3"]
