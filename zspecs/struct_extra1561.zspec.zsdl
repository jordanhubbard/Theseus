spec: struct_extra1561
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "IEEE 754 — Binary floating-point arithmetic standard"
  notes:
    - "Wave 551 (_extra1561): numeric type conversion protocol dict-presence checks for struct classes."
    - "struct.Struct is a compiled format object (C type from _struct module); it is not a numeric type."
    - "struct.Struct.__dict__ contains only: __new__, __repr__, __getattribute__, __setattr__, __delattr__, __init__, __sizeof__, __doc__, __module__ plus pack/unpack attrs."
    - "struct.error is the exception class for struct errors; it inherits from Exception; no numeric protocol in its __dict__."
    - "Verified: no numeric conversion dunders (__bool__, __int__, __float__, __complex__, __index__, __trunc__, __floor__, __ceil__, __round__) in struct.Struct.__dict__ or struct.error.__dict__; verified with Python 3.14.3."
    - "struct.Struct.__module__ == '_struct' (implemented in C); verified with Python 3.14.3."
    - "struct.error.__module__ == 'struct'; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: struct.Struct — numeric conversion protocol dict-presence (all False)
#
# struct.Struct.__dict__.__contains__('__bool__')    == False
# struct.Struct.__dict__.__contains__('__int__')     == False
# struct.Struct.__dict__.__contains__('__float__')   == False
# struct.Struct.__dict__.__contains__('__complex__') == False
# struct.Struct.__dict__.__contains__('__index__')   == False
# struct.Struct.__dict__.__contains__('__trunc__')   == False
# struct.Struct.__dict__.__contains__('__floor__')   == False
# struct.Struct.__dict__.__contains__('__ceil__')    == False
# struct.Struct.__dict__.__contains__('__round__')   == False
# ---------------------------------------------------------------------------

table struct_extra1561.struct_numeric_protocol:
  description: "struct.Struct defines no numeric conversion protocol methods in its own __dict__ — st1561sn namespace. struct.Struct is a compiled binary format descriptor; it parses format strings and packs/unpacks binary data; it is purely a data serialization helper, not a numeric type; none of the numeric protocol dunders appear in struct.Struct.__dict__; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: numeric_protocol_presence
  id_prefix: st1561sn

  columns: [id, function, args, expected, description]
  rows:
    - [st1561sn001, struct.Struct.__dict__.__contains__, ["__bool__"],    false, "struct.Struct.__dict__.__contains__('__bool__')==False — Struct is a format descriptor, not a boolean type; verified with Python 3.14.3"]
    - [st1561sn002, struct.Struct.__dict__.__contains__, ["__int__"],     false, "struct.Struct.__dict__.__contains__('__int__')==False — Struct cannot be converted to int; no __int__ in Struct.__dict__; verified with Python 3.14.3"]
    - [st1561sn003, struct.Struct.__dict__.__contains__, ["__float__"],   false, "struct.Struct.__dict__.__contains__('__float__')==False — Struct cannot be converted to float; no __float__ in Struct.__dict__; verified with Python 3.14.3"]
    - [st1561sn004, struct.Struct.__dict__.__contains__, ["__complex__"], false, "struct.Struct.__dict__.__contains__('__complex__')==False — Struct defines no __complex__; verified with Python 3.14.3"]
    - [st1561sn005, struct.Struct.__dict__.__contains__, ["__index__"],   false, "struct.Struct.__dict__.__contains__('__index__')==False — Struct cannot be used as a sequence index; no __index__ in Struct.__dict__; verified with Python 3.14.3"]
    - [st1561sn006, struct.Struct.__dict__.__contains__, ["__trunc__"],   false, "struct.Struct.__dict__.__contains__('__trunc__')==False — math.trunc() protocol not supported by Struct; verified with Python 3.14.3"]
    - [st1561sn007, struct.Struct.__dict__.__contains__, ["__floor__"],   false, "struct.Struct.__dict__.__contains__('__floor__')==False — math.floor() protocol not supported by Struct; verified with Python 3.14.3"]
    - [st1561sn008, struct.Struct.__dict__.__contains__, ["__ceil__"],    false, "struct.Struct.__dict__.__contains__('__ceil__')==False — math.ceil() protocol not supported by Struct; verified with Python 3.14.3"]
    - [st1561sn009, struct.Struct.__dict__.__contains__, ["__round__"],   false, "struct.Struct.__dict__.__contains__('__round__')==False — round() protocol not supported by Struct; verified with Python 3.14.3"]

