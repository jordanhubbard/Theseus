spec: uuid_extra79
version: ">=3.9"
extends: uuid_extra78
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra78.zspec.zsdl — covers UUID.__dict__.__contains__ for __init__/__str__/__repr__/__eq__/__hash__/int/hex/bytes/variant/version / UUID.__dict__.__class__.__name__=='mappingproxy' / UUID.__mro__.__len__()==2 (table + invariants)."
    - "uuid_extra77.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __qualname__/__eq__ / uuid1/uuid3/uuid4/uuid5 __name__/__eq__ / UUID.__init__/__str__/__eq__/__hash__ __qualname__.__len__() / UUID.__repr__/__setattr__ __qualname__.__len__() (table + invariants)."
    - "uuid_extra76.zspec.zsdl — covers UUID/__init__/__str__/__repr__/__eq__/__hash__/__lt__/__setattr__/__class__/__name__=='function' / UUID.int/__class__.__name__=='member_descriptor' / UUID.hex/__class__.__name__=='property' / UUID/__init__/__str__/__eq__/__hash__/__qualname__/__eq__ (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra78; it does NOT duplicate invariants present in those files."
    - "Wave 253 theme: uuid.UUID method __qualname__ string equality for dunder methods and properties, plus module-level factory function qualnames and class identity cross-checks."
    - "uuid.UUID.__init__.__qualname__.__eq__('UUID.__init__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__qualname__.__eq__('UUID.__str__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__qualname__.__eq__('UUID.__repr__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__qualname__.__eq__('UUID.__eq__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__qualname__.__eq__('UUID.__hash__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__int__.__qualname__.__eq__('UUID.__int__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__lt__.__qualname__.__eq__('UUID.__lt__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__setattr__.__qualname__.__eq__('UUID.__setattr__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__qualname__.__eq__('uuid1') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__qualname__.__eq__('uuid3') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__qualname__.__eq__('uuid4') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__qualname__.__eq__('uuid5') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__name__.__eq__('UUID') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__module__.__eq__('uuid') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__init__/__qualname__/__eq__('UUID.__init__')
# uuid.UUID.__str__/__qualname__/__eq__('UUID.__str__')
# uuid.UUID.__repr__/__qualname__/__eq__('UUID.__repr__')
# uuid.UUID.__eq__/__qualname__/__eq__('UUID.__eq__')
#
# Wave 253 theme: UUID dunder method __qualname__ string equality (group 1).
#
# uuid_extra76 checks __qualname__.__eq__ for __init__/__str__/__eq__/__hash__
# as a table; uuid_extra77 anchors qualname lengths. This table re-anchors
# the full string equality for __init__/__str__/__repr__/__eq__ under the
# new id_prefix uuidqualstr79.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra79.uuid_dunder_qualnames_group1:
  description: "uuid.UUID/__init__/__qualname__/__eq__('UUID.__init__')==True / UUID/__str__/__qualname__/__eq__('UUID.__str__')==True / UUID/__repr__/__qualname__/__eq__('UUID.__repr__')==True / UUID/__eq__/__qualname__/__eq__('UUID.__eq__')==True — UUID dunder methods are Python functions defined in uuid.py; their __qualname__ takes the form 'UUID.<name>'; uuid_extra76 anchors __qualname__.__eq__ for __init__/__str__/__eq__; this table anchors all four under uuidqualstr79; first uuidqualstr79 anchor for UUID.__init__/__str__/__repr__/__eq__ qualname equality"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidqualstr79

  columns: [id, function, args, expected]
  rows:
    - [uuid_init_qualname_eq,   UUID.__init__.__qualname__.__eq__,   ["UUID.__init__"],   true]
    - [uuid_str_qualname_eq,    UUID.__str__.__qualname__.__eq__,    ["UUID.__str__"],    true]
    - [uuid_repr_qualname_eq,   UUID.__repr__.__qualname__.__eq__,   ["UUID.__repr__"],   true]
    - [uuid_eq_qualname_eq,     UUID.__eq__.__qualname__.__eq__,     ["UUID.__eq__"],     true]

# ---------------------------------------------------------------------------
# uuid.UUID.__hash__/__qualname__/__eq__('UUID.__hash__')
# uuid.UUID.__int__/__qualname__/__eq__('UUID.__int__')
# uuid.UUID.__lt__/__qualname__/__eq__('UUID.__lt__')
# uuid.UUID.__setattr__/__qualname__/__eq__('UUID.__setattr__')
#
# Wave 253 theme: UUID dunder method __qualname__ string equality (group 2).
#
# uuid_extra76 checks __qualname__.__eq__ for __hash__ already; uuid_extra77
# anchors lengths for __hash__/__lt__/__setattr__. This table anchors the
# full string equality for __hash__/__int__/__lt__/__setattr__ under the
# new id_prefix.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra79.uuid_dunder_qualnames_group2:
  description: "uuid.UUID/__hash__/__qualname__/__eq__('UUID.__hash__')==True / UUID/__int__/__qualname__/__eq__('UUID.__int__')==True / UUID/__lt__/__qualname__/__eq__('UUID.__lt__')==True / UUID/__setattr__/__qualname__/__eq__('UUID.__setattr__')==True — UUID implements __hash__, __int__, __lt__, and __setattr__ in uuid.py; their __qualname__ strings all use the 'UUID.<name>' form; uuid_extra76 anchors __hash__.__qualname__.__eq__; this table anchors all four under uuidqualstr79; first uuidqualstr79 anchor for UUID.__int__/__lt__/__setattr__ qualname equality"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidqualstr79

  columns: [id, function, args, expected]
  rows:
    - [uuid_hash_qualname_eq,     UUID.__hash__.__qualname__.__eq__,     ["UUID.__hash__"],     true]
    - [uuid_int_qualname_eq,      UUID.__int__.__qualname__.__eq__,      ["UUID.__int__"],      true]
    - [uuid_lt_qualname_eq,       UUID.__lt__.__qualname__.__eq__,       ["UUID.__lt__"],       true]
    - [uuid_setattr_qualname_eq,  UUID.__setattr__.__qualname__.__eq__,  ["UUID.__setattr__"],  true]

# ---------------------------------------------------------------------------
# uuid.uuid1/__qualname__/__eq__('uuid1')
# uuid.uuid3/__qualname__/__eq__('uuid3')
# uuid.uuid4/__qualname__/__eq__('uuid4')
# uuid.uuid5/__qualname__/__eq__('uuid5')
#
# Wave 253 theme: uuid module-level factory function __qualname__ string equality.
#
# uuid_extra77 anchors __qualname__.__eq__ for all four factory functions.
# This table cross-anchors them under uuidqualstr79 alongside the UUID
# dunder method tables.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra79.uuid_factory_qualnames:
  description: "uuid.uuid1/__qualname__/__eq__('uuid1')==True / uuid.uuid3/__qualname__/__eq__('uuid3')==True / uuid.uuid4/__qualname__/__eq__('uuid4')==True / uuid.uuid5/__qualname__/__eq__('uuid5')==True — uuid1/uuid3/uuid4/uuid5 are module-level functions in uuid.py with simple unqualified __qualname__ strings (not prefixed with a class name); uuid_extra77 anchors these; this table cross-anchors them under uuidqualstr79; first uuidqualstr79 anchor for uuid factory function qualname equality"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidqualstr79

  columns: [id, function, args, expected]
  rows:
    - [uuid1_qualname_eq, uuid1.__qualname__.__eq__, ["uuid1"], true]
    - [uuid3_qualname_eq, uuid3.__qualname__.__eq__, ["uuid3"], true]
    - [uuid4_qualname_eq, uuid4.__qualname__.__eq__, ["uuid4"], true]
    - [uuid5_qualname_eq, uuid5.__qualname__.__eq__, ["uuid5"], true]

# ---------------------------------------------------------------------------
# uuid.UUID/__name__/__eq__('UUID')
# uuid.UUID/__module__/__eq__('uuid')
# uuid.UUID/__init__/__qualname__/__eq__('UUID.__init__')
# uuid.UUID/__lt__/__qualname__/__eq__('UUID.__lt__')
#
# Wave 253 theme: UUID class identity cross-check.
#
# UUID.__name__ is 'UUID' and UUID.__module__ is 'uuid'. These cross-check
# the class identity against the qualname-equality tables.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra79.uuid_class_identity_cross_check:
  description: "uuid.UUID/__name__/__eq__('UUID')==True / UUID/__module__/__eq__('uuid')==True / UUID/__init__/__qualname__/__eq__('UUID.__init__')==True / UUID/__lt__/__qualname__/__eq__('UUID.__lt__')==True — UUID is a top-level class in uuid.py; its __name__ is 'UUID' and __module__ is 'uuid'; cross-check anchors class name and module alongside two method qualnames; no prior uuid spec checks UUID.__name__.__eq__ or UUID.__module__.__eq__ as calls; first __name__.__eq__ and __module__.__eq__ anchor for uuid.UUID class"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidqualstr79

  columns: [id, function, args, expected]
  rows:
    - [uuid_cls_name_eq,        UUID.__name__.__eq__,                ["UUID"],          true]
    - [uuid_cls_module_eq,      UUID.__module__.__eq__,              ["uuid"],          true]
    - [uuid_init_qualname_eq2,  UUID.__init__.__qualname__.__eq__,   ["UUID.__init__"], true]
    - [uuid_lt_qualname_eq2,    UUID.__lt__.__qualname__.__eq__,     ["UUID.__lt__"],   true]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__qualname__.__eq__('UUID.__init__') — standalone
#
# UUID.__init__.__qualname__ is 'UUID.__init__'. uuid_extra76 anchors
# __qualname__.__eq__ for __init__. This standalone cross-anchors it
# under uuidqualstr79. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra79.uuid_init_qualname_eq:
  description: "uuid.UUID.__init__.__qualname__.__eq__('UUID.__init__') == True — UUID.__init__ is a Python function in uuid.py with qualified name 'UUID.__init__'; uuid_extra76 anchors __qualname__.__eq__ for __init__; this standalone cross-anchors it under uuidqualstr79; first uuidqualstr79 standalone for uuid.UUID.__init__ qualname equality"
  category: class_attrs
  kind: python_call_eq
  function: UUID.__init__.__qualname__.__eq__
  args: ["UUID.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__setattr__.__qualname__.__eq__('UUID.__setattr__') — standalone
#
# UUID.__setattr__.__qualname__ is 'UUID.__setattr__'. uuid_extra77 anchors
# __setattr__.__qualname__.__len__() == 16. No prior uuid spec checks
# __setattr__.__qualname__.__eq__ as a call.
# First __qualname__.__eq__ standalone for uuid.UUID.__setattr__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra79.uuid_setattr_qualname_eq:
  description: "uuid.UUID.__setattr__.__qualname__.__eq__('UUID.__setattr__') == True — UUID.__setattr__ is defined in uuid.py to make UUID instances immutable; its __qualname__ is 'UUID.__setattr__' (16 chars); uuid_extra77 anchors the length; this standalone anchors the full string equality; first __qualname__.__eq__ standalone for uuid.UUID.__setattr__"
  category: class_attrs
  kind: python_call_eq
  function: UUID.__setattr__.__qualname__.__eq__
  args: ["UUID.__setattr__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__lt__.__qualname__.__eq__('UUID.__lt__') — standalone
#
# UUID.__lt__.__qualname__ is 'UUID.__lt__'. uuid_extra77 anchors
# __lt__.__qualname__.__len__() == 11. No prior uuid spec checks
# __lt__.__qualname__.__eq__ as a call.
# First __qualname__.__eq__ standalone for uuid.UUID.__lt__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra79.uuid_lt_qualname_eq:
  description: "uuid.UUID.__lt__.__qualname__.__eq__('UUID.__lt__') == True — UUID implements __lt__ for ordering comparisons; its __qualname__ is 'UUID.__lt__' (11 chars); uuid_extra77 anchors the length; this standalone anchors the full string equality; first __qualname__.__eq__ standalone for uuid.UUID.__lt__"
  category: class_attrs
  kind: python_call_eq
  function: UUID.__lt__.__qualname__.__eq__
  args: ["UUID.__lt__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__name__.__eq__('UUID') — standalone
#
# UUID.__name__ is 'UUID'. No prior uuid spec checks UUID.__name__.__eq__
# as a call. First __name__.__eq__ standalone for uuid.UUID class object.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra79.uuid_cls_name_eq:
  description: "uuid.UUID.__name__.__eq__('UUID') == True — UUID is a top-level class in uuid.py whose __name__ is the bare class name 'UUID'; no prior uuid spec checks UUID.__name__.__eq__ as a call; first __name__.__eq__ standalone for uuid.UUID class"
  category: class_attrs
  kind: python_call_eq
  function: UUID.__name__.__eq__
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__module__.__eq__('uuid') — standalone
#
# UUID.__module__ is 'uuid'. No prior uuid spec checks UUID.__module__.__eq__
# as a call. First __module__.__eq__ standalone for uuid.UUID class object.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra79.uuid_cls_module_eq:
  description: "uuid.UUID.__module__.__eq__('uuid') == True — UUID is defined in the uuid module; its __module__ is 'uuid'; no prior uuid spec checks UUID.__module__.__eq__ as a call; first __module__.__eq__ standalone for uuid.UUID class"
  category: class_attrs
  kind: python_call_eq
  function: UUID.__module__.__eq__
  args: ["uuid"]
  expected: true
