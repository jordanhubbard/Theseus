  rows:
    - ["dc2716007", "decimal.Decimal.__dict__.__contains__",          ["__abs__"], true]
    - ["dc2716008", "decimal.Context.__dict__.__contains__",          ["__abs__"], false]
    - ["dc2716009", "decimal.DecimalException.__dict__.__contains__", ["__abs__"], false]

# ---------------------------------------------------------------------------
# Complementary: decimal.Decimal has full arithmetic dunders including unary numeric operators
# Contrasts Decimal's unary operators with the absent __neg__/__pos__/__abs__ on Context and DecimalException
# ---------------------------------------------------------------------------

table decimal_extra2716.decimal_has_full_unary_numeric_protocol:
  description: "decimal.Decimal defines __add__/__sub__/__mul__ and also __neg__/__pos__/__abs__; decimal.Context and decimal.DecimalException define none of __neg__/__pos__/__abs__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2716

  columns: [id, function, args, expected]
  rows:
    - ["dc2716010", "decimal.Decimal.__dict__.__contains__", ["__add__"], true]
    - ["dc2716011", "decimal.Decimal.__dict__.__contains__", ["__sub__"], true]
    - ["dc2716012", "decimal.Decimal.__dict__.__contains__", ["__mul__"], true]
    - ["dc2716013", "decimal.Decimal.__dict__.__contains__", ["__neg__"], true]
    - ["dc2716014", "decimal.Decimal.__dict__.__contains__", ["__pos__"], true]
    - ["dc2716015", "decimal.Decimal.__dict__.__contains__", ["__abs__"], true]
    - ["dc2716016", "decimal.Context.__dict__.__contains__", ["__neg__"], false]
    - ["dc2716017", "decimal.Context.__dict__.__contains__", ["__pos__"], false]
    - ["dc2716018", "decimal.Context.__dict__.__contains__", ["__abs__"], false]
    - ["dc2716019", "decimal.DecimalException.__dict__.__contains__", ["__neg__"], false]
    - ["dc2716020", "decimal.DecimalException.__dict__.__contains__", ["__pos__"], false]
    - ["dc2716021", "decimal.DecimalException.__dict__.__contains__", ["__abs__"], false]
