spec: decimal_extra2716
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra.zspec.zsdl — covers existing decimal invariants"
    - "decimal_extra2701.zspec.zsdl — covers __lshift__/__rshift__/__invert__ dict-presence"
  notes:
    - "Wave 628 (decimal_extra2716) theme: __neg__, __pos__, and __abs__ dict-presence checks."
    - "decimal.Decimal DOES define __neg__, __pos__, and __abs__ in its own __dict__ — Decimal implements the full unary numeric protocol."
    - "decimal.Context and decimal.DecimalException do NOT define __neg__, __pos__, or __abs__ in their own __dict__."
    - "__neg__ (unary -) on Decimal returns a negated copy with sign flipped; __pos__ (unary +) applies the current context and returns a copy; __abs__ (abs()) returns a non-negative copy."
    - "decimal.Context provides context-level control for arithmetic but does not itself support unary numeric operators."
    - "decimal.DecimalException is an exception base class with no numeric operator semantics."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __neg__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2716.neg_presence_in_decimal_classes:
  description: "__neg__ is present in decimal.Decimal __dict__ (full unary numeric protocol) but absent from decimal.Context and decimal.DecimalException"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2716

  columns: [id, function, args, expected]
  rows:
    - ["dc2716001", "decimal.Decimal.__dict__.__contains__",          ["__neg__"], true]
    - ["dc2716002", "decimal.Context.__dict__.__contains__",          ["__neg__"], false]
    - ["dc2716003", "decimal.DecimalException.__dict__.__contains__", ["__neg__"], false]

