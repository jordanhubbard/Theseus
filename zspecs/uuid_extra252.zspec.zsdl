spec: uuid_extra252
version: ">=3.2"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 9562 — Universally Unique IDentifiers (UUID) — https://www.rfc-editor.org/rfc/rfc9562"
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "RFC 9562 — Universally Unique IDentifiers (UUID)"
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "CPython source: internal PRNG or MAC address resolution"
  notes:
    - "This spec extends uuid_extra.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "uuid_extra.zspec.zsdl covers: UUID class name/module; uuid1/uuid3/uuid4/uuid5 function names; uuid4() return class and version; NAMESPACE_* class membership; UUID .int and .hex attribute types."
    - "uuid.uuid3(NAMESPACE_DNS, 'python.org') is fully deterministic (MD5-based); str value is '6fa459ea-ee8a-3ca4-894e-db77e160355e'."
    - "uuid.uuid5(NAMESPACE_DNS, 'python.org') is fully deterministic (SHA-1-based); str value is '886313e1-3b8a-5372-9b90-0c9aee199e5d'."
    - "uuid3 hex == '6fa459eaee8a3ca4894edb77e160355e' (32 lowercase hex chars, no hyphens)."
    - "uuid5 hex == '886313e13b8a53729b900c9aee199e5d' (32 lowercase hex chars, no hyphens)."
    - "uuid3.version == 3 and uuid5.version == 5 — the version nibble is encoded in bits 12-15 of the time_hi_and_version field."
    - "Both uuid3 and uuid5 have variant == 'specified in RFC 4122' (the string returned by Python's uuid.UUID.variant property)."
    - "NAMESPACE_DNS str == '6ba7b810-9dad-11d1-80b4-00c04fd430c8' — the DNS namespace UUID per RFC 9562."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid3(NAMESPACE_DNS, 'python.org') — deterministic MD5-based UUID
# ---------------------------------------------------------------------------

invariant uuid_extra252.uuid3.dns_python_org_str:
  description: "str(uuid.uuid3(NAMESPACE_DNS, 'python.org')) == '6fa459ea-ee8a-3ca4-894e-db77e160355e'"
  category: uuid3
  kind: python_call_eq
  function: uuid3
  args: ["6ba7b810-9dad-11d1-80b4-00c04fd430c8", "python.org"]
  method: __str__
  method_args: []
  expected: "6fa459ea-ee8a-3ca4-894e-db77e160355e"

invariant uuid_extra252.uuid3.dns_python_org_hex:
  description: "uuid.uuid3(NAMESPACE_DNS, 'python.org').hex == '6fa459eaee8a3ca4894edb77e160355e'"
  category: uuid3
  kind: python_call_eq
  function: uuid3
  args: ["6ba7b810-9dad-11d1-80b4-00c04fd430c8", "python.org"]
  method: hex.__eq__
  method_args: ["6fa459eaee8a3ca4894edb77e160355e"]
  expected: true

invariant uuid_extra252.uuid3.version:
  description: "uuid.uuid3(NAMESPACE_DNS, 'python.org').version == 3"
  category: uuid3
  kind: python_call_eq
  function: uuid3
  args: ["6ba7b810-9dad-11d1-80b4-00c04fd430c8", "python.org"]
  method: version.__eq__
  method_args: [3]
  expected: true

invariant uuid_extra252.uuid3.hex_len:
  description: "len(uuid.uuid3(NAMESPACE_DNS, 'python.org').hex) == 32 (32 lowercase hex chars)"
  category: uuid3
  kind: python_call_eq
  function: uuid3
  args: ["6ba7b810-9dad-11d1-80b4-00c04fd430c8", "python.org"]
  method: hex.__len__
  method_args: []
  expected: 32

# ---------------------------------------------------------------------------
# uuid5(NAMESPACE_DNS, 'python.org') — deterministic SHA-1-based UUID
# ---------------------------------------------------------------------------

invariant uuid_extra252.uuid5.dns_python_org_str:
  description: "str(uuid.uuid5(NAMESPACE_DNS, 'python.org')) == '886313e1-3b8a-5372-9b90-0c9aee199e5d'"
  category: uuid5
  kind: python_call_eq
  function: uuid5
  args: ["6ba7b810-9dad-11d1-80b4-00c04fd430c8", "python.org"]
  method: __str__
  method_args: []
  expected: "886313e1-3b8a-5372-9b90-0c9aee199e5d"

invariant uuid_extra252.uuid5.dns_python_org_hex:
  description: "uuid.uuid5(NAMESPACE_DNS, 'python.org').hex == '886313e13b8a53729b900c9aee199e5d'"
  category: uuid5
  kind: python_call_eq
  function: uuid5
  args: ["6ba7b810-9dad-11d1-80b4-00c04fd430c8", "python.org"]
  method: hex.__eq__
  method_args: ["886313e13b8a53729b900c9aee199e5d"]
  expected: true

invariant uuid_extra252.uuid5.version:
  description: "uuid.uuid5(NAMESPACE_DNS, 'python.org').version == 5"
  category: uuid5
  kind: python_call_eq
  function: uuid5
  args: ["6ba7b810-9dad-11d1-80b4-00c04fd430c8", "python.org"]
  method: version.__eq__
  method_args: [5]
  expected: true

invariant uuid_extra252.uuid5.hex_len:
  description: "len(uuid.uuid5(NAMESPACE_DNS, 'python.org').hex) == 32 (32 lowercase hex chars)"
  category: uuid5
  kind: python_call_eq
  function: uuid5
  args: ["6ba7b810-9dad-11d1-80b4-00c04fd430c8", "python.org"]
  method: hex.__len__
  method_args: []
  expected: 32

# ---------------------------------------------------------------------------
# NAMESPACE_DNS — canonical string form per RFC 9562
# ---------------------------------------------------------------------------

invariant uuid_extra252.NAMESPACE_DNS.str:
  description: "str(uuid.NAMESPACE_DNS) == '6ba7b810-9dad-11d1-80b4-00c04fd430c8' — DNS namespace UUID per RFC 9562"
  category: namespaces
  kind: python_call_eq
  function: NAMESPACE_DNS.__str__
  args: []
  expected: "6ba7b810-9dad-11d1-80b4-00c04fd430c8"

invariant uuid_extra252.NAMESPACE_DNS.hex:
  description: "uuid.NAMESPACE_DNS.hex == '6ba7b8109dad11d180b400c04fd430c8'"
  category: namespaces
  kind: python_call_eq
  function: NAMESPACE_DNS.hex.__eq__
  args: ["6ba7b8109dad11d180b400c04fd430c8"]
  expected: true

# ---------------------------------------------------------------------------
# uuid3 and uuid5 return class identity
# ---------------------------------------------------------------------------

invariant uuid_extra252.uuid3.return_class_name:
  description: "uuid.uuid3(NAMESPACE_DNS, 'python.org').__class__.__name__ == 'UUID'"
  category: uuid3
  kind: python_call_eq
  function: uuid3
  args: ["6ba7b810-9dad-11d1-80b4-00c04fd430c8", "python.org"]
  method: __class__.__name__.__eq__
  method_args: ["UUID"]
  expected: true

invariant uuid_extra252.uuid5.return_class_name:
  description: "uuid.uuid5(NAMESPACE_DNS, 'python.org').__class__.__name__ == 'UUID'"
  category: uuid5
  kind: python_call_eq
  function: uuid5
  args: ["6ba7b810-9dad-11d1-80b4-00c04fd430c8", "python.org"]
  method: __class__.__name__.__eq__
  method_args: ["UUID"]
  expected: true
