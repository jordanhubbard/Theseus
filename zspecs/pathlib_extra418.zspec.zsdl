spec: pathlib_extra418
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "pathlib.Path methods symlink_to, hardlink_to, is_symlink, is_mount, lstat, readlink each report __name__ matching their Python-level name"
    - "hardlink_to was added in Python 3.10; readlink was added in Python 3.9"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path symlink and hardlink method __name__ identity
# ---------------------------------------------------------------------------

table pathlib_extra418.path_link_method_names:
  description: "pathlib.Path symlink and hardlink method __name__ identity — symlink_to, hardlink_to, is_symlink, is_mount, lstat, readlink; each method's __name__ matches its Python-level name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: pathliblink418

  columns: [id, function, args, expected]
  rows:
    - [symlink_to_name,  pathlib.Path.symlink_to.__name__.__eq__,  ["symlink_to"],  true]
    - [hardlink_to_name, pathlib.Path.hardlink_to.__name__.__eq__, ["hardlink_to"], true]
    - [is_symlink_name,  pathlib.Path.is_symlink.__name__.__eq__,  ["is_symlink"],  true]
    - [is_mount_name,    pathlib.Path.is_mount.__name__.__eq__,    ["is_mount"],    true]
    - [lstat_name,       pathlib.Path.lstat.__name__.__eq__,       ["lstat"],       true]
    - [readlink_name,    pathlib.Path.readlink.__name__.__eq__,    ["readlink"],    true]
