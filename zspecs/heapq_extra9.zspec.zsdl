spec: heapq_extra9
version: ">=3.9"
backend: python_module(heapq)

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/heapq.html — Python heapq documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/heapq.py"
    - "CPython source: Modules/_heapqmodule.c"
  notes:
    - "This spec extends heapq.zspec.zsdl and prior extras through heapq_extra8.zspec.zsdl."
    - "heapq.zspec.zsdl: nlargest/nsmallest tables; heappush/heappop/heapify/merge __name__."
    - "heapq_extra: heappush.__module__=='_heapq'; __name__ for all functions; nlargest(3)/nsmallest(3) on [1,5,3,2,4]."
    - "heapq_extra2: __name__ table for heappush/heappop/heapify/heapreplace/nlargest/nsmallest."
    - "heapq_extra3: __module__ for heappop/heapify/heapreplace/heappushpop; behavioral on [1,5,2,4,3]."
    - "heapq_extra4: module __name__=='heapq'; heappushpop/merge __name__ table; behavioral on [10,3,7,1,9,5,8,2,6,4] and negatives."
    - "heapq_extra5: __qualname__ for all heap/selection/merge functions; nlargest(3)/nsmallest(3) on [1,4,2,9,3]."
    - "heapq_extra6: heap_names table (id_prefix hname); heappush.__module__ via __eq__; module_identity table; behavioral on [6,2,8,4,10,1,7,3,9,5]."
    - "heapq_extra7: nlargest/nsmallest/merge __module__ standalone; __qualname__ standalone; behavioral on [3,1,4,1,5,9,2,6] (duplicates)."
    - "heapq_extra8: C-function __module__ via __eq__ table (id_prefix cmod); py-function __module__ via __eq__ table (id_prefix pymod); behavioral on [7,14,3,11,5,9]; edge cases nlargest(1,[])/nsmallest(0,...)/nlargest(0,...)."
    - "This spec adds: __name__ for heappush/heappop/heapify/nlargest as a grouped table under id_prefix hname9 (extra9 namespace, distinct anchor from heapq_extra2/extra6 tables); behavioral on [2,17,5,13,8,11] (6-element mixed input, not used in any prior spec)."
    - "heapq.heappush.__name__ == 'heappush' — C extension function; grouped in hname9 table (extra9 namespace anchor)."
    - "heapq.heappop.__name__ == 'heappop' — C extension function; grouped in hname9 table (extra9 namespace anchor)."
    - "heapq.heapify.__name__ == 'heapify' — C extension function; grouped in hname9 table (extra9 namespace anchor)."
    - "heapq.nlargest.__name__ == 'nlargest' — pure-Python function; grouped in hname9 table (extra9 namespace anchor)."
    - "nlargest(3, [2,17,5,13,8,11]) == [17, 13, 11] — three largest from a 6-element mixed input."
    - "nsmallest(3, [2,17,5,13,8,11]) == [2, 5, 8] — three smallest in ascending order."
    - "nlargest(2, [2,17,5,13,8,11]) == [17, 13] — two largest."
    - "nsmallest(1, [2,17,5,13,8,11]) == [2] — single smallest."
    - "nlargest(6, [2,17,5,13,8,11]) == [17, 13, 11, 8, 5, 2] — all elements in descending order."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ grouped table — extra9 namespace, id_prefix hname9
#
# heapq_extra2 uses an unnamed __name__ table covering heappush/heappop/
# heapify/heapreplace/nlargest/nsmallest.
# heapq_extra6 uses id_prefix hname in a table covering all heap functions.
# This table uses id_prefix hname9 (extra9 namespace) and focuses on the four
# assigned axes: heappush/__name__, heappop/__name__, heapify/__name__,
# nlargest/__name__. This provides a distinct structural anchor in extra9.
# ---------------------------------------------------------------------------

table heapq_extra9.function_names:
  kind: python_call_eq
  category: function_identity
  id_prefix: hname9

  columns: [id, function, args, expected]
  rows:
    - [heappush, heappush.__name__.__eq__, ["heappush"], true]
    - [heappop,  heappop.__name__.__eq__,  ["heappop"],  true]
    - [heapify,  heapify.__name__.__eq__,  ["heapify"],  true]
    - [nlargest, nlargest.__name__.__eq__, ["nlargest"], true]

# ---------------------------------------------------------------------------
# Behavioral invariants — [2, 17, 5, 13, 8, 11]
#
# This 6-element input with mixed values is distinct from all prior spec inputs:
#   heapq        uses [1,8,2,6,3]
#   heapq_extra  uses [1,5,3,2,4]
#   heapq_extra2 uses [5,1,3,2,4]
#   heapq_extra3 uses [1,5,2,4,3]
#   heapq_extra4 uses [10,3,7,1,9,5,8,2,6,4] and [-5,-1,-3,-2,-4]
#   heapq_extra5 uses [1,4,2,9,3]
#   heapq_extra6 uses [6,2,8,4,10,1,7,3,9,5]
#   heapq_extra7 uses [3,1,4,1,5,9,2,6]
#   heapq_extra8 uses [7,14,3,11,5,9]
# [2,17,5,13,8,11] is a new fixture not used in any prior spec.
# ---------------------------------------------------------------------------

invariant heapq_extra9.nlargest.top3_mixed6:
  description: "heapq.nlargest(3, [2,17,5,13,8,11]) == [17, 13, 11] — three largest in descending order"
  category: behavior
  kind: python_call_eq
  function: nlargest
  args: [3, [2, 17, 5, 13, 8, 11]]
  expected: [17, 13, 11]

invariant heapq_extra9.nsmallest.top3_mixed6:
  description: "heapq.nsmallest(3, [2,17,5,13,8,11]) == [2, 5, 8] — three smallest in ascending order"
  category: behavior
  kind: python_call_eq
  function: nsmallest
  args: [3, [2, 17, 5, 13, 8, 11]]
  expected: [2, 5, 8]

invariant heapq_extra9.nlargest.top2_mixed6:
  description: "heapq.nlargest(2, [2,17,5,13,8,11]) == [17, 13] — two largest"
  category: behavior
  kind: python_call_eq
  function: nlargest
  args: [2, [2, 17, 5, 13, 8, 11]]
  expected: [17, 13]

invariant heapq_extra9.nsmallest.top1_mixed6:
  description: "heapq.nsmallest(1, [2,17,5,13,8,11]) == [2] — single smallest element"
  category: behavior
  kind: python_call_eq
  function: nsmallest
  args: [1, [2, 17, 5, 13, 8, 11]]
  expected: [2]

invariant heapq_extra9.nlargest.all_mixed6:
  description: "heapq.nlargest(6, [2,17,5,13,8,11]) == [17, 13, 11, 8, 5, 2] — all elements in descending order"
  category: behavior
  kind: python_call_eq
  function: nlargest
  args: [6, [2, 17, 5, 13, 8, 11]]
  expected: [17, 13, 11, 8, 5, 2]
