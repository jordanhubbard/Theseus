    - ["uu2266013", "uuid.SafeUUID.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["uu2266014", "uuid.SafeUUID.__dict__.__contains__", ["__getstate__"], false]
    - ["uu2266015", "uuid.SafeUUID.__dict__.__contains__", ["__setstate__"], false]
    - ["uu2266016", "uuid.SafeUUID.__dict__.__contains__", ["__getnewargs__"], false]
    - ["uu2266017", "uuid.SafeUUID.__dict__.__contains__", ["__getnewargs_ex__"], false]
    - ["uu2266018", "uuid.SafeUUID.__dict__.__contains__", ["__copy__"], false]
    - ["uu2266019", "uuid.SafeUUID.__dict__.__contains__", ["__deepcopy__"], false]
    - ["uu2266020", "uuid.SafeUUID.__dict__.__contains__", ["__sizeof__"], false]
