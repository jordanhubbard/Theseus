spec: uuid_extra2266
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "Wave 598 (_extra2266): pickling/serialization protocol dict-presence checks."
    - "Checks __reduce__, __reduce_ex__, __getstate__, __setstate__, __getnewargs__, __getnewargs_ex__, __copy__, __deepcopy__, __sizeof__, __class_getitem__, __init_subclass__ presence in __dict__ of uuid types."
    - "uuid.UUID is a slotted Python class; it defines __getstate__ and __setstate__ for pickling support (True); all other pickling/copy protocol keys absent."
    - "uuid.SafeUUID is an IntEnum subclass; all pickling/copy/sizeof protocol keys absent from its __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table uuid_extra2266.uuid_pickle:
  description: "uuid.UUID pickle/copy protocol dict-presence — __getstate__ and __setstate__ present; all other protocol keys absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2266

  columns: [id, function, args, expected]
  rows:
    - ["uu2266001", "uuid.UUID.__dict__.__contains__", ["__reduce__"], false]
    - ["uu2266002", "uuid.UUID.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["uu2266003", "uuid.UUID.__dict__.__contains__", ["__getstate__"], true]
    - ["uu2266004", "uuid.UUID.__dict__.__contains__", ["__setstate__"], true]
    - ["uu2266005", "uuid.UUID.__dict__.__contains__", ["__getnewargs__"], false]
    - ["uu2266006", "uuid.UUID.__dict__.__contains__", ["__getnewargs_ex__"], false]
    - ["uu2266007", "uuid.UUID.__dict__.__contains__", ["__copy__"], false]
    - ["uu2266008", "uuid.UUID.__dict__.__contains__", ["__deepcopy__"], false]
    - ["uu2266009", "uuid.UUID.__dict__.__contains__", ["__sizeof__"], false]
    - ["uu2266010", "uuid.UUID.__dict__.__contains__", ["__class_getitem__"], false]
    - ["uu2266011", "uuid.UUID.__dict__.__contains__", ["__init_subclass__"], false]

table uuid_extra2266.safeuuid_pickle:
  description: "uuid.SafeUUID pickle/copy protocol dict-presence — all pickling and copy protocol keys absent from __dict__"
