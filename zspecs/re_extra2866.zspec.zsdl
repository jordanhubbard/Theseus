spec: re2866
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "zspecs/re_extra2851.zspec.zsdl — wave 637 predecessor (covered __rlshift__, __rrshift__, __rpow__)"
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "Wave 638 theme: __rand__, __ror__, __rxor__ dict-presence checks (reflected bitwise AND, OR, XOR operators)."
    - "re.RegexFlag is an IntFlag subclass — IntFlag defines __rand__, __ror__, and __rxor__ in its own __dict__ for reflected bitwise combination of flag values."
    - "re.RegexFlag.__rand__, re.RegexFlag.__ror__, and re.RegexFlag.__rxor__ are ALL present (True) — verified with Python 3.14.3."
    - "re.Pattern (type(re.compile(''))) does NOT define __rand__, __ror__, or __rxor__ — compiled patterns are not bitwise operands."
    - "re.Match (type(re.match('',''))) does NOT define __rand__, __ror__, or __rxor__ — match objects are not bitwise operands."
    - "The asymmetry between RegexFlag (present) and Pattern/Match (absent) reflects IntFlag's role as an integer-based flag enum."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __rand__ dict-presence
# RegexFlag: True (IntFlag); Pattern and Match: False
# ---------------------------------------------------------------------------

table re2866.rand:
  description: "__rand__ is present in re.RegexFlag (IntFlag subclass) but absent from Pattern and Match"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2866

  columns: [id, function, args, expected]
  rows:
    - ["re2866001", "re.RegexFlag.__dict__.__contains__",                    ["__rand__"], true]
    - ["re2866002", "type(re.compile('')).__dict__.__contains__",            ["__rand__"], false]
    - ["re2866003", "type(re.match('', '')).__dict__.__contains__",          ["__rand__"], false]
    - ["re2866004", "re.RegexFlag.__dict__.__contains__",                    ["__and__"],  true]
    - ["re2866005", "type(re.compile('')).__dict__.__contains__",            ["__and__"],  false]
    - ["re2866006", "type(re.match('', '')).__dict__.__contains__",          ["__and__"],  false]

