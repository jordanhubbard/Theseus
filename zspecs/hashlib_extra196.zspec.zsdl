spec: hashlib_extra196
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "RFC 7914 — The scrypt Password-Based Key Derivation Function"
  - "RFC 2898 — PKCS #5: Password-Based Cryptography Specification Version 2.0"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "RFC 7914 — The scrypt Password-Based Key Derivation Function, September 2016"
    - "RFC 2898 — PKCS #5: Password-Based Cryptography Specification Version 2.0"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha3/sha3module.c"
  notes:
    - "This spec does NOT duplicate invariants already present in hashlib.zspec.zsdl or prior hashlib_extra files."
    - "hashlib.pbkdf2_hmac is a builtin_function_or_method; its __module__ is '_hashlib' (the C extension)."
    - "hashlib.pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac' — C-extension builtins have flat qualnames."
    - "hashlib.scrypt is available on macOS/Darwin (OpenSSL-backed); its __name__ is 'scrypt'."
    - "hashlib.scrypt.__module__ == '_hashlib' — same C extension as pbkdf2_hmac."
    - "hashlib.shake_256.__name__ == 'openssl_shake_256' — the OpenSSL-backed constructor uses the openssl_ prefix."
    - "hashlib.shake_256.__module__ == '_hashlib' — OpenSSL-backed constructors live in _hashlib."
    - "hashlib.shake_256.__class__.__name__ == 'builtin_function_or_method' — same as other hashlib constructors."
    - "hashlib.shake_256.__qualname__ == 'openssl_shake_256' — flat qualname for C-extension builtin."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pbkdf2_hmac function identity
# ---------------------------------------------------------------------------

table hashlib_extra196.pbkdf2_hmac.identity:
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlibpbkdf196

  columns: [id, function, args, expected]
  rows:
    - [name,         pbkdf2_hmac.__name__.__eq__,         ["pbkdf2_hmac"],               true]
    - [module,       pbkdf2_hmac.__module__.__eq__,       ["_hashlib"],                  true]
    - [class_name,   pbkdf2_hmac.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# scrypt function identity (OpenSSL-backed; available on macOS/Darwin)
# ---------------------------------------------------------------------------

table hashlib_extra196.scrypt.identity:
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlibpbkdf196

  columns: [id, function, args, expected]
  rows:
    - [scrypt_name,   scrypt.__name__.__eq__,   ["scrypt"],   true]
    - [scrypt_module, scrypt.__module__.__eq__,  ["_hashlib"], true]

# ---------------------------------------------------------------------------
# shake_256 function identity (OpenSSL-backed constructor)
# ---------------------------------------------------------------------------

table hashlib_extra196.shake_256.identity:
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlibpbkdf196

  columns: [id, function, args, expected]
  rows:
    - [shake256_name,   shake_256.__name__.__eq__,            ["openssl_shake_256"],          true]
    - [shake256_module, shake_256.__module__.__eq__,          ["_hashlib"],                   true]
    - [shake256_class,  shake_256.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashlib_extra196.pbkdf2_hmac.qualname:
  description: "hashlib.pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac' — C-extension builtin has flat qualname"
  category: function_identity
  kind: python_call_eq
  function: pbkdf2_hmac.__qualname__.__eq__
  args: ["pbkdf2_hmac"]
  expected: true

invariant hashlib_extra196.pbkdf2_hmac.class_name_eq:
  description: "hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method'"
  category: function_identity
  kind: python_call_eq
  function: pbkdf2_hmac.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant hashlib_extra196.scrypt.qualname:
  description: "hashlib.scrypt.__qualname__ == 'scrypt' — C-extension builtin has flat qualname"
  category: function_identity
  kind: python_call_eq
  function: scrypt.__qualname__.__eq__
  args: ["scrypt"]
  expected: true

invariant hashlib_extra196.scrypt.class_name:
  description: "hashlib.scrypt.__class__.__name__ == 'builtin_function_or_method'"
  category: function_identity
  kind: python_call_eq
  function: scrypt.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant hashlib_extra196.shake_256.qualname:
  description: "hashlib.shake_256.__qualname__ == 'openssl_shake_256' — OpenSSL-backed constructor has openssl_ prefix qualname"
  category: function_identity
  kind: python_call_eq
  function: shake_256.__qualname__.__eq__
  args: ["openssl_shake_256"]
  expected: true

invariant hashlib_extra196.shake_128.name:
  description: "hashlib.shake_128.__name__ == 'openssl_shake_128' — OpenSSL-backed SHAKE-128 constructor"
  category: function_identity
  kind: python_call_eq
  function: shake_128.__name__.__eq__
  args: ["openssl_shake_128"]
  expected: true

invariant hashlib_extra196.shake_128.module:
  description: "hashlib.shake_128.__module__ == '_hashlib' — OpenSSL-backed constructors live in _hashlib"
  category: function_identity
  kind: python_call_eq
  function: shake_128.__module__.__eq__
  args: ["_hashlib"]
  expected: true

invariant hashlib_extra196.shake_128.class_name:
  description: "hashlib.shake_128.__class__.__name__ == 'builtin_function_or_method'"
  category: function_identity
  kind: python_call_eq
  function: shake_128.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

