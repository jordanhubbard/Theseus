spec: io_extra196
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/io.py"
  notes:
    - "io.RawIOBase.read.__name__ == 'read' (len=4); confirmed Python 3.14.3 macOS."
    - "io.RawIOBase.readall.__name__ == 'readall' (len=7); confirmed Python 3.14.3 macOS."
    - "io.RawIOBase.readinto.__name__ == 'readinto' (len=8); confirmed Python 3.14.3 macOS."
    - "io.RawIOBase.write.__name__ == 'write' (len=5); confirmed Python 3.14.3 macOS."
    - "io.RawIOBase.__class__.__name__ == 'ABCMeta' (not 'type'); RawIOBase uses ABCMeta metaclass."
    - "io.RawIOBase.__module__ == 'io' (len=2); confirmed Python 3.14.3 macOS."
    - "io.RawIOBase.__qualname__ == 'RawIOBase' (len=9); confirmed Python 3.14.3 macOS."
    - "Length ordering: read(4) < write(5) < readall(7) < readinto(8); confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io.RawIOBase method __name__ equality
# read(4), write(5), readall(7), readinto(8)
# ---------------------------------------------------------------------------

table io_extra196.rawiobase_method_names:
  description: "io.RawIOBase method __name__ values: read='read'(4), write='write'(5), readall='readall'(7), readinto='readinto'(8)"
  kind: python_call_eq
  category: identity
  id_prefix: iorawiobase196

  columns: [id, function, args, expected, description]
  rows:
    - [read_name_eq,    io.RawIOBase.read.__name__.__eq__,    ["read"],    true, "io.RawIOBase.read.__name__ == 'read'; confirmed Python 3.14.3 macOS"]
    - [write_name_eq,   io.RawIOBase.write.__name__.__eq__,   ["write"],   true, "io.RawIOBase.write.__name__ == 'write'; confirmed Python 3.14.3 macOS"]
    - [readall_name_eq, io.RawIOBase.readall.__name__.__eq__, ["readall"], true, "io.RawIOBase.readall.__name__ == 'readall'; confirmed Python 3.14.3 macOS"]
    - [readinto_name_eq,io.RawIOBase.readinto.__name__.__eq__,["readinto"],true, "io.RawIOBase.readinto.__name__ == 'readinto'; confirmed Python 3.14.3 macOS"]
    - [read_name_len,   io.RawIOBase.read.__name__.__len__,   [],          4,    "io.RawIOBase.read.__name__.__len__() == 4 — r(1)e(2)a(3)d(4); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: io.RawIOBase method __name__ lengths (ordering table)
# read(4) < write(5) < readall(7) < readinto(8)
# ---------------------------------------------------------------------------

table io_extra196.rawiobase_method_name_lengths:
  description: "io.RawIOBase method __name__ lengths: read=4, write=5, readall=7, readinto=8; length ordering read<write<readall<readinto"
  kind: python_call_eq
  category: identity
  id_prefix: iorawiobase196

  columns: [id, function, args, expected, description]
  rows:
    - [read_len,    io.RawIOBase.read.__name__.__len__,    [], 4, "io.RawIOBase.read.__name__.__len__() == 4; shortest method name; confirmed Python 3.14.3 macOS"]
    - [write_len,   io.RawIOBase.write.__name__.__len__,   [], 5, "io.RawIOBase.write.__name__.__len__() == 5; second shortest; confirmed Python 3.14.3 macOS"]
    - [readall_len, io.RawIOBase.readall.__name__.__len__, [], 7, "io.RawIOBase.readall.__name__.__len__() == 7; third; confirmed Python 3.14.3 macOS"]
    - [readinto_len,io.RawIOBase.readinto.__name__.__len__,[], 8, "io.RawIOBase.readinto.__name__.__len__() == 8; longest method name; confirmed Python 3.14.3 macOS"]
    - [module_len,  io.RawIOBase.__module__.__len__,       [], 2, "io.RawIOBase.__module__.__len__() == 2 — i(1)o(2); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: io.RawIOBase class-level identity attributes
# __class__(ABCMeta), __module__(io), __qualname__(RawIOBase)
# ---------------------------------------------------------------------------

table io_extra196.rawiobase_class_identity:
  description: "io.RawIOBase class-level identity: __class__.__name__='ABCMeta', __module__='io', __qualname__='RawIOBase'"
  kind: python_call_eq
  category: identity
  id_prefix: iorawiobase196

  columns: [id, function, args, expected, description]
  rows:
    - [class_name_eq,   io.RawIOBase.__class__.__name__.__eq__,   ["ABCMeta"],   true, "io.RawIOBase.__class__.__name__ == 'ABCMeta'; RawIOBase uses ABCMeta metaclass; confirmed Python 3.14.3 macOS"]
    - [module_eq,       io.RawIOBase.__module__.__eq__,           ["io"],        true, "io.RawIOBase.__module__ == 'io'; confirmed Python 3.14.3 macOS"]
    - [qualname_eq,     io.RawIOBase.__qualname__.__eq__,         ["RawIOBase"], true, "io.RawIOBase.__qualname__ == 'RawIOBase'; top-level class; confirmed Python 3.14.3 macOS"]
    - [qualname_len,    io.RawIOBase.__qualname__.__len__,         [],            9,    "io.RawIOBase.__qualname__.__len__() == 9 — R(1)a(2)w(3)I(4)O(5)B(6)a(7)s(8)e(9); confirmed Python 3.14.3 macOS"]
    - [class_name_len,  io.RawIOBase.__class__.__name__.__len__,  [],            7,    "io.RawIOBase.__class__.__name__.__len__() == 7 — A(1)B(2)C(3)M(4)e(5)t(6)a(7); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra196.read_name_eq:
  description: "io.RawIOBase.read.__name__ == 'read' — method name length 4; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.RawIOBase.read.__name__.__eq__
  args: ["read"]
  expected: true

invariant io_extra196.readall_name_eq:
  description: "io.RawIOBase.readall.__name__ == 'readall' — method name length 7; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.RawIOBase.readall.__name__.__eq__
  args: ["readall"]
  expected: true

invariant io_extra196.readinto_name_eq:
  description: "io.RawIOBase.readinto.__name__ == 'readinto' — method name length 8, longest of the four; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.RawIOBase.readinto.__name__.__eq__
  args: ["readinto"]
  expected: true

invariant io_extra196.write_name_eq:
  description: "io.RawIOBase.write.__name__ == 'write' — method name length 5; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.RawIOBase.write.__name__.__eq__
  args: ["write"]
  expected: true

invariant io_extra196.class_name_abcmeta:
  description: "io.RawIOBase.__class__.__name__ == 'ABCMeta' — RawIOBase metaclass is ABCMeta, not plain type; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.RawIOBase.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant io_extra196.module_eq:
  description: "io.RawIOBase.__module__ == 'io' — attributed to the public io module (len=2); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.RawIOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra196.qualname_eq:
  description: "io.RawIOBase.__qualname__ == 'RawIOBase' — top-level class, qualname equals class name, length 9; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.RawIOBase.__qualname__.__eq__
  args: ["RawIOBase"]
  expected: true

invariant io_extra196.readinto_len_max:
  description: "io.RawIOBase.readinto.__name__.__len__() == 8 — longest among read(4), write(5), readall(7), readinto(8); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.RawIOBase.readinto.__name__.__len__
  args: []
  expected: 8
