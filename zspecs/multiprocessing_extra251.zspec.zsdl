spec: multiprocessing_extra251
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/connection.py"
  notes:
    - "Connection.__bases__[0].__name__ == '_ConnectionBase': Connection inherits from the private _ConnectionBase mixin."
    - "Connection.send, .recv, .close are all defined on _ConnectionBase (qualnames confirm)."
    - "Client is a plain function (not a class): __class__.__name__ == 'function'."
    - "Listener.__bases__[0].__name__ == 'object': Listener does not inherit from a custom base."
    - "Listener.accept qualname is 'Listener.accept'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Connection class identity
# ---------------------------------------------------------------------------

invariant multiprocessing_extra251.connection.name:
  description: "multiprocessing.connection.Connection.__name__ == 'Connection'"
  category: identity
  kind: python_call_eq
  function: Connection.__name__.__eq__
  args: ["Connection"]
  expected: true

invariant multiprocessing_extra251.connection.module:
  description: "multiprocessing.connection.Connection.__module__ == 'multiprocessing.connection'"
  category: identity
  kind: python_call_eq
  function: Connection.__module__.__eq__
  args: ["multiprocessing.connection"]
  expected: true

invariant multiprocessing_extra251.connection.base:
  description: "multiprocessing.connection.Connection.__bases__[0].__name__ == '_ConnectionBase'"
  category: identity
  kind: python_call_eq
  function: Connection.__bases__[0].__name__.__eq__
  args: ["_ConnectionBase"]
  expected: true

# ---------------------------------------------------------------------------
# Connection method qualnames
# ---------------------------------------------------------------------------

invariant multiprocessing_extra251.connection.send_qualname:
  description: "multiprocessing.connection.Connection.send.__qualname__ == '_ConnectionBase.send'"
  category: identity
  kind: python_call_eq
  function: Connection.send.__qualname__.__eq__
  args: ["_ConnectionBase.send"]
  expected: true

invariant multiprocessing_extra251.connection.recv_qualname:
  description: "multiprocessing.connection.Connection.recv.__qualname__ == '_ConnectionBase.recv'"
  category: identity
  kind: python_call_eq
  function: Connection.recv.__qualname__.__eq__
  args: ["_ConnectionBase.recv"]
  expected: true

invariant multiprocessing_extra251.connection.close_qualname:
  description: "multiprocessing.connection.Connection.close.__qualname__ == '_ConnectionBase.close'"
  category: identity
  kind: python_call_eq
  function: Connection.close.__qualname__.__eq__
  args: ["_ConnectionBase.close"]
  expected: true

# ---------------------------------------------------------------------------
# Client function identity
# ---------------------------------------------------------------------------

invariant multiprocessing_extra251.client.name:
  description: "multiprocessing.connection.Client.__name__ == 'Client'"
  category: identity
  kind: python_call_eq
  function: Client.__name__.__eq__
  args: ["Client"]
  expected: true

invariant multiprocessing_extra251.client.class:
  description: "type(multiprocessing.connection.Client).__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: Client.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant multiprocessing_extra251.client.module:
  description: "multiprocessing.connection.Client.__module__ == 'multiprocessing.connection'"
  category: identity
  kind: python_call_eq
  function: Client.__module__.__eq__
  args: ["multiprocessing.connection"]
  expected: true

# ---------------------------------------------------------------------------
# Listener class identity
# ---------------------------------------------------------------------------

invariant multiprocessing_extra251.listener.name:
  description: "multiprocessing.connection.Listener.__name__ == 'Listener'"
  category: identity
  kind: python_call_eq
  function: Listener.__name__.__eq__
  args: ["Listener"]
  expected: true

invariant multiprocessing_extra251.listener.module:
  description: "multiprocessing.connection.Listener.__module__ == 'multiprocessing.connection'"
  category: identity
  kind: python_call_eq
  function: Listener.__module__.__eq__
  args: ["multiprocessing.connection"]
  expected: true

invariant multiprocessing_extra251.listener.base:
  description: "multiprocessing.connection.Listener.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: Listener.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

invariant multiprocessing_extra251.listener.accept_qualname:
  description: "multiprocessing.connection.Listener.accept.__qualname__ == 'Listener.accept'"
  category: identity
  kind: python_call_eq
  function: Listener.accept.__qualname__.__eq__
  args: ["Listener.accept"]
  expected: true
