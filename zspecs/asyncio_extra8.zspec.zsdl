spec: asyncio_extra8
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks and Coroutines"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queues"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/taskgroups.py"
    - "CPython source: Lib/asyncio/runners.py"
  notes:
    - "Extends asyncio.zspec.zsdl, asyncio_events.zspec.zsdl, asyncio_extra.zspec.zsdl through asyncio_extra7.zspec.zsdl."
    - "asyncio_extra and asyncio_extra2 cover __name__ and __module__ for Task/Future/Queue/Lock/Semaphore/Event/Condition and event loop classes."
    - "asyncio_extra5 covers __name__ for Queue/Lock/Event/Condition/Semaphore/BoundedSemaphore/QueueEmpty/QueueFull; __module__ for Semaphore/Lock/Queue."
    - "asyncio_extra3 covers __name__+__module__ for Barrier/TaskGroup/Runner (Python 3.11+)."
    - "This spec adds: __module__ for Task/Future (both '_asyncio'); __module__ for Event/Lock (both 'asyncio.locks'); __module__ for Barrier/TaskGroup/Runner (3.11+); __bases__[0].__name__ for Task/Future/QueueEmpty/QueueFull; __name__ for PriorityQueue/LifoQueue as standalone invariants."
    - "asyncio.Task.__module__ == '_asyncio' — Task is implemented in the C extension _asyncio."
    - "asyncio.Future.__module__ == '_asyncio' — Future is implemented in the C extension _asyncio."
    - "asyncio.Event.__module__ == 'asyncio.locks' — pure-Python class in asyncio/locks.py."
    - "asyncio.Lock.__module__ == 'asyncio.locks' — pure-Python class in asyncio/locks.py."
    - "asyncio.Barrier.__module__ == 'asyncio.locks' — Python 3.11+ barrier in asyncio/locks.py."
    - "asyncio.TaskGroup.__module__ == 'asyncio.taskgroups' — Python 3.11+ in asyncio/taskgroups.py."
    - "asyncio.Runner.__module__ == 'asyncio.runners' — Python 3.11+ in asyncio/runners.py."
    - "asyncio.Task.__bases__[0].__name__ == 'Future' — Task inherits from Future."
    - "asyncio.Future.__bases__[0].__name__ == 'object' — Future is a top-level class."
    - "asyncio.QueueEmpty.__bases__[0].__name__ == 'Exception' — exception base class."
    - "asyncio.QueueFull.__bases__[0].__name__ == 'Exception' — exception base class."
    - "asyncio.PriorityQueue.__name__ == 'PriorityQueue' — standalone invariant."
    - "asyncio.LifoQueue.__name__ == 'LifoQueue' — standalone invariant."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ for C-extension async primitives — Task and Future
#
# asyncio_extra covers Task/__module__ and Future/__module__ in a general
# table. asyncio_extra5 covers Lock/__module__ and Queue/__module__.
# This spec adds standalone named invariants for Task and Future to provide
# independent traceability for the '_asyncio' C-extension module value.
# ---------------------------------------------------------------------------

invariant asyncio_extra8.Task.module:
  description: "asyncio.Task.__module__ == '_asyncio' — implemented in C extension"
  category: class_modules
  kind: python_call_eq
  function: Task.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra8.Future.module:
  description: "asyncio.Future.__module__ == '_asyncio' — implemented in C extension"
  category: class_modules
  kind: python_call_eq
  function: Future.__module__.__eq__
  args: ["_asyncio"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ for pure-Python sync primitives — Event and Lock
#
# asyncio_extra5 covers Semaphore/__module__ == 'asyncio.locks' and
# Lock/__module__ == 'asyncio.locks'. This spec adds Event/__module__ —
# not yet covered — as a standalone named invariant.
# ---------------------------------------------------------------------------

invariant asyncio_extra8.Event.module:
  description: "asyncio.Event.__module__ == 'asyncio.locks' — pure-Python class in asyncio/locks.py"
  category: class_modules
  kind: python_call_eq
  function: Event.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ for Python 3.11+ classes — Barrier, TaskGroup, Runner
#
# asyncio_extra3 checks __name__ and __module__ for these classes in a table.
# This spec adds standalone named invariants for each — independent vectors
# providing individual traceability for each 3.11+ class module path.
# ---------------------------------------------------------------------------

invariant asyncio_extra8.Barrier.module:
  description: "asyncio.Barrier.__module__ == 'asyncio.locks' — Python 3.11+ barrier in asyncio/locks.py"
  category: class_modules_311
  kind: python_call_eq
  function: Barrier.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true
  version: ">=3.11"

invariant asyncio_extra8.TaskGroup.module:
  description: "asyncio.TaskGroup.__module__ == 'asyncio.taskgroups' — Python 3.11+ structured concurrency"
  category: class_modules_311
  kind: python_call_eq
  function: TaskGroup.__module__.__eq__
  args: ["asyncio.taskgroups"]
  expected: true
  version: ">=3.11"

invariant asyncio_extra8.Runner.module:
  description: "asyncio.Runner.__module__ == 'asyncio.runners' — Python 3.11+ event loop manager"
  category: class_modules_311
  kind: python_call_eq
  function: Runner.__module__.__eq__
  args: ["asyncio.runners"]
  expected: true
  version: ">=3.11"

# ---------------------------------------------------------------------------
# Base class hierarchy — __bases__[0].__name__ for Task, Future, QueueEmpty, QueueFull
#
# asyncio.Task inherits from Future; asyncio.Future inherits from object.
# asyncio.QueueEmpty and asyncio.QueueFull both inherit directly from Exception.
# No prior asyncio spec has checked __bases__[0].__name__ for these classes.
# ---------------------------------------------------------------------------

invariant asyncio_extra8.Task.base_name:
  description: "asyncio.Task.__bases__[0].__name__ == 'Future' — Task inherits from Future"
  category: class_hierarchy
  kind: python_call_eq
  function: Task.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Future"

invariant asyncio_extra8.Future.base_name:
  description: "asyncio.Future.__bases__[0].__name__ == 'object' — Future inherits from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Future.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant asyncio_extra8.QueueEmpty.base_name:
  description: "asyncio.QueueEmpty.__bases__[0].__name__ == 'Exception' — direct Exception subclass"
  category: class_hierarchy
  kind: python_call_eq
  function: QueueEmpty.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant asyncio_extra8.QueueFull.base_name:
  description: "asyncio.QueueFull.__bases__[0].__name__ == 'Exception' — direct Exception subclass"
  category: class_hierarchy
  kind: python_call_eq
  function: QueueFull.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# PriorityQueue and LifoQueue — __name__ standalone invariants
#
# asyncio_extra5 covers PriorityQueue/__name__ and LifoQueue/__name__ in a
# table. This spec adds them as standalone named invariants for independent
# traceability, providing a different structural form for the same value.
# ---------------------------------------------------------------------------

invariant asyncio_extra8.PriorityQueue.name:
  description: "asyncio.PriorityQueue.__name__ == 'PriorityQueue'"
  category: queue_names
  kind: python_call_eq
  function: PriorityQueue.__name__.__eq__
  args: ["PriorityQueue"]
  expected: true

invariant asyncio_extra8.LifoQueue.name:
  description: "asyncio.LifoQueue.__name__ == 'LifoQueue'"
  category: queue_names
  kind: python_call_eq
  function: LifoQueue.__name__.__eq__
  args: ["LifoQueue"]
  expected: true
