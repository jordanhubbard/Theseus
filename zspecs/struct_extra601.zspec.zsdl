spec: struct_extra601
version: ">=3.9"
backend: python_module(struct)
docs: "Behavioral spec covering struct.Struct property descriptors, top-level function __module__ identity, and struct.error/struct.Struct documentation identity."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module reference"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Rows verify getset_descriptor identity for Struct attributes, module identity for top-level functions, and str identity for docstrings"
  created_at: "2026-04-12T00:00:00Z"

table struct_extra601.st:
  id_prefix: st601

  columns: [id, function, args, expected]
  rows:
    - [st601pr01, struct.Struct.format.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [st601pr02, struct.Struct.size.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [st601fn01, struct.pack.__module__.__eq__, ["struct"], true]
    - [st601fn02, struct.unpack.__module__.__eq__, ["struct"], true]
    - [st601fn03, struct.pack_into.__module__.__eq__, ["struct"], true]
    - [st601fn04, struct.unpack_from.__module__.__eq__, ["struct"], true]
    - [st601fn05, struct.calcsize.__module__.__eq__, ["struct"], true]
    - [st601fn06, struct.iter_unpack.__module__.__eq__, ["struct"], true]
    - [st601dc01, struct.Struct.__init__.__qualname__.__eq__, ["Struct.__init__"], true]
    - [st601dc02, struct.Struct.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st601dc03, struct.error.__doc__.__class__.__name__.__eq__, ["str"], true]
