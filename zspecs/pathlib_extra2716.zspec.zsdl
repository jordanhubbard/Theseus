spec: pathlib_extra2716
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 pathlib documentation — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
    - "pathlib_extra.zspec.zsdl — covers existing pathlib invariants"
    - "pathlib_extra2701.zspec.zsdl — covers __lshift__/__rshift__/__invert__ dict-presence"
  notes:
    - "Wave 628 (pathlib_extra2716) theme: __neg__, __pos__, and __abs__ dict-presence checks."
    - "None of the pathlib classes define __neg__, __pos__, or __abs__ in their own __dict__."
    - "__neg__ is the unary negation operator (-x); pathlib path objects are filesystem path types, not numeric types."
    - "__pos__ is the unary positive operator (+x); pathlib path objects do not implement unary numeric semantics."
    - "__abs__ is the absolute value operator (abs(x)); pathlib path objects do not implement absolute-value semantics."
    - "pathlib uses __truediv__ (the / operator) for path joining — none of __neg__, __pos__, or __abs__ are used."
    - "Covers pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, and pathlib.Path."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __neg__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2716.no_neg_in_pathlib_classes:
  description: "__neg__ is absent from all pathlib class __dict__s — pathlib path objects do not implement the unary negation protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2716

  columns: [id, function, args, expected]
  rows:
    - ["pp2716001", "pathlib.PurePath.__dict__.__contains__",        ["__neg__"], false]
    - ["pp2716002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__neg__"], false]
    - ["pp2716003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__neg__"], false]
    - ["pp2716004", "pathlib.Path.__dict__.__contains__",            ["__neg__"], false]

# ---------------------------------------------------------------------------
# __pos__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2716.no_pos_in_pathlib_classes:
  description: "__pos__ is absent from all pathlib class __dict__s — pathlib path objects do not implement the unary positive protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2716

  columns: [id, function, args, expected]
  rows:
    - ["pp2716005", "pathlib.PurePath.__dict__.__contains__",        ["__pos__"], false]
    - ["pp2716006", "pathlib.PurePosixPath.__dict__.__contains__",   ["__pos__"], false]
    - ["pp2716007", "pathlib.PureWindowsPath.__dict__.__contains__", ["__pos__"], false]
    - ["pp2716008", "pathlib.Path.__dict__.__contains__",            ["__pos__"], false]

# ---------------------------------------------------------------------------
# __abs__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2716.no_abs_in_pathlib_classes:
  description: "__abs__ is absent from all pathlib class __dict__s — pathlib path objects do not implement the absolute-value protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2716

  columns: [id, function, args, expected]
  rows:
    - ["pp2716009", "pathlib.PurePath.__dict__.__contains__",        ["__abs__"], false]
    - ["pp2716010", "pathlib.PurePosixPath.__dict__.__contains__",   ["__abs__"], false]
    - ["pp2716011", "pathlib.PureWindowsPath.__dict__.__contains__", ["__abs__"], false]
    - ["pp2716012", "pathlib.Path.__dict__.__contains__",            ["__abs__"], false]

# ---------------------------------------------------------------------------
# Complementary: pathlib classes have path-manipulation methods but not unary numeric hooks
# Confirms that path objects use __truediv__ for joining and have no __neg__/__pos__/__abs__ semantics
# ---------------------------------------------------------------------------

table pathlib_extra2716.pathlib_has_path_methods_not_unary_numeric_hooks:
  description: "pathlib.PurePath defines __str__/__truediv__/__fspath__ but NOT __neg__/__pos__/__abs__; pathlib.Path defines stat/exists/open but NOT __neg__/__pos__/__abs__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2716

  columns: [id, function, args, expected]
  rows:
    - ["pp2716013", "pathlib.PurePath.__dict__.__contains__", ["__str__"],     true]
    - ["pp2716014", "pathlib.PurePath.__dict__.__contains__", ["__truediv__"], true]
    - ["pp2716015", "pathlib.PurePath.__dict__.__contains__", ["__fspath__"],  true]
    - ["pp2716016", "pathlib.PurePath.__dict__.__contains__", ["__neg__"],     false]
    - ["pp2716017", "pathlib.PurePath.__dict__.__contains__", ["__pos__"],     false]
    - ["pp2716018", "pathlib.PurePath.__dict__.__contains__", ["__abs__"],     false]
    - ["pp2716019", "pathlib.Path.__dict__.__contains__",     ["stat"],        true]
    - ["pp2716020", "pathlib.Path.__dict__.__contains__",     ["exists"],      true]
    - ["pp2716021", "pathlib.Path.__dict__.__contains__",     ["open"],        true]
    - ["pp2716022", "pathlib.Path.__dict__.__contains__",     ["__neg__"],     false]
    - ["pp2716023", "pathlib.Path.__dict__.__contains__",     ["__pos__"],     false]
    - ["pp2716024", "pathlib.Path.__dict__.__contains__",     ["__abs__"],     false]
