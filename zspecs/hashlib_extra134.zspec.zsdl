spec: hashlib_extra134
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra133.zspec.zsdl — covers sha3_256/sha3_512/sha3_224/sha3_384/blake2b/blake2s/shake_128/shake_256 block_size values / sha3_256().__class__.__mro__.__len__()==2 / sha3_256().__class__.__bases__[0].__name__=='object' / sha3_256().__class__.__module__=='_hashlib' (table + invariants)."
    - "hashlib_extra132.zspec.zsdl — covers hashlib.__all__ tuple membership / pbkdf2_hmac function identity (__name__/__qualname__/__module__/__class__.__name__) (table + invariants)."
    - "hashlib_extra131.zspec.zsdl — covers hashlib._hashlib.HASH class-level method_descriptor identity — update/digest/hexdigest/copy __name__ equality / __objclass__.__name__ equality (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 __class__.__name__=='builtin_function_or_method' and __name__ equality / blake2b/blake2s class identity and __module__=='_blake2' / algorithms_guaranteed.__len__()==14 (table + invariants)."
    - "hashlib_extra98.zspec.zsdl — covers sha3_*/shake_* constructor __qualname__ and __module__ equality / sha3_*/shake_* __class__.__name__=='builtin_function_or_method' / file_digest function identity / hashlib.__all__ class name and length (table + invariants)."
    - "hashlib_extra97.zspec.zsdl — covers hashlib.algorithms_guaranteed membership for sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512/sha3_224/sha3_384/blake2b/blake2s/shake_128/shake_256 / new/__qualname__.__eq__('__hash_new') / new/__qualname__.__len__()==10 (table + invariants)."
    - "hashlib_extra96.zspec.zsdl — covers hashlib.__name__/__package__/__spec__/__loader__/__doc__ module identity / hashlib.new __qualname__/__module__/co_argcount cross-checks / sha256/sha512/sha1/md5 __module__ cross-checks (table + invariants)."
    - "hashlib_extra95.zspec.zsdl — covers hashlib.new/__qualname__.__eq__('__hash_new') / sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__ and __module__ equality (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior hashlib spec files."
    - "Wave 307 theme: hashlib.file_digest and hashlib.new function identity — file_digest __name__/__qualname__/__module__/__class__.__name__ / new __name__/__qualname__/__module__/__class__.__name__ / file_digest co_name and co_argcount / new co_argcount."
    - "hashlib.file_digest.__class__.__name__ == 'function'. file_digest is a pure-Python function defined in Lib/hashlib.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__module__ == 'hashlib'. file_digest lives in the hashlib module. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__qualname__ == 'file_digest'. Top-level function; qualname equals name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__name__ == 'file_digest'. __name__ and __qualname__ are the same for file_digest. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__qualname__.__len__() == 11. len('file_digest')==11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__code__.co_name == 'file_digest'. co_name matches the def statement name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__code__.co_argcount == 2. Args: fileobj, digest. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__class__.__name__ == 'function'. new is a pure-Python wrapper function in Lib/hashlib.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__module__ == 'hashlib'. new lives in the hashlib module. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__qualname__ == '__hash_new'. The internal implementation name differs from the public attribute name 'new'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__name__ == '__hash_new'. __name__ and __qualname__ both reflect the internal function name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__qualname__.__len__() == 10. len('__hash_new')==10. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__code__.co_argcount == 1. Takes 'name' as the sole positional arg. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.new is exposed as 'new' in the module namespace, but its internal function name is '__hash_new'. This is because hashlib assigns the function: new = __hash_new after defining it. The __qualname__ and __name__ attributes reflect the def statement name '__hash_new'."
    - "Note: hashlib.file_digest was added in Python 3.11. It computes the hash of a file-like object efficiently using a buffer to avoid loading the whole file into memory."
    - "Note: file_digest.__name__ == file_digest.__qualname__ == 'file_digest' — both match the def statement name and there is no enclosing scope prefix."
    - "Note: hashlib_extra98 anchors file_digest identity (__class__.__name__, __qualname__, __module__, co_argcount) at table level; this spec anchors the same attributes via __eq__ calls in new grouped tables and standalone invariants using the id_prefix hashlibfdnew134."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.file_digest.__class__.__name__.__eq__('function')
# hashlib.file_digest.__module__.__eq__('hashlib')
# hashlib.file_digest.__qualname__.__eq__('file_digest')
# hashlib.file_digest.__name__.__eq__('file_digest')
# hashlib.file_digest.__qualname__.__len__()==11
#
# Wave 307 theme: file_digest function identity attributes.
#
# hashlib.file_digest is a pure-Python function (class 'function') defined in
# Lib/hashlib.py. Added in Python 3.11, it computes a hash digest of a file-like
# object using a read buffer to avoid loading the entire file. Its __qualname__
# and __name__ are both 'file_digest' (11 chars) — matching the def statement
# name. Its __module__ is 'hashlib'. hashlib_extra98 anchors these attributes
# at table level via direct value checks; this table anchors them via __eq__
# calls under hashlibfdnew134. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra134.file_digest_identity:
  description: "hashlib.file_digest/__class__.__name__.__eq__('function')==True / __module__.__eq__('hashlib')==True / __qualname__.__eq__('file_digest')==True / __name__.__eq__('file_digest')==True / __qualname__.__len__()==11 — file_digest is a pure-Python function added in Python 3.11; __qualname__ and __name__ both match the def statement name 'file_digest' (11 chars); extra98 anchors at table level; first hashlibfdnew134 anchor via __eq__ calls"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibfdnew134

  columns: [id, function, args, expected]
  rows:
    - [fd_class,   file_digest.__class__.__name__.__eq__, ["function"],    true]
    - [fd_module,  file_digest.__module__.__eq__,         ["hashlib"],     true]
    - [fd_qualname, file_digest.__qualname__.__eq__,      ["file_digest"], true]
    - [fd_name,    file_digest.__name__.__eq__,           ["file_digest"], true]
    - [fd_qlen,    file_digest.__qualname__.__len__,      [],              11]

# ---------------------------------------------------------------------------
# hashlib.file_digest.__code__.co_name.__eq__('file_digest')
# hashlib.file_digest.__code__.co_argcount.__eq__(2)
# hashlib.new.__class__.__name__.__eq__('function')
# hashlib.new.__module__.__eq__('hashlib')
# hashlib.new.__qualname__.__eq__('__hash_new')
#
# Wave 307 theme: file_digest code attributes and new function identity.
#
# file_digest.__code__.co_name is 'file_digest' — the def statement name.
# co_argcount is 2 (fileobj, digest). hashlib.new is exposed as 'new' in the
# module namespace but defined with the name '__hash_new'. So new.__qualname__
# is '__hash_new' (10 chars), not 'new'. new is class 'function' from hashlib.
# No prior hashlib spec anchors file_digest co_name/__eq__ or new.__qualname__/__eq__
# together under hashlibfdnew134. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra134.file_digest_code_and_new_identity:
  description: "hashlib.file_digest/__code__/co_name.__eq__('file_digest')==True / __code__/co_argcount.__eq__(2)==True / new/__class__.__name__.__eq__('function')==True / new/__module__.__eq__('hashlib')==True / new/__qualname__.__eq__('__hash_new')==True — file_digest co_name matches def name; co_argcount=2 (fileobj, digest); new is 'function' from hashlib; new.__qualname__ is '__hash_new' (internal def name); first hashlibfdnew134 anchor for code attrs and new identity"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibfdnew134

  columns: [id, function, args, expected]
  rows:
    - [fd_co_name,    file_digest.__code__.co_name.__eq__,    ["file_digest"], true]
    - [fd_co_argc,    file_digest.__code__.co_argcount.__eq__, [2],            true]
    - [new_class,     new.__class__.__name__.__eq__,          ["function"],    true]
    - [new_module,    new.__module__.__eq__,                  ["hashlib"],     true]
    - [new_qualname,  new.__qualname__.__eq__,                ["__hash_new"],  true]

# ---------------------------------------------------------------------------
# hashlib.new.__name__.__eq__('__hash_new')
# hashlib.new.__qualname__.__len__()==10
# hashlib.new.__code__.co_argcount.__eq__(1)
#
# Wave 307 theme: hashlib.new name, qualname length, and code argcount.
#
# hashlib.new.__name__ is '__hash_new' — same as __qualname__. This is because
# new is assigned in hashlib.py as: new = __hash_new. The function's __name__
# reflects the def statement name, not the attribute name. __qualname__.__len__()
# is 10 (len('__hash_new')). co_argcount is 1 — new takes 'name' as the sole
# positional arg (plus **kwargs). hashlib_extra97 anchors new.__qualname__.__len__()
# == 10 at table level; this table anchors it via __len__ call and adds __name__
# and co_argcount under hashlibfdnew134. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra134.new_name_len_and_argcount:
  description: "hashlib.new/__name__.__eq__('__hash_new')==True / new/__qualname__.__len__()==10 / new/__code__/co_argcount.__eq__(1)==True — new.__name__ is '__hash_new' (matches __qualname__); assigned as new=__hash_new in Lib/hashlib.py; qualname len 10; co_argcount=1 (takes 'name' as sole positional arg plus **kwargs); extra97 anchors qualname len at table level; first hashlibfdnew134 anchor for new __name__ and co_argcount"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibfdnew134

  columns: [id, function, args, expected]
  rows:
    - [new_name,     new.__name__.__eq__,              ["__hash_new"], true]
    - [new_qlen,     new.__qualname__.__len__,         [],             10]
    - [new_co_argc,  new.__code__.co_argcount.__eq__,  [1],            true]

# ---------------------------------------------------------------------------
# hashlib.file_digest.__class__.__name__.__eq__('function') — standalone
#
# hashlib.file_digest.__class__.__name__ is 'function'. file_digest is a pure-
# Python function defined in Lib/hashlib.py (added in 3.11). This contrasts with
# the C-extension constructors like hashlib.md5 (class 'builtin_function_or_method').
# file_digest wraps file I/O with hash computation using a buffer loop to avoid
# loading the entire file content into memory at once. hashlib_extra98 anchors
# this at table level; this is the first standalone for file_digest.__class__.__name__
# under hashlibfdnew134. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra134.file_digest_class_function:
  description: "hashlib.file_digest.__class__.__name__.__eq__('function') == True — file_digest is a pure-Python function from Lib/hashlib.py (added in 3.11), unlike md5/sha256 which are 'builtin_function_or_method'; wraps file I/O with buffered hash computation; extra98 anchors at table level; first standalone for file_digest.__class__.__name__ under hashlibfdnew134"
  category: type_identity
  kind: python_call_eq
  function: file_digest.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.file_digest.__qualname__.__eq__('file_digest') — standalone
#
# hashlib.file_digest.__qualname__ is 'file_digest'. For a top-level function
# (no enclosing class or function), __qualname__ equals __name__ and equals
# the bare function name from the def statement. This makes file_digest unusual
# among hashlib functions: hashlib.new has __qualname__ '__hash_new' (the
# internal def name differs from the attribute name). file_digest has no such
# mismatch — the attribute name and def name are identical. No prior hashlib
# spec anchors file_digest.__qualname__.__eq__ as a standalone under
# hashlibfdnew134. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra134.file_digest_qualname_eq:
  description: "hashlib.file_digest.__qualname__.__eq__('file_digest') == True — top-level function; __qualname__ equals __name__ equals def name 'file_digest' (11 chars); no mismatch between attribute name and def name, unlike hashlib.new where attribute='new' but qualname='__hash_new'; first standalone for file_digest.__qualname__.__eq__ under hashlibfdnew134"
  category: type_identity
  kind: python_call_eq
  function: file_digest.__qualname__.__eq__
  args: ["file_digest"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__qualname__.__eq__('__hash_new') — standalone
#
# hashlib.new.__qualname__ is '__hash_new'. hashlib.new is the public API entry
# point for creating hash objects by name (e.g., hashlib.new('sha256')), but the
# underlying function was defined with def __hash_new(name, **kwargs). hashlib
# assigns new = __hash_new at module level, so the attribute is named 'new' but
# the function's __qualname__ (and __name__) retain the original '__hash_new'.
# hashlib_extra97 anchors this at table level via __eq__; no prior hashlib spec
# anchors new.__qualname__.__eq__ as a standalone under hashlibfdnew134.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra134.new_qualname_hash_new:
  description: "hashlib.new.__qualname__.__eq__('__hash_new') == True — new is publicly accessible as hashlib.new but defined as def __hash_new; assigned as new=__hash_new in Lib/hashlib.py; __qualname__ and __name__ both retain the internal def name '__hash_new' (10 chars); extra97 anchors at table level; first standalone under hashlibfdnew134"
  category: type_identity
  kind: python_call_eq
  function: new.__qualname__.__eq__
  args: ["__hash_new"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__module__.__eq__('hashlib') — standalone
#
# hashlib.new.__module__ is 'hashlib'. Despite new being a wrapper around C
# builtins from _hashlib, the __hash_new function itself is defined in
# Lib/hashlib.py (a pure-Python module), so its __module__ is 'hashlib' — not
# '_hashlib'. This contrasts with the sha256/md5 constructors whose __module__
# is '_hashlib' (the C extension). No prior hashlib spec anchors new.__module__
# __eq__('hashlib') as a standalone under hashlibfdnew134.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra134.new_module_hashlib:
  description: "hashlib.new.__module__.__eq__('hashlib') == True — __hash_new is defined in Lib/hashlib.py (pure Python), so __module__=='hashlib' (not '_hashlib'); contrasts with md5/sha256 constructors whose __module__ is '_hashlib' (C extension); first standalone for new.__module__ under hashlibfdnew134"
  category: type_identity
  kind: python_call_eq
  function: new.__module__.__eq__
  args: ["hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.file_digest.__code__.co_argcount.__eq__(2) — standalone
#
# hashlib.file_digest.__code__.co_argcount is 2. file_digest takes 2 positional
# args: fileobj (a file-like object supporting read()) and digest (either a hash
# name string or a constructor callable). The function reads from fileobj in
# chunks and feeds each chunk to the hash object. No prior hashlib spec anchors
# file_digest.__code__.co_argcount.__eq__(2) as a standalone under hashlibfdnew134.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra134.file_digest_co_argcount_2:
  description: "hashlib.file_digest.__code__.co_argcount.__eq__(2) == True — file_digest takes 2 positional args: fileobj (file-like object supporting read()) and digest (hash name string or constructor callable); reads in chunks feeding each to the hash; first standalone for file_digest co_argcount under hashlibfdnew134"
  category: type_identity
  kind: python_call_eq
  function: file_digest.__code__.co_argcount.__eq__
  args: [2]
  expected: true
