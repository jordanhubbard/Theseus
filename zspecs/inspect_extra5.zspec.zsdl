spec: inspect_extra5
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends prior inspect specs."
    - "Focus: __module__ and __name__ for inspect functions not yet covered."
    - "inspect.isfunction.__name__ == 'isfunction'."
    - "inspect.ismethod.__name__ == 'ismethod'."
    - "inspect.isclass.__name__ == 'isclass'."
    - "inspect.ismodule.__name__ == 'ismodule'."
    - "inspect.isbuiltin.__name__ == 'isbuiltin'."
    - "inspect.getmembers.__name__ == 'getmembers'."
    - "inspect.getsource.__name__ == 'getsource'."
    - "inspect.signature.__name__ == 'signature'."
    - "inspect.Parameter.__name__ == 'Parameter'; inspect.Signature.__name__ == 'Signature'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table inspect_extra5.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [isfunction,  isfunction.__name__.__eq__,  ["isfunction"],  true]
    - [ismethod,    ismethod.__name__.__eq__,    ["ismethod"],    true]
    - [isclass,     isclass.__name__.__eq__,     ["isclass"],     true]
    - [ismodule,    ismodule.__name__.__eq__,    ["ismodule"],    true]
    - [isbuiltin,   isbuiltin.__name__.__eq__,   ["isbuiltin"],   true]
    - [getmembers,  getmembers.__name__.__eq__,  ["getmembers"],  true]
    - [getsource,   getsource.__name__.__eq__,   ["getsource"],   true]
    - [signature,   signature.__name__.__eq__,   ["signature"],   true]
    - [getdoc,      getdoc.__name__.__eq__,      ["getdoc"],      true]
    - [getfile,     getfile.__name__.__eq__,     ["getfile"],     true]

table inspect_extra5.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [Parameter, Parameter.__name__.__eq__, ["Parameter"], true]
    - [Signature, Signature.__name__.__eq__, ["Signature"], true]

invariant inspect_extra5.Parameter.module:
  description: "inspect.Parameter.__module__ == 'inspect'"
  category: module
  kind: python_call_eq
  function: Parameter.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra5.Signature.module:
  description: "inspect.Signature.__module__ == 'inspect'"
  category: module
  kind: python_call_eq
  function: Signature.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra5.isclass.class_name:
  description: "inspect.isclass.__name__ == 'isclass'"
  category: function_names
  kind: python_call_eq
  function: isclass.__name__.__eq__
  args: ["isclass"]
  expected: true

invariant inspect_extra5.isbuiltin.class_name:
  description: "inspect.isbuiltin.__name__ == 'isbuiltin'"
  category: function_names
  kind: python_call_eq
  function: isbuiltin.__name__.__eq__
  args: ["isbuiltin"]
  expected: true

invariant inspect_extra5.isclass.on_type:
  description: "inspect.isclass(type) == True"
  category: predicates
  kind: python_call_eq
  function: isclass
  args: [{type: builtin_class, value: "type"}]
  expected: true

invariant inspect_extra5.Parameter.POSITIONAL_OR_KEYWORD.value:
  description: "inspect.Parameter.POSITIONAL_OR_KEYWORD == 1"
  category: Parameter_kinds
  kind: python_call_eq
  function: Parameter.POSITIONAL_OR_KEYWORD.__eq__
  args: [1]
  expected: true

invariant inspect_extra5.Parameter.VAR_POSITIONAL.value:
  description: "inspect.Parameter.VAR_POSITIONAL == 2"
  category: Parameter_kinds
  kind: python_call_eq
  function: Parameter.VAR_POSITIONAL.__eq__
  args: [2]
  expected: true

invariant inspect_extra5.Parameter.KEYWORD_ONLY.value:
  description: "inspect.Parameter.KEYWORD_ONLY == 3"
  category: Parameter_kinds
  kind: python_call_eq
  function: Parameter.KEYWORD_ONLY.__eq__
  args: [3]
  expected: true
