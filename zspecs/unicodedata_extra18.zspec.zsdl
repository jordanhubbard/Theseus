spec: unicodedata_extra18
version: ">=3.9"
backend: python_module(unicodedata)

docs: https://docs.python.org/3/library/unicodedata.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unicodedata.html — Python unicodedata module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/unicodedata.c"
  notes:
    - "This spec extends unicodedata.zspec.zsdl through unicodedata_extra17.zspec.zsdl."
    - "unicodedata_extra16 covers: lookup/name/decimal/digit/numeric/category/normalize/bidirectional __qualname__ attributes."
    - "unicodedata_extra17 covers: combining/east_asian_width/mirrored/decomposition/is_normalized __qualname__ attributes."
    - "No prior spec verifies UCD.__qualname__, unidata_version.__len__, or ucd_3_2_0.unidata_version as standalone invariants."
    - "unicodedata.UCD.__qualname__ == 'UCD' — the UCD class qualname is its simple name. Verified at runtime."
    - "unicodedata.unidata_version is a str; on Python 3.12 it is '16.0.0' (len==6). __len__() >= 3 holds for any valid version string. Verified at runtime."
    - "unicodedata.ucd_3_2_0 is a UCD instance for Unicode 3.2.0; its unidata_version attribute is '3.2.0'. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UCD class __qualname__
#
# unicodedata.UCD is the type of the ucd_3_2_0 instance (and the module-level
# functions dispatch through a UCD object). No prior spec verifies UCD.__qualname__
# as a standalone invariant. The class qualname is its simple name 'UCD'.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant unicodedata_extra18.UCD.qualname:
  description: "unicodedata.UCD.__qualname__ == 'UCD' — class qualname is its simple name"
  category: function_identity
  kind: python_call_eq
  function: UCD.__qualname__.__eq__
  args: ["UCD"]
  expected: true

# ---------------------------------------------------------------------------
# unidata_version string length
#
# unicodedata.unidata_version is the Unicode standard version string (e.g.
# '16.0.0'). Its length is at least 3 characters for any valid version string
# (minimum form: 'X.Y'). No prior spec verifies this length property.
# On Python 3.12 / macOS/Darwin 25.4.0, unidata_version == '16.0.0' (len==6).
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant unicodedata_extra18.unidata_version.len_ge_3:
  description: "unicodedata.unidata_version.__len__() >= 3 — version string is at least 3 characters"
  category: module_constants
  kind: python_call_eq
  function: unidata_version.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# ucd_3_2_0.unidata_version
#
# unicodedata.ucd_3_2_0 is a UCD instance exposing Unicode 3.2.0 data for
# compatibility purposes. Its unidata_version attribute must equal '3.2.0'.
# No prior spec verifies this property as a standalone invariant.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant unicodedata_extra18.ucd_3_2_0.unidata_version:
  description: "unicodedata.ucd_3_2_0.unidata_version == '3.2.0' — legacy UCD instance version"
  category: module_constants
  kind: python_call_eq
  function: ucd_3_2_0.unidata_version.__eq__
  args: ["3.2.0"]
  expected: true

# ---------------------------------------------------------------------------
# Table: unicodedata module-level version and class identity
#
# Groups UCD.__qualname__, unidata_version length, and ucd_3_2_0.unidata_version
# in one indexed table. No prior table covers these module-level attributes.
# All verified at runtime.
# ---------------------------------------------------------------------------

table unicodedata_extra18.version_and_class_identity:
  description: "unicodedata UCD class identity and version string properties"
  kind: python_call_eq
  category: module_constants
  id_prefix: ud18vc

  columns: [id, function, args, expected, description]
  rows:
    - [ucd_qualname,
       UCD.__qualname__.__eq__,
       ["UCD"],
       true,
       "UCD.__qualname__ == 'UCD'"]
    - [unidata_version_len,
       unidata_version.__len__,
       [],
       6,
       "unidata_version.__len__() == 6 on Python 3.12 (version '16.0.0')"]
    - [ucd_3_2_0_version,
       ucd_3_2_0.unidata_version.__eq__,
       ["3.2.0"],
       true,
       "ucd_3_2_0.unidata_version == '3.2.0' — legacy compatibility instance"]
