spec: cmd_extra5
version: ">=3.9"
backend: python_module(cmd)

docs: https://docs.python.org/3/library/cmd.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/cmd.html — Python cmd module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/cmd.py"
  notes:
    - "This spec extends cmd.zspec.zsdl and cmd_extra through cmd_extra4.zspec.zsdl."
    - "cmd covers: Cmd.__name__/__module__; Cmd() instance attrs (prompt/intro/use_rawinput/cmdqueue/ruler/doc_header/misc_header/undoc_header); IDENTCHARS contains 'a'/'A'/'0'/'_'."
    - "cmd_extra covers: Cmd.__name__/__module__; method names table (cmdloop/onecmd/default/do_help/emptyline/precmd/postcmd/parseline); IDENTCHARS type/nonempty/'_'/'a'."
    - "cmd_extra2 covers: Cmd.__bases__[0]/__name__=='object'; Cmd.__qualname__; PROMPT type+value; identchars/ruler/lastcmd/doc_header class attr types; ruler value."
    - "cmd_extra3 covers: Cmd.__bases__.__len__==1; __name__/__module__/__qualname__ type checks; cmdloop/onecmd/default method __qualname__; misc_header/undoc_header class attr types."
    - "cmd_extra4 covers: do_help/emptyline/precmd/postcmd/parseline method __qualname__; IDENTCHARS contains 'z'/'9'; doc_header/misc_header/undoc_header values; lastcmd value; Cmd.__mro__.__len__==2."
    - "NEW in this spec: Method __qualname__ checks for columnize/get_names/complete/completenames/complete_help/print_topics (not covered by any prior cmd spec); Cmd.__doc__ is a string; Cmd.__mro__[0]/__name__ and Cmd.__mro__[-1]/__name__ consistency checks."
    - "cmd.Cmd.columnize.__qualname__ == 'Cmd.columnize' — helper for printing tabular data in help output."
    - "cmd.Cmd.get_names.__qualname__ == 'Cmd.get_names' — returns the names of all methods in the class."
    - "cmd.Cmd.complete.__qualname__ == 'Cmd.complete' — tab-completion entry point."
    - "cmd.Cmd.completenames.__qualname__ == 'Cmd.completenames' — returns matching command names."
    - "cmd.Cmd.complete_help.__qualname__ == 'Cmd.complete_help' — tab-completion for help topics."
    - "cmd.Cmd.print_topics.__qualname__ == 'Cmd.print_topics' — prints a section of the help output."
    - "cmd.Cmd.__doc__.__class__.__name__ == 'str' — Cmd has a docstring."
    - "cmd.Cmd.__mro__[0].__name__ == 'Cmd' — first MRO entry is Cmd itself."
    - "cmd.Cmd.__mro__[-1].__name__ == 'object' — last MRO entry is object (MRO length is 2)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Cmd method __qualname__ — columnize, get_names, complete, completenames,
# complete_help, print_topics.
# cmd_extra3 covers cmdloop/onecmd/default; cmd_extra4 covers do_help/
# emptyline/precmd/postcmd/parseline. These six are new here.
# ---------------------------------------------------------------------------

table cmd_extra5.cmd_new_method_qualnames:
  kind: python_call_eq
  category: method_qualnames
  id_prefix: mqn

  columns: [id, function, args, expected]
  rows:
    - [columnize,      Cmd.columnize.__qualname__.__eq__,      ["Cmd.columnize"],      true]
    - [get_names,      Cmd.get_names.__qualname__.__eq__,      ["Cmd.get_names"],      true]
    - [complete,       Cmd.complete.__qualname__.__eq__,       ["Cmd.complete"],       true]
    - [completenames,  Cmd.completenames.__qualname__.__eq__,  ["Cmd.completenames"],  true]
    - [complete_help,  Cmd.complete_help.__qualname__.__eq__,  ["Cmd.complete_help"],  true]
    - [print_topics,   Cmd.print_topics.__qualname__.__eq__,   ["Cmd.print_topics"],   true]

# ---------------------------------------------------------------------------
# Cmd method __name__ checks for the same six methods
# Prior specs do not cover any of these six method __name__ values.
# ---------------------------------------------------------------------------

table cmd_extra5.cmd_new_method_names:
  kind: python_call_eq
  category: methods
  id_prefix: mname

  columns: [id, function, args, expected]
  rows:
    - [columnize,     Cmd.columnize.__name__.__eq__,     ["columnize"],     true]
    - [get_names,     Cmd.get_names.__name__.__eq__,     ["get_names"],     true]
    - [complete,      Cmd.complete.__name__.__eq__,      ["complete"],      true]
    - [completenames, Cmd.completenames.__name__.__eq__, ["completenames"], true]
    - [complete_help, Cmd.complete_help.__name__.__eq__, ["complete_help"], true]
    - [print_topics,  Cmd.print_topics.__name__.__eq__,  ["print_topics"],  true]

# ---------------------------------------------------------------------------
# Cmd.__doc__ — the class has a docstring
# No prior cmd spec checks whether Cmd has a docstring.
# ---------------------------------------------------------------------------

invariant cmd_extra5.Cmd.doc_is_str:
  description: "cmd.Cmd.__doc__.__class__.__name__ == 'str' — Cmd has a docstring"
  category: class_types
  kind: python_call_eq
  function: Cmd.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Cmd.__mro__ entry name checks
# cmd_extra4 checks __mro__.__len__()==2; this spec checks the first and last
# entries by name as complementary structural invariants.
# ---------------------------------------------------------------------------

invariant cmd_extra5.Cmd.mro0_name:
  description: "cmd.Cmd.__mro__[0].__name__ == 'Cmd' — first MRO entry is Cmd itself"
  category: class_hierarchy
  kind: python_call_eq
  function: Cmd.__mro__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Cmd"]
  expected: true

invariant cmd_extra5.Cmd.mro_last_name:
  description: "cmd.Cmd.__mro__[-1].__name__ == 'object' — last MRO entry is object"
  category: class_hierarchy
  kind: python_call_eq
  function: Cmd.__mro__.__getitem__
  args: [-1]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true
