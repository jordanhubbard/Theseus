spec: theseus_collections_cr
version: ">=3.8"
backend: python_cleanroom(theseus_collections_cr)
blocks: collections

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/collections.html"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
  notes:
    - "Clean-room collections module. Do NOT import collections."
    - "Counter, defaultdict, OrderedDict, deque, namedtuple, ChainMap."

error_model: python_exceptions

invariant theseus_collections_cr.collections2_counter:
  description: "Counter counts elements in an iterable"
  category: behavior
  kind: python_call_eq
  function: collections2_counter
  args: []
  expected: true

invariant theseus_collections_cr.collections2_defaultdict:
  description: "defaultdict returns default for missing keys"
  category: behavior
  kind: python_call_eq
  function: collections2_defaultdict
  args: []
  expected: true

invariant theseus_collections_cr.collections2_deque:
  description: "deque supports appendleft and appendright"
  category: behavior
  kind: python_call_eq
  function: collections2_deque
  args: []
  expected: true
