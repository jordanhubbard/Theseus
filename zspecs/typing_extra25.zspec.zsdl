spec: typing_extra25
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html — Python typing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/typing.py"
    - "typing_extra24.zspec.zsdl — covers __module__ table for get_args/get_origin/is_typeddict/no_type_check; __name__ table for get_args/get_origin/is_typeddict; TypeVarTuple/__bases__[0].__name__ standalone; TypeVar/__mro__.__len__==2; ParamSpec/__mro__.__len__==2."
    - "typing_extra23.zspec.zsdl — covers combined __class__.__name__ table for Literal/ClassVar/Final; combined __qualname__.__eq__ table for overload/final/no_type_check/cast."
    - "typing_extra22.zspec.zsdl — covers combined __qualname__ table for Generic/TypeVar/ParamSpec/TypeVarTuple; Generic/__qualname__.__eq__ standalone."
    - "typing_extra21.zspec.zsdl — covers __class__.__name__ for Any/Union/Optional/ClassVar; __name__ and __module__ tables for cast/overload/get_type_hints."
    - "typing_extra20.zspec.zsdl — covers __qualname__.__len__ for overload/final/runtime_checkable."
    - "typing_extra19.zspec.zsdl — covers TypedDict/__qualname__.__eq__ and NamedTuple/__qualname__.__eq__ standalone."
  notes:
    - "This spec extends typing.zspec.zsdl through typing_extra24.zspec.zsdl."
    - "Focus: (1) combined __qualname__ table for Protocol/NamedTuple/TypedDict — not yet combined in any prior table; (2) combined __qualname__.__len__ table for Protocol/NamedTuple/TypedDict; (3) Protocol.__mro__.__len__ == 3 standalone; (4) Protocol.__module__ standalone."
    - "typing_extra22 covers: Generic/TypeVar/ParamSpec/TypeVarTuple in a combined qualname table — Protocol and NamedTuple are absent from that table."
    - "typing_extra19 covers TypedDict/__qualname__.__eq__ and NamedTuple/__qualname__.__eq__ as standalone invariants but not together in a combined table in the extra25 namespace."
    - "Protocol.__qualname__ == 'Protocol' — Protocol is defined at module level in typing."
    - "NamedTuple.__qualname__ == 'NamedTuple' — NamedTuple is a module-level function whose __qualname__ equals its name."
    - "TypedDict.__qualname__ == 'TypedDict' — TypedDict is a module-level function/class whose __qualname__ equals its name."
    - "Protocol.__mro__.__len__() == 3 — MRO is [Protocol, Generic, object]."
    - "Protocol.__module__ == 'typing' — defined in the typing module."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for Protocol, NamedTuple, TypedDict — combined table
#
# typing_extra22 covers Generic/TypeVar/ParamSpec/TypeVarTuple in one table.
# typing_extra19 covers TypedDict/__qualname__.__eq__ and NamedTuple/__qualname__.__eq__
# as standalone invariants but not combined with Protocol in one table.
# No prior spec groups Protocol/NamedTuple/TypedDict together in a combined
# __qualname__ table in the extra25 namespace.
# ---------------------------------------------------------------------------

table typing_extra25.qualnames:
  description: "__qualname__ for Protocol, NamedTuple, TypedDict"
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Protocol,    Protocol.__qualname__.__eq__,    ["Protocol"],    true]
    - [NamedTuple,  NamedTuple.__qualname__.__eq__,  ["NamedTuple"],  true]
    - [TypedDict,   TypedDict.__qualname__.__eq__,   ["TypedDict"],   true]

# ---------------------------------------------------------------------------
# __qualname__.__len__ for Protocol, NamedTuple, TypedDict — combined table
#
# Protocol qualname length == 8 (len('Protocol')).
# NamedTuple qualname length == 10 (len('NamedTuple')).
# TypedDict qualname length == 9 (len('TypedDict')).
# No prior spec collects all three lengths together in one combined table
# in the extra25 namespace.
# ---------------------------------------------------------------------------

table typing_extra25.qualname_lens:
  description: "__qualname__.__len__ for Protocol, NamedTuple, TypedDict"
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [Protocol,   Protocol.__qualname__.__len__,   [], 8]
    - [NamedTuple, NamedTuple.__qualname__.__len__,  [], 10]
    - [TypedDict,  TypedDict.__qualname__.__len__,   [], 9]

# ---------------------------------------------------------------------------
# Protocol.__mro__.__len__() == 3
#
# Protocol's MRO is [Protocol, Generic, object]. typing_extra22 records
# Protocol.__mro__[1].__name__ == 'Generic' and [2].__name__ == 'object'
# via __getitem__. No prior spec records Protocol.__mro__.__len__() == 3
# as a standalone invariant in the extra25 namespace.
# ---------------------------------------------------------------------------

invariant typing_extra25.Protocol.mro_len:
  description: "typing.Protocol.__mro__.__len__() == 3 — MRO is [Protocol, Generic, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: Protocol.__mro__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# Protocol.__module__ == 'typing'
#
# Protocol is defined at module level in Lib/typing.py. Its __module__ is
# 'typing'. No prior spec records Protocol.__module__ as a standalone boolean
# invariant using __eq__ in the extra25 namespace.
# ---------------------------------------------------------------------------

invariant typing_extra25.Protocol.module_eq:
  description: "typing.Protocol.__module__ == 'typing' — Protocol is defined in the typing module"
  category: module_attrs
  kind: python_call_eq
  function: Protocol.__module__.__eq__
  args: ["typing"]
  expected: true
