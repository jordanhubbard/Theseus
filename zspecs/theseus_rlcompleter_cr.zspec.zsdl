spec: theseus_rlcompleter_cr
version: ">=3.8"
backend: python_cleanroom(theseus_rlcompleter_cr)
blocks: rlcompleter

docs: https://docs.python.org/3/library/rlcompleter.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/rlcompleter.html"
  not_derived_from:
    - "CPython source: Lib/rlcompleter.py"
  notes:
    - "Clean-room rlcompleter module. Do NOT import rlcompleter."

error_model: python_exceptions

invariant theseus_rlcompleter_cr.rlcompleter2_create:
  description: "Completer() can be created"
  category: behavior
  kind: python_call_eq
  function: rlcompleter2_create
  args: []
  expected: true

invariant theseus_rlcompleter_cr.rlcompleter2_complete_builtin:
  description: "complete() returns builtins for 'pr'"
  category: behavior
  kind: python_call_eq
  function: rlcompleter2_complete_builtin
  args: []
  expected: true

invariant theseus_rlcompleter_cr.rlcompleter2_complete_none:
  description: "complete() returns None when no more completions"
  category: behavior
  kind: python_call_eq
  function: rlcompleter2_complete_none
  args: []
  expected: true
