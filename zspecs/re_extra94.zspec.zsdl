spec: re_extra94
version: ">=3.9"
backend: python_module(re)
extends: re_extra93

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends all prior re specs through re_extra93."
    - "Prior specs covered: Pattern/Match class identity; Pattern/Match __dict__ membership; method qualnames; re.error/__name__; module-level function qualnames; re.RegexFlag hierarchy; re module constants; Pattern/Match __dict__.__class__.__name__; Pattern/Match __qualname__ and length; PatternError attributes; re.NOFLAG value; Pattern/Match method __doc__.__len__(); re.Pattern/__dict__.__contains__; re module-level function __qualname__ for all functions; Pattern/Match __name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__(); RegexFlag class identity; re.Pattern/Match method __qualname__ string equality; re_extra92 covered re.Pattern/Match method __qualname__ string lengths; re_extra93 covered re module identity (__name__, __package__, __spec__, __loader__, __file__, __doc__, constants class names)."
    - "This spec covers: re.Pattern and re.Match method __qualname__ lengths (scanner and groupdict); re.Pattern/__name__/__module__ equality; re top-level function __code__.co_argcount values."
    - "re.Pattern.scanner.__qualname__.__len__() == 15 — 'Pattern.scanner' has 15 characters."
    - "re.Match.groupdict.__qualname__.__len__() == 15 — 'Match.groupdict' has 15 characters."
    - "re.Match.expand.__qualname__.__len__() == 12 — 'Match.expand' has 12 characters."
    - "re.Pattern.__name__ == 'Pattern' — the class name without module prefix."
    - "re.Pattern.__module__ == 're' — defined in the re module."
    - "re.Match.__name__ == 'Match' — the class name without module prefix."
    - "re.Match.__module__ == 're' — defined in the re module."
    - "re.compile.__code__.co_argcount == 2 — compile(pattern, flags=0) takes 2 args."
    - "re.match.__code__.co_argcount == 3 — match(pattern, string, flags=0) takes 3 args."
    - "re.escape.__code__.co_argcount == 1 — escape(pattern) takes 1 arg."
    - "re.purge.__code__.co_argcount == 0 — purge() takes no args."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern method __qualname__ lengths
# Pattern is a C type from _sre. Method qualnames follow 'Pattern.<method>' format.
# scanner=15 (new), match=13, search=14, findall=15, finditer=16,
# sub=11, subn=12, split=13, fullmatch=17 (covered in re_extra92).
# ---------------------------------------------------------------------------

table re_extra94.Pattern_method_qualname_lengths:
  description: "re.Pattern method __qualname__ string lengths (scanner and cross-checks with prior values)"
  kind: python_call_eq
  category: qualname
  id_prefix: repatternmatch94

  columns: [id, function, args, expected]
  rows:
    - [pattern_scanner_len,   Pattern.scanner.__qualname__.__len__,   [], 15]
    - [pattern_match_len,     Pattern.match.__qualname__.__len__,     [], 13]
    - [pattern_search_len,    Pattern.search.__qualname__.__len__,    [], 14]
    - [pattern_findall_len,   Pattern.findall.__qualname__.__len__,   [], 15]
    - [pattern_finditer_len,  Pattern.finditer.__qualname__.__len__,  [], 16]
    - [pattern_sub_len,       Pattern.sub.__qualname__.__len__,       [], 11]
    - [pattern_subn_len,      Pattern.subn.__qualname__.__len__,      [], 12]
    - [pattern_split_len,     Pattern.split.__qualname__.__len__,     [], 13]

# ---------------------------------------------------------------------------
# re.Match method __qualname__ lengths
# Match method qualnames follow 'Match.<method>' format.
# group=11, groups=12, groupdict=15, start=11, end=9, span=10, expand=12.
# ---------------------------------------------------------------------------

table re_extra94.Match_method_qualname_lengths:
  description: "re.Match method __qualname__ string lengths (groupdict/expand and cross-checks)"
  kind: python_call_eq
  category: qualname
  id_prefix: repatternmatch94

  columns: [id, function, args, expected]
  rows:
    - [match_group_len,     Match.group.__qualname__.__len__,     [], 11]
    - [match_groups_len,    Match.groups.__qualname__.__len__,    [], 12]
    - [match_groupdict_len, Match.groupdict.__qualname__.__len__, [], 15]
    - [match_start_len,     Match.start.__qualname__.__len__,     [], 11]
    - [match_end_len,       Match.end.__qualname__.__len__,       [], 9]
    - [match_span_len,      Match.span.__qualname__.__len__,      [], 10]
    - [match_expand_len,    Match.expand.__qualname__.__len__,    [], 12]

# ---------------------------------------------------------------------------
# re.Pattern and re.Match __name__ and __module__ equality
# Both are C extension types from _sre, but exposed under the re namespace.
# __name__ is the short class name; __module__ is 're'.
# ---------------------------------------------------------------------------

table re_extra94.Pattern_Match_name_module:
  description: "re.Pattern and re.Match __name__ and __module__ string equality"
  kind: python_call_eq
  category: class_identity
  id_prefix: repatternmatch94

  columns: [id, function, args, expected]
  rows:
    - [pattern_name_eq,     Pattern.__name__.__eq__,   ["Pattern"], true]
    - [pattern_module_eq,   Pattern.__module__.__eq__, ["re"],      true]
    - [match_name_eq,       Match.__name__.__eq__,     ["Match"],   true]
    - [match_module_eq,     Match.__module__.__eq__,   ["re"],      true]

# ---------------------------------------------------------------------------
# re top-level function __code__.co_argcount values
# compile(pattern, flags=0)=2; match/search/findall/finditer/fullmatch/sub/subn=3;
# split(pattern, string)=2; escape(pattern)=1; purge()=0.
# ---------------------------------------------------------------------------

table re_extra94.toplevel_func_co_argcount:
  description: "re top-level function __code__.co_argcount values"
  kind: python_call_eq
  category: code_identity
  id_prefix: repatternmatch94

  columns: [id, function, args, expected]
  rows:
    - [compile_argc,   compile.__code__.co_argcount,   [], 2]
    - [match_argc,     match.__code__.co_argcount,     [], 3]
    - [search_argc,    search.__code__.co_argcount,    [], 3]
    - [sub_argc,       sub.__code__.co_argcount,       [], 3]
    - [subn_argc,      subn.__code__.co_argcount,      [], 3]
    - [split_argc,     split.__code__.co_argcount,     [], 2]
    - [findall_argc,   findall.__code__.co_argcount,   [], 3]
    - [finditer_argc,  finditer.__code__.co_argcount,  [], 3]
    - [fullmatch_argc, fullmatch.__code__.co_argcount, [], 3]
    - [escape_argc,    escape.__code__.co_argcount,    [], 1]
    - [purge_argc,     purge.__code__.co_argcount,     [], 0]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra94.Pattern.scanner_qualname_len:
  description: "re.Pattern.scanner.__qualname__.__len__() == 15 ('Pattern.scanner' has 15 characters)"
  category: qualname
  kind: python_call_eq
  function: Pattern.scanner.__qualname__.__len__
  args: []
  expected: 15

invariant re_extra94.Match.groupdict_qualname_len:
  description: "re.Match.groupdict.__qualname__.__len__() == 15 ('Match.groupdict' has 15 characters)"
  category: qualname
  kind: python_call_eq
  function: Match.groupdict.__qualname__.__len__
  args: []
  expected: 15

invariant re_extra94.Pattern.name_eq_Pattern:
  description: "re.Pattern.__name__ == 'Pattern' (the short class name without module prefix)"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra94.compile.co_argcount_2:
  description: "re.compile.__code__.co_argcount == 2 (compile(pattern, flags=0) takes 2 positional parameters)"
  category: code_identity
  kind: python_call_eq
  function: compile.__code__.co_argcount
  args: []
  expected: 2

invariant re_extra94.purge.co_argcount_0:
  description: "re.purge.__code__.co_argcount == 0 (purge() takes no positional parameters)"
  category: code_identity
  kind: python_call_eq
  function: purge.__code__.co_argcount
  args: []
  expected: 0
