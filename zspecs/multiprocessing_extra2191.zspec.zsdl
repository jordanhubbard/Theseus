spec: multiprocessing_extra2191
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2191: context manager protocol dict-presence checks — __enter__, __exit__, __aenter__, __aexit__, acquire, release, __wrapped__, __closure__."
    - "multiprocessing.synchronize.SemLock defines __enter__ and __exit__ directly in its own __dict__; it does NOT define acquire or release at class level — those are added per-instance by _make_methods()."
    - "multiprocessing.synchronize.Lock, RLock, Semaphore, BoundedSemaphore all inherit from SemLock and do not re-define __enter__ or __exit__ in their own __dict__."
    - "multiprocessing.synchronize.Condition defines __enter__ and __exit__ directly in its own __dict__ (does not subclass SemLock)."
    - "multiprocessing.synchronize.Event, Barrier do NOT define any context manager or lock protocol in their own __dict__."
    - "multiprocessing.pool.Pool defines __enter__ and __exit__ directly in its own __dict__."
    - "multiprocessing.managers.BaseManager defines __enter__ and __exit__ directly in its own __dict__."
    - "multiprocessing.queues.Queue, JoinableQueue do NOT define context manager protocol in their own __dict__."
    - "None of the multiprocessing classes define __aenter__ or __aexit__ — multiprocessing does not support async context managers."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table multiprocessing_extra2191.semlock_protocol:
  description: "multiprocessing.synchronize.SemLock dict-presence — __enter__/__exit__ direct; acquire/release are per-instance only"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2191

  columns: [id, function, args, expected]
  rows:
    - ["mp2191001", "multiprocessing.synchronize.SemLock.__dict__.__contains__", ["__enter__"], true]
    - ["mp2191002", "multiprocessing.synchronize.SemLock.__dict__.__contains__", ["__exit__"], true]
    - ["mp2191003", "multiprocessing.synchronize.SemLock.__dict__.__contains__", ["__aenter__"], false]
    - ["mp2191004", "multiprocessing.synchronize.SemLock.__dict__.__contains__", ["__aexit__"], false]
    - ["mp2191005", "multiprocessing.synchronize.SemLock.__dict__.__contains__", ["acquire"], false]
    - ["mp2191006", "multiprocessing.synchronize.SemLock.__dict__.__contains__", ["release"], false]
    - ["mp2191007", "multiprocessing.synchronize.SemLock.__dict__.__contains__", ["__wrapped__"], false]

