  columns: [id, function, args, expected]
  rows:
    - ["mp2191008", "multiprocessing.synchronize.Lock.__dict__.__contains__", ["__enter__"], false]
    - ["mp2191009", "multiprocessing.synchronize.Lock.__dict__.__contains__", ["__exit__"], false]
    - ["mp2191010", "multiprocessing.synchronize.Lock.__dict__.__contains__", ["__aenter__"], false]
    - ["mp2191011", "multiprocessing.synchronize.Lock.__dict__.__contains__", ["acquire"], false]
    - ["mp2191012", "multiprocessing.synchronize.RLock.__dict__.__contains__", ["__enter__"], false]
    - ["mp2191013", "multiprocessing.synchronize.RLock.__dict__.__contains__", ["__exit__"], false]
    - ["mp2191014", "multiprocessing.synchronize.RLock.__dict__.__contains__", ["acquire"], false]

