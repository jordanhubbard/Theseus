spec: hashlib_extra162
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra161.zspec.zsdl — covers hashlib.sha256() HASH method qualnames: sha256().update/__qualname__.__eq__('HASH.update') / sha256().digest/__qualname__.__eq__('HASH.digest') / sha256().hexdigest/__qualname__.__eq__('HASH.hexdigest') / sha256().copy.__qualname__.__eq__('HASH.copy') and qualname lengths (table + invariants)."
    - "hashlib_extra160.zspec.zsdl — covers hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') / new.__qualname__.__eq__('__hash_new') / new.__class__.__name__.__eq__('function') / algorithms_guaranteed.__class__.__name__.__eq__('set') (table + invariants)."
    - "hashlib_extra158.zspec.zsdl — covers hashlib.sha256/__doc__/__class__.__name__.__eq__('str') / md5/__doc__/__class__.__name__.__eq__('str') / sha256/__qualname__.__len__()==14 / md5/__qualname__.__len__()==11 / sha1/__qualname__.__len__()==12 / sha512/__qualname__.__len__()==14 / sha3_256/__qualname__.__len__()==16 (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra161."
    - "Wave 341 theme: hashlib sha256/md5 constructor __name__ strings and __module__ identity — sha256.__name__.__eq__('openssl_sha256') / md5.__name__.__eq__('openssl_md5') / sha256.__module__.__eq__('_hashlib') / md5.__module__.__eq__('_hashlib') / sha256.__doc__.__len__()==66 / md5.__doc__.__len__()==63; hashlib constructors are builtin_function_or_method objects from the _hashlib C extension."
    - "hashlib.sha256.__name__ == 'openssl_sha256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__name__ == 'openssl_md5'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__doc__.__len__() == 66. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__doc__.__len__() == 63. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__doc__.__len__() == 64. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__doc__.__len__() == 66. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__doc__.__len__() == 68. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.sha256.__name__ == 'openssl_sha256' (14 chars = 'openssl_'=8 + 'sha256'=6). hashlib constructors such as sha256, md5, sha1, sha512 are builtin_function_or_method objects provided by the _hashlib C extension (OpenSSL-backed). Their __name__ attribute reflects the C-level function name, which uses the 'openssl_' prefix to distinguish them from any PurePython fallback implementations. hashlib.sha256.__qualname__ == hashlib.sha256.__name__ == 'openssl_sha256' for these constructors. extra158 anchors sha256/__qualname__.__len__()==14 (qualname length) but NOT the string value 'openssl_sha256' as __name__."
    - "Note: hashlib.sha256.__module__ == '_hashlib' (8 chars = '_'=1 + 'hashlib'=7). The constructors sha256, md5, sha1, sha512 are all defined in the _hashlib C extension module (Modules/_hashlib.c). Their __module__ is '_hashlib' (with leading underscore), not 'hashlib' (without underscore). This contrasts with hashlib.new.__module__ == 'hashlib' (extra160 anchors this): new() is a pure Python function defined in Lib/hashlib.py, while sha256/md5 are C extension functions from _hashlib."
    - "Note: hashlib.sha256.__doc__.__len__() == 66. The sha256 docstring is: 'Returns a sha256 hash object; optionally initialized with a string' (66 chars). sha512 also has a 66-char docstring. md5 has 63 chars and sha1 has 64 chars. sha3_256 has 68 chars (longest in this spec). The docstring pattern is 'Returns a <name> hash object; optionally initialized with a string' where the algorithm name length drives the total length. sha3-256 uses a hyphen in the docstring name ('sha3-256') instead of underscore, adding 1 char."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha256.__name__.__eq__('openssl_sha256')
# hashlib.md5.__name__.__eq__('openssl_md5')
# hashlib.sha256.__module__.__eq__('_hashlib')
# hashlib.md5.__module__.__eq__('_hashlib')
#
# Wave 341 theme: hashlib constructor __name__ strings and _hashlib module identity.
#
# sha256.__name__ == 'openssl_sha256' (14 chars = 'openssl_'=8 + 'sha256'=6).
# md5.__name__ == 'openssl_md5' (11 chars = 'openssl_'=8 + 'md5'=3).
# sha256.__module__ == '_hashlib' (8 chars; C extension with leading underscore).
# md5.__module__ == '_hashlib' (8 chars; same C extension as sha256).
# No prior hashlib spec anchors sha256/__name__ string or sha256/__module__ as a table
# under hashctr162. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra162.sha256_md5_constructor_name_and_module:
  description: "hashlib.sha256.__name__.__eq__('openssl_sha256')==True / md5.__name__.__eq__('openssl_md5')==True / sha256.__module__.__eq__('_hashlib')==True / md5.__module__.__eq__('_hashlib')==True — sha256.__name__ is 'openssl_sha256' (14 chars = 'openssl_'=8 + 'sha256'=6; C-level function name in _hashlib; OpenSSL-backed; builtin_function_or_method); md5.__name__ is 'openssl_md5' (11 chars = 'openssl_'=8 + 'md5'=3; same 'openssl_' prefix; 3 chars shorter than sha256); sha256.__module__ is '_hashlib' (8 chars = '_'=1 + 'hashlib'=7; C extension; contrasts with hashlib.new.__module__=='hashlib' from pure Python); md5.__module__ is '_hashlib' (8 chars; same C extension as sha256); first hashctr162 anchor for sha256/__name__ string and sha256/__module__"
  kind: python_call_eq
  category: identity
  id_prefix: hashctr162

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_name_openssl_sha256, "sha256.__name__.__eq__",   ["openssl_sha256"], true, "hashlib.sha256.__name__ == 'openssl_sha256' (14 chars; 'openssl_'=8 + 'sha256'=6; C-level function name from _hashlib OpenSSL backend)"]
    - [md5_name_openssl_md5,       "md5.__name__.__eq__",      ["openssl_md5"],    true, "hashlib.md5.__name__ == 'openssl_md5' (11 chars; 'openssl_'=8 + 'md5'=3; same prefix pattern as sha256; 3 chars shorter)"]
    - [sha256_module_hashlib,      "sha256.__module__.__eq__", ["_hashlib"],       true, "hashlib.sha256.__module__ == '_hashlib' (8 chars; C extension module; contrasts with new.__module__=='hashlib' from pure Python)"]
    - [md5_module_hashlib,         "md5.__module__.__eq__",    ["_hashlib"],       true, "hashlib.md5.__module__ == '_hashlib' (8 chars; same C extension as sha256; both OpenSSL-backed constructors share _hashlib module)"]

# ---------------------------------------------------------------------------
# hashlib.sha256.__name__.__len__()==14
# hashlib.md5.__name__.__len__()==11
# hashlib.sha256.__doc__.__len__()==66
# hashlib.md5.__doc__.__len__()==63
#
# Wave 341 theme: constructor __name__ and __doc__ lengths across sha256/md5.
#
# sha256.__name__.__len__() == 14 ('openssl_sha256' = 'openssl_'=8 + 'sha256'=6 = 14).
# md5.__name__.__len__() == 11 ('openssl_md5' = 'openssl_'=8 + 'md5'=3 = 11).
# sha256.__doc__.__len__() == 66 (docstring: 'Returns a sha256 hash object...').
# md5.__doc__.__len__() == 63 (docstring: 'Returns a md5 hash object...').
# Length ordering: md5_name(11) < sha256_name(14); md5_doc(63) < sha256_doc(66).
# No prior hashlib spec anchors sha256/__name__.__len__() or sha256/__doc__.__len__() as a table
# under hashctr162. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra162.sha256_md5_name_and_doc_lengths:
  description: "hashlib.sha256.__name__.__len__()==14 / md5.__name__.__len__()==11 / sha256.__doc__.__len__()==66 / md5.__doc__.__len__()==63 — sha256.__name__ is 14 chars ('openssl_sha256' = 'openssl_'=8 + 'sha256'=6; extra158 anchors __qualname__.__len__()==14 but NOT __name__.__len__()); md5.__name__ is 11 chars ('openssl_md5' = 'openssl_'=8 + 'md5'=3; same prefix; shorter algorithm name); sha256.__doc__ is 66 chars ('Returns a sha256 hash object; optionally initialized with a string'); md5.__doc__ is 63 chars ('Returns a md5 hash object; optionally initialized with a string'; 3 chars shorter because 'sha256' vs 'md5' = 3 char difference); length ordering: md5_name(11) < sha256_name(14); md5_doc(63) < sha1_doc(64) < sha256_doc==sha512_doc(66) < sha3_256_doc(68); first hashctr162 anchor for these length values"
  kind: python_call_eq
  category: identity
  id_prefix: hashctr162

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_name_len_14,  "sha256.__name__.__len__",  [], 14, "hashlib.sha256.__name__.__len__() is 14 ('openssl_sha256' = 'openssl_'=8 + 'sha256'=6 = 14; extra158 anchors qualname len but not __name__ len)"]
    - [md5_name_len_11,     "md5.__name__.__len__",     [], 11, "hashlib.md5.__name__.__len__() is 11 ('openssl_md5' = 'openssl_'=8 + 'md5'=3 = 11; 3 chars shorter than sha256 name)"]
    - [sha256_doc_len_66,   "sha256.__doc__.__len__",   [], 66, "hashlib.sha256.__doc__.__len__() is 66 ('Returns a sha256 hash object; optionally initialized with a string' = 66 chars)"]
    - [md5_doc_len_63,      "md5.__doc__.__len__",      [], 63, "hashlib.md5.__doc__.__len__() is 63 ('Returns a md5 hash object; optionally initialized with a string' = 63 chars; 3 fewer than sha256)"]

# ---------------------------------------------------------------------------
# hashlib doc length ordering across hash constructors
#
# Wave 341 theme: docstring length ordering across sha1/sha512/sha3_256.
#
# sha1.__doc__.__len__() == 64.
# sha512.__doc__.__len__() == 66 (ties sha256).
# sha3_256.__doc__.__len__() == 68 (longest in this spec).
# Full ordering: md5(63) < sha1(64) < sha256==sha512(66) < sha3_256(68).
# No prior hashlib spec anchors sha1/sha512/sha3_256 doc lengths as a table under hashctr162.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra162.hash_constructor_doc_length_ordering:
  description: "hashlib.sha1.__doc__.__len__()==64 / sha512.__doc__.__len__()==66 / sha3_256.__doc__.__len__()==68 / sha256.__doc__.__len__()==66 — sha1.__doc__ is 64 chars ('Returns a sha1 hash object; optionally initialized with a string'); sha512.__doc__ is 66 chars (same length as sha256; algorithm 'sha512' = 6 chars same as 'sha256'); sha3_256.__doc__ is 68 chars (longest; 'sha3-256' uses a hyphen so the algorithm name in docstring is 8 chars vs 6 chars for sha256; 'sha3-256' != 'sha3_256'); sha256.__doc__ confirmed at 66 chars; ordering: md5(63) < sha1(64) < sha256==sha512(66) < sha3_256(68); first hashctr162 anchor for sha1/sha512/sha3_256 doc lengths"
  kind: python_call_eq
  category: identity
  id_prefix: hashctr162

  columns: [id, function, args, expected, description]
  rows:
    - [sha1_doc_len_64,     "sha1.__doc__.__len__",     [], 64, "hashlib.sha1.__doc__.__len__() is 64 ('Returns a sha1 hash object; optionally initialized with a string' = 64 chars)"]
    - [sha512_doc_len_66,   "sha512.__doc__.__len__",   [], 66, "hashlib.sha512.__doc__.__len__() is 66 ('Returns a sha512 hash object; ...'; same length as sha256; 'sha512'=6 chars same as 'sha256'=6)"]
    - [sha3_256_doc_len_68, "sha3_256.__doc__.__len__", [], 68, "hashlib.sha3_256.__doc__.__len__() is 68 ('Returns a sha3-256 hash object; ...'; 'sha3-256'=8 chars with hyphen; 2 more than 'sha256'=6; longest in spec)"]
    - [sha256_doc_len_66b,  "sha256.__doc__.__len__",   [], 66, "hashlib.sha256.__doc__.__len__() is 66 (confirmed; ties sha512 at 66; md5(63) < sha1(64) < sha256==sha512(66) < sha3_256(68))"]

# ---------------------------------------------------------------------------
# hashlib.sha256.__name__.__eq__('openssl_sha256') — standalone
#
# hashlib.sha256.__name__ is 'openssl_sha256' (14 chars). hashlib.sha256 is a
# builtin_function_or_method defined in the _hashlib C extension (Modules/_hashlib.c).
# Its C-level function name includes the 'openssl_' prefix, reflecting that these
# constructors wrap OpenSSL's EVP digest API. The __name__ attribute of a
# builtin_function_or_method is the C-level name, not the Python attribute name through
# which it is accessed (hashlib.sha256). So sha256.__name__ == 'openssl_sha256' even
# though the attribute is accessed as hashlib.sha256. Similarly, md5.__name__ ==
# 'openssl_md5'. Note that sha256.__name__ == sha256.__qualname__ == 'openssl_sha256'
# (extra158 anchors __qualname__.__len__()==14 but not the __name__ string value).
# No prior hashlib spec anchors sha256.__name__ string as a standalone under hashctr162.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra162.sha256_name_openssl_sha256:
  description: "hashlib.sha256.__name__.__eq__('openssl_sha256') == True — 14 chars = 'openssl_'=8 + 'sha256'=6; builtin_function_or_method from _hashlib C extension; 'openssl_' prefix reflects OpenSSL EVP digest API wrapper; C-level function name differs from Python attribute name 'sha256'; sha256.__name__==sha256.__qualname__=='openssl_sha256'; extra158 anchors __qualname__.__len__()==14 but not the string value as __name__; md5.__name__=='openssl_md5' (11 chars); no prior hashlib spec anchors sha256.__name__ string as a standalone; first standalone under hashctr162"
  category: identity
  kind: python_call_eq
  function: sha256.__name__.__eq__
  args: ["openssl_sha256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha256.__module__.__eq__('_hashlib') — standalone
#
# hashlib.sha256.__module__ is '_hashlib' (8 chars = '_'=1 + 'hashlib'=7). The
# hashlib constructors sha256, md5, sha1, sha512, sha3_256 are all defined in the
# _hashlib C extension module, which lives at Modules/_hashlib.c in the CPython
# source and is compiled as _hashlib.so (or equivalent). The leading underscore in
# '_hashlib' is a Python convention indicating a private or implementation module.
# hashlib.py (the pure Python wrapper) re-exports these constructors as hashlib.sha256
# etc. This contrasts with hashlib.new.__module__ == 'hashlib' (extra160 anchors this):
# new() is defined in Lib/hashlib.py (the pure Python wrapper). '_hashlib' = 8 chars
# ('_'=1 + 'hashlib'=7). No prior hashlib spec anchors sha256.__module__ as a standalone
# under hashctr162. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra162.sha256_module_hashlib:
  description: "hashlib.sha256.__module__.__eq__('_hashlib') == True — 8 chars = '_'=1 + 'hashlib'=7; private C extension module (leading underscore = implementation module convention); Modules/_hashlib.c in CPython source; compiled as _hashlib.so; hashlib.py re-exports these constructors as public API; contrasts with new.__module__=='hashlib' (8 chars for 'hashlib' vs 8 chars for '_hashlib' — same length, different strings!); md5.__module__=='_hashlib' (same C extension); no prior hashlib spec anchors sha256.__module__ as a standalone; first standalone under hashctr162"
  category: identity
  kind: python_call_eq
  function: sha256.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5.__name__.__eq__('openssl_md5') — standalone
#
# hashlib.md5.__name__ is 'openssl_md5' (11 chars = 'openssl_'=8 + 'md5'=3). Like
# sha256, md5 is a builtin_function_or_method from the _hashlib C extension. The 'openssl_'
# prefix (8 chars) is common to all hashlib constructors wrapping OpenSSL's EVP API.
# 'md5' (3 chars) is the shortest algorithm name among the common hashlib constructors
# (sha1=4, sha256=6, sha512=6, sha3_256=8). This makes 'openssl_md5' (11 chars) the
# shortest __name__ among the commonly used hashlib constructors, with ordering:
# openssl_md5(11) < openssl_sha1(12) < openssl_sha256==openssl_sha512(14) < openssl_sha3_256(16).
# No prior hashlib spec anchors md5.__name__ string as a standalone under hashctr162.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra162.md5_name_openssl_md5:
  description: "hashlib.md5.__name__.__eq__('openssl_md5') == True — 11 chars = 'openssl_'=8 + 'md5'=3; 'md5' is 3 chars (shortest algorithm name among common hashlib constructors); builtin_function_or_method from _hashlib C extension; same 'openssl_' prefix as sha256 (8 chars); length ordering: openssl_md5(11) < openssl_sha1(12) < openssl_sha256==openssl_sha512(14); md5.__module__=='_hashlib'; md5.__name__==md5.__qualname__; no prior hashlib spec anchors md5.__name__ string as a standalone; first standalone under hashctr162"
  category: identity
  kind: python_call_eq
  function: md5.__name__.__eq__
  args: ["openssl_md5"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__doc__.__len__()==68 — standalone
#
# hashlib.sha3_256.__doc__.__len__() is 68. The sha3_256 docstring is:
# 'Returns a sha3-256 hash object; optionally initialized with a string' (68 chars).
# Note that the docstring uses 'sha3-256' (with a hyphen) while the Python attribute
# name uses 'sha3_256' (with an underscore). This gives sha3_256 a docstring 2 chars
# longer than sha256 and sha512 (which both have 66-char docstrings). 68 is the longest
# docstring length among the hash constructors in this spec. The ordering is:
# md5(63) < sha1(64) < sha256==sha512(66) < sha3_256(68).
# No prior hashlib spec anchors sha3_256.__doc__.__len__() as a standalone under hashctr162.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra162.sha3_256_doc_len_68:
  description: "hashlib.sha3_256.__doc__.__len__() == 68 — 'Returns a sha3-256 hash object; optionally initialized with a string' = 68 chars; docstring uses 'sha3-256' (hyphen) while attr is 'sha3_256' (underscore); 'sha3-256'=8 chars vs 'sha256'=6 chars gives 2-char difference in docstring length (66 vs 68); longest docstring among hash constructors in this spec; ordering: md5(63) < sha1(64) < sha256==sha512(66) < sha3_256(68); sha3_256.__doc__.__class__.__name__=='str' (extra158 pattern for sha256); no prior hashlib spec anchors sha3_256.__doc__.__len__() as a standalone; first standalone under hashctr162"
  category: identity
  kind: python_call_eq
  function: sha3_256.__doc__.__len__
  args: []
  expected: 68
