spec: shelve_extra4
version: ">=3.0"
backend: python_module(shelve)

docs: https://docs.python.org/3/library/shelve.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/shelve.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "shelve source: internal dbm backend implementation details"
  notes:
    - "This spec extends shelve.zspec.zsdl, shelve_extra.zspec.zsdl, shelve_extra2.zspec.zsdl, and shelve_extra3.zspec.zsdl."
    - "shelve.zspec.zsdl covers: open/__name__; Shelf/BsdDbShelf/DbfilenameShelf __name__; Shelf/__module__/DbfilenameShelf/__module__; Shelf.__bases__[0].__name__=='MutableMapping'; DbfilenameShelf.__bases__[0].__name__=='Shelf'."
    - "shelve_extra.zspec.zsdl covers: Shelf/__name__/__module__; BsdDbShelf/__name__; DbfilenameShelf/__name__; open/__name__."
    - "shelve_extra2.zspec.zsdl covers: Shelf/__name__; BsdDbShelf/__name__; DbfilenameShelf/__name__; Shelf/__module__; Shelf.__bases__[0] (MutableMapping); open/__name__; open/__module__."
    - "shelve_extra3.zspec.zsdl covers: BsdDbShelf/__module__; DbfilenameShelf/__module__; Shelf.__bases__.__len__; DbfilenameShelf.__bases__.__len__; open.__class__.__name__; class metatype table; BsdDbShelf.__bases__[0].__name__=='Shelf'."
    - "This spec adds: __qualname__ for open, Shelf, BsdDbShelf, and DbfilenameShelf — not covered in any prior shelve spec."
    - "For top-level classes and module-level functions, __qualname__ == __name__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for module-level function and classes
# None of the prior shelve specs check __qualname__ for any symbol.
# For top-level names __qualname__ == __name__.
# ---------------------------------------------------------------------------

table shelve_extra4.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [open,             open.__qualname__.__eq__,             ["open"],             true]
    - [Shelf,            Shelf.__qualname__.__eq__,            ["Shelf"],            true]
    - [BsdDbShelf,       BsdDbShelf.__qualname__.__eq__,       ["BsdDbShelf"],       true]
    - [DbfilenameShelf,  DbfilenameShelf.__qualname__.__eq__,  ["DbfilenameShelf"],  true]
