spec: theseus_time_cr
version: ">=3.9"
backend: python_cleanroom(theseus_time_cr)
blocks: time

docs: https://docs.python.org/3/library/time.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/time.html"
    - "https://pubs.opengroup.org/onlinepubs/9699919799/ — POSIX time"
  notes:
    - "Clean-room time utilities. Do NOT import time, datetime, or calendar."
    - "struct_time: namedtuple-like with tm_year, tm_mon, tm_mday, tm_hour, tm_min, tm_sec, tm_wday, tm_yday, tm_isdst."
    - "gmtime(seconds=0): convert seconds since epoch to struct_time in UTC."
    - "mktime(struct_time): inverse of gmtime; returns seconds since epoch."
    - "gmtime(0) has tm_year=1970, tm_mon=1, tm_mday=1 (Unix epoch)."
    - "mktime(gmtime(86400)) == 86400 (round-trip for 1 day)."
    - "time_gmtime_epoch(): gmtime(0).tm_year == 1970."
    - "time_gmtime_month(): gmtime(0).tm_mon == 1."
    - "time_mktime_roundtrip(): mktime(gmtime(86400)) == 86400."
    - "Export: struct_time, gmtime(secs) -> struct_time, mktime(t) -> float."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_time_cr.gmtime_epoch_year:
  description: "gmtime(0).tm_year == 1970"
  category: gmtime
  kind: python_call_eq
  function: time_gmtime_epoch
  args: []
  expected: 1970

invariant theseus_time_cr.gmtime_epoch_month:
  description: "gmtime(0).tm_mon == 1"
  category: gmtime
  kind: python_call_eq
  function: time_gmtime_month
  args: []
  expected: 1

invariant theseus_time_cr.mktime_roundtrip:
  description: "mktime(gmtime(86400)) == 86400"
  category: mktime
  kind: python_call_eq
  function: time_mktime_roundtrip
  args: []
  expected: 86400
