spec: sched
version: ">=3.x"
backend: python_module(sched)

docs: https://docs.python.org/3/library/sched.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/sched.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sched.py"
  notes:
    - "sched.scheduler is a class; sched.Event is a namedtuple subclass."
    - "A freshly constructed scheduler() has no events: empty() returns True and queue == []."
    - "scheduler.queue is a read-only property returning a sorted list of pending Event objects."
    - "The Event namedtuple has fields: time, priority, sequence, action, argument, kwargs."
    - "scheduler.__module__ == 'sched' because the class is defined at module top-level."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "scheduler.run() raises ValueError if delay is negative; enter() and enterabs() raise ValueError if time or priority is not comparable."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Class name attributes
# ---------------------------------------------------------------------------

invariant sched.scheduler.class_name:
  description: "sched.scheduler.__name__ == 'scheduler'"
  category: classnames
  kind: python_call_eq
  function: "scheduler.__name__.__eq__"
  args: ["scheduler"]
  expected: true

invariant sched.scheduler.module:
  description: "sched.scheduler.__module__ == 'sched'"
  category: classnames
  kind: python_call_eq
  function: "scheduler.__module__.__eq__"
  args: ["sched"]
  expected: true

invariant sched.Event.class_name:
  description: "sched.Event.__name__ == 'Event'"
  category: classnames
  kind: python_call_eq
  function: "Event.__name__.__eq__"
  args: ["Event"]
  expected: true

# ---------------------------------------------------------------------------
# Empty scheduler — empty() and queue
# ---------------------------------------------------------------------------

invariant sched.new_scheduler_is_empty:
  description: "scheduler().empty() == True — a freshly created scheduler has no events"
  category: behavior
  kind: python_call_eq
  function: scheduler
  args: []
  method: empty
  method_args: []
  expected: true

invariant sched.new_scheduler_queue_empty:
  description: "scheduler().queue == [] — a freshly created scheduler has an empty queue list"
  category: behavior
  kind: python_call_eq
  function: scheduler
  args: []
  method: queue
  expected: []

# ---------------------------------------------------------------------------
# scheduler instance has expected methods
# ---------------------------------------------------------------------------

table sched.scheduler.methods:
  kind: python_call_eq
  category: classnames
  id_prefix: method_name

  columns: [id, function, args, expected]
  rows:
    - [enter,    "scheduler.enter.__name__.__eq__",    ["enter"],    true]
    - [enterabs, "scheduler.enterabs.__name__.__eq__",  ["enterabs"], true]
    - [cancel,   "scheduler.cancel.__name__.__eq__",   ["cancel"],   true]
    - [run,      "scheduler.run.__name__.__eq__",      ["run"],      true]
    - [empty,    "scheduler.empty.__name__.__eq__",    ["empty"],    true]

# ---------------------------------------------------------------------------
# Event namedtuple fields
# ---------------------------------------------------------------------------

invariant sched.Event.fields:
  description: "Event._fields contains the expected namedtuple field names"
  category: behavior
  kind: python_set_contains
  attribute: "Event._fields"
  must_contain: ["time", "priority", "action", "argument"]

# ---------------------------------------------------------------------------
# scheduler is a class (not a function)
# ---------------------------------------------------------------------------

invariant sched.scheduler.is_type:
  description: "sched.scheduler.__class__.__name__ == 'type' — scheduler is a class"
  category: classnames
  kind: python_call_eq
  function: "scheduler.__class__.__name__.__eq__"
  args: ["type"]
  expected: true

