spec: string_extra
version: ">=3.0"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/string.py"
  notes:
    - "This spec covers aspects not in string.zspec.zsdl: Formatter and Template class identity, constant type checks (all are str), and capwords function name."
    - "All module-level string constants (ascii_letters, digits, etc.) are instances of str."
    - "Formatter is a pure-Python class in the string module; __name__ == 'Formatter', __module__ == 'string'."
    - "Template is a pure-Python class in the string module; __name__ == 'Template', __module__ == 'string'."
    - "capwords is a module-level function; capwords.__name__ == 'capwords'."
    - "Type checks use __class__.__name__.__eq__ pattern to verify the constant is a str instance."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Formatter — class identity
# ---------------------------------------------------------------------------

invariant string_extra.formatter.class_name:
  description: "Formatter.__name__ == 'Formatter'"
  category: formatter
  kind: python_call_eq
  function: Formatter.__name__.__eq__
  args: ["Formatter"]
  expected: true

invariant string_extra.formatter.module_name:
  description: "Formatter.__module__ == 'string'"
  category: formatter
  kind: python_call_eq
  function: Formatter.__module__.__eq__
  args: ["string"]
  expected: true

# ---------------------------------------------------------------------------
# Template — class identity
# ---------------------------------------------------------------------------

invariant string_extra.template.class_name:
  description: "Template.__name__ == 'Template'"
  category: template
  kind: python_call_eq
  function: Template.__name__.__eq__
  args: ["Template"]
  expected: true

invariant string_extra.template.module_name:
  description: "Template.__module__ == 'string'"
  category: template
  kind: python_call_eq
  function: Template.__module__.__eq__
  args: ["string"]
  expected: true

# ---------------------------------------------------------------------------
# capwords — function identity
# ---------------------------------------------------------------------------

invariant string_extra.capwords.function_name:
  description: "capwords.__name__ == 'capwords'"
  category: capwords
  kind: python_call_eq
  function: capwords.__name__.__eq__
  args: ["capwords"]
  expected: true

# ---------------------------------------------------------------------------
# Module constants — type checks (all constants are str instances)
#
# Pattern: constant.__class__.__name__.__eq__('str') → true
# ---------------------------------------------------------------------------

table string_extra.constants.type_is_str:
  kind: python_call_eq
  category: constants
  id_prefix: type_str

  columns: [id, function, args, expected]
  rows:
    - [ascii_letters,   ascii_letters.__class__.__name__.__eq__,   ["str"],  true]
    - [ascii_lowercase, ascii_lowercase.__class__.__name__.__eq__,  ["str"],  true]
    - [ascii_uppercase, ascii_uppercase.__class__.__name__.__eq__,  ["str"],  true]
    - [digits,          digits.__class__.__name__.__eq__,           ["str"],  true]
    - [hexdigits,       hexdigits.__class__.__name__.__eq__,        ["str"],  true]
    - [octdigits,       octdigits.__class__.__name__.__eq__,        ["str"],  true]
    - [punctuation,     punctuation.__class__.__name__.__eq__,      ["str"],  true]
    - [whitespace,      whitespace.__class__.__name__.__eq__,       ["str"],  true]

# ---------------------------------------------------------------------------
# Module constants — length checks for digits and ascii_lowercase
#
# These are distinct from string.zspec.zsdl only in being cross-referenced here;
# they serve as anchor invariants confirming the same values in this spec context.
# ---------------------------------------------------------------------------

invariant string_extra.constants.digits_len:
  description: "len(digits) == 10 — digits is '0123456789'"
  category: constants
  kind: python_call_eq
  function: digits.__len__
  args: []
  expected: 10

invariant string_extra.constants.ascii_lowercase_len:
  description: "len(ascii_lowercase) == 26 — ascii_lowercase is 'abcdefghijklmnopqrstuvwxyz'"
  category: constants
  kind: python_call_eq
  function: ascii_lowercase.__len__
  args: []
  expected: 26
