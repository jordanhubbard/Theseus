spec: abc_extra571
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module class and function identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers class, function, module, and method identity for core abc types; abstractmethod is a plain function"
  created_at: "2026-04-12T00:00:00Z"

table abc_extra571.class_identity:
  description: "Identity checks for abc objects via __class__.__name__"
  kind: python_call_eq
  category: class_identity
  id_prefix: ABCEX571
  columns: [id, function, args, expected]
  rows:
    - [ABCEX571001, abc.ABC.__class__.__name__.__eq__, ["type"], true]
    - [ABCEX571002, abc.ABCMeta.__class__.__name__.__eq__, ["type"], true]
    - [ABCEX571003, abc.abstractmethod.__class__.__name__.__eq__, ["function"], true]
table abc_extra571.class_qualname:
  description: "Qualname checks for abc class objects"
  kind: python_call_eq
  category: class_qualname
  id_prefix: ABCEX571Q
  columns: [id, function, args, expected]
  rows:
    - [ABCEX571Q001, abc.ABC.__qualname__.__eq__, ["ABC"], true]
    - [ABCEX571Q002, abc.ABCMeta.__qualname__.__eq__, ["ABCMeta"], true]
table abc_extra571.module_identity:
  description: "Module identity checks for abc objects via __module__"
  kind: python_call_eq
  category: module_identity
  id_prefix: ABCEX571M
  columns: [id, function, args, expected]
  rows:
    - [ABCEX571M001, abc.ABC.__module__.__eq__, ["abc"], true]
    - [ABCEX571M002, abc.ABCMeta.__module__.__eq__, ["abc"], true]
    - [ABCEX571M003, abc.abstractmethod.__module__.__eq__, ["abc"], true]
table abc_extra571.method_qualname:
  description: "Qualname checks for ABCMeta methods"
  kind: python_call_eq
  category: method_qualname
  id_prefix: ABCEX571MQ
  columns: [id, function, args, expected]
  rows:
    - [ABCEX571MQ001, abc.ABCMeta.__init__.__qualname__.__eq__, ["ABCMeta.__init__"], true]
    - [ABCEX571MQ002, abc.ABCMeta.register.__qualname__.__eq__, ["ABCMeta.register"], true]
    - [ABCEX571MQ003, abc.ABCMeta.__instancecheck__.__qualname__.__eq__, ["ABCMeta.__instancecheck__"], true]
    - [ABCEX571MQ004, abc.ABCMeta.__subclasscheck__.__qualname__.__eq__, ["ABCMeta.__subclasscheck__"], true]