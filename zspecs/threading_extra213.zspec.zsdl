spec: threading_extra213
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "threading_extra212.zspec.zsdl — covers threading attribute checks prior to extra213"
    - "threading_sync.zspec.zsdl — covers threading synchronization primitive behavior"
    - "threading.zspec.zsdl — covers core threading function behavior"
  notes:
    - "threading.Thread.__qualname__ == 'Thread' — Thread is a Python class defined in threading; its __qualname__ is 'Thread' (6 characters). Verified with Python 3.14.3."
    - "threading.Lock.__qualname__ == 'lock' — Lock is a C-implemented type (allocate_lock from _thread); its __qualname__ is 'lock' (lowercase, 4 characters), not 'Lock'. Verified with Python 3.14.3."
    - "threading.RLock.__qualname__ == 'RLock' — RLock is a Python class defined in threading (with C acceleration available); its __qualname__ is 'RLock' (5 characters). Verified with Python 3.14.3."
    - "threading.Event.__qualname__ == 'Event' — Event is a Python class defined in threading; its __qualname__ is 'Event' (5 characters). Verified with Python 3.14.3."
    - "threading.Condition.__qualname__ == 'Condition' — Condition is a Python class defined in threading; its __qualname__ is 'Condition' (9 characters). Verified with Python 3.14.3."
    - "threading.Semaphore.__qualname__ == 'Semaphore' — Semaphore is a Python class defined in threading; its __qualname__ is 'Semaphore' (9 characters). Verified with Python 3.14.3."
    - "threading.Lock.__qualname__ is 'lock' (lowercase) — this is a key distinction from 'Lock' (the module-level factory function); the C type's __qualname__ uses the internal C-level name. Verified with Python 3.14.3."
    - "threading.Barrier.__qualname__ == 'Barrier' — Barrier is a Python class in threading; its __qualname__ is 'Barrier' (7 characters). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading __qualname__ equality checks — Thread, Lock, RLock
#
# Thread.__qualname__.__eq__('Thread') == True
# Lock.__qualname__.__eq__('lock')     == True   (C type, lowercase)
# RLock.__qualname__.__eq__('RLock')   == True
# Lock.__qualname__.__eq__('Lock')     == False  (capital L is wrong for C type)
# ---------------------------------------------------------------------------

table threading_extra213.qualname_eq_group1:
  description: "threading __qualname__ equality checks for Thread, Lock, and RLock in threadqualname213g1 namespace — Thread.__qualname__ is 'Thread' (True), Lock.__qualname__ is 'lock' lowercase (True), RLock.__qualname__ is 'RLock' (True), and Lock.__qualname__.__eq__('Lock') is False (C type uses lowercase 'lock'); all four rows verified with Python 3.14.3"
  kind: python_call_eq
  category: qualname
  id_prefix: threadqualname213g1

  columns: [id, function, args, expected, description]
  rows:
    - [thread_qualname_eq,
       "Thread.__qualname__.__eq__",
       ["Thread"],
       true,
       "threading.Thread.__qualname__.__eq__('Thread') == True — Thread is a Python class defined in threading; its __qualname__ is 'Thread' (6 characters); __eq__('Thread') returns True; verified with Python 3.14.3"]
    - [lock_qualname_eq_lowercase,
       "Lock.__qualname__.__eq__",
       ["lock"],
       true,
       "threading.Lock.__qualname__.__eq__('lock') == True — Lock is backed by a C-implemented type (_thread.lock); its __qualname__ is 'lock' (lowercase, 4 characters), not 'Lock'; __eq__('lock') returns True; verified with Python 3.14.3"]
    - [rlock_qualname_eq,
       "RLock.__qualname__.__eq__",
       ["RLock"],
       true,
       "threading.RLock.__qualname__.__eq__('RLock') == True — RLock is a Python class defined in threading; its __qualname__ is 'RLock' (5 characters); __eq__('RLock') returns True; verified with Python 3.14.3"]
    - [lock_qualname_neq_capital,
       "Lock.__qualname__.__eq__",
       ["Lock"],
       false,
       "threading.Lock.__qualname__.__eq__('Lock') == False — the C type's __qualname__ is 'lock' (lowercase); comparing against 'Lock' (capital L) returns False; the module-level name 'Lock' is a factory, not the type name; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
