       ["Event"],
       true,
       "threading.Event.__qualname__.__eq__('Event') == True — Event is a Python class defined in threading; its __qualname__ is 'Event' (5 characters); __eq__('Event') returns True; verified with Python 3.14.3"]
    - [condition_qualname_eq,
       "Condition.__qualname__.__eq__",
       ["Condition"],
       true,
       "threading.Condition.__qualname__.__eq__('Condition') == True — Condition is a Python class defined in threading; its __qualname__ is 'Condition' (9 characters); __eq__('Condition') returns True; verified with Python 3.14.3"]
    - [semaphore_qualname_eq,
       "Semaphore.__qualname__.__eq__",
       ["Semaphore"],
       true,
       "threading.Semaphore.__qualname__.__eq__('Semaphore') == True — Semaphore is a Python class defined in threading; its __qualname__ is 'Semaphore' (9 characters); __eq__('Semaphore') returns True; verified with Python 3.14.3"]
    - [event_qualname_neq_lowercase,
       "Event.__qualname__.__eq__",
       ["event"],
       false,
       "threading.Event.__qualname__.__eq__('event') == False — __qualname__ is 'Event' (capital E); comparing against 'event' (lowercase e) returns False; __eq__ is case-sensitive; verified with Python 3.14.3"]

