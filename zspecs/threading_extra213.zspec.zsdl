#
# Event.__qualname__.__eq__('Event')         == True
# Condition.__qualname__.__eq__('Condition') == True
# Semaphore.__qualname__.__eq__('Semaphore') == True
# Event.__qualname__.__eq__('event')         == False  (case-sensitive)
# ---------------------------------------------------------------------------

