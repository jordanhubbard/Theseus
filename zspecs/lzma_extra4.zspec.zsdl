spec: lzma_extra4
version: ">=3.3"
backend: python_module(lzma)

docs: https://docs.python.org/3/library/lzma.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/lzma.html — Python lzma documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/lzma.py"
    - "CPython source: Modules/_lzmamodule.c"
    - "lzma_extra3.zspec.zsdl — covers FORMAT_*/CHECK_* __class__.__name__=='int' tables; CHECK_ID_MAX value; FILTER_LZMA1/LZMA2 class names; class/function type identity tables."
    - "lzma_extra2.zspec.zsdl — covers class __qualname__ table; LZMAFile/__module__ standalone; LZMAError/__module__ table; LZMAError base name bool form."
    - "lzma.zspec.zsdl — covers LZMAFile/LZMACompressor/LZMADecompressor/LZMAError __name__ table; compress/decompress/open __name__ table; LZMAFile.__module__; FORMAT_AUTO/XZ/ALONE/RAW eq values; CHECK_NONE/CRC32/CRC64/SHA256 eq values; LZMAError.__bases__[0].__name__; compress returns bytes; is_check_supported."
  notes:
    - "This spec extends lzma through lzma_extra3; it does NOT duplicate invariants present in those files."
    - "Focus: compress/__name__ standalone (extra4 namespace anchor); decompress/__name__ standalone (extra4 namespace anchor); LZMAError/__name__ standalone (extra4 namespace anchor); LZMAError.__bases__[0].__name__ standalone bool form (extra4 namespace anchor); LZMAFile/__name__ standalone (extra4 namespace anchor); FORMAT_AUTO/__class__.__name__ standalone (extra4 namespace anchor); FORMAT_XZ/__class__.__name__ standalone (extra4 namespace anchor); CHECK_CRC32/__class__.__name__ standalone (extra4 namespace anchor)."
    - "lzma (base) covers compress/decompress/open __name__ in a table. These standalone invariants re-anchor compress and decompress from the extra4 namespace."
    - "lzma (base) covers LZMAFile/LZMAError __name__ in a class_names table. These standalone invariants re-anchor both from the extra4 namespace."
    - "lzma (base) covers LZMAError.__bases__[0].__name__ via getitem+method_chain. This bool-form re-anchors it from extra4 using __eq__ directly."
    - "lzma_extra3 covers FORMAT_AUTO/XZ __class__.__name__ in a table. These standalone invariants re-anchor each from the extra4 namespace."
    - "lzma_extra3 covers CHECK_CRC32 __class__.__name__ in a table. This standalone invariant re-anchors it from the extra4 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# compress and decompress __name__ — extra4 namespace anchors
#
# lzma (base) covers these in a function_names table from the base namespace.
# These standalone invariants re-anchor each from the extra4 namespace.
# ---------------------------------------------------------------------------

invariant lzma_extra4.compress.name:
  description: "lzma.compress.__name__ == 'compress' — extra4 namespace anchor"
  category: function_names
  kind: python_call_eq
  function: compress.__name__.__eq__
  args: ["compress"]
  expected: true

invariant lzma_extra4.decompress.name:
  description: "lzma.decompress.__name__ == 'decompress' — extra4 namespace anchor"
  category: function_names
  kind: python_call_eq
  function: decompress.__name__.__eq__
  args: ["decompress"]
  expected: true

# ---------------------------------------------------------------------------
# LZMAError and LZMAFile __name__ — extra4 namespace anchors
#
# lzma (base) covers both in the class_names table. These standalone invariants
# re-anchor each from the extra4 namespace.
# ---------------------------------------------------------------------------

invariant lzma_extra4.LZMAError.name:
  description: "lzma.LZMAError.__name__ == 'LZMAError' — extra4 namespace anchor"
  category: class_names
  kind: python_call_eq
  function: LZMAError.__name__.__eq__
  args: ["LZMAError"]
  expected: true

invariant lzma_extra4.LZMAFile.name:
  description: "lzma.LZMAFile.__name__ == 'LZMAFile' — extra4 namespace anchor"
  category: class_names
  kind: python_call_eq
  function: LZMAFile.__name__.__eq__
  args: ["LZMAFile"]
  expected: true

# ---------------------------------------------------------------------------
# LZMAError.__bases__[0].__name__ == 'Exception' — bool form (extra4 anchor)
#
# lzma (base) covers this via __bases__.__getitem__ with method: __name__
# (string form). lzma_extra2 covers it as a bool-form string eq.
# This invariant re-anchors the bool-form from the extra4 namespace.
# ---------------------------------------------------------------------------

invariant lzma_extra4.LZMAError.base_name:
  description: "lzma.LZMAError.__bases__[0].__name__ == 'Exception' — LZMAError inherits from Exception (extra4 bool-form anchor)"
  category: class_hierarchy
  kind: python_call_eq
  function: LZMAError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# FORMAT_AUTO and FORMAT_XZ __class__.__name__ — extra4 namespace anchors
#
# lzma_extra3 covers FORMAT_AUTO and FORMAT_XZ in the format_constant_class_names
# table from extra3. These standalone invariants re-anchor each from extra4.
# ---------------------------------------------------------------------------

invariant lzma_extra4.FORMAT_AUTO.class_name:
  description: "lzma.FORMAT_AUTO.__class__.__name__ == 'int' — FORMAT_AUTO is a plain int (extra4 anchor)"
  category: constants
  kind: python_call_eq
  function: FORMAT_AUTO.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant lzma_extra4.FORMAT_XZ.class_name:
  description: "lzma.FORMAT_XZ.__class__.__name__ == 'int' — FORMAT_XZ is a plain int (extra4 anchor)"
  category: constants
  kind: python_call_eq
  function: FORMAT_XZ.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# CHECK_CRC32 __class__.__name__ — extra4 namespace anchor
#
# lzma_extra3 covers CHECK_CRC32 in the check_constant_class_names table from
# extra3. This standalone invariant re-anchors it from the extra4 namespace.
# ---------------------------------------------------------------------------

invariant lzma_extra4.CHECK_CRC32.class_name:
  description: "lzma.CHECK_CRC32.__class__.__name__ == 'int' — CHECK_CRC32 is a plain int (extra4 anchor)"
  category: constants
  kind: python_call_eq
  function: CHECK_CRC32.__class__.__name__.__eq__
  args: ["int"]
  expected: true
