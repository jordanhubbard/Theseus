spec: itertools_extra214
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "itertools_extra213.zspec.zsdl — covers itertools __doc__.__contains__ and __doc__.__len__ checks from the previous wave"
    - "itertools.zspec.zsdl — covers core itertools functional behavior"
  notes:
    - "itertools.chain.__doc__.__contains__('__next__') == True — chain docstring describes the .__next__() method. Verified with Python 3.14.3."
    - "itertools.product.__doc__.__contains__('Cartesian') == True — product docstring opens with 'Cartesian product of input iterables'. Verified with Python 3.14.3."
    - "itertools.combinations.__doc__.__contains__('successive') == True — combinations docstring says 'Return successive r-length combinations'. Verified with Python 3.14.3."
    - "itertools.groupby.__doc__.__contains__('consecutive') == True — groupby docstring says 'returns consecutive keys and groups'. Verified with Python 3.14.3."
    - "itertools.accumulate.__doc__.__contains__('sums') == True — accumulate docstring says 'Return series of accumulated sums'. Verified with Python 3.14.3."
    - "itertools.compress.__doc__.__contains__('selector') == True — compress docstring says 'corresponding to true selector elements'. Verified with Python 3.14.3."
    - "itertools.dropwhile.__doc__.__contains__('predicate') == True — dropwhile docstring mentions 'predicate(item) is true'. Verified with Python 3.14.3."
    - "itertools.takewhile.__doc__.__contains__('predicate') == True — takewhile docstring mentions 'the predicate'. Verified with Python 3.14.3."
    - "itertools.starmap.__doc__.__contains__('iterator') == True — starmap docstring says 'Return an iterator whose values'. Verified with Python 3.14.3."
    - "itertools.zip_longest.__doc__.__contains__('zip_longest') == True — zip_longest docstring mentions its own class name. Verified with Python 3.14.3."
    - "itertools.permutations.__doc__.__contains__('permutations') == True — permutations docstring says 'Return successive r-length permutations'. Verified with Python 3.14.3."
    - "itertools.chain.__doc__.__len__() == 190 — chain docstring has exactly 190 characters. Verified with Python 3.14.3."
    - "itertools.product.__doc__.__len__() == 681 — product docstring has exactly 681 characters. Verified with Python 3.14.3."
    - "itertools.groupby.__doc__.__len__() == 323 — groupby docstring has exactly 323 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools __doc__.__contains__ — chain, product, combinations, groupby
#
# chain.__doc__.__contains__('__next__')        == True
# chain.__doc__.__contains__('elements')        == True
# product.__doc__.__contains__('Cartesian')     == True
# product.__doc__.__contains__('nested')        == True
# combinations.__doc__.__contains__('successive') == True
# combinations.__doc__.__contains__('r-length') == True
# groupby.__doc__.__contains__('consecutive')   == True
# groupby.__doc__.__contains__('iterator')      == True
# ---------------------------------------------------------------------------

table itertools_extra214.doc_contains_group1:
  description: "itertools __doc__.__contains__ checks for chain, product, combinations, groupby in iterdoccontains214g1 namespace — chain doc contains '__next__' and 'elements'; product doc contains 'Cartesian' and 'nested'; combinations doc contains 'successive' and 'r-length'; groupby doc contains 'consecutive' and 'iterator'; all rows verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: iterdoccontains214g1

  columns: [id, function, args, expected, description]
  rows:
    - [chain_doc_contains_next,
       chain.__doc__.__contains__,
       ["__next__"],
       true,
       "itertools.chain.__doc__.__contains__('__next__') == True — chain docstring describes '.__next__() method returns elements'; __contains__('__next__') returns True; verified with Python 3.14.3"]
    - [chain_doc_contains_elements,
       chain.__doc__.__contains__,
       ["elements"],
       true,
       "itertools.chain.__doc__.__contains__('elements') == True — chain docstring says 'returns elements from the first iterable'; __contains__('elements') returns True; verified with Python 3.14.3"]
    - [product_doc_contains_cartesian,
       product.__doc__.__contains__,
       ["Cartesian"],
       true,
       "itertools.product.__doc__.__contains__('Cartesian') == True — product docstring opens with 'Cartesian product of input iterables'; __contains__('Cartesian') returns True; verified with Python 3.14.3"]
    - [product_doc_contains_nested,
       product.__doc__.__contains__,
       ["nested"],
       true,
       "itertools.product.__doc__.__contains__('nested') == True — product docstring says 'Equivalent to nested for-loops'; __contains__('nested') returns True; verified with Python 3.14.3"]
    - [combinations_doc_contains_successive,
       combinations.__doc__.__contains__,
       ["successive"],
       true,
       "itertools.combinations.__doc__.__contains__('successive') == True — combinations docstring says 'Return successive r-length combinations'; __contains__('successive') returns True; verified with Python 3.14.3"]
    - [combinations_doc_contains_rlength,
       combinations.__doc__.__contains__,
       ["r-length"],
       true,
       "itertools.combinations.__doc__.__contains__('r-length') == True — combinations docstring says 'successive r-length combinations of elements'; __contains__('r-length') returns True; verified with Python 3.14.3"]
    - [groupby_doc_contains_consecutive,
       groupby.__doc__.__contains__,
       ["consecutive"],
       true,
       "itertools.groupby.__doc__.__contains__('consecutive') == True — groupby docstring says 'returns consecutive keys and groups'; __contains__('consecutive') returns True; verified with Python 3.14.3"]
    - [groupby_doc_contains_iterator,
       groupby.__doc__.__contains__,
       ["iterator"],
       true,
       "itertools.groupby.__doc__.__contains__('iterator') == True — groupby docstring says 'make an iterator that returns'; __contains__('iterator') returns True; verified with Python 3.14.3"]

