table itertools_extra214.doc_contains_group2:
  description: "itertools __doc__.__contains__ checks for accumulate, compress, dropwhile, takewhile, starmap, zip_longest, permutations in iterdoccontains214g2 namespace — accumulate doc contains 'sums'; compress doc contains 'selector'; dropwhile and takewhile docs contain 'predicate'; starmap doc contains 'iterator'; zip_longest doc contains 'zip_longest'; permutations doc contains 'permutations'; all rows verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: iterdoccontains214g2

  columns: [id, function, args, expected, description]
  rows:
    - [accumulate_doc_contains_sums,
       accumulate.__doc__.__contains__,
       ["sums"],
       true,
       "itertools.accumulate.__doc__.__contains__('sums') == True — accumulate docstring says 'Return series of accumulated sums'; __contains__('sums') returns True; verified with Python 3.14.3"]
    - [compress_doc_contains_selector,
       compress.__doc__.__contains__,
       ["selector"],
       true,
       "itertools.compress.__doc__.__contains__('selector') == True — compress docstring says 'corresponding to true selector elements'; __contains__('selector') returns True; verified with Python 3.14.3"]
    - [dropwhile_doc_contains_predicate,
       dropwhile.__doc__.__contains__,
       ["predicate"],
       true,
       "itertools.dropwhile.__doc__.__contains__('predicate') == True — dropwhile docstring says 'while predicate(item) is true'; __contains__('predicate') returns True; verified with Python 3.14.3"]
    - [takewhile_doc_contains_predicate,
       takewhile.__doc__.__contains__,
       ["predicate"],
       true,
       "itertools.takewhile.__doc__.__contains__('predicate') == True — takewhile docstring says 'as long as the predicate is true'; __contains__('predicate') returns True; verified with Python 3.14.3"]
    - [starmap_doc_contains_iterator,
       starmap.__doc__.__contains__,
       ["iterator"],
       true,
       "itertools.starmap.__doc__.__contains__('iterator') == True — starmap docstring says 'Return an iterator whose values'; __contains__('iterator') returns True; verified with Python 3.14.3"]
    - [zip_longest_doc_contains_name,
       zip_longest.__doc__.__contains__,
       ["zip_longest"],
       true,
       "itertools.zip_longest.__doc__.__contains__('zip_longest') == True — zip_longest docstring mentions its own class name; __contains__('zip_longest') returns True; verified with Python 3.14.3"]
    - [permutations_doc_contains_name,
       permutations.__doc__.__contains__,
       ["permutations"],
       true,
       "itertools.permutations.__doc__.__contains__('permutations') == True — permutations docstring says 'Return successive r-length permutations'; __contains__('permutations') returns True; verified with Python 3.14.3"]

