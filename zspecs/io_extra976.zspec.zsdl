spec: io_extra976
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module IOBase documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks io.IOBase method __qualname__ identity for core I/O interface methods"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra976.iobase_read_qualnames:
  description: "io.IOBase read-family method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: io976x
  columns: [id, function, args, expected]
  rows:
    - [io976x001, io.IOBase.read.__qualname__.__eq__,      ["IOBase.read"],      true]
    - [io976x002, io.IOBase.readline.__qualname__.__eq__,  ["IOBase.readline"],  true]
    - [io976x003, io.IOBase.readlines.__qualname__.__eq__, ["IOBase.readlines"], true]

table io_extra976.iobase_write_qualnames:
  description: "io.IOBase write-family method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: io976w
  columns: [id, function, args, expected]
  rows:
    - [io976w001, io.IOBase.writelines.__qualname__.__eq__, ["IOBase.writelines"], true]
    - [io976w002, io.IOBase.flush.__qualname__.__eq__,      ["IOBase.flush"],      true]
    - [io976w003, io.IOBase.close.__qualname__.__eq__,      ["IOBase.close"],      true]

table io_extra976.iobase_seek_qualnames:
  description: "io.IOBase seek and tell method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: io976s
  columns: [id, function, args, expected]
  rows:
    - [io976s001, io.IOBase.seek.__qualname__.__eq__, ["IOBase.seek"], true]
    - [io976s002, io.IOBase.tell.__qualname__.__eq__, ["IOBase.tell"], true]

table io_extra976.iobase_context_qualnames:
  description: "io.IOBase context manager method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: io976c
  columns: [id, function, args, expected]
  rows:
    - [io976c001, io.IOBase.__enter__.__qualname__.__eq__, ["IOBase.__enter__"], true]
    - [io976c002, io.IOBase.__exit__.__qualname__.__eq__,  ["IOBase.__exit__"],  true]

table io_extra976.iobase_module_identity:
  description: "io.IOBase class-level module and name identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: io976m
  columns: [id, function, args, expected]
  rows:
    - [io976m001, io.IOBase.__module__.__eq__,            ["io"],     true]
    - [io976m002, io.IOBase.__name__.__eq__,              ["IOBase"], true]
    - [io976m003, io.IOBase.__class__.__name__.__eq__,    ["type"],   true]
    - [io976m004, io.RawIOBase.__module__.__eq__,         ["io"],     true]
    - [io976m005, io.BufferedIOBase.__module__.__eq__,    ["io"],     true]
    - [io976m006, io.TextIOBase.__module__.__eq__,        ["io"],     true]
