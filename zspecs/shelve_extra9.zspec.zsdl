spec: shelve_extra9
version: ">=3.0"
backend: python_module(shelve)

docs: https://docs.python.org/3/library/shelve.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shelve.html — Python shelve module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/shelve.py"
  notes:
    - "This spec extends shelve.zspec.zsdl through shelve_extra8.zspec.zsdl."
    - "shelve_extra8 covers: DbfilenameShelf.__mro__[0..2] table; Shelf.__mro__[3].__name__; Shelf dunder item-access method names; Shelf.pop.__name__."
    - "shelve_extra7 covers: Shelf.__mro__[0..2] table; BsdDbShelf.__mro__[0..1] table; Shelf.update/__name__; Shelf.setdefault/__name__."
    - "shelve_extra6 covers: Shelf.__mro__.__len__ >= 4; BsdDbShelf.__bases__.__len__ == 1; open.__doc__.__class__.__name__; Shelf.get.__name__."
    - "shelve_extra5 covers: Shelf method names (keys, values, items, sync, close); Shelf.__dict__.__class__.__name__."
    - "shelve_extra4 covers: __qualname__ for open, Shelf, BsdDbShelf, DbfilenameShelf."
    - "shelve_extra3 covers: BsdDbShelf/__module__; DbfilenameShelf/__module__; Shelf/__bases__/__len__; class metatype table; BsdDbShelf/__bases__[0]/__name__."
    - "Focus: new axes — shelve.__name__; shelve.__package__; shelve.__spec__.name; Shelf/__module__.__class__.__name__; DbfilenameShelf/__module__.__class__.__name__; open/__qualname__.__class__.__name__."
    - "shelve.__name__ == 'shelve' — module identity; no prior shelve spec checks the module __name__ attribute directly."
    - "shelve.__package__ == '' — shelve is a top-level module with no parent package; no prior spec checks __package__."
    - "shelve.__spec__.name == 'shelve' — importlib ModuleSpec name; no prior shelve spec checks __spec__.name."
    - "shelve.Shelf.__module__.__class__.__name__ == 'str' — the __module__ attribute is always a string; no prior spec checks this type axis."
    - "shelve.DbfilenameShelf.__module__.__class__.__name__ == 'str' — same type guarantee for DbfilenameShelf.__module__."
    - "shelve.open.__qualname__.__class__.__name__ == 'str' — qualname type check for open; no prior spec checks this."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# shelve module identity — __name__ and __package__
#
# shelve.zspec and prior extras check class/function names and module attrs,
# but no prior shelve spec checks __name__ or __package__ at the module level.
# ---------------------------------------------------------------------------

invariant shelve_extra9.module.name:
  description: "shelve.__name__ == 'shelve' — module identity name"
  category: module_attrs
  kind: python_call_eq
  function: __name__.__eq__
  args: ["shelve"]
  expected: true

invariant shelve_extra9.module.package:
  description: "shelve.__package__ == '' — top-level module has no parent package"
  category: module_attrs
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# shelve.__spec__.name
#
# No prior shelve spec checks any __spec__ field. The ModuleSpec name must
# equal the module's own __name__.
# ---------------------------------------------------------------------------

invariant shelve_extra9.spec.name:
  description: "shelve.__spec__.name == 'shelve' — importlib ModuleSpec name"
  category: module_attrs
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["shelve"]
  expected: true

# ---------------------------------------------------------------------------
# Shelf and DbfilenameShelf — __module__.__class__.__name__
#
# shelve.zspec and shelve_extra3 check __module__ string values. No prior spec
# checks the type of the __module__ attribute (__class__.__name__ == 'str').
# ---------------------------------------------------------------------------

table shelve_extra9.class_module_types:
  description: "shelve classes — __module__.__class__.__name__ == 'str'"
  kind: python_call_eq
  category: class_attrs
  id_prefix: scmt9

  columns: [id, function, args, expected]
  rows:
    - [Shelf_module_type,           Shelf.__module__.__class__.__name__.__eq__,           ["str"], true]
    - [DbfilenameShelf_module_type, DbfilenameShelf.__module__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# open — __qualname__.__class__.__name__
#
# shelve_extra4 checks open.__qualname__ == 'open'. No prior spec checks the
# type of open's qualname attribute.
# ---------------------------------------------------------------------------

invariant shelve_extra9.open.qualname_type:
  description: "shelve.open.__qualname__.__class__.__name__ == 'str' — qualname is a string"
  category: function_attrs
  kind: python_call_eq
  function: open.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
