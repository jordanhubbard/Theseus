spec: inspect_extra130
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.unwrap and inspect.formatannotation code attributes; inspect.cleandoc code attributes (Wave 260)."
    - "inspect.unwrap.__code__.co_varnames[0] == 'func' — first positional param of unwrap. Verified with Python 3.14.3."
    - "inspect.unwrap.__code__.co_argcount == 1 — one positional argument (func); stop is keyword-only. Verified with Python 3.14.3."
    - "len(inspect.unwrap.__code__.co_varnames) == 6 — variables: func, stop, f, memo, recursion_limit, id_func. Verified with Python 3.14.3."
    - "inspect.formatannotation.__code__.co_varnames[0] == 'annotation' — first positional param. Verified with Python 3.14.3."
    - "inspect.formatannotation.__code__.co_argcount == 2 — two positional args: annotation, base_module. Verified with Python 3.14.3."
    - "len(inspect.formatannotation.__code__.co_varnames) == 4 — variables: annotation, base_module, quote_annotation_strings, repl. Verified with Python 3.14.3."
    - "inspect.cleandoc.__code__.co_varnames[0] == 'doc' — first positional param. Verified with Python 3.14.3."
    - "inspect.cleandoc.__code__.co_argcount == 1 — one positional argument (doc). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.unwrap code object attributes
#
# Wave 260 theme: inspect.unwrap co_varnames, co_argcount, co_varnames length.
#
# inspect.unwrap.__code__.co_varnames[0] == 'func'
# inspect.unwrap.__code__.co_argcount == 1
# len(inspect.unwrap.__code__.co_varnames) == 6
#
# unwrap(func, *, stop=None) has co_argcount==1 (func is the only positional
# parameter; stop is keyword-only). co_varnames contains all local names:
# func, stop, f, memo, recursion_limit, id_func. New to extra130.
# ---------------------------------------------------------------------------

table inspect_extra130.unwrap_code_attrs:
  description: "inspect.unwrap code object: co_varnames[0]=='func', co_argcount==1, len(co_varnames)==6; wave 260; new to extra130"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectcode130

  columns: [id, function, args, expected, description]
  rows:
    - [unwrap_co_varnames_0_eq_func,
       "unwrap.__code__.co_varnames[0].__eq__",
       ["func"],
       true,
       "inspect.unwrap.__code__.co_varnames[0].__eq__('func') == True — inspect.unwrap is defined as 'def unwrap(func, *, stop=None):' in Lib/inspect.py; the first entry in co_varnames is the first positional parameter name 'func'; str.__eq__('func') returns True; new to extra130"]
    - [unwrap_co_argcount_eq_1,
       "unwrap.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.unwrap.__code__.co_argcount.__eq__(1) == True — co_argcount counts only positional (and positional-or-keyword) parameters; unwrap has one such parameter (func); the keyword-only parameter stop is not counted in co_argcount; int.__eq__(1) returns True; new to extra130"]
    - [unwrap_co_varnames_len_6,
       "unwrap.__code__.co_varnames.__len__",
       [],
       6,
       "inspect.unwrap.__code__.co_varnames.__len__() == 6 — co_varnames lists all local variable names: func, stop, f, memo, recursion_limit, id_func; tuple.__len__() returns 6; new to extra130"]
    - [unwrap_co_varnames_class_eq_tuple,
       "unwrap.__code__.co_varnames.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "inspect.unwrap.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — co_varnames is a tuple of local variable name strings as stored in the code object; __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra130"]

# ---------------------------------------------------------------------------
# Table 2: inspect.formatannotation code object attributes
#
# Wave 260 theme: inspect.formatannotation co_varnames, co_argcount, co_varnames length.
#
# inspect.formatannotation.__code__.co_varnames[0] == 'annotation'
# inspect.formatannotation.__code__.co_argcount == 2
# len(inspect.formatannotation.__code__.co_varnames) == 4
#
# formatannotation(annotation, base_module=None, *, quote_annotation_strings=True)
# has co_argcount==2 (annotation and base_module are positional-or-keyword);
# co_varnames: annotation, base_module, quote_annotation_strings, repl. New to extra130.
# ---------------------------------------------------------------------------

table inspect_extra130.formatannotation_code_attrs:
  description: "inspect.formatannotation code object: co_varnames[0]=='annotation', co_argcount==2, len(co_varnames)==4; wave 260; new to extra130"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectcode130

  columns: [id, function, args, expected, description]
  rows:
    - [formatannotation_co_varnames_0_eq_annotation,
       "formatannotation.__code__.co_varnames[0].__eq__",
       ["annotation"],
       true,
       "inspect.formatannotation.__code__.co_varnames[0].__eq__('annotation') == True — formatannotation is defined as 'def formatannotation(annotation, base_module=None, *, quote_annotation_strings=True):' in Lib/inspect.py; the first positional parameter is 'annotation'; co_varnames[0] is 'annotation'; str.__eq__('annotation') returns True; new to extra130"]
    - [formatannotation_co_argcount_eq_2,
       "formatannotation.__code__.co_argcount.__eq__",
       [2],
       true,
       "inspect.formatannotation.__code__.co_argcount.__eq__(2) == True — co_argcount counts positional-or-keyword parameters; formatannotation has two such parameters: annotation and base_module; quote_annotation_strings is keyword-only and is not counted; int.__eq__(2) returns True; new to extra130"]
    - [formatannotation_co_varnames_len_4,
       "formatannotation.__code__.co_varnames.__len__",
       [],
       4,
       "inspect.formatannotation.__code__.co_varnames.__len__() == 4 — co_varnames contains all local names: annotation, base_module, quote_annotation_strings, repl; tuple.__len__() returns 4; new to extra130"]
    - [formatannotation_co_varnames_class_eq_tuple,
       "formatannotation.__code__.co_varnames.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "inspect.formatannotation.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — co_varnames is always a tuple of strings in CPython code objects; __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra130"]
    - [formatannotation_co_varnames_1_eq_base_module,
       "formatannotation.__code__.co_varnames[1].__eq__",
       ["base_module"],
       true,
       "inspect.formatannotation.__code__.co_varnames[1].__eq__('base_module') == True — the second positional-or-keyword parameter of formatannotation is 'base_module'; co_varnames[1] is 'base_module'; str.__eq__('base_module') returns True; new to extra130"]

# ---------------------------------------------------------------------------
# Table 3: inspect.cleandoc code object attributes
#
# Wave 260 theme: inspect.cleandoc co_varnames[0] and co_argcount.
#
# inspect.cleandoc.__code__.co_varnames[0] == 'doc'
# inspect.cleandoc.__code__.co_argcount == 1
#
# cleandoc(doc) has a single positional parameter 'doc'.
# co_varnames: doc, lines, margin, line, content, indent, i. New to extra130.
# ---------------------------------------------------------------------------

table inspect_extra130.cleandoc_code_attrs:
  description: "inspect.cleandoc code object: co_varnames[0]=='doc', co_argcount==1; single-arg docstring cleaner; wave 260; new to extra130"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectcode130

  columns: [id, function, args, expected, description]
  rows:
    - [cleandoc_co_varnames_0_eq_doc,
       "cleandoc.__code__.co_varnames[0].__eq__",
       ["doc"],
       true,
       "inspect.cleandoc.__code__.co_varnames[0].__eq__('doc') == True — cleandoc is defined as 'def cleandoc(doc):' in Lib/inspect.py; the single positional parameter is 'doc'; co_varnames[0] is 'doc'; str.__eq__('doc') returns True; new to extra130"]
    - [cleandoc_co_argcount_eq_1,
       "cleandoc.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.cleandoc.__code__.co_argcount.__eq__(1) == True — cleandoc takes a single positional argument 'doc'; co_argcount is 1; int.__eq__(1) returns True; new to extra130"]
    - [cleandoc_co_varnames_class_eq_tuple,
       "cleandoc.__code__.co_varnames.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "inspect.cleandoc.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — co_varnames is a tuple of local variable name strings; for cleandoc it includes: doc, lines, margin, line, content, indent, i; __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra130"]
    - [cleandoc_code_class_eq_code,
       "cleandoc.__code__.__class__.__name__.__eq__",
       ["code"],
       true,
       "inspect.cleandoc.__code__.__class__.__name__.__eq__('code') == True — every Python function has a __code__ attribute that is a code object; the code type's __name__ is 'code'; str.__eq__('code') returns True; new to extra130"]
    - [cleandoc_qualname_eq,
       "cleandoc.__qualname__.__eq__",
       ["cleandoc"],
       true,
       "inspect.cleandoc.__qualname__.__eq__('cleandoc') == True — cleandoc is defined at module scope in Lib/inspect.py; its __qualname__ is the simple function name 'cleandoc'; str.__eq__('cleandoc') returns True; new to extra130"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra130
# ---------------------------------------------------------------------------

invariant inspect_extra130.unwrap_co_varnames_0:
  description: "inspect.unwrap.__code__.co_varnames[0] == 'func' — first positional parameter of unwrap; wave 260; new to extra130"
  kind: python_call_eq
  function: unwrap.__code__.co_varnames[0].__eq__
  args: ["func"]
  expected: true

invariant inspect_extra130.unwrap_co_argcount:
  description: "inspect.unwrap.__code__.co_argcount == 1 — one positional parameter; stop is keyword-only; wave 260; new to extra130"
  kind: python_call_eq
  function: unwrap.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra130.formatannotation_co_varnames_0:
  description: "inspect.formatannotation.__code__.co_varnames[0] == 'annotation' — first positional parameter; wave 260; new to extra130"
  kind: python_call_eq
  function: formatannotation.__code__.co_varnames[0].__eq__
  args: ["annotation"]
  expected: true

invariant inspect_extra130.formatannotation_co_argcount:
  description: "inspect.formatannotation.__code__.co_argcount == 2 — positional params: annotation, base_module; wave 260; new to extra130"
  kind: python_call_eq
  function: formatannotation.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant inspect_extra130.cleandoc_co_varnames_0:
  description: "inspect.cleandoc.__code__.co_varnames[0] == 'doc' — single positional parameter of cleandoc; wave 260; new to extra130"
  kind: python_call_eq
  function: cleandoc.__code__.co_varnames[0].__eq__
  args: ["doc"]
  expected: true

