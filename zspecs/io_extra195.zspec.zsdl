spec: io_extra195
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "io.IOBase.readline.__name__ == 'readline' (len=8); class='method_descriptor'."
    - "io.IOBase.readlines.__name__ == 'readlines' (len=9); class='method_descriptor'."
    - "io.IOBase.writelines.__name__ == 'writelines' (len=10); class='method_descriptor'."
    - "io.IOBase.flush.__name__ == 'flush' (len=5); class='method_descriptor'."
    - "io.IOBase.close.__name__ == 'close' (len=5); class='method_descriptor'."
    - "io.IOBase.seek.__name__ == 'seek' (len=4); class='method_descriptor'; confirmed present on IOBase."
    - "io.IOBase.tell.__name__ == 'tell' (len=4); class='method_descriptor'; confirmed present on IOBase."
    - "io.IOBase.truncate.__name__ == 'truncate' (len=8); class='method_descriptor'; confirmed present on IOBase."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io.IOBase line-I/O method __name__ equality
# readline(8), readlines(9), writelines(10)
# ---------------------------------------------------------------------------

table io_extra195.iobase_line_io_names:
  description: "io.IOBase line-I/O method __name__ values: readline='readline'(8), readlines='readlines'(9), writelines='writelines'(10)"
  kind: python_call_eq
  category: identity
  id_prefix: ioiobasemethods195

  columns: [id, function, args, expected, description]
  rows:
    - [readline_name_eq,    io.IOBase.readline.__name__.__eq__,    ["readline"],    true,  "io.IOBase.readline.__name__ == 'readline'; confirmed Python 3.14.3 macOS"]
    - [readline_name_len,   io.IOBase.readline.__name__.__len__,   [],              8,     "io.IOBase.readline.__name__.__len__() == 8 — r(1)e(2)a(3)d(4)l(5)i(6)n(7)e(8); confirmed Python 3.14.3 macOS"]
    - [readlines_name_eq,   io.IOBase.readlines.__name__.__eq__,   ["readlines"],   true,  "io.IOBase.readlines.__name__ == 'readlines'; confirmed Python 3.14.3 macOS"]
    - [readlines_name_len,  io.IOBase.readlines.__name__.__len__,  [],              9,     "io.IOBase.readlines.__name__.__len__() == 9 — r(1)e(2)a(3)d(4)l(5)i(6)n(7)e(8)s(9); confirmed Python 3.14.3 macOS"]
    - [writelines_name_eq,  io.IOBase.writelines.__name__.__eq__,  ["writelines"],  true,  "io.IOBase.writelines.__name__ == 'writelines'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
