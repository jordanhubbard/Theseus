    - [flush_name_len,  io.IOBase.flush.__name__.__len__,  [],         5,     "io.IOBase.flush.__name__.__len__() == 5 — f(1)l(2)u(3)s(4)h(5); confirmed Python 3.14.3 macOS"]
    - [close_name_eq,   io.IOBase.close.__name__.__eq__,   ["close"],  true,  "io.IOBase.close.__name__ == 'close'; confirmed Python 3.14.3 macOS"]
