  rows:
    - [seek_name_eq,      io.IOBase.seek.__name__.__eq__,      ["seek"],     true,  "io.IOBase.seek.__name__ == 'seek'; confirmed present on IOBase, Python 3.14.3 macOS"]
    - [seek_name_len,     io.IOBase.seek.__name__.__len__,     [],           4,     "io.IOBase.seek.__name__.__len__() == 4 — s(1)e(2)e(3)k(4); confirmed Python 3.14.3 macOS"]
