spec: sysconfig_extra7
version: ">=3.9"
backend: python_module(sysconfig)

docs: https://docs.python.org/3/library/sysconfig.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sysconfig.html — Python sysconfig documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sysconfig.py"
  notes:
    - "This spec extends sysconfig.zspec.zsdl through sysconfig_extra6.zspec.zsdl."
    - "sysconfig (base) covers: function names table (10 functions); return types for get_python_version/get_scheme_names/get_path_names/get_platform; get_scheme_names len==7; get_path_names contains stdlib/platlib."
    - "sysconfig_extra covers: function names (9 functions); return types via method."
    - "sysconfig_extra2 covers: get_config_vars/get_paths return dict and non-empty; get_scheme_names contains 'posix_prefix'; get_path_names contains scripts/data; get_python_version contains dot/len>=3."
    - "sysconfig_extra3 covers: __qualname__ for 8 functions; __module__ for get_python_version/get_platform; get_default_scheme __name__/__qualname__/returns_str/non-empty."
    - "sysconfig_extra4 covers: module __name__; is_python_build returns_bool; get_platform nonempty; get_path_names len==8; get_scheme_names posix_home; __module__ for get_config_var/parse_config_h/get_path/get_paths; __qualname__ for get_config_var/parse_config_h."
    - "sysconfig_extra5 covers: __doc__ type for 4 functions; get_path_names contains include/purelib; get_scheme_names contains posix_local; get_python_version len>=3; get_config_var.__name__ class is str."
    - "sysconfig_extra6 covers: get_path_names()/get_scheme_names() return tuple; get_scheme_names contains venv/posix_user; get_path_names contains platstdlib; get_config_vars() len>=100; parse_config_h __doc__ is str; get_paths() contains stdlib/include keys; get_config_var.__name__ nonempty."
    - "This spec adds new axes: __name__ for get_python_version/get_platform/get_paths/get_config_vars in a consolidated table; get_python_version().__class__.__name__ == 'str'; get_platform().__class__.__name__ == 'str'; get_paths().__class__.__name__ == 'dict' as standalone invariants in the extra7 namespace."
    - "sysconfig.get_python_version.__name__ == 'get_python_version' — verified at runtime."
    - "sysconfig.get_platform.__name__ == 'get_platform' — verified at runtime."
    - "sysconfig.get_paths.__name__ == 'get_paths' — verified at runtime."
    - "sysconfig.get_config_vars.__name__ == 'get_config_vars' — verified at runtime."
    - "sysconfig.get_python_version().__class__.__name__ == 'str' — verified at runtime (returns '3.14' on test system)."
    - "sysconfig.get_platform().__class__.__name__ == 'str' — verified at runtime (returns 'macosx-26.0-arm64' on test system)."
    - "sysconfig.get_paths().__class__.__name__ == 'dict' — verified at runtime."
    - "The __name__ table groups four sysconfig functions covered individually in earlier extras; this is a new consolidated table in the extra7 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ attributes — consolidated table
#
# get_python_version/__name__, get_platform/__name__, get_paths/__name__, and
# get_config_vars/__name__ appear in sysconfig base and sysconfig_extra in
# various table positions. This table groups all four into a single block in
# the extra7 namespace.
# ---------------------------------------------------------------------------

table sysconfig_extra7.function_names:
  description: "__name__ for get_python_version, get_platform, get_paths, get_config_vars"
  kind: python_call_eq
  category: function_attrs
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [get_python_version, get_python_version.__name__.__eq__, ["get_python_version"], true]
    - [get_platform,       get_platform.__name__.__eq__,       ["get_platform"],       true]
    - [get_paths,          get_paths.__name__.__eq__,          ["get_paths"],          true]
    - [get_config_vars,    get_config_vars.__name__.__eq__,    ["get_config_vars"],    true]

# ---------------------------------------------------------------------------
# Return type: get_python_version() returns a str
#
# sysconfig base confirms get_python_version() return type via method_chain.
# This standalone invariant anchors __class__.__name__ == 'str' in the extra7
# namespace as a distinct coverage axis.
# ---------------------------------------------------------------------------

invariant sysconfig_extra7.get_python_version.returns_str:
  description: "sysconfig.get_python_version().__class__.__name__ == 'str'"
  category: runtime
  kind: python_call_eq
  function: get_python_version().__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Return type: get_platform() returns a str
#
# sysconfig base confirms get_platform() return type via method_chain.
# This standalone invariant anchors __class__.__name__ == 'str' in the extra7
# namespace as a distinct coverage axis.
# ---------------------------------------------------------------------------

invariant sysconfig_extra7.get_platform.returns_str:
  description: "sysconfig.get_platform().__class__.__name__ == 'str'"
  category: runtime
  kind: python_call_eq
  function: get_platform().__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Return type: get_paths() returns a dict
#
# sysconfig_extra2 confirms get_paths() is a non-empty dict but does not check
# __class__.__name__ directly. This standalone invariant anchors the dict type
# in the extra7 namespace.
# ---------------------------------------------------------------------------

invariant sysconfig_extra7.get_paths.returns_dict:
  description: "sysconfig.get_paths().__class__.__name__ == 'dict'"
  category: runtime
  kind: python_call_eq
  function: get_paths().__class__.__name__.__eq__
  args: ["dict"]
  expected: true
