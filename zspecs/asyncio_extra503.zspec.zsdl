spec: asyncio_extra503
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio-sync.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Semaphore, Event, Condition, BoundedSemaphore all inherit directly from object"
    - "Barrier was added in Python 3.11; rows marked version>=3.11"
    - "All synchronization classes live in asyncio.locks module"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra503.semaphore_identity:
  description: "asyncio.Semaphore class identity invariants"
  kind: python_call_eq
  category: class_identity
  id_prefix: SEM

  columns: [id, function, args, expected]
  rows:
    - [SEM001, asyncio.Semaphore.__name__.__eq__, ["Semaphore"], true]
    - [SEM002, asyncio.Semaphore.__module__.__eq__, ["asyncio.locks"], true]

table asyncio_extra503.semaphore_bases:
  description: "asyncio.Semaphore base class invariants"
  kind: python_call_eq
  category: class_identity
  id_prefix: SEMB

  columns: [id, function, args, expected]
  rows:
    - [SEMB001, "asyncio.Semaphore.__bases__[0].__name__.__eq__", ["object"], true]

