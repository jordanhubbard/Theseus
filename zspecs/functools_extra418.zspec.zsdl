spec: functools_extra418
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools documentation"
    - "Test vectors verified with Python 3.14.0 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "functools.WRAPPER_ASSIGNMENTS is a tuple of attribute names copied from the wrapped function by functools.wraps. In Python 3.14 it contains '__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'. Note: '__annotations__' was replaced by '__annotate__' and '__type_params__' was added in 3.14. Verified with Python 3.14.0."
    - "functools.WRAPPER_UPDATES is a tuple of attribute names merged (via update) from the wrapped function by functools.wraps. In Python 3.14 it contains only '__dict__'. Verified with Python 3.14.0."
    - "WRAPPER_ASSIGNMENTS.__contains__('__module__') == True — '__module__' is in WRAPPER_ASSIGNMENTS. Verified with Python 3.14.0."
    - "WRAPPER_ASSIGNMENTS.__contains__('__name__') == True — '__name__' is in WRAPPER_ASSIGNMENTS. Verified with Python 3.14.0."
    - "WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True — '__qualname__' is in WRAPPER_ASSIGNMENTS. Verified with Python 3.14.0."
    - "WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True — '__doc__' is in WRAPPER_ASSIGNMENTS. Verified with Python 3.14.0."
    - "WRAPPER_UPDATES.__contains__('__dict__') == True — '__dict__' is in WRAPPER_UPDATES. Verified with Python 3.14.0."
    - "All expected values verified by running Python 3.14.0 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.WRAPPER_ASSIGNMENTS element membership
#
# functools.WRAPPER_ASSIGNMENTS is a tuple of attribute name strings.
# Calling __contains__ on the tuple returns True for each expected member.
# All values verified with Python 3.14.0 on macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table functools_extra418.wrapper_assignments_contains:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__ membership checks — elements present in the WRAPPER_ASSIGNMENTS tuple; new to extra418"
  kind: python_call_eq
  category: membership
  id_prefix: functoolswa418

  columns: [id, function, args, expected, description]
  rows:
    - [wa_contains_module_eq,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__module__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True — '__module__' is an element of WRAPPER_ASSIGNMENTS in Python 3.14; new to extra418"]
    - [wa_contains_name_eq,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__name__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True — '__name__' is an element of WRAPPER_ASSIGNMENTS in Python 3.14; new to extra418"]
    - [wa_contains_qualname_eq,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__qualname__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True — '__qualname__' is an element of WRAPPER_ASSIGNMENTS in Python 3.14; new to extra418"]
    - [wa_contains_doc_eq,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__doc__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True — '__doc__' is an element of WRAPPER_ASSIGNMENTS in Python 3.14; new to extra418"]
    - [wu_contains_dict_eq,
       "WRAPPER_UPDATES.__contains__",
       ["__dict__"],
       true,
       "functools.WRAPPER_UPDATES.__contains__('__dict__') == True — '__dict__' is the sole element of WRAPPER_UPDATES in Python 3.14; new to extra418"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra418
# ---------------------------------------------------------------------------

invariant functools_extra418.wa_contains_module:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True — '__module__' is in WRAPPER_ASSIGNMENTS; new to extra418"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__module__"]
  expected: true

invariant functools_extra418.wa_contains_name:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True — '__name__' is in WRAPPER_ASSIGNMENTS; new to extra418"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__name__"]
  expected: true

invariant functools_extra418.wa_contains_qualname:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True — '__qualname__' is in WRAPPER_ASSIGNMENTS; new to extra418"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__qualname__"]
  expected: true

invariant functools_extra418.wa_contains_doc:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True — '__doc__' is in WRAPPER_ASSIGNMENTS; new to extra418"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__doc__"]
  expected: true

invariant functools_extra418.wu_contains_dict:
  description: "functools.WRAPPER_UPDATES.__contains__('__dict__') == True — '__dict__' is in WRAPPER_UPDATES; new to extra418"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__contains__
  args: ["__dict__"]
  expected: true
