spec: multiprocessing_extra5
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
    - "CPython source: Lib/multiprocessing/synchronize.py"
  notes:
    - "This spec extends multiprocessing.zspec.zsdl, multiprocessing_extra.zspec.zsdl, multiprocessing_extra2.zspec.zsdl, multiprocessing_extra3.zspec.zsdl, multiprocessing_extra4.zspec.zsdl."
    - "Prior specs cover: __name__ for Process/Pool/Value/Array/cpu_count/current_process/active_children; __module__ for Process; class hierarchy for Process; cpu_count >= 1; current_process class name == 'MainProcess'; active_children returns list."
    - "This spec adds __qualname__ vectors for major multiprocessing classes and exception classes — not previously covered."
    - "multiprocessing.Process.__qualname__ == 'Process' — top-level class in multiprocessing.process."
    - "multiprocessing.Queue.__qualname__ == 'Queue' — multiprocessing queue, top-level."
    - "multiprocessing.Pipe.__qualname__ == 'Pipe' — factory function at module scope."
    - "multiprocessing.Pool.__qualname__ == 'Pool' — process pool class, top-level."
    - "multiprocessing.Manager.__qualname__ == 'Manager' — SyncManager subclass, top-level."
    - "multiprocessing.Lock.__qualname__ == 'Lock' — synchronization primitive, top-level."
    - "multiprocessing.Value.__qualname__ == 'Value' — shared value, top-level."
    - "multiprocessing.Array.__qualname__ == 'Array' — shared array, top-level."
    - "multiprocessing.AuthenticationError.__qualname__ == 'AuthenticationError' — exception class."
    - "multiprocessing.ProcessError.__qualname__ == 'ProcessError' — exception class."
    - "multiprocessing.TimeoutError.__qualname__ == 'TimeoutError' — exception class."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ table for core multiprocessing classes
#
# For top-level (non-nested) classes, __qualname__ equals __name__.
# Prior specs checked __name__; this spec introduces __qualname__ vectors.
# ---------------------------------------------------------------------------

table multiprocessing_extra5.class_qualnames:
  description: "Core multiprocessing classes have correct __qualname__ (equals __name__ for top-level classes)"
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Process, Process.__qualname__.__eq__, ["Process"], true]
    - [Pool,    Pool.__qualname__.__eq__,    ["Pool"],    true]
    - [Manager, Manager.__qualname__.__eq__, ["Manager"], true]
    - [Pipe,    Pipe.__qualname__.__eq__,    ["Pipe"],    true]
    - [Lock,    Lock.__qualname__.__eq__,    ["Lock"],    true]

# ---------------------------------------------------------------------------
# __qualname__ for additional multiprocessing classes
#
# Queue, Value, and Array are not in the table above for clarity; they get
# standalone invariants for independent traceability.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra5.Queue.qualname:
  description: "multiprocessing.Queue.__qualname__ == 'Queue'"
  category: qualnames
  kind: python_call_eq
  function: Queue.__qualname__.__eq__
  args: ["Queue"]
  expected: true

invariant multiprocessing_extra5.Value.qualname:
  description: "multiprocessing.Value.__qualname__ == 'Value'"
  category: qualnames
  kind: python_call_eq
  function: Value.__qualname__.__eq__
  args: ["Value"]
  expected: true

invariant multiprocessing_extra5.Array.qualname:
  description: "multiprocessing.Array.__qualname__ == 'Array'"
  category: qualnames
  kind: python_call_eq
  function: Array.__qualname__.__eq__
  args: ["Array"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ for multiprocessing exception classes
#
# ProcessError, AuthenticationError, and TimeoutError are exception classes
# defined in multiprocessing. Not previously covered in any prior spec.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra5.ProcessError.qualname:
  description: "multiprocessing.ProcessError.__qualname__ == 'ProcessError'"
  category: exception_qualnames
  kind: python_call_eq
  function: ProcessError.__qualname__.__eq__
  args: ["ProcessError"]
  expected: true

invariant multiprocessing_extra5.AuthenticationError.qualname:
  description: "multiprocessing.AuthenticationError.__qualname__ == 'AuthenticationError'"
  category: exception_qualnames
  kind: python_call_eq
  function: AuthenticationError.__qualname__.__eq__
  args: ["AuthenticationError"]
  expected: true

invariant multiprocessing_extra5.TimeoutError.qualname:
  description: "multiprocessing.TimeoutError.__qualname__ == 'TimeoutError'"
  category: exception_qualnames
  kind: python_call_eq
  function: TimeoutError.__qualname__.__eq__
  args: ["TimeoutError"]
  expected: true
