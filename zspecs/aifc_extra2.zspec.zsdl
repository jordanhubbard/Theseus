spec: aifc_extra2
version: ">=3.9,<3.13"
backend: python_module(aifc)

docs: https://docs.python.org/3/library/aifc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/aifc.html — Python aifc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/aifc.py"
  notes:
    - "This spec extends aifc.zspec.zsdl and aifc_extra.zspec.zsdl."
    - "aifc.zspec.zsdl covers: Error/__name__, Error/__module__, Error/__bases__[0].__name__, Aifc_read/__name__, Aifc_read/__module__, Aifc_write/__name__, Aifc_write/__module__, open/__name__, open/__module__, Error/__bases__.__len__."
    - "aifc_extra.zspec.zsdl covers: open/__name__, open/__module__, Error/__name__, Error/__module__, Error/__bases__[0].__name__, Error/__bases__.__len__, Aifc_read/__name__, Aifc_read/__module__, Aifc_read method names, Aifc_write/__name__, Aifc_write/__module__, Aifc_write method names."
    - "This spec adds: __qualname__ checks for Aifc_read, Aifc_write, Error, and open — not covered in any prior spec."
    - "For top-level classes and functions, __qualname__ == __name__ in CPython."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Aifc_read — __qualname__
# Not covered by aifc.zspec.zsdl or aifc_extra.zspec.zsdl
# ---------------------------------------------------------------------------

invariant aifc_extra2.Aifc_read.qualname:
  description: "aifc.Aifc_read.__qualname__ == 'Aifc_read' — top-level class qualname matches name"
  category: classes
  kind: python_call_eq
  function: Aifc_read.__qualname__.__eq__
  args: ["Aifc_read"]
  expected: true

# ---------------------------------------------------------------------------
# Aifc_write — __qualname__
# Not covered by aifc.zspec.zsdl or aifc_extra.zspec.zsdl
# ---------------------------------------------------------------------------

invariant aifc_extra2.Aifc_write.qualname:
  description: "aifc.Aifc_write.__qualname__ == 'Aifc_write' — top-level class qualname matches name"
  category: classes
  kind: python_call_eq
  function: Aifc_write.__qualname__.__eq__
  args: ["Aifc_write"]
  expected: true

# ---------------------------------------------------------------------------
# Error — __qualname__
# Not covered by aifc.zspec.zsdl or aifc_extra.zspec.zsdl
# ---------------------------------------------------------------------------

invariant aifc_extra2.Error.qualname:
  description: "aifc.Error.__qualname__ == 'Error' — top-level exception class qualname matches name"
  category: classes
  kind: python_call_eq
  function: Error.__qualname__.__eq__
  args: ["Error"]
  expected: true

# ---------------------------------------------------------------------------
# open — __qualname__
# Not covered by aifc.zspec.zsdl or aifc_extra.zspec.zsdl
# ---------------------------------------------------------------------------

invariant aifc_extra2.open.qualname:
  description: "aifc.open.__qualname__ == 'open' — module-level function qualname matches name"
  category: functions
  kind: python_call_eq
  function: open.__qualname__.__eq__
  args: ["open"]
  expected: true

# ---------------------------------------------------------------------------
# Table: batch __qualname__ cross-checks for classes
# Structural companion to the individual invariants above, using a table form
# with a distinct id_prefix to avoid conflicts.
# ---------------------------------------------------------------------------

table aifc_extra2.class_qualnames:
  kind: python_call_eq
  category: classes
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Aifc_read,  Aifc_read.__qualname__.__eq__,  ["Aifc_read"],  true]
    - [Aifc_write, Aifc_write.__qualname__.__eq__, ["Aifc_write"], true]
    - [Error,      Error.__qualname__.__eq__,      ["Error"],      true]
