spec: concurrent_futures_extra108
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec extends concurrent_futures_extra107.zspec.zsdl."
    - "This spec covers: wave 254 theme — concurrent.futures.ThreadPoolExecutor.__init__ qualname length, ProcessPoolExecutor.__init__ qualname, and class qualnames. NEW in extra108: ThreadPoolExecutor.__qualname__=='ThreadPoolExecutor' (len=18); ProcessPoolExecutor.__qualname__=='ProcessPoolExecutor' (len=19, longest class qualname in spec); Executor.__qualname__=='Executor' (len=8, shortest class qualname in spec); Future.__qualname__=='Future' (len=6); ThreadPoolExecutor.__module__=='concurrent.futures.thread'; ProcessPoolExecutor.__module__=='concurrent.futures.process'; Executor.__module__=='concurrent.futures._base'; Future.__module__=='concurrent.futures._base'; ThreadPoolExecutor.__init__.__qualname__=='ThreadPoolExecutor.__init__' (len=27); ProcessPoolExecutor.__init__.__qualname__=='ProcessPoolExecutor.__init__' (len=28, longest qualname in spec); ThreadPoolExecutor.__init__.__code__.co_argcount==5; ProcessPoolExecutor.__init__.__code__.co_argcount==5. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor' (len=18). concurrent.futures.ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor' (len=19). concurrent.futures.Executor.__qualname__ == 'Executor' (len=8). concurrent.futures.Future.__qualname__ == 'Future' (len=6, shortest in spec). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__ == 'ThreadPoolExecutor.__init__' (len=27). concurrent.futures.ProcessPoolExecutor.__init__.__qualname__ == 'ProcessPoolExecutor.__init__' (len=28, longest qualname in spec, one char longer than TPE.__init__). Both __init__ methods have co_argcount=5. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ThreadPoolExecutor and ProcessPoolExecutor class qualnames — extra108
#
# Wave 254 theme: executor class __qualname__ lengths.
#
# ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor' (len=18)
# ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor' (len=19, longest class qualname)
# Executor.__qualname__           == 'Executor'            (len=8)
# Future.__qualname__             == 'Future'              (len=6, shortest)
# ---------------------------------------------------------------------------

table concurrent_futures_extra108.cf_class_qualnames:
  description: "concurrent.futures class __qualname__ length checks in cfclass108 namespace — wave 254 theme: concurrent.futures.ThreadPoolExecutor.__qualname__.__eq__('ThreadPoolExecutor')==True (len=18: 'ThreadPoolExecutor'=18); concurrent.futures.ThreadPoolExecutor.__qualname__.__len__()==18; concurrent.futures.ProcessPoolExecutor.__qualname__.__eq__('ProcessPoolExecutor')==True (len=19: 'ProcessPoolExecutor'=19; longest class qualname in spec — PPE is one char longer than TPE); concurrent.futures.ProcessPoolExecutor.__qualname__.__len__()==19; concurrent.futures.Executor.__qualname__.__eq__('Executor')==True (len=8: 'Executor'=8); concurrent.futures.Executor.__qualname__.__len__()==8; concurrent.futures.Future.__qualname__.__eq__('Future')==True (len=6: 'Future'=6; shortest class qualname in spec); concurrent.futures.Future.__qualname__.__len__()==6; compare class qualname lengths: Future=6 (shortest) < Executor=8 < ThreadPoolExecutor=18 < ProcessPoolExecutor=19 (longest); ProcessPoolExecutor len=19 > ThreadPoolExecutor len=18 (PPE qualname is one char longer: 'ProcessPoolExecutor'=19 vs 'ThreadPoolExecutor'=18 — 'Process'=7 vs 'Thread'=6, +1 char); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfclass108

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_qn_eq,         concurrent.futures.ThreadPoolExecutor.__qualname__.__eq__,    ["ThreadPoolExecutor"],   true, "ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor' (len=18); verified with Python 3.14.3"]
    - [tpe_qn_len,        concurrent.futures.ThreadPoolExecutor.__qualname__.__len__,   [],                       18,   "ThreadPoolExecutor.__qualname__.__len__() == 18 ('ThreadPoolExecutor'=18); verified with Python 3.14.3"]
    - [ppe_qn_eq,         concurrent.futures.ProcessPoolExecutor.__qualname__.__eq__,   ["ProcessPoolExecutor"],  true, "ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor' (len=19, longest class qualname in spec); verified with Python 3.14.3"]
    - [ppe_qn_len,        concurrent.futures.ProcessPoolExecutor.__qualname__.__len__,  [],                       19,   "ProcessPoolExecutor.__qualname__.__len__() == 19 ('ProcessPoolExecutor'=19, longest class qualname); verified with Python 3.14.3"]
    - [exec_qn_eq,        concurrent.futures.Executor.__qualname__.__eq__,              ["Executor"],             true, "Executor.__qualname__ == 'Executor' (len=8); verified with Python 3.14.3"]
    - [exec_qn_len,       concurrent.futures.Executor.__qualname__.__len__,             [],                       8,    "Executor.__qualname__.__len__() == 8 ('Executor'=8); verified with Python 3.14.3"]
    - [fut_qn_eq,         concurrent.futures.Future.__qualname__.__eq__,                ["Future"],               true, "Future.__qualname__ == 'Future' (len=6, shortest class qualname in spec); verified with Python 3.14.3"]
    - [fut_qn_len,        concurrent.futures.Future.__qualname__.__len__,               [],                       6,    "Future.__qualname__.__len__() == 6 ('Future'=6, shortest class qualname in spec); verified with Python 3.14.3"]
    - [tpe_vs_ppe_cmp,    concurrent.futures.ProcessPoolExecutor.__qualname__.__len__,  [],                       19,   "PPE qualname len=19 > TPE qualname len=18 (Process=7 vs Thread=6, +1 char); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ThreadPoolExecutor and ProcessPoolExecutor __init__ qualnames — extra108
#
# Wave 254 theme: __init__ method qualname lengths.
#
# ThreadPoolExecutor.__init__.__qualname__ == 'ThreadPoolExecutor.__init__' (len=27)
# ProcessPoolExecutor.__init__.__qualname__ == 'ProcessPoolExecutor.__init__' (len=28, longest)
# ---------------------------------------------------------------------------

table concurrent_futures_extra108.cf_init_qualnames:
  description: "concurrent.futures ThreadPoolExecutor and ProcessPoolExecutor __init__ method qualname checks in cfclass108 namespace — wave 254 theme: concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__eq__('ThreadPoolExecutor.__init__')==True (len=27: 'ThreadPoolExecutor.'=19+'__init__'=8=27); concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__len__()==27; type(concurrent.futures.ThreadPoolExecutor.__init__).__name__.__eq__('function')==True (Python-defined); concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount==5 (self, max_workers, thread_name_prefix, initializer, initargs — 5 positional args); concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__eq__('ProcessPoolExecutor.__init__')==True (len=28: 'ProcessPoolExecutor.'=20+'__init__'=8=28; longest qualname in spec); concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__len__()==28; type(concurrent.futures.ProcessPoolExecutor.__init__).__name__.__eq__('function')==True; concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_argcount==5 (self, max_workers, mp_context, initializer, initargs — also 5 positional args); compare __init__ qualname lengths: TPE.__init__=27 < PPE.__init__=28 (PPE is one char longer, matching the class qualname difference of 18 vs 19); both __init__ methods have co_argcount=5; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: cfclass108a

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_init_qn_eq,    concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__eq__,   ["ThreadPoolExecutor.__init__"], true, "TPE.__init__.__qualname__ == 'ThreadPoolExecutor.__init__' (len=27); verified with Python 3.14.3"]
    - [tpe_init_qn_len,   concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__len__,  [],                              27,   "TPE.__init__.__qualname__.__len__() == 27 ('ThreadPoolExecutor.__init__'=27); verified with Python 3.14.3"]
    - [tpe_init_type_eq,  type(concurrent.futures.ThreadPoolExecutor.__init__).__name__.__eq__, ["function"],                    true, "type(TPE.__init__).__name__ == 'function' (Python-defined); verified with Python 3.14.3"]
    - [tpe_init_argc,     concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount.__eq__, [5],                       true, "TPE.__init__.__code__.co_argcount == 5 (self, max_workers, thread_name_prefix, initializer, initargs); verified with Python 3.14.3"]
    - [ppe_init_qn_eq,    concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__eq__,  ["ProcessPoolExecutor.__init__"], true, "PPE.__init__.__qualname__ == 'ProcessPoolExecutor.__init__' (len=28, longest in spec); verified with Python 3.14.3"]
    - [ppe_init_qn_len,   concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__len__, [],                              28,   "PPE.__init__.__qualname__.__len__() == 28 ('ProcessPoolExecutor.__init__'=28, longest qualname in spec); verified with Python 3.14.3"]
    - [ppe_init_type_eq,  type(concurrent.futures.ProcessPoolExecutor.__init__).__name__.__eq__, ["function"],                   true, "type(PPE.__init__).__name__ == 'function' (Python-defined); verified with Python 3.14.3"]
    - [ppe_init_argc,     concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_argcount.__eq__, [5],                      true, "PPE.__init__.__code__.co_argcount == 5 (self, max_workers, mp_context, initializer, initargs); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures class modules — extra108
#
# Wave 254 theme: executor class __module__ values.
#
# ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'
# ProcessPoolExecutor.__module__ == 'concurrent.futures.process'
# Executor.__module__           == 'concurrent.futures._base'
# Future.__module__             == 'concurrent.futures._base'
# ---------------------------------------------------------------------------

table concurrent_futures_extra108.cf_class_modules:
  description: "concurrent.futures class __module__ attribute checks in cfclass108 namespace — wave 254 theme: concurrent.futures.ThreadPoolExecutor.__module__.__eq__('concurrent.futures.thread')==True (TPE is defined in concurrent.futures.thread submodule); concurrent.futures.ProcessPoolExecutor.__module__.__eq__('concurrent.futures.process')==True (PPE is defined in concurrent.futures.process submodule); concurrent.futures.Executor.__module__.__eq__('concurrent.futures._base')==True (Executor is defined in the private _base submodule); concurrent.futures.Future.__module__.__eq__('concurrent.futures._base')==True (Future is also in _base, same as Executor); compare: TPE and PPE are in their own dedicated submodules ('thread' and 'process' respectively); Executor and Future share the '_base' submodule; concurrent.futures.Executor.__mro__.__len__()==2 ([Executor, object]); concurrent.futures.ThreadPoolExecutor.__mro__.__len__()==3 ([ThreadPoolExecutor, Executor, object]); concurrent.futures.Future.__mro__.__len__()==2 ([Future, object]); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfclass108b

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_module_eq,     concurrent.futures.ThreadPoolExecutor.__module__.__eq__,      ["concurrent.futures.thread"],   true, "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'; verified with Python 3.14.3"]
    - [ppe_module_eq,     concurrent.futures.ProcessPoolExecutor.__module__.__eq__,     ["concurrent.futures.process"],  true, "ProcessPoolExecutor.__module__ == 'concurrent.futures.process'; verified with Python 3.14.3"]
    - [exec_module_eq,    concurrent.futures.Executor.__module__.__eq__,                ["concurrent.futures._base"],    true, "Executor.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [fut_module_eq,     concurrent.futures.Future.__module__.__eq__,                  ["concurrent.futures._base"],    true, "Future.__module__ == 'concurrent.futures._base' (same as Executor); verified with Python 3.14.3"]
    - [exec_mro_len,      concurrent.futures.Executor.__mro__.__len__,                  [],                              2,    "Executor.__mro__.__len__() == 2 ([Executor, object]); verified with Python 3.14.3"]
    - [tpe_mro_len,       concurrent.futures.ThreadPoolExecutor.__mro__.__len__,        [],                              3,    "ThreadPoolExecutor.__mro__.__len__() == 3 ([ThreadPoolExecutor, Executor, object]); verified with Python 3.14.3"]
    - [ppe_mro_len,       concurrent.futures.ProcessPoolExecutor.__mro__.__len__,       [],                              3,    "ProcessPoolExecutor.__mro__.__len__() == 3 ([ProcessPoolExecutor, Executor, object]); verified with Python 3.14.3"]
    - [fut_mro_len,       concurrent.futures.Future.__mro__.__len__,                    [],                              2,    "Future.__mro__.__len__() == 2 ([Future, object]); verified with Python 3.14.3"]
    - [exec_base_eq,      "concurrent.futures.Executor.__bases__[0].__name__.__eq__",   ["object"],                      true, "Executor.__bases__[0].__name__ == 'object' (Executor inherits directly from object); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra108
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra108.ProcessPoolExecutor_init_qualname_len_28:
  description: "concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__len__() == 28 — 'ProcessPoolExecutor.__init__' = 'ProcessPoolExecutor.'=20 + '__init__'=8 = 28; this is the longest qualname in this spec; compare __init__ qualname lengths: TPE.__init__=27 < PPE.__init__=28 (PPE is one char longer); compare class qualname lengths: Future=6 (shortest) < Executor=8 < TPE=18 < PPE=19 (longest class qualname); PPE.__init__ qualname len=28 > TPE.__init__ qualname len=27 (one char difference: 'Process'=7 vs 'Thread'=6); PPE.__init__.__code__.co_argcount==5 (self, max_workers, mp_context, initializer, initargs); TPE.__init__.__code__.co_argcount==5 (same count, different parameter names); NEW in extra108: first standalone PPE.__init__ qualname length invariant in cfclass108 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__len__
  args: []
  expected: 28

invariant concurrent_futures_extra108.ThreadPoolExecutor_qualname_len_18:
  description: "concurrent.futures.ThreadPoolExecutor.__qualname__.__len__() == 18 — 'ThreadPoolExecutor'=18 chars; compare class qualname lengths in spec: Future=6 (shortest) < Executor=8 < ThreadPoolExecutor=18 < ProcessPoolExecutor=19 (longest); TPE class qualname len=18 < PPE class qualname len=19 (Process=7 chars vs Thread=6 chars, PPE is one char longer); TPE.__init__.__qualname__.__len__()==27 (class qualname 18 + '.__init__'=9); TPE.__module__=='concurrent.futures.thread'; ThreadPoolExecutor.__mro__.__len__()==3 ([ThreadPoolExecutor, Executor, object]); TPE inherits from Executor — the base class implementing the context manager protocol; NEW in extra108: first standalone TPE qualname length invariant in cfclass108 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__qualname__.__len__
  args: []
  expected: 18

invariant concurrent_futures_extra108.ProcessPoolExecutor_qualname_len_19:
  description: "concurrent.futures.ProcessPoolExecutor.__qualname__.__len__() == 19 — 'ProcessPoolExecutor'=19 chars; this is the longest class qualname in this spec; compare: Future=6 (shortest) < Executor=8 < ThreadPoolExecutor=18 < ProcessPoolExecutor=19 (longest); PPE qualname len=19 > TPE qualname len=18 (Process=7 chars vs Thread=6 chars, PPE one char longer); PPE.__init__.__qualname__.__len__()==28 (class qualname 19 + '.__init__'=9 = 28); PPE.__module__=='concurrent.futures.process'; ProcessPoolExecutor.__mro__.__len__()==3 ([ProcessPoolExecutor, Executor, object]); PPE is the executor that runs callables using a pool of worker processes (for CPU-bound work); NEW in extra108: first standalone PPE qualname length invariant in cfclass108 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ProcessPoolExecutor.__qualname__.__len__
  args: []
  expected: 19

invariant concurrent_futures_extra108.Future_qualname_len_6:
  description: "concurrent.futures.Future.__qualname__.__len__() == 6 — 'Future'=6 chars; this is the shortest class qualname in this spec; compare: Future=6 (shortest) < Executor=8 < ThreadPoolExecutor=18 < ProcessPoolExecutor=19 (longest); Future.__module__=='concurrent.futures._base' (same submodule as Executor); Future.__mro__.__len__()==2 ([Future, object]); Future is the result object returned by executor.submit() — it represents the eventual result of an asynchronous computation; Future.__qualname__=='Future' (simple top-level class name); Future.__qualname__.__len__()==6 < Executor.__qualname__.__len__()==8 (Future is shorter name than Executor); NEW in extra108: first standalone Future qualname length invariant in cfclass108 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.__qualname__.__len__
  args: []
  expected: 6

invariant concurrent_futures_extra108.Executor_qualname_len_8:
  description: "concurrent.futures.Executor.__qualname__.__len__() == 8 — 'Executor'=8 chars; compare: Future=6 (shorter) < Executor=8 < ThreadPoolExecutor=18 < ProcessPoolExecutor=19 (longest class qualname in spec); Executor is the abstract base class for both ThreadPoolExecutor and ProcessPoolExecutor; Executor.__module__=='concurrent.futures._base'; Executor.__mro__.__len__()==2 ([Executor, object]); Executor.__bases__[0].__name__=='object' (Executor inherits directly from object); Executor provides the context manager protocol (__enter__/__exit__) and the map/submit/shutdown interface; Executor.__qualname__=='Executor' (top-level class); Executor qualname len=8 < TPE qualname len=18 (the concrete executor subclasses have much longer names); NEW in extra108: first standalone Executor qualname length invariant in cfclass108 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Executor.__qualname__.__len__
  args: []
  expected: 8
