spec: functools_extra297
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — singledispatch, singledispatchmethod, total_ordering, update_wrapper, wraps, reduce, cmp_to_key identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py, Modules/_functoolsmodule.c"
  notes:
    - "singledispatch is a plain function (class name 'function')"
    - "singledispatchmethod is a class/type (class name 'type')"
    - "reduce and cmp_to_key are C builtins (class name 'builtin_function_or_method')"
    - "total_ordering, update_wrapper, wraps are plain Python functions"
    - "functools.partial.__module__ is 'functools' even though partial is implemented in C"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table functools_extra297.class_names:
  description: "__class__.__name__ for key functools callables"
  kind: python_call_eq
  category: identity
  id_prefix: fce297a

  columns: [id, function, args, expected, description]
  rows:
    - [fce297a001, functools.singledispatch.__class__.__name__.__eq__, ["function"], true, "singledispatch is a plain function"]
    - [fce297a002, functools.singledispatchmethod.__class__.__name__.__eq__, ["type"], true, "singledispatchmethod is a type/class"]
    - [fce297a003, functools.total_ordering.__class__.__name__.__eq__, ["function"], true, "total_ordering is a plain function"]
    - [fce297a004, functools.update_wrapper.__class__.__name__.__eq__, ["function"], true, "update_wrapper is a plain function"]
    - [fce297a005, functools.wraps.__class__.__name__.__eq__, ["function"], true, "wraps is a plain function"]
    - [fce297a006, functools.reduce.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "reduce is a C builtin"]
    - [fce297a007, functools.cmp_to_key.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "cmp_to_key is a C builtin"]

table functools_extra297.qualnames:
  description: "__qualname__ for key functools callables"
  kind: python_call_eq
  category: identity
  id_prefix: fce297b

  columns: [id, function, args, expected, description]
  rows:
    - [fce297b001, functools.singledispatch.__qualname__.__eq__, ["singledispatch"], true, "singledispatch qualname matches name"]
    - [fce297b002, functools.singledispatchmethod.__qualname__.__eq__, ["singledispatchmethod"], true, "singledispatchmethod qualname matches name"]
    - [fce297b003, functools.total_ordering.__qualname__.__eq__, ["total_ordering"], true, "total_ordering qualname matches name"]
    - [fce297b004, functools.update_wrapper.__qualname__.__eq__, ["update_wrapper"], true, "update_wrapper qualname matches name"]
    - [fce297b005, functools.wraps.__qualname__.__eq__, ["wraps"], true, "wraps qualname matches name"]
    - [fce297b006, functools.reduce.__qualname__.__eq__, ["reduce"], true, "reduce qualname matches name"]
    - [fce297b007, functools.cmp_to_key.__qualname__.__eq__, ["cmp_to_key"], true, "cmp_to_key qualname matches name"]

invariant functools_extra297.singledispatch_is_function:
  description: "functools.singledispatch.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: functools.singledispatch.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra297.singledispatchmethod_is_type:
  description: "functools.singledispatchmethod.__class__.__name__ == 'type'"
  category: identity
  kind: python_call_eq
  function: functools.singledispatchmethod.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra297.reduce_is_builtin:
  description: "functools.reduce.__class__.__name__ == 'builtin_function_or_method'"
  category: identity
  kind: python_call_eq
  function: functools.reduce.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra297.partial_module:
  description: "functools.partial.__module__ == 'functools'"
  category: identity
  kind: python_call_eq
  function: functools.partial.__module__.__eq__
  args: ["functools"]
  expected: true
