spec: abc_extra34
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra33.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__/__name__/__qualname__.__len__() for ABC/ABCMeta/abstractmethod/get_cache_token/update_abstractmethods, abstractproperty lengths, ABCMeta.register qualname lengths, ABCMeta method __qualname__.__len__() tables, __mro__.__len__() for ABCMeta(3)/ABC(2), __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__(), ABCMeta/__subclasshook__/__qualname__.__len__()==24, update_abstractmethods/__qualname__.__len__()==22, ABC.__abstractmethods__.__class__.__name__.__len__()==9, ABC.__name__.__len__()==3, abstractmethod/__name__.__len__()==14, get_cache_token/__name__.__len__()==15, abc/__name__.__len__()==3, ABCMeta mro entry name/qualname lengths, ABC/__subclasshook__/__qualname__.__len__()==20, issubclass/isinstance behavioral invariants, abstractmethod/__class__/__name__.__len__()==8, ABC/__doc__/__class__/__name__.__len__()==3, ABCMeta/__prepare__/__qualname__.__len__()==19, ABCMeta/__init__/__qualname__.__len__()==13, ABCMeta/__getattribute__/__qualname__.__len__()==21, ABCMeta/__call__/__repr__/__qualname__.__len__()==13, ABCMeta/__setattr__/__delattr__/__qualname__.__len__()==16, abstractmethod/__code__/__class__/__name__.__len__()==4, ABC/__init_subclass__/__qualname__/__len__()==21, metaclass chain __class__/__name__.__len__() tables, abstractmethod/__annotations__/__class__/__name__.__len__()==4, get_cache_token/__class__/__name__.__len__()==26, ABCMeta/__bases__[0]/__module__/__qualname__.__len__(), ABC/__bases__[0]/__module__/__qualname__.__len__(), abstractmethod/__class__/__module__.__len__()==8, abc/__spec__/__class__/__name__.__len__()==10, ABCMeta MRO __module__/__qualname__.__len__() tables."
    - "This spec covers: abstractmethod.__name__=='abstractmethod'; abstractmethod.__module__=='abc'; abstractmethod.__qualname__=='abstractmethod'; get_cache_token.__name__=='get_cache_token'; get_cache_token.__module__=='_abc' (4 chars); ABC.__name__=='ABC'; ABC.__module__=='abc'; ABC.__bases__[0].__name__=='object'."
    - "get_cache_token.__module__ == '_abc' (4 chars, NOT 'abc'). The get_cache_token function is implemented in the C extension module '_abc' (CPython's Modules/_abc.c), not the pure-Python 'abc' module. This contrasts with abstractmethod.__module__ == 'abc' (3 chars). The '_abc' module name (with underscore prefix) signals a C-accelerated implementation. Prior specs (extra15, extra25) measured get_cache_token.__module__ as a string equality with 'abc', but the actual value in Python 3.14 is '_abc'. The extra34 spec corrects this: get_cache_token.__module__ == '_abc'."
    - "abstractmethod.__name__ == 'abstractmethod' (14 chars), abstractmethod.__module__ == 'abc' (3 chars), abstractmethod.__qualname__ == 'abstractmethod' (14 chars). For this top-level class, __name__ and __qualname__ are identical. Prior specs measured __len__() integer values for these attributes; the extra34 spec provides string equality checks in a fresh namespace."
    - "ABC.__name__ == 'ABC' (3 chars), ABC.__module__ == 'abc' (3 chars). Both have length 3, a coincidence of the same 3-char value for both the class name and the module name. ABC.__bases__[0].__name__ == 'object' confirms the direct inheritance from object (the only base class of ABC in the abc module)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.abstractmethod identity — extra34 namespace
#
# abstractmethod is the core abc decorator. Its identity attributes:
#   abstractmethod.__name__     == 'abstractmethod' (14 chars)
#   abstractmethod.__module__   == 'abc'            ( 3 chars)
#   abstractmethod.__qualname__ == 'abstractmethod' (14 chars)
# For a top-level class, __name__ and __qualname__ are the same string (both
# 'abstractmethod', 14 chars). The module is 'abc' (3 chars), the same as the
# top-level module. Prior specs measured __len__() integer values; extra34
# captures the string equality checks in this namespace.
# ---------------------------------------------------------------------------

table abc_extra34.abstractmethod_identity:
  description: "abc.abstractmethod identity string equality in extra34 namespace — __name__, __module__, __qualname__"
  kind: python_call_eq
  category: class_names
  id_prefix: abcabsmethid34

  columns: [id, function, args, expected, description]
  rows:
    - [name,     abstractmethod.__name__.__eq__,     ["abstractmethod"], true, "abstractmethod.__name__ == 'abstractmethod'"]
    - [module,   abstractmethod.__module__.__eq__,   ["abc"],            true, "abstractmethod.__module__ == 'abc'"]
    - [qualname, abstractmethod.__qualname__.__eq__, ["abstractmethod"], true, "abstractmethod.__qualname__ == 'abstractmethod' — same as __name__ for top-level class"]

# ---------------------------------------------------------------------------
# abc.get_cache_token identity — extra34 namespace
#
# get_cache_token is implemented in the C extension _abc, not the Python abc:
#   get_cache_token.__name__   == 'get_cache_token' (15 chars)
#   get_cache_token.__module__ == '_abc'             ( 4 chars)
# The module '_abc' (with underscore prefix, 4 chars) signals that get_cache_token
# is from CPython's C-accelerated abc implementation (Modules/_abc.c). This
# contrasts with abstractmethod.__module__ == 'abc' (3 chars, pure Python).
# The underscore prefix '_abc' is 1 char longer than 'abc' (4 vs 3).
# Prior specs may have expected get_cache_token.__module__ == 'abc'; the verified
# value on Python 3.14 is '_abc'.
# ---------------------------------------------------------------------------

table abc_extra34.get_cache_token_identity:
  description: "abc.get_cache_token identity string equality in extra34 namespace — from C extension _abc"
  kind: python_call_eq
  category: function_names
  id_prefix: abcgctid34

  columns: [id, function, args, expected, description]
  rows:
    - [name,   get_cache_token.__name__.__eq__,   ["get_cache_token"], true, "get_cache_token.__name__ == 'get_cache_token'"]
    - [module, get_cache_token.__module__.__eq__,  ["_abc"],            true, "get_cache_token.__module__ == '_abc' — C extension, not pure-Python 'abc'"]

# ---------------------------------------------------------------------------
# abc.ABC identity — extra34 namespace
#
# ABC is the helper class for abstract base classes:
#   ABC.__name__           == 'ABC'    (3 chars)
#   ABC.__module__         == 'abc'    (3 chars)
#   ABC.__bases__[0].__name__ == 'object' (6 chars)
# Both ABC.__name__ and ABC.__module__ have the same length (3), which is a
# coincidence: the class name 'ABC' and the module name 'abc' are both 3 chars.
# ABC inherits directly from object (and uses ABCMeta as its metaclass), so
# ABC.__bases__[0].__name__ == 'object'.
# Prior specs measured these as integer lengths and other boolean forms;
# extra34 captures fresh string equality checks in this namespace.
# ---------------------------------------------------------------------------

table abc_extra34.ABC_identity:
  description: "abc.ABC identity string equality in extra34 namespace — __name__, __module__, __bases__[0].__name__"
  kind: python_call_eq
  category: class_names
  id_prefix: abcabcid34

  columns: [id, function, args, expected, description]
  rows:
    - [name,       ABC.__name__.__eq__,              ["ABC"],    true, "ABC.__name__ == 'ABC' (3 chars)"]
    - [module,     ABC.__module__.__eq__,             ["abc"],    true, "ABC.__module__ == 'abc' (3 chars) — same length as __name__"]
    - [bases0_name, "ABC.__bases__[0].__name__.__eq__", ["object"], true, "ABC.__bases__[0].__name__ == 'object' — ABC directly inherits from object"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra34
# ---------------------------------------------------------------------------

invariant abc_extra34.abstractmethod_name_eq:
  description: "abc.abstractmethod.__name__ == 'abstractmethod' — the canonical name of the abstractmethod decorator; 14 characters"
  category: class_names
  kind: python_call_eq
  function: abstractmethod.__name__.__eq__
  args: ["abstractmethod"]
  expected: true

invariant abc_extra34.get_cache_token_module_eq:
  description: "abc.get_cache_token.__module__ == '_abc' — get_cache_token is from the C-accelerated _abc extension (4 chars), not the pure-Python abc module (3 chars)"
  category: module_names
  kind: python_call_eq
  function: get_cache_token.__module__.__eq__
  args: ["_abc"]
  expected: true

invariant abc_extra34.get_cache_token_module_len:
  description: "abc.get_cache_token.__module__.__len__() == 4 — '_abc' has 4 characters; 1 longer than 'abc' (3) due to the underscore prefix on the C extension module"
  category: module_names
  kind: python_call_eq
  function: get_cache_token.__module__.__len__
  args: []
  expected: 4

invariant abc_extra34.ABC_bases0_name_eq:
  description: "abc.ABC.__bases__[0].__name__ == 'object' — ABC's sole base class is object; ABC uses ABCMeta as its metaclass but inherits from object"
  category: class_names
  kind: python_call_eq
  function: "ABC.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
