spec: logging_extra4
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "Python 3 logging documentation — https://docs.python.org/3/library/logging.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
    - "logging.zspec.zsdl — covers level constants/ordering, getLevelName int↔str, class __name__ table, function __name__ table"
    - "logging_extra.zspec.zsdl — covers level constants, WARN/FATAL aliases, Logger/Handler/Formatter/Filter/LogRecord/Manager __name__, Logger.__module__, getLogger/__name__, getLevelName forward lookups"
    - "logging_extra2.zspec.zsdl — covers StreamHandler/FileHandler __name__+__module__, level constants, basicConfig/makeLogRecord/captureWarnings/disable/addLevelName __name__"
    - "logging_extra3.zspec.zsdl — covers NullHandler __name__+__module__, Handler/Formatter/Filter/LogRecord __module__, Logger method names, level type checks, getLogger/__module__, basicConfig/__module__, getLevelName/getLogger class_is_function"
  notes:
    - "This spec extends all prior logging specs; it does NOT duplicate invariants already present there."
    - "logging.Logger.__bases__[0].__name__ == 'Filterer' — Logger inherits from Filterer."
    - "logging.Handler.__bases__[0].__name__ == 'Filterer' — Handler inherits from Filterer."
    - "logging.StreamHandler.__bases__[0].__name__ == 'Handler' — StreamHandler inherits from Handler."
    - "logging.FileHandler.__bases__[0].__name__ == 'StreamHandler' — FileHandler inherits from StreamHandler."
    - "logging.Formatter.__bases__[0].__name__ == 'object' — Formatter inherits directly from object."
    - "logging.Filter.__bases__[0].__name__ == 'object' — Filter inherits directly from object."
    - "logging.LogRecord.__bases__[0].__name__ == 'object' — LogRecord inherits directly from object."
    - "logging.Filterer.__name__ == 'Filterer' — the common base for Logger and Handler."
    - "logging.Filterer.__module__ == 'logging' — Filterer is defined in the core logging module."
    - "logging.Manager.__name__ == 'Manager' — Manager tracks the Logger hierarchy."
    - "logging.PlaceHolder.__name__ == 'PlaceHolder' — PlaceHolder is used internally in the logger hierarchy."
    - "logging.PercentStyle.__name__ == 'PercentStyle' — default % formatting style."
    - "logging.StrFormatStyle.__name__ == 'StrFormatStyle' — {}-format style."
    - "logging.StringTemplateStyle.__name__ == 'StringTemplateStyle' — Template-format style."
    - "logging.BASIC_FORMAT is a str constant containing the default basicConfig format string."
    - "All expected values verified by running Python 3.12 logging module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Filterer — name and module
# Not covered by any prior logging spec.
# ---------------------------------------------------------------------------

invariant logging_extra4.Filterer.name:
  description: "logging.Filterer.__name__ == 'Filterer'"
  category: class_names
  kind: python_call_eq
  function: Filterer.__name__.__eq__
  args: ["Filterer"]
  expected: true

invariant logging_extra4.Filterer.module:
  description: "logging.Filterer.__module__ == 'logging'"
  category: class_modules
  kind: python_call_eq
  function: Filterer.__module__.__eq__
  args: ["logging"]
  expected: true

# ---------------------------------------------------------------------------
# Manager and PlaceHolder — name checks
# Manager.__name__ is covered in logging_extra (table row); here we add
# PlaceHolder.__name__ which is new coverage.
# ---------------------------------------------------------------------------

invariant logging_extra4.Manager.name:
  description: "logging.Manager.__name__ == 'Manager'"
  category: class_names
  kind: python_call_eq
  function: Manager.__name__.__eq__
  args: ["Manager"]
  expected: true

invariant logging_extra4.PlaceHolder.name:
  description: "logging.PlaceHolder.__name__ == 'PlaceHolder'"
  category: class_names
  kind: python_call_eq
  function: PlaceHolder.__name__.__eq__
  args: ["PlaceHolder"]
  expected: true

# ---------------------------------------------------------------------------
# Formatting style classes — name checks
# PercentStyle, StrFormatStyle, StringTemplateStyle are the three style classes.
# ---------------------------------------------------------------------------

table logging_extra4.style_class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: sname

  columns: [id, function, args, expected]
  rows:
    - [percentstyle,         PercentStyle.__name__.__eq__,         ["PercentStyle"],         true]
    - [strformatstyle,       StrFormatStyle.__name__.__eq__,       ["StrFormatStyle"],       true]
    - [stringtemplatestyle,  StringTemplateStyle.__name__.__eq__,  ["StringTemplateStyle"],  true]

# ---------------------------------------------------------------------------
# BASIC_FORMAT — string type check
# logging.BASIC_FORMAT is the default format string used by basicConfig.
# ---------------------------------------------------------------------------

invariant logging_extra4.BASIC_FORMAT.class_name:
  description: "logging.BASIC_FORMAT.__class__.__name__ == 'str' — BASIC_FORMAT is a plain string"
  category: constants
  kind: python_call_eq
  function: BASIC_FORMAT.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Class hierarchy — __bases__[0].__name__ checks
#
# Logger → Filterer, Handler → Filterer, StreamHandler → Handler,
# FileHandler → StreamHandler, Formatter → object, Filter → object,
# LogRecord → object
# ---------------------------------------------------------------------------

invariant logging_extra4.Logger.base_is_Filterer:
  description: "logging.Logger.__bases__[0].__name__ == 'Filterer' — Logger inherits from Filterer"
  category: class_hierarchy
  kind: python_call_eq
  function: Logger.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Filterer"

invariant logging_extra4.Handler.base_is_Filterer:
  description: "logging.Handler.__bases__[0].__name__ == 'Filterer' — Handler inherits from Filterer"
  category: class_hierarchy
  kind: python_call_eq
  function: Handler.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Filterer"

invariant logging_extra4.StreamHandler.base_is_Handler:
  description: "logging.StreamHandler.__bases__[0].__name__ == 'Handler' — StreamHandler inherits from Handler"
  category: class_hierarchy
  kind: python_call_eq
  function: StreamHandler.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Handler"

invariant logging_extra4.FileHandler.base_is_StreamHandler:
  description: "logging.FileHandler.__bases__[0].__name__ == 'StreamHandler' — FileHandler inherits from StreamHandler"
  category: class_hierarchy
  kind: python_call_eq
  function: FileHandler.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "StreamHandler"

invariant logging_extra4.Formatter.base_is_object:
  description: "logging.Formatter.__bases__[0].__name__ == 'object' — Formatter inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Formatter.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant logging_extra4.Filter.base_is_object:
  description: "logging.Filter.__bases__[0].__name__ == 'object' — Filter inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Filter.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant logging_extra4.LogRecord.base_is_object:
  description: "logging.LogRecord.__bases__[0].__name__ == 'object' — LogRecord inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: LogRecord.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"
