spec: logging_extra20
version: ">=3.9"
backend: python_module(logging.handlers)

docs: https://docs.python.org/3/library/logging.handlers.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.handlers.html — Python logging.handlers module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/handlers.py"
  notes:
    - "This spec extends logging.zspec.zsdl through logging_extra19.zspec.zsdl."
    - "logging_extra19 covers: Manager/PlaceHolder/LogRecord/Filter __class__.__name__ == 'type'; RotatingFileHandler __name__/__qualname__/__module__/__class__.__name__ and mro_len."
    - "logging_extra4 covers: Logger/Handler/StreamHandler/FileHandler/Formatter/Filter/LogRecord __bases__[0].__name__."
    - "logging_extra12 covers: NullHandler.__bases__[0].__name__."
    - "NOT yet covered in any prior spec: BaseRotatingHandler/__name__/__qualname__/__module__/__class__.__name__."
    - "NOT yet covered in any prior spec: TimedRotatingFileHandler/__name__/__qualname__/__module__/__class__.__name__."
    - "NOT yet covered in any prior spec: BaseRotatingHandler.__bases__[0].__name__ == 'FileHandler'."
    - "NOT yet covered in any prior spec: TimedRotatingFileHandler.__bases__[0].__name__ == 'BaseRotatingHandler'."
    - "NOT yet covered in any prior spec: SocketHandler.__bases__[0].__name__ == 'Handler'."
    - "NOT yet covered in any prior spec: SysLogHandler.__bases__[0].__name__ == 'Handler'."
    - "BaseRotatingHandler.__bases__[0].__name__ == 'FileHandler' — BaseRotatingHandler extends FileHandler."
    - "TimedRotatingFileHandler.__bases__[0].__name__ == 'BaseRotatingHandler' — mirrors RotatingFileHandler hierarchy."
    - "SocketHandler.__bases__[0].__name__ == 'Handler' — SocketHandler is a direct subclass of Handler."
    - "SysLogHandler.__bases__[0].__name__ == 'Handler' — SysLogHandler is a direct subclass of Handler."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BaseRotatingHandler — identity attributes
#
# logging_extra19 covers RotatingFileHandler identity attributes.
# No prior spec records BaseRotatingHandler __name__, __qualname__,
# __module__, or __class__.__name__ as standalone invariants.
# BaseRotatingHandler is the abstract base for all rotating-file handlers;
# it inherits directly from FileHandler.
# ---------------------------------------------------------------------------

invariant logging_extra20.BaseRotatingHandler.name:
  description: "logging.handlers.BaseRotatingHandler.__name__ == 'BaseRotatingHandler'"
  category: class_identity
  kind: python_call_eq
  function: BaseRotatingHandler.__name__.__eq__
  args: ["BaseRotatingHandler"]
  expected: true

invariant logging_extra20.BaseRotatingHandler.qualname:
  description: "logging.handlers.BaseRotatingHandler.__qualname__ == 'BaseRotatingHandler'"
  category: class_identity
  kind: python_call_eq
  function: BaseRotatingHandler.__qualname__.__eq__
  args: ["BaseRotatingHandler"]
  expected: true

invariant logging_extra20.BaseRotatingHandler.module:
  description: "logging.handlers.BaseRotatingHandler.__module__ == 'logging.handlers'"
  category: class_identity
  kind: python_call_eq
  function: BaseRotatingHandler.__module__.__eq__
  args: ["logging.handlers"]
  expected: true

invariant logging_extra20.BaseRotatingHandler.class_name:
  description: "logging.handlers.BaseRotatingHandler.__class__.__name__ == 'type'"
  category: class_identity
  kind: python_call_eq
  function: BaseRotatingHandler.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant logging_extra20.BaseRotatingHandler.base_class:
  description: "logging.handlers.BaseRotatingHandler.__bases__[0].__name__ == 'FileHandler'"
  category: class_hierarchy
  kind: python_call_eq
  function: BaseRotatingHandler.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "FileHandler"

# ---------------------------------------------------------------------------
# TimedRotatingFileHandler — identity attributes
#
# No prior spec records TimedRotatingFileHandler __name__, __qualname__,
# __module__, __class__.__name__, or __bases__[0].__name__.
# TimedRotatingFileHandler inherits directly from BaseRotatingHandler.
# ---------------------------------------------------------------------------

invariant logging_extra20.TimedRotatingFileHandler.name:
  description: "logging.handlers.TimedRotatingFileHandler.__name__ == 'TimedRotatingFileHandler'"
  category: class_identity
  kind: python_call_eq
  function: TimedRotatingFileHandler.__name__.__eq__
  args: ["TimedRotatingFileHandler"]
  expected: true

invariant logging_extra20.TimedRotatingFileHandler.module:
  description: "logging.handlers.TimedRotatingFileHandler.__module__ == 'logging.handlers'"
  category: class_identity
  kind: python_call_eq
  function: TimedRotatingFileHandler.__module__.__eq__
  args: ["logging.handlers"]
  expected: true

invariant logging_extra20.TimedRotatingFileHandler.base_class:
  description: "logging.handlers.TimedRotatingFileHandler.__bases__[0].__name__ == 'BaseRotatingHandler'"
  category: class_hierarchy
  kind: python_call_eq
  function: TimedRotatingFileHandler.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "BaseRotatingHandler"

# ---------------------------------------------------------------------------
# Handler subclasses — base class table
#
# SocketHandler and SysLogHandler both inherit directly from Handler.
# No prior spec checks __bases__[0].__name__ for either.
# This table groups them with other handlers for a consolidated hierarchy view.
# ---------------------------------------------------------------------------

table logging_extra20.handler_base_classes:
  description: "Base class names for logging.handlers subclasses via __bases__[0].__name__"
  kind: python_call_eq
  category: class_hierarchy

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [SocketHandler,             SocketHandler.__bases__.__getitem__,             [0], __name__, [], "Handler"]
    - [SysLogHandler,             SysLogHandler.__bases__.__getitem__,             [0], __name__, [], "Handler"]
    - [BaseRotatingHandler,       BaseRotatingHandler.__bases__.__getitem__,       [0], __name__, [], "FileHandler"]
    - [RotatingFileHandler,       RotatingFileHandler.__bases__.__getitem__,       [0], __name__, [], "BaseRotatingHandler"]
    - [TimedRotatingFileHandler,  TimedRotatingFileHandler.__bases__.__getitem__,  [0], __name__, [], "BaseRotatingHandler"]
