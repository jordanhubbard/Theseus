spec: tkinter_extra4
version: ">=3.9"
backend: python_module(tkinter)

docs: https://docs.python.org/3/library/tkinter.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tkinter.html — Python tkinter module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tkinter/__init__.py"
  notes:
    - "This spec extends tkinter.zspec.zsdl and tkinter_extra through tkinter_extra3.zspec.zsdl."
    - "tkinter.zspec.zsdl covers: TclError __name__/__module__/__bases__; TRUE/FALSE/YES/NO/HORIZONTAL/VERTICAL/TOP/BOTTOM/LEFT/RIGHT constants."
    - "tkinter_extra.zspec.zsdl covers: Tk/Frame/Widget/Misc/Variable/StringVar __name__/__module__; TclError and StringVar hierarchy."
    - "tkinter_extra2.zspec.zsdl covers: Button/Label/Entry/Text/Canvas/IntVar __name__; batch widget class names table."
    - "tkinter_extra3.zspec.zsdl covers: DoubleVar/BooleanVar/Event __name__/__module__; IntVar/StringVar __module__; module __name__."
    - "This spec adds: BaseWidget/__name__, Pack/__name__, Place/__name__, Grid/__name__, EventType/__name__, Wm/__name__, BOTH constant; Widget/__module__."
    - "tkinter.BaseWidget is the base for all geometry-managed widgets; Widget inherits from it."
    - "tkinter.Pack, tkinter.Place, tkinter.Grid are the three geometry manager mixin classes."
    - "tkinter.EventType is an enum.IntEnum subclass (Python 3.3+) whose members represent X event types."
    - "tkinter.Wm is the window manager mixin class that provides wm_* methods to Tk."
    - "tkinter.BOTH == 'both' — used with the fill= option of pack geometry manager."
    - "All class name and constant checks are safe without a running Tk display."
    - "All expected values verified with Python 3.12 tkinter on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BaseWidget — class name
# tkinter_extra covers Widget.__name__; BaseWidget is Widget's immediate base
# and has not appeared in any prior tkinter spec.
# ---------------------------------------------------------------------------

invariant tkinter_extra4.BaseWidget.name:
  description: "tkinter.BaseWidget.__name__ == 'BaseWidget'"
  category: class_names
  kind: python_call_eq
  function: BaseWidget.__name__.__eq__
  args: ["BaseWidget"]
  expected: true

invariant tkinter_extra4.BaseWidget.module:
  description: "tkinter.BaseWidget.__module__ == 'tkinter'"
  category: class_modules
  kind: python_call_eq
  function: BaseWidget.__module__.__eq__
  args: ["tkinter"]
  expected: true

# ---------------------------------------------------------------------------
# Pack — geometry manager mixin class name
# Not covered in any prior tkinter spec.
# ---------------------------------------------------------------------------

invariant tkinter_extra4.Pack.name:
  description: "tkinter.Pack.__name__ == 'Pack'"
  category: class_names
  kind: python_call_eq
  function: Pack.__name__.__eq__
  args: ["Pack"]
  expected: true

invariant tkinter_extra4.Pack.module:
  description: "tkinter.Pack.__module__ == 'tkinter'"
  category: class_modules
  kind: python_call_eq
  function: Pack.__module__.__eq__
  args: ["tkinter"]
  expected: true

# ---------------------------------------------------------------------------
# Place — geometry manager mixin class name
# Not covered in any prior tkinter spec.
# ---------------------------------------------------------------------------

invariant tkinter_extra4.Place.name:
  description: "tkinter.Place.__name__ == 'Place'"
  category: class_names
  kind: python_call_eq
  function: Place.__name__.__eq__
  args: ["Place"]
  expected: true

invariant tkinter_extra4.Place.module:
  description: "tkinter.Place.__module__ == 'tkinter'"
  category: class_modules
  kind: python_call_eq
  function: Place.__module__.__eq__
  args: ["tkinter"]
  expected: true

# ---------------------------------------------------------------------------
# Grid — geometry manager mixin class name
# Not covered in any prior tkinter spec.
# ---------------------------------------------------------------------------

invariant tkinter_extra4.Grid.name:
  description: "tkinter.Grid.__name__ == 'Grid'"
  category: class_names
  kind: python_call_eq
  function: Grid.__name__.__eq__
  args: ["Grid"]
  expected: true

invariant tkinter_extra4.Grid.module:
  description: "tkinter.Grid.__module__ == 'tkinter'"
  category: class_modules
  kind: python_call_eq
  function: Grid.__module__.__eq__
  args: ["tkinter"]
  expected: true

# ---------------------------------------------------------------------------
# EventType — enum class name
# tkinter.EventType is an enum.IntEnum introduced in Python 3.3 that enumerates
# X event types (KeyPress, ButtonPress, Motion, etc.).
# Not covered in any prior tkinter spec.
# ---------------------------------------------------------------------------

invariant tkinter_extra4.EventType.name:
  description: "tkinter.EventType.__name__ == 'EventType'"
  category: class_names
  kind: python_call_eq
  function: EventType.__name__.__eq__
  args: ["EventType"]
  expected: true

invariant tkinter_extra4.EventType.module:
  description: "tkinter.EventType.__module__ == 'tkinter'"
  category: class_modules
  kind: python_call_eq
  function: EventType.__module__.__eq__
  args: ["tkinter"]
  expected: true

# ---------------------------------------------------------------------------
# Widget.__module__ — not covered in any prior tkinter spec
# tkinter_extra.zspec.zsdl covers Widget.__name__ only.
# ---------------------------------------------------------------------------

invariant tkinter_extra4.Widget.module:
  description: "tkinter.Widget.__module__ == 'tkinter'"
  category: class_modules
  kind: python_call_eq
  function: Widget.__module__.__eq__
  args: ["tkinter"]
  expected: true

# ---------------------------------------------------------------------------
# BOTH constant — fill/expand direction value
# tkinter.BOTH == 'both' is used with the fill= option of pack geometry manager
# to fill in both horizontal and vertical directions.
# tkinter.zspec.zsdl covers TOP/BOTTOM/LEFT/RIGHT/HORIZONTAL/VERTICAL but
# NOT BOTH; BOTH is not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant tkinter_extra4.BOTH.value:
  description: "tkinter.BOTH == 'both'"
  category: constants
  kind: python_call_eq
  function: BOTH.__eq__
  args: ["both"]
  expected: true

# ---------------------------------------------------------------------------
# Wm — window manager mixin class name
# tkinter.Wm provides window manager (wm_*) methods; it is a mixin of tkinter.Tk.
# Not covered in any prior tkinter spec.
# ---------------------------------------------------------------------------

invariant tkinter_extra4.Wm.name:
  description: "tkinter.Wm.__name__ == 'Wm'"
  category: class_names
  kind: python_call_eq
  function: Wm.__name__.__eq__
  args: ["Wm"]
  expected: true

invariant tkinter_extra4.Wm.module:
  description: "tkinter.Wm.__module__ == 'tkinter'"
  category: class_modules
  kind: python_call_eq
  function: Wm.__module__.__eq__
  args: ["tkinter"]
  expected: true

# ---------------------------------------------------------------------------
# Table: batch __name__ checks for geometry manager mixin classes
# Provides a consolidated view of Pack, Place, and Grid alongside BaseWidget.
# ---------------------------------------------------------------------------

table tkinter_extra4.geometry_managers.names:
  kind: python_call_eq
  category: class_names
  id_prefix: geomname

  columns: [id, function, args, expected]
  rows:
    - [BaseWidget, BaseWidget.__name__.__eq__, ["BaseWidget"], true]
    - [Pack,       Pack.__name__.__eq__,       ["Pack"],       true]
    - [Place,      Place.__name__.__eq__,      ["Place"],      true]
    - [Grid,       Grid.__name__.__eq__,       ["Grid"],       true]
    - [EventType,  EventType.__name__.__eq__,  ["EventType"],  true]
    - [Wm,         Wm.__name__.__eq__,         ["Wm"],         true]
