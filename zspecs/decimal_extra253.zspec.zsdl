spec: decimal_extra253
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra.zspec.zsdl — covers Decimal predicates, to_eng_string, Context/BasicContext/ExtendedContext class names, DefaultContext instance type, ROUND_HALF_UP/ROUND_HALF_DOWN/ROUND_CEILING/ROUND_FLOOR"
  notes:
    - "decimal.Context.__name__ == 'Context' and __module__ == 'decimal'."
    - "decimal.Context.__bases__[0].__name__ == 'object' — Context inherits directly from object."
    - "decimal.getcontext() returns the current thread-local context; default prec == 28."
    - "Default Emax == 999999, Emin == -999999 per the IBM General Decimal Arithmetic Specification."
    - "Default rounding mode is 'ROUND_HALF_EVEN' (banker's rounding)."
    - "ROUND_HALF_EVEN, ROUND_DOWN, ROUND_UP, ROUND_CEILING, ROUND_FLOOR are plain str constants equal to their own names."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Context — class identity: name, module, base
# ---------------------------------------------------------------------------

invariant decimal_extra253.Context.class_name:
  description: "decimal.Context.__name__ == 'Context'"
  category: identity
  kind: python_call_eq
  function: Context.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra253.Context.module:
  description: "decimal.Context.__module__ == 'decimal'"
  category: identity
  kind: python_call_eq
  function: Context.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra253.Context.base_name:
  description: "decimal.Context.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: Context.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

# ---------------------------------------------------------------------------
# decimal.getcontext() — default prec, Emax, Emin values
# ---------------------------------------------------------------------------

invariant decimal_extra253.getcontext.prec:
  description: "decimal.getcontext().prec == 28 (default precision)"
  category: context_defaults
  kind: python_call_eq
  function: getcontext
  args: []
  method: prec
  method_chain: __eq__
  method_chain_args: [28]
  expected: true

invariant decimal_extra253.getcontext.Emax:
  description: "decimal.getcontext().Emax == 999999 (default max exponent)"
  category: context_defaults
  kind: python_call_eq
  function: getcontext
  args: []
  method: Emax
  method_chain: __eq__
  method_chain_args: [999999]
  expected: true

invariant decimal_extra253.getcontext.Emin:
  description: "decimal.getcontext().Emin == -999999 (default min exponent)"
  category: context_defaults
  kind: python_call_eq
  function: getcontext
  args: []
  method: Emin
  method_chain: __eq__
  method_chain_args: [-999999]
  expected: true

invariant decimal_extra253.getcontext.rounding:
  description: "decimal.getcontext().rounding == 'ROUND_HALF_EVEN' (default rounding mode)"
  category: context_defaults
  kind: python_call_eq
  function: getcontext
  args: []
  method: rounding
  method_chain: __eq__
  method_chain_args: ["ROUND_HALF_EVEN"]
  expected: true

# ---------------------------------------------------------------------------
# ROUND_* constants — string identity
# (decimal_extra.zspec.zsdl has ROUND_HALF_UP/DOWN/CEILING/FLOOR; we add HALF_EVEN/DOWN/UP/05UP)
# ---------------------------------------------------------------------------

table decimal_extra253.rounding_constants:
  description: "ROUND_* constants are plain strings equal to their own names"
  kind: python_call_eq
  category: rounding_modes
  id_prefix: round_const

  columns: [id, function, args, expected, description]
  rows:
    - [ROUND_HALF_EVEN, ROUND_HALF_EVEN.__eq__, ["ROUND_HALF_EVEN"], true, "ROUND_HALF_EVEN equals its own name"]
    - [ROUND_DOWN,      ROUND_DOWN.__eq__,      ["ROUND_DOWN"],      true, "ROUND_DOWN equals its own name"]
    - [ROUND_UP,        ROUND_UP.__eq__,        ["ROUND_UP"],        true, "ROUND_UP equals its own name"]
    - [ROUND_CEILING,   ROUND_CEILING.__eq__,   ["ROUND_CEILING"],   true, "ROUND_CEILING equals its own name"]
    - [ROUND_FLOOR,     ROUND_FLOOR.__eq__,     ["ROUND_FLOOR"],     true, "ROUND_FLOOR equals its own name"]
