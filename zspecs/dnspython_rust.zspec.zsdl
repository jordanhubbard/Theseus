spec: dnspython_rust
version: ">=3.9"
backend: rust_module(dnspython_rust)

docs: https://www.dnspython.org/

provenance:
  derived_from:
    - "https://www.dnspython.org/ — dnspython library"
  notes:
    - "dnspython provides DNS toolkit for Python."
    - "dns.name.from_text('www.example.com') returns a Name."
    - "dns.name.from_text('www.example.com').to_text() contains 'example'."
    - "dns.version.version is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant dnspython_rust.name_contains_example:
  description: "dns.name.from_text('www.example.com').to_text() contains 'example'"
  category: name
  kind: python_call_eq
  function: dns_name_contains_example
  args: []
  expected: true

invariant dnspython_rust.has_dns_name:
  description: "dns.name module is importable"
  category: presence
  kind: python_call_eq
  function: dns_has_name_module
  args: []
  expected: true

invariant dnspython_rust.version_nonempty:
  description: "dns.version.version is non-empty"
  category: version
  kind: python_call_eq
  function: dns_version_nonempty
  args: []
  expected: true

