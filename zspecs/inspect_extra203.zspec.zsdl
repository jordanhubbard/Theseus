spec: inspect_extra203
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers deeper __spec__ attributes of inspect: name, origin.__class__.__name__, has_location, parent, __class__.__name__, loader class identity."
    - "inspect.__spec__.name == 'inspect' — ModuleSpec.name equals the module name. Verified with Python 3.14.3."
    - "inspect.__spec__.origin.__class__.__name__ == 'str' — origin is a str holding the .py file path. Verified with Python 3.14.3."
    - "inspect.__spec__.has_location == True — inspect is a pure-Python source file; has_location is True. Verified with Python 3.14.3."
    - "inspect.__spec__.parent == '' — top-level module; spec.parent is an empty string. Verified with Python 3.14.3."
    - "inspect.__spec__.__class__.__name__ == 'ModuleSpec' — the spec object is an instance of ModuleSpec. Verified with Python 3.14.3."
    - "inspect.__spec__.loader.__class__.__name__ == 'SourceFileLoader' — inspect uses SourceFileLoader as a pure-Python source file. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.__spec__ name, class, and parent identity
#
# inspect.__spec__.name == 'inspect'
# inspect.__spec__.__class__.__name__ == 'ModuleSpec'
# inspect.__spec__.parent == ''
# inspect.__spec__.__class__.__module__ == '_frozen_importlib'
# ---------------------------------------------------------------------------

table inspect_extra203.spec_name_class_parent:
  description: "inspect.__spec__ name, __class__.__name__, parent, and __class__.__module__ identity; new to extra203"
  kind: python_call_eq
  category: module_spec
  id_prefix: inspectspec203

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,
       __spec__.name.__eq__,
       ["inspect"],
       true,
       "inspect.__spec__.name.__eq__('inspect') == True — ModuleSpec.name attribute equals 'inspect'; new to extra203"]
    - [spec_class_name_eq,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "inspect.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — __spec__ is a ModuleSpec instance; new to extra203"]
    - [spec_parent_eq,
       __spec__.parent.__eq__,
       [""],
       true,
       "inspect.__spec__.parent.__eq__('') == True — top-level module; spec.parent is empty string; new to extra203"]
    - [spec_class_module_eq,
       "__spec__.__class__.__module__.__eq__",
       ["_frozen_importlib"],
       true,
       "inspect.__spec__.__class__.__module__.__eq__('_frozen_importlib') == True — ModuleSpec is defined in _frozen_importlib; new to extra203"]

# ---------------------------------------------------------------------------
# Table 2: inspect.__spec__ has_location and origin (source file module)
#
# inspect.__spec__.has_location == True
# inspect.__spec__.origin.__class__.__name__ == 'str'
# inspect.__spec__.origin.endswith('inspect.py') == True
# inspect.__spec__.name.__len__() == 7
# ---------------------------------------------------------------------------

table inspect_extra203.spec_location_origin:
  description: "inspect.__spec__ has_location, origin type, origin suffix, and name length; new to extra203"
  kind: python_call_eq
  category: module_spec
  id_prefix: inspectspec203

  columns: [id, function, args, expected, description]
  rows:
    - [spec_has_location_true,
       __spec__.has_location.__eq__,
       [true],
       true,
       "inspect.__spec__.has_location.__eq__(True) == True — inspect is a source file module; has_location is True; new to extra203"]
    - [spec_origin_class_str,
       __spec__.origin.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.__spec__.origin.__class__.__name__.__eq__('str') == True — spec.origin is a str (file path); new to extra203"]
    - [spec_origin_endswith_py,
       __spec__.origin.endswith,
       ["inspect.py"],
       true,
       "inspect.__spec__.origin.endswith('inspect.py') == True — origin path ends with inspect.py; new to extra203"]
    - [spec_name_len,
       __spec__.name.__len__,
       [],
       7,
       "inspect.__spec__.name.__len__() == 7 — len('inspect') is 7; new to extra203"]

# ---------------------------------------------------------------------------
# Table 3: inspect.__spec__ loader and cached identity
#
# inspect.__spec__.loader.__class__.__name__ == 'SourceFileLoader'
# inspect.__spec__.loader.__class__.__module__ == '_frozen_importlib_external'
# inspect.__spec__.cached.endswith('.pyc') == True
# inspect.__spec__.submodule_search_locations.__class__.__name__ == 'NoneType'
# ---------------------------------------------------------------------------

table inspect_extra203.spec_loader_cached:
  description: "inspect.__spec__ loader class name, loader class module, cached suffix, and submodule_search_locations; new to extra203"
  kind: python_call_eq
  category: module_spec
  id_prefix: inspectspec203

  columns: [id, function, args, expected, description]
  rows:
    - [spec_loader_class_name,
       __spec__.loader.__class__.__name__.__eq__,
       ["SourceFileLoader"],
       true,
       "inspect.__spec__.loader.__class__.__name__.__eq__('SourceFileLoader') == True — inspect uses SourceFileLoader (pure Python source file); new to extra203"]
    - [spec_loader_class_module,
       __spec__.loader.__class__.__module__.__eq__,
       ["_frozen_importlib_external"],
       true,
       "inspect.__spec__.loader.__class__.__module__.__eq__('_frozen_importlib_external') == True — SourceFileLoader is from _frozen_importlib_external; new to extra203"]
    - [spec_cached_endswith_pyc,
       __spec__.cached.endswith,
       [".pyc"],
       true,
       "inspect.__spec__.cached.endswith('.pyc') == True — cached path ends with .pyc (compiled bytecode); new to extra203"]
    - [spec_submodule_locs_class,
       "__spec__.submodule_search_locations.__class__.__name__.__eq__",
       ["NoneType"],
       true,
       "inspect.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') == True — no submodules; submodule_search_locations is None; new to extra203"]

# ---------------------------------------------------------------------------
# Standalone invariants — inspect_extra203
# ---------------------------------------------------------------------------

invariant inspect_extra203.spec_name_eq:
  description: "inspect.__spec__.name == 'inspect' — ModuleSpec.name attribute equals module name; new to extra203"
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra203.spec_class_name_eq:
  description: "inspect.__spec__.__class__.__name__ == 'ModuleSpec' — __spec__ is a ModuleSpec instance; new to extra203"
  kind: python_call_eq
  function: "__spec__.__class__.__name__.__eq__"
  args: ["ModuleSpec"]
  expected: true

invariant inspect_extra203.spec_parent_eq:
  description: "inspect.__spec__.parent == '' — top-level module; spec.parent is empty string; new to extra203"
  kind: python_call_eq
  function: __spec__.parent.__eq__
  args: [""]
  expected: true

invariant inspect_extra203.spec_has_location_true:
  description: "inspect.__spec__.has_location == True — inspect is a source file module; has_location is True; new to extra203"
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [true]
  expected: true

invariant inspect_extra203.spec_origin_class_str:
  description: "inspect.__spec__.origin.__class__.__name__ == 'str' — spec.origin is a str holding the .py file path; new to extra203"
  kind: python_call_eq
  function: __spec__.origin.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant inspect_extra203.spec_origin_endswith_py:
  description: "inspect.__spec__.origin.endswith('inspect.py') == True — origin path ends with inspect.py; new to extra203"
  kind: python_call_eq
  function: __spec__.origin.endswith
  args: ["inspect.py"]
  expected: true

invariant inspect_extra203.spec_loader_class_name:
  description: "inspect.__spec__.loader.__class__.__name__ == 'SourceFileLoader' — inspect uses SourceFileLoader; new to extra203"
  kind: python_call_eq
  function: __spec__.loader.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant inspect_extra203.spec_class_module_eq:
  description: "inspect.__spec__.__class__.__module__ == '_frozen_importlib' — ModuleSpec is defined in _frozen_importlib; new to extra203"
  kind: python_call_eq
  function: "__spec__.__class__.__module__.__eq__"
