spec: base64_extra5
version: ">=3.9"
backend: python_module(base64)

docs: https://docs.python.org/3/library/base64.html
rfcs:
  - "RFC 4648 — The Base16, Base32, and Base64 Data Encodings"

provenance:
  derived_from:
    - "RFC 4648 — The Base16, Base32, and Base64 Data Encodings, October 2006"
    - "https://docs.python.org/3/library/base64.html — Python base64 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/base64.py"
    - "CPython source: Modules/binascii.c"
  notes:
    - "This spec extends base64.zspec.zsdl, base64_extra.zspec.zsdl, base64_extra2.zspec.zsdl, and base64_extra4.zspec.zsdl."
    - "It does NOT duplicate invariants present in those files."
    - "base64_extra and base64_extra2 cover __name__ for urlsafe_b64encode/urlsafe_b64decode, b16encode/b16decode, b32encode/b32decode, b85encode/b85decode, a85encode, encodebytes/decodebytes."
    - "base64_extra2 covers __module__ for b16encode, encodebytes, b85encode, decodebytes."
    - "base64_extra4 covers __name__ for urlsafe_b64encode/urlsafe_b64decode, b16encode/b16decode, b32encode/b32decode."
    - "MISSING from all prior specs: b64encode.__name__ and b64decode.__name__ (not in any existing table or invariant)."
    - "MISSING from all prior specs: b64encode.__module__ and b64decode.__module__."
    - "MISSING from all prior specs: urlsafe_b64encode.__module__ and urlsafe_b64decode.__module__."
    - "MISSING from all prior specs: b32decode.__module__ and b32encode.__module__."
    - "base64.b64encode.__name__ == 'b64encode' — b64encode is a plain Python function in Lib/base64.py."
    - "base64.b64decode.__name__ == 'b64decode' — likewise."
    - "base64.b64encode.__module__ == 'base64' — the function belongs to the base64 module."
    - "base64.b16encode(b'\\x00\\xff').__class__.__name__ == 'bytes' — return type check."
    - "base64.b32encode(b'abcd').__class__.__name__ == 'bytes' — return type check."
    - "base64.b64encode(b'\\x00').__class__.__name__ == 'bytes' — return type check."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# b64encode and b64decode __name__ checks
#
# Every prior base64 spec's function_names table covers urlsafe, b16, b32,
# b85, a85, encodebytes, decodebytes — but NOT b64encode or b64decode.
# These are the most fundamental functions in the module and are missing.
# ---------------------------------------------------------------------------

table base64_extra5.b64_function_names:
  description: "base64.b64encode and b64decode __name__ identity — not in any prior base64 spec table"
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [b64encode, b64encode.__name__.__eq__, ["b64encode"], true]
    - [b64decode, b64decode.__name__.__eq__, ["b64decode"], true]

# ---------------------------------------------------------------------------
# __module__ checks — functions not yet covered by base64_extra2
#
# base64_extra2 covers: b16encode, encodebytes, b85encode, decodebytes.
# This spec adds the remaining standard functions.
# ---------------------------------------------------------------------------

table base64_extra5.function_modules:
  description: "base64 functions __module__ == 'base64' — functions not covered in base64_extra2"
  kind: python_call_eq
  category: module_affiliation
  id_prefix: mod

  columns: [id, function, args, expected]
  rows:
    - [b64encode,           b64encode.__module__.__eq__,           ["base64"], true]
    - [b64decode,           b64decode.__module__.__eq__,           ["base64"], true]
    - [urlsafe_b64encode,   urlsafe_b64encode.__module__.__eq__,   ["base64"], true]
    - [urlsafe_b64decode,   urlsafe_b64decode.__module__.__eq__,   ["base64"], true]
    - [b32encode,           b32encode.__module__.__eq__,           ["base64"], true]
    - [b32decode,           b32decode.__module__.__eq__,           ["base64"], true]
    - [b16decode,           b16decode.__module__.__eq__,           ["base64"], true]

# ---------------------------------------------------------------------------
# Return-type class name checks — encode functions return bytes
#
# base64_extra4 covers urlsafe_b64encode return type via method_chain.
# Here we add b64encode, b16encode, b32encode — same dimension, new functions.
# ---------------------------------------------------------------------------

invariant base64_extra5.b64encode.returns_bytes:
  description: "base64.b64encode(b'\\x00').__class__.__name__ == 'bytes'"
  category: return_types
  kind: python_call_eq
  function: b64encode
  args: [!hex 00]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["bytes"]
  expected: true

invariant base64_extra5.b16encode.returns_bytes:
  description: "base64.b16encode(b'\\x00\\xff').__class__.__name__ == 'bytes'"
  category: return_types
  kind: python_call_eq
  function: b16encode
  args: [!hex 00ff]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["bytes"]
  expected: true

invariant base64_extra5.b32encode.returns_bytes:
  description: "base64.b32encode(b'abcd').__class__.__name__ == 'bytes'"
  category: return_types
  kind: python_call_eq
  function: b32encode
  args: [!hex 61626364]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# b64encode — length correctness
# b64encode output length is always ceil(n/3)*4 bytes.
# For 3 input bytes the output is exactly 4 bytes; for 1 byte it is 4 bytes (padded).
# Not covered in any prior base64 spec via __len__.
# ---------------------------------------------------------------------------

invariant base64_extra5.b64encode.three_bytes_len:
  description: "len(base64.b64encode(b'abc')) == 4 — 3 bytes encode to exactly 4 base64 chars"
  category: lengths
  kind: python_call_eq
  function: b64encode
  args: [!hex 616263]
  method: __len__
  method_args: []
  expected: 4

invariant base64_extra5.b64encode.one_byte_len:
  description: "len(base64.b64encode(b'\\x00')) == 4 — 1 byte encodes to 4 base64 chars (padded)"
  category: lengths
  kind: python_call_eq
  function: b64encode
  args: [!hex 00]
  method: __len__
  method_args: []
  expected: 4

invariant base64_extra5.b64encode.six_bytes_len:
  description: "len(base64.b64encode(b'abcdef')) == 8 — 6 bytes encode to exactly 8 base64 chars"
  category: lengths
  kind: python_call_eq
  function: b64encode
  args: [!hex 616263646566]
  method: __len__
  method_args: []
  expected: 8

# ---------------------------------------------------------------------------
# b64encode — value correctness for a binary (non-ASCII) input
# base64.b64encode(b'\\x00\\x00\\x00') == b'AAAA'
# Not in any prior spec (prior specs cover ASCII text like 'hello', 'foo', 'foobar').
# ---------------------------------------------------------------------------

invariant base64_extra5.b64encode.three_zero_bytes:
  description: "base64.b64encode(b'\\x00\\x00\\x00') == b'AAAA' — three zero bytes encode to 'AAAA'"
  category: encode_values
  kind: python_call_eq
  function: b64encode
  args: [!hex 000000]
  expected: !ascii "AAAA"

invariant base64_extra5.b64encode.single_zero_byte:
  description: "base64.b64encode(b'\\x00') == b'AA==' — single zero byte with padding"
  category: encode_values
  kind: python_call_eq
  function: b64encode
  args: [!hex 00]
  expected: !ascii "AA=="

# ---------------------------------------------------------------------------
# b64decode — value correctness matching the b64encode vectors above
# ---------------------------------------------------------------------------

invariant base64_extra5.b64decode.three_zero_bytes:
  description: "base64.b64decode(b'AAAA') == b'\\x00\\x00\\x00' — roundtrip with b64encode"
  category: decode_values
  kind: python_call_eq
  function: b64decode
  args: [!ascii "AAAA"]
  expected: !hex 000000

invariant base64_extra5.b64decode.single_zero_byte:
  description: "base64.b64decode(b'AA==') == b'\\x00' — decode padded single-byte output"
  category: decode_values
  kind: python_call_eq
  function: b64decode
  args: [!ascii "AA=="]
  expected: !hex 00
