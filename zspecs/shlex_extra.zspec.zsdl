spec: shlex_extra
version: ">=3.8"
backend: python_module(shlex)

docs: https://docs.python.org/3/library/shlex.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shlex.html — Python shlex module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/shlex.py"
    - "shlex.zspec.zsdl — covers split/quote/join functional vectors and error cases"
  notes:
    - "This spec extends shlex.zspec.zsdl with class and function identity checks."
    - "shlex.shlex.__name__ == 'shlex' — the class shares a name with the module."
    - "shlex.shlex.__module__ == 'shlex' — the class is defined in the shlex module."
    - "shlex.split.__name__ == 'split' — function identity check."
    - "shlex.join.__name__ == 'join' — function identity check (added in Python 3.8)."
    - "shlex.quote.__name__ == 'quote' — function identity check."
    - "shlex.split('hello world') == ['hello', 'world'] — basic two-word split."
    - "shlex.split('hello \"foo bar\"') == ['hello', 'foo bar'] — double-quoted phrase stripped."
    - "shlex.quote('hello world') == \"'hello world'\" — space forces single-quoting."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class identity — shlex.shlex
# ---------------------------------------------------------------------------

invariant shlex_extra.shlex_class.name:
  description: "shlex.shlex.__name__ == 'shlex'"
  category: class_metadata
  kind: python_call_eq
  function: shlex.__name__.__eq__
  args: ["shlex"]
  expected: true

invariant shlex_extra.shlex_class.module:
  description: "shlex.shlex.__module__ == 'shlex'"
  category: class_metadata
  kind: python_call_eq
  function: shlex.__module__.__eq__
  args: ["shlex"]
  expected: true

# ---------------------------------------------------------------------------
# Function identity — split, join, quote
# ---------------------------------------------------------------------------

table shlex_extra.function_names:
  description: "shlex function __name__ checks"
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [split, split.__name__.__eq__, ["split"], true]
    - [join,  join.__name__.__eq__,  ["join"],  true]
    - [quote, quote.__name__.__eq__, ["quote"], true]

# ---------------------------------------------------------------------------
# shlex.split — selected vectors
# shlex.zspec.zsdl already covers a wider table; here we add the specific
# vectors requested: basic two-word split and embedded double-quoted phrase.
# ---------------------------------------------------------------------------

invariant shlex_extra.split.two_words:
  description: "shlex.split('hello world') == ['hello', 'world']"
  category: split
  kind: python_call_eq
  function: split
  args: ["hello world"]
  expected: ["hello", "world"]

invariant shlex_extra.split.embedded_double_quote:
  description: "shlex.split('hello \"foo bar\"') == ['hello', 'foo bar']"
  category: split
  kind: python_call_eq
  function: split
  args: ["hello \"foo bar\""]
  expected: ["hello", "foo bar"]

# ---------------------------------------------------------------------------
# shlex.quote — space forces single-quoting
# shlex.zspec.zsdl covers this vector; here it is retained as a standalone
# invariant for cross-reference and independent verification.
# ---------------------------------------------------------------------------

invariant shlex_extra.quote.space_single_quoted:
  description: "shlex.quote('hello world') == \"'hello world'\""
  category: quote
  kind: python_call_eq
  function: quote
  args: ["hello world"]
  expected: "'hello world'"
