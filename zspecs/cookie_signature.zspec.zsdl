spec: cookie_signature
version: ">=1.0.0"
backend: node(cookie-signature)

docs: https://github.com/tj/node-cookie-signature#readme

provenance:
  derived_from:
    - "cookie-signature README — https://github.com/tj/node-cookie-signature#readme"
    - "Test vectors verified with cookie-signature@1.2.2 pre-installed in theseus repo, 2026-04-24"
  not_derived_from:
    - "cookie-signature source: index.js"
  notes:
    - "cookie-signature exports { sign, unsign }."
    - "sign(val, secret) produces HMAC-SHA256 signature appended with dot separator."
    - "unsign(val, secret) verifies the signature and returns original value or false."
    - "The output is deterministic: same inputs always produce the same signature."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "sign returns string; unsign returns string or false. No errors for valid inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table cookie_signature.sign:
  kind: node_module_call_eq
  function: sign
  category: sign
  id_prefix: csig_sign

  columns: [id, args, expected]
  rows:
    - [hello,  ["hello", "secret"],      "hello.iKqz7ejTrflNJquQ07r9SiCDBww7zOnAFO4EpEOEfAs"]
    - [test,   ["test value", "mysecret"], "test value.EfmAUA4sM+WnaJ5KvLzgoD98AiQKijLotKcmlzJWXuM"]

table cookie_signature.unsign:
  kind: node_module_call_eq
  function: unsign
  category: unsign
  id_prefix: csig_unsign

  columns: [id, args, expected]
  rows:
    - [valid,    ["hello.iKqz7ejTrflNJquQ07r9SiCDBww7zOnAFO4EpEOEfAs", "secret"],  "hello"]
    - [invalid,  ["bad.value", "secret"],  false]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T08:27:39Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
