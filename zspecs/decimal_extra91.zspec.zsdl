spec: decimal_extra91
version: ">=3.9"
backend: python_module(decimal)
extends: decimal_extra90

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal_extra90.zspec.zsdl."
    - "This spec covers: decimal.Decimal __dict__ membership + key method __qualname__ lengths."
    - "decimal.Decimal is a C extension class (_decimal.Decimal). Its __dict__ is a mappingproxy."
    - "Arithmetic operator dunders (__add__, __sub__, __mul__, __truediv__, __mod__, __pow__, __neg__, __abs__, __round__, __float__, __int__) are present in Decimal.__dict__."
    - "Math/conversion methods (as_tuple, sqrt, exp, ln, log10, quantize, normalize) are present in Decimal.__dict__."
    - "Decimal.__init__ is NOT in Decimal.__dict__ (False); __new__, __repr__, __str__ ARE present (True)."
    - "Decimal.__add__.__qualname__ = 'Decimal.__add__' (len=15), Decimal.__sub__.__qualname__ = 'Decimal.__sub__' (len=15)."
    - "Decimal.__mul__.__qualname__ = 'Decimal.__mul__' (len=15), Decimal.sqrt.__qualname__ = 'Decimal.sqrt' (len=12)."
    - "Decimal.quantize.__qualname__ = 'Decimal.quantize' (len=16), Decimal.as_tuple.__qualname__ = 'Decimal.as_tuple' (len=16)."
    - "Decimal.normalize.__qualname__ = 'Decimal.normalize' (len=17)."
    - "decimal.Decimal.__dict__.__class__.__name__ = 'mappingproxy'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal.__dict__ membership for arithmetic operators
# __add__, __sub__, __mul__, __truediv__, __mod__, __pow__,
# __neg__, __abs__, __round__, __float__, __int__ — all True
# ---------------------------------------------------------------------------

table decimal_extra91.Decimal_dict_arithmetic:
  description: "decimal.Decimal.__dict__ membership for arithmetic operators — all True"
  kind: python_call_eq
  category: dict_membership
  id_prefix: decimalclsdict91

  columns: [id, function, args, expected]
  rows:
    - [dec_has_add,    "Decimal.__dict__.__contains__",  ["__add__"],     true]
    - [dec_has_sub,    "Decimal.__dict__.__contains__",  ["__sub__"],     true]
    - [dec_has_mul,    "Decimal.__dict__.__contains__",  ["__mul__"],     true]
    - [dec_has_div,    "Decimal.__dict__.__contains__",  ["__truediv__"], true]
    - [dec_has_mod,    "Decimal.__dict__.__contains__",  ["__mod__"],     true]
    - [dec_has_pow,    "Decimal.__dict__.__contains__",  ["__pow__"],     true]
    - [dec_has_neg,    "Decimal.__dict__.__contains__",  ["__neg__"],     true]
    - [dec_has_abs,    "Decimal.__dict__.__contains__",  ["__abs__"],     true]
    - [dec_has_round,  "Decimal.__dict__.__contains__",  ["__round__"],   true]
    - [dec_has_float,  "Decimal.__dict__.__contains__",  ["__float__"],   true]
    - [dec_has_int,    "Decimal.__dict__.__contains__",  ["__int__"],     true]

# ---------------------------------------------------------------------------
# decimal.Decimal.__dict__ membership for conversion/math methods
# as_tuple, sqrt, exp, ln, log10, quantize, normalize — all True
# ---------------------------------------------------------------------------

table decimal_extra91.Decimal_dict_math:
  description: "decimal.Decimal.__dict__ membership for math/conversion methods: as_tuple, sqrt, exp, ln, log10, quantize, normalize — all True"
  kind: python_call_eq
  category: dict_membership
  id_prefix: decimalclsdict91

  columns: [id, function, args, expected]
  rows:
    - [dec_has_as_tuple,  "Decimal.__dict__.__contains__",  ["as_tuple"],  true]
    - [dec_has_sqrt,      "Decimal.__dict__.__contains__",  ["sqrt"],      true]
    - [dec_has_exp,       "Decimal.__dict__.__contains__",  ["exp"],       true]
    - [dec_has_ln,        "Decimal.__dict__.__contains__",  ["ln"],        true]
    - [dec_has_log10,     "Decimal.__dict__.__contains__",  ["log10"],     true]
    - [dec_has_quantize,  "Decimal.__dict__.__contains__",  ["quantize"],  true]
    - [dec_has_normalize, "Decimal.__dict__.__contains__",  ["normalize"], true]
    - [dec_has_nosuchm,   "Decimal.__dict__.__contains__",  ["no_such_method"], false]

# ---------------------------------------------------------------------------
# decimal.Decimal.__dict__ membership for dunder methods
# __init__ -> False (not present in C extension Decimal.__dict__)
# __new__, __repr__, __str__ -> True
# ---------------------------------------------------------------------------

table decimal_extra91.Decimal_dict_dunders:
  description: "decimal.Decimal.__dict__ membership for dunder methods: __init__ is False; __new__, __repr__, __str__ are True"
  kind: python_call_eq
  category: dict_membership
  id_prefix: decimalclsdict91

  columns: [id, function, args, expected]
  rows:
    - [dec_has_init,    "Decimal.__dict__.__contains__",  ["__init__"], false]
    - [dec_has_new,     "Decimal.__dict__.__contains__",  ["__new__"],  true]
    - [dec_has_repr,    "Decimal.__dict__.__contains__",  ["__repr__"], true]
    - [dec_has_str,     "Decimal.__dict__.__contains__",  ["__str__"],  true]
    - [dec_dict_cls,    Decimal.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# Selected Decimal method __qualname__ lengths
# __add__, __sub__, __mul__ -> len 15
# sqrt -> len 12
# quantize -> len 16
# as_tuple -> len 16
# normalize -> len 17
# ---------------------------------------------------------------------------

table decimal_extra91.Decimal_qualname_lengths:
  description: "Selected decimal.Decimal method __qualname__ lengths"
  kind: python_call_eq
  category: method_qualname
  id_prefix: decimalclsdict91

  columns: [id, function, args, expected]
  rows:
    - [dec_add_qnlen,   Decimal.__add__.__qualname__.__len__,   [], 15]
    - [dec_sub_qnlen,   Decimal.__sub__.__qualname__.__len__,   [], 15]
    - [dec_mul_qnlen,   Decimal.__mul__.__qualname__.__len__,   [], 15]
    - [dec_sqrt_qnlen,  Decimal.sqrt.__qualname__.__len__,      [], 12]
    - [dec_quant_qnlen, Decimal.quantize.__qualname__.__len__,  [], 16]
    - [dec_tuple_qnlen, Decimal.as_tuple.__qualname__.__len__,  [], 16]
    - [dec_norm_qnlen,  Decimal.normalize.__qualname__.__len__, [], 17]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra91.Decimal.dict_has_add:
  description: "decimal.Decimal.__dict__.__contains__('__add__') == True (Decimal's arithmetic operators are defined in the C extension class's __dict__)"
  category: dict_membership
  kind: python_call_eq
  function: "Decimal.__dict__.__contains__"
  args: ["__add__"]
  expected: true

invariant decimal_extra91.Decimal.dict_not_has_init:
  description: "decimal.Decimal.__dict__.__contains__('__init__') == False (Decimal C extension class does not expose __init__ in its __dict__; object construction goes through __new__)"
  category: dict_membership
  kind: python_call_eq
  function: "Decimal.__dict__.__contains__"
  args: ["__init__"]
  expected: false

invariant decimal_extra91.Decimal.dict_classname_mappingproxy:
  description: "decimal.Decimal.__dict__.__class__.__name__ == 'mappingproxy' (the class __dict__ of any Python class is always a mappingproxy, including C extension classes)"
  category: dict_membership
  kind: python_call_eq
  function: Decimal.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant decimal_extra91.Decimal.normalize_qualname_len:
  description: "decimal.Decimal.normalize.__qualname__.__len__() == 17 (qualname is 'Decimal.normalize', which is 17 characters)"
  category: method_qualname
  kind: python_call_eq
  function: Decimal.normalize.__qualname__.__len__
  args: []
  expected: 17

invariant decimal_extra91.Decimal.sqrt_qualname_len:
  description: "decimal.Decimal.sqrt.__qualname__.__len__() == 12 (qualname is 'Decimal.sqrt', which is 12 characters)"
  category: method_qualname
  kind: python_call_eq
  function: Decimal.sqrt.__qualname__.__len__
  args: []
  expected: 12
