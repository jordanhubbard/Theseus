spec: pathlib_extra214
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "pathlib_extra.zspec.zsdl — covers Path.__name__, Path.__module__, PurePosixPath component access"
    - "pathlib_extra210.zspec.zsdl — covers pathlib.Path.__mro__ type, length, and element names"
  notes:
    - "pathlib.Path.__dict__ is a mappingproxy; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__dict__.__contains__('open') == True; open() is defined directly on Path; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__dict__.__contains__('read_text') == True; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__dict__.__contains__('write_text') == True; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__dict__.__contains__('exists') == True; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__dict__.__contains__('mkdir') == True; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__dict__.__contains__('glob') == True; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__dict__.__contains__('iterdir') == True; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePath.__dict__.__contains__('name') == True; the 'name' property is defined on PurePath, not Path; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePath.__dict__.__contains__('exists') == False; filesystem methods are only on Path; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePath.__dict__.__contains__('mkdir') == False; filesystem methods are only on Path; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib.Path.__dict__ membership — I/O and file-content methods
# open, read_text, write_text are defined directly on Path
# ---------------------------------------------------------------------------

table pathlib_extra214.path_dict_io_methods:
  description: "pathlib.Path.__dict__ contains I/O and file-content method names"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibdict214

  columns: [id, function, args, expected, description]
  rows:
    - [path_has_open,       pathlib.Path.__dict__.__contains__,  ["open"],       true,  "pathlib.Path.__dict__.__contains__('open') == True; open() is defined directly on Path; confirmed Python 3.14.3 macOS"]
    - [path_has_read_text,  pathlib.Path.__dict__.__contains__,  ["read_text"],  true,  "pathlib.Path.__dict__.__contains__('read_text') == True; read_text() is a convenience method on Path; confirmed Python 3.14.3 macOS"]
    - [path_has_write_text, pathlib.Path.__dict__.__contains__,  ["write_text"], true,  "pathlib.Path.__dict__.__contains__('write_text') == True; write_text() is a convenience method on Path; confirmed Python 3.14.3 macOS"]
    - [path_no_listdir,     pathlib.Path.__dict__.__contains__,  ["listdir"],    false, "pathlib.Path.__dict__.__contains__('listdir') == False; 'listdir' is an os module function, not a Path method; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: pathlib.Path.__dict__ membership — filesystem operation methods
# exists, mkdir, glob, iterdir are defined directly on Path
# ---------------------------------------------------------------------------

table pathlib_extra214.path_dict_fs_methods:
  description: "pathlib.Path.__dict__ contains filesystem operation method names"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibdict214

  columns: [id, function, args, expected, description]
  rows:
    - [path_has_exists,  pathlib.Path.__dict__.__contains__,  ["exists"],  true,  "pathlib.Path.__dict__.__contains__('exists') == True; exists() is defined on Path; confirmed Python 3.14.3 macOS"]
    - [path_has_mkdir,   pathlib.Path.__dict__.__contains__,  ["mkdir"],   true,  "pathlib.Path.__dict__.__contains__('mkdir') == True; mkdir() is defined on Path; confirmed Python 3.14.3 macOS"]
    - [path_has_glob,    pathlib.Path.__dict__.__contains__,  ["glob"],    true,  "pathlib.Path.__dict__.__contains__('glob') == True; glob() is defined on Path; confirmed Python 3.14.3 macOS"]
    - [path_has_iterdir, pathlib.Path.__dict__.__contains__,  ["iterdir"], true,  "pathlib.Path.__dict__.__contains__('iterdir') == True; iterdir() is defined on Path; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: pathlib.PurePath.__dict__ membership — pure-path properties vs absent filesystem methods
# 'name' is present on PurePath; 'exists' and 'mkdir' are absent
# ---------------------------------------------------------------------------

table pathlib_extra214.purepath_dict_membership:
  description: "pathlib.PurePath.__dict__ contains pure-path property names but not filesystem method names"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibdict214

  columns: [id, function, args, expected, description]
  rows:
    - [purepath_has_name,      pathlib.PurePath.__dict__.__contains__,  ["name"],   true,   "pathlib.PurePath.__dict__.__contains__('name') == True; the 'name' property is defined on PurePath; confirmed Python 3.14.3 macOS"]
    - [purepath_has_suffix,    pathlib.PurePath.__dict__.__contains__,  ["suffix"],  true,   "pathlib.PurePath.__dict__.__contains__('suffix') == True; the 'suffix' property is defined on PurePath; confirmed Python 3.14.3 macOS"]
    - [purepath_no_exists,     pathlib.PurePath.__dict__.__contains__,  ["exists"],  false,  "pathlib.PurePath.__dict__.__contains__('exists') == False; filesystem methods are only on Path, not PurePath; confirmed Python 3.14.3 macOS"]
    - [purepath_no_mkdir,      pathlib.PurePath.__dict__.__contains__,  ["mkdir"],   false,  "pathlib.PurePath.__dict__.__contains__('mkdir') == False; filesystem methods are only on Path, not PurePath; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra214.path_has_open:
  description: "pathlib.Path.__dict__.__contains__('open') == True — open() is defined directly on Path; confirmed Python 3.14.3 macOS"
  category: dict_membership
  kind: python_call_eq
  function: pathlib.Path.__dict__.__contains__
  args: ["open"]
  expected: true

