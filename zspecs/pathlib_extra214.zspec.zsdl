  args: ["glob"]
  expected: true

invariant pathlib_extra214.path_has_iterdir:
  description: "pathlib.Path.__dict__.__contains__('iterdir') == True — iterdir() is defined on Path; confirmed Python 3.14.3 macOS"
  category: dict_membership
