  description: "inspect __doc__.__len__ checks in inspectdoclen213 namespace — getmembers.__doc__ has len 134, signature.__doc__ has len 47, isfunction.__doc__ has len 817, getsource.__doc__ has len 250; all four rows verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inspectdoclen213

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_doc_len,
       getmembers.__doc__.__len__,
       [],
       134,
       "inspect.getmembers.__doc__.__len__() == 134 — the getmembers docstring has exactly 134 characters; verified with Python 3.14.3"]
    - [signature_doc_len,
       signature.__doc__.__len__,
       [],
       47,
       "inspect.signature.__doc__.__len__() == 47 — the signature docstring has exactly 47 characters; verified with Python 3.14.3"]
    - [isfunction_doc_len,
       isfunction.__doc__.__len__,
       [],
       817,
       "inspect.isfunction.__doc__.__len__() == 817 — the isfunction docstring has exactly 817 characters; verified with Python 3.14.3"]
    - [getsource_doc_len,
       getsource.__doc__.__len__,
       [],
       250,
       "inspect.getsource.__doc__.__len__() == 250 — the getsource docstring has exactly 250 characters; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — inspect_extra213
# ---------------------------------------------------------------------------

invariant inspect_extra213.getmembers_doc_contains_member:
  description: "inspect.getmembers.__doc__.__contains__('member') == True — the getmembers docstring says 'Return all members of an object'; new to extra213; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: getmembers.__doc__.__contains__
  args: ["member"]
  expected: true

invariant inspect_extra213.signature_doc_contains_signature:
  description: "inspect.signature.__doc__.__contains__('signature') == True — the signature docstring says 'Get a signature object'; new to extra213; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: signature.__doc__.__contains__
  args: ["signature"]
  expected: true

invariant inspect_extra213.signature_doc_contains_callable:
  description: "inspect.signature.__doc__.__contains__('callable') == True — the signature docstring says 'for the passed callable'; new to extra213; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: signature.__doc__.__contains__
  args: ["callable"]
  expected: true

invariant inspect_extra213.isfunction_doc_contains_function:
