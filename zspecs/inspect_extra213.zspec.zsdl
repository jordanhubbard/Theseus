spec: inspect_extra213
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect_extra212.zspec.zsdl — covers inspect __qualname__ equality and length checks"
    - "inspect_signature.zspec.zsdl — covers inspect.Signature behavior"
    - "inspect.zspec.zsdl — covers core inspect function behavior"
  notes:
    - "inspect.getmembers.__doc__.__contains__('member') == True — the getmembers docstring says 'Return all members of an object as (name, value) pairs'. Verified with Python 3.14.3."
    - "inspect.signature.__doc__.__contains__('signature') == True — the signature docstring says 'Get a signature object for the passed callable.' Verified with Python 3.14.3."
    - "inspect.signature.__doc__.__contains__('callable') == True — the signature docstring says 'for the passed callable'. Verified with Python 3.14.3."
    - "inspect.isfunction.__doc__.__contains__('function') == True — the isfunction docstring says 'Return true if the object is a user-defined function.' Verified with Python 3.14.3."
    - "inspect.getmodule.__doc__.__contains__('module') == True — the getmodule docstring says 'Return the module an object was defined in'. Verified with Python 3.14.3."
    - "inspect.getsource.__doc__.__contains__('source') == True — the getsource docstring says 'Return the text of the source code for an object.' Verified with Python 3.14.3."
    - "inspect.isclass.__doc__.__contains__('class') == True — the isclass docstring says 'Return true if the object is a class.' Verified with Python 3.14.3."
    - "inspect.ismodule.__doc__.__contains__('module') == True — the ismodule docstring says 'Return true if the object is a module.' Verified with Python 3.14.3."
    - "inspect.getmembers.__doc__.__len__() == 134 — the getmembers docstring has exactly 134 characters. Verified with Python 3.14.3."
    - "inspect.isfunction.__doc__.__len__() == 817 — the isfunction docstring has exactly 817 characters. Verified with Python 3.14.3."
    - "inspect.getsource.__doc__.__len__() == 250 — the getsource docstring has exactly 250 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect __doc__.__contains__ checks — getmembers, signature, isfunction
#
# getmembers.__doc__.__contains__('member')    == True
# signature.__doc__.__contains__('signature')  == True
# signature.__doc__.__contains__('callable')   == True
# isfunction.__doc__.__contains__('function')  == True
# ---------------------------------------------------------------------------

table inspect_extra213.doc_contains_group1:
  description: "inspect __doc__.__contains__ checks for getmembers, signature, and isfunction in inspectdoccontains213g1 namespace — getmembers.__doc__ contains 'member' (True), signature.__doc__ contains 'signature' (True), signature.__doc__ contains 'callable' (True), isfunction.__doc__ contains 'function' (True); all four rows verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inspectdoccontains213g1

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_doc_contains_member,
       getmembers.__doc__.__contains__,
       ["member"],
       true,
       "inspect.getmembers.__doc__.__contains__('member') == True — the getmembers docstring says 'Return all members of an object as (name, value) pairs sorted by name'; __contains__('member') returns True; verified with Python 3.14.3"]
    - [signature_doc_contains_signature,
       signature.__doc__.__contains__,
       ["signature"],
       true,
       "inspect.signature.__doc__.__contains__('signature') == True — the signature docstring says 'Get a signature object for the passed callable'; __contains__('signature') returns True; verified with Python 3.14.3"]
    - [signature_doc_contains_callable,
       signature.__doc__.__contains__,
       ["callable"],
       true,
       "inspect.signature.__doc__.__contains__('callable') == True — the signature docstring says 'for the passed callable'; __contains__('callable') returns True; verified with Python 3.14.3"]
    - [isfunction_doc_contains_function,
       isfunction.__doc__.__contains__,
       ["function"],
       true,
       "inspect.isfunction.__doc__.__contains__('function') == True — the isfunction docstring says 'Return true if the object is a user-defined function'; __contains__('function') returns True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: inspect __doc__.__contains__ checks — getmodule, getsource, isclass, ismodule
#
# getmodule.__doc__.__contains__('module')   == True
# getsource.__doc__.__contains__('source')   == True
# isclass.__doc__.__contains__('class')      == True
# ismodule.__doc__.__contains__('module')    == True
# ---------------------------------------------------------------------------

table inspect_extra213.doc_contains_group2:
  description: "inspect __doc__.__contains__ checks for getmodule, getsource, isclass, and ismodule in inspectdoccontains213g2 namespace — getmodule.__doc__ contains 'module' (True), getsource.__doc__ contains 'source' (True), isclass.__doc__ contains 'class' (True), ismodule.__doc__ contains 'module' (True); all four rows verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inspectdoccontains213g2

  columns: [id, function, args, expected, description]
  rows:
    - [getmodule_doc_contains_module,
       getmodule.__doc__.__contains__,
       ["module"],
       true,
       "inspect.getmodule.__doc__.__contains__('module') == True — the getmodule docstring says 'Return the module an object was defined in, or None if not found'; __contains__('module') returns True; verified with Python 3.14.3"]
    - [getsource_doc_contains_source,
       getsource.__doc__.__contains__,
       ["source"],
       true,
       "inspect.getsource.__doc__.__contains__('source') == True — the getsource docstring says 'Return the text of the source code for an object'; __contains__('source') returns True; verified with Python 3.14.3"]
    - [isclass_doc_contains_class,
       isclass.__doc__.__contains__,
       ["class"],
       true,
       "inspect.isclass.__doc__.__contains__('class') == True — the isclass docstring says 'Return true if the object is a class'; __contains__('class') returns True; verified with Python 3.14.3"]
    - [ismodule_doc_contains_module,
       ismodule.__doc__.__contains__,
       ["module"],
       true,
       "inspect.ismodule.__doc__.__contains__('module') == True — the ismodule docstring says 'Return true if the object is a module'; __contains__('module') returns True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
