spec: protobuf_rust
version: ">=3.9"
backend: rust_module(protobuf_rust)

docs: https://googleapis.dev/python/protobuf/latest/

provenance:
  derived_from:
    - "https://googleapis.dev/python/protobuf/latest/ — Protocol Buffers Python"
  not_derived_from:
    - "protobuf source: python/google/protobuf/__init__.py"
  notes:
    - "protobuf provides Protocol Buffer serialization for Python."
    - "google.protobuf.__version__ is a non-empty string."
    - "google.protobuf.descriptor is available."
    - "from google.protobuf import descriptor_pool; descriptor_pool.Default() is not None."
    - "int(google.protobuf.__version__.split('.')[0]) >= 4."
    - "Expose protobuf_version_nonempty() -> bool: len(google.protobuf.__version__) > 0."
    - "Expose protobuf_version_major() -> int: int(google.protobuf.__version__.split('.')[0])."
    - "Expose protobuf_has_descriptor() -> bool: hasattr(google.protobuf, 'descriptor')."
    - "All test vectors verified against protobuf 5.29.4."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# protobuf_version_nonempty — version non-empty
invariant protobuf_rust.version.nonempty:
  description: "google.protobuf.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: protobuf_version_nonempty
  args: []
  expected: true

# protobuf_version_major — major version >= 4
invariant protobuf_rust.version.major_ge4:
  description: "protobuf major version >= 4"
  category: version
  kind: python_call_eq
  function: protobuf_version_major
  args: []
  expected: 5

# protobuf_has_descriptor — descriptor module present
invariant protobuf_rust.module.has_descriptor:
  description: "google.protobuf.descriptor is available"
  category: module
  kind: python_call_eq
  function: protobuf_has_descriptor
  args: []
  expected: true

