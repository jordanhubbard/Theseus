spec: itertools_extra35
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra34.zspec.zsdl."
    - "Prior specs covered: chain/cycle/count/dropwhile/filterfalse/groupby/islice/pairwise/permutations/combinations/product/repeat/starmap/takewhile/zip_longest __name__/__module__/__qualname__ and their __len__() values; __mro__.__len__() for all major types (all 2); __bases__[0].__name__.__len__() for all major types (all 6 — 'object'); __dict__.__class__.__name__.__len__() for all major types (all 12 — 'mappingproxy'); chain.from_iterable.__qualname__.__len__() (19 — 'chain.from_iterable'); __qualname__.__len__() for all major types; itertools.__package__.__len__()==0; itertools.__name__.__len__()==9; itertools.__spec__.__class__.__name__.__len__()==10."
    - "This spec covers: chain.from_iterable.__name__.__len__() (13 — 'from_iterable', confirming the short classmethod name distinct from its qualified 19-char path); chain.__doc__.__len__() (190 — the C type docstring); count.__doc__.__len__() (205 — the C type docstring, longest of the core trio); repeat.__doc__.__len__() (154 — the C type docstring)."
    - "Key findings: chain.from_iterable.__name__ is 'from_iterable' (13 chars) — shorter than its __qualname__ 'chain.from_iterable' (19 chars) because __name__ gives only the local method name. chain.__doc__ is 190 chars, count.__doc__ is 205 chars (the longest among chain/count/repeat), and repeat.__doc__ is 154 chars. All three C-type docstrings are distinct in length."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# chain.from_iterable.__name__.__len__() — extra35 namespace
#
# itertools.chain.from_iterable.__name__ is 'from_iterable' (13 chars). This
# is the short local name of the classmethod descriptor. Its __qualname__ is
# 'chain.from_iterable' (19 chars) — recorded in extra30. The distinction
# between __name__ (13) and __qualname__ (19) is notable: __name__ gives only
# the unqualified method name, while __qualname__ includes the owning class.
# No prior itertools spec records chain.from_iterable.__name__.__len__() == 13
# as a standalone in the extra35 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra35.chain_from_iterable_name_len:
  description: "len(itertools.chain.from_iterable.__name__) == 13 — 'from_iterable' (shorter than 19-char __qualname__ 'chain.from_iterable')"
  category: string_properties
  kind: python_call_eq
  function: chain.from_iterable.__name__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# C-type docstring length table — chain/count/repeat __doc__.__len__()
#
# itertools.chain.__doc__ is 190 characters. itertools.count.__doc__ is 205
# characters — the longest of this trio. itertools.repeat.__doc__ is 154
# characters. All three are C-level types whose docstrings are embedded in
# the C source. No prior itertools spec records __doc__.__len__() for chain,
# count, or repeat. These three values are recorded together for the first
# time in the extra35 namespace.
# ---------------------------------------------------------------------------

table itertools_extra35.type_docstring_lengths:
  description: "itertools C-type __doc__.__len__() for chain (190), count (205), and repeat (154)"
  kind: python_call_eq
  category: string_properties
  id_prefix: typedoclen35

  columns: [id, function, args, expected, description]
  rows:
    - [chain,
       chain.__doc__.__len__,
       [],
       190,
       "len(itertools.chain.__doc__) == 190 — C-type docstring embedded in itertoolsmodule.c"]
    - [count,
       count.__doc__.__len__,
       [],
       205,
       "len(itertools.count.__doc__) == 205 — longest docstring of the core trio (chain/count/repeat)"]
    - [repeat,
       repeat.__doc__.__len__,
       [],
       154,
       "len(itertools.repeat.__doc__) == 154 — shortest docstring of the core trio"]
