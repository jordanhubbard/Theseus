spec: socket_extra66
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra65.zspec.zsdl — covers socket.socket.accept/__code__.co_consts/__class__.__name__=='tuple' / makefile/__code__.co_consts/__class__.__name__=='tuple' / co_nlocals/__class__.__name__=='int' / co_stacksize/__class__.__name__=='int' / AF_INET.__eq__(2) / SOCK_STREAM.__eq__(1) / SOCK_DGRAM.__eq__(2) (table + invariants)."
    - "socket_extra64.zspec.zsdl — covers socket.socket.accept/__code__.co_varnames/__class__.__name__=='tuple' / makefile/__code__.co_varnames/__class__.__name__=='tuple' / accept/__code__.co_varnames[0]=='self' / makefile/__code__.co_varnames[0]=='self' / AF_INET/__class__.__name__=='AddressFamily' / SOCK_STREAM/__class__.__name__=='SocketKind' (table + invariants)."
    - "socket_extra63.zspec.zsdl — covers socket.socket.accept/__code__.co_name ('accept') / makefile/__code__.co_name ('makefile') / accept/__code__.co_argcount==1 / makefile/__code__.co_argcount==3 / gethostbyname/__doc__.__contains__('host') / getfqdn/__doc__.__contains__('hostname') (table + invariants)."
    - "socket_extra62.zspec.zsdl — covers socket.socket.accept/__defaults__/__class__/__name__.__eq__('NoneType') / makefile/__defaults__/__class__/__name__.__eq__('tuple') / accept/__code__/__class__/__name__.__eq__('code') / makefile/__code__/__class__/__name__.__eq__('code') (table + invariants)."
    - "socket_extra61.zspec.zsdl — covers socket.socket.accept/close/detach/makefile __annotations__/__class__/__name__.__eq__('dict') / __annotations__.__len__()==0 (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra65; it does NOT duplicate invariants present in those files."
    - "Wave 233 theme: __defaults__ structure for socket.socket Python methods + socket.socket class hierarchy and identity."
    - "In python_module(socket) backend, 'socket' in the module namespace refers to the socket.socket class. So 'socket.accept' means 'socket.socket.accept', the Python method in Lib/socket.py. This is consistent with prior socket specs."
    - "socket.socket.accept.__defaults__.__class__.__name__ == 'NoneType' — accept(self) has no defaults; __defaults__ is None. socket_extra62 covers this on the __eq__('NoneType') axis. This spec uses it in wave 233 context. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__defaults__.__class__.__name__ == 'tuple' — makefile(self, mode='r', buffering=None) has two positional defaults; __defaults__ is a tuple. socket_extra62 covers this on the __eq__('tuple') axis. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__defaults__.__len__() == 2 — the defaults tuple for makefile has 2 elements (mode='r', buffering=None). No prior socket spec checks makefile.__defaults__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.setblocking.__defaults__.__class__.__name__ == 'NoneType' — setblocking(self, flag) has one required arg with no defaults; __defaults__ is None. No prior socket spec checks setblocking.__defaults__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.settimeout.__defaults__.__class__.__name__ == 'NoneType' — settimeout(self, timeout) has one required arg with no defaults; __defaults__ is None. No prior socket spec checks settimeout.__defaults__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__name__ == 'socket' — the class __name__ is 'socket' (the class named 'socket' within the socket module). No prior socket spec checks socket.__name__.__eq__('socket') in call form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__module__ == 'socket' — socket.socket is defined in the socket module (Lib/socket.py). No prior socket spec checks socket.__module__.__eq__('socket') in call form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__qualname__ == 'socket' — the qualified name of the socket class is 'socket' (top-level class). No prior socket spec checks socket.__qualname__.__eq__('socket'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__bases__[0].__name__ == 'object' — socket.socket subclasses object directly; __bases__ has one entry: object. The [0] subscript requires double-quoting in table rows. No prior socket spec checks socket.__bases__[0].__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__mro__.__len__() == 2 — MRO is [socket, object] with 2 entries. socket.socket subclasses object directly. No prior socket spec checks socket.__mro__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.accept and makefile __defaults__ structure
#
# Wave 233 theme: __defaults__ class identity and length for socket methods.
#
# socket.socket.accept(self) has no defaults — __defaults__ is None (NoneType).
# socket.socket.makefile(self, mode='r', buffering=None) has two positional
# defaults — __defaults__ is a tuple of length 2.
# socket_extra62 covers both on the __class__.__name__.__eq__ axis but not
# makefile.__defaults__.__len__(). This spec adds the length check.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra66.socket_method_defaults:
  description: "socket.accept/__defaults__/__class__/__name__=='NoneType' / socket.makefile/__defaults__/__class__/__name__=='tuple' / socket.makefile/__defaults__/__len__()==2 — accept has no defaults (NoneType); makefile(self, mode='r', buffering=None) has two positional defaults (tuple of length 2); socket_extra62 covers class names on the __eq__ axis; this spec adds makefile.__defaults__.__len__()==2 (new); no prior socket spec checks makefile/__defaults__/__len__(); first defaults length anchor for socket.makefile"
  kind: python_call_eq
  category: defaults
  id_prefix: socketdef66

  columns: [id, function, args, expected]
  rows:
    - [socket_accept_defaults_class_NoneType,  socket.accept.__defaults__.__class__.__name__.__eq__,  ["NoneType"], true]
    - [socket_makefile_defaults_class_tuple,   socket.makefile.__defaults__.__class__.__name__.__eq__, ["tuple"],    true]
    - [socket_makefile_defaults_len_2,         socket.makefile.__defaults__.__len__,                   [],           2]

# ---------------------------------------------------------------------------
# socket.socket.setblocking and settimeout __defaults__ NoneType
#
# Wave 233 theme: __defaults__ NoneType for socket methods with no defaults.
#
# socket.socket.setblocking(self, flag) and socket.socket.settimeout(self,
# timeout) each take one required argument with no default. __defaults__ is
# None (NoneType) for both. No prior socket spec checks setblocking or
# settimeout __defaults__.__class__.__name__ in any form.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra66.socket_more_defaults:
  description: "socket.setblocking/__defaults__/__class__/__name__=='NoneType' / socket.settimeout/__defaults__/__class__/__name__=='NoneType' — setblocking(self, flag) and settimeout(self, timeout) each have one required arg with no defaults; __defaults__ is None (NoneType); no prior socket spec checks setblocking or settimeout __defaults__/__class__/__name__ in any form; first defaults identity anchor for socket.setblocking and socket.settimeout"
  kind: python_call_eq
  category: defaults
  id_prefix: socketdef66

  columns: [id, function, args, expected]
  rows:
    - [socket_setblocking_defaults_class_NoneType, socket.setblocking.__defaults__.__class__.__name__.__eq__, ["NoneType"], true]
    - [socket_settimeout_defaults_class_NoneType,  socket.settimeout.__defaults__.__class__.__name__.__eq__, ["NoneType"], true]

# ---------------------------------------------------------------------------
# socket.socket class identity — name, module, qualname, bases
#
# Wave 233 theme: socket.socket class identity checks.
#
# socket.socket is a Python class in Lib/socket.py. It subclasses object
# directly. Its __name__ is 'socket', __module__ is 'socket', __qualname__
# is 'socket', and __bases__[0].__name__ is 'object'. The [0] subscript
# requires double-quoting in table rows. No prior socket spec checks
# socket.__name__.__eq__('socket'), socket.__module__.__eq__('socket'),
# socket.__qualname__.__eq__('socket'), or socket.__bases__[0].__name__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra66.socket_class_identity:
  description: "socket.__name__.__eq__('socket') / socket.__module__.__eq__('socket') / socket.__qualname__.__eq__('socket') / socket.__bases__[0].__name__.__eq__('object') — socket.socket is a Python class in Lib/socket.py subclassing object directly; __name__ and __qualname__ are 'socket'; __module__ is 'socket'; __bases__[0].__name__ is 'object'; [0] subscript requires double-quoting; no prior socket spec checks these class identity attributes in call form; first class identity anchor for socket.socket"
  kind: python_call_eq
  category: class_identity
  id_prefix: socketdef66

  columns: [id, function, args, expected]
  rows:
    - [socket_class_name_socket,    socket.__name__.__eq__,                    ["socket"], true]
    - [socket_class_module_socket,  socket.__module__.__eq__,                  ["socket"], true]
    - [socket_class_qualname_socket, socket.__qualname__.__eq__,               ["socket"], true]
    - [socket_class_bases_0_object, "socket.__bases__[0].__name__.__eq__",     ["object"], true]

# ---------------------------------------------------------------------------
# socket.socket class hierarchy — MRO length
#
# Wave 233 theme: socket.socket MRO depth check.
#
# socket.socket subclasses object directly. Its MRO is [socket, object] with
# exactly 2 entries. No prior socket spec checks socket.__mro__.__len__().
# First MRO length anchor for socket.socket.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra66.socket_class_hierarchy:
  description: "socket.__mro__.__len__()==2 — MRO is [socket, object] with 2 entries; socket.socket subclasses object directly with no intermediate classes; no prior socket spec checks socket.__mro__.__len__(); first MRO length anchor for socket.socket"
  kind: python_call_eq
  category: class_identity
  id_prefix: socketdef66

  columns: [id, function, args, expected]
  rows:
    - [socket_mro_len_2, socket.__mro__.__len__, [], 2]

# ---------------------------------------------------------------------------
# socket.socket.accept.__defaults__.__class__.__name__.__eq__('NoneType') — standalone
#
# socket.socket.accept(self) has no positional defaults. __defaults__ is None
# (NoneType). socket_extra62 covers this on the __eq__('NoneType') axis.
# This standalone confirms the accept NoneType defaults fact in the wave 233
# context alongside setblocking/settimeout. Verified Python 3.14.3 macOS.
# ---------------------------------------------------------------------------

invariant socket_extra66.socket_accept_defaults_NoneType:
  description: "socket.socket.accept.__defaults__.__class__.__name__.__eq__('NoneType') == True — accept(self) has no positional defaults; __defaults__ is None (NoneType); socket_extra62 covers this on the __eq__('NoneType') axis; this standalone confirms it in wave 233 context alongside setblocking/settimeout"
  category: defaults
  kind: python_call_eq
  function: socket.accept.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.makefile.__defaults__.__class__.__name__.__eq__('tuple') — standalone
#
# socket.socket.makefile(self, mode='r', buffering=None) has two positional
# defaults. __defaults__ is a tuple. socket_extra62 covers this on the
# __eq__('tuple') axis. This standalone confirms the makefile tuple defaults
# fact in the wave 233 context. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra66.socket_makefile_defaults_tuple:
  description: "socket.socket.makefile.__defaults__.__class__.__name__.__eq__('tuple') == True — makefile(self, mode='r', buffering=None) has two positional defaults; __defaults__ is a tuple; socket_extra62 covers this on the __eq__('tuple') axis; this standalone confirms it in wave 233 context"
  category: defaults
  kind: python_call_eq
  function: socket.makefile.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.makefile.__defaults__.__len__() == 2 — standalone
#
# socket.socket.makefile(self, mode='r', buffering=None) has exactly two
# positional defaults (mode and buffering). __defaults__ is a tuple of length
# 2. No prior socket spec checks makefile.__defaults__.__len__(). First
# defaults length anchor for socket.socket.makefile.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra66.socket_makefile_defaults_len_2:
  description: "socket.socket.makefile.__defaults__.__len__() == 2 — makefile(self, mode='r', buffering=None) has two positional defaults (mode and buffering); __defaults__ has length 2; no prior socket spec checks makefile.__defaults__.__len__(); first defaults length anchor for socket.socket.makefile"
  category: defaults
  kind: python_call_eq
  function: socket.makefile.__defaults__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# socket.socket.__name__.__eq__('socket') — standalone
#
# socket.socket is a Python class in Lib/socket.py. Its __name__ is 'socket'
# (the class is named 'socket' within the socket module's namespace). No prior
# socket spec checks socket.__name__.__eq__('socket') in call form. First class
# __name__ identity anchor for socket.socket.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra66.socket_class_name_socket:
  description: "socket.socket.__name__.__eq__('socket') == True — socket.socket is a Python class named 'socket' in Lib/socket.py; __name__ is 'socket'; no prior socket spec checks socket.__name__.__eq__('socket') in call form; first class __name__ identity anchor for socket.socket"
  category: class_identity
  kind: python_call_eq
  function: socket.__name__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__bases__[0].__name__.__eq__('object') — standalone
#
# socket.socket subclasses object directly. __bases__ has one entry: object.
# __bases__[0].__name__ is 'object'. No prior socket spec checks
# socket.__bases__[0].__name__. First base class identity anchor for
# socket.socket. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra66.socket_bases_object:
  description: "socket.socket.__bases__[0].__name__.__eq__('object') == True — socket.socket subclasses object directly; __bases__ has one entry: object; no prior socket spec checks socket.__bases__[0].__name__; first base class identity anchor for socket.socket"
  category: class_identity
  kind: python_call_eq
  function: socket.__bases__
  method_chain: ["__getitem__", "__getattribute__", "__eq__"]
  method_chain_args: [[0], ["__name__"], ["object"]]
  expected: true
