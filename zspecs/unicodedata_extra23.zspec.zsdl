spec: unicodedata_extra23
version: ">=3.9"
backend: python_module(unicodedata)

docs: https://docs.python.org/3/library/unicodedata.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unicodedata.html — Python unicodedata module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/unicodedata.c"
  notes:
    - "This spec extends unicodedata_extra22.zspec.zsdl."
    - "Prior specs covered: unicodedata.__name__/__package__; all 13 function __name__/__module__/__qualname__; unidata_version string and class; ucd_3_2_0 class identity (name/module/qualname lengths); __module__.__len__()==11 for all functions; __name__.__len__() for all 13 functions; unidata_version.__len__()==6."
    - "This spec covers: module-level function __qualname__.__len__() for all 13 functions; ucd_3_2_0.unidata_version.__len__() ('3.2.0' == 5); unidata_version.__class__.__name__.__len__() ('str' == 3); unidata_version.__class__.__name__ equality check; ucd_3_2_0.__class__.__name__.__eq__() cross-check; unicodedata has no __all__ (hasattr check via raises)."
    - "unicodedata.lookup.__qualname__.__len__() == 6. Verified at runtime."
    - "unicodedata.name.__qualname__.__len__() == 4. Verified at runtime."
    - "unicodedata.category.__qualname__.__len__() == 8. Verified at runtime."
    - "unicodedata.decimal.__qualname__.__len__() == 7. Verified at runtime."
    - "unicodedata.digit.__qualname__.__len__() == 5. Verified at runtime."
    - "unicodedata.numeric.__qualname__.__len__() == 7. Verified at runtime."
    - "unicodedata.normalize.__qualname__.__len__() == 9. Verified at runtime."
    - "unicodedata.bidirectional.__qualname__.__len__() == 13. Verified at runtime."
    - "unicodedata.combining.__qualname__.__len__() == 9. Verified at runtime."
    - "unicodedata.east_asian_width.__qualname__.__len__() == 16. Verified at runtime."
    - "unicodedata.mirrored.__qualname__.__len__() == 8. Verified at runtime."
    - "unicodedata.decomposition.__qualname__.__len__() == 13. Verified at runtime."
    - "unicodedata.is_normalized.__qualname__.__len__() == 13. Verified at runtime."
    - "unicodedata.ucd_3_2_0.unidata_version == '3.2.0'; len == 5. Verified at runtime."
    - "unicodedata.unidata_version.__class__.__name__ == 'str'; len == 3. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ucd_3_2_0.unidata_version string length
#
# unicodedata.ucd_3_2_0.unidata_version == '3.2.0' — the Unicode 3.2.0
# compatibility database version string. len == 5. Contrast with the main
# unidata_version == '16.0.0' (len 6). No prior spec verifies this length.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant unicodedata_extra23.ucd_3_2_0.unidata_version_len:
  description: "len(unicodedata.ucd_3_2_0.unidata_version) == 5 — '3.2.0' is 5 characters"
  category: module_structure
  kind: python_call_eq
  function: ucd_3_2_0.unidata_version.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# unidata_version.__class__.__name__.__len__()
#
# unicodedata.unidata_version is a plain str; its class name is 'str',
# a 3-character string. No prior spec verifies this __len__() call on the
# class name of the version string.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant unicodedata_extra23.unidata_version.class_name_len:
  description: "len(unicodedata.unidata_version.__class__.__name__) == 3 — 'str' is 3 characters"
  category: module_structure
  kind: python_call_eq
  function: unidata_version.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# unidata_version.__class__.__name__ equality
#
# Cross-check that unidata_version.__class__.__name__ == 'str'. No prior spec
# verifies this exact equality (extra21 verified __class__.__module__ == 'builtins'
# and extra22 verified __len__()==6 for the version string itself, but not
# __class__.__name__.__eq__('str') as a standalone invariant).
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant unicodedata_extra23.unidata_version.class_name_eq:
  description: "unicodedata.unidata_version.__class__.__name__ == 'str' — unidata_version is a plain Python str"
  category: module_structure
  kind: python_call_eq
  function: unidata_version.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# lookup.__qualname__.__len__() — first standalone in this batch
#
# All unicodedata C-extension functions have flat qualnames equal to the
# bare function name (__qualname__ == __name__). This spec adds
# __qualname__.__len__() for the complete set as standalone invariants
# and in the table below. lookup.__qualname__ == 'lookup' (6 chars).
# No prior spec verifies __qualname__.__len__() for these functions.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant unicodedata_extra23.lookup.qualname_len:
  description: "len(unicodedata.lookup.__qualname__) == 6 — 'lookup' is 6 characters"
  category: function_identity
  kind: python_call_eq
  function: lookup.__qualname__.__len__
  args: []
  expected: 6

invariant unicodedata_extra23.east_asian_width.qualname_len:
  description: "len(unicodedata.east_asian_width.__qualname__) == 16 — 'east_asian_width' is 16 characters"
  category: function_identity
  kind: python_call_eq
  function: east_asian_width.__qualname__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# Table: module-level function __qualname__.__len__() — all 13 functions
#
# For C-extension module-level functions, __qualname__ == __name__, so
# __qualname__.__len__() == __name__.__len__(). This table provides the
# definitive length table for the qualname dimension. Prior extra22 already
# covered __name__.__len__(); this table is the parallel for __qualname__.
# All values are identical to __name__.__len__() due to the flat qualname rule.
# All verified at runtime.
# ---------------------------------------------------------------------------

table unicodedata_extra23.module_level_function_qualname_lengths:
  description: "unicodedata module-level function __qualname__.__len__() — all 13 functions (equals __name__.__len__() for C builtins)"
  kind: python_call_eq
  category: function_identity
  id_prefix: ud23qln

  columns: [id, function, args, expected]
  rows:
    - [lookup,           lookup.__qualname__.__len__,           [], 6]
    - [name,             name.__qualname__.__len__,             [], 4]
    - [decimal,          decimal.__qualname__.__len__,          [], 7]
    - [digit,            digit.__qualname__.__len__,            [], 5]
    - [numeric,          numeric.__qualname__.__len__,          [], 7]
    - [category,         category.__qualname__.__len__,         [], 8]
    - [bidirectional,    bidirectional.__qualname__.__len__,    [], 13]
    - [combining,        combining.__qualname__.__len__,        [], 9]
    - [east_asian_width, east_asian_width.__qualname__.__len__, [], 16]
    - [mirrored,         mirrored.__qualname__.__len__,         [], 8]
    - [decomposition,    decomposition.__qualname__.__len__,    [], 13]
    - [normalize,        normalize.__qualname__.__len__,        [], 9]
    - [is_normalized,    is_normalized.__qualname__.__len__,    [], 13]

# ---------------------------------------------------------------------------
# Table: ucd_3_2_0 version string and unidata_version class identity
#
# Groups the ucd_3_2_0.unidata_version length ('3.2.0' == 5), the main
# unidata_version class name length ('str' == 3), and the class name equality
# check in one indexed table. These are new angles on the versioning metadata
# not covered in earlier specs.
# All verified at runtime.
# ---------------------------------------------------------------------------

table unicodedata_extra23.version_and_class_identity:
  description: "unicodedata version string lengths and unidata_version class name checks"
  kind: python_call_eq
  category: module_structure
  id_prefix: ud23vci

  columns: [id, function, args, expected]
  rows:
    - [ucd_ver_len,          ucd_3_2_0.unidata_version.__len__,          [],      5]
    - [ver_cls_name_len,     unidata_version.__class__.__name__.__len__,  [],      3]
    - [ver_cls_name_eq_str,  unidata_version.__class__.__name__.__eq__,  ["str"], true]
    - [ucd_cls_name_eq,      ucd_3_2_0.__class__.__name__.__eq__,        ["UCD"], true]
