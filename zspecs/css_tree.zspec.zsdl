spec: css_tree
version: ">=2.0.0"
backend: node(css-tree)

docs: https://github.com/csstree/csstree#readme

provenance:
  derived_from:
    - "css-tree README — https://github.com/csstree/csstree#readme"
    - "CSS Syntax Module Level 3 — https://drafts.csswg.org/css-syntax/"
    - "Test vectors verified with css-tree via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "css-tree source"
  notes:
    - "Spec-compliant CSS parser, walker, and AST → string generator."
    - "Install: npm install css-tree"
    - "v3 ESM only; named exports parse / walk / generate / lexer."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "parse() throws SyntaxError on malformed input (or returns error nodes depending on options)."
  stderr: "null"
  stickiness: "N/A — each parse independent."
  codes: {}

invariant css_tree.parse_returns_StyleSheet:
  description: "parse() returns a StyleSheet AST node"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: [".foo { color: red; }"]
  chain:
    - {get: type}
  expected: "StyleSheet"

invariant css_tree.has_parse_function:
  description: "parse is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "parse.constructor.name"}
  expected: "Function"

invariant css_tree.has_walk_function:
  description: "walk is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "walk.constructor.name"}
  expected: "Function"

invariant css_tree.has_generate_function:
  description: "generate is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "generate.constructor.name"}
  expected: "Function"

invariant css_tree.parse_simple_rule_no_error:
  description: "parse() of a basic rule does not produce an error AST"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: [".foo { color: red; }"]
  chain:
    - {get: "children.first.type"}
  expected: "Rule"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: infeasible
  model: claude-cli
  attempted_at: 2026-05-04T15:53:26Z
  iterations: 1
  pass_count: 0
  fail_count: 0
  total_invariants: 5
  notes: "LLM unavailable: claude CLI failed (exit 1): "
  infeasible_reason: llm_unavailable
  invariant_annotations: {}
