spec: functools_extra74
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra73.zspec.zsdl."
    - "Wave 235 theme: WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES constants and reduce/cmp_to_key C builtin identity."
    - "WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple' — WRAPPER_ASSIGNMENTS is a module-level tuple constant in functools. Verified with Python 3.14.3."
    - "WRAPPER_ASSIGNMENTS.__len__() == 5 — contains '__module__', '__name__', '__qualname__', '__annotations__', '__doc__'. Verified with Python 3.14.3."
    - "WRAPPER_ASSIGNMENTS.__contains__('__name__') == True — '__name__' is one of the five standard wrapper assignment attributes. Verified with Python 3.14.3."
    - "WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True — '__doc__' is one of the five standard wrapper assignment attributes. Verified with Python 3.14.3."
    - "WRAPPER_ASSIGNMENTS.__contains__('__module__') == True — '__module__' is one of the five standard wrapper assignment attributes. Verified with Python 3.14.3."
    - "WRAPPER_UPDATES.__class__.__name__ == 'tuple' — WRAPPER_UPDATES is a module-level tuple constant in functools. Verified with Python 3.14.3."
    - "WRAPPER_UPDATES.__len__() == 1 — contains only '__dict__'. Verified with Python 3.14.3."
    - "WRAPPER_UPDATES.__contains__('__dict__') == True — '__dict__' is the sole wrapper update attribute. Verified with Python 3.14.3."
    - "reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is implemented in C (_functoolsmodule.c) and exposed as a builtin. Verified with Python 3.14.3."
    - "reduce.__module__ == '_functools' — reduce comes from the C extension module _functools, not Lib/functools.py. Verified with Python 3.14.3."
    - "reduce.__qualname__ == 'reduce' — C builtins use a simple flat qualname equal to their name. Verified with Python 3.14.3."
    - "cmp_to_key.__class__.__name__ == 'builtin_function_or_method' — cmp_to_key is implemented in C (_functoolsmodule.c). Verified with Python 3.14.3."
    - "cmp_to_key.__module__ == '_functools' — cmp_to_key comes from the C extension module _functools. Verified with Python 3.14.3."
    - "No prior functools spec checks WRAPPER_ASSIGNMENTS or WRAPPER_UPDATES constants, or checks reduce/cmp_to_key __module__ as '_functools'. All checks in this spec are new to extra74."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# WRAPPER_ASSIGNMENTS content — extra74
#
# Wave 235 theme: WRAPPER_ASSIGNMENTS is a tuple of 5 strings listing the
# function attributes that update_wrapper/wraps copy from the wrapped function
# to the wrapper function.
#
# Contents: ('__module__', '__name__', '__qualname__', '__annotations__', '__doc__')
#
# WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'   (it is a tuple)
# WRAPPER_ASSIGNMENTS.__len__()          == 5          (five elements)
# WRAPPER_ASSIGNMENTS.__contains__('__name__')  == True
# WRAPPER_ASSIGNMENTS.__contains__('__doc__')   == True
#
# No prior functools spec checks WRAPPER_ASSIGNMENTS in any form. New to extra74.
# ---------------------------------------------------------------------------

table functools_extra74.WRAPPER_ASSIGNMENTS_content:
  description: "WRAPPER_ASSIGNMENTS is a 5-element tuple; __class__.__name__=='tuple', __len__()==5, contains '__name__' and '__doc__'; wave 235 WRAPPER_ASSIGNMENTS checks; new to extra74"
  kind: python_call_eq
  category: constant_identity
  id_prefix: functoolsconst74

  columns: [id, function, args, expected, description]
  rows:
    - [WRAPPER_ASSIGNMENTS_class_name_eq_tuple,
       WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('tuple') == True — WRAPPER_ASSIGNMENTS is a module-level constant defined in Lib/functools.py as a tuple of strings listing the function attributes that update_wrapper copies from the wrapped to the wrapper function; its __class__ is the built-in tuple type; tuple.__name__ == 'tuple' (5 chars); __eq__ returns True; no prior functools spec checks WRAPPER_ASSIGNMENTS.__class__.__name__; new to extra74"]
    - [WRAPPER_ASSIGNMENTS_len_eq_5,
       WRAPPER_ASSIGNMENTS.__len__,
       [],
       5,
       "functools.WRAPPER_ASSIGNMENTS.__len__() == 5 — WRAPPER_ASSIGNMENTS contains exactly five string elements: '__module__', '__name__', '__qualname__', '__annotations__', '__doc__'; these are the five standard function attributes copied by update_wrapper from the wrapped function to the wrapper function; tuple.__len__() returns 5; no prior functools spec checks WRAPPER_ASSIGNMENTS.__len__(); new to extra74"]
    - [WRAPPER_ASSIGNMENTS_contains_name,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__name__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True — '__name__' is one of the five elements of the WRAPPER_ASSIGNMENTS tuple; update_wrapper uses this to copy the function name from the wrapped function to the wrapper; tuple.__contains__('__name__') returns True; no prior functools spec checks WRAPPER_ASSIGNMENTS.__contains__ for any element; new to extra74"]
    - [WRAPPER_ASSIGNMENTS_contains_doc,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__doc__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True — '__doc__' is one of the five elements of the WRAPPER_ASSIGNMENTS tuple; update_wrapper copies the docstring from the wrapped function to the wrapper so that help() displays the correct documentation; tuple.__contains__('__doc__') returns True; no prior functools spec checks WRAPPER_ASSIGNMENTS.__contains__('__doc__'); new to extra74"]

# ---------------------------------------------------------------------------
# WRAPPER_UPDATES content — extra74
#
# Wave 235 theme: WRAPPER_UPDATES is a tuple of 1 string listing the
# function attributes that update_wrapper updates (merges) on the wrapper.
#
# Contents: ('__dict__',)
#
# WRAPPER_UPDATES.__class__.__name__ == 'tuple'   (it is a tuple)
# WRAPPER_UPDATES.__len__()          == 1          (one element)
# WRAPPER_UPDATES.__contains__('__dict__') == True
#
# No prior functools spec checks WRAPPER_UPDATES. New to extra74.
# ---------------------------------------------------------------------------

table functools_extra74.WRAPPER_UPDATES_content:
  description: "WRAPPER_UPDATES is a 1-element tuple; __class__.__name__=='tuple', __len__()==1, contains '__dict__'; wave 235 WRAPPER_UPDATES checks; new to extra74"
  kind: python_call_eq
  category: constant_identity
  id_prefix: functoolsconst74

  columns: [id, function, args, expected, description]
  rows:
    - [WRAPPER_UPDATES_class_name_eq_tuple,
       WRAPPER_UPDATES.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.WRAPPER_UPDATES.__class__.__name__.__eq__('tuple') == True — WRAPPER_UPDATES is a module-level constant defined in Lib/functools.py as a tuple listing the function attributes that update_wrapper updates (merges via .update()) on the wrapper function; its __class__ is the built-in tuple type; tuple.__name__ == 'tuple' (5 chars); __eq__ returns True; no prior functools spec checks WRAPPER_UPDATES.__class__.__name__; new to extra74"]
    - [WRAPPER_UPDATES_len_eq_1,
       WRAPPER_UPDATES.__len__,
       [],
       1,
       "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES contains exactly one string element: '__dict__'; update_wrapper calls wrapper.__dict__.update(wrapped.__dict__) to merge the wrapped function's attribute dictionary into the wrapper's; tuple.__len__() returns 1; no prior functools spec checks WRAPPER_UPDATES.__len__(); new to extra74"]
    - [WRAPPER_UPDATES_contains_dict,
       WRAPPER_UPDATES.__contains__,
       ["__dict__"],
       true,
       "functools.WRAPPER_UPDATES.__contains__('__dict__') == True — '__dict__' is the sole element of the WRAPPER_UPDATES tuple; update_wrapper uses this to merge the wrapped function's attribute dictionary into the wrapper function's attribute dictionary; tuple.__contains__('__dict__') returns True; no prior functools spec checks WRAPPER_UPDATES.__contains__ for any element; new to extra74"]

# ---------------------------------------------------------------------------
# reduce identity — extra74
#
# Wave 235 theme: reduce is a C builtin in the _functools extension module.
#
# functools.reduce is implemented in Modules/_functoolsmodule.c and imported
# into the functools namespace. It is a builtin_function_or_method, not a
# Python function, so it has no __code__ or __defaults__ attributes but does
# have __module__ pointing to the internal '_functools' C module.
#
# reduce.__class__.__name__ == 'builtin_function_or_method'
# reduce.__module__         == '_functools'
# reduce.__qualname__       == 'reduce'
#
# No prior functools spec checks reduce.__module__ == '_functools'. New to extra74.
# ---------------------------------------------------------------------------

table functools_extra74.reduce_identity:
  description: "reduce is a C builtin from _functools; __class__.__name__=='builtin_function_or_method', __module__=='_functools', __qualname__=='reduce'; wave 235 reduce identity; new to extra74"
  kind: python_call_eq
  category: builtin_identity
  id_prefix: functoolsconst74

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_class_name_eq_builtin_function_or_method,
       reduce.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — reduce is implemented in C in Modules/_functoolsmodule.c and exposed as a builtin function in the functools namespace; C builtin functions and methods have a __class__ of builtin_function_or_method (the same type as len, print, etc.); builtin_function_or_method.__name__ == 'builtin_function_or_method' (26 chars); __eq__ returns True; no prior functools spec checks reduce.__class__.__name__; new to extra74"]
    - [reduce_module_eq_functools_internal,
       reduce.__module__.__eq__,
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — reduce is implemented in C in Modules/_functoolsmodule.c which exports itself under the module name '_functools' (with a leading underscore indicating a private C implementation module); when functools.py imports reduce it comes from _functools, so reduce.__module__ is '_functools' (10 chars) not 'functools'; __eq__ returns True; no prior functools spec checks reduce.__module__ == '_functools'; new to extra74"]
    - [reduce_qualname_eq_reduce,
       reduce.__qualname__.__eq__,
       ["reduce"],
       true,
       "functools.reduce.__qualname__.__eq__('reduce') == True — reduce is a C builtin function at module level in _functools; C builtins that are not nested within a type have __qualname__ equal to their simple name; __qualname__ == 'reduce' (6 chars); __eq__ returns True; no prior functools spec checks reduce.__qualname__; new to extra74"]

# ---------------------------------------------------------------------------
# cmp_to_key identity — extra74
#
# Wave 235 theme: cmp_to_key is also a C builtin in the _functools module.
#
# functools.cmp_to_key is implemented in Modules/_functoolsmodule.c. Like
# reduce, it is a builtin_function_or_method with __module__ == '_functools'.
#
# cmp_to_key.__class__.__name__ == 'builtin_function_or_method'
# cmp_to_key.__module__         == '_functools'
#
# No prior functools spec checks cmp_to_key.__module__. New to extra74.
# ---------------------------------------------------------------------------

table functools_extra74.cmp_to_key_identity:
  description: "cmp_to_key is a C builtin from _functools; __class__.__name__=='builtin_function_or_method', __module__=='_functools'; wave 235 cmp_to_key identity; new to extra74"
  kind: python_call_eq
  category: builtin_identity
  id_prefix: functoolsconst74

  columns: [id, function, args, expected, description]
  rows:
    - [cmp_to_key_class_name_eq_builtin_function_or_method,
       cmp_to_key.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "functools.cmp_to_key.__class__.__name__.__eq__('builtin_function_or_method') == True — cmp_to_key is implemented in C in Modules/_functoolsmodule.c; it converts an old-style comparison function (cmp) into a key function suitable for use with sorted() and min()/max(); C builtins have __class__ == builtin_function_or_method; builtin_function_or_method.__name__ == 'builtin_function_or_method' (26 chars); __eq__ returns True; no prior functools spec checks cmp_to_key.__class__.__name__; new to extra74"]
    - [cmp_to_key_module_eq_functools_internal,
       cmp_to_key.__module__.__eq__,
       ["_functools"],
       true,
       "functools.cmp_to_key.__module__.__eq__('_functools') == True — cmp_to_key is implemented in C in Modules/_functoolsmodule.c which registers itself as the '_functools' module; functools.py imports cmp_to_key from _functools, so cmp_to_key.__module__ is '_functools' (10 chars, with leading underscore) not 'functools'; __eq__ returns True; no prior functools spec checks cmp_to_key.__module__ == '_functools'; new to extra74"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra74
# ---------------------------------------------------------------------------

invariant functools_extra74.WRAPPER_ASSIGNMENTS_tuple:
  description: "functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('tuple') == True — WRAPPER_ASSIGNMENTS is a module-level tuple constant; wave 235 constant identity; new to extra74"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra74.WRAPPER_ASSIGNMENTS_len_5:
  description: "functools.WRAPPER_ASSIGNMENTS.__len__() == 5 — contains five wrapper assignment attribute names; wave 235 constant length; new to extra74"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 5

invariant functools_extra74.WRAPPER_UPDATES_tuple:
  description: "functools.WRAPPER_UPDATES.__class__.__name__.__eq__('tuple') == True — WRAPPER_UPDATES is a module-level tuple constant; wave 235 constant identity; new to extra74"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra74.WRAPPER_UPDATES_len_1:
  description: "functools.WRAPPER_UPDATES.__len__() == 1 — contains only '__dict__'; wave 235 constant length; new to extra74"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1

invariant functools_extra74.reduce_class_builtin:
  description: "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — reduce is a C builtin from _functools; wave 235 reduce identity; new to extra74"
  kind: python_call_eq
  function: reduce.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
