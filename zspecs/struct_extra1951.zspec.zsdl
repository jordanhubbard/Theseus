spec: struct_extra1951
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/struct.html"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "Wave 577 (_extra1951): __contains__, __iter__, __next__, __aiter__, __anext__ dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.Struct is a C-extension type; its __dict__ contains no __contains__, __iter__, __next__, __aiter__, or __anext__."
    - "struct.error is an exception subclass (inherits from Exception); it does not define any iteration dunders in its own __dict__."
    - "struct.Struct objects are not iterable — they expose pack/unpack methods, not iteration."
    - "No async iteration support exists in any struct module class."
  created_at: "2026-04-12"
error_model: python_exceptions

table struct_extra1951.contains_protocol:
  description: "struct types __contains__ dict-presence — none define __contains__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1951

  columns: [id, function, args, expected]
  rows:
    - ["st1951001", "struct.Struct.__dict__.__contains__", ["__contains__"], false]
    - ["st1951002", "struct.error.__dict__.__contains__",  ["__contains__"], false]

table struct_extra1951.iter_protocol:
