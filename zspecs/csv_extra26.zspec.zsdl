spec: csv_extra26
version: ">=3.9"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html — Python csv module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
    - "CPython source: Lib/csv.py"
    - "csv_extra25.zspec.zsdl — covers __module__.__len__() for DictReader/DictWriter/Dialect/Error/reader/writer/register_dialect/field_size_limit; __name__.__len__() for DictReader/DictWriter/Dialect/Error"
  notes:
    - "This spec extends csv_extra25.zspec.zsdl."
    - "Prior specs covered: reader/writer/DictReader/DictWriter/Dialect/Error __name__/__module__/__qualname__, DictReader/DictWriter __init__.__name__, register_dialect/field_size_limit __module__.__len__(), various __module__.__len__() and __name__.__len__()."
    - "This spec covers: __qualname__.__len__() for Dialect, DictReader, DictWriter, excel, excel_tab, unix_dialect; __module__.__len__() for excel, excel_tab, unix_dialect; __qualname__.__len__() for DictReader.__init__, DictWriter.writerow, DictWriter.writerows, DictWriter.writeheader, DictReader.__next__."
    - "csv.Dialect.__qualname__ == 'Dialect' (len 7) — verified Python 3.12."
    - "csv.DictReader.__qualname__ == 'DictReader' (len 10) — verified Python 3.12."
    - "csv.DictWriter.__qualname__ == 'DictWriter' (len 10) — verified Python 3.12."
    - "csv.excel.__qualname__ == 'excel' (len 5) — verified Python 3.12."
    - "csv.excel_tab.__qualname__ == 'excel_tab' (len 9) — verified Python 3.12."
    - "csv.unix_dialect.__qualname__ == 'unix_dialect' (len 12) — verified Python 3.12."
    - "csv.excel.__module__ == 'csv' (len 3) — verified Python 3.12."
    - "csv.excel_tab.__module__ == 'csv' (len 3) — verified Python 3.12."
    - "csv.unix_dialect.__module__ == 'csv' (len 3) — verified Python 3.12."
    - "csv.DictReader.__init__.__qualname__ == 'DictReader.__init__' (len 19) — verified Python 3.12."
    - "csv.DictWriter.writerow.__qualname__ == 'DictWriter.writerow' (len 19) — verified Python 3.12."
    - "csv.DictWriter.writerows.__qualname__ == 'DictWriter.writerows' (len 20) — verified Python 3.12."
    - "csv.DictWriter.writeheader.__qualname__ == 'DictWriter.writeheader' (len 22) — verified Python 3.12."
    - "csv.DictReader.__next__.__qualname__ == 'DictReader.__next__' (len 19) — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() for Dialect subclasses and the base class itself:
# Dialect, excel, excel_tab, unix_dialect, DictReader, DictWriter
#
# All are pure-Python classes defined in csv.py.  Their __qualname__ equals
# their simple name (no nesting), so lengths mirror __name__ lengths:
#   Dialect      -> 'Dialect'      -> 7
#   excel        -> 'excel'        -> 5
#   excel_tab    -> 'excel_tab'    -> 9
#   unix_dialect -> 'unix_dialect' -> 12
#   DictReader   -> 'DictReader'   -> 10
#   DictWriter   -> 'DictWriter'   -> 10
# No prior csv spec checks __qualname__.__len__() for any of these classes.
# ---------------------------------------------------------------------------

table csv_extra26.class_qualname_lengths:
  description: "__qualname__.__len__() for Dialect, excel, excel_tab, unix_dialect, DictReader, DictWriter"
  kind: python_call_eq
  category: class_identity
  id_prefix: cql26

  columns: [id, function, args, expected]
  rows:
    - [Dialect,      Dialect.__qualname__.__len__,      [], 7]
    - [excel,        excel.__qualname__.__len__,        [], 5]
    - [excel_tab,    excel_tab.__qualname__.__len__,    [], 9]
    - [unix_dialect, unix_dialect.__qualname__.__len__, [], 12]
    - [DictReader,   DictReader.__qualname__.__len__,   [], 10]
    - [DictWriter,   DictWriter.__qualname__.__len__,   [], 10]

# ---------------------------------------------------------------------------
# __module__.__len__() for dialect subclasses: excel, excel_tab, unix_dialect
#
# All three concrete Dialect subclasses are pure-Python and defined in csv.py.
# Their __module__ is 'csv' (3 characters). No prior csv spec checks the
# __module__.__len__() for these dialect subclasses specifically.
# ---------------------------------------------------------------------------

table csv_extra26.dialect_module_lengths:
  description: "__module__.__len__() for excel, excel_tab, unix_dialect — all 3 (module name 'csv')"
  kind: python_call_eq
  category: class_identity
  id_prefix: dml26

  columns: [id, function, args, expected]
  rows:
    - [excel,        excel.__module__.__len__,        [], 3]
    - [excel_tab,    excel_tab.__module__.__len__,    [], 3]
    - [unix_dialect, unix_dialect.__module__.__len__, [], 3]

# ---------------------------------------------------------------------------
# __qualname__.__len__() for DictReader and DictWriter method qualnames
#
# Method qualnames follow the pattern 'ClassName.methodname', giving:
#   DictReader.__init__    -> 'DictReader.__init__'    -> 19
#   DictReader.__next__    -> 'DictReader.__next__'    -> 19
#   DictWriter.writerow    -> 'DictWriter.writerow'    -> 19
#   DictWriter.writerows   -> 'DictWriter.writerows'   -> 20
#   DictWriter.writeheader -> 'DictWriter.writeheader' -> 22
# No prior csv spec checks __qualname__.__len__() for any of these methods.
# ---------------------------------------------------------------------------

invariant csv_extra26.DictReader.__init__.qualname_len:
  description: "csv.DictReader.__init__.__qualname__.__len__() == 19 — 'DictReader.__init__' has 19 characters"
  category: method_identity
  kind: python_call_eq
  function: DictReader.__init__.__qualname__.__len__
  args: []
  expected: 19

invariant csv_extra26.DictReader.__next__.qualname_len:
  description: "csv.DictReader.__next__.__qualname__.__len__() == 19 — 'DictReader.__next__' has 19 characters"
  category: method_identity
  kind: python_call_eq
  function: DictReader.__next__.__qualname__.__len__
  args: []
  expected: 19

invariant csv_extra26.DictWriter.writerow.qualname_len:
  description: "csv.DictWriter.writerow.__qualname__.__len__() == 19 — 'DictWriter.writerow' has 19 characters"
  category: method_identity
  kind: python_call_eq
  function: DictWriter.writerow.__qualname__.__len__
  args: []
  expected: 19

invariant csv_extra26.DictWriter.writerows.qualname_len:
  description: "csv.DictWriter.writerows.__qualname__.__len__() == 20 — 'DictWriter.writerows' has 20 characters"
  category: method_identity
  kind: python_call_eq
  function: DictWriter.writerows.__qualname__.__len__
  args: []
  expected: 20

invariant csv_extra26.DictWriter.writeheader.qualname_len:
  description: "csv.DictWriter.writeheader.__qualname__.__len__() == 22 — 'DictWriter.writeheader' has 22 characters"
  category: method_identity
  kind: python_call_eq
  function: DictWriter.writeheader.__qualname__.__len__
  args: []
  expected: 22
