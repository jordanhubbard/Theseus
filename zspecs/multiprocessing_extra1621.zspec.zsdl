    - ["mp1621pw025", "multiprocessing.synchronize.Lock.__dict__.__contains__",             ["__weakref__"], false]
    - ["mp1621pw026", "multiprocessing.synchronize.RLock.__dict__.__contains__",            ["__weakref__"], false]
