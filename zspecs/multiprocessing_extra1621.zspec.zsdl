    - ["mp1621pw035", "multiprocessing.sharedctypes.Array.__dict__.__contains__",           ["__weakref__"], false]

table multiprocessing_extra1621.exceptions_weakref:
  description: "multiprocessing exception hierarchy: ProcessError is the base class and owns __weakref__; all concrete exception subclasses inherit from ProcessError and do not re-define __weakref__ in their own class dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1621ew

  columns: [id, function, args, expected]
  rows:
    - ["mp1621ew001", "multiprocessing.ProcessError.__dict__.__contains__",        ["__weakref__"], true]
    - ["mp1621ew002", "multiprocessing.AuthenticationError.__dict__.__contains__", ["__weakref__"], false]
    - ["mp1621ew003", "multiprocessing.BufferTooShort.__dict__.__contains__",      ["__weakref__"], false]
    - ["mp1621ew004", "multiprocessing.TimeoutError.__dict__.__contains__",        ["__weakref__"], false]
    - ["mp1621ew005", "multiprocessing.ProcessError.__dict__.__contains__",        ["__dict__"],    false]
    - ["mp1621ew006", "multiprocessing.AuthenticationError.__dict__.__contains__", ["__dict__"],    false]
    - ["mp1621ew007", "multiprocessing.BufferTooShort.__dict__.__contains__",      ["__dict__"],    false]
    - ["mp1621ew008", "multiprocessing.TimeoutError.__dict__.__contains__",        ["__dict__"],    false]
    - ["mp1621ew009", "multiprocessing.ProcessError.__name__.__eq__",              ["ProcessError"], true]
    - ["mp1621ew010", "multiprocessing.AuthenticationError.__name__.__eq__",       ["AuthenticationError"], true]
    - ["mp1621ew011", "multiprocessing.BufferTooShort.__name__.__eq__",            ["BufferTooShort"], true]
    - ["mp1621ew012", "multiprocessing.TimeoutError.__name__.__eq__",              ["TimeoutError"], true]
    - ["mp1621ew013", "multiprocessing.ProcessError.__dict__.__class__.__name__.__eq__",        ["mappingproxy"], true]
    - ["mp1621ew014", "multiprocessing.AuthenticationError.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
    - ["mp1621ew015", "multiprocessing.managers.ProcessError.__dict__.__contains__",            ["__weakref__"], true]
    - ["mp1621ew016", "multiprocessing.managers.RemoteError.__dict__.__contains__",             ["__weakref__"], true]
    - ["mp1621ew017", "multiprocessing.managers.ProcessError.__name__.__eq__",                  ["ProcessError"], true]
    - ["mp1621ew018", "multiprocessing.managers.RemoteError.__name__.__eq__",                   ["RemoteError"], true]
