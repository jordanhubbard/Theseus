spec: multiprocessing_extra1621
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __weakref__ and weak reference protocol"
    - "multiprocessing.Process does not own __weakref__ in its class __dict__; it inherits from object through a chain where a parent already supplies it"
    - "multiprocessing.pool.Pool and multiprocessing.pool.AsyncResult are pure Python classes that directly subclass object; they own __weakref__ in their own __dict__"
    - "multiprocessing.pool.MapResult inherits from AsyncResult which already owns __weakref__; MapResult does not re-define it"
    - "multiprocessing.pool.IMapIterator is a pure Python class that directly subclasses object; it owns __weakref__ in its own __dict__"
    - "multiprocessing.pool.IMapUnorderedIterator inherits from IMapIterator which already owns __weakref__; it does not re-define it"
    - "multiprocessing.pool.ApplyResult is a pure Python class that directly subclasses object; it owns __weakref__ in its own __dict__"
    - "multiprocessing.queues.Queue is a pure Python class that directly subclasses object; it owns __weakref__ in its own __dict__"
    - "multiprocessing.queues.SimpleQueue is a pure Python class that directly subclasses object; it owns __weakref__ in its own __dict__"
    - "multiprocessing.queues.JoinableQueue inherits from Queue which already owns __weakref__; it does not re-define it"
    - "multiprocessing.managers.BaseManager is a pure Python class that directly subclasses object; it owns __weakref__ in its own __dict__"
    - "multiprocessing.managers.BaseProxy is a pure Python class that directly subclasses object; it owns __weakref__ in its own __dict__"
    - "Proxy subclasses (DictProxy, ListProxy, SyncManager, AcquirerProxy, etc.) inherit from BaseProxy or BaseManager; they do not re-define __weakref__"
    - "multiprocessing.synchronize.Lock and Semaphore classes do not own __weakref__ in their own __dict__"
    - "multiprocessing.synchronize.Event and Condition own __weakref__ in their own __dict__ as they appear to be base classes in their respective MRO chains"
    - "multiprocessing.synchronize.Barrier and RLock do not own __weakref__"
    - "multiprocessing exception classes: ProcessError is the base exception and owns __weakref__; its subclasses (AuthenticationError, BufferTooShort, TimeoutError) inherit it and do not re-define it"
    - "multiprocessing.managers.RemoteError and managers.Server own __weakref__ as they are direct object subclasses"
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12"
error_model: python_exceptions

table multiprocessing_extra1621.process_weakref:
  description: "multiprocessing process, pool, queue, synchronize, and manager classes: base classes own __weakref__; subclasses that inherit from those bases do not re-define it; direct object subclasses that are the root of a hierarchy own __weakref__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1621pw

  columns: [id, function, args, expected]
  rows:
    - ["mp1621pw001", "multiprocessing.Process.__dict__.__contains__",                      ["__weakref__"], false]
    - ["mp1621pw002", "multiprocessing.pool.Pool.__dict__.__contains__",                    ["__weakref__"], true]
    - ["mp1621pw003", "multiprocessing.pool.AsyncResult.__dict__.__contains__",             ["__weakref__"], true]
    - ["mp1621pw004", "multiprocessing.pool.MapResult.__dict__.__contains__",               ["__weakref__"], false]
    - ["mp1621pw005", "multiprocessing.pool.IMapIterator.__dict__.__contains__",            ["__weakref__"], true]
    - ["mp1621pw006", "multiprocessing.pool.IMapUnorderedIterator.__dict__.__contains__",   ["__weakref__"], false]
    - ["mp1621pw007", "multiprocessing.pool.ApplyResult.__dict__.__contains__",             ["__weakref__"], true]
    - ["mp1621pw008", "multiprocessing.queues.Queue.__dict__.__contains__",                 ["__weakref__"], true]
    - ["mp1621pw009", "multiprocessing.queues.SimpleQueue.__dict__.__contains__",           ["__weakref__"], true]
    - ["mp1621pw010", "multiprocessing.queues.JoinableQueue.__dict__.__contains__",         ["__weakref__"], false]
    - ["mp1621pw011", "multiprocessing.managers.BaseManager.__dict__.__contains__",         ["__weakref__"], true]
    - ["mp1621pw012", "multiprocessing.managers.BaseProxy.__dict__.__contains__",           ["__weakref__"], true]
    - ["mp1621pw013", "multiprocessing.managers.SyncManager.__dict__.__contains__",         ["__weakref__"], false]
    - ["mp1621pw014", "multiprocessing.managers.DictProxy.__dict__.__contains__",           ["__weakref__"], false]
    - ["mp1621pw015", "multiprocessing.managers.ListProxy.__dict__.__contains__",           ["__weakref__"], false]
    - ["mp1621pw016", "multiprocessing.managers.AcquirerProxy.__dict__.__contains__",       ["__weakref__"], false]
    - ["mp1621pw017", "multiprocessing.managers.NamespaceProxy.__dict__.__contains__",      ["__weakref__"], false]
    - ["mp1621pw018", "multiprocessing.managers.EventProxy.__dict__.__contains__",          ["__weakref__"], false]
    - ["mp1621pw019", "multiprocessing.managers.ConditionProxy.__dict__.__contains__",      ["__weakref__"], false]
