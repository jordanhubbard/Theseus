spec: chunk_extra
version: ">=3.9,<3.13"
backend: python_module(chunk)

docs: https://docs.python.org/3.11/library/chunk.html

provenance:
  derived_from:
    - "https://docs.python.org/3.11/library/chunk.html — Python chunk module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/chunk.py"
  notes:
    - "Extends chunk.zspec.zsdl with additional method name, module, and class identity invariants."
    - "The chunk module was deprecated in Python 3.11 (PEP 594) and removed in Python 3.13."
    - "chunk.Chunk.__name__ == 'Chunk' — the sole public class in the module."
    - "chunk.Chunk.__module__ == 'chunk' — Chunk is defined at top level in the chunk module."
    - "chunk.Chunk.getname.__name__ == 'getname' — returns the 4-byte chunk-type identifier as bytes."
    - "chunk.Chunk.getsize.__name__ == 'getsize' — returns the size of the chunk data as an integer."
    - "chunk.Chunk.read.__name__ == 'read' — reads up to size bytes of chunk data."
    - "chunk.Chunk.seek.__name__ == 'seek' — seeks within chunk data."
    - "chunk.Chunk.tell.__name__ == 'tell' — returns current position within chunk data."
    - "chunk.Chunk.close.__name__ == 'close' — marks the chunk as closed."
    - "chunk.Chunk.skip.__name__ == 'skip' — advances past the rest of the chunk data."
    - "chunk.Chunk.isatty.__name__ == 'isatty' — always returns False for a Chunk."
    - "chunk.Chunk.__class__.__name__ == 'type' — Chunk is a class object."
    - "chunk.Chunk.__bases__[0].__name__ == 'object' — Chunk inherits directly from object."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name — chunk.Chunk
# ---------------------------------------------------------------------------

invariant chunk_extra.Chunk.name:
  description: "chunk.Chunk.__name__ == 'Chunk'"
  category: class_names
  kind: python_call_eq
  function: Chunk.__name__.__eq__
  args: ["Chunk"]
  expected: true

# ---------------------------------------------------------------------------
# Module identity — chunk.Chunk is defined in chunk
# ---------------------------------------------------------------------------

invariant chunk_extra.Chunk.module:
  description: "chunk.Chunk.__module__ == 'chunk' — Chunk is defined in the chunk module"
  category: class_modules
  kind: python_call_eq
  function: Chunk.__module__.__eq__
  args: ["chunk"]
  expected: true

# ---------------------------------------------------------------------------
# Chunk is a class (type)
# ---------------------------------------------------------------------------

invariant chunk_extra.Chunk.is_class:
  description: "chunk.Chunk.__class__.__name__ == 'type' — Chunk is a class object"
  category: class_identity
  kind: python_call_eq
  function: Chunk.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# Chunk base class is object
# ---------------------------------------------------------------------------

invariant chunk_extra.Chunk.base_class:
  description: "chunk.Chunk.__bases__[0].__name__ == 'object' — Chunk inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Chunk.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

# ---------------------------------------------------------------------------
# Method name attributes on the Chunk class
# ---------------------------------------------------------------------------

table chunk_extra.Chunk.method_names:
  kind: python_call_eq
  category: method_names
  id_prefix: method_name

  columns: [id, function, args, expected]
  rows:
    - [getname, Chunk.getname.__name__.__eq__, ["getname"], true]
    - [getsize, Chunk.getsize.__name__.__eq__, ["getsize"], true]
    - [read,    Chunk.read.__name__.__eq__,    ["read"],    true]
    - [seek,    Chunk.seek.__name__.__eq__,    ["seek"],    true]
    - [tell,    Chunk.tell.__name__.__eq__,    ["tell"],    true]
    - [close,   Chunk.close.__name__.__eq__,   ["close"],   true]
    - [skip,    Chunk.skip.__name__.__eq__,    ["skip"],    true]
    - [isatty,  Chunk.isatty.__name__.__eq__,  ["isatty"],  true]
