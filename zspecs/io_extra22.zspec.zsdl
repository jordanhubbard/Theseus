spec: io_extra22
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra.zspec.zsdl — covers DEFAULT_BUFFER_SIZE type/value; StringIO/BytesIO basic class checks"
    - "io_extra21.zspec.zsdl — covers various io class and exception properties through prior spec"
  notes:
    - "This spec extends io.zspec.zsdl and prior extras through io_extra21.zspec.zsdl."
    - "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' — the buffer size constant is always an integer."
    - "io.DEFAULT_BUFFER_SIZE >= 4096 — CPython sets this to 8192 or 131072 depending on platform; 4096 is a safe lower bound."
    - "io.UnsupportedOperation.__qualname__ == 'UnsupportedOperation' — simple class, qualname equals name."
    - "io.UnsupportedOperation.__module__ == 'io' — defined in the public io namespace."
    - "io.UnsupportedOperation.__bases__[0].__name__ == 'OSError' — verified at runtime: first base is OSError (UnsupportedOperation inherits from OSError and ValueError; OSError is first)."
    - "BlockingIOError.__qualname__ == 'BlockingIOError' — built-in exception; qualname equals name."
    - "io.StringIO.__qualname__ == 'StringIO' — simple class, qualname equals name."
    - "io.BytesIO.__qualname__ == 'BytesIO' — simple class, qualname equals name."
    - "io.BufferedReader.__qualname__ == 'BufferedReader' — simple class, qualname equals name."
    - "StringIO/BytesIO/BufferedReader/BufferedWriter all have __module__ == '_io' — implemented in the C extension _io."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.DEFAULT_BUFFER_SIZE — type check
#
# No prior spec in this namespace checks DEFAULT_BUFFER_SIZE.__class__.__name__.
# The constant is always an int.
# ---------------------------------------------------------------------------

invariant io_extra22.DEFAULT_BUFFER_SIZE.class_name:
  description: "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' — buffer size constant is always an int"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# io.DEFAULT_BUFFER_SIZE — lower bound
#
# CPython sets DEFAULT_BUFFER_SIZE to 8192 or 131072. A lower bound of 4096
# is universally safe and documents the minimum meaningful buffer size.
# ---------------------------------------------------------------------------

invariant io_extra22.DEFAULT_BUFFER_SIZE.ge_4096:
  description: "io.DEFAULT_BUFFER_SIZE >= 4096 — buffer size is always at least 4096 bytes"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__ge__
  args: [4096]
  expected: true

# ---------------------------------------------------------------------------
# io.UnsupportedOperation — qualname and module
#
# No prior spec checks UnsupportedOperation.__qualname__ or __module__.
# UnsupportedOperation is a simple (non-nested) class, so qualname == name.
# It is defined in the public 'io' module namespace.
# ---------------------------------------------------------------------------

invariant io_extra22.UnsupportedOperation.qualname:
  description: "io.UnsupportedOperation.__qualname__ == 'UnsupportedOperation'"
  category: exceptions
  kind: python_call_eq
  function: UnsupportedOperation.__qualname__.__eq__
  args: ["UnsupportedOperation"]
  expected: true

invariant io_extra22.UnsupportedOperation.module:
  description: "io.UnsupportedOperation.__module__ == 'io'"
  category: exceptions
  kind: python_call_eq
  function: UnsupportedOperation.__module__.__eq__
  args: ["io"]
  expected: true

# ---------------------------------------------------------------------------
# io.UnsupportedOperation — first base class
#
# UnsupportedOperation inherits from both OSError and ValueError.
# OSError is listed first in the MRO / __bases__ tuple.
# Accessed via __bases__.__getitem__(0) (dotted chain, no subscript syntax).
# ---------------------------------------------------------------------------

invariant io_extra22.UnsupportedOperation.base0_name:
  description: "io.UnsupportedOperation.__bases__.__getitem__(0).__name__ == 'OSError' — first base is OSError"
  category: exceptions
  kind: python_call_eq
  function: UnsupportedOperation.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# BlockingIOError — qualname
#
# BlockingIOError is a built-in exception. No prior io spec checks its qualname.
# As a simple non-nested class, qualname equals name.
# ---------------------------------------------------------------------------

invariant io_extra22.BlockingIOError.qualname:
  description: "BlockingIOError.__qualname__ == 'BlockingIOError'"
  category: exceptions
  kind: python_call_eq
  function: BlockingIOError.__qualname__.__eq__
  args: ["BlockingIOError"]
  expected: true

# ---------------------------------------------------------------------------
# io.StringIO, BytesIO, BufferedReader — qualnames
#
# No prior spec checks __qualname__ for these classes. Each is a simple
# (non-nested) class, so qualname equals the class name.
# ---------------------------------------------------------------------------

invariant io_extra22.StringIO.qualname:
  description: "io.StringIO.__qualname__ == 'StringIO'"
  category: classes
  kind: python_call_eq
  function: StringIO.__qualname__.__eq__
  args: ["StringIO"]
  expected: true

invariant io_extra22.BytesIO.qualname:
  description: "io.BytesIO.__qualname__ == 'BytesIO'"
  category: classes
  kind: python_call_eq
  function: BytesIO.__qualname__.__eq__
  args: ["BytesIO"]
  expected: true

invariant io_extra22.BufferedReader.qualname:
  description: "io.BufferedReader.__qualname__ == 'BufferedReader'"
  category: classes
  kind: python_call_eq
  function: BufferedReader.__qualname__.__eq__
  args: ["BufferedReader"]
  expected: true

# ---------------------------------------------------------------------------
# io class __module__ attributes — all '_io'
#
# StringIO, BytesIO, BufferedReader, and BufferedWriter are all implemented
# in the C extension '_io'. No prior spec covers their __module__ attributes
# as a group in this namespace.
# ---------------------------------------------------------------------------

table io_extra22.class_modules:
  description: "io classes StringIO/BytesIO/BufferedReader/BufferedWriter all have __module__ == '_io'"
  kind: python_call_eq
  category: classes

  columns: [id, function, args, expected]
  rows:
    - [StringIO,       StringIO.__module__.__eq__,       ["_io"], true]
    - [BytesIO,        BytesIO.__module__.__eq__,        ["_io"], true]
    - [BufferedReader, BufferedReader.__module__.__eq__, ["_io"], true]
    - [BufferedWriter, BufferedWriter.__module__.__eq__, ["_io"], true]
