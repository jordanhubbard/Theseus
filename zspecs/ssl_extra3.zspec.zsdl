spec: ssl_extra3
version: ">=3.7"
backend: python_module(ssl)

docs: https://docs.python.org/3/library/ssl.html
rfcs:
  - "RFC 8446 — The Transport Layer Security (TLS) Protocol Version 1.3"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "ssl source: internal CPython _ssl C extension"
    - "OpenSSL source: ssl/ directory"
    - "CPython source: Lib/ssl.py"
  notes:
    - "This spec extends ssl.zspec.zsdl, ssl_extra.zspec.zsdl, and ssl_extra2.zspec.zsdl; it does NOT duplicate invariants present in those files."
    - "ssl.zspec.zsdl covers: SSLError/SSLContext/SSLSocket/SSLCertVerificationError __name__; SSLError.__bases__[0].__name__=='OSError'; SSLError.__module__; CERT_NONE/CERT_OPTIONAL/CERT_REQUIRED int values; HAS_SNI/HAS_ALPN bool type."
    - "ssl_extra.zspec.zsdl covers: SSLContext.__module__; SSLCertVerificationError module and base; create_default_context; OP_NO_SSLv2/OP_NO_SSLv3 Options type; Purpose.__name__; Purpose.SERVER_AUTH/CLIENT_AUTH names; PROTOCOL_TLS_CLIENT/SERVER class name 'Protocol'."
    - "ssl_extra2.zspec.zsdl covers: SSLZeroReturnError/SSLWantReadError/SSLWantWriteError names, bases, modules; CERT_NONE/CERT_REQUIRED VerifyMode class name; PROTOCOL_TLS_CLIENT/SERVER __bool__; OP_NO_SSLv2 __bool__; SSLSocket.__module__."
    - "This spec focuses on: TLSVersion.__name__; TLSVersion.__bases__[0].__name__ (IntEnum base); PROTOCOL_TLS_CLIENT.__class__.__name__ == '_SSLMethod'; ssl.TLSVersion.TLSv1_2 name and ssl.TLSVersion.TLSv1_3 name."
    - "ssl.TLSVersion is an IntEnum added in Python 3.7; TLSVersion.__name__ == 'TLSVersion'."
    - "TLSVersion inherits from IntEnum; TLSVersion.__bases__[0].__name__ == 'IntEnum'."
    - "ssl.PROTOCOL_TLS_CLIENT.__class__.__name__ == '_SSLMethod' on Python 3.12/macOS — it is a member of the internal _ssl._SSLMethod IntEnum."
    - "TLSVersion.TLSv1_2 and TLSVersion.TLSv1_3 are members of TLSVersion enum; their .name attribute is 'TLSv1_2' and 'TLSv1_3'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "ssl.SSLError (subclass of OSError) is raised for TLS-level failures. Class attribute reads are stateless and never raise."
  stderr: "null"
  stickiness: "N/A — all tested invariants are stateless class attribute reads."
  codes: {}

# ---------------------------------------------------------------------------
# TLSVersion — class name and base class (Python 3.7+)
# TLSVersion is an IntEnum; its __name__ is 'TLSVersion' and it inherits from IntEnum.
# ---------------------------------------------------------------------------

invariant ssl_extra3.TLSVersion.name:
  description: "ssl.TLSVersion.__name__ == 'TLSVersion'"
  category: class_metadata
  kind: python_call_eq
  function: TLSVersion.__name__.__eq__
  args: ["TLSVersion"]
  expected: true

invariant ssl_extra3.TLSVersion.base:
  description: "ssl.TLSVersion.__bases__[0].__name__ == 'IntEnum' — TLSVersion is an IntEnum subclass"
  category: hierarchy
  kind: python_call_eq
  function: TLSVersion.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "IntEnum"

# ---------------------------------------------------------------------------
# TLSVersion member names — TLSv1_2 and TLSv1_3
# These enum members expose their YAML key via the .name attribute.
# ---------------------------------------------------------------------------

invariant ssl_extra3.TLSVersion.TLSv1_2_name:
  description: "ssl.TLSVersion.TLSv1_2.name == 'TLSv1_2'"
  category: constants
  kind: python_call_eq
  function: TLSVersion.TLSv1_2.name.__eq__
  args: ["TLSv1_2"]
  expected: true

invariant ssl_extra3.TLSVersion.TLSv1_3_name:
  description: "ssl.TLSVersion.TLSv1_3.name == 'TLSv1_3'"
  category: constants
  kind: python_call_eq
  function: TLSVersion.TLSv1_3.name.__eq__
  args: ["TLSv1_3"]
  expected: true

# ---------------------------------------------------------------------------
# PROTOCOL_TLS_CLIENT — internal class name
# ssl_extra.zspec.zsdl checks __class__.__name__ == 'Protocol' (Python < 3.10).
# On Python 3.12, PROTOCOL_TLS_CLIENT is an _SSLMethod member (internal enum).
# ssl_extra2.zspec.zsdl checks __bool__. This spec records the actual class name.
# ---------------------------------------------------------------------------

invariant ssl_extra3.PROTOCOL_TLS_CLIENT.class_name:
  description: "ssl.PROTOCOL_TLS_CLIENT.__class__.__name__ == '_SSLMethod' on Python 3.12"
  category: constants
  kind: python_call_eq
  function: PROTOCOL_TLS_CLIENT.__class__.__name__.__eq__
  args: ["_SSLMethod"]
  expected: true
