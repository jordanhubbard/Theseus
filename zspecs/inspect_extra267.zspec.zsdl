spec: inspect_extra267
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "All inspect classification functions in this spec are plain Python functions: __class__.__name__ == 'function' for all."
    - "All inspect functions have __module__ == 'inspect' (len=7)."
    - "iscoroutinefunction.__name__ (19) == isgeneratorfunction.__name__ (19) — tied longest in spec."
    - "isasyncgenfunction.__name__ (18) is one shorter than the tied pair."
    - "istraceback.__name__ (11) > isabstract.__name__ (10) > isbuiltin.__name__ (9) == isroutine.__name__ (9) > isframe.__name__ (7) > iscode.__name__ (6)."
    - "iscode.__name__ (6) is shortest in spec."
    - "isframe.__name__ (7) equals module name 'inspect' length (7)."
    - "All qualnames equal names (module-level, no nesting)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect classification functions: isbuiltin, isroutine, isabstract, isframe, iscode, istraceback
#
# All plain Python functions in inspect (len=7).
# iscode.__name__ (6) is shortest.
# isframe.__name__ (7) equals module name length.
# isbuiltin.__name__ (9) == isroutine.__name__ (9) — tied.
# isabstract.__name__ (10).
# istraceback.__name__ (11).
# ---------------------------------------------------------------------------

table inspect_extra267.classification_functions_identity:
  description: "inspect.isbuiltin(9), isroutine(9), isabstract(10), isframe(7), iscode(6), istraceback(11) identity — all plain Python functions in inspect(7); iscode(6) shortest; isframe(7) equals module len; isbuiltin==isroutine(9) tied; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex267c

  columns: [id, function, args, expected, description]
  rows:
    - [ib_name_eq,         isbuiltin.__name__.__eq__,                  ["isbuiltin"],                  true, "inspect.isbuiltin.__name__ == 'isbuiltin'; verified with Python 3.14.3"]
    - [ib_name_len,        isbuiltin.__name__.__len__,                 [],                             9,    "inspect.isbuiltin.__name__.__len__() == 9 — tied with isroutine; verified with Python 3.14.3"]
    - [ib_qn_eq,           isbuiltin.__qualname__.__eq__,              ["isbuiltin"],                  true, "inspect.isbuiltin.__qualname__ == 'isbuiltin' — qualname equals name; verified with Python 3.14.3"]
    - [ib_mod_eq,          isbuiltin.__module__.__eq__,                ["inspect"],                    true, "inspect.isbuiltin.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [ib_cls_eq,          isbuiltin.__class__.__name__.__eq__,        ["function"],                   true, "inspect.isbuiltin.__class__.__name__ == 'function' — plain Python function; verified with Python 3.14.3"]
    - [ir_name_eq,         isroutine.__name__.__eq__,                  ["isroutine"],                  true, "inspect.isroutine.__name__ == 'isroutine'; verified with Python 3.14.3"]
    - [ir_name_len,        isroutine.__name__.__len__,                 [],                             9,    "inspect.isroutine.__name__.__len__() == 9 — tied with isbuiltin; verified with Python 3.14.3"]
    - [ir_qn_eq,           isroutine.__qualname__.__eq__,              ["isroutine"],                  true, "inspect.isroutine.__qualname__ == 'isroutine' — qualname equals name; verified with Python 3.14.3"]
    - [ir_mod_eq,          isroutine.__module__.__eq__,                ["inspect"],                    true, "inspect.isroutine.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [ir_cls_eq,          isroutine.__class__.__name__.__eq__,        ["function"],                   true, "inspect.isroutine.__class__.__name__ == 'function' — plain Python function; verified with Python 3.14.3"]
    - [ia_name_eq,         isabstract.__name__.__eq__,                 ["isabstract"],                 true, "inspect.isabstract.__name__ == 'isabstract'; verified with Python 3.14.3"]
    - [ia_name_len,        isabstract.__name__.__len__,                [],                             10,   "inspect.isabstract.__name__.__len__() == 10; verified with Python 3.14.3"]
    - [ia_qn_eq,           isabstract.__qualname__.__eq__,             ["isabstract"],                 true, "inspect.isabstract.__qualname__ == 'isabstract' — qualname equals name; verified with Python 3.14.3"]
    - [ia_mod_eq,          isabstract.__module__.__eq__,               ["inspect"],                    true, "inspect.isabstract.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [ia_cls_eq,          isabstract.__class__.__name__.__eq__,       ["function"],                   true, "inspect.isabstract.__class__.__name__ == 'function' — plain Python function; verified with Python 3.14.3"]
    - [if_name_eq,         isframe.__name__.__eq__,                    ["isframe"],                    true, "inspect.isframe.__name__ == 'isframe'; verified with Python 3.14.3"]
    - [if_name_len,        isframe.__name__.__len__,                   [],                             7,    "inspect.isframe.__name__.__len__() == 7 — equals module name 'inspect' length; verified with Python 3.14.3"]
    - [if_qn_eq,           isframe.__qualname__.__eq__,                ["isframe"],                    true, "inspect.isframe.__qualname__ == 'isframe' — qualname equals name; verified with Python 3.14.3"]
    - [if_mod_eq,          isframe.__module__.__eq__,                  ["inspect"],                    true, "inspect.isframe.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [if_cls_eq,          isframe.__class__.__name__.__eq__,          ["function"],                   true, "inspect.isframe.__class__.__name__ == 'function' — plain Python function; verified with Python 3.14.3"]
    - [ic_name_eq,         iscode.__name__.__eq__,                     ["iscode"],                     true, "inspect.iscode.__name__ == 'iscode'; verified with Python 3.14.3"]
    - [ic_name_len,        iscode.__name__.__len__,                    [],                             6,    "inspect.iscode.__name__.__len__() == 6 — shortest in spec; verified with Python 3.14.3"]
    - [ic_qn_eq,           iscode.__qualname__.__eq__,                 ["iscode"],                     true, "inspect.iscode.__qualname__ == 'iscode' — qualname equals name; verified with Python 3.14.3"]
    - [ic_mod_eq,          iscode.__module__.__eq__,                   ["inspect"],                    true, "inspect.iscode.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [ic_cls_eq,          iscode.__class__.__name__.__eq__,           ["function"],                   true, "inspect.iscode.__class__.__name__ == 'function' — plain Python function; verified with Python 3.14.3"]
    - [it_name_eq,         istraceback.__name__.__eq__,                ["istraceback"],                true, "inspect.istraceback.__name__ == 'istraceback'; verified with Python 3.14.3"]
    - [it_name_len,        istraceback.__name__.__len__,               [],                             11,   "inspect.istraceback.__name__.__len__() == 11; verified with Python 3.14.3"]
    - [it_qn_eq,           istraceback.__qualname__.__eq__,            ["istraceback"],                true, "inspect.istraceback.__qualname__ == 'istraceback' — qualname equals name; verified with Python 3.14.3"]
    - [it_mod_eq,          istraceback.__module__.__eq__,              ["inspect"],                    true, "inspect.istraceback.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [it_cls_eq,          istraceback.__class__.__name__.__eq__,      ["function"],                   true, "inspect.istraceback.__class__.__name__ == 'function' — plain Python function; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# inspect coroutine/generator/asyncgen classification functions identity
#
# iscoroutinefunction.__name__ (19) == isgeneratorfunction.__name__ (19) — tied longest.
# isasyncgenfunction.__name__ (18) — one shorter than the tied pair.
# All plain Python functions in inspect.
# ---------------------------------------------------------------------------

table inspect_extra267.coroutine_generator_identity:
  description: "inspect.iscoroutinefunction(19), isgeneratorfunction(19), isasyncgenfunction(18) identity — all plain Python functions in inspect(7); iscoroutinefunction and isgeneratorfunction names(19) tied longest in spec; isasyncgenfunction(18) one shorter; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex267g

  columns: [id, function, args, expected, description]
  rows:
    - [cf_name_eq,         iscoroutinefunction.__name__.__eq__,        ["iscoroutinefunction"],        true, "inspect.iscoroutinefunction.__name__ == 'iscoroutinefunction'; verified with Python 3.14.3"]
    - [cf_name_len,        iscoroutinefunction.__name__.__len__,       [],                             19,   "inspect.iscoroutinefunction.__name__.__len__() == 19 — tied longest with isgeneratorfunction; verified with Python 3.14.3"]
    - [cf_qn_eq,           iscoroutinefunction.__qualname__.__eq__,    ["iscoroutinefunction"],        true, "inspect.iscoroutinefunction.__qualname__ == 'iscoroutinefunction' — qualname equals name; verified with Python 3.14.3"]
    - [cf_mod_eq,          iscoroutinefunction.__module__.__eq__,      ["inspect"],                    true, "inspect.iscoroutinefunction.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [cf_cls_eq,          iscoroutinefunction.__class__.__name__.__eq__, ["function"],                true, "inspect.iscoroutinefunction.__class__.__name__ == 'function' — plain Python function; verified with Python 3.14.3"]
    - [gf_name_eq,         isgeneratorfunction.__name__.__eq__,        ["isgeneratorfunction"],        true, "inspect.isgeneratorfunction.__name__ == 'isgeneratorfunction'; verified with Python 3.14.3"]
    - [gf_name_len,        isgeneratorfunction.__name__.__len__,       [],                             19,   "inspect.isgeneratorfunction.__name__.__len__() == 19 — tied longest with iscoroutinefunction; verified with Python 3.14.3"]
    - [gf_qn_eq,           isgeneratorfunction.__qualname__.__eq__,    ["isgeneratorfunction"],        true, "inspect.isgeneratorfunction.__qualname__ == 'isgeneratorfunction' — qualname equals name; verified with Python 3.14.3"]
    - [gf_mod_eq,          isgeneratorfunction.__module__.__eq__,      ["inspect"],                    true, "inspect.isgeneratorfunction.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [gf_cls_eq,          isgeneratorfunction.__class__.__name__.__eq__, ["function"],                true, "inspect.isgeneratorfunction.__class__.__name__ == 'function' — plain Python function; verified with Python 3.14.3"]
    - [ag_name_eq,         isasyncgenfunction.__name__.__eq__,         ["isasyncgenfunction"],         true, "inspect.isasyncgenfunction.__name__ == 'isasyncgenfunction'; verified with Python 3.14.3"]
    - [ag_name_len,        isasyncgenfunction.__name__.__len__,        [],                             18,   "inspect.isasyncgenfunction.__name__.__len__() == 18 — one shorter than iscoroutinefunction/isgeneratorfunction(19); verified with Python 3.14.3"]
    - [ag_qn_eq,           isasyncgenfunction.__qualname__.__eq__,     ["isasyncgenfunction"],         true, "inspect.isasyncgenfunction.__qualname__ == 'isasyncgenfunction' — qualname equals name; verified with Python 3.14.3"]
    - [ag_mod_eq,          isasyncgenfunction.__module__.__eq__,       ["inspect"],                    true, "inspect.isasyncgenfunction.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [ag_cls_eq,          isasyncgenfunction.__class__.__name__.__eq__, ["function"],                 true, "inspect.isasyncgenfunction.__class__.__name__ == 'function' — plain Python function; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — inspect_extra267
# ---------------------------------------------------------------------------

invariant inspect_extra267.all_functions_share_module:
  description: "inspect.isbuiltin.__module__ == 'inspect' (len=7) — all inspect classification functions in this spec share __module__ == 'inspect'; isframe name len (7) equals module name len (7)"
  category: identity
  kind: python_call_eq
  function: isbuiltin.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra267.iscoroutinefunction_name_len_equals_isgeneratorfunction:
  description: "inspect.iscoroutinefunction.__name__.__len__() == 19 == inspect.isgeneratorfunction.__name__.__len__() — tied longest names in spec at length 19"
  category: identity
  kind: python_call_eq
  function: iscoroutinefunction.__name__.__len__
  args: []
  expected: 19

invariant inspect_extra267.iscode_is_shortest_name:
  description: "inspect.iscode.__name__.__len__() == 6 — shortest name in spec; shorter than isframe(7), isbuiltin(9), isroutine(9), isabstract(10), istraceback(11)"
  category: identity
  kind: python_call_eq
  function: iscode.__name__.__len__
  args: []
  expected: 6

invariant inspect_extra267.isbuiltin_name_len_equals_isroutine:
  description: "inspect.isbuiltin.__name__.__len__() == 9 == inspect.isroutine.__name__.__len__() — isbuiltin and isroutine names are both length 9"
  category: identity
  kind: python_call_eq
  function: isbuiltin.__name__.__len__
  args: []
  expected: 9

invariant inspect_extra267.isasyncgenfunction_class_is_function:
  description: "inspect.isasyncgenfunction.__class__.__name__ == 'function' — isasyncgenfunction is a plain Python function; all classification helpers in this spec are plain Python functions"
  category: identity
  kind: python_call_eq
  function: isasyncgenfunction.__class__.__name__.__eq__
  args: ["function"]
  expected: true
