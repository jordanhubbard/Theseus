spec: re_extra1081
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module error/PatternError, RegexFlag integer values, and additional module function documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks re.error __name__ and __qualname__ (both resolve to PatternError in 3.13+), RegexFlag member integer values via __eq__, and additional module-level function qualnames not covered in _extra1051/_extra1066"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra1081.error_class_identity:
  description: "re.error class __name__, __qualname__, and __module__ checks (re.error is an alias for re.PatternError in Python 3.13+)"
  kind: python_call_eq
  category: error_class_identity
  id_prefix: re1081ec
  columns: [id, function, args, expected]
  rows:
    - [re1081ec001, re.error.__name__.__eq__,          ["PatternError"], true]
    - [re1081ec002, re.error.__qualname__.__eq__,       ["PatternError"], true]
    - [re1081ec003, re.error.__module__.__eq__,         ["re"],           true]
    - [re1081ec004, re.PatternError.__name__.__eq__,    ["PatternError"], true]
    - [re1081ec005, re.PatternError.__qualname__.__eq__, ["PatternError"], true]
    - [re1081ec006, re.PatternError.__module__.__eq__,  ["re"],           true]
    - [re1081ec007, re.error.__name__.__eq__,           ["error"],        false]

table re_extra1081.regexflag_int_values:
  description: "re.RegexFlag member integer value checks via __eq__"
  kind: python_call_eq
  category: regexflag_int_values
  id_prefix: re1081rv
  columns: [id, function, args, expected]
  rows:
    - [re1081rv001, re.IGNORECASE.__eq__, ["2"],   false]
    - [re1081rv002, re.IGNORECASE.__eq__, [2],     true]
    - [re1081rv003, re.MULTILINE.__eq__,  [8],     true]
    - [re1081rv004, re.DOTALL.__eq__,     [16],    true]
    - [re1081rv005, re.VERBOSE.__eq__,    [64],    true]
    - [re1081rv006, re.UNICODE.__eq__,    [32],    true]
    - [re1081rv007, re.ASCII.__eq__,      [256],   true]
    - [re1081rv008, re.IGNORECASE.__class__.__name__.__eq__, ["RegexFlag"], true]

table re_extra1081.module_extra_function_identity:
  description: "re module-level function __qualname__ and __module__ checks not covered in _extra1066"
  kind: python_call_eq
  category: module_extra_function_identity
  id_prefix: re1081mf
  columns: [id, function, args, expected]
  rows:
    - [re1081mf001, re.escape.__qualname__.__eq__,    ["escape"],    true]
    - [re1081mf002, re.escape.__module__.__eq__,      ["re"],        true]
    - [re1081mf003, re.fullmatch.__qualname__.__eq__,  ["fullmatch"],  true]
    - [re1081mf004, re.fullmatch.__module__.__eq__,    ["re"],        true]
    - [re1081mf005, re.finditer.__qualname__.__eq__,  ["finditer"],  true]
    - [re1081mf006, re.finditer.__module__.__eq__,    ["re"],        true]
    - [re1081mf007, re.subn.__qualname__.__eq__,      ["subn"],      true]
    - [re1081mf008, re.purge.__qualname__.__eq__,     ["purge"],     true]
