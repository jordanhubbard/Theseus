spec: concurrent_futures_extra215
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'."
    - "ProcessPoolExecutor.__module__ == 'concurrent.futures.process'."
    - "Both ThreadPoolExecutor and ProcessPoolExecutor inherit directly from Executor."
    - "ThreadPoolExecutor.map inherits from Executor (qualname 'Executor.map'); ProcessPoolExecutor overrides map."
    - "ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit'."
    - "ProcessPoolExecutor.submit.__qualname__ == 'ProcessPoolExecutor.submit'."
    - "verified with Python 3.14.3."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ThreadPoolExecutor class identity — extra215 namespace
#
# ThreadPoolExecutor lives in concurrent.futures.thread and inherits
# from Executor.
# ---------------------------------------------------------------------------

table concurrent_futures_extra215.threadpool_class_identity:
  description: "ThreadPoolExecutor class __name__, __module__, and base class checks in extra215 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cfe215tpident

  columns: [id, function, args, expected, description]
  rows:
    - [tp_name,   ThreadPoolExecutor.__name__.__eq__,   ["ThreadPoolExecutor"],        true, "ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor'"]
    - [tp_module, ThreadPoolExecutor.__module__.__eq__, ["concurrent.futures.thread"], true, "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'"]
    - [tp_qualname, ThreadPoolExecutor.__qualname__.__eq__, ["ThreadPoolExecutor"],    true, "ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor'"]
    - [tp_base,   "ThreadPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"],     true, "ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'"]

