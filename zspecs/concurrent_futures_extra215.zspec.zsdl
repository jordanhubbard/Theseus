    - [tp_shutdown_qualname, ThreadPoolExecutor.shutdown.__qualname__.__eq__, ["ThreadPoolExecutor.shutdown"], true, "ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown'"]

