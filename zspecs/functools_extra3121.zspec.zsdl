spec: ft3121
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 655 (ft3121): __ge__, __repr__, __str__ dict-presence checks for functools types."
    - "None of the four functools types define __ge__ or __str__ in their own __dict__."
    - "functools.partial and functools.partialmethod define __repr__; functools.cached_property and functools._lru_cache_wrapper do not."
    - "functools.partial.__repr__ formats as 'functools.partial(<func>, ...)'; functools.partialmethod.__repr__ formats as 'functools.partialmethod(<func>, ...)'."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ft3121.ge:
  description: "functools types __ge__ dict-presence checks; wave 655"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft3121
  columns: [id, function, args, expected]
  rows:
    - ["ft3121001", operator.contains, [functools.partial.__dict__,            "__ge__"], false]
    - ["ft3121002", operator.contains, [functools.partialmethod.__dict__,      "__ge__"], false]
    - ["ft3121003", operator.contains, [functools.cached_property.__dict__,    "__ge__"], false]
    - ["ft3121004", operator.contains, [functools._lru_cache_wrapper.__dict__, "__ge__"], false]

table ft3121.repr:
  description: "functools types __repr__ dict-presence checks; wave 655"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft3121
  columns: [id, function, args, expected]
  rows:
    - ["ft3121005", operator.contains, [functools.partial.__dict__,            "__repr__"], true]
    - ["ft3121006", operator.contains, [functools.partialmethod.__dict__,      "__repr__"], true]
    - ["ft3121007", operator.contains, [functools.cached_property.__dict__,    "__repr__"], false]
    - ["ft3121008", operator.contains, [functools._lru_cache_wrapper.__dict__, "__repr__"], false]

