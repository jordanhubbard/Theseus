spec: cachelib_rust
version: ">=3.9"
backend: rust_module(cachelib_rust)

docs: https://cachelib.readthedocs.io/en/stable/

provenance:
  derived_from:
    - "https://cachelib.readthedocs.io/en/stable/ — Cachelib documentation"
  not_derived_from:
    - "cachelib source: cachelib/simple.py"
  notes:
    - "Cachelib provides caching utilities for Python."
    - "from cachelib import SimpleCache; c = SimpleCache()."
    - "c.set('key', 'value'); c.get('key') == 'value'."
    - "c.set('num', 42); c.get('num') == 42."
    - "c.get('missing') is None."
    - "Expose cachelib_get_str(key, value) -> str: c.set(key, value); c.get(key)."
    - "Expose cachelib_get_int(key, value) -> int: c.set(key, value); c.get(key)."
    - "Expose cachelib_get_missing(key) -> any: c.get(key) — returns None."
    - "All test vectors verified against cachelib 0.9.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# cachelib_get_str — get string value
table cachelib_rust.cache.get_str:
  kind: python_call_eq
  category: get_str
  id_prefix: cl_gs
  function: cachelib_get_str

  columns: [id, args, expected]
  rows:
    - [hello, ["k1", "hello"], "hello"]
    - [world, ["k2", "world"], "world"]

# cachelib_get_int — get integer value
table cachelib_rust.cache.get_int:
  kind: python_call_eq
  category: get_int
  id_prefix: cl_gi
  function: cachelib_get_int

  columns: [id, args, expected]
  rows:
    - [forty2, ["k1", 42], 42]
    - [zero,   ["k2", 0],   0]

# cachelib_get_missing — missing key returns None
invariant cachelib_rust.cache.get_missing:
  description: "SimpleCache.get('missing') is None"
  category: missing
  kind: python_call_eq
  function: cachelib_get_missing
  args: ["notexist_xyz"]
  expected: null

