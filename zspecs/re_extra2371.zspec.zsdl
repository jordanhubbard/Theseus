spec: re_extra2371
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/re.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2371 (_extra2371): __class__.__name__ of module-level objects."
    - "All values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "re.compile, re.search, re.match, re.fullmatch, re.findall, re.finditer, re.sub, re.subn, re.split, re.purge, re.escape are Python functions; __class__.__name__ == 'function'."
    - "re.error, re.Pattern, re.Match are class objects; __class__.__name__ == 'type'."
    - "re.RegexFlag is an IntFlag enum metaclass; __class__.__name__ == 'EnumType' (NOT 'type')."
    - "re.IGNORECASE, re.MULTILINE, re.DOTALL, re.UNICODE, re.ASCII, re.VERBOSE, re.NOFLAG are RegexFlag enum members; __class__.__name__ == 'RegexFlag'."
  created_at: "2026-04-12"

table re_extra2371.object_types:
  description: "re module-level object type classification via __class__.__name__"
  kind: python_call_eq
  category: type_identity
