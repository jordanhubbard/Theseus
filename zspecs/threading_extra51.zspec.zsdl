spec: threading_extra51
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra50.zspec.zsdl."
    - "Prior specs covered: Thread/__name__/__qualname__/__module__; Thread/__qualname__.__len__()==6; Thread/__mro__.__len__()==2; Thread/__bases__[0].__name__=='object'; Thread/__bases__[0].__qualname__=='object'; Event/__qualname__=='Event'; Event/__qualname__.__len__()==5; Event/__mro__.__len__()==2; Event/__bases__[0].__name__=='object'; Event/__bases__[0].__qualname__=='object'; Semaphore/__name__/__qualname__/__module__; Semaphore/__qualname__.__len__()==9; Semaphore/__mro__.__len__()==2; Semaphore/__bases__[0].__qualname__=='object'; BoundedSemaphore/__name__/__qualname__/__module__; BoundedSemaphore/__qualname__.__len__()==16; BoundedSemaphore/__mro__.__len__()==3; BoundedSemaphore/__bases__[0].__name__=='Semaphore'; BoundedSemaphore/__bases__[0].__qualname__=='Semaphore'; Condition/__name__/__module__; Condition/__qualname__=='Condition'; Condition/__qualname__.__len__()==9; Condition/__mro__.__len__()==2; Condition/__bases__[0].__name__=='object'; Condition/__bases__[0].__qualname__=='object'; Barrier/__name__/__qualname__/__module__; Barrier/__mro__.__len__()==2; Barrier/__bases__[0].__name__=='object'; Barrier/__bases__[0].__qualname__=='object'; Timer/__name__/__qualname__/__module__; Timer/__mro__.__len__()==3; Timer/__bases__[0].__name__=='Thread'; Timer/__bases__[0].__qualname__=='Thread'; Lock/__name__=='lock'; Lock/__qualname__=='lock'; Lock/__qualname__.__len__()==4; Lock/__module__=='_thread'; Lock/__module__.__len__()==7; local/__name__=='_local'; TIMEOUT_MAX; threading.__all__.__len__()==28; current_thread/__name__/__qualname__/__module__; main_thread/__name__/__qualname__/__module__; active_count/__name__/__qualname__/__module__; enumerate/__name__/__qualname__/__module__; settrace/__name__/__qualname__; setprofile/__name__/__qualname__; stack_size/__name__/__qualname__; RLock/__name__/__qualname__/__module__; Thread/__class__.__name__=='type'; Event/__class__.__name__=='type'; Semaphore/__class__.__name__=='type'; BoundedSemaphore/__class__.__name__=='type'; Condition/__class__.__name__=='type'; Barrier/__class__.__name__=='type'; Timer/__class__.__name__=='type'; main_thread/__class__.__name__=='function'; current_thread/__class__.__name__=='function'; Thread/__class__.__qualname__=='type'; Event/__class__.__qualname__=='type'; Semaphore/__class__.__qualname__=='type'; BoundedSemaphore/__class__.__qualname__=='type'; Condition/__class__.__qualname__=='type'; Barrier/__class__.__qualname__=='type'; Timer/__class__.__qualname__=='type'; Lock/__class__.__qualname__=='type'; RLock/__class__.__qualname__=='type'; main_thread/__class__.__qualname__=='function'; current_thread/__class__.__qualname__=='function'; TIMEOUT_MAX/__class__.__name__=='float'; active_count/__class__.__name__=='function'; enumerate/__class__.__name__=='function'; settrace/__class__.__name__=='function'; setprofile/__class__.__name__=='function'; stack_size/__class__.__name__=='builtin_function_or_method'; TIMEOUT_MAX/__class__.__qualname__=='float'; active_count/__class__.__qualname__=='function'; Thread.daemon/__class__.__name__=='property'."
    - "This spec covers: threading.Thread.start/__qualname__.__len__()==12; threading.Thread.run/__qualname__.__len__()==10; threading.Thread.join/__qualname__.__len__()==11; threading.Thread.is_alive/__qualname__.__len__()==15; threading.Thread.__init__/__qualname__.__len__()==15; threading.Thread.start/__qualname__.__eq__('Thread.start')==true; threading.Thread.run/__qualname__.__eq__('Thread.run')==true; threading.Event.set/__qualname__.__len__()==9; threading.Event.clear/__qualname__.__len__()==11; threading.Event.wait/__qualname__.__len__()==10; threading.Event.is_set/__qualname__.__len__()==12."
    - "Key findings: threading.Thread is a pure-Python class in Lib/threading.py. Its methods carry qualnames of the form 'Thread.<method>', where the 7-char prefix 'Thread.' is prepended to each method name. The resulting qualname lengths are: start (12 = 7 + 5), run (10 = 7 + 3), join (11 = 7 + 4), is_alive (15 = 7 + 8), __init__ (15 = 7 + 8). Note that is_alive and __init__ both produce length 15 even though their method names differ in length ('is_alive' = 8 chars, '__init__' = 8 chars — both eight characters). threading.Event is also a pure-Python class in Lib/threading.py. Its methods carry qualnames of the form 'Event.<method>', where the 6-char prefix 'Event.' is prepended. The lengths are: set (9 = 6 + 3), clear (11 = 6 + 5), wait (10 = 6 + 4), is_set (12 = 6 + 6). Two additional string equality checks confirm the full qualname for Thread.start and Thread.run. No prior spec recorded __qualname__.__len__() or __qualname__ string equality for any method of Thread or Event. All eleven invariants are new to extra51."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.Thread method qualname lengths — extra51 namespace
#
# threading.Thread is a pure-Python class in Lib/threading.py. Its methods
# carry qualnames of the form 'Thread.<method>'. The 7-char prefix 'Thread.'
# is prepended to each method name. Lengths:
#   start    -> 'Thread.start'    = 12 chars  (7 + 5)
#   run      -> 'Thread.run'      = 10 chars  (7 + 3)
#   join     -> 'Thread.join'     = 11 chars  (7 + 4)
#   is_alive -> 'Thread.is_alive' = 15 chars  (7 + 8)
#   __init__ -> 'Thread.__init__' = 15 chars  (7 + 8)
# No prior spec recorded __qualname__.__len__() for any Thread method.
# All five are new to extra51.
# ---------------------------------------------------------------------------

table threading_extra51.Thread_method_qualname_lengths:
  description: "threading.Thread method __qualname__.__len__() — pure-Python class in Lib/threading.py; methods carry 'Thread.<method>' qualnames with 7-char prefix; start==12, run==10, join==11, is_alive==15, __init__==15"
  kind: python_call_eq
  category: identity
  id_prefix: thrdmlen51

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_start_qualname_len,
       Thread.start.__qualname__.__len__,
       [],
       12,
       "threading.Thread.start.__qualname__.__len__() == 12 — pure-Python method in Lib/threading.py; qualname is 'Thread.start' (7-char prefix 'Thread.' + 5-char 'start' = 12 chars total); Thread.start() initiates thread activity by arranging for the thread's run() method to be invoked in a separate thread of control"]
    - [Thread_run_qualname_len,
       Thread.run.__qualname__.__len__,
       [],
       10,
       "threading.Thread.run.__qualname__.__len__() == 10 — pure-Python method in Lib/threading.py; qualname is 'Thread.run' (7-char prefix 'Thread.' + 3-char 'run' = 10 chars total); Thread.run() invokes the callable passed as the target argument to the Thread constructor; subclasses override this method to implement thread logic"]
    - [Thread_join_qualname_len,
       Thread.join.__qualname__.__len__,
       [],
       11,
       "threading.Thread.join.__qualname__.__len__() == 11 — pure-Python method in Lib/threading.py; qualname is 'Thread.join' (7-char prefix 'Thread.' + 4-char 'join' = 11 chars total); Thread.join() blocks the calling thread until the thread represented by this object terminates or the optional timeout elapses"]
    - [Thread_is_alive_qualname_len,
       Thread.is_alive.__qualname__.__len__,
       [],
       15,
       "threading.Thread.is_alive.__qualname__.__len__() == 15 — pure-Python method in Lib/threading.py; qualname is 'Thread.is_alive' (7-char prefix 'Thread.' + 8-char 'is_alive' = 15 chars total); Thread.is_alive() returns True if the thread is alive (has been started and has not yet terminated); same length as Thread.__init__ because both method names are 8 chars"]
    - [Thread_init_qualname_len,
       Thread.__init__.__qualname__.__len__,
       [],
       15,
       "threading.Thread.__init__.__qualname__.__len__() == 15 — pure-Python method in Lib/threading.py; qualname is 'Thread.__init__' (7-char prefix 'Thread.' + 8-char '__init__' = 15 chars total); Thread.__init__() accepts group/target/name/args/kwargs/daemon parameters; same length as Thread.is_alive because both method names are 8 chars"]

# ---------------------------------------------------------------------------
# threading.Thread method qualname string equality — extra51 namespace
#
# In addition to verifying lengths, two string equality checks confirm the
# exact qualname strings for Thread.start and Thread.run. This verifies
# not just the length but the actual dotted-prefix form. No prior spec
# recorded qualname string equality for any Thread method. Both are new to extra51.
# ---------------------------------------------------------------------------

table threading_extra51.Thread_method_qualname_equality:
  description: "threading.Thread method __qualname__ string equality — Thread.start qualname is exactly 'Thread.start'; Thread.run qualname is exactly 'Thread.run'; confirms the dotted-prefix convention for pure-Python class methods"
  kind: python_call_eq
  category: identity
  id_prefix: thrdmlen51

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_start_qualname_eq,
       Thread.start.__qualname__.__eq__,
       ["Thread.start"],
       true,
       "threading.Thread.start.__qualname__.__eq__('Thread.start') == True — pure-Python method; qualname is exactly the string 'Thread.start' (7-char class prefix 'Thread.' followed by the 5-char method name 'start'); confirms the dotted-prefix qualname convention for methods of pure-Python classes defined at module level"]
    - [Thread_run_qualname_eq,
       Thread.run.__qualname__.__eq__,
       ["Thread.run"],
       true,
       "threading.Thread.run.__qualname__.__eq__('Thread.run') == True — pure-Python method; qualname is exactly the string 'Thread.run' (7-char class prefix 'Thread.' followed by the 3-char method name 'run'); the short method name 'run' makes this the shortest Thread method qualname at 10 chars"]

# ---------------------------------------------------------------------------
# threading.Event method qualname lengths — extra51 namespace
#
# threading.Event is a pure-Python class in Lib/threading.py. Its methods
# carry qualnames of the form 'Event.<method>'. The 6-char prefix 'Event.'
# is prepended to each method name. Lengths:
#   set    -> 'Event.set'    =  9 chars  (6 + 3)
#   clear  -> 'Event.clear'  = 11 chars  (6 + 5)
#   wait   -> 'Event.wait'   = 10 chars  (6 + 4)
#   is_set -> 'Event.is_set' = 12 chars  (6 + 6)
# No prior spec recorded __qualname__.__len__() for any Event method.
# All four are new to extra51.
# ---------------------------------------------------------------------------

table threading_extra51.Event_method_qualname_lengths:
  description: "threading.Event method __qualname__.__len__() — pure-Python class in Lib/threading.py; methods carry 'Event.<method>' qualnames with 6-char prefix; set==9, clear==11, wait==10, is_set==12"
  kind: python_call_eq
  category: identity
  id_prefix: thrdmlen51

  columns: [id, function, args, expected, description]
  rows:
    - [Event_set_qualname_len,
       Event.set.__qualname__.__len__,
       [],
       9,
       "threading.Event.set.__qualname__.__len__() == 9 — pure-Python method in Lib/threading.py; qualname is 'Event.set' (6-char prefix 'Event.' + 3-char 'set' = 9 chars total); Event.set() sets the internal flag to true and awakens all threads waiting on the event"]
    - [Event_clear_qualname_len,
       Event.clear.__qualname__.__len__,
       [],
       11,
       "threading.Event.clear.__qualname__.__len__() == 11 — pure-Python method in Lib/threading.py; qualname is 'Event.clear' (6-char prefix 'Event.' + 5-char 'clear' = 11 chars total); Event.clear() resets the internal flag to false so that threads calling wait() will block again"]
    - [Event_wait_qualname_len,
       Event.wait.__qualname__.__len__,
       [],
       10,
       "threading.Event.wait.__qualname__.__len__() == 10 — pure-Python method in Lib/threading.py; qualname is 'Event.wait' (6-char prefix 'Event.' + 4-char 'wait' = 10 chars total); Event.wait() blocks until the internal flag is true or an optional timeout elapses; returns True if the flag was set before the timeout"]
    - [Event_is_set_qualname_len,
       Event.is_set.__qualname__.__len__,
       [],
       12,
       "threading.Event.is_set.__qualname__.__len__() == 12 — pure-Python method in Lib/threading.py; qualname is 'Event.is_set' (6-char prefix 'Event.' + 6-char 'is_set' = 12 chars total); Event.is_set() returns True if and only if the internal flag is currently set; non-blocking predicate check that does not wait"]
