table multiprocessing_extra189.mp_queues_Queue_class_identity:
  description: "multiprocessing.queues.Queue actual class identity in mpqueue189 namespace — multiprocessing.queues.Queue is the actual Queue class (as opposed to the top-level bound method); queues.Queue.__name__=='Queue' (len=5; same as the factory); queues.Queue.__module__=='multiprocessing.queues' (len=22: 'multiprocessing'=15+'.'=1+'queues'=6=22; compare: multiprocessing.context=23 is 1 char longer than multiprocessing.queues=22); queues.Queue.__bases__[0].__name__=='object' (the class inherits directly from object; it is a standalone class, not derived from asyncio.Queue or any queue ABC); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpqueue189

  columns: [id, function, args, expected, description]
  rows:
    - [class_name_eq,    multiprocessing.queues.Queue.__name__.__eq__,    ["Queue"],                      true, "multiprocessing.queues.Queue.__name__ == 'Queue' (len=5; the actual class in the queues submodule); verified Python 3.14.3"]
    - [class_module_eq,  multiprocessing.queues.Queue.__module__.__eq__,  ["multiprocessing.queues"],     true, "multiprocessing.queues.Queue.__module__ == 'multiprocessing.queues' (len=22; 1 shorter than multiprocessing.context=23); verified Python 3.14.3"]
    - [class_module_len, multiprocessing.queues.Queue.__module__.__len__, [],                             22,   "multiprocessing.queues.Queue.__module__.__len__() == 22 ('multiprocessing.queues'=22: 'multiprocessing'=15+'.'=1+'queues'=6=22); verified Python 3.14.3"]
    - ["class_base_eq",  "multiprocessing.queues.Queue.__bases__[0].__name__.__eq__",                     ["object"], true, "multiprocessing.queues.Queue.__bases__[0].__name__ == 'object' (Queue inherits directly from object); verified Python 3.14.3"]
    - [class_name_len,   multiprocessing.queues.Queue.__name__.__len__,   [],                             5,    "multiprocessing.queues.Queue.__name__.__len__() == 5 ('Queue'=5); queues.Queue.__module__(22) < context(23): queues module path is 1 shorter; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: multiprocessing.queues.Queue __init__ and put qualnames
#
# multiprocessing.queues.Queue.__init__.__qualname__ == 'Queue.__init__' (len=14)
# multiprocessing.queues.Queue.put.__qualname__ == 'Queue.put' (len=9)
# ---------------------------------------------------------------------------

table multiprocessing_extra189.mp_queues_Queue_method_qualnames:
  description: "multiprocessing.queues.Queue __init__ and put qualname identity in mpqueue189 namespace — queues.Queue.__init__.__qualname__=='Queue.__init__' (len=14: 'Queue'=5+'.'=1+'__init__'=8=14; initializes the queue using OS-level IPC primitives — a multiprocessing.Pipe (two Connection objects), a multiprocessing.Lock for serialization, and a semaphore for tracking item count; unlike asyncio.Queue which uses coroutine-level synchronization, multiprocessing.Queue uses OS-level shared memory and semaphores so it works across process boundaries); queues.Queue.put.__qualname__=='Queue.put' (len=9: 'Queue'=5+'.'=1+'put'=3=9; put serializes the item with pickle and sends it over the internal Pipe; put blocks if the queue is full by waiting on a semaphore); __init__(14) > put(9) by 5; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpqueue189

  columns: [id, function, args, expected, description]
  rows:
    - [init_qualname_eq,  "multiprocessing.queues.Queue.__init__.__qualname__.__eq__", ["Queue.__init__"], true, "multiprocessing.queues.Queue.__init__.__qualname__ == 'Queue.__init__' (len=14; sets up IPC pipe, lock, semaphore); verified Python 3.14.3"]
    - [init_qualname_len, "multiprocessing.queues.Queue.__init__.__qualname__.__len__", [],               14,   "multiprocessing.queues.Queue.__init__.__qualname__.__len__() == 14 ('Queue.__init__'=14: 'Queue'=5+'.'=1+'__init__'=8=14); verified Python 3.14.3"]
    - [put_qualname_eq,   multiprocessing.queues.Queue.put.__qualname__.__eq__,        ["Queue.put"],     true, "multiprocessing.queues.Queue.put.__qualname__ == 'Queue.put' (len=9; serializes with pickle, sends over IPC pipe); verified Python 3.14.3"]
    - [put_qualname_len,  multiprocessing.queues.Queue.put.__qualname__.__len__,       [],               9,    "multiprocessing.queues.Queue.put.__qualname__.__len__() == 9 ('Queue.put'=9: 'Queue'=5+'.'=1+'put'=3=9); __init__(14) > put(9) by 5; verified Python 3.14.3"]
    - [context_vs_queues, Queue.__module__.__len__,                                    [],               23,   "multiprocessing.Queue.__module__.__len__() == 23 confirms context(23) > queues(22) by 1: the factory module path is 1 char longer than the class module path; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra189
# ---------------------------------------------------------------------------

invariant multiprocessing_extra189.mp_Queue_factory_name_eq:
  description: "multiprocessing.Queue.__name__.__eq__('Queue') returns True — multiprocessing.Queue is a bound method (factory) of the DefaultContext singleton defined in Lib/multiprocessing/context.py; Queue.__name__=='Queue' (len=5: Q(1)u(2)e(3)u(4)e(5)); the factory creates and returns a multiprocessing.queues.Queue instance; the factory pattern means that multiprocessing.Queue is a callable that returns a Queue, but is NOT a class — you cannot use it as multiprocessing.Queue.__bases__ (it has no bases); calling multiprocessing.Queue() creates a process-safe IPC queue that works across process boundaries using OS-level pipes and semaphores; NEW in extra189: first standalone multiprocessing.Queue factory __name__ invariant in mpqueue189 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: Queue.__name__.__eq__
  args: ["Queue"]
  expected: true

invariant multiprocessing_extra189.mp_Queue_factory_module_eq:
  description: "multiprocessing.Queue.__module__.__eq__('multiprocessing.context') returns True — Queue.__module__=='multiprocessing.context' (len=23: 'multiprocessing'=15+'.'=1+'context'=7=23); the factory method is defined in Lib/multiprocessing/context.py within the BaseContext class; DefaultContext (a singleton) binds all factory methods including Queue, Pipe, Pool, Lock, etc.; 'multiprocessing.context'=23 is the longest module path for any public multiprocessing name in the mpqueue189 namespace; compare: 'multiprocessing.queues'=22 (the actual class module) is 1 char shorter; 'context'=7 == 'process'=7 == 'queues'=6+1: context and process are both 7-char submodule names; NEW in extra189: standalone multiprocessing.Queue factory __module__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: Queue.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra189.mp_Queue_factory_class_is_method:
  description: "multiprocessing.Queue.__class__.__name__.__eq__('method') returns True — multiprocessing.Queue.__class__.__name__=='method' (len=6: m(1)e(2)t(3)h(4)o(5)d(6)); this confirms that multiprocessing.Queue is a bound method of the DefaultContext singleton rather than a class or standalone function; the DefaultContext instance (created once at module import time) has bound methods Queue, Pipe, Pool, Lock, Event, Semaphore, Value, Array, and Manager — all of these are factories that delegate to the appropriate class constructors in the chosen start method context (spawn, fork, or forkserver); 'method'=6 distinguishes multiprocessing.Queue from asyncio.Queue which is a class (asyncio.Queue.__class__.__name__=='type'); NEW in extra189: standalone Queue factory __class__.__name__ invariant establishing it is 'method'; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: Queue.__class__.__name__.__eq__
  args: ["method"]
  expected: true

invariant multiprocessing_extra189.mp_queues_Queue_name_eq:
  description: "multiprocessing.queues.Queue.__name__.__eq__('Queue') returns True — multiprocessing.queues.Queue is the actual Queue class (as distinct from the factory bound method at multiprocessing.Queue); queues.Queue.__name__=='Queue' (len=5); the class is defined in Lib/multiprocessing/queues.py; multiprocessing.queues.Queue uses OS-level IPC: internally it stores items via a serialized pipe (pickle over connection) and uses a multiprocessing.Semaphore to track the item count and block producers when the queue is full; it is safe to share across fork()ed child processes but NOT across independently spawned processes (spawn mode) without explicit passing via manager; NEW in extra189: first standalone multiprocessing.queues.Queue.__name__ invariant (distinguishing the class from the factory); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.queues.Queue.__name__.__eq__
  args: ["Queue"]
  expected: true

invariant multiprocessing_extra189.mp_queues_Queue_module_eq:
  description: "multiprocessing.queues.Queue.__module__.__eq__('multiprocessing.queues') returns True — queues.Queue.__module__=='multiprocessing.queues' (len=22: 'multiprocessing'=15+'.'=1+'queues'=6=22); the actual class lives in Lib/multiprocessing/queues.py; 'multiprocessing.queues'=22 is 1 char shorter than 'multiprocessing.context'=23 (the factory's module) because 'queues'=6 < 'context'=7; length ordering among multiprocessing submodule paths: 'multiprocessing.queues'(22) < 'multiprocessing.context'(23) == 'multiprocessing.process'(23); all three 'multiprocessing.*' paths start with the 15-char prefix; NEW in extra189: standalone multiprocessing.queues.Queue.__module__ invariant confirming the actual class module; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.queues.Queue.__module__.__eq__
  args: ["multiprocessing.queues"]
  expected: true

invariant multiprocessing_extra189.mp_queues_Queue_base_is_object:
  description: "multiprocessing.queues.Queue.__bases__[0].__name__.__eq__('object') returns True — queues.Queue.__bases__[0].__name__=='object' (len=6); the Queue class inherits directly from object with no intermediate base classes; this contrasts with asyncio.Queue which inherits from _LoopBoundMixin; multiprocessing.queues.Queue is a standalone pure-Python class that coordinates IPC via a pair of multiprocessing.connection.Connection objects (created by a Pipe), a Lock for mutual exclusion during put/get, a Semaphore for capacity tracking, and a JoinableQueue extends Queue with task_done/join for completion tracking; the direct-from-object inheritance keeps the class hierarchy simple while all synchronization is handled via composition with OS primitives; NEW in extra189: standalone Queue.__bases__[0].__name__ invariant for multiprocessing.queues.Queue; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.queues.Queue.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant multiprocessing_extra189.mp_queues_Queue_init_qualname_eq:
  description: "multiprocessing.queues.Queue.__init__.__qualname__.__eq__('Queue.__init__') returns True — queues.Queue.__init__.__qualname__=='Queue.__init__' (len=14: 'Queue'=5+'.'=1+'__init__'=8=14); Queue.__init__ accepts maxsize=0 (0 means unbounded), ctx (the multiprocessing context), and sets up: _reader/_writer (Connection pair from Pipe), _rlock (Lock for reader), _wlock (Lock for writer on non-Unix), _sem (BoundedSemaphore tracking capacity), _opid (opener PID for cross-fork safety); the use of a Pipe and separate read/write locks allows concurrent producers and consumers in different processes; 'Queue.__init__'=14 is the same length as asyncio.Queue.__init__.__qualname__ (also 14): both share the same init qualname length by coincidence; NEW in extra189: standalone queues.Queue.__init__.__qualname__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.queues.Queue.__init__.__qualname__.__eq__"
  args: ["Queue.__init__"]
  expected: true

invariant multiprocessing_extra189.mp_queues_Queue_put_qualname_eq:
  description: "multiprocessing.queues.Queue.put.__qualname__.__eq__('Queue.put') returns True — queues.Queue.put.__qualname__=='Queue.put' (len=9: 'Queue'=5+'.'=1+'put'=3=9); Queue.put(item, block=True, timeout=None) serializes item with pickle, acquires _wlock, decrements _sem (blocking if full and block=True), and writes to _writer (the Connection's send method); the pickle serialization requirement means only pickleable objects can be queued — this is a key difference from asyncio.Queue and threading.Queue which have no such requirement; put (9) < __init__ (14) by 5; 'Queue.put'=9 is the same qualname as asyncio.Queue.put.__qualname__ (also 9) and multiprocessing.queues.Queue.put.__qualname__ (also 9): all three Queue implementations share identical put qualname lengths; NEW in extra189: standalone queues.Queue.put.__qualname__ invariant completing the 8-item coverage; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.queues.Queue.put.__qualname__.__eq__
  args: ["Queue.put"]
  expected: true
