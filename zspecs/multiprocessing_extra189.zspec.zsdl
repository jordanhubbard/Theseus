spec: multiprocessing_extra189
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/queues.py"
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "multiprocessing.Queue is a bound method (factory function) on the context object, not a class; its __class__.__name__ == 'method' and __name__ == 'Queue'."
    - "multiprocessing.Queue.__module__ == 'multiprocessing.context' (len=23: 'multiprocessing'=15+'.'=1+'context'=7=23); the factory lives in the context module."
    - "multiprocessing.Queue.__class__.__name__ == 'method' — it is a bound method of the DefaultContext/BaseContext, not a class object."
    - "multiprocessing.queues.Queue.__name__ == 'Queue' — this is the actual Queue class in the queues submodule."
    - "multiprocessing.queues.Queue.__module__ == 'multiprocessing.queues' (len=22: 'multiprocessing'=15+'.'=1+'queues'=6=22)."
    - "multiprocessing.queues.Queue.__bases__[0].__name__ == 'object' — the actual class inherits directly from object."
    - "multiprocessing.queues.Queue.__init__.__qualname__ == 'Queue.__init__' (len=14)."
    - "multiprocessing.queues.Queue.put.__qualname__ == 'Queue.put' (len=9)."
    - "Length comparison: multiprocessing.queues (22) vs multiprocessing.context (23): context is 1 char longer."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.Queue factory identity
