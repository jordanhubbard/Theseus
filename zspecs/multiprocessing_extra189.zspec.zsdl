table multiprocessing_extra189.mp_queue_factory_identity:
  description: "multiprocessing.Queue factory (bound method) identity checks in mpqueue189 namespace — multiprocessing.Queue is NOT a class but a bound method on the DefaultContext/BaseContext object; Queue.__name__=='Queue' (the bound method retains the underlying function name 'Queue'); Queue.__module__=='multiprocessing.context' (len=23: 'multiprocessing'=15+'.'=1+'context'=7=23; the factory is defined in Lib/multiprocessing/context.py where DefaultContext binds all the factory methods); Queue.__class__.__name__=='method' (confirms it is a bound method of the context singleton, not a type); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpqueue189

  columns: [id, function, args, expected, description]
  rows:
    - [factory_name_eq,    Queue.__name__.__eq__,                 ["Queue"],                    true, "multiprocessing.Queue.__name__ == 'Queue' (bound method retains underlying function name); verified Python 3.14.3"]
    - [factory_module_eq,  Queue.__module__.__eq__,               ["multiprocessing.context"],  true, "multiprocessing.Queue.__module__ == 'multiprocessing.context' (len=23; factory lives in context module); verified Python 3.14.3"]
    - [factory_module_len, Queue.__module__.__len__,              [],                           23,   "multiprocessing.Queue.__module__.__len__() == 23 ('multiprocessing.context'=23: 'multiprocessing'=15+'.'=1+'context'=7=23); verified Python 3.14.3"]
    - [factory_class_eq,   Queue.__class__.__name__.__eq__,       ["method"],                   true, "multiprocessing.Queue.__class__.__name__ == 'method' (bound method of DefaultContext, not a class object); verified Python 3.14.3"]
    - [factory_name_len,   Queue.__name__.__len__,                [],                           5,    "multiprocessing.Queue.__name__.__len__() == 5 ('Queue'=5; same length as asyncio.Queue.__name__); verified Python 3.14.3"]

