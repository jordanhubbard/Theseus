spec: io_extra207
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra206.zspec.zsdl — covers io class __doc__.__class__.__name__ identity"
  notes:
    - "This spec covers io class __class__.__name__ (metaclass) identity not covered by prior io_extra specs."
    - "io.IOBase.__class__.__name__ == 'ABCMeta'; IOBase is an abstract base class whose metaclass is ABCMeta; confirmed Python 3.14.3 macOS."
    - "io.RawIOBase.__class__.__name__ == 'ABCMeta'; abstract base for raw binary I/O; metaclass is ABCMeta; confirmed Python 3.14.3 macOS."
    - "io.BufferedIOBase.__class__.__name__ == 'ABCMeta'; abstract base for buffered binary I/O; metaclass is ABCMeta; confirmed Python 3.14.3 macOS."
    - "io.TextIOBase.__class__.__name__ == 'ABCMeta'; abstract base for text-mode I/O; metaclass is ABCMeta; confirmed Python 3.14.3 macOS."
    - "io.FileIO.__class__.__name__ == 'type'; concrete raw binary file I/O class; metaclass is type; confirmed Python 3.14.3 macOS."
    - "io.BufferedReader.__class__.__name__ == 'type'; buffered binary reader; metaclass is type; confirmed Python 3.14.3 macOS."
    - "io.StringIO.__class__.__name__ == 'type'; in-memory text stream; metaclass is type; confirmed Python 3.14.3 macOS."
    - "io.BytesIO.__class__.__name__ == 'type'; in-memory binary stream; metaclass is type; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io abstract base class __class__.__name__ identity
# IOBase, RawIOBase, BufferedIOBase, TextIOBase — all 'ABCMeta'
# ---------------------------------------------------------------------------

table io_extra207.abstract_base_class_names:
  description: "io abstract base class __class__.__name__: IOBase, RawIOBase, BufferedIOBase, TextIOBase — all 'ABCMeta'"
  kind: python_call_eq
  category: metaclass_identity
  id_prefix: ioclasses207

  columns: [id, function, args, expected, description]
  rows:
    - [iobase_class_name,       io.IOBase.__class__.__name__.__eq__,       ["ABCMeta"], true, "io.IOBase.__class__.__name__ == 'ABCMeta'; IOBase is the abstract root of the io class hierarchy; its metaclass is ABCMeta; confirmed Python 3.14.3 macOS"]
    - [rawiobase_class_name,    io.RawIOBase.__class__.__name__.__eq__,    ["ABCMeta"], true, "io.RawIOBase.__class__.__name__ == 'ABCMeta'; abstract base for raw unbuffered binary I/O; metaclass is ABCMeta; confirmed Python 3.14.3 macOS"]
    - [bufferediobase_class_name, io.BufferedIOBase.__class__.__name__.__eq__, ["ABCMeta"], true, "io.BufferedIOBase.__class__.__name__ == 'ABCMeta'; abstract base for buffered binary I/O; metaclass is ABCMeta; confirmed Python 3.14.3 macOS"]
    - [textiobase_class_name,   io.TextIOBase.__class__.__name__.__eq__,   ["ABCMeta"], true, "io.TextIOBase.__class__.__name__ == 'ABCMeta'; abstract base for text-mode I/O; metaclass is ABCMeta; confirmed Python 3.14.3 macOS"]
    - [iobase_class_name_len,   io.IOBase.__class__.__name__.__len__,       [], 7, "io.IOBase.__class__.__name__.__len__() == 7 — 'ABCMeta' has A(1)B(2)C(3)M(4)e(5)t(6)a(7); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: io concrete binary class __class__.__name__ identity
# FileIO, BufferedReader — both 'type'
# ---------------------------------------------------------------------------

table io_extra207.concrete_binary_class_names:
  description: "io concrete binary class __class__.__name__: FileIO, BufferedReader — both 'type'"
  kind: python_call_eq
  category: metaclass_identity
  id_prefix: ioclasses207

  columns: [id, function, args, expected, description]
  rows:
    - [fileio_class_name,         io.FileIO.__class__.__name__.__eq__,         ["type"], true, "io.FileIO.__class__.__name__ == 'type'; raw binary file I/O class; metaclass is type; confirmed Python 3.14.3 macOS"]
    - [bufferedreader_class_name, io.BufferedReader.__class__.__name__.__eq__, ["type"], true, "io.BufferedReader.__class__.__name__ == 'type'; buffered binary reader; metaclass is type; confirmed Python 3.14.3 macOS"]
    - [fileio_class_name_len,     io.FileIO.__class__.__name__.__len__,         [], 4, "io.FileIO.__class__.__name__.__len__() == 4 — 'type' has t(1)y(2)p(3)e(4); confirmed Python 3.14.3 macOS"]
    - [bufferedreader_class_name_len, io.BufferedReader.__class__.__name__.__len__, [], 4, "io.BufferedReader.__class__.__name__.__len__() == 4 — 'type' has t(1)y(2)p(3)e(4); confirmed Python 3.14.3 macOS"]
    - [rawiobase_class_name_len,  io.RawIOBase.__class__.__name__.__len__,  [], 7, "io.RawIOBase.__class__.__name__.__len__() == 7 — 'ABCMeta' has A(1)B(2)C(3)M(4)e(5)t(6)a(7); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: io in-memory stream __class__.__name__ identity
# StringIO, BytesIO — both 'type'
# ---------------------------------------------------------------------------

table io_extra207.inmemory_stream_class_names:
  description: "io in-memory stream __class__.__name__: StringIO, BytesIO — both 'type'"
  kind: python_call_eq
  category: metaclass_identity
  id_prefix: ioclasses207

  columns: [id, function, args, expected, description]
  rows:
    - [stringio_class_name,      io.StringIO.__class__.__name__.__eq__,      ["type"], true, "io.StringIO.__class__.__name__ == 'type'; in-memory text stream; metaclass is type; confirmed Python 3.14.3 macOS"]
    - [bytesio_class_name,       io.BytesIO.__class__.__name__.__eq__,       ["type"], true, "io.BytesIO.__class__.__name__ == 'type'; in-memory binary stream; metaclass is type; confirmed Python 3.14.3 macOS"]
    - [stringio_class_name_len,  io.StringIO.__class__.__name__.__len__,      [], 4, "io.StringIO.__class__.__name__.__len__() == 4 — 'type' has t(1)y(2)p(3)e(4); confirmed Python 3.14.3 macOS"]
    - [bytesio_class_name_len,   io.BytesIO.__class__.__name__.__len__,       [], 4, "io.BytesIO.__class__.__name__.__len__() == 4 — 'type' has t(1)y(2)p(3)e(4); confirmed Python 3.14.3 macOS"]
    - [bufferediobase_class_name_len, io.BufferedIOBase.__class__.__name__.__len__, [], 7, "io.BufferedIOBase.__class__.__name__.__len__() == 7 — 'ABCMeta' has A(1)B(2)C(3)M(4)e(5)t(6)a(7); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra207.iobase_class_name:
  description: "io.IOBase.__class__.__name__ == 'ABCMeta' — IOBase is the abstract root of the io hierarchy; its metaclass is ABCMeta; confirmed Python 3.14.3 macOS"
  category: metaclass_identity
  kind: python_call_eq
  function: io.IOBase.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant io_extra207.rawiobase_class_name:
  description: "io.RawIOBase.__class__.__name__ == 'ABCMeta' — abstract base for raw binary I/O; metaclass is ABCMeta; confirmed Python 3.14.3 macOS"
  category: metaclass_identity
  kind: python_call_eq
  function: io.RawIOBase.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

