spec: functools_extra1516
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "Wave 548 theme: arithmetic/numeric operator protocol dict-presence checks — __add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__, __pow__ and reflected variants __radd__, __rmul__, __rsub__, __rtruediv__, __rfloordiv__, __rmod__, __rpow__ for functools classes."
    - "functools.partial: no arithmetic operator methods in __dict__. Verified with Python 3.12."
    - "functools.cached_property: no arithmetic operator methods in __dict__. Verified with Python 3.12."
    - "functools.singledispatchmethod: no arithmetic operator methods in __dict__. Verified with Python 3.12."
    - "functools.partialmethod: no arithmetic operator methods in __dict__. Verified with Python 3.12."
    - "None of the functools wrapper/descriptor classes are numeric types; they are callable wrappers and descriptors with no arithmetic operator support whatsoever."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial — arithmetic operator protocol absence checks
#
# Wave 548 theme: functools.partial — partial application of a callable.
#
# functools.partial.__dict__.__contains__("__add__") == False
# functools.partial.__dict__.__contains__("__mul__") == False
# functools.partial.__dict__.__contains__("__sub__") == False
# functools.partial.__dict__.__contains__("__truediv__") == False
# functools.partial.__dict__.__contains__("__radd__") == False
# functools.partial.__dict__.__contains__("__rmul__") == False
#
# partial is a synchronous callable wrapper. It does not implement any
# arithmetic operator protocol. Positive anchors: __call__ and __get__ are
# present. New to extra1516.
# ---------------------------------------------------------------------------

table functools_extra1516.partial_arithmetic_protocol_absence:
  description: "functools.partial has no arithmetic operator methods in __dict__; partial is a callable wrapper with no numeric support; wave 548; new to extra1516"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1516pa

  columns: [id, function, args, expected, description]
  rows:
    - [fu1516pa001,
       "partial.__dict__.__contains__",
       ["__add__"],
       false,
       "functools.partial.__dict__.__contains__('__add__') == False — partial is a synchronous callable wrapper that partially applies arguments to another callable; it is not a numeric type and does not implement the addition operator protocol; __add__ is not defined in partial.__dict__; verified with Python 3.12; new to extra1516"]
    - [fu1516pa002,
       "partial.__dict__.__contains__",
       ["__mul__"],
       false,
       "functools.partial.__dict__.__contains__('__mul__') == False — partial does not implement the multiplication operator protocol; __mul__ is not in partial.__dict__; verified with Python 3.12; new to extra1516"]
    - [fu1516pa003,
       "partial.__dict__.__contains__",
       ["__sub__"],
       false,
       "functools.partial.__dict__.__contains__('__sub__') == False — partial does not implement the subtraction operator protocol; __sub__ is not in partial.__dict__; verified with Python 3.12; new to extra1516"]
    - [fu1516pa004,
       "partial.__dict__.__contains__",
       ["__truediv__"],
       false,
       "functools.partial.__dict__.__contains__('__truediv__') == False — partial does not implement the true division operator protocol; __truediv__ is not in partial.__dict__; verified with Python 3.12; new to extra1516"]
    - [fu1516pa005,
       "partial.__dict__.__contains__",
       ["__radd__"],
       false,
       "functools.partial.__dict__.__contains__('__radd__') == False — partial does not implement the reflected addition operator protocol; __radd__ is not in partial.__dict__; verified with Python 3.12; new to extra1516"]
    - [fu1516pa006,
       "partial.__dict__.__contains__",
       ["__rmul__"],
       false,
       "functools.partial.__dict__.__contains__('__rmul__') == False — partial does not implement the reflected multiplication operator protocol; __rmul__ is not in partial.__dict__; verified with Python 3.12; new to extra1516"]
    - [fu1516pa007,
       "partial.__dict__.__contains__",
       ["__call__"],
       true,
       "functools.partial.__dict__.__contains__('__call__') == True — partial IS callable and defines __call__ in its __dict__; this is its primary synchronous interface and distinguishes it from arithmetic operator support which is wholly absent; verified with Python 3.12; new to extra1516"]

# ---------------------------------------------------------------------------
# Table 2: functools.cached_property — arithmetic operator protocol absence
# checks
#
# Wave 548 theme: functools.cached_property — descriptor that caches the
# result of a method as a per-instance attribute.
#
# functools.cached_property.__dict__.__contains__("__add__") == False
# functools.cached_property.__dict__.__contains__("__mul__") == False
# functools.cached_property.__dict__.__contains__("__floordiv__") == False
# functools.cached_property.__dict__.__contains__("__mod__") == False
# functools.cached_property.__dict__.__contains__("__pow__") == False
# functools.cached_property.__dict__.__contains__("__rsub__") == False
#
# cached_property is a synchronous data descriptor. It has __get__ and
# __set_name__ but no arithmetic operator methods. New to extra1516.
# ---------------------------------------------------------------------------

table functools_extra1516.cached_property_arithmetic_protocol_absence:
  description: "functools.cached_property has no arithmetic operator methods in __dict__; cached_property is a synchronous descriptor with no numeric support; wave 548; new to extra1516"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1516cp

  columns: [id, function, args, expected, description]
  rows:
    - [fu1516cp001,
       "cached_property.__dict__.__contains__",
       ["__add__"],
       false,
       "functools.cached_property.__dict__.__contains__('__add__') == False — cached_property is a synchronous descriptor that caches computed property values in the instance __dict__; it is not a numeric type and does not implement the addition operator protocol; __add__ is not in cached_property.__dict__; verified with Python 3.12; new to extra1516"]
    - [fu1516cp002,
       "cached_property.__dict__.__contains__",
       ["__mul__"],
       false,
       "functools.cached_property.__dict__.__contains__('__mul__') == False — cached_property does not implement the multiplication operator protocol; __mul__ is not in cached_property.__dict__; verified with Python 3.12; new to extra1516"]
    - [fu1516cp003,
       "cached_property.__dict__.__contains__",
       ["__floordiv__"],
       false,
       "functools.cached_property.__dict__.__contains__('__floordiv__') == False — cached_property does not implement the floor division operator protocol; __floordiv__ is not in cached_property.__dict__; verified with Python 3.12; new to extra1516"]
    - [fu1516cp004,
       "cached_property.__dict__.__contains__",
       ["__mod__"],
       false,
       "functools.cached_property.__dict__.__contains__('__mod__') == False — cached_property does not implement the modulo operator protocol; __mod__ is not in cached_property.__dict__; verified with Python 3.12; new to extra1516"]
    - [fu1516cp005,
       "cached_property.__dict__.__contains__",
       ["__pow__"],
       false,
       "functools.cached_property.__dict__.__contains__('__pow__') == False — cached_property does not implement the exponentiation operator protocol; __pow__ is not in cached_property.__dict__; verified with Python 3.12; new to extra1516"]
    - [fu1516cp006,
       "cached_property.__dict__.__contains__",
       ["__rsub__"],
       false,
       "functools.cached_property.__dict__.__contains__('__rsub__') == False — cached_property does not implement the reflected subtraction operator protocol; __rsub__ is not in cached_property.__dict__; verified with Python 3.12; new to extra1516"]
    - [fu1516cp007,
       "cached_property.__dict__.__contains__",
       ["__get__"],
       true,
       "functools.cached_property.__dict__.__contains__('__get__') == True — cached_property IS a descriptor and defines __get__ in its __dict__; this is its primary interface, distinct from any arithmetic operator protocol which is wholly absent; verified with Python 3.12; new to extra1516"]

# ---------------------------------------------------------------------------
# Table 3: functools.singledispatchmethod and partialmethod — arithmetic
# operator protocol absence checks
#
# Wave 548 theme: descriptor-based decorator classes.
#
# functools.singledispatchmethod.__dict__.__contains__("__add__") == False
# functools.singledispatchmethod.__dict__.__contains__("__mul__") == False
# functools.partialmethod.__dict__.__contains__("__sub__") == False
# functools.partialmethod.__dict__.__contains__("__truediv__") == False
# functools.singledispatchmethod.__dict__.__contains__("__rpow__") == False
# functools.partialmethod.__dict__.__contains__("__rfloordiv__") == False
#
# Both are synchronous descriptor decorators with no arithmetic support.
# Positive anchor: __get__ is present in both. New to extra1516.
# ---------------------------------------------------------------------------

table functools_extra1516.singledispatchmethod_partialmethod_arithmetic_protocol_absence:
  description: "functools.singledispatchmethod and partialmethod have no arithmetic operator methods in __dict__; both are synchronous descriptor decorators with no numeric support; wave 548; new to extra1516"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1516sd

  columns: [id, function, args, expected, description]
  rows:
    - [fu1516sd001,
       "singledispatchmethod.__dict__.__contains__",
       ["__add__"],
       false,
       "functools.singledispatchmethod.__dict__.__contains__('__add__') == False — singledispatchmethod is a descriptor for single-dispatch generic methods; it dispatches based on the type of the first non-self argument but does not implement the addition operator protocol; __add__ is not in singledispatchmethod.__dict__; verified with Python 3.12; new to extra1516"]
    - [fu1516sd002,
       "singledispatchmethod.__dict__.__contains__",
       ["__mul__"],
       false,
       "functools.singledispatchmethod.__dict__.__contains__('__mul__') == False — singledispatchmethod does not implement the multiplication operator protocol; __mul__ is not in singledispatchmethod.__dict__; verified with Python 3.12; new to extra1516"]
    - [fu1516sd003,
       "singledispatchmethod.__dict__.__contains__",
       ["__rpow__"],
       false,
       "functools.singledispatchmethod.__dict__.__contains__('__rpow__') == False — singledispatchmethod does not implement the reflected exponentiation operator protocol; __rpow__ is not in singledispatchmethod.__dict__; verified with Python 3.12; new to extra1516"]
    - [fu1516sd004,
       "partialmethod.__dict__.__contains__",
       ["__sub__"],
       false,
       "functools.partialmethod.__dict__.__contains__('__sub__') == False — partialmethod is a descriptor that creates partial methods for use inside class bodies; it does not implement the subtraction operator protocol; __sub__ is not in partialmethod.__dict__; verified with Python 3.12; new to extra1516"]
    - [fu1516sd005,
       "partialmethod.__dict__.__contains__",
       ["__truediv__"],
       false,
       "functools.partialmethod.__dict__.__contains__('__truediv__') == False — partialmethod does not implement the true division operator protocol; __truediv__ is not defined in partialmethod.__dict__; verified with Python 3.12; new to extra1516"]
    - [fu1516sd006,
       "partialmethod.__dict__.__contains__",
       ["__rfloordiv__"],
       false,
       "functools.partialmethod.__dict__.__contains__('__rfloordiv__') == False — partialmethod does not implement the reflected floor division operator protocol; __rfloordiv__ is not in partialmethod.__dict__; verified with Python 3.12; new to extra1516"]
    - [fu1516sd007,
       "singledispatchmethod.__dict__.__contains__",
       ["__get__"],
       true,
       "functools.singledispatchmethod.__dict__.__contains__('__get__') == True — singledispatchmethod IS a descriptor and defines __get__ in its __dict__; the descriptor protocol is its primary interface, not any arithmetic operator protocol; verified with Python 3.12; new to extra1516"]
    - [fu1516sd008,
       "partialmethod.__dict__.__contains__",
       ["__get__"],
       true,
       "functools.partialmethod.__dict__.__contains__('__get__') == True — partialmethod IS a descriptor and defines __get__ in its __dict__; descriptor protocol is its primary interface, not any arithmetic operator protocol; verified with Python 3.12; new to extra1516"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1516
# ---------------------------------------------------------------------------

invariant functools_extra1516.partial_no_add:
  description: "functools.partial.__dict__ does not contain '__add__' — partial is a callable wrapper, not a numeric type; wave 548; new to extra1516"
  kind: python_call_eq
  function: partial.__dict__.__contains__
  args: ["__add__"]
  expected: false

invariant functools_extra1516.partial_no_mul:
  description: "functools.partial.__dict__ does not contain '__mul__' — partial does not implement the multiplication operator protocol; wave 548; new to extra1516"
  kind: python_call_eq
  function: partial.__dict__.__contains__
  args: ["__mul__"]
  expected: false

invariant functools_extra1516.partial_no_radd:
  description: "functools.partial.__dict__ does not contain '__radd__' — partial does not implement the reflected addition operator protocol; wave 548; new to extra1516"
  kind: python_call_eq
  function: partial.__dict__.__contains__
  args: ["__radd__"]
  expected: false

invariant functools_extra1516.cached_property_no_add:
  description: "functools.cached_property.__dict__ does not contain '__add__' — cached_property is a descriptor, not a numeric type; wave 548; new to extra1516"
  kind: python_call_eq
  function: cached_property.__dict__.__contains__
  args: ["__add__"]
  expected: false

invariant functools_extra1516.cached_property_no_rmul:
  description: "functools.cached_property.__dict__ does not contain '__rmul__' — cached_property does not implement the reflected multiplication operator protocol; wave 548; new to extra1516"
  kind: python_call_eq
  function: cached_property.__dict__.__contains__
  args: ["__rmul__"]
  expected: false

invariant functools_extra1516.singledispatchmethod_no_sub:
  description: "functools.singledispatchmethod.__dict__ does not contain '__sub__' — singledispatchmethod is a dispatch descriptor, not a numeric type; wave 548; new to extra1516"
  kind: python_call_eq
  function: singledispatchmethod.__dict__.__contains__
  args: ["__sub__"]
  expected: false

invariant functools_extra1516.partialmethod_no_pow:
  description: "functools.partialmethod.__dict__ does not contain '__pow__' — partialmethod is a method-wrapping descriptor, not a numeric type; wave 548; new to extra1516"
  kind: python_call_eq
  function: partialmethod.__dict__.__contains__
  args: ["__pow__"]
  expected: false
