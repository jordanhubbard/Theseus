spec: abc_extra265
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "collections.abc.Set inherits from Collection; __bases__[0].__name__ == 'Collection'."
    - "collections.abc.MutableSet inherits from Set; __bases__[0].__name__ == 'Set'."
    - "collections.abc.KeysView, ValuesView, ItemsView each inherit from MappingView."
    - "collections.abc.MappingView.__bases__[0].__name__ == 'Sized'."
    - "collections.abc.ItemsView also inherits from Set — but __bases__[0].__name__ == 'MappingView'."
    - "All __module__ values == 'collections.abc'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Set and MutableSet class identity — table
#
# collections.abc.Set inherits from Collection.
# collections.abc.MutableSet inherits from Set.
# ---------------------------------------------------------------------------

table abc_extra265.set_abc_identity:
  description: "collections.abc Set and MutableSet report expected __name__, __module__, and base class names"
  kind: python_call_eq
  category: identity
  id_prefix: setabc

  columns: [id, function, args, expected, description]
  rows:
    - [set_name,        collections.abc.Set.__name__.__eq__,                   ["Set"],             true, "collections.abc.Set.__name__ == 'Set'"]
    - [set_module,      collections.abc.Set.__module__.__eq__,                 ["collections.abc"], true, "collections.abc.Set.__module__ == 'collections.abc'"]
    - [set_base,        "collections.abc.Set.__bases__[0].__name__.__eq__",    ["Collection"],      true, "collections.abc.Set.__bases__[0].__name__ == 'Collection'"]
    - [mset_name,       collections.abc.MutableSet.__name__.__eq__,            ["MutableSet"],      true, "collections.abc.MutableSet.__name__ == 'MutableSet'"]
    - [mset_base,       "collections.abc.MutableSet.__bases__[0].__name__.__eq__", ["Set"],         true, "collections.abc.MutableSet.__bases__[0].__name__ == 'Set'"]

# ---------------------------------------------------------------------------
# KeysView, ValuesView, ItemsView, MappingView identity — table
#
# All four view ABCs are defined in collections.abc.
# KeysView, ValuesView, ItemsView each inherit from MappingView.
# MappingView inherits from Sized.
# ---------------------------------------------------------------------------

table abc_extra265.view_abc_identity:
  description: "collections.abc view ABCs report expected __name__, __module__, and base class names"
  kind: python_call_eq
  category: identity
  id_prefix: viewabc

  columns: [id, function, args, expected, description]
  rows:
    - [keys_name,       collections.abc.KeysView.__name__.__eq__,              ["KeysView"],        true, "collections.abc.KeysView.__name__ == 'KeysView'"]
    - [keys_module,     collections.abc.KeysView.__module__.__eq__,            ["collections.abc"], true, "collections.abc.KeysView.__module__ == 'collections.abc'"]
    - [values_name,     collections.abc.ValuesView.__name__.__eq__,            ["ValuesView"],      true, "collections.abc.ValuesView.__name__ == 'ValuesView'"]
    - [items_name,      collections.abc.ItemsView.__name__.__eq__,             ["ItemsView"],       true, "collections.abc.ItemsView.__name__ == 'ItemsView'"]
    - [mapping_name,    collections.abc.MappingView.__name__.__eq__,           ["MappingView"],     true, "collections.abc.MappingView.__name__ == 'MappingView'"]

# ---------------------------------------------------------------------------
# Base class chains for view ABCs — standalone invariants
# ---------------------------------------------------------------------------

invariant abc_extra265.KeysView.bases0_name:
  description: "collections.abc.KeysView.__bases__[0].__name__ == 'MappingView'"
  category: identity
  kind: python_call_eq
  function: "collections.abc.KeysView.__bases__[0].__name__.__eq__"
  args: ["MappingView"]
  expected: true

invariant abc_extra265.ValuesView.bases0_name:
  description: "collections.abc.ValuesView.__bases__[0].__name__ == 'MappingView'"
  category: identity
  kind: python_call_eq
  function: "collections.abc.ValuesView.__bases__[0].__name__.__eq__"
  args: ["MappingView"]
  expected: true

invariant abc_extra265.ItemsView.bases0_name:
  description: "collections.abc.ItemsView.__bases__[0].__name__ == 'MappingView'"
  category: identity
  kind: python_call_eq
  function: "collections.abc.ItemsView.__bases__[0].__name__.__eq__"
  args: ["MappingView"]
  expected: true

invariant abc_extra265.MappingView.bases0_name:
  description: "collections.abc.MappingView.__bases__[0].__name__ == 'Sized'"
  category: identity
  kind: python_call_eq
  function: "collections.abc.MappingView.__bases__[0].__name__.__eq__"
  args: ["Sized"]
  expected: true

invariant abc_extra265.MutableSet.module:
  description: "collections.abc.MutableSet.__module__ == 'collections.abc'"
  category: identity
  kind: python_call_eq
  function: collections.abc.MutableSet.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra265.ValuesView.module:
  description: "collections.abc.ValuesView.__module__ == 'collections.abc'"
  category: identity
  kind: python_call_eq
  function: collections.abc.ValuesView.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra265.ItemsView.module:
  description: "collections.abc.ItemsView.__module__ == 'collections.abc'"
  category: identity
  kind: python_call_eq
  function: collections.abc.ItemsView.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra265.MappingView.module:
  description: "collections.abc.MappingView.__module__ == 'collections.abc'"
  category: identity
  kind: python_call_eq
  function: collections.abc.MappingView.__module__.__eq__
  args: ["collections.abc"]
  expected: true
