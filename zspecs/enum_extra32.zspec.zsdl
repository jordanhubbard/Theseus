spec: enum_extra32
version: ">=3.11"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum_extra31.zspec.zsdl."
    - "Prior specs covered: Enum/IntEnum/Flag __module__.__len__(), Enum/IntEnum/Flag/IntFlag/StrEnum/auto/unique __name__.__len__(), Enum/__qualname__.__len__() == 4, EnumMeta/__qualname__.__len__() == 8."
    - "This spec covers: __qualname__.__len__() for IntEnum, Flag, IntFlag, StrEnum, auto, unique, EnumType; __module__.__len__() for StrEnum, IntFlag, auto, unique, EnumType; and standalone qualname equality checks for EnumType and unique."
    - "All enum types have __module__ == 'enum' (len 4)."
    - "IntEnum/__qualname__ == 'IntEnum' (len 7); Flag/__qualname__ == 'Flag' (len 4); IntFlag/__qualname__ == 'IntFlag' (len 7); StrEnum/__qualname__ == 'StrEnum' (len 7)."
    - "auto/__qualname__ == 'auto' (len 4); unique/__qualname__ == 'unique' (len 6)."
    - "EnumType/__qualname__ == 'EnumType' (len 8) — EnumType is the alias for EnumMeta in Python 3.11+."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# enum classes __qualname__.__len__() — combined table
#
# enum_extra31 records Enum.__qualname__.__len__() == 4 and
# EnumMeta.__qualname__.__len__() == 8 as standalone invariants.
# This table adds the remaining enum types: IntEnum (7), Flag (4),
# IntFlag (7), StrEnum (7), auto (4), unique (6), EnumType (8).
# No prior enum spec records these __qualname__.__len__() values together
# in the extra32 namespace.
# ---------------------------------------------------------------------------

table enum_extra32.qualname_lens:
  description: "__qualname__.__len__() for enum types and functions"
  kind: python_call_eq
  category: qualname_attr_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [IntEnum,   IntEnum.__qualname__.__len__,   [], 7]
    - [Flag,      Flag.__qualname__.__len__,       [], 4]
    - [IntFlag,   IntFlag.__qualname__.__len__,    [], 7]
    - [StrEnum,   StrEnum.__qualname__.__len__,    [], 7]
    - [auto,      auto.__qualname__.__len__,       [], 4]
    - [unique,    unique.__qualname__.__len__,     [], 6]
    - [EnumType,  EnumType.__qualname__.__len__,   [], 8]

# ---------------------------------------------------------------------------
# enum types __module__.__len__() extended table
#
# enum_extra31 records __module__.__len__() for Enum, IntEnum, and Flag.
# This table extends coverage to StrEnum, IntFlag, auto, unique, and EnumType.
# All report __module__ == 'enum' (len 4). No prior enum spec records these
# __module__.__len__() values together in the extra32 namespace.
# ---------------------------------------------------------------------------

table enum_extra32.extended_module_lens:
  description: "__module__.__len__() for additional enum types — all 4"
  kind: python_call_eq
  category: module_attr_lengths
  id_prefix: module_len

  columns: [id, function, args, expected]
  rows:
    - [StrEnum,   StrEnum.__module__.__len__,   [], 4]
    - [IntFlag,   IntFlag.__module__.__len__,   [], 4]
    - [auto,      auto.__module__.__len__,       [], 4]
    - [unique,    unique.__module__.__len__,     [], 4]
    - [EnumType,  EnumType.__module__.__len__,   [], 4]

# ---------------------------------------------------------------------------
# enum.EnumType.__qualname__ — standalone equality invariant
#
# In Python 3.11+, EnumType is the canonical name for the enum metaclass
# (EnumMeta is the legacy alias). EnumType.__qualname__ == 'EnumType'.
# No prior enum spec records this equality check as a standalone invariant
# in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant enum_extra32.EnumType.qualname_eq:
  description: "enum.EnumType.__qualname__ == 'EnumType'"
  category: qualname_attr_lengths
  kind: python_call_eq
  function: EnumType.__qualname__.__eq__
  args: ["EnumType"]
  expected: true

# ---------------------------------------------------------------------------
# enum.EnumType.__qualname__.__len__() — standalone length invariant
#
# EnumType.__qualname__ == 'EnumType' (8 chars). Complements the standalone
# EnumMeta.__qualname__.__len__() invariant from enum_extra31 by using the
# canonical name. No prior enum spec records this in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant enum_extra32.EnumType.qualname_len:
  description: "len(enum.EnumType.__qualname__) == 8 — 'EnumType' is 8 chars"
  category: qualname_attr_lengths
  kind: python_call_eq
  function: EnumType.__qualname__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# enum.unique.__qualname__ — standalone equality invariant
#
# unique is a module-level decorator function; __qualname__ == __name__ == 'unique'.
# No prior enum spec records unique.__qualname__ as a standalone equality
# invariant in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant enum_extra32.unique.qualname_eq:
  description: "enum.unique.__qualname__ == 'unique'"
  category: qualname_attr_lengths
  kind: python_call_eq
  function: unique.__qualname__.__eq__
  args: ["unique"]
  expected: true

# ---------------------------------------------------------------------------
# enum.unique.__qualname__.__len__() — standalone length invariant
#
# unique.__qualname__ == 'unique' (6 chars). No prior enum spec records
# unique.__qualname__.__len__() as a standalone invariant in the extra32
# namespace.
# ---------------------------------------------------------------------------

invariant enum_extra32.unique.qualname_len:
  description: "len(enum.unique.__qualname__) == 6 — 'unique' is 6 chars"
  category: qualname_attr_lengths
  kind: python_call_eq
  function: unique.__qualname__.__len__
  args: []
  expected: 6
