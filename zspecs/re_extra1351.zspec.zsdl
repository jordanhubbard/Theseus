spec: re_extra1351
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module Pattern, Match, and error documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 537 (_extra1351): focuses on __slots__ and __weakref__ attribute checks at the class __dict__ level."
    - "re.error is a pure-Python exception class (subclass of Exception); it defines __weakref__ in its own __dict__ (True) because it is a top-level Python class, but not __slots__ or __dict__."
    - "re.Pattern is a C extension type (exposed as re.Pattern since Python 3.7); it does not define __slots__, __weakref__, or __dict__ in its class __dict__ — C extension type weak-reference support is handled at the C level."
    - "re.Match is a C extension type; like re.Pattern, it does not define __slots__, __weakref__, or __dict__ in its class __dict__."
    - "The contrast between re.error (Python class, __weakref__=True) and re.Pattern/re.Match (C extension types, __weakref__=False) illustrates the difference in how weak-reference support is recorded in class __dict__."
    - "re.error.__dict__.__contains__('__weakref__') is True — pure-Python exception class at the top of its own hierarchy adds the __weakref__ descriptor."
    - "re.Pattern.__dict__.__contains__('__slots__') is False — C extension types do not use the Python __slots__ mechanism."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table re_extra1351.error_slots_weakref_dict:
  description: "re.error __slots__, __weakref__, and __dict__ membership in class __dict__: re.error is a pure-Python exception class that defines __weakref__ (True) but not __slots__ or __dict__; verified with Python 3.12"
  kind: python_call_eq
  category: slots_weakref_dict_checks
  id_prefix: re1351er
  columns: [id, function, args, expected]
  rows:
    - [re1351er001, re.error.__dict__.__contains__, ["__slots__"],   false]
    - [re1351er002, re.error.__dict__.__contains__, ["__weakref__"], true]
    - [re1351er003, re.error.__dict__.__contains__, ["__dict__"],    false]
    - [re1351er004, re.Pattern.__dict__.__contains__, ["__slots__"],   false]
    - [re1351er005, re.Pattern.__dict__.__contains__, ["__weakref__"], false]
    - [re1351er006, re.Pattern.__dict__.__contains__, ["__dict__"],    false]

table re_extra1351.Match_slots_weakref_dict:
  description: "re.Match __slots__, __weakref__, and __dict__ membership in class __dict__: re.Match is a C extension type; it defines none of __slots__, __weakref__, or __dict__ in its class __dict__; verified with Python 3.12"
  kind: python_call_eq
  category: slots_weakref_dict_checks
  id_prefix: re1351ma
  columns: [id, function, args, expected]
  rows:
    - [re1351ma001, re.Match.__dict__.__contains__, ["__slots__"],   false]
    - [re1351ma002, re.Match.__dict__.__contains__, ["__weakref__"], false]
    - [re1351ma003, re.Match.__dict__.__contains__, ["__dict__"],    false]
    - [re1351ma004, re.error.__dict__.__contains__,   ["__weakref__"], true]
    - [re1351ma005, re.Pattern.__dict__.__contains__, ["__weakref__"], false]
    - [re1351ma006, re.Match.__dict__.__contains__,   ["__weakref__"], false]

table re_extra1351.cross_class_slots_weakref_summary:
  description: "Cross-class summary of __slots__ and __weakref__ presence across re module classes: re.error (Python class) defines __weakref__; re.Pattern and re.Match (C extension types) define neither __slots__ nor __weakref__ in their class __dict__; verified with Python 3.12"
  kind: python_call_eq
  category: slots_weakref_dict_checks
  id_prefix: re1351cx
  columns: [id, function, args, expected]
  rows:
    - [re1351cx001, re.error.__dict__.__contains__,   ["__slots__"],   false]
    - [re1351cx002, re.error.__dict__.__contains__,   ["__weakref__"], true]
    - [re1351cx003, re.Pattern.__dict__.__contains__, ["__slots__"],   false]
    - [re1351cx004, re.Pattern.__dict__.__contains__, ["__weakref__"], false]
    - [re1351cx005, re.Match.__dict__.__contains__,   ["__slots__"],   false]
    - [re1351cx006, re.Match.__dict__.__contains__,   ["__weakref__"], false]
