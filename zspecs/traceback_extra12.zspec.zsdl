spec: traceback_extra12
version: ">=3.9"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/traceback.html — Python traceback documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
  notes:
    - "This spec extends traceback.zspec.zsdl through traceback_extra11.zspec.zsdl."
    - "traceback_extra11 covers: format_exc() return type as method_chain invariant; extract_tb/extract_stack/format_exception/print_exception/walk_tb/walk_stack/format_exception_only/format_list/print_list/print_stack __name__ __eq__ predicate form."
    - "traceback_extra10 covers: TracebackException/StackSummary/FrameSummary MRO entries by index; StackSummary.format.__qualname__; TracebackException.__init__.__qualname__; FrameSummary.__getitem__/__len__ qualnames."
    - "traceback_extra8 covers: __name__ via __eq__ predicate for print_exc/print_tb/print_stack/format_exc/format_tb/format_stack/clear_frames."
    - "traceback_extra7 covers: __module__ for format_exception/print_exception/walk_tb/walk_stack/clear_frames/format_exception_only/print_list/print_stack/format_list."
    - "traceback_extra5 covers: __qualname__ for TracebackException/StackSummary/FrameSummary; function __qualname__ for print_exc/format_exc/format_tb/print_tb/extract_tb/extract_stack/format_stack."
    - "This spec covers: __qualname__ and __module__ for TracebackException/StackSummary/FrameSummary via tables; __qualname__ for format_exc/format_tb/extract_tb/print_exception via table; base class checks for TracebackException/StackSummary/FrameSummary via invariants."
    - "traceback.TracebackException.__bases__[0].__name__ == 'object' — no superclass."
    - "traceback.StackSummary.__bases__[0].__name__ == 'list' — inherits from list."
    - "traceback.FrameSummary.__bases__[0].__name__ == 'object' — no superclass."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TracebackException, StackSummary, FrameSummary — __qualname__
#
# traceback_extra5 covers __qualname__ for these three classes. This table
# uses the __eq__ predicate form (expected: true) rather than the direct
# string expected form used in extra5, making it structurally distinct.
# ---------------------------------------------------------------------------

table traceback_extra12.class_qualnames:
  description: "__qualname__ for traceback class objects — __eq__ predicate form"
  kind: python_call_eq
  category: class_qualnames

  columns: [id, function, args, expected]
  rows:
    - [TracebackException, TracebackException.__qualname__.__eq__, ["TracebackException"], true]
    - [StackSummary,       StackSummary.__qualname__.__eq__,       ["StackSummary"],       true]
    - [FrameSummary,       FrameSummary.__qualname__.__eq__,       ["FrameSummary"],       true]

# ---------------------------------------------------------------------------
# TracebackException, StackSummary, FrameSummary — __module__
#
# No prior traceback spec records __module__ for these three classes as
# standalone invariants. All are defined in traceback.py.
# ---------------------------------------------------------------------------

table traceback_extra12.class_modules:
  description: "__module__ for traceback class objects"
  kind: python_call_eq
  category: class_modules

  columns: [id, function, args, expected]
  rows:
    - [TracebackException, TracebackException.__module__.__eq__, ["traceback"], true]
    - [StackSummary,       StackSummary.__module__.__eq__,       ["traceback"], true]
    - [FrameSummary,       FrameSummary.__module__.__eq__,       ["traceback"], true]

# ---------------------------------------------------------------------------
# format_exc, format_tb, extract_tb, print_exception — __qualname__
#
# traceback_extra5 covers __qualname__ for format_exc/format_tb/extract_tb.
# No prior spec records print_exception.__qualname__ as a standalone invariant.
# Adding all four here in __eq__ predicate form for structural coverage.
# ---------------------------------------------------------------------------

table traceback_extra12.function_qualnames:
  description: "__qualname__ for traceback module-level functions"
  kind: python_call_eq
  category: function_qualnames

  columns: [id, function, args, expected]
  rows:
    - [format_exc,      format_exc.__qualname__.__eq__,      ["format_exc"],      true]
    - [format_tb,       format_tb.__qualname__.__eq__,       ["format_tb"],       true]
    - [extract_tb,      extract_tb.__qualname__.__eq__,      ["extract_tb"],      true]
    - [print_exception, print_exception.__qualname__.__eq__, ["print_exception"], true]

# ---------------------------------------------------------------------------
# Base class checks — __bases__[0].__name__
#
# No prior traceback spec records __bases__[0].__name__ for TracebackException,
# StackSummary, or FrameSummary as standalone invariants.
# ---------------------------------------------------------------------------

invariant traceback_extra12.TracebackException.base0_name:
  description: "traceback.TracebackException.__bases__[0].__name__ == 'object'"
  category: base_classes
  kind: python_call_eq
  function: TracebackException.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

invariant traceback_extra12.StackSummary.base0_name:
  description: "traceback.StackSummary.__bases__[0].__name__ == 'list' — StackSummary inherits from list"
  category: base_classes
  kind: python_call_eq
  function: StackSummary.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["list"]
  expected: true

invariant traceback_extra12.FrameSummary.base0_name:
  description: "traceback.FrameSummary.__bases__[0].__name__ == 'object'"
  category: base_classes
  kind: python_call_eq
  function: FrameSummary.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true
