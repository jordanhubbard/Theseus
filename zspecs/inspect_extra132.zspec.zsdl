spec: inspect_extra132
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.currentframe identity and inspect.stack/trace code attributes (Wave 257)."
    - "inspect.currentframe.__class__.__name__ == 'function' — currentframe is a thin Python wrapper around the C builtin sys._getframe. Verified with Python 3.14.3."
    - "inspect.currentframe.__module__ == 'inspect' — defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.currentframe.__qualname__ == 'currentframe' (len 12) — module-scope function. Verified with Python 3.14.3."
    - "inspect.stack.__code__.co_name == 'stack' — the def statement in Lib/inspect.py uses 'def stack'. Verified with Python 3.14.3."
    - "inspect.stack.__code__.co_argcount == 1 — stack takes a single positional argument (context). Verified with Python 3.14.3."
    - "inspect.stack.__code__.co_varnames[0] == 'context' — first local variable is the 'context' parameter. Verified with Python 3.14.3."
    - "len(inspect.stack.__code__.co_varnames) == 1 — stack has exactly one local variable (context). Verified with Python 3.14.3."
    - "inspect.trace.__code__.co_name == 'trace' — defined with 'def trace' in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.trace.__code__.co_argcount == 1 — trace takes a single positional argument (context). Verified with Python 3.14.3."
    - "inspect.trace.__code__.co_varnames[0] == 'context' — first local variable is the 'context' parameter. Verified with Python 3.14.3."
    - "len(inspect.trace.__code__.co_varnames) == 3 — trace has 3 local variables: context, exc, tb. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.currentframe identity attributes
#
# Wave 257 theme: inspect.currentframe class identity and qualname.
#
# inspect.currentframe.__class__.__name__ == 'function'
# inspect.currentframe.__module__ == 'inspect'
# inspect.currentframe.__qualname__ == 'currentframe'
# len(inspect.currentframe.__qualname__) == 12
#
# inspect.currentframe is a Python function defined in Lib/inspect.py that
# wraps the C builtin sys._getframe. It is not itself a C builtin.
# New to extra132.
# ---------------------------------------------------------------------------

table inspect_extra132.currentframe_identity:
  description: "inspect.currentframe class identity: __class__.__name__=='function', __module__=='inspect', __qualname__=='currentframe' len 12; wave 257; new to extra132"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectcurrentframe132

  columns: [id, function, args, expected, description]
  rows:
    - [currentframe_class_name_eq_function,
       "currentframe.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.currentframe.__class__.__name__.__eq__('function') == True — inspect.currentframe is a Python function defined in Lib/inspect.py; it wraps the C builtin sys._getframe but is itself a plain Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra132"]
    - [currentframe_module_eq_inspect,
       "currentframe.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.currentframe.__module__.__eq__('inspect') == True — currentframe is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra132"]
    - [currentframe_qualname_eq,
       "currentframe.__qualname__.__eq__",
       ["currentframe"],
       true,
       "inspect.currentframe.__qualname__.__eq__('currentframe') == True — currentframe is defined at module scope in Lib/inspect.py; its __qualname__ is the simple function name 'currentframe'; str.__eq__('currentframe') returns True; new to extra132"]
    - [currentframe_qualname_len_eq_12,
       "currentframe.__qualname__.__len__",
       [],
       12,
       "inspect.currentframe.__qualname__.__len__() == 12 — __qualname__ is 'currentframe' which is 12 characters; len('currentframe') == 12; new to extra132"]

# ---------------------------------------------------------------------------
# Table 2: inspect.stack code attributes
#
# Wave 257 theme: inspect.stack code object attributes.
#
# inspect.stack.__code__.co_name == 'stack'
# inspect.stack.__code__.co_argcount == 1
# inspect.stack.__code__.co_varnames[0] == 'context'
# len(inspect.stack.__code__.co_varnames) == 1
#
# inspect.stack is a Python function; its code object records the function
# name, argument count, and local variable names. New to extra132.
# ---------------------------------------------------------------------------

table inspect_extra132.stack_code_attrs:
  description: "inspect.stack code attrs: co_name=='stack', co_argcount==1, co_varnames[0]=='context', co_varnames len==1; wave 257; new to extra132"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectstack132

  columns: [id, function, args, expected, description]
  rows:
    - [stack_co_name_eq_stack,
       "stack.__code__.co_name.__eq__",
       ["stack"],
       true,
       "inspect.stack.__code__.co_name.__eq__('stack') == True — inspect.stack is defined with 'def stack(context=1):' in Lib/inspect.py; co_name is the name from the def statement; str.__eq__('stack') returns True; new to extra132"]
    - [stack_co_argcount_eq_1,
       "stack.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.stack.__code__.co_argcount.__eq__(1) == True — stack accepts one positional argument (context); co_argcount counts positional-or-keyword parameters; int.__eq__(1) returns True; new to extra132"]
    - [stack_co_varnames_first_eq_context,
       "stack.__code__.co_varnames[0].__eq__",
       ["context"],
       true,
       "inspect.stack.__code__.co_varnames[0].__eq__('context') == True — the first entry in co_varnames is always the first parameter; for inspect.stack that is 'context'; str.__eq__('context') returns True; new to extra132"]
    - [stack_co_varnames_len_eq_1,
       "stack.__code__.co_varnames.__len__",
       [],
       1,
       "inspect.stack.__code__.co_varnames.__len__() == 1 — co_varnames contains all local variable names; inspect.stack has exactly one local variable ('context'); len(co_varnames) is 1; new to extra132"]

# ---------------------------------------------------------------------------
# Table 3: inspect.trace code attributes
#
# Wave 257 theme: inspect.trace code object attributes.
#
# inspect.trace.__code__.co_name == 'trace'
# inspect.trace.__code__.co_argcount == 1
# inspect.trace.__code__.co_varnames[0] == 'context'
# len(inspect.trace.__code__.co_varnames) == 3
#
# inspect.trace is structurally similar to inspect.stack but has additional
# locals (exc, tb) for exception handling; its co_varnames length is 3.
# New to extra132.
# ---------------------------------------------------------------------------

table inspect_extra132.trace_code_attrs:
  description: "inspect.trace code attrs: co_name=='trace', co_argcount==1, co_varnames[0]=='context', co_varnames len==3; wave 257; new to extra132"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspecttrace132

  columns: [id, function, args, expected, description]
  rows:
    - [trace_co_name_eq_trace,
       "trace.__code__.co_name.__eq__",
       ["trace"],
       true,
       "inspect.trace.__code__.co_name.__eq__('trace') == True — inspect.trace is defined with 'def trace(context=1):' in Lib/inspect.py; co_name is the name from the def statement; str.__eq__('trace') returns True; new to extra132"]
    - [trace_co_argcount_eq_1,
       "trace.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.trace.__code__.co_argcount.__eq__(1) == True — trace accepts one positional argument (context); co_argcount is 1; int.__eq__(1) returns True; new to extra132"]
    - [trace_co_varnames_first_eq_context,
       "trace.__code__.co_varnames[0].__eq__",
       ["context"],
       true,
       "inspect.trace.__code__.co_varnames[0].__eq__('context') == True — the first entry in co_varnames is the first parameter; for inspect.trace that is 'context'; str.__eq__('context') returns True; new to extra132"]
    - [trace_co_varnames_len_eq_3,
       "trace.__code__.co_varnames.__len__",
       [],
       3,
       "inspect.trace.__code__.co_varnames.__len__() == 3 — co_varnames for trace contains 3 entries: 'context' (parameter), 'exc', and 'tb' (locals used during exception frame traversal); len(co_varnames) is 3; new to extra132"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra132
# ---------------------------------------------------------------------------

invariant inspect_extra132.currentframe_class_name:
  description: "inspect.currentframe.__class__.__name__ == 'function' — currentframe is a Python function wrapping sys._getframe; wave 257; new to extra132"
  kind: python_call_eq
  function: currentframe.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra132.currentframe_module:
  description: "inspect.currentframe.__module__ == 'inspect' — defined in Lib/inspect.py; wave 257; new to extra132"
  kind: python_call_eq
  function: currentframe.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra132.stack_co_name:
  description: "inspect.stack.__code__.co_name == 'stack' — co_name matches the def statement; wave 257; new to extra132"
  kind: python_call_eq
  function: stack.__code__.co_name.__eq__
  args: ["stack"]
  expected: true

invariant inspect_extra132.stack_co_argcount:
  description: "inspect.stack.__code__.co_argcount == 1 — stack takes one positional argument (context); wave 257; new to extra132"
  kind: python_call_eq
  function: stack.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra132.trace_co_varnames_len:
  description: "len(inspect.trace.__code__.co_varnames) == 3 — trace has locals context, exc, tb; wave 257; new to extra132"
  kind: python_call_eq
  function: trace.__code__.co_varnames.__len__
  args: []
  expected: 3
