spec: pathlib_extra2776
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 pathlib documentation — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
    - "pathlib_extra.zspec.zsdl — covers existing pathlib invariants"
    - "pathlib_extra2761.zspec.zsdl — covers __matmul__/__truediv__/__iadd__ dict-presence"
    - "pathlib_extra2746.zspec.zsdl — covers __round__/__divmod__/__pow__ dict-presence"
    - "pathlib_extra2731.zspec.zsdl — covers __trunc__/__floor__/__ceil__ dict-presence"
    - "pathlib_extra2716.zspec.zsdl — covers __neg__/__pos__/__abs__ dict-presence"
  notes:
    - "Wave 632 (pathlib_extra2776) theme: __isub__, __imul__, and __itruediv__ dict-presence checks."
    - "None of the pathlib classes define __isub__, __imul__, or __itruediv__ in their own __dict__."
    - "__isub__ supports the -= operator; pathlib path objects do not implement in-place subtraction semantics."
    - "__imul__ supports the *= operator; pathlib path objects do not implement in-place multiplication semantics."
    - "__itruediv__ supports the /= operator; although pathlib.PurePath defines __truediv__ for path joining (PurePath('a') / 'b'), it does NOT define __itruediv__ — path joining is not an in-place operation."
    - "Covers pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, and pathlib.Path."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __isub__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2776.no_isub_in_pathlib_classes:
  description: "__isub__ is absent from all pathlib class __dict__s — pathlib path objects do not implement the -= in-place subtraction protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2776

  columns: [id, function, args, expected]
  rows:
    - ["pp2776001", "pathlib.PurePath.__dict__.__contains__",        ["__isub__"], false]
    - ["pp2776002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__isub__"], false]
    - ["pp2776003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__isub__"], false]
    - ["pp2776004", "pathlib.Path.__dict__.__contains__",            ["__isub__"], false]

# ---------------------------------------------------------------------------
# __imul__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2776.no_imul_in_pathlib_classes:
  description: "__imul__ is absent from all pathlib class __dict__s — pathlib path objects do not implement the *= in-place multiplication protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2776

  columns: [id, function, args, expected]
  rows:
    - ["pp2776005", "pathlib.PurePath.__dict__.__contains__",        ["__imul__"], false]
    - ["pp2776006", "pathlib.PurePosixPath.__dict__.__contains__",   ["__imul__"], false]
    - ["pp2776007", "pathlib.PureWindowsPath.__dict__.__contains__", ["__imul__"], false]
    - ["pp2776008", "pathlib.Path.__dict__.__contains__",            ["__imul__"], false]

# ---------------------------------------------------------------------------
# __itruediv__ dict-presence — pathlib path classes
# PurePath defines __truediv__ for path joining but does NOT define __itruediv__
# ---------------------------------------------------------------------------

table pathlib_extra2776.no_itruediv_in_pathlib_classes:
  description: "__itruediv__ is absent from all pathlib class __dict__s — path joining uses __truediv__ but /= in-place assignment is not implemented by any pathlib class"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2776

  columns: [id, function, args, expected]
  rows:
    - ["pp2776009",  "pathlib.PurePath.__dict__.__contains__",        ["__itruediv__"], false]
    - ["pp2776010", "pathlib.PurePosixPath.__dict__.__contains__",   ["__itruediv__"], false]
    - ["pp2776011", "pathlib.PureWindowsPath.__dict__.__contains__", ["__itruediv__"], false]
    - ["pp2776012", "pathlib.Path.__dict__.__contains__",            ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# Complementary: PurePath has __truediv__ but not __itruediv__, __isub__, or __imul__
# Distinguishes the path-joining / operator from unsupported in-place arithmetic
# ---------------------------------------------------------------------------

table pathlib_extra2776.pathlib_truediv_but_not_inplace_arithmetic:
  description: "pathlib.PurePath defines __truediv__/__rtruediv__ for path joining but NOT __itruediv__/__isub__/__imul__; pathlib.Path defines stat/exists/open but none of the in-place arithmetic hooks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2776

  columns: [id, function, args, expected]
  rows:
    - ["pp2776013", "pathlib.PurePath.__dict__.__contains__", ["__truediv__"],  true]
    - ["pp2776014", "pathlib.PurePath.__dict__.__contains__", ["__rtruediv__"], true]
    - ["pp2776015", "pathlib.PurePath.__dict__.__contains__", ["__itruediv__"], false]
    - ["pp2776016", "pathlib.PurePath.__dict__.__contains__", ["__isub__"],     false]
    - ["pp2776017", "pathlib.PurePath.__dict__.__contains__", ["__imul__"],     false]
    - ["pp2776018", "pathlib.Path.__dict__.__contains__",     ["stat"],         true]
    - ["pp2776019", "pathlib.Path.__dict__.__contains__",     ["exists"],       true]
    - ["pp2776020", "pathlib.Path.__dict__.__contains__",     ["open"],         true]
    - ["pp2776021", "pathlib.Path.__dict__.__contains__",     ["__itruediv__"], false]
    - ["pp2776022", "pathlib.Path.__dict__.__contains__",     ["__isub__"],     false]
    - ["pp2776023", "pathlib.Path.__dict__.__contains__",     ["__imul__"],     false]
