spec: th3271
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 665 (th3271): __rand__, __ror__, __rxor__ dict-presence checks for threading types."
    - "Theme: __rand__/__ror__/__rxor__ reflected bitwise logical dict-presence."
    - "Reflected operators are called when the left operand doesn't support the operation."
    - "All values False — callable/iterator/inspection/synchronization types have no reflected bitwise logical operators."
    - "None of the threading types define __rand__, __ror__, or __rxor__ in their own __dict__."
    - "threading.Thread, threading.Event, threading.Condition, threading.Semaphore, threading.BoundedSemaphore, threading.Timer, threading.Barrier, and threading.local are Python-level classes."
    - "threading.Lock() returns a _thread.lock instance; type(threading.Lock()) is used to access its __dict__."
    - "threading.RLock() returns a _thread.RLock instance; type(threading.RLock()) is used to access its __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th3271.rand:
  description: "threading types __rand__ dict-presence checks; wave 665"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: th3271
  columns: [id, function, args, expected]
  rows:
    - ["th3271001", operator.contains, [threading.Thread.__dict__,           "__rand__"], false]
    - ["th3271002", operator.contains, [threading.Event.__dict__,            "__rand__"], false]
    - ["th3271003", operator.contains, [threading.Condition.__dict__,        "__rand__"], false]
    - ["th3271004", operator.contains, [threading.Semaphore.__dict__,        "__rand__"], false]
    - ["th3271005", operator.contains, [threading.BoundedSemaphore.__dict__, "__rand__"], false]
    - ["th3271006", operator.contains, [threading.Timer.__dict__,            "__rand__"], false]
    - ["th3271007", operator.contains, [threading.Barrier.__dict__,          "__rand__"], false]
    - ["th3271008", operator.contains, [threading.local.__dict__,            "__rand__"], false]
    - ["th3271009", operator.contains, [type(threading.Lock()).__dict__,     "__rand__"], false]
    - ["th3271010", operator.contains, [type(threading.RLock()).__dict__,    "__rand__"], false]

