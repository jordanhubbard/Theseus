spec: random_extra14
version: ">=3.9"
backend: python_module(random)

docs: https://docs.python.org/3/library/random.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/random.html — Python random module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/random.py"
  notes:
    - "This spec extends random.zspec.zsdl and prior extras through random_extra13.zspec.zsdl."
    - "random_extra3 covers randint/choice/shuffle/sample/seed/uniform/triangular/choices/gauss/expovariate/betavariate __name__."
    - "random_extra6 covers gammavariate/lognormvariate/vonmisesvariate/paretovariate/weibullvariate __qualname__ only — not __name__."
    - "random_extra13 covers randint/uniform/shuffle/sample/choices/randrange/seed __name__ and __module__."
    - "No prior spec records vonmisesvariate/__name__, paretovariate/__name__, or weibullvariate/__name__ via __eq__ call form."
    - "No prior spec records Random.__name__ as a standalone invariant (random.zspec covers it as a value, not via __eq__)."
    - "No prior spec covers random.choice.__name__ == 'choice' or random.sample.__name__ == 'sample' as standalone invariants (random_extra3 covers these in a table but random_extra13 does not repeat them)."
    - "random.vonmisesvariate.__name__ == 'vonmisesvariate' — circular normal distribution function."
    - "random.paretovariate.__name__ == 'paretovariate' — Pareto distribution function."
    - "random.weibullvariate.__name__ == 'weibullvariate' — Weibull distribution function."
    - "random.Random.__name__ == 'Random' — class name attribute."
    - "random.SystemRandom.__name__ == 'SystemRandom' — class name attribute."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Random and SystemRandom __name__ — standalone invariants
#
# random.zspec records Random.__name__ as an expected value; no prior spec
# tests it via __name__.__eq__ as a python_call_eq invariant.
# ---------------------------------------------------------------------------

invariant random_extra14.Random.name:
  description: "random.Random.__name__ == 'Random' — class name attribute"
  category: class_metadata
  kind: python_call_eq
  function: Random.__name__.__eq__
  args: ["Random"]
  expected: true

invariant random_extra14.SystemRandom.name:
  description: "random.SystemRandom.__name__ == 'SystemRandom' — class name attribute"
  category: class_metadata
  kind: python_call_eq
  function: SystemRandom.__name__.__eq__
  args: ["SystemRandom"]
  expected: true

# ---------------------------------------------------------------------------
# Distribution function __name__ attributes — vonmisesvariate, paretovariate,
# weibullvariate
#
# random_extra6 covers __qualname__ for these three functions. No prior spec
# records their __name__ attributes via __eq__ call. __name__ equals the
# bare function identifier for all module-level callables.
# ---------------------------------------------------------------------------

table random_extra14.distribution_names:
  kind: python_call_eq
  category: function_metadata
  id_prefix: dname

  columns: [id, function, args, expected]
  rows:
    - [vonmisesvariate, vonmisesvariate.__name__.__eq__, ["vonmisesvariate"], true]
    - [paretovariate,   paretovariate.__name__.__eq__,   ["paretovariate"],   true]
    - [weibullvariate,  weibullvariate.__name__.__eq__,  ["weibullvariate"],  true]
