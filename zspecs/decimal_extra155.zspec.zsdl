spec: decimal_extra155
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal arithmetic dunder method __qualname__ values and decimal rounding constant string values."
    - "All Decimal arithmetic dunder qualnames follow the 'Decimal.<method>' pattern. The 'Decimal.' prefix is 8 characters."
    - "decimal.Decimal.__add__.__qualname__ == 'Decimal.__add__' (len=15; 'Decimal.' (8) + '__add__' (7) = 15)."
    - "decimal.Decimal.__sub__.__qualname__ == 'Decimal.__sub__' (len=15; tied with __add__, __mul__, __mod__, __pow__ at 15)."
    - "decimal.Decimal.__mul__.__qualname__ == 'Decimal.__mul__' (len=15; five-way tie with __add__, __sub__, __mod__, __pow__ at 15)."
    - "decimal.Decimal.__truediv__.__qualname__ == 'Decimal.__truediv__' (len=19; 'Decimal.' (8) + '__truediv__' (11) = 19; the longest arithmetic dunder qualname in this spec)."
    - "decimal.Decimal.__mod__.__qualname__ == 'Decimal.__mod__' (len=15; tied with __add__, __sub__, __mul__, __pow__ at 15)."
    - "decimal.Decimal.__pow__.__qualname__ == 'Decimal.__pow__' (len=15; completes the five-way tie at 15)."
    - "Five-way tie at length 15: __add__, __sub__, __mul__, __mod__, __pow__ — all have 7-character dunder names ('__xxx__' format with 3-char operator name)."
    - "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP' (len=13; a string constant)."
    - "decimal.ROUND_DOWN == 'ROUND_DOWN' (len=10; a string constant)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal arithmetic dunder method __qualname__ values (group 1)
# __add__, __sub__, __mul__, __mod__ — all tied at length 15.
# Five-way tie: all are 7-character dunder names ('__xxx__' format).
# 'Decimal.' (8) + '__xxx__' (7) = 15 for all five arithmetic operators.
# ---------------------------------------------------------------------------

table decimal_extra155.Decimal_arithmetic_dunder_qualnames_group1:
  description: "decimal.Decimal arithmetic dunder __qualname__ values: __add__=__sub__=__mul__=__mod__='Decimal.__xxx__' (all len=15); four-way tie at 15; all use 'Decimal.' prefix"
  kind: python_call_eq
  category: qualname
  id_prefix: decarithq155

  columns: [id, function, args, expected, description]
  rows:
    - [add_qeq,  "Decimal.__add__.__qualname__.__eq__",  ["Decimal.__add__"],  true, "decimal.Decimal.__add__.__qualname__ == 'Decimal.__add__' (Decimal.__add__() implements the addition operator for Decimal objects; Decimal('1.1') + Decimal('2.2') gives Decimal('3.3') with exact decimal arithmetic unlike float arithmetic where 1.1 + 2.2 produces a rounding error; 'Decimal.__add__' has 15 characters: 'Decimal.' (8) + '__add__' (7) = 15; part of the five-way tie at length 15 with __sub__, __mul__, __mod__, __pow__ — all have 7-character dunder names of the form '__xxx__')"]
    - [sub_qeq,  "Decimal.__sub__.__qualname__.__eq__",  ["Decimal.__sub__"],  true, "decimal.Decimal.__sub__.__qualname__ == 'Decimal.__sub__' (Decimal.__sub__() implements the subtraction operator; Decimal subtraction is exact within the current context precision; 'Decimal.__sub__' has 15 characters: 'Decimal.' (8) + '__sub__' (7) = 15; tied with __add__, __mul__, __mod__, __pow__ at length 15; the five-way tie at 15 reflects that all five arithmetic operators (__add__, __sub__, __mul__, __mod__, __pow__) have 3-character abbreviated names sandwiched between double underscores)"]
    - [mul_qeq,  "Decimal.__mul__.__qualname__.__eq__",  ["Decimal.__mul__"],  true, "decimal.Decimal.__mul__.__qualname__ == 'Decimal.__mul__' (Decimal.__mul__() implements the multiplication operator; Decimal multiplication preserves precision according to the General Decimal Arithmetic specification; 'Decimal.__mul__' has 15 characters: 'Decimal.' (8) + '__mul__' (7) = 15; tied with __add__, __sub__, __mod__, __pow__ at 15; the five arithmetic dunders __add__, __sub__, __mul__, __mod__, __pow__ all use 3-letter abbreviations (add, sub, mul, mod, pow) as their core names)"]
    - [mod_qeq,  "Decimal.__mod__.__qualname__.__eq__",  ["Decimal.__mod__"],  true, "decimal.Decimal.__mod__.__qualname__ == 'Decimal.__mod__' (Decimal.__mod__() implements the modulo operator (%); Decimal modulo follows the General Decimal Arithmetic specification, differing from Python float modulo in edge cases involving NaN and sign; 'Decimal.__mod__' has 15 characters: 'Decimal.' (8) + '__mod__' (7) = 15; tied with __add__, __sub__, __mul__, __pow__ at 15; the five-way tie at qualname length 15 for Decimal arithmetic dunders is the defining structural fact of this spec)"]

# ---------------------------------------------------------------------------
# decimal.Decimal arithmetic dunder __qualname__ values (group 2) and rounding constants
# __pow__ (len=15) and __truediv__ (len=19).
# __truediv__ is the longest arithmetic dunder qualname in this spec.
# decimal.ROUND_HALF_UP == 'ROUND_HALF_UP' (len=13)
# decimal.ROUND_DOWN == 'ROUND_DOWN' (len=10)
# ---------------------------------------------------------------------------

table decimal_extra155.Decimal_arithmetic_dunder_qualnames_group2:
  description: "decimal.Decimal arithmetic dunders: __pow__='Decimal.__pow__' (len=15; completes five-way tie), __truediv__='Decimal.__truediv__' (len=19; the longest); rounding constants: ROUND_HALF_UP='ROUND_HALF_UP' (len=13), ROUND_DOWN='ROUND_DOWN' (len=10)"
  kind: python_call_eq
  category: qualname
  id_prefix: decarithq155

  columns: [id, function, args, expected, description]
  rows:
    - [pow_qeq,         "Decimal.__pow__.__qualname__.__eq__",                  ["Decimal.__pow__"],      true, "decimal.Decimal.__pow__.__qualname__ == 'Decimal.__pow__' (Decimal.__pow__() implements the exponentiation operator (**); Decimal('2') ** 10 == Decimal('1024'); 'Decimal.__pow__' has 15 characters: 'Decimal.' (8) + '__pow__' (7) = 15; completes the five-way tie at length 15 with __add__, __sub__, __mul__, __mod__; __pow__ has the same 3-letter core name 'pow' sandwiched between double underscores; Decimal.__pow__() respects context precision and can raise InvalidOperation for undefined cases like 0**0)"]
    - [truediv_qeq,     "Decimal.__truediv__.__qualname__.__eq__",               ["Decimal.__truediv__"], true, "decimal.Decimal.__truediv__.__qualname__ == 'Decimal.__truediv__' (Decimal.__truediv__() implements true division (/) for Decimal; Decimal('1') / Decimal('3') produces a finite approximation within the current context precision; 'Decimal.__truediv__' has 19 characters: 'Decimal.' (8) + '__truediv__' (11) = 19; the longest arithmetic dunder qualname in this spec; '__truediv__' (11 chars) is 4 characters longer than the 7-char dunders (__add__, __sub__, etc.) because 'truediv' (7 chars) is longer than the 3-char operator names)"]
    - [roundhalfup_eq,  decimal.ROUND_HALF_UP.__eq__,                           ["ROUND_HALF_UP"],        true, "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP' (ROUND_HALF_UP is a string constant used to specify rounding mode in decimal.Context or Decimal.quantize(); it means: round to nearest, with ties going away from zero (e.g., 2.5 rounds to 3, -2.5 rounds to -3); 'ROUND_HALF_UP' has 13 characters; ROUND_HALF_UP is the most familiar rounding mode to most users because it matches the common school-taught rounding rule)"]
    - [rounddown_eq,    decimal.ROUND_DOWN.__eq__,                               ["ROUND_DOWN"],           true, "decimal.ROUND_DOWN == 'ROUND_DOWN' (ROUND_DOWN is a string constant for the truncation rounding mode — round towards zero, discarding excess digits without rounding up; Decimal('2.9').quantize(Decimal('1'), rounding=ROUND_DOWN) == Decimal('2'); 'ROUND_DOWN' has 10 characters; ROUND_DOWN is 3 characters shorter than ROUND_HALF_UP (13) because it lacks the '_HALF_UP' suffix; both rounding constants are plain Python strings)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra155.Decimal_arithmetic_dunders_five_way_tie_at_15:
  description: "decimal.Decimal.__add__.__qualname__.__len__() == 15 — 'Decimal.__add__' has 15 characters: 'Decimal.' (8) + '__add__' (7) = 15; __add__ is part of a five-way tie at qualname length 15 with __sub__, __mul__, __mod__, and __pow__ — all five have 7-character arithmetic dunder names of the form '__xxx__' (2 underscores + 3-char operator name + 2 underscores = 7); the five-way tie at 15 for arithmetic dunders contrasts with the earlier five-way tie at 14 for comparison dunders (__lt__, __le__, __gt__, __ge__, __eq__) which use 6-char dunder names; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: "Decimal.__add__.__qualname__.__len__"
  args: []
  expected: 15

invariant decimal_extra155.Decimal_truediv_is_longest_at_19:
  description: "decimal.Decimal.__truediv__.__qualname__.__len__() == 19 — 'Decimal.__truediv__' has 19 characters: 'Decimal.' (8) + '__truediv__' (11) = 19; the longest arithmetic dunder qualname in this spec; '__truediv__' (11 chars) is 4 characters longer than the 7-char dunders (__add__, __sub__, __mul__, __mod__, __pow__) because 'truediv' (7 chars) is longer than 'add', 'sub', 'mul', 'mod', 'pow' (all 3 chars); the complete length ranking: __add__=__sub__=__mul__=__mod__=__pow__=15, __truediv__=19; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: "Decimal.__truediv__.__qualname__.__len__"
  args: []
  expected: 19

invariant decimal_extra155.ROUND_HALF_UP_is_string_len_13:
  description: "decimal.ROUND_HALF_UP.__len__() == 13 — 'ROUND_HALF_UP' has 13 characters; decimal rounding mode constants are plain Python strings (not enums or integers); ROUND_HALF_UP is the most commonly used rounding mode, matching the 'round half away from zero' rule taught in schools; it differs from Python's built-in round() which uses ROUND_HALF_EVEN (banker's rounding); 'ROUND_HALF_UP' (13) is 3 characters longer than 'ROUND_DOWN' (10); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.ROUND_HALF_UP.__len__
  args: []
  expected: 13

invariant decimal_extra155.ROUND_DOWN_is_string_len_10:
  description: "decimal.ROUND_DOWN.__len__() == 10 — 'ROUND_DOWN' has 10 characters; ROUND_DOWN is the truncation rounding mode (round towards zero), discarding excess digits without rounding up; it is the shortest rounding constant name in this spec at 10 characters; 'ROUND_DOWN' (10) is 3 characters shorter than 'ROUND_HALF_UP' (13); decimal rounding mode constants are plain Python strings, making their __len__() and __eq__() methods directly usable for verification; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.ROUND_DOWN.__len__
  args: []
  expected: 10

