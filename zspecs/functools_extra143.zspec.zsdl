spec: functools_extra143
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.partialmethod — class identity, __get__, _make_unbound_method, __repr__, __isabstractmethod__ fget, __module__, __bases__[0].__name__, MRO (Wave 266)."
    - "functools.partialmethod is a Python class (type), not a C extension type. Verified with Python 3.14.3."
    - "functools.partialmethod.__class__.__name__ == 'type' — metaclass is the built-in type. Verified with Python 3.14.3."
    - "functools.partialmethod.__module__ == 'functools' (len 9). Verified with Python 3.14.3."
    - "functools.partialmethod.__name__ == 'partialmethod' (len 13). Verified with Python 3.14.3."
    - "functools.partialmethod.__bases__[0].__name__ == 'object' — partialmethod directly inherits object. Verified with Python 3.14.3."
    - "len(functools.partialmethod.__mro__) == 2 — MRO is [partialmethod, object]. Verified with Python 3.14.3."
    - "functools.partialmethod.__init__.__qualname__ == 'object.__init__' (len 15) — partialmethod does not define __init__; it is inherited from object. Verified with Python 3.14.3."
    - "functools.partialmethod.__get__.__qualname__ == 'partialmethod.__get__' (len 21) — __get__ is a Python function defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.partialmethod.__get__.__code__.co_argcount == 3 — takes self, obj, cls. Verified with Python 3.14.3."
    - "len(functools.partialmethod.__get__.__code__.co_varnames) == 6 — self, obj, cls, get, result, new_func. Verified with Python 3.14.3."
    - "functools.partialmethod._make_unbound_method.__qualname__ == 'partialmethod._make_unbound_method' (len 34). Verified with Python 3.14.3."
    - "functools.partialmethod._make_unbound_method.__code__.co_argcount == 1 — takes only self. Verified with Python 3.14.3."
    - "len(functools.partialmethod._make_unbound_method.__code__.co_varnames) == 2 — self, _method. Verified with Python 3.14.3."
    - "functools.partialmethod.__repr__.__qualname__ == '_partial_repr' (len 13) — __repr__ on partialmethod is the shared _partial_repr function. Verified with Python 3.14.3."
    - "functools.partialmethod.__dict__['__isabstractmethod__'] is a property; its fget.__qualname__ == 'partialmethod.__isabstractmethod__' (len 34). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

