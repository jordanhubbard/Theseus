spec: uuid_extra85
version: ">=3.9"
extends: uuid_extra84
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra84.zspec.zsdl — covers uuid.UUID/__name__/__module__/__qualname__/__class__.__name__ / UUID/__bases__/__mro__ / SafeUUID class identity / uuid namespace and reserved constant class names (table + invariants)."
    - "uuid_extra83.zspec.zsdl — covers UUID dunder method __qualname__ lengths / UUID string and numeric property fget __qualname__ lengths / module-level uuid function qualname equality (table + invariants)."
    - "uuid_extra82.zspec.zsdl — covers uuid.SafeUUID enum member class identity / uuid module identity (__name__/__package__/__spec__/__loader__) (table + invariants)."
    - "uuid_extra80.zspec.zsdl — covers UUID property __class__.__name__ identity / SafeUUID class identity (__name__/__module__/__qualname__/__bases__[0].__name__) / SafeUUID.__mro__.__len__()==3 (table + invariants)."
    - "uuid_extra79.zspec.zsdl — covers UUID dunder method __qualname__.__eq__ / uuid1/uuid3/uuid4/uuid5 __qualname__.__eq__ / UUID.__name__/__module__.__eq__ (table + invariants)."
    - "uuid_extra78.zspec.zsdl — covers UUID.__dict__.__contains__ for __init__/__str__/__repr__/__eq__/__hash__/int/hex/bytes/variant/version / UUID.__dict__.__class__.__name__=='mappingproxy' / UUID.__mro__.__len__()==2 (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra84; it does NOT duplicate invariants present in those files."
    - "Wave 257 theme: uuid.UUID __dict__ membership for dunder methods and property names."
    - "uuid.UUID.__dict__.__contains__('__init__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__setattr__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__delattr__') == False. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__repr__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__str__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__hash__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__int__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__eq__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__lt__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('hex') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('bytes') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('bytes_le') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('fields') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('time_low') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('urn') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('variant') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('version') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('is_safe') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__class__.__name__ == 'mappingproxy'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__dict__.__class__.__name__ == 'mappingproxy'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid_extra78 anchors __contains__ for __init__/__str__/__repr__/__eq__/__hash__/hex/bytes/variant/version; this spec extends coverage to __setattr__/__delattr__/__int__/__lt__ and property names bytes_le/fields/time_low/urn/is_safe."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('__init__') == True (cross-check)
# uuid.UUID.__dict__.__contains__('__setattr__') == True
# uuid.UUID.__dict__.__contains__('__repr__') == True (cross-check)
# uuid.UUID.__dict__.__contains__('__str__') == True (cross-check)
# uuid.UUID.__dict__.__contains__('__hash__') == True (cross-check)
# uuid.UUID.__dict__.__contains__('__int__') == True
# uuid.UUID.__dict__.__contains__('__eq__') == True (cross-check)
# uuid.UUID.__dict__.__contains__('__lt__') == True
#
# Wave 257 theme: UUID __dict__ membership for dunder methods.
#
# UUID defines __init__, __setattr__, __repr__, __str__, __hash__, __int__,
# __eq__, and __lt__ directly in its class body. uuid_extra78 anchors
# __init__/__str__/__repr__/__eq__/__hash__ as present; this table extends
# coverage to __setattr__, __int__, and __lt__ under uuidmodule85.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra85.uuid_UUID_dict_dunder_methods:
  description: "uuid.UUID/__dict__/__contains__('__init__')==True / __contains__('__setattr__')==True / __contains__('__repr__')==True / __contains__('__str__')==True / __contains__('__hash__')==True / __contains__('__int__')==True / __contains__('__eq__')==True / __contains__('__lt__')==True — UUID defines all eight dunder methods directly in its __dict__; uuid_extra78 anchors __init__/__str__/__repr__/__eq__/__hash__; this table extends coverage to __setattr__/__int__/__lt__ under uuidmodule85; first uuidmodule85 anchor for UUID dunder method __dict__ membership"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidmodule85

  columns: [id, function, args, expected]
  rows:
    - [dict_has_init,      "UUID.__dict__.__contains__", ["__init__"],     true]
    - [dict_has_setattr,   "UUID.__dict__.__contains__", ["__setattr__"],  true]
    - [dict_has_repr,      "UUID.__dict__.__contains__", ["__repr__"],     true]
    - [dict_has_str,       "UUID.__dict__.__contains__", ["__str__"],      true]
    - [dict_has_hash,      "UUID.__dict__.__contains__", ["__hash__"],     true]
    - [dict_has_int,       "UUID.__dict__.__contains__", ["__int__"],      true]
    - [dict_has_eq,        "UUID.__dict__.__contains__", ["__eq__"],       true]
    - [dict_has_lt,        "UUID.__dict__.__contains__", ["__lt__"],       true]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('hex') == True (cross-check)
# uuid.UUID.__dict__.__contains__('bytes') == True (cross-check)
# uuid.UUID.__dict__.__contains__('bytes_le') == True
# uuid.UUID.__dict__.__contains__('fields') == True
# uuid.UUID.__dict__.__contains__('time_low') == True
# uuid.UUID.__dict__.__contains__('urn') == True
# uuid.UUID.__dict__.__contains__('variant') == True (cross-check)
# uuid.UUID.__dict__.__contains__('version') == True (cross-check)
# uuid.UUID.__dict__.__contains__('is_safe') == True
#
# Wave 257 theme: UUID __dict__ membership for property names.
#
# UUID defines hex, bytes, bytes_le, fields, time_low, urn, variant, version,
# and is_safe as properties in its class body. uuid_extra78 anchors
# hex/bytes/variant/version; this table extends coverage to bytes_le, fields,
# time_low, urn, and is_safe under uuidmodule85.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra85.uuid_UUID_dict_properties:
  description: "uuid.UUID/__dict__/__contains__('hex')==True / __contains__('bytes')==True / __contains__('bytes_le')==True / __contains__('fields')==True / __contains__('time_low')==True / __contains__('urn')==True / __contains__('variant')==True / __contains__('version')==True / __contains__('is_safe')==True — UUID defines nine properties in its __dict__; uuid_extra78 anchors hex/bytes/variant/version; this table extends to bytes_le/fields/time_low/urn/is_safe under uuidmodule85; first uuidmodule85 anchor for UUID property __dict__ membership"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidmodule85

  columns: [id, function, args, expected]
  rows:
    - [dict_has_hex,      "UUID.__dict__.__contains__", ["hex"],      true]
    - [dict_has_bytes,    "UUID.__dict__.__contains__", ["bytes"],    true]
    - [dict_has_bytes_le, "UUID.__dict__.__contains__", ["bytes_le"], true]
    - [dict_has_fields,   "UUID.__dict__.__contains__", ["fields"],   true]
    - [dict_has_time_low, "UUID.__dict__.__contains__", ["time_low"], true]
    - [dict_has_urn,      "UUID.__dict__.__contains__", ["urn"],      true]
    - [dict_has_variant,  "UUID.__dict__.__contains__", ["variant"],  true]
    - [dict_has_version,  "UUID.__dict__.__contains__", ["version"],  true]
    - [dict_has_is_safe,  "UUID.__dict__.__contains__", ["is_safe"],  true]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('__delattr__') == False
#
# Wave 257 theme: UUID __dict__ negative membership.
#
# uuid.UUID does NOT define __delattr__ in its class body; __delattr__ is
# inherited from object. This negative membership test distinguishes UUID's
# own dict from inherited attrs. No prior uuid spec anchors
# UUID.__dict__.__contains__('__delattr__') as False under uuidmodule85.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra85.uuid_UUID_dict_negative_membership:
  description: "uuid.UUID/__dict__/__contains__('__delattr__')==False — UUID does NOT define __delattr__ in its own __dict__; it inherits __delattr__ from object; this negative test distinguishes UUID's own dict from inherited attrs; no prior uuid spec anchors this under uuidmodule85; first uuidmodule85 anchor for UUID __dict__ negative membership"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidmodule85

  columns: [id, function, args, expected]
  rows:
    - [dict_no_delattr, "UUID.__dict__.__contains__", ["__delattr__"], false]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__class__.__name__.__eq__('mappingproxy')
# uuid.SafeUUID.__dict__.__class__.__name__.__eq__('mappingproxy')
#
# Wave 257 theme: UUID and SafeUUID __dict__ class names.
#
# Both uuid.UUID.__dict__ and uuid.SafeUUID.__dict__ are mappingproxy objects
# (the standard read-only view of a class's namespace). uuid_extra78 first
# anchors UUID.__dict__.__class__.__name__=='mappingproxy'; this table
# cross-checks UUID and adds SafeUUID under uuidmodule85.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra85.uuid_dict_class_names:
  description: "uuid.UUID/__dict__/__class__/__name__.__eq__('mappingproxy')==True / SafeUUID/__dict__/__class__/__name__.__eq__('mappingproxy')==True — both UUID and SafeUUID __dict__ are mappingproxy read-only views of the class namespace; uuid_extra78 first anchors UUID.__dict__.__class__.__name__; this table cross-checks UUID and adds SafeUUID under uuidmodule85; first uuidmodule85 anchor for UUID/SafeUUID __dict__ class names"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidmodule85

  columns: [id, function, args, expected]
  rows:
    - [uuid_dict_mappingproxy,    UUID.__dict__.__class__.__name__.__eq__,    ["mappingproxy"], true]
    - [safeuuid_dict_mappingproxy, SafeUUID.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('__setattr__') == True — standalone
#
# uuid.UUID.__dict__.__contains__('__setattr__') is True. UUID defines
# __setattr__ to enforce immutability after construction. No prior uuid spec
# anchors UUID.__dict__.__contains__('__setattr__') as a standalone.
# First standalone for UUID __setattr__ dict membership under uuidmodule85.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra85.uuid_dict_has_setattr:
  description: "uuid.UUID.__dict__.__contains__('__setattr__') == True — UUID defines __setattr__ in its own __dict__ to enforce immutability (frozen after construction); no prior uuid spec anchors this as a standalone; first standalone for UUID.__setattr__ __dict__ membership under uuidmodule85"
  category: type_identity
  kind: python_call_eq
  function: "UUID.__dict__.__contains__"
  args: ["__setattr__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('is_safe') == True — standalone
#
# uuid.UUID.__dict__.__contains__('is_safe') is True. is_safe is a property
# introduced in Python 3.7 to indicate whether the UUID was generated using
# a platform-specific safe generator. No prior uuid spec anchors is_safe dict
# membership as a standalone under uuidmodule85. First standalone for UUID.is_safe.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra85.uuid_dict_has_is_safe:
  description: "uuid.UUID.__dict__.__contains__('is_safe') == True — uuid.UUID.is_safe is a property (added in Python 3.7) stored in UUID.__dict__; it indicates whether the UUID was generated using a platform-specific safe generator; no prior uuid spec anchors this as a standalone; first standalone for UUID.is_safe __dict__ membership under uuidmodule85"
  category: type_identity
  kind: python_call_eq
  function: "UUID.__dict__.__contains__"
  args: ["is_safe"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('__delattr__') == False — standalone
#
# uuid.UUID.__dict__.__contains__('__delattr__') is False. UUID inherits
# __delattr__ from object without overriding it. This confirms UUID does not
# have a custom __delattr__. No prior uuid spec anchors this negative
# membership as a standalone under uuidmodule85.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra85.uuid_dict_no_delattr:
  description: "uuid.UUID.__dict__.__contains__('__delattr__') == False — UUID does not define __delattr__ in its own class dict; it inherits __delattr__ from object; this distinguishes UUID's explicit definitions from inherited attributes; no prior uuid spec anchors this negative test as a standalone; first standalone for UUID.__delattr__ negative dict membership under uuidmodule85"
  category: type_identity
  kind: python_call_eq
  function: "UUID.__dict__.__contains__"
  args: ["__delattr__"]
  expected: false

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__class__.__name__.__eq__('mappingproxy') — standalone
#
# uuid.UUID.__dict__.__class__.__name__ is 'mappingproxy'. uuid_extra78 first
# anchors this; this standalone re-anchors it under uuidmodule85.
# The mappingproxy protects the class __dict__ from direct mutation.
# First standalone for UUID.__dict__ class name under uuidmodule85.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra85.uuid_dict_mappingproxy:
  description: "uuid.UUID.__dict__.__class__.__name__.__eq__('mappingproxy') == True — UUID.__dict__ is a mappingproxy providing a read-only view of the class namespace; uuid_extra78 first anchors this; this standalone re-anchors under uuidmodule85; first standalone for UUID.__dict__ class name under uuidmodule85"
  category: type_identity
  kind: python_call_eq
  function: UUID.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__dict__.__class__.__name__.__eq__('mappingproxy') — standalone
#
# uuid.SafeUUID.__dict__.__class__.__name__ is 'mappingproxy'. SafeUUID is an
# Enum subclass; its __dict__ is also a mappingproxy. No prior uuid spec
# anchors SafeUUID.__dict__.__class__.__name__.__eq__ as a standalone under
# uuidmodule85. First standalone for SafeUUID __dict__ class name.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra85.safeuuid_dict_mappingproxy:
  description: "uuid.SafeUUID.__dict__.__class__.__name__.__eq__('mappingproxy') == True — SafeUUID is an Enum subclass; its __dict__ is a mappingproxy (read-only view of the class namespace) like all Python class dicts; no prior uuid spec anchors this as a standalone; first standalone for SafeUUID.__dict__ class name under uuidmodule85"
  category: type_identity
  kind: python_call_eq
  function: SafeUUID.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true
