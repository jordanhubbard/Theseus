spec: url_join
version: ">=5.0.0"
backend: node(url-join)

docs: https://www.npmjs.com/package/url-join

provenance:
  derived_from:
    - "url-join README — https://www.npmjs.com/package/url-join"
    - "Test vectors verified with url-join via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "url-join source"
  notes:
    - "url-join is an npm package. Install: npm install url-join"
    - "Joins URL parts, normalizing slashes. ESM package; use function: default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a joined URL string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table url_join.urlJoin:
  kind: node_module_call_eq
  function: "default"
  category: transform
  id_prefix: urljoin

  columns: [id, args, expected]
  rows:
    - [three_parts,     ["http://a.com", "b", "c"],  "http://a.com/b/c"]
    - [trailing_slash,  ["http://a.com/", "/b/"],    "http://a.com/b/"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T01:13:05Z
  iterations: 1
  pass_count: 2
  fail_count: 0
  total_invariants: 2
  notes: Synthesis succeeded in 1 iteration(s). 2 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
