spec: pathlib_extra172
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.PurePath class identity (__name__, __module__, __bases__[0].__name__), and PurePosixPath and PureWindowsPath class identity."
    - "pathlib.PurePath.__name__ == 'PurePath' (len=8: 'Pure' (4) + 'Path' (4) = 8)."
    - "pathlib.PurePath.__module__ == 'pathlib' (len=7)."
    - "pathlib.PurePath.__bases__[0].__name__ == 'object' (len=6) — PurePath inherits directly from object."
    - "pathlib.PurePosixPath.__name__ == 'PurePosixPath' (len=13: 'Pure' (4) + 'Posix' (5) + 'Path' (4) = 13)."
    - "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' (len=8) — PurePosixPath inherits from PurePath."
    - "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath' (len=15: 'Pure' (4) + 'Windows' (7) + 'Path' (4) = 15)."
    - "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' (len=8) — PureWindowsPath inherits from PurePath."
    - "Name length ranking: PurePath=8, PurePosixPath=13, PureWindowsPath=15."
    - "PurePosixPath (13) is 5 longer than PurePath (8) — the 'Posix' infix (5 chars) is inserted between 'Pure' and 'Path'."
    - "PureWindowsPath (15) is 7 longer than PurePath (8) — the 'Windows' infix (7 chars) is inserted between 'Pure' and 'Path'."
    - "PureWindowsPath (15) is 2 longer than PurePosixPath (13) — 'Windows' (7) is 2 longer than 'Posix' (5)."
    - "All three pure path classes have __module__ == 'pathlib' (7 chars) — they all live in the public pathlib module."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath class identity
# __name__ == 'PurePath' (len=8), __module__ == 'pathlib' (len=7)
# __bases__[0].__name__ == 'object' (len=6)
# PurePath inherits directly from object — top of the pure path hierarchy.
# ---------------------------------------------------------------------------

table pathlib_extra172.PurePath_class_identity:
  description: "pathlib.PurePath class identity: __name__=='PurePath' (len=8), __module__=='pathlib' (len=7), __bases__[0].__name__=='object' (len=6); PurePath is the root of the pure path class hierarchy, inheriting directly from object"
  kind: python_call_eq
  category: identity
  id_prefix: ppid172

  columns: [id, function, args, expected, description]
  rows:
    - [pure_name,    PurePath.__name__.__eq__,                ["PurePath"], true, "pathlib.PurePath.__name__ == 'PurePath' (PurePath is the abstract base class for all pathlib path classes that do not perform filesystem I/O; 'PurePath' has 8 characters: 'Pure' (4) + 'Path' (4) = 8; the 'Pure' prefix signals no I/O — a pure path operates on path strings without touching the filesystem; PurePath (8 chars) is the shortest name among the three pure path classes: PurePath (8) < PurePosixPath (13) < PureWindowsPath (15); the subclass names are formed by inserting an OS-specific infix between 'Pure' and 'Path': 'Posix' (5) for PurePosixPath and 'Windows' (7) for PureWindowsPath; PurePath.__name__ (8 chars) equals len('suffixes') == 8 from pathlib_extra170 — a coincidental tie between the class name and a property name length)"]
    - [pure_module,  PurePath.__module__.__eq__,              ["pathlib"],  true, "pathlib.PurePath.__module__ == 'pathlib' (PurePath is defined in the public 'pathlib' module; 'pathlib' has 7 characters; PurePath.__module__ (7 chars) is the same for all six pathlib path classes: PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath, WindowsPath — they all have __module__ == 'pathlib'; the uniform 7-character module name across all pathlib classes contrasts with the io module hierarchy where some classes have __module__ == '_io' (3 chars) and others have __module__ == 'io' (2 chars); 'pathlib' (7 chars) == len('PurePath') - 1 == 8 - 1 == 7: the module name is 1 character shorter than the base class name PurePath (8))"]
    - [pure_base0,   "PurePath.__bases__[0].__name__.__eq__", ["object"],   true, "pathlib.PurePath.__bases__[0].__name__ == 'object' (PurePath inherits directly from the built-in object class — it is at the top of the pathlib inheritance hierarchy; 'object' has 6 characters: 'o-b-j-e-c-t'; PurePath.__bases__[0].__name__ == 'object' (6 chars) is shorter than PurePath.__name__ (8 chars) by 2; the base class being 'object' (6) means PurePath does not extend any other pathlib or I/O class — it is the pure abstract foundation; contrast: PurePosixPath.__bases__[0].__name__ == 'PurePath' (8) and PureWindowsPath.__bases__[0].__name__ == 'PurePath' (8) — the two concrete pure subclasses inherit from PurePath, not from object directly; confirmed Python 3.14.3 macOS)"]
    - [pure_name_len, PurePath.__name__.__len__,              [],           8,    "pathlib.PurePath.__name__.__len__() == 8 — 'PurePath' has 8 characters: 'Pure' (4) + 'Path' (4) = 8; the two halves are equal in length (4 chars each) — a symmetric name structure; PurePath (8) is the root class; PurePosixPath (13) adds 'Posix' (5 chars) for an 8+5=13 total — but the infix is inserted not appended: 'Pure'+'Posix'+'Path' = 4+5+4 = 13; PureWindowsPath (15) adds 'Windows' (7 chars): 'Pure'+'Windows'+'Path' = 4+7+4 = 15; the name length 8 for PurePath is the baseline from which PurePosixPath (+5) and PureWindowsPath (+7) extend; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath class identity
# __name__ == 'PurePosixPath' (len=13), __bases__[0].__name__ == 'PurePath' (len=8)
# Infix 'Posix' (5 chars) inserted between 'Pure' (4) and 'Path' (4)
# ---------------------------------------------------------------------------

table pathlib_extra172.PurePosixPath_class_identity:
  description: "pathlib.PurePosixPath class identity: __name__=='PurePosixPath' (len=13), __bases__[0].__name__=='PurePath' (len=8); PurePosixPath (13) = 'Pure' (4) + 'Posix' (5) + 'Path' (4) = 13; PurePosixPath inherits from PurePath"
  kind: python_call_eq
  category: identity
  id_prefix: ppposix172

  columns: [id, function, args, expected, description]
  rows:
    - [posix_name,     PurePosixPath.__name__.__eq__,                ["PurePosixPath"], true, "pathlib.PurePosixPath.__name__ == 'PurePosixPath' (PurePosixPath is the pure path class for POSIX (Unix/Linux/macOS) path semantics; 'PurePosixPath' has 13 characters: 'Pure' (4) + 'Posix' (5) + 'Path' (4) = 13; the infix 'Posix' (5 chars) is inserted between the 'Pure' prefix and 'Path' suffix; PurePosixPath (13) is 5 characters longer than PurePath (8) — the 'Posix' infix adds exactly 5 chars; PurePosixPath (13) < PureWindowsPath (15) by 2 — 'Posix' (5) is 2 shorter than 'Windows' (7); PurePosixPath uses forward slashes as separators and is case-sensitive; PurePosixPath can be instantiated on any platform (Windows included) since it does no filesystem I/O)"]
    - [posix_base0,    "PurePosixPath.__bases__[0].__name__.__eq__", ["PurePath"],      true, "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' (PurePosixPath inherits directly from PurePath — not from object; 'PurePath' has 8 characters; the inheritance chain is: PurePosixPath -> PurePath -> object; PurePosixPath.__bases__[0].__name__ (8 chars) equals PurePath.__name__ (also 8 chars) — as expected since PurePath is the immediate base; both PurePosixPath and PureWindowsPath share the same immediate base class PurePath (8 chars) — a parallel inheritance structure; PurePosixPath adds POSIX-specific path parsing on top of PurePath's generic pure path machinery; confirmed Python 3.14.3 macOS"]
    - [posix_module,   PurePosixPath.__module__.__eq__,              ["pathlib"],       true, "pathlib.PurePosixPath.__module__ == 'pathlib' (PurePosixPath is defined in the public 'pathlib' module; 'pathlib' has 7 characters; PurePosixPath.__module__ (7 chars) is the same as PurePath.__module__ (7 chars) — all pathlib classes share the 'pathlib' module name; the uniform module name across all pathlib classes means repr(PurePosixPath('.')) includes 'pathlib' and isinstance checks can rely on the consistent module hierarchy; 'pathlib' (7 chars) is 6 characters shorter than PurePosixPath (13 chars) — the module name is much shorter than the class name; confirmed Python 3.14.3 macOS"]
    - [posix_name_len, PurePosixPath.__name__.__len__,               [],               13,   "pathlib.PurePosixPath.__name__.__len__() == 13 — 'PurePosixPath' has 13 characters: 'Pure' (4) + 'Posix' (5) + 'Path' (4) = 4 + 5 + 4 = 13; the three-part name structure (Pure + OS-infix + Path) is the naming pattern for all concrete pure path classes; 13 chars for PurePosixPath vs 15 chars for PureWindowsPath: the 2-character difference arises because 'Posix' (5) is 2 shorter than 'Windows' (7); PurePosixPath (13) - PurePath (8) == 5: the 'Posix' infix contributes exactly 5 characters of the name length increase; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# pathlib.PureWindowsPath class identity
# __name__ == 'PureWindowsPath' (len=15), __bases__[0].__name__ == 'PurePath' (len=8)
# Infix 'Windows' (7 chars) inserted between 'Pure' (4) and 'Path' (4)
# PureWindowsPath (15) is the longest pure path class name.
# ---------------------------------------------------------------------------

table pathlib_extra172.PureWindowsPath_class_identity:
  description: "pathlib.PureWindowsPath class identity: __name__=='PureWindowsPath' (len=15), __bases__[0].__name__=='PurePath' (len=8); PureWindowsPath (15) = 'Pure' (4) + 'Windows' (7) + 'Path' (4) = 15; PureWindowsPath is the longest pure path class name"
  kind: python_call_eq
  category: identity
  id_prefix: ppwin172

  columns: [id, function, args, expected, description]
  rows:
    - [win_name,     PureWindowsPath.__name__.__eq__,                ["PureWindowsPath"], true, "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath' (PureWindowsPath is the pure path class for Windows path semantics; 'PureWindowsPath' has 15 characters: 'Pure' (4) + 'Windows' (7) + 'Path' (4) = 15; the infix 'Windows' (7 chars) is the longest OS infix in the pure path naming scheme; PureWindowsPath (15) is the longest name among the three pure path classes: PurePath (8) < PurePosixPath (13) < PureWindowsPath (15); PureWindowsPath (15) > PurePosixPath (13) by 2 — 'Windows' (7) > 'Posix' (5) by 2; PureWindowsPath uses backslashes as separators and is case-insensitive; it can be instantiated on any platform since it does no I/O)"]
    - [win_base0,    "PureWindowsPath.__bases__[0].__name__.__eq__", ["PurePath"],        true, "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' (PureWindowsPath inherits directly from PurePath — the same base as PurePosixPath; 'PurePath' has 8 characters; the inheritance chain is: PureWindowsPath -> PurePath -> object; PureWindowsPath.__bases__[0].__name__ (8 chars) equals PurePosixPath.__bases__[0].__name__ (also 8 chars: 'PurePath') — both concrete pure path classes share the same immediate parent; this parallel inheritance means PureWindowsPath and PurePosixPath differ only in their OS-specific path parsing logic, not in their abstract base; confirmed Python 3.14.3 macOS"]
    - [win_module,   PureWindowsPath.__module__.__eq__,              ["pathlib"],         true, "pathlib.PureWindowsPath.__module__ == 'pathlib' (PureWindowsPath is defined in the public 'pathlib' module; 'pathlib' has 7 characters; all three pure path classes (PurePath, PurePosixPath, PureWindowsPath) share __module__ == 'pathlib' (7 chars) — the uniform module name reflects the unified pathlib design; 'pathlib' (7 chars) < PureWindowsPath (15 chars) by 8 — the module name is 8 characters shorter than the class name; PureWindowsPath.__module__ (7) == PurePosixPath.__module__ (7) == PurePath.__module__ (7): all three have the same 7-character module name; confirmed Python 3.14.3 macOS"]
    - [win_name_len, PureWindowsPath.__name__.__len__,               [],                 15,   "pathlib.PureWindowsPath.__name__.__len__() == 15 — 'PureWindowsPath' has 15 characters: 'Pure' (4) + 'Windows' (7) + 'Path' (4) = 4 + 7 + 4 = 15; PureWindowsPath (15) is the maximum name length among the three pure path classes; the ascending name length sequence: PurePath (8) < PurePosixPath (13) < PureWindowsPath (15); the gap from PurePath (8) to PurePosixPath (13) is 5 (the 'Posix' infix length); the gap from PurePosixPath (13) to PureWindowsPath (15) is 2 (the difference between 'Windows' (7) and 'Posix' (5) infix lengths); PureWindowsPath (15) - PurePath (8) == 7 == len('Windows'): the total name increase over the base class equals the infix length; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Pure path hierarchy name length comparisons
# PurePath (8) < PurePosixPath (13) < PureWindowsPath (15)
# Common 'Pure' prefix (4) and 'Path' suffix (4) across all three.
# ---------------------------------------------------------------------------

table pathlib_extra172.pure_path_name_length_comparisons:
  description: "Pure path class name lengths: PurePath (8) < PurePosixPath (13) < PureWindowsPath (15); common 'Pure'(4)+'Path'(4) frame; infix lengths: 'Posix'(5) for PurePosixPath, 'Windows'(7) for PureWindowsPath; PureWindowsPath is 2 longer than PurePosixPath"
  kind: python_call_eq
  category: identity
  id_prefix: pplen172

  columns: [id, function, args, expected, description]
  rows:
    - [pure_lt_posix,  PurePath.__name__.__len__,        [],  8,   "pathlib.PurePath.__name__.__len__() == 8 — confirming PurePath (8) is the shortest of the three pure path class names; PurePath (8) < PurePosixPath (13) by 5 — the 'Posix' infix adds 5 chars; PurePath (8) < PureWindowsPath (15) by 7 — the 'Windows' infix adds 7 chars; PurePath (8) is the abstract base with no OS-specific infix; the 'Pure'+'Path' frame (4+4=8) is the irreducible minimum name length in the pure path hierarchy; the two equal halves 'Pure' (4) and 'Path' (4) give PurePath a symmetric 4+4=8 structure; confirmed Python 3.14.3 macOS"]
    - [posix_len_13,   PurePosixPath.__name__.__len__,   [],  13,  "pathlib.PurePosixPath.__name__.__len__() == 13 — 'PurePosixPath' = 'Pure'(4)+'Posix'(5)+'Path'(4) = 13; PurePosixPath (13) is the middle name length among the three pure path classes; PurePosixPath (13) - PurePath (8) == 5 == len('Posix'); the 'Posix' infix (5 chars: P-o-s-i-x) contributes the name length increase from PurePath (8) to PurePosixPath (13); PurePosixPath (13) < PureWindowsPath (15) by 2 because 'Posix' (5) < 'Windows' (7) by 2; 13 chars is also the length of 'PurePosixPath' in the repr() output: pathlib.PurePosixPath('.') shows 'PurePosixPath'('.') in the REPL; confirmed Python 3.14.3 macOS"]
    - [win_len_15,     PureWindowsPath.__name__.__len__, [],  15,  "pathlib.PureWindowsPath.__name__.__len__() == 15 — 'PureWindowsPath' = 'Pure'(4)+'Windows'(7)+'Path'(4) = 15; PureWindowsPath (15) is the maximum name length among the three pure path classes; PureWindowsPath (15) - PurePath (8) == 7 == len('Windows'); the 'Windows' infix (7 chars: W-i-n-d-o-w-s) is the longest OS-specific infix and makes PureWindowsPath the longest pure path class name; the ascending sequence: PurePath(8), PurePosixPath(13), PureWindowsPath(15) with gaps of 5 and 2; 15 chars for PureWindowsPath also equals len('PureWindowsPath') which is its own __name__ — a tautological identity; confirmed Python 3.14.3 macOS"]
    - [posix_gt_pure,  PurePosixPath.__name__.__len__,   [],  13,  "pathlib.PurePosixPath.__name__.__len__() == 13 == PurePath.__name__.__len__() + 5 == 8 + 5 == 13; the name length increase from PurePath (8) to PurePosixPath (13) is exactly 5 — matching len('Posix') == 5; 13 is also the number of characters in the MRO segment PurePosixPath -> PurePath -> object (three classes); PurePosixPath (13) is 2 shorter than PureWindowsPath (15); the common 'Pure'+'Path' frame (8 chars) is shared across all three pure path classes — it is the structural constant while the OS infix is the variable; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra172.PurePath_name_is_PurePath:
  description: "pathlib.PurePath.__name__ == 'PurePath' — PurePath is the abstract base for all pathlib path classes; 'PurePath' has 8 characters: 'Pure' (4) + 'Path' (4) = 8; the two equal halves give PurePath a symmetric name structure unique among the three pure path classes (PurePosixPath has an unequal 4+5+4=13 split; PureWindowsPath has 4+7+4=15); PurePath.__bases__[0].__name__ == 'object' (6 chars) — PurePath inherits directly from object, making it the root of the pathlib class hierarchy; the ascending name length sequence: PurePath (8) < PurePosixPath (13) < PureWindowsPath (15); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: PurePath.__name__.__eq__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra172.PurePath_module_is_pathlib:
  description: "pathlib.PurePath.__module__ == 'pathlib' — PurePath is defined in the public 'pathlib' module; 'pathlib' has 7 characters; all six pathlib path classes (PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath, WindowsPath) share __module__ == 'pathlib' (7 chars); the uniform 7-character module name for all pathlib classes contrasts with the io module where some classes have __module__ == '_io' (3 chars) and others have __module__ == 'io' (2 chars); PurePath.__module__ (7 chars) is 1 character shorter than PurePath.__name__ (8 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: PurePath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra172.PurePath_base_is_object:
  description: "pathlib.PurePath.__bases__[0].__name__ == 'object' — PurePath inherits directly from the built-in object class; 'object' has 6 characters; PurePath is the only pathlib class whose immediate base is 'object' — all other pathlib classes (PurePosixPath, PureWindowsPath, Path, PosixPath, WindowsPath) have a pathlib class as their immediate base; PurePath.__bases__[0].__name__ (6 chars: 'object') is shorter than PurePath.__name__ (8 chars: 'PurePath') by 2; the fact that PurePath's base is 'object' confirms it is the root ABC of the entire pathlib hierarchy; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "PurePath.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant pathlib_extra172.PurePosixPath_base_is_PurePath:
  description: "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' — PurePosixPath inherits directly from PurePath; 'PurePath' has 8 characters; both PurePosixPath and PureWindowsPath share PurePath as their immediate base class — a parallel inheritance structure; PurePosixPath.__bases__[0].__name__ (8 chars: 'PurePath') equals PurePath.__name__ (also 8 chars) — confirming the direct parent-child relationship; 'PurePosixPath' (13 chars) -> 'PurePath' (8 chars) -> 'object' (6 chars): the inheritance chain has decreasing name lengths at each level; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "PurePosixPath.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra172.PureWindowsPath_name_len_15:
  description: "pathlib.PureWindowsPath.__name__.__len__() == 15 — 'PureWindowsPath' has 15 characters: 'Pure' (4) + 'Windows' (7) + 'Path' (4) = 15; PureWindowsPath (15) is the longest of the three pure path class names; PureWindowsPath (15) > PurePosixPath (13) by 2 because 'Windows' (7) > 'Posix' (5) by 2; the ascending name length sequence is PurePath (8) < PurePosixPath (13) < PureWindowsPath (15) with gaps of 5 and 2; PureWindowsPath uses Windows path semantics (backslash separators, drive letters, case-insensitivity) and can be instantiated on any platform; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: PureWindowsPath.__name__.__len__
  args: []
  expected: 15

invariant pathlib_extra172.PureWindowsPath_base_is_PurePath:
  description: "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' — PureWindowsPath inherits directly from PurePath (the same immediate base as PurePosixPath); 'PurePath' has 8 characters; PurePosixPath and PureWindowsPath both have PurePath (8 chars) as their __bases__[0].__name__ — a symmetric inheritance structure where both OS-specific pure path classes derive from the same abstract base; 'PureWindowsPath' (15 chars) -> 'PurePath' (8 chars) -> 'object' (6 chars): the inheritance chain; PureWindowsPath.__bases__[0].__name__ (8) == PurePosixPath.__bases__[0].__name__ (8): equal base names for the two concrete pure path classes; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "PureWindowsPath.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra172.PurePosixPath_name_len_13:
  description: "pathlib.PurePosixPath.__name__.__len__() == 13 — 'PurePosixPath' has 13 characters: 'Pure' (4) + 'Posix' (5) + 'Path' (4) = 13; PurePosixPath (13) is between PurePath (8) and PureWindowsPath (15) in name length; PurePosixPath (13) - PurePath (8) == 5 == len('Posix') — the infix length equals the name length increment; PurePosixPath (13) < PureWindowsPath (15) by 2 — because 'Windows' (7) > 'Posix' (5) by 2; the three pure path class names follow the pattern Pure + OS-infix + Path where the OS infix length determines the class name length: no infix (PurePath, 8), 'Posix' (5, PurePosixPath, 13), 'Windows' (7, PureWindowsPath, 15); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: PurePosixPath.__name__.__len__
  args: []
  expected: 13
