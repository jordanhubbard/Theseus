spec: threading_extra1651
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __init_subclass__ class creation hook"
    - "threading.Thread, Event, Condition, Semaphore, BoundedSemaphore, Timer, and Barrier are pure Python classes"
    - "none of them define __init_subclass__ in their own __dict__"
    - "they inherit the default no-op __init_subclass__ from object"
    - "threading.Lock is a C extension type (_thread.lock) accessed via a factory alias"
    - "none of the threading classes define __set_name__ (they are not descriptors)"
    - "none of the threading classes define __class_getitem__ (no generic alias support)"
    - "threading module exposes a complete concurrency API: Thread, Lock, RLock, Event, Condition, Semaphore, BoundedSemaphore, Timer, Barrier, local"
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: threading classes do not define __init_subclass__ in their own
# __dict__. These are user-subclassable classes (Thread especially) but they
# do not inject any __init_subclass__ hook to control subclassing behavior.
# They rely entirely on object's default no-op implementation.
# ---------------------------------------------------------------------------

table threading_extra1651.no_init_subclass:
  description: "threading classes do not define __init_subclass__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1651ni

  columns: [id, function, args, expected]
  rows:
    - ["th1651ni001", "threading.Thread.__dict__.__contains__",          ["__init_subclass__"], false]
    - ["th1651ni002", "threading.Event.__dict__.__contains__",           ["__init_subclass__"], false]
    - ["th1651ni003", "threading.Condition.__dict__.__contains__",       ["__init_subclass__"], false]
    - ["th1651ni004", "threading.Semaphore.__dict__.__contains__",       ["__init_subclass__"], false]
    - ["th1651ni005", "threading.BoundedSemaphore.__dict__.__contains__", ["__init_subclass__"], false]
    - ["th1651ni006", "threading.Timer.__dict__.__contains__",           ["__init_subclass__"], false]
    - ["th1651ni007", "threading.Barrier.__dict__.__contains__",         ["__init_subclass__"], false]
    - ["th1651ni008", "threading.local.__dict__.__contains__",           ["__init_subclass__"], false]
    - ["th1651ni009", "object.__dict__.__contains__",                    ["__init_subclass__"], true]
    - ["th1651ni010", "threading.Thread.__dict__.__contains__",          ["__subclasshook__"],  false]
    - ["th1651ni011", "threading.Event.__dict__.__contains__",           ["__subclasshook__"],  false]
    - ["th1651ni012", "threading.Condition.__dict__.__contains__",       ["__subclasshook__"],  false]
    - ["th1651ni013", "threading.Semaphore.__dict__.__contains__",       ["__subclasshook__"],  false]
    - ["th1651ni014", "threading.BoundedSemaphore.__dict__.__contains__", ["__subclasshook__"],  false]
    - ["th1651ni015", "threading.Timer.__dict__.__contains__",           ["__subclasshook__"],  false]
    - ["th1651ni016", "threading.Barrier.__dict__.__contains__",         ["__subclasshook__"],  false]
    - ["th1651ni017", "threading.Thread.__dict__.__contains__",          ["__instancecheck__"], false]
    - ["th1651ni018", "threading.Thread.__dict__.__contains__",          ["__subclasscheck__"], false]
    - ["th1651ni019", "threading.Thread.__dict__.__contains__",          ["__class_getitem__"], false]
    - ["th1651ni020", "threading.Event.__dict__.__contains__",           ["__class_getitem__"], false]
    - ["th1651ni021", "threading.Condition.__dict__.__contains__",       ["__class_getitem__"], false]
    - ["th1651ni022", "threading.Semaphore.__dict__.__contains__",       ["__class_getitem__"], false]
    - ["th1651ni023", "threading.Timer.__dict__.__contains__",           ["__class_getitem__"], false]
    - ["th1651ni024", "threading.Barrier.__dict__.__contains__",         ["__class_getitem__"], false]
    - ["th1651ni025", "threading.local.__dict__.__contains__",           ["__class_getitem__"], false]

# ---------------------------------------------------------------------------
# Table 2: threading classes do not define __set_name__. They are not
# descriptors and are not intended to be used as class-level attributes
# that need name injection at class definition time.
# ---------------------------------------------------------------------------

table threading_extra1651.no_set_name:
  description: "threading classes do not define __set_name__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1651sn

  columns: [id, function, args, expected]
  rows:
    - ["th1651sn001", "threading.Thread.__dict__.__contains__",          ["__set_name__"], false]
    - ["th1651sn002", "threading.Event.__dict__.__contains__",           ["__set_name__"], false]
    - ["th1651sn003", "threading.Condition.__dict__.__contains__",       ["__set_name__"], false]
    - ["th1651sn004", "threading.Semaphore.__dict__.__contains__",       ["__set_name__"], false]
    - ["th1651sn005", "threading.BoundedSemaphore.__dict__.__contains__", ["__set_name__"], false]
    - ["th1651sn006", "threading.Timer.__dict__.__contains__",           ["__set_name__"], false]
    - ["th1651sn007", "threading.Barrier.__dict__.__contains__",         ["__set_name__"], false]
    - ["th1651sn008", "threading.local.__dict__.__contains__",           ["__set_name__"], false]
    - ["th1651sn009", "threading.Thread.__dict__.__contains__",          ["__init__"],     true]
    - ["th1651sn010", "threading.Thread.__dict__.__contains__",          ["run"],          true]
    - ["th1651sn011", "threading.Thread.__dict__.__contains__",          ["start"],        true]
    - ["th1651sn012", "threading.Thread.__dict__.__contains__",          ["join"],         true]
    - ["th1651sn013", "threading.Thread.__dict__.__contains__",          ["is_alive"],     true]
    - ["th1651sn014", "threading.Thread.__dict__.__contains__",          ["daemon"],       true]
    - ["th1651sn015", "threading.Thread.__dict__.__contains__",          ["name"],         true]
    - ["th1651sn016", "threading.Thread.__dict__.__contains__",          ["ident"],        true]
    - ["th1651sn017", "threading.Condition.__dict__.__contains__",       ["acquire"],      false]
    - ["th1651sn018", "threading.Condition.__dict__.__contains__",       ["release"],      false]
    - ["th1651sn019", "threading.Condition.__dict__.__contains__",       ["wait"],         true]
    - ["th1651sn020", "threading.Condition.__dict__.__contains__",       ["notify"],       true]
    - ["th1651sn021", "threading.Condition.__dict__.__contains__",       ["notify_all"],   true]
    - ["th1651sn022", "threading.Barrier.__dict__.__contains__",         ["wait"],         true]
    - ["th1651sn023", "threading.Barrier.__dict__.__contains__",         ["reset"],        true]
    - ["th1651sn024", "threading.Barrier.__dict__.__contains__",         ["abort"],        true]
    - ["th1651sn025", "threading.Semaphore.__dict__.__contains__",       ["acquire"],      true]
    - ["th1651sn026", "threading.Semaphore.__dict__.__contains__",       ["release"],      true]

# ---------------------------------------------------------------------------
# Table 3: threading module-level attribute presence.
# The threading module exposes its full public API as module-level names.
# These include all the synchronization primitive classes, thread-local
# storage, introspection functions, and configuration hooks.
# ---------------------------------------------------------------------------

table threading_extra1651.module_attr_presence:
  description: "threading module-level attribute presence in threading.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1651mp

  columns: [id, function, args, expected]
  rows:
    - ["th1651mp001", "threading.__dict__.__contains__", ["Thread"],           true]
    - ["th1651mp002", "threading.__dict__.__contains__", ["Lock"],             true]
    - ["th1651mp003", "threading.__dict__.__contains__", ["RLock"],            true]
    - ["th1651mp004", "threading.__dict__.__contains__", ["Event"],            true]
    - ["th1651mp005", "threading.__dict__.__contains__", ["Condition"],        true]
    - ["th1651mp006", "threading.__dict__.__contains__", ["Semaphore"],        true]
    - ["th1651mp007", "threading.__dict__.__contains__", ["BoundedSemaphore"], true]
    - ["th1651mp008", "threading.__dict__.__contains__", ["Timer"],            true]
    - ["th1651mp009", "threading.__dict__.__contains__", ["Barrier"],          true]
    - ["th1651mp010", "threading.__dict__.__contains__", ["local"],            true]
    - ["th1651mp011", "threading.__dict__.__contains__", ["current_thread"],   true]
    - ["th1651mp012", "threading.__dict__.__contains__", ["main_thread"],      true]
    - ["th1651mp013", "threading.__dict__.__contains__", ["active_count"],     true]
    - ["th1651mp014", "threading.__dict__.__contains__", ["enumerate"],        true]
    - ["th1651mp015", "threading.__dict__.__contains__", ["settrace"],         true]
    - ["th1651mp016", "threading.__dict__.__contains__", ["setprofile"],       true]
    - ["th1651mp017", "threading.__dict__.__contains__", ["stack_size"],       true]
    - ["th1651mp018", "threading.__dict__.__contains__", ["get_ident"],        true]
    - ["th1651mp019", "threading.__dict__.__contains__", ["get_native_id"],    true]
    - ["th1651mp020", "threading.__dict__.__contains__", ["excepthook"],       true]
    - ["th1651mp021", "threading.__dict__.__contains__", ["TIMEOUT_MAX"],      true]
    - ["th1651mp022", "threading.__dict__.__contains__", ["__init_subclass__"], false]
    - ["th1651mp023", "threading.__dict__.__contains__", ["__subclasshook__"], false]
    - ["th1651mp024", "threading.__dict__.__contains__", ["__version__"],      false]
    - ["th1651mp025", "threading.__dict__.__contains__", ["__name__"],         true]
    - ["th1651mp026", "threading.__dict__.__contains__", ["__doc__"],          true]
    - ["th1651mp027", "threading.__dict__.__contains__", ["__package__"],      true]
    - ["th1651mp028", "threading.__dict__.__contains__", ["__spec__"],         true]
