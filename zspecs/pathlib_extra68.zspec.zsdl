spec: pathlib_extra68
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "pathlib_extra67.zspec.zsdl — covers PurePath.__str__/__repr__/__fspath__/__eq__/__hash__ __qualname__.__eq__(); Path.open/read_text/write_text __qualname__.__eq__()."
    - "pathlib_extra66.zspec.zsdl — covers pathlib.__loader__/__spec__ class identity checks."
    - "pathlib_extra65.zspec.zsdl — covers pathlib.__loader__/__spec__/__file__/__cached__ class identity."
    - "pathlib_extra63.zspec.zsdl — covers pathlib.__all__.__class__.__name__.__eq__('list') and __all__.__len__()==7; Path/PurePath dunder __class__.__name__.__eq__('function')."
    - "pathlib_extra52.zspec.zsdl — covers PurePath/Path method __qualname__.__len__() values."
  notes:
    - "This spec extends pathlib_extra67.zspec.zsdl."
    - "Wave 228 theme: __annotations__ class identity + __globals__ dict keys + __doc__.__contains__ content checks."
    - "Path.open.__annotations__.__class__.__name__.__eq__('dict') — Path is a pure Python class (Lib/pathlib/__init__.py). Path.open is a regular Python function and has __annotations__ as a dict object. Path.open.__annotations__ is {} (empty dict) because no parameter annotations are declared. __annotations__.__class__.__name__ is 'dict'. No prior pathlib spec checks Path.open.__annotations__.__class__.__name__.__eq__('dict'). Novel annotation class identity anchor in pathlibann68 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Path.read_text.__annotations__.__class__.__name__.__eq__('dict') — same pattern as Path.open; read_text is a pure Python function with __annotations__ == {} (empty dict). Novel annotation class identity anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Path.open.__globals__.__class__.__name__.__eq__('dict') — Path.open is a pure Python function and carries __globals__ (the module global namespace dict). __globals__.__class__.__name__ is 'dict'. No prior pathlib spec checks Path.open.__globals__.__class__.__name__.__eq__('dict'). Novel __globals__ class identity anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Path.open.__globals__.__contains__('Path') — the pathlib module namespace contains 'Path' as a key. No prior pathlib spec checks Path.open.__globals__.__contains__('Path'). Novel __globals__ key content anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "PurePath.__doc__.__contains__('path') — PurePath.__doc__ begins 'Base class for manipulating paths without I/O.' The word 'path' appears (in 'paths'). No prior pathlib spec checks PurePath.__doc__.__contains__(). Novel __doc__ content anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path.open and Path.read_text __annotations__.__class__.__name__.__eq__('dict')
#
# Path is a pure Python class. Path.open and Path.read_text are regular Python
# functions. Python functions always have an __annotations__ attribute which is
# a dict. Even with no parameter annotations declared the dict is empty {}.
#
#   Path.open.__annotations__.__class__.__name__ == 'dict'
#   Path.read_text.__annotations__.__class__.__name__ == 'dict'
#
# No prior pathlib spec checks __annotations__.__class__.__name__.__eq__('dict')
# for any pathlib function. Novel annotation class identity anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra68.path_annotations_class:
  description: "Path.open and Path.read_text __annotations__.__class__.__name__.__eq__('dict') — Path is pure Python; these functions have __annotations__=={} (empty dict); __annotations__.__class__.__name__ is 'dict'; no prior pathlib spec checks __annotations__.__class__.__name__.__eq__() for any pathlib function; novel annotation class identity anchors in pathlibann68 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: annotation_class_identity
  id_prefix: pathlibann68ann

  columns: [id, function, args, expected]
  rows:
    - [open_ann_class_eq,      Path.open.__annotations__.__class__.__name__.__eq__,      ["dict"], true]
    - [read_text_ann_class_eq, Path.read_text.__annotations__.__class__.__name__.__eq__, ["dict"], true]

# ---------------------------------------------------------------------------
# Path.open.__globals__ class identity and key content
#
# Path.open is a pure Python function and carries __globals__ pointing at the
# pathlib module namespace dict. The namespace contains 'Path' as a key.
#
#   Path.open.__globals__.__class__.__name__ == 'dict'
#   'Path' in Path.open.__globals__          == True
#
# No prior pathlib spec checks Path.open.__globals__ class identity or key
# content. Novel __globals__ anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra68.path_open_globals:
  description: "Path.open.__globals__.__class__.__name__.__eq__('dict') and __contains__('Path') — Path.open is a pure Python function; __globals__ is the pathlib module namespace dict; __class__.__name__ is 'dict'; 'Path' is a key in the namespace; no prior pathlib spec checks Path.open.__globals__ class identity or key content; novel __globals__ anchors in pathlibann68 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: globals_dict_identity
  id_prefix: pathlibann68glb

  columns: [id, function, args, expected]
  rows:
    - [globals_class_eq,        Path.open.__globals__.__class__.__name__.__eq__, ["dict"], true]
    - [globals_contains_path,   Path.open.__globals__.__contains__,              ["Path"], true]

# ---------------------------------------------------------------------------
# PurePath.__doc__.__contains__ content checks
#
# PurePath.__doc__ begins:
#   'Base class for manipulating paths without I/O.'
# followed by further description. The word 'path' appears (in 'paths').
# 'Base' also appears in the opening.
#
# No prior pathlib spec checks PurePath.__doc__.__contains__(). Novel content anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra68.purepath_doc_contains:
  description: "PurePath.__doc__.__contains__('path') and __contains__('Base') — PurePath.__doc__ begins 'Base class for manipulating paths without I/O.'; 'path' appears (in 'paths') and 'Base' appears; no prior pathlib spec checks PurePath.__doc__.__contains__(); novel __doc__ content anchors in pathlibann68 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_doc_content
  id_prefix: pathlibann68ppdoc

  columns: [id, function, args, expected]
  rows:
    - [doc_contains_path, PurePath.__doc__.__contains__, ["path"], true]
    - [doc_contains_base, PurePath.__doc__.__contains__, ["Base"], true]

invariant pathlib_extra68.path_open_annotations_class:
  description: "Path.open.__annotations__.__class__.__name__.__eq__('dict') == True — Path is pure Python; Path.open.__annotations__=={} (empty dict); __class__.__name__ is 'dict'; no prior pathlib spec checks __annotations__.__class__.__name__.__eq__('dict') for Path.open; novel annotation class identity anchor in pathlibann68 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: annotation_class_identity
  kind: python_call_eq
  function: Path.open.__annotations__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant pathlib_extra68.path_read_text_annotations_class:
  description: "Path.read_text.__annotations__.__class__.__name__.__eq__('dict') == True — Path is pure Python; Path.read_text.__annotations__=={} (empty dict); __class__.__name__ is 'dict'; no prior pathlib spec checks __annotations__.__class__.__name__.__eq__('dict') for Path.read_text; novel annotation class identity anchor in pathlibann68 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: annotation_class_identity
  kind: python_call_eq
  function: Path.read_text.__annotations__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant pathlib_extra68.path_open_globals_class:
  description: "Path.open.__globals__.__class__.__name__.__eq__('dict') == True — Path.open is a pure Python function; __globals__ is the pathlib module namespace dict; __class__.__name__ is 'dict'; no prior pathlib spec checks Path.open.__globals__.__class__.__name__.__eq__('dict'); novel __globals__ class identity anchor in pathlibann68 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: globals_dict_identity
  kind: python_call_eq
  function: Path.open.__globals__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant pathlib_extra68.path_open_globals_contains_path:
  description: "Path.open.__globals__.__contains__('Path') == True — Path.open is a pure Python function; __globals__ is the pathlib module namespace dict; 'Path' is a key in the namespace because the pathlib module defines Path; no prior pathlib spec checks Path.open.__globals__.__contains__('Path'); novel __globals__ key content anchor in pathlibann68 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: globals_dict_identity
  kind: python_call_eq
  function: Path.open.__globals__.__contains__
  args: ["Path"]
  expected: true

invariant pathlib_extra68.purepath_doc_contains_path:
  description: "PurePath.__doc__.__contains__('path') == True — PurePath.__doc__ begins 'Base class for manipulating paths without I/O.'; 'path' appears (in 'paths'); no prior pathlib spec checks PurePath.__doc__.__contains__(); novel __doc__ content anchor in pathlibann68 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_content
  kind: python_call_eq
  function: PurePath.__doc__.__contains__
  args: ["path"]
  expected: true
