spec: hashlib_extra212
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "RFC 1321 — The MD5 Message-Digest Algorithm"

provenance:
  derived_from:
    - "FIPS 180-4 — Secure Hash Standard (SHS), NIST, August 2015"
    - "RFC 1321 — The MD5 Message-Digest Algorithm, April 1992"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified by running Python 3.14.3 hashlib on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Modules/_sha512module.c"
    - "CPython source: Modules/md5module.c"
  notes:
    - "This spec extends hashlib.zspec.zsdl and prior hashlib_extra specs; it does NOT duplicate invariants already present there."
    - "hashlib.new.__code__.co_varnames is ('name', 'args', 'kwargs') on Python 3.14.3 — it does NOT contain 'usedforsecurity' as a named co_varname (verified False on macOS/Darwin 25.4.0)."
    - "hashlib.new.__code__.co_varnames.__len__() == 3 (verified on Python 3.14.3 macOS/Darwin 25.4.0)."
    - "hashlib.file_digest.__code__.co_varnames.__len__() == 7 (verified on Python 3.14.3 macOS/Darwin 25.4.0)."
    - "hashlib.file_digest.__code__.co_varnames contains 'fileobj', 'digest', 'buf' (all verified True on Python 3.14.3 macOS/Darwin 25.4.0)."
    - "hashlib.new co_varnames contains 'name' and 'args' but NOT 'usedforsecurity' (all verified on Python 3.14.3)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model:
  semantics: "hashlib raises ValueError for unknown algorithm names passed to hashlib.new(). Co-varname membership checks are stateless and never raise."
  stderr: "null"
  stickiness: "N/A — co_varnames tuples are read-only attributes of code objects."
  codes: {}

# ---------------------------------------------------------------------------
# hashlib.new.__code__.co_varnames — membership checks (known-true values)
# co_varnames for hashlib.new is ('name', 'args', 'kwargs') on Python 3.14.3.
# ---------------------------------------------------------------------------

table hashlibmethods212.new_covarnames.known_true:
  description: "hashlib.new.__code__.co_varnames contains 'name', 'args', 'kwargs'"
  kind: python_call_eq
  category: code_metadata
  id_prefix: hashlibmethods212_new_true

  columns: [id, function, args, expected, description]
  rows:
    - [has_name,   "new.__code__.co_varnames.__contains__", ["name"],   true, "hashlib.new co_varnames contains 'name'"]
    - [has_args,   "new.__code__.co_varnames.__contains__", ["args"],   true, "hashlib.new co_varnames contains 'args'"]
    - [has_kwargs, "new.__code__.co_varnames.__contains__", ["kwargs"], true, "hashlib.new co_varnames contains 'kwargs'"]
    - [len_eq_3,   "new.__code__.co_varnames.__len__",      [],         3,    "hashlib.new co_varnames has exactly 3 entries"]

# ---------------------------------------------------------------------------
# hashlib.new.__code__.co_varnames — membership checks (known-false values)
# 'usedforsecurity' is NOT a co_varname of hashlib.new on Python 3.14.3.
# ---------------------------------------------------------------------------

table hashlibmethods212.new_covarnames.known_false:
  description: "hashlib.new.__code__.co_varnames does NOT contain 'usedforsecurity' or other absent names"
  kind: python_call_eq
  category: code_metadata
  id_prefix: hashlibmethods212_new_false

  columns: [id, function, args, expected, description]
  rows:
    - [no_usedforsecurity, "new.__code__.co_varnames.__contains__", ["usedforsecurity"], false, "'usedforsecurity' is NOT a co_varname of hashlib.new on Python 3.14.3"]
    - [no_data,            "new.__code__.co_varnames.__contains__", ["data"],            false, "'data' is NOT a co_varname of hashlib.new"]
    - [no_empty,           "new.__code__.co_varnames.__contains__", [""],                false, "empty string is NOT a co_varname of hashlib.new"]
    - [no_string,          "new.__code__.co_varnames.__contains__", ["string"],          false, "'string' is NOT a co_varname of hashlib.new"]

# ---------------------------------------------------------------------------
# hashlib.file_digest.__code__.co_varnames — membership checks
# co_varnames: ('fileobj', 'digest', '_bufsize', 'digestobj', 'buf', 'view', 'size')
# ---------------------------------------------------------------------------

table hashlibmethods212.file_digest_covarnames.checks:
  description: "hashlib.file_digest.__code__.co_varnames membership and length"
  kind: python_call_eq
  category: code_metadata
  id_prefix: hashlibmethods212_fd

  columns: [id, function, args, expected, description]
  rows:
    - [has_fileobj, "file_digest.__code__.co_varnames.__contains__", ["fileobj"], true, "file_digest co_varnames contains 'fileobj'"]
    - [has_digest,  "file_digest.__code__.co_varnames.__contains__", ["digest"],  true, "file_digest co_varnames contains 'digest'"]
    - [has_buf,     "file_digest.__code__.co_varnames.__contains__", ["buf"],     true, "file_digest co_varnames contains 'buf'"]
    - [len_eq_7,    "file_digest.__code__.co_varnames.__len__",      [],          7,    "file_digest co_varnames has exactly 7 entries"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashlibmethods212.new_covarnames.has_name:
  description: "hashlib.new.__code__.co_varnames.__contains__('name') == True — 'name' is the first co_varname of hashlib.new"
  category: code_metadata
  kind: python_call_eq
  function: "new.__code__.co_varnames.__contains__"
  args: ["name"]
  expected: true

invariant hashlibmethods212.new_covarnames.has_args:
  description: "hashlib.new.__code__.co_varnames.__contains__('args') == True — 'args' is a co_varname of hashlib.new"
  category: code_metadata
  kind: python_call_eq
  function: "new.__code__.co_varnames.__contains__"
  args: ["args"]
  expected: true

invariant hashlibmethods212.new_covarnames.no_usedforsecurity:
  description: "hashlib.new.__code__.co_varnames.__contains__('usedforsecurity') == False — not a co_varname on Python 3.14.3"
  category: code_metadata
  kind: python_call_eq
  function: "new.__code__.co_varnames.__contains__"
  args: ["usedforsecurity"]
  expected: false

invariant hashlibmethods212.new_covarnames.len:
  description: "hashlib.new.__code__.co_varnames.__len__() == 3 — hashlib.new has exactly 3 co_varnames"
  category: code_metadata
  kind: python_call_eq
  function: "new.__code__.co_varnames.__len__"
  args: []
  expected: 3

invariant hashlibmethods212.file_digest_covarnames.has_fileobj:
  description: "hashlib.file_digest.__code__.co_varnames.__contains__('fileobj') == True — 'fileobj' is the first parameter of file_digest"
  category: code_metadata
  kind: python_call_eq
  function: "file_digest.__code__.co_varnames.__contains__"
  args: ["fileobj"]
  expected: true

invariant hashlibmethods212.file_digest_covarnames.has_digest:
  description: "hashlib.file_digest.__code__.co_varnames.__contains__('digest') == True — 'digest' is the second parameter of file_digest"
  category: code_metadata
  kind: python_call_eq
  function: "file_digest.__code__.co_varnames.__contains__"
  args: ["digest"]
  expected: true

invariant hashlibmethods212.file_digest_covarnames.has_buf:
  description: "hashlib.file_digest.__code__.co_varnames.__contains__('buf') == True — 'buf' is a local variable in file_digest"
  category: code_metadata
  kind: python_call_eq
  function: "file_digest.__code__.co_varnames.__contains__"
  args: ["buf"]
  expected: true

invariant hashlibmethods212.file_digest_covarnames.len:
  description: "hashlib.file_digest.__code__.co_varnames.__len__() == 7 — file_digest has exactly 7 co_varnames"
  category: code_metadata
  kind: python_call_eq
  function: "file_digest.__code__.co_varnames.__len__"
  args: []
  expected: 7

