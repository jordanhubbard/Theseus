spec: queue_extra12
version: ">=3.9"
backend: python_module(queue)

docs: https://docs.python.org/3/library/queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/queue.html — Python queue module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/queue.py"
    - "CPython source: Modules/_queuemodule.c"
  notes:
    - "This spec extends queue.zspec.zsdl and prior extras through queue_extra11.zspec.zsdl."
    - "queue_extra4/extra8 cover __qualname__ for all 6 queue classes."
    - "queue_extra6/extra7 cover Queue method __name__ (put, get, task_done, join, put_nowait, get_nowait)."
    - "queue_extra11 covers module __name__, __package__, and __qualname__.__len__() for all 6 classes."
    - "NOT yet covered: Queue method __qualname__ values (Queue.put.__qualname__, etc.) — no prior spec checks __qualname__ on Queue's instance methods."
    - "Focus: __qualname__.__eq__ for all 9 Queue instance methods; LifoQueue.__qualname__ and PriorityQueue.__qualname__ standalone in extra12 namespace."
    - "queue.Queue.put.__qualname__ == 'Queue.put' — Verified Python 3.12 macOS."
    - "queue.Queue.get.__qualname__ == 'Queue.get' — Verified."
    - "queue.Queue.put_nowait.__qualname__ == 'Queue.put_nowait' — Verified."
    - "queue.Queue.get_nowait.__qualname__ == 'Queue.get_nowait' — Verified."
    - "queue.Queue.empty.__qualname__ == 'Queue.empty' — Verified."
    - "queue.Queue.full.__qualname__ == 'Queue.full' — Verified."
    - "queue.Queue.qsize.__qualname__ == 'Queue.qsize' — Verified."
    - "queue.Queue.task_done.__qualname__ == 'Queue.task_done' — Verified."
    - "queue.Queue.join.__qualname__ == 'Queue.join' — Verified."
    - "queue.LifoQueue.__qualname__ == 'LifoQueue' — Verified."
    - "queue.PriorityQueue.__qualname__ == 'PriorityQueue' — Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Queue instance method __qualname__ values — unified table
#
# Prior specs (extra6, extra7) check __name__ for Queue methods. No prior
# queue spec checks __qualname__ on Queue's instance methods. For methods
# defined on a class 'Queue', Python sets __qualname__ to 'Queue.<method>'.
# Under python_module(queue), 'Queue.put.__qualname__.__eq__' resolves as
# queue_module.Queue.put.__qualname__.__eq__. id_prefix qmqn12 is novel.
# ---------------------------------------------------------------------------

table queue_extra12.queue_method_qualnames:
  description: "queue.Queue instance method __qualname__ values — all follow 'Queue.<method>' pattern"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qmqn12

  columns: [id, function, args, expected]
  rows:
    - [put,       "Queue.put.__qualname__.__eq__",       ["Queue.put"],       true]
    - [get,       "Queue.get.__qualname__.__eq__",       ["Queue.get"],       true]
    - [put_nowait,"Queue.put_nowait.__qualname__.__eq__",["Queue.put_nowait"],true]
    - [get_nowait,"Queue.get_nowait.__qualname__.__eq__",["Queue.get_nowait"],true]
    - [empty,     "Queue.empty.__qualname__.__eq__",     ["Queue.empty"],     true]
    - [full,      "Queue.full.__qualname__.__eq__",      ["Queue.full"],      true]
    - [qsize,     "Queue.qsize.__qualname__.__eq__",     ["Queue.qsize"],     true]
    - [task_done, "Queue.task_done.__qualname__.__eq__", ["Queue.task_done"], true]
    - [join,      "Queue.join.__qualname__.__eq__",      ["Queue.join"],      true]

# ---------------------------------------------------------------------------
# LifoQueue and PriorityQueue __qualname__ standalone — extra12 namespace
#
# queue_extra4 and queue_extra8 cover __qualname__ for all 6 classes in tables.
# These extra12 standalone invariants provide independent anchors for
# LifoQueue and PriorityQueue in the extra12 namespace.
# ---------------------------------------------------------------------------

invariant queue_extra12.LifoQueue.qualname:
  description: "queue.LifoQueue.__qualname__ == 'LifoQueue' — top-level class qualname is bare class name"
  category: class_qualnames
  kind: python_call_eq
  function: LifoQueue.__qualname__.__eq__
  args: ["LifoQueue"]
  expected: true

invariant queue_extra12.PriorityQueue.qualname:
  description: "queue.PriorityQueue.__qualname__ == 'PriorityQueue' — top-level class qualname is bare class name"
  category: class_qualnames
  kind: python_call_eq
  function: PriorityQueue.__qualname__.__eq__
  args: ["PriorityQueue"]
  expected: true
