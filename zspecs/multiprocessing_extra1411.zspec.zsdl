spec: multiprocessing_extra1411
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing: Process-based parallelism"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.pool.Pool — multiprocessing.pool.Pool documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Queue — multiprocessing.queues documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py, Lib/multiprocessing/pool.py, Lib/multiprocessing/queues.py"
  notes:
    - "Wave 541 (_extra1411): focuses on __sizeof__ method type and presence, plus __reduce_ex__ checks for multiprocessing classes."
    - "multiprocessing.Process, multiprocessing.pool.Pool, multiprocessing.queues.Queue, multiprocessing.queues.SimpleQueue all have __sizeof__ with type 'method_descriptor'."
    - "All of these classes have __reduce_ex__ with type 'method_descriptor'."
    - "None define __sizeof__ or __reduce_ex__ in their own __dict__ — both are inherited from object."
    - "multiprocessing.Process.__sizeof__.__class__.__name__ == 'method_descriptor'; '__sizeof__' not in multiprocessing.Process.__dict__."
    - "multiprocessing.pool.Pool.__sizeof__.__class__.__name__ == 'method_descriptor'; '__sizeof__' not in multiprocessing.pool.Pool.__dict__."
    - "multiprocessing.queues.Queue.__sizeof__.__class__.__name__ == 'method_descriptor'; '__sizeof__' not in multiprocessing.queues.Queue.__dict__."
    - "multiprocessing.queues.SimpleQueue.__sizeof__.__class__.__name__ == 'method_descriptor'; '__sizeof__' not in multiprocessing.queues.SimpleQueue.__dict__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table multiprocessing_extra1411.sizeof_class_name:
  description: "multiprocessing class __sizeof__.__class__.__name__ identity checks — Process, pool.Pool, queues.Queue, queues.SimpleQueue all inherit __sizeof__ from object; type is 'method_descriptor' for all; none define __sizeof__ in their own __dict__; verified with Python 3.14.3"
  kind: python_call_eq
  category: sizeof_class_name
  id_prefix: mp1411sz
  columns: [id, function, args, expected]
  rows:
    - [mp1411sz001, multiprocessing.Process.__sizeof__.__class__.__name__.__eq__,            ["method_descriptor"], true]
    - [mp1411sz002, multiprocessing.pool.Pool.__sizeof__.__class__.__name__.__eq__,          ["method_descriptor"], true]
    - [mp1411sz003, multiprocessing.queues.Queue.__sizeof__.__class__.__name__.__eq__,       ["method_descriptor"], true]
    - [mp1411sz004, multiprocessing.queues.SimpleQueue.__sizeof__.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [mp1411sz005, multiprocessing.queues.JoinableQueue.__sizeof__.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [mp1411sz006, multiprocessing.Process.__sizeof__.__class__.__name__.__eq__,            ["method_descriptor"], true]

table multiprocessing_extra1411.sizeof_not_in_dict:
  description: "multiprocessing class __sizeof__ absence from own __dict__ — none of Process, pool.Pool, queues.Queue, queues.SimpleQueue define __sizeof__ directly; all inherit from object; __dict__.__contains__('__sizeof__') is False for each; verified with Python 3.14.3"
  kind: python_call_eq
  category: sizeof_dict_membership
  id_prefix: mp1411sd
  columns: [id, function, args, expected]
  rows:
    - [mp1411sd001, multiprocessing.Process.__dict__.__contains__,            ["__sizeof__"], false]
    - [mp1411sd002, multiprocessing.pool.Pool.__dict__.__contains__,          ["__sizeof__"], false]
    - [mp1411sd003, multiprocessing.queues.Queue.__dict__.__contains__,       ["__sizeof__"], false]
    - [mp1411sd004, multiprocessing.queues.SimpleQueue.__dict__.__contains__, ["__sizeof__"], false]
    - [mp1411sd005, multiprocessing.queues.JoinableQueue.__dict__.__contains__, ["__sizeof__"], false]
    - [mp1411sd006, multiprocessing.Process.__dict__.__contains__,            ["__reduce_ex__"], false]

table multiprocessing_extra1411.reduce_ex_class_name:
  description: "multiprocessing class __reduce_ex__.__class__.__name__ identity checks — all classes inherit __reduce_ex__ from object; type is 'method_descriptor'; none define __reduce_ex__ in their own __dict__; verified with Python 3.14.3"
  kind: python_call_eq
  category: reduce_ex_class_name
  id_prefix: mp1411rx
  columns: [id, function, args, expected]
  rows:
    - [mp1411rx001, multiprocessing.Process.__reduce_ex__.__class__.__name__.__eq__,            ["method_descriptor"], true]
    - [mp1411rx002, multiprocessing.pool.Pool.__reduce_ex__.__class__.__name__.__eq__,          ["method_descriptor"], true]
    - [mp1411rx003, multiprocessing.queues.Queue.__reduce_ex__.__class__.__name__.__eq__,       ["method_descriptor"], true]
    - [mp1411rx004, multiprocessing.queues.SimpleQueue.__reduce_ex__.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [mp1411rx005, multiprocessing.queues.JoinableQueue.__reduce_ex__.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [mp1411rx006, multiprocessing.pool.Pool.__dict__.__contains__,          ["__reduce_ex__"], false]

table multiprocessing_extra1411.reduce_ex_not_in_dict:
  description: "multiprocessing class __reduce_ex__ absence from own __dict__ — none of Process, pool.Pool, queues.Queue, queues.SimpleQueue, queues.JoinableQueue define __reduce_ex__ directly; all inherit from object; verified with Python 3.14.3"
  kind: python_call_eq
  category: reduce_ex_dict_membership
  id_prefix: mp1411rd
  columns: [id, function, args, expected]
  rows:
    - [mp1411rd001, multiprocessing.Process.__dict__.__contains__,              ["__reduce_ex__"], false]
    - [mp1411rd002, multiprocessing.pool.Pool.__dict__.__contains__,            ["__reduce_ex__"], false]
    - [mp1411rd003, multiprocessing.queues.Queue.__dict__.__contains__,         ["__reduce_ex__"], false]
    - [mp1411rd004, multiprocessing.queues.SimpleQueue.__dict__.__contains__,   ["__reduce_ex__"], false]
    - [mp1411rd005, multiprocessing.queues.JoinableQueue.__dict__.__contains__,  ["__reduce_ex__"], false]
    - [mp1411rd006, multiprocessing.queues.JoinableQueue.__dict__.__contains__,  ["__sizeof__"], false]
