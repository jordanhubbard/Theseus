table asyncio_extra260.bounded_semaphore_class_identity:
  description: "asyncio.BoundedSemaphore(len=16) class identity — inherits from Semaphore(len=9); defined in asyncio.locks(len=13); BoundedSemaphore name length (16) equals Semaphore.acquire qualname length (17) minus 1; verified with Python 3.14.4"
  kind: python_call_eq
  category: identity
  id_prefix: async260bs

  columns: [id, function, args, expected, description]
  rows:
    - [bs_name_eq,         BoundedSemaphore.__name__.__eq__,                       ["BoundedSemaphore"],      true, "asyncio.BoundedSemaphore.__name__ == 'BoundedSemaphore'; verified with Python 3.14.4"]
    - [bs_name_len,        BoundedSemaphore.__name__.__len__,                      [],                        16,   "asyncio.BoundedSemaphore.__name__.__len__() == 16; verified with Python 3.14.4"]
    - [bs_mod_eq,          BoundedSemaphore.__module__.__eq__,                     ["asyncio.locks"],         true, "asyncio.BoundedSemaphore.__module__ == 'asyncio.locks' — same as Semaphore module; verified with Python 3.14.4"]
    - [bs_mod_len,         BoundedSemaphore.__module__.__len__,                    [],                        13,   "asyncio.BoundedSemaphore.__module__.__len__() == 13 — same as Semaphore module length; verified with Python 3.14.4"]
    - [bs_base_eq,         "BoundedSemaphore.__bases__[0].__name__.__eq__",        ["Semaphore"],             true, "asyncio.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — BoundedSemaphore inherits from Semaphore; verified with Python 3.14.4"]
    - [bs_base_len,        "BoundedSemaphore.__bases__[0].__name__.__len__",       [],                        9,    "asyncio.BoundedSemaphore.__bases__[0].__name__.__len__() == 9 — Semaphore name length; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# asyncio.sleep / asyncio.gather / asyncio.wait_for function identity
#
# asyncio.sleep.__name__ == 'sleep' (len=5); __qualname__ == 'sleep'; __module__ == 'asyncio.tasks'
# asyncio.gather.__name__ == 'gather' (len=6); __qualname__ == 'gather'; __module__ == 'asyncio.tasks'
# asyncio.wait_for.__name__ == 'wait_for' (len=8); __qualname__ == 'wait_for'; __module__ == 'asyncio.tasks'
# ---------------------------------------------------------------------------

table asyncio_extra260.task_functions_identity:
  description: "asyncio.sleep(len=5), gather(len=6), wait_for(len=8) function identity — all plain functions in asyncio.tasks(len=13); sleep is shortest name, wait_for is longest; all have qualname == name (module-level); asyncio.tasks module length (13) equals asyncio.locks length (13); verified with Python 3.14.4"
  kind: python_call_eq
  category: identity
  id_prefix: async260tf

  columns: [id, function, args, expected, description]
  rows:
    - [sl_name_eq,         sleep.__name__.__eq__,                                  ["sleep"],                 true, "asyncio.sleep.__name__ == 'sleep'; verified with Python 3.14.4"]
    - [sl_name_len,        sleep.__name__.__len__,                                 [],                        5,    "asyncio.sleep.__name__.__len__() == 5 — shortest function name in spec; verified with Python 3.14.4"]
    - [sl_qn_eq,           sleep.__qualname__.__eq__,                              ["sleep"],                 true, "asyncio.sleep.__qualname__ == 'sleep' — module-level function, qualname equals name; verified with Python 3.14.4"]
    - [sl_qn_len,          sleep.__qualname__.__len__,                             [],                        5,    "asyncio.sleep.__qualname__.__len__() == 5 — qualname equals name for module-level function; verified with Python 3.14.4"]
    - [sl_mod_eq,          sleep.__module__.__eq__,                                ["asyncio.tasks"],         true, "asyncio.sleep.__module__ == 'asyncio.tasks'; verified with Python 3.14.4"]
    - [sl_mod_len,         sleep.__module__.__len__,                               [],                        13,   "asyncio.sleep.__module__.__len__() == 13 — same length as 'asyncio.locks'; verified with Python 3.14.4"]
    - [sl_cls_eq,          sleep.__class__.__name__.__eq__,                        ["function"],              true, "asyncio.sleep.__class__.__name__ == 'function' — plain Python coroutine function; verified with Python 3.14.4"]
    - [ga_name_eq,         gather.__name__.__eq__,                                 ["gather"],                true, "asyncio.gather.__name__ == 'gather'; verified with Python 3.14.4"]
    - [ga_name_len,        gather.__name__.__len__,                                [],                        6,    "asyncio.gather.__name__.__len__() == 6; verified with Python 3.14.4"]
    - [ga_qn_eq,           gather.__qualname__.__eq__,                             ["gather"],                true, "asyncio.gather.__qualname__ == 'gather' — module-level function, qualname equals name; verified with Python 3.14.4"]
    - [ga_qn_len,          gather.__qualname__.__len__,                            [],                        6,    "asyncio.gather.__qualname__.__len__() == 6; verified with Python 3.14.4"]
    - [ga_mod_eq,          gather.__module__.__eq__,                               ["asyncio.tasks"],         true, "asyncio.gather.__module__ == 'asyncio.tasks' — same module as sleep and wait_for; verified with Python 3.14.4"]
    - [ga_cls_eq,          gather.__class__.__name__.__eq__,                       ["function"],              true, "asyncio.gather.__class__.__name__ == 'function' — plain Python function; verified with Python 3.14.4"]
    - [wf_name_eq,         wait_for.__name__.__eq__,                               ["wait_for"],              true, "asyncio.wait_for.__name__ == 'wait_for'; verified with Python 3.14.4"]
    - [wf_name_len,        wait_for.__name__.__len__,                              [],                        8,    "asyncio.wait_for.__name__.__len__() == 8 — longest function name in spec; verified with Python 3.14.4"]
    - [wf_qn_eq,           wait_for.__qualname__.__eq__,                           ["wait_for"],              true, "asyncio.wait_for.__qualname__ == 'wait_for' — module-level function, qualname equals name; verified with Python 3.14.4"]
    - [wf_qn_len,          wait_for.__qualname__.__len__,                          [],                        8,    "asyncio.wait_for.__qualname__.__len__() == 8; verified with Python 3.14.4"]
    - [wf_mod_eq,          wait_for.__module__.__eq__,                             ["asyncio.tasks"],         true, "asyncio.wait_for.__module__ == 'asyncio.tasks' — same module as sleep and gather; verified with Python 3.14.4"]
    - [wf_cls_eq,          wait_for.__class__.__name__.__eq__,                     ["function"],              true, "asyncio.wait_for.__class__.__name__ == 'function' — plain Python coroutine function; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra260
# ---------------------------------------------------------------------------

invariant asyncio_extra260.bounded_semaphore_base_is_semaphore:
  description: "asyncio.BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore') returns True — BoundedSemaphore inherits from Semaphore (not directly from _ContextManagerMixin); BoundedSemaphore.__name__ has length 16; Semaphore.__name__ has length 9; verified with Python 3.14.4"
  category: identity
  kind: python_call_eq
  function: "BoundedSemaphore.__bases__[0].__name__.__eq__"
  args: ["Semaphore"]
  expected: true

invariant asyncio_extra260.semaphore_base_is_context_manager_mixin:
  description: "asyncio.Semaphore.__bases__[0].__name__.__eq__('_ContextManagerMixin') returns True — Semaphore inherits from _ContextManagerMixin (len=20); this is the same base as asyncio.Condition.__bases__[0]; Semaphore.__module__ is 'asyncio.locks' (len=13); verified with Python 3.14.4"
  category: identity
  kind: python_call_eq
  function: "Semaphore.__bases__[0].__name__.__eq__"
  args: ["_ContextManagerMixin"]
  expected: true

invariant asyncio_extra260.task_functions_share_module:
  description: "asyncio.sleep.__module__.__eq__('asyncio.tasks') returns True — sleep, gather, and wait_for all share __module__ == 'asyncio.tasks' (len=13); 'asyncio.tasks' and 'asyncio.locks' have the same length (13); all three are module-level functions with qualname == name; verified with Python 3.14.4"
  category: identity
  kind: python_call_eq
  function: sleep.__module__.__eq__
  args: ["asyncio.tasks"]
  expected: true
