spec: asyncio_extra260
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio coroutines and tasks documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/tasks.py"
  notes:
    - "asyncio.Semaphore.__name__ == 'Semaphore' (len=9); __module__ == 'asyncio.locks' (len=13); __bases__[0].__name__ == '_ContextManagerMixin' (len=20)."
    - "Semaphore.acquire.__qualname__ == 'Semaphore.acquire' (len=17); release.__qualname__ == 'Semaphore.release' (len=17, same length); locked.__qualname__ == 'Semaphore.locked' (len=16, shortest)."
    - "asyncio.BoundedSemaphore.__name__ == 'BoundedSemaphore' (len=16); __module__ == 'asyncio.locks' (len=13); __bases__[0].__name__ == 'Semaphore' (len=9) — BoundedSemaphore subclasses Semaphore."
    - "asyncio.sleep.__name__ == 'sleep' (len=5); __qualname__ == 'sleep' (len=5); __module__ == 'asyncio.tasks' (len=13); __class__.__name__ == 'function'."
    - "asyncio.gather.__name__ == 'gather' (len=6); __qualname__ == 'gather' (len=6); __module__ == 'asyncio.tasks' (len=13); __class__.__name__ == 'function'."
    - "asyncio.wait_for.__name__ == 'wait_for' (len=8); __qualname__ == 'wait_for' (len=8); __module__ == 'asyncio.tasks' (len=13); __class__.__name__ == 'function'."
    - "sleep, gather, and wait_for all share __module__ == 'asyncio.tasks' (len=13) — same length as 'asyncio.locks' (len=13)."
    - "Semaphore.__module__ and BoundedSemaphore.__module__ are both 'asyncio.locks' (len=13)."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Semaphore class identity
#
# asyncio.Semaphore.__name__ == 'Semaphore' (len=9)
# asyncio.Semaphore.__module__ == 'asyncio.locks' (len=13)
# asyncio.Semaphore.__bases__[0].__name__ == '_ContextManagerMixin' (len=20)
# asyncio.Semaphore.acquire.__qualname__ == 'Semaphore.acquire' (len=17)
# asyncio.Semaphore.release.__qualname__ == 'Semaphore.release' (len=17)
# asyncio.Semaphore.locked.__qualname__ == 'Semaphore.locked' (len=16)
# ---------------------------------------------------------------------------

table asyncio_extra260.semaphore_class_identity:
  description: "asyncio.Semaphore(len=9) class identity — inherits from _ContextManagerMixin(len=20); defined in asyncio.locks(len=13); locked.__qualname__ len=16 (shortest), acquire.__qualname__ len=17 == release.__qualname__ len=17 (longest, tied); verified with Python 3.14.4"
  kind: python_call_eq
  category: identity
  id_prefix: async260s

  columns: [id, function, args, expected, description]
  rows:
    - [s_name_eq,          Semaphore.__name__.__eq__,                              ["Semaphore"],              true, "asyncio.Semaphore.__name__ == 'Semaphore'; verified with Python 3.14.4"]
    - [s_name_len,         Semaphore.__name__.__len__,                             [],                         9,    "asyncio.Semaphore.__name__.__len__() == 9; verified with Python 3.14.4"]
    - [s_mod_eq,           Semaphore.__module__.__eq__,                            ["asyncio.locks"],          true, "asyncio.Semaphore.__module__ == 'asyncio.locks'; verified with Python 3.14.4"]
    - [s_mod_len,          Semaphore.__module__.__len__,                           [],                         13,   "asyncio.Semaphore.__module__.__len__() == 13; verified with Python 3.14.4"]
    - [s_base_eq,          "Semaphore.__bases__[0].__name__.__eq__",               ["_ContextManagerMixin"],   true, "asyncio.Semaphore.__bases__[0].__name__ == '_ContextManagerMixin' — Semaphore inherits from _ContextManagerMixin; verified with Python 3.14.4"]
    - [s_base_len,         "Semaphore.__bases__[0].__name__.__len__",              [],                         20,   "asyncio.Semaphore.__bases__[0].__name__.__len__() == 20; verified with Python 3.14.4"]
    - [s_acq_name_eq,      Semaphore.acquire.__name__.__eq__,                      ["acquire"],                true, "asyncio.Semaphore.acquire.__name__ == 'acquire'; verified with Python 3.14.4"]
    - [s_acq_name_len,     Semaphore.acquire.__name__.__len__,                     [],                         7,    "asyncio.Semaphore.acquire.__name__.__len__() == 7; verified with Python 3.14.4"]
    - [s_acq_qn_eq,        Semaphore.acquire.__qualname__.__eq__,                  ["Semaphore.acquire"],      true, "asyncio.Semaphore.acquire.__qualname__ == 'Semaphore.acquire'; verified with Python 3.14.4"]
    - [s_acq_qn_len,       Semaphore.acquire.__qualname__.__len__,                 [],                         17,   "asyncio.Semaphore.acquire.__qualname__.__len__() == 17 — tied longest with release; verified with Python 3.14.4"]
    - [s_rel_name_eq,      Semaphore.release.__name__.__eq__,                      ["release"],                true, "asyncio.Semaphore.release.__name__ == 'release'; verified with Python 3.14.4"]
    - [s_rel_name_len,     Semaphore.release.__name__.__len__,                     [],                         7,    "asyncio.Semaphore.release.__name__.__len__() == 7 — same length as acquire; verified with Python 3.14.4"]
    - [s_rel_qn_eq,        Semaphore.release.__qualname__.__eq__,                  ["Semaphore.release"],      true, "asyncio.Semaphore.release.__qualname__ == 'Semaphore.release'; verified with Python 3.14.4"]
    - [s_rel_qn_len,       Semaphore.release.__qualname__.__len__,                 [],                         17,   "asyncio.Semaphore.release.__qualname__.__len__() == 17 — tied longest with acquire; verified with Python 3.14.4"]
    - [s_lk_name_eq,       Semaphore.locked.__name__.__eq__,                       ["locked"],                 true, "asyncio.Semaphore.locked.__name__ == 'locked'; verified with Python 3.14.4"]
    - [s_lk_name_len,      Semaphore.locked.__name__.__len__,                      [],                         6,    "asyncio.Semaphore.locked.__name__.__len__() == 6 — shorter than acquire/release; verified with Python 3.14.4"]
    - [s_lk_qn_eq,         Semaphore.locked.__qualname__.__eq__,                   ["Semaphore.locked"],       true, "asyncio.Semaphore.locked.__qualname__ == 'Semaphore.locked'; verified with Python 3.14.4"]
    - [s_lk_qn_len,        Semaphore.locked.__qualname__.__len__,                  [],                         16,   "asyncio.Semaphore.locked.__qualname__.__len__() == 16 — shortest method qualname; verified with Python 3.14.4"]

