spec: node_crypto
version: ">=21.7.0"
backend: node(crypto)

docs: https://nodejs.org/api/crypto.html

provenance:
  derived_from:
    - "Node.js crypto module documentation — https://nodejs.org/api/crypto.html"
    - "Test vectors verified with Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "Node.js source"
  notes:
    - "crypto is a Node.js built-in module. No npm install required."
    - "crypto.hash(algorithm, data, outputEncoding) was added in Node.js v21.7.0."
    - "Returns the hash in one call. Known NIST test vectors for SHA-256 and SHA-512."
    - "SHA-256 hash of empty string is the known NIST FIPS 180-4 test vector."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns hex-encoded hash string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table node_crypto.hash:
  kind: node_module_call_eq
  function: hash
  category: hash
  id_prefix: crhash

  columns: [id, args, expected]
  rows:
    - [sha256_hello, ["sha256", "hello", "hex"],
       "2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824"]
    - [sha256_abc,   ["sha256", "abc", "hex"],
       "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad"]
    - [sha256_empty, ["sha256", "", "hex"],
       "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"]
    - [md5_hello,    ["md5", "hello", "hex"],
       "5d41402abc4b2a76b9719d911017c592"]

