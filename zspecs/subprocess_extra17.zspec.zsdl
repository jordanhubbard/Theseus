spec: subprocess_extra17
version: ">=3.9"
backend: python_module(subprocess)

docs: https://docs.python.org/3/library/subprocess.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/subprocess.html — Python subprocess module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/subprocess.py"
    - "subprocess_extra.zspec.zsdl — covers PIPE/STDOUT/DEVNULL __class__.__name__ == 'int' in a table."
    - "subprocess_extra6.zspec.zsdl — covers __qualname__ for Popen and module-level functions; CalledProcessError/TimeoutExpired/SubprocessError __qualname__ equality."
    - "subprocess_extra12.zspec.zsdl — covers Popen.__enter__/__exit__ __qualname__ and __module__."
    - "subprocess_extra13.zspec.zsdl — covers CalledProcessError/TimeoutExpired/SubprocessError __qualname__ equality standalone invariants."
    - "subprocess_extra15.zspec.zsdl — covers __qualname__ string lengths for subprocess classes and functions."
    - "subprocess_extra16.zspec.zsdl — covers __qualname__ for Popen instance methods communicate/wait/poll/kill/terminate/send_signal."
  notes:
    - "This spec extends subprocess.zspec.zsdl and all prior subprocess_extra specs through subprocess_extra16.zspec.zsdl."
    - "Focus: Popen.__init__.__qualname__, Popen.__repr__.__qualname__, subprocess module __name__/__package__, and PIPE/STDOUT/DEVNULL __class__.__qualname__."
    - "subprocess.Popen.__init__.__qualname__ == 'Popen.__init__' — dotted qualname for dunder constructor; not covered in any prior subprocess spec."
    - "subprocess.Popen.__repr__.__qualname__ == 'Popen.__repr__' — dotted qualname for repr method; not covered in any prior subprocess spec."
    - "subprocess.__name__ == 'subprocess' — module __name__ attribute; not covered in any prior subprocess spec."
    - "subprocess.__package__ == '' — module __package__ attribute; not covered in any prior subprocess spec."
    - "subprocess.PIPE.__class__.__qualname__ == 'int' — PIPE constant type qualname; prior specs check __class__.__name__ but not __qualname__."
    - "subprocess.STDOUT.__class__.__qualname__ == 'int' — STDOUT constant type qualname; not covered in any prior subprocess spec."
    - "subprocess.DEVNULL.__class__.__qualname__ == 'int' — DEVNULL constant type qualname; not covered in any prior subprocess spec."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Popen dunder method __qualname__ table — __init__ and __repr__
#
# subprocess_extra16 covers Popen method qualnames for communicate/wait/poll/
# kill/terminate/send_signal. subprocess_extra12 covers __enter__/__exit__.
# No prior subprocess spec covers Popen.__init__.__qualname__ or
# Popen.__repr__.__qualname__. This table fills those two gaps.
# ---------------------------------------------------------------------------

table subprocess_extra17.popen_dunder_qualnames:
  description: "__qualname__ for Popen.__init__ and Popen.__repr__ has dotted form 'Popen.<method>'"
  kind: python_call_eq
  category: function_identity
  id_prefix: qname17

  columns: [id, function, args, expected]
  rows:
    - [init,   "Popen.__init__.__qualname__.__eq__",   ["Popen.__init__"],   true]
    - [repr,   "Popen.__repr__.__qualname__.__eq__",   ["Popen.__repr__"],   true]

# ---------------------------------------------------------------------------
# subprocess module attributes — __name__ and __package__
#
# No prior subprocess spec checks subprocess.__name__ or subprocess.__package__.
# subprocess.__name__ is 'subprocess' (the module's fully qualified name).
# subprocess.__package__ is '' (empty string — subprocess is a top-level module).
# ---------------------------------------------------------------------------

table subprocess_extra17.module_attrs:
  description: "subprocess module __name__ and __package__ attributes"
  kind: python_call_eq
  category: module_attrs
  id_prefix: modattr17

  columns: [id, function, args, expected]
  rows:
    - [name,    __name__.__eq__,    ["subprocess"], true]
    - [package, __package__.__eq__, [""],           true]

# ---------------------------------------------------------------------------
# PIPE/STDOUT/DEVNULL — __class__.__qualname__
#
# subprocess_extra.zspec.zsdl covers PIPE/STDOUT/DEVNULL __class__.__name__
# == 'int'. No prior subprocess spec checks __class__.__qualname__ for any of
# these constants. Since int is a top-level builtin, its __qualname__ == 'int'.
# ---------------------------------------------------------------------------

table subprocess_extra17.sentinel_class_qualnames:
  description: "__class__.__qualname__ for PIPE/STDOUT/DEVNULL sentinel constants is 'int'"
  kind: python_call_eq
  category: type_attrs
  id_prefix: cqname17

  columns: [id, function, args, expected]
  rows:
    - [pipe,    PIPE.__class__.__qualname__.__eq__,    ["int"], true]
    - [stdout,  STDOUT.__class__.__qualname__.__eq__,  ["int"], true]
    - [devnull, DEVNULL.__class__.__qualname__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# Standalone invariants — Popen dunder qualnames
# ---------------------------------------------------------------------------

invariant subprocess_extra17.Popen.init.qualname:
  description: "subprocess.Popen.__init__.__qualname__ == 'Popen.__init__' — dotted qualname for constructor"
  category: function_identity
  kind: python_call_eq
  function: "Popen.__init__.__qualname__.__eq__"
  args: ["Popen.__init__"]
  expected: true

invariant subprocess_extra17.Popen.repr.qualname:
  description: "subprocess.Popen.__repr__.__qualname__ == 'Popen.__repr__' — dotted qualname for repr method"
  category: function_identity
  kind: python_call_eq
  function: "Popen.__repr__.__qualname__.__eq__"
  args: ["Popen.__repr__"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — module name and package
# ---------------------------------------------------------------------------

invariant subprocess_extra17.module.name:
  description: "subprocess.__name__ == 'subprocess' — module identity attribute"
  category: module_attrs
  kind: python_call_eq
  function: __name__.__eq__
  args: ["subprocess"]
  expected: true

invariant subprocess_extra17.module.package:
  description: "subprocess.__package__ == '' — subprocess is a top-level module with empty package"
  category: module_attrs
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true
