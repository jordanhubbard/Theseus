spec: pyright_rust
version: ">=3.9"
backend: rust_module(pyright_rust)

docs: https://github.com/microsoft/pyright

provenance:
  derived_from:
    - "https://github.com/microsoft/pyright — pyright type checker"
  notes:
    - "pyright is a static type checker for Python."
    - "pyright.__version__ is non-empty."
    - "pyright has version attribute."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant pyright_rust.has_version:
  description: "pyright.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: pyright_has_version
  args: []
  expected: true

invariant pyright_rust.version_is_string:
  description: "pyright.__version__ is a string"
  category: version
  kind: python_call_eq
  function: pyright_version_is_string
  args: []
  expected: true

invariant pyright_rust.version_nonempty:
  description: "pyright version string is non-empty"
  category: version
  kind: python_call_eq
  function: pyright_version_nonempty
  args: []
  expected: true

