spec: uuid_extra93
version: ">=3.9"
backend: python_module(uuid)
extends: uuid_extra92

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra92.zspec.zsdl — covers uuid.UUID property fget.__code__.co_name equality for all 10 properties / fget.__code__.co_argcount==1 / co_name.__len__() values (table + invariants)."
    - "uuid_extra91.zspec.zsdl — covers uuid.UUID.__init__/__str__/__repr__/__eq__/__hash__/__lt__/__int__ __qualname__.__len__() / uuid1/uuid4 __qualname__.__len__() / qualname equality cross-checks (table + invariants)."
    - "uuid_extra90.zspec.zsdl — covers NAMESPACE_URL/OID/X500 __class__.__name__=='UUID' / NAMESPACE_* version==1 / RFC_4122/RESERVED_* __class__.__name__=='str' and __len__() / UUID.__class__.__name__=='type' (table + invariants)."
    - "uuid_extra89.zspec.zsdl — covers UUID method __module__.__eq__('uuid') / UUID.fields.fget class/qualname / getnode/__code__.co_name / uuid5.__module__ (table + invariants)."
    - "uuid_extra86.zspec.zsdl — covers uuid.UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount (table + invariants)."
  notes:
    - "This spec extends uuid through uuid_extra92; it does NOT duplicate invariants present in those files."
    - "Wave 264 theme: uuid module __spec__ and __loader__ attribute lengths + UUID/uuid* __module__ lengths."
    - "uuid.__name__.__len__() == 4 ('uuid'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__spec__.name.__len__() == 4 ('uuid'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__spec__.__class__.__name__.__len__() == 10 ('ModuleSpec'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__loader__.__class__.__name__.__len__() == 16 ('SourceFileLoader'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__spec__.has_location == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__spec__.name.__eq__('uuid') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__module__.__len__() == 4 ('uuid'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__module__.__len__() == 4 ('uuid'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__module__.__len__() == 4 ('uuid'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.__class__.__module__.__len__() == 4 ('uuid'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.__name__.__len__()==4 ('uuid') is the shortest module name among the four spec series in this wave."
    - "Note: uuid.__spec__.name equals uuid.__name__ ('uuid') — both are 4 chars."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.__name__.__len__()==4
# uuid.__spec__.name.__len__()==4
# uuid.__spec__.__class__.__name__.__len__()==10
# uuid.__loader__.__class__.__name__.__len__()==16
#
# Wave 264 theme: uuid module attribute name lengths.
#
# uuid.__name__ is 'uuid' (4 chars). __spec__.name is also 'uuid' (4), confirming
# the spec's canonical name matches __name__. __spec__.__class__.__name__ is
# 'ModuleSpec' (10 chars). __loader__.__class__.__name__ is 'SourceFileLoader'
# (16 chars). Early uuid specs anchor __name__ and __package__ equality; this
# table first anchors __len__() for these attrs under uuidmodlen93.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra93.uuid_module_attr_name_lengths:
  description: "uuid.__name__/__len__()==4 / __spec__.name/__len__()==4 / __spec__/__class__.__name__/__len__()==10 / __loader__/__class__.__name__/__len__()==16 — __name__ and __spec__.name share length 4; 'ModuleSpec' is 10 chars; 'SourceFileLoader' is 16 chars; early uuid specs anchor equality; first uuidmodlen93 anchor for module attribute name lengths"
  kind: python_call_eq
  category: module_identity
  id_prefix: uuidmodlen93

  columns: [id, function, args, expected, description]
  rows:
    - [name_len,              __name__.__len__,                       [], 4,  "'uuid' is 4 chars"]
    - [spec_name_len,         __spec__.name.__len__,                  [], 4,  "__spec__.name is 'uuid', also 4 chars"]
    - [spec_class_name_len,   __spec__.__class__.__name__.__len__,    [], 10, "'ModuleSpec' is 10 chars"]
    - [loader_class_name_len, __loader__.__class__.__name__.__len__,  [], 16, "'SourceFileLoader' is 16 chars"]

# ---------------------------------------------------------------------------
# uuid.__spec__.has_location == True
# uuid.__spec__.name.__eq__('uuid')
#
# Wave 264 theme: uuid __spec__ location and name equality.
#
# uuid.__spec__.has_location is True because uuid.py is a source file with a
# known file-system path. __spec__.name is 'uuid', matching __name__. These
# confirm uuid is a regular source file with a known origin. Early uuid specs
# anchor __spec__.__class__.__name__.__eq__('ModuleSpec'); no prior spec anchors
# has_location or __spec__.name equality under uuidmodlen93.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra93.uuid_spec_location_and_name:
  description: "uuid.__spec__.has_location==True / __spec__.name/__eq__('uuid')==True — has_location is True because uuid.py is a source file with a known path; __spec__.name equals __name__ (both 'uuid'); early uuid specs anchor __spec__.__class__.__name__; first uuidmodlen93 anchor for has_location and __spec__.name equality"
  kind: python_call_eq
  category: module_identity
  id_prefix: uuidmodlen93

  columns: [id, function, args, expected, description]
  rows:
    - [spec_has_location, __spec__.has_location.__eq__, [true],    true, "has_location is True: uuid.py has a known file-system path"]
    - [spec_name_eq,      __spec__.name.__eq__,         ["uuid"],  true, "__spec__.name is 'uuid', equal to __name__"]

# ---------------------------------------------------------------------------
# uuid.UUID.__module__.__len__()==4
# uuid.uuid1.__module__.__len__()==4
# uuid.uuid4.__module__.__len__()==4
# uuid.NAMESPACE_DNS.__class__.__module__.__len__()==4
#
# Wave 264 theme: uuid sub-component __module__ string lengths.
#
# uuid.UUID.__module__ is 'uuid' (4 chars). uuid1.__module__ is 'uuid' (4 chars).
# uuid4.__module__ is 'uuid' (4 chars). NAMESPACE_DNS.__class__.__module__ is
# 'uuid' (4 chars) — NAMESPACE_DNS is a UUID instance, and UUID.__module__ is
# 'uuid'. All sub-components defined in Lib/uuid.py share __module__ == 'uuid'.
# uuid_extra89 anchors UUID method __module__.__eq__('uuid'); uuid_extra86 anchors
# uuid1/uuid4/uuid3/uuid5 __module__; no prior spec anchors __module__.__len__()==4
# for these sub-components under uuidmodlen93. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra93.uuid_subcomponent_module_lengths:
  description: "uuid.UUID/__module__/__len__()==4 / uuid1/__module__/__len__()==4 / uuid4/__module__/__len__()==4 / NAMESPACE_DNS/__class__/__module__/__len__()==4 — all defined in Lib/uuid.py; all share __module__=='uuid' (4 chars); extra89 anchors UUID __module__ equality; extra86 anchors uuid1/uuid4 __module__; first uuidmodlen93 anchor for sub-component __module__.__len__()"
  kind: python_call_eq
  category: module_identity
  id_prefix: uuidmodlen93

  columns: [id, function, args, expected, description]
  rows:
    - [UUID_module_len,           UUID.__module__.__len__,                   [], 4, "'uuid' is 4 chars — UUID class module length"]
    - [uuid1_module_len,          uuid1.__module__.__len__,                  [], 4, "'uuid' is 4 chars — uuid1 function module length"]
    - [uuid4_module_len,          uuid4.__module__.__len__,                  [], 4, "'uuid' is 4 chars — uuid4 function module length"]
    - [NAMESPACE_DNS_class_modlen, NAMESPACE_DNS.__class__.__module__.__len__, [], 4, "'uuid' is 4 chars — NAMESPACE_DNS is a UUID instance, UUID.__module__=='uuid'"]

# ---------------------------------------------------------------------------
# uuid.__spec__.name.__len__()==4 — standalone
#
# uuid.__spec__.name.__len__() is 4. __spec__.name is 'uuid', the canonical dotted
# name used by importlib to identify the module. For top-level modules it equals
# __name__. The module 'uuid' has the shortest name among the four modules covered
# in this wave (hashlib=7, struct=6, socket=6, uuid=4). Early uuid specs anchor
# __spec__.__class__.__name__.__eq__('ModuleSpec'); no prior spec anchors
# __spec__.name.__len__()==4 as a standalone under uuidmodlen93.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra93.spec_name_len_4:
  description: "uuid.__spec__.name.__len__() == 4 — __spec__.name is 'uuid' (4 chars); canonical importlib module name equals __name__; uuid has the shortest name among hashlib/struct/socket/uuid; early uuid specs anchor __spec__.__class__.__name__.__eq__('ModuleSpec'); first standalone for __spec__.name.__len__() under uuidmodlen93"
  category: module_identity
  kind: python_call_eq
  function: __spec__.name.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# uuid.__spec__.has_location == True — standalone
#
# uuid.__spec__.has_location is True. uuid.py is a pure-Python source file
# (Lib/uuid.py) with a known file-system path. The has_location property
# returns True when the ModuleSpec has an origin path pointing to a real file.
# Early uuid specs anchor __loader__.__class__.__name__.__eq__('SourceFileLoader');
# no prior spec anchors has_location as a standalone under uuidmodlen93.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra93.spec_has_location_true:
  description: "uuid.__spec__.has_location.__eq__(True) == True — has_location is True because uuid.py is a source file (Lib/uuid.py) with a known file-system path; early uuid specs anchor __loader__ class name; first standalone for has_location under uuidmodlen93"
  category: module_identity
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [true]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__module__.__len__()==4 — standalone
#
# uuid.UUID.__module__.__len__() is 4. UUID.__module__ is 'uuid' (4 chars).
# The UUID class is defined in Lib/uuid.py and its __module__ is 'uuid'. This
# 4-char module name is the same for all public names defined in uuid.py.
# uuid_extra89 anchors UUID.__hash__/__eq__/__int__/__lt__/__setattr__ __module__
# .__eq__('uuid'); no prior spec anchors UUID.__module__.__len__()==4 as a
# standalone under uuidmodlen93. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra93.UUID_module_len_4:
  description: "uuid.UUID.__module__.__len__() == 4 — UUID.__module__ is 'uuid' (4 chars); UUID is defined in Lib/uuid.py; all public uuid names share __module__=='uuid' (4 chars); extra89 anchors UUID method __module__.__eq__('uuid'); first standalone for UUID.__module__.__len__() under uuidmodlen93"
  category: module_identity
  kind: python_call_eq
  function: UUID.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# uuid.__loader__.__class__.__name__.__len__()==16 — standalone
#
# uuid.__loader__.__class__.__name__.__len__() is 16. The class name is
# 'SourceFileLoader' — 16 characters. uuid.py is a pure-Python source file
# loaded by importlib.machinery.SourceFileLoader. This is consistent with
# other pure-Python stdlib modules like hashlib and socket.
# Early uuid specs anchor __loader__.__class__.__name__.__eq__('SourceFileLoader');
# no prior spec anchors __loader__.__class__.__name__.__len__()==16 as a
# standalone under uuidmodlen93. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra93.loader_class_name_len_16:
  description: "uuid.__loader__.__class__.__name__.__len__() == 16 — 'SourceFileLoader' is 16 chars; uuid.py is loaded by importlib.machinery.SourceFileLoader; consistent with other pure-Python stdlib modules; early uuid specs anchor __loader__.__class__.__name__.__eq__('SourceFileLoader'); first standalone for __loader__.__class__.__name__.__len__() under uuidmodlen93"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__len__
  args: []
  expected: 16
