spec: multiprocessing_extra1531
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.pool.Pool — Pool class documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "Wave 549 theme: comparison operator dict-presence checks — __lt__, __le__, __gt__, __ge__, __ne__, __eq__, __hash__ in class __dict__."
    - "multiprocessing.Process is the concrete process class; its own __dict__ is thin — run(), start(), join(), terminate(), kill(), is_alive() are defined in BaseProcess, not Process.__dict__ itself."
    - "multiprocessing.pool.Pool is the worker pool class; its own __dict__ contains apply(), map(), close(), terminate(), join() but no comparison operators."
    - "Neither Process nor Pool define any comparison operator protocol methods in their own __dict__ — these are process-management types, not ordered or value-equality types."
    - "multiprocessing.Process.__dict__ is sparse — only _start_method, _Popen, _after_fork plus standard dunder slots; run/start/join etc. are on BaseProcess."
    - "multiprocessing.pool.Pool.__dict__ contains pool-management methods: apply(), map(), starmap(), imap(), imap_unordered(), apply_async(), map_async(), close(), terminate(), join()."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.Process comparison operator __dict__ absence
#
# multiprocessing.Process.__dict__.__contains__('__lt__')        == False
# multiprocessing.Process.__dict__.__contains__('__le__')        == False
# multiprocessing.Process.__dict__.__contains__('__gt__')        == False
# multiprocessing.Process.__dict__.__contains__('__ge__')        == False
# multiprocessing.Process.__dict__.__contains__('__ne__')        == False
# multiprocessing.Process.__dict__.__contains__('__eq__')        == False
# multiprocessing.Process.__dict__.__contains__('__hash__')      == False
# multiprocessing.Process.__dict__.__contains__('_start_method') == True
# ---------------------------------------------------------------------------

table multiprocessing_extra1531.process_no_cmp_ops:
  description: "multiprocessing.Process has no comparison operator methods in its own __dict__ — mp1531pr namespace. multiprocessing.Process.__dict__.__contains__('__lt__')==False (Process is a process-management class; ordering between process objects is semantically undefined; no __lt__ in Process.__dict__); multiprocessing.Process.__dict__.__contains__('__le__')==False (no less-than-or-equal on Process); multiprocessing.Process.__dict__.__contains__('__gt__')==False (no greater-than on Process); multiprocessing.Process.__dict__.__contains__('__ge__')==False (no greater-than-or-equal on Process); multiprocessing.Process.__dict__.__contains__('__ne__')==False (Process does not override __ne__); multiprocessing.Process.__dict__.__contains__('__eq__')==False (Process does not override __eq__ in its own __dict__; identity falls through to object); multiprocessing.Process.__dict__.__contains__('__hash__')==False (Process does not override __hash__); multiprocessing.Process.__dict__.__contains__('_start_method')==True (_start_method IS defined directly in Process.__dict__ — it is a platform-specific class attribute set to None or a start method string on the concrete Process class); verified with Python 3.14.4"
  kind: python_call_eq
  category: comparison_protocol
  id_prefix: mp1531pr

  columns: [id, function, args, expected, description]
  rows:
    - [mp1531pr001, multiprocessing.Process.__dict__.__contains__, ["__lt__"],        false, "multiprocessing.Process.__dict__.__contains__('__lt__')==False — Process is a process-management class; no ordering operators; verified with Python 3.14.4"]
    - [mp1531pr002, multiprocessing.Process.__dict__.__contains__, ["__le__"],        false, "multiprocessing.Process.__dict__.__contains__('__le__')==False — no less-than-or-equal on Process; verified with Python 3.14.4"]
    - [mp1531pr003, multiprocessing.Process.__dict__.__contains__, ["__gt__"],        false, "multiprocessing.Process.__dict__.__contains__('__gt__')==False — no greater-than on Process; verified with Python 3.14.4"]
    - [mp1531pr004, multiprocessing.Process.__dict__.__contains__, ["__ge__"],        false, "multiprocessing.Process.__dict__.__contains__('__ge__')==False — no greater-than-or-equal on Process; verified with Python 3.14.4"]
    - [mp1531pr005, multiprocessing.Process.__dict__.__contains__, ["__ne__"],        false, "multiprocessing.Process.__dict__.__contains__('__ne__')==False — Process does not override __ne__; verified with Python 3.14.4"]
    - [mp1531pr006, multiprocessing.Process.__dict__.__contains__, ["__eq__"],        false, "multiprocessing.Process.__dict__.__contains__('__eq__')==False — Process does not override __eq__; identity falls through to object; verified with Python 3.14.4"]
    - [mp1531pr007, multiprocessing.Process.__dict__.__contains__, ["__hash__"],      false, "multiprocessing.Process.__dict__.__contains__('__hash__')==False — Process does not override __hash__; verified with Python 3.14.4"]
    - [mp1531pr008, multiprocessing.Process.__dict__.__contains__, ["_start_method"], true,  "multiprocessing.Process.__dict__.__contains__('_start_method')==True — _start_method IS defined directly in Process.__dict__; platform-specific start method attribute; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Table 2: multiprocessing.pool.Pool comparison operator __dict__ absence
#
# multiprocessing.pool.Pool.__dict__.__contains__('__lt__')   == False
# multiprocessing.pool.Pool.__dict__.__contains__('__le__')   == False
# multiprocessing.pool.Pool.__dict__.__contains__('__gt__')   == False
# multiprocessing.pool.Pool.__dict__.__contains__('__ge__')   == False
# multiprocessing.pool.Pool.__dict__.__contains__('__ne__')   == False
# multiprocessing.pool.Pool.__dict__.__contains__('__eq__')   == False
# multiprocessing.pool.Pool.__dict__.__contains__('__hash__') == False
# multiprocessing.pool.Pool.__dict__.__contains__('apply')    == True
# multiprocessing.pool.Pool.__dict__.__contains__('map')      == True
# ---------------------------------------------------------------------------

table multiprocessing_extra1531.pool_no_cmp_ops:
  description: "multiprocessing.pool.Pool has no comparison operator methods in its own __dict__ — mp1531po namespace. multiprocessing.pool.Pool.__dict__.__contains__('__lt__')==False (Pool is a worker pool managing a set of child processes; ordering between pool objects is not meaningful; no __lt__ in Pool.__dict__); multiprocessing.pool.Pool.__dict__.__contains__('__le__')==False (no less-than-or-equal on Pool); multiprocessing.pool.Pool.__dict__.__contains__('__gt__')==False (no greater-than on Pool); multiprocessing.pool.Pool.__dict__.__contains__('__ge__')==False (no greater-than-or-equal on Pool); multiprocessing.pool.Pool.__dict__.__contains__('__ne__')==False (Pool does not override __ne__); multiprocessing.pool.Pool.__dict__.__contains__('__eq__')==False (Pool does not override __eq__); multiprocessing.pool.Pool.__dict__.__contains__('__hash__')==False (Pool does not override __hash__); multiprocessing.pool.Pool.__dict__.__contains__('apply')==True (Pool.apply() IS defined directly in Pool.__dict__ — submits a single call to a worker process synchronously); multiprocessing.pool.Pool.__dict__.__contains__('map')==True (Pool.map() IS defined directly in Pool.__dict__ — distributes iterable items across the pool workers); verified with Python 3.14.4"
  kind: python_call_eq
  category: comparison_protocol
  id_prefix: mp1531po

  columns: [id, function, args, expected, description]
  rows:
    - [mp1531po001, multiprocessing.pool.Pool.__dict__.__contains__, ["__lt__"],   false, "multiprocessing.pool.Pool.__dict__.__contains__('__lt__')==False — Pool manages worker processes; no ordering operators; verified with Python 3.14.4"]
    - [mp1531po002, multiprocessing.pool.Pool.__dict__.__contains__, ["__le__"],   false, "multiprocessing.pool.Pool.__dict__.__contains__('__le__')==False — no less-than-or-equal on Pool; verified with Python 3.14.4"]
    - [mp1531po003, multiprocessing.pool.Pool.__dict__.__contains__, ["__gt__"],   false, "multiprocessing.pool.Pool.__dict__.__contains__('__gt__')==False — no greater-than on Pool; verified with Python 3.14.4"]
    - [mp1531po004, multiprocessing.pool.Pool.__dict__.__contains__, ["__ge__"],   false, "multiprocessing.pool.Pool.__dict__.__contains__('__ge__')==False — no greater-than-or-equal on Pool; verified with Python 3.14.4"]
    - [mp1531po005, multiprocessing.pool.Pool.__dict__.__contains__, ["__ne__"],   false, "multiprocessing.pool.Pool.__dict__.__contains__('__ne__')==False — Pool does not override __ne__; verified with Python 3.14.4"]
    - [mp1531po006, multiprocessing.pool.Pool.__dict__.__contains__, ["__eq__"],   false, "multiprocessing.pool.Pool.__dict__.__contains__('__eq__')==False — Pool does not override __eq__; verified with Python 3.14.4"]
    - [mp1531po007, multiprocessing.pool.Pool.__dict__.__contains__, ["__hash__"], false, "multiprocessing.pool.Pool.__dict__.__contains__('__hash__')==False — Pool does not override __hash__; verified with Python 3.14.4"]
    - [mp1531po008, multiprocessing.pool.Pool.__dict__.__contains__, ["apply"],    true,  "multiprocessing.pool.Pool.__dict__.__contains__('apply')==True — Pool.apply() IS defined in Pool.__dict__; submits single call to worker synchronously; verified with Python 3.14.4"]
    - [mp1531po009, multiprocessing.pool.Pool.__dict__.__contains__, ["map"],      true,  "multiprocessing.pool.Pool.__dict__.__contains__('map')==True — Pool.map() IS defined in Pool.__dict__; distributes iterable work across pool workers; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Table 3: cross-class comparison operator absence survey
#          (both Process and Pool, covering remaining ops)
#
# multiprocessing.Process.__dict__.__contains__('__lt__')   == False
# multiprocessing.Process.__dict__.__contains__('__hash__') == False
# multiprocessing.pool.Pool.__dict__.__contains__('close')  == True
# multiprocessing.pool.Pool.__dict__.__contains__('join')   == True
# multiprocessing.pool.Pool.__dict__.__contains__('__lt__') == False
# multiprocessing.pool.Pool.__dict__.__contains__('__ne__') == False
# multiprocessing.Process.__dict__.__contains__('__gt__')   == False
# multiprocessing.Process.__dict__.__contains__('__ge__')   == False
# ---------------------------------------------------------------------------

table multiprocessing_extra1531.cross_class_no_cmp_ops:
  description: "Cross-class survey: both multiprocessing.Process and multiprocessing.pool.Pool have no comparison operators in their __dict__ — mp1531cc namespace. This table consolidates additional absence checks across both classes alongside anchor true-rows confirming that pool lifecycle methods (close, join) are present in Pool.__dict__. multiprocessing.Process.__dict__.__contains__('__lt__')==False (confirmed absence — Process defines no ordering operators); multiprocessing.Process.__dict__.__contains__('__hash__')==False (Process does not override __hash__ in its own __dict__); multiprocessing.pool.Pool.__dict__.__contains__('close')==True (Pool.close() IS defined in Pool.__dict__ — prevents any more tasks from being submitted to the pool); multiprocessing.pool.Pool.__dict__.__contains__('join')==True (Pool.join() IS defined in Pool.__dict__ — waits for all worker processes to exit; must be called after close() or terminate()); multiprocessing.pool.Pool.__dict__.__contains__('__lt__')==False (Pool defines no ordering operators); multiprocessing.pool.Pool.__dict__.__contains__('__ne__')==False (Pool does not override __ne__); multiprocessing.Process.__dict__.__contains__('__gt__')==False (no greater-than on Process); multiprocessing.Process.__dict__.__contains__('__ge__')==False (no greater-than-or-equal on Process); verified with Python 3.14.4"
  kind: python_call_eq
  category: comparison_protocol
  id_prefix: mp1531cc

  columns: [id, function, args, expected, description]
  rows:
    - [mp1531cc001, multiprocessing.Process.__dict__.__contains__,   ["__lt__"],   false, "multiprocessing.Process.__dict__.__contains__('__lt__')==False — Process is a process manager; no ordering; verified with Python 3.14.4"]
    - [mp1531cc002, multiprocessing.Process.__dict__.__contains__,   ["__hash__"], false, "multiprocessing.Process.__dict__.__contains__('__hash__')==False — Process does not override __hash__; verified with Python 3.14.4"]
    - [mp1531cc003, multiprocessing.pool.Pool.__dict__.__contains__,  ["close"],    true,  "multiprocessing.pool.Pool.__dict__.__contains__('close')==True — Pool.close() IS defined in Pool.__dict__; stops accepting new tasks; verified with Python 3.14.4"]
    - [mp1531cc004, multiprocessing.pool.Pool.__dict__.__contains__,  ["join"],     true,  "multiprocessing.pool.Pool.__dict__.__contains__('join')==True — Pool.join() IS defined in Pool.__dict__; waits for all workers to exit; verified with Python 3.14.4"]
    - [mp1531cc005, multiprocessing.pool.Pool.__dict__.__contains__,  ["__lt__"],   false, "multiprocessing.pool.Pool.__dict__.__contains__('__lt__')==False — Pool defines no ordering operators; verified with Python 3.14.4"]
    - [mp1531cc006, multiprocessing.pool.Pool.__dict__.__contains__,  ["__ne__"],   false, "multiprocessing.pool.Pool.__dict__.__contains__('__ne__')==False — Pool does not override __ne__; verified with Python 3.14.4"]
    - [mp1531cc007, multiprocessing.Process.__dict__.__contains__,   ["__gt__"],   false, "multiprocessing.Process.__dict__.__contains__('__gt__')==False — no greater-than on Process; verified with Python 3.14.4"]
    - [mp1531cc008, multiprocessing.Process.__dict__.__contains__,   ["__ge__"],   false, "multiprocessing.Process.__dict__.__contains__('__ge__')==False — no greater-than-or-equal on Process; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1531
# ---------------------------------------------------------------------------

invariant multiprocessing_extra1531.process_no_lt:
  description: "multiprocessing.Process.__dict__.__contains__('__lt__') returns False — multiprocessing.Process does not define __lt__ in its own __dict__; Process is a concrete class for spawning and managing child OS processes; its own __dict__ is thin (only _start_method, _Popen, _after_fork plus standard dunder slots); the runtime interface (run(), start(), join(), terminate(), kill(), is_alive()) is defined on the BaseProcess parent class rather than Process itself; no comparison operator protocol methods exist anywhere in Process's own __dict__; wave 549 theme: comparison operator dict-presence checks; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: comparison_protocol
  kind: python_call_eq
  function: multiprocessing.Process.__dict__.__contains__
  args: ["__lt__"]
  expected: false

invariant multiprocessing_extra1531.pool_no_hash:
  description: "multiprocessing.pool.Pool.__dict__.__contains__('__hash__') returns False — multiprocessing.pool.Pool does not define __hash__ in its own __dict__; Pool is a worker pool class that manages a set of worker processes for parallel task dispatch; its __dict__ contains apply(), map(), starmap(), imap(), imap_unordered(), apply_async(), map_async(), close(), terminate(), join(), and internal helpers — all task-dispatch and lifecycle methods; __hash__ is not overridden so pool objects use default object identity hashing; wave 549 theme: comparison operator dict-presence checks; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: comparison_protocol
  kind: python_call_eq
  function: multiprocessing.pool.Pool.__dict__.__contains__
  args: ["__hash__"]
  expected: false

invariant multiprocessing_extra1531.process_no_eq:
  description: "multiprocessing.Process.__dict__.__contains__('__eq__') returns False — multiprocessing.Process does not define __eq__ in its own __dict__; Process identity equality is not overridden at the Process class level — two distinct Process objects with the same target function are not considered equal by the Process class; equality falls through to object.__eq__ (identity comparison); wave 549 theme; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: comparison_protocol
  kind: python_call_eq
  function: multiprocessing.Process.__dict__.__contains__
  args: ["__eq__"]
  expected: false

invariant multiprocessing_extra1531.pool_no_le:
  description: "multiprocessing.pool.Pool.__dict__.__contains__('__le__') returns False — multiprocessing.pool.Pool does not define __le__ in its own __dict__; Pool manages a bounded pool of worker subprocesses; the pool size may be configured via processes= argument but the Pool object itself is not comparable with __le__ (less-than-or-equal); ordering between pools is not defined; wave 549 theme; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: comparison_protocol
  kind: python_call_eq
  function: multiprocessing.pool.Pool.__dict__.__contains__
  args: ["__le__"]
  expected: false
