spec: ft3181
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 659 (ft3181): __truediv__, __floordiv__, __mod__ dict-presence checks for functools types."
    - "None of the four functools types define __truediv__, __floordiv__, or __mod__ in their own __dict__."
    - "functools.partial and functools._lru_cache_wrapper are C-level types; functools.partialmethod and functools.cached_property are Python-level classes."
    - "functools._lru_cache_wrapper is accessed as type(functools.lru_cache(lambda: None)) at runtime; functools._lru_cache_wrapper is the internal C wrapper class."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ft3181.truediv:
  description: "functools types __truediv__ dict-presence checks; wave 659"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft3181
  columns: [id, function, args, expected]
  rows:
    - ["ft3181001", operator.contains, [functools.partial.__dict__,            "__truediv__"], false]
    - ["ft3181002", operator.contains, [functools.partialmethod.__dict__,      "__truediv__"], false]
    - ["ft3181003", operator.contains, [functools.cached_property.__dict__,    "__truediv__"], false]
    - ["ft3181004", operator.contains, [functools._lru_cache_wrapper.__dict__, "__truediv__"], false]

