spec: mailbox_extra4
version: ">=3.9"
backend: python_module(mailbox)

docs: https://docs.python.org/3/library/mailbox.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/mailbox.html — Python mailbox module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/mailbox.py"
  notes:
    - "This spec extends mailbox.zspec.zsdl through mailbox_extra3.zspec.zsdl."
    - "mailbox.zspec.zsdl covers: __name__ table for container/message/exception classes; Mailbox.__module__; hierarchy for Maildir/NoSuchMailboxError/NotEmptyError/ExternalClashError."
    - "mailbox_extra.zspec.zsdl covers: __module__ for all container/message/exception classes; Error.__name__ and base; mbox/MH/Babyl/MMDF bases; Message base; Mailbox.__doc__; FormatError base; all message-subclass bases."
    - "mailbox_extra2.zspec.zsdl covers: __qualname__ for Mailbox/Maildir/mbox/MH/Babyl/MMDF/Message and exception classes; mbox direct base == '_singlefileMailbox'; Mailbox base == 'object'; Message base __qualname__; Error.__qualname__."
    - "mailbox_extra3.zspec.zsdl covers: __name__ standalone invariants for container classes; Message.__module__ standalone; __name__ length checks for container classes and Message."
    - "This spec adds: __qualname__ for the five format-specific message subclasses (MaildirMessage, mboxMessage, MHMessage, BabylMessage, MMDFMessage) — not present in any prior spec; __name__ length checks for those subclasses; __module__ for MaildirMessage via standalone invariant (all prior module checks were in table form)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — format-specific message subclasses
# (mailbox_extra2 covers __qualname__ for container classes and exception
#  classes, and Message itself; the five message subclasses are new here)
# ---------------------------------------------------------------------------

table mailbox_extra4.qualnames.message_subclasses:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [MaildirMessage, MaildirMessage.__qualname__.__eq__, ["MaildirMessage"], true]
    - [mboxMessage,    mboxMessage.__qualname__.__eq__,    ["mboxMessage"],    true]
    - [MHMessage,      MHMessage.__qualname__.__eq__,      ["MHMessage"],      true]
    - [BabylMessage,   BabylMessage.__qualname__.__eq__,   ["BabylMessage"],   true]
    - [MMDFMessage,    MMDFMessage.__qualname__.__eq__,    ["MMDFMessage"],    true]

# ---------------------------------------------------------------------------
# __name__ length checks — format-specific message subclasses
# (mailbox_extra3 checks length for container classes and Message;
#  the five format-specific message subclasses are not yet checked)
# ---------------------------------------------------------------------------

invariant mailbox_extra4.MaildirMessage.name_len:
  description: "mailbox.MaildirMessage.__name__.__len__() == 14 — 'MaildirMessage' has 14 characters"
  category: class_identity
  kind: python_call_eq
  function: MaildirMessage.__name__.__len__
  args: []
  expected: 14

invariant mailbox_extra4.mboxMessage.name_len:
  description: "mailbox.mboxMessage.__name__.__len__() == 11 — 'mboxMessage' has 11 characters"
  category: class_identity
  kind: python_call_eq
  function: mboxMessage.__name__.__len__
  args: []
  expected: 11

invariant mailbox_extra4.MHMessage.name_len:
  description: "mailbox.MHMessage.__name__.__len__() == 9 — 'MHMessage' has 9 characters"
  category: class_identity
  kind: python_call_eq
  function: MHMessage.__name__.__len__
  args: []
  expected: 9

invariant mailbox_extra4.BabylMessage.name_len:
  description: "mailbox.BabylMessage.__name__.__len__() == 12 — 'BabylMessage' has 12 characters"
  category: class_identity
  kind: python_call_eq
  function: BabylMessage.__name__.__len__
  args: []
  expected: 12

invariant mailbox_extra4.MMDFMessage.name_len:
  description: "mailbox.MMDFMessage.__name__.__len__() == 11 — 'MMDFMessage' has 11 characters"
  category: class_identity
  kind: python_call_eq
  function: MMDFMessage.__name__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# __module__ standalone invariants — format-specific message subclasses
# (mailbox_extra covered __module__ for all message classes in a table row;
#  here we add standalone invariants for individual traceability)
# ---------------------------------------------------------------------------

invariant mailbox_extra4.MaildirMessage.module:
  description: "mailbox.MaildirMessage.__module__ == 'mailbox'"
  category: module
  kind: python_call_eq
  function: MaildirMessage.__module__.__eq__
  args: ["mailbox"]
  expected: true

invariant mailbox_extra4.mboxMessage.module:
  description: "mailbox.mboxMessage.__module__ == 'mailbox'"
  category: module
  kind: python_call_eq
  function: mboxMessage.__module__.__eq__
  args: ["mailbox"]
  expected: true

invariant mailbox_extra4.MHMessage.module:
  description: "mailbox.MHMessage.__module__ == 'mailbox'"
  category: module
  kind: python_call_eq
  function: MHMessage.__module__.__eq__
  args: ["mailbox"]
  expected: true
