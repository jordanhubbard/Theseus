spec: re_extra75
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends all prior re specs through re_extra74."
    - "Prior specs covered: Pattern/Match class identity (__name__/__module__/__qualname__); Pattern/Match __class__.__name__ == 'type'; Pattern/Match __dict__ membership (match, search, group, span, findall, sub, groups); Pattern/Match method __class__.__name__ == 'method_descriptor'; re flag __class__.__name__ == 'RegexFlag'."
    - "re_extra74 covers Pattern/Match C method __class__.__name__ == 'method_descriptor'; re flag RegexFlag enum membership."
    - "This spec covers: re compiled Pattern/Match method __qualname__ values; Pattern/Match __dict__.__class__.__name__; re.error.__name__ and re.error.__bases__[0].__name__."
    - "re.Pattern.match.__qualname__ == 'Pattern.match' — C method descriptor qualname."
    - "re.Pattern.search.__qualname__ == 'Pattern.search' — C method descriptor qualname."
    - "re.Pattern.findall.__qualname__ == 'Pattern.findall' — C method descriptor qualname."
    - "re.Pattern.sub.__qualname__ == 'Pattern.sub' — C method descriptor qualname."
    - "re.Match.group.__qualname__ == 'Match.group' — C method descriptor qualname."
    - "re.Match.groups.__qualname__ == 'Match.groups' — C method descriptor qualname."
    - "re.Match.span.__qualname__ == 'Match.span' — C method descriptor qualname."
    - "re.Pattern.__dict__.__class__.__name__ == 'mappingproxy' — C type dict is mappingproxy."
    - "re.Match.__dict__.__class__.__name__ == 'mappingproxy' — C type dict is mappingproxy."
    - "re.error.__name__ == 'PatternError' — Python 3.13+ renamed re.error to PatternError."
    - "re.error.__bases__[0].__name__ == 'Exception' — PatternError directly subclasses Exception."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Pattern method __qualname__ checks
# Pattern is a C type in _sre. Its methods are C method_descriptors that
# carry __qualname__ attributes. Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra75.Pattern_method_qualnames:
  description: "re.Pattern C method descriptors carry correct __qualname__ values"
  kind: python_call_eq
  category: method_descriptors
  id_prefix: remore75

  columns: [id, function, args, expected]
  rows:
    - [match_qualname,   Pattern.match.__qualname__.__eq__,   ["Pattern.match"],   true]
    - [search_qualname,  Pattern.search.__qualname__.__eq__,  ["Pattern.search"],  true]
    - [findall_qualname, Pattern.findall.__qualname__.__eq__, ["Pattern.findall"], true]
    - [sub_qualname,     Pattern.sub.__qualname__.__eq__,     ["Pattern.sub"],     true]

# ---------------------------------------------------------------------------
# Match method __qualname__ checks
# Match is a C type in _sre. Its methods carry __qualname__ attributes.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra75.Match_method_qualnames:
  description: "re.Match C method descriptors carry correct __qualname__ values"
  kind: python_call_eq
  category: method_descriptors
  id_prefix: remore75

  columns: [id, function, args, expected]
  rows:
    - [group_qualname,  Match.group.__qualname__.__eq__,  ["Match.group"],  true]
    - [groups_qualname, Match.groups.__qualname__.__eq__, ["Match.groups"], true]
    - [span_qualname,   Match.span.__qualname__.__eq__,   ["Match.span"],   true]

# ---------------------------------------------------------------------------
# Pattern and Match __dict__.__class__.__name__ checks
# Both are C types; their class __dict__ is a mappingproxy.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra75.Pattern_Match_dict_class:
  description: "re.Pattern and re.Match __dict__ are mappingproxy instances"
  kind: python_call_eq
  category: class_dict
  id_prefix: remore75

  columns: [id, function, args, expected]
  rows:
    - [pattern_dict_class, Pattern.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [match_dict_class,   Match.__dict__.__class__.__name__.__eq__,   ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# re.error class identity
# In Python 3.13+, re.error was renamed to re.PatternError.
# re.error is now an alias for re.PatternError; __name__ returns 'PatternError'.
# re.error.__bases__[0].__name__ == 'Exception'.
# Function values with [ must be double-quoted.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra75.error_identity:
  description: "re.error class identity: __name__ and base class"
  kind: python_call_eq
  category: class_names
  id_prefix: remore75

  columns: [id, function, args, expected]
  rows:
    - [error_name,      error.__name__.__eq__,                      ["PatternError"], true]
    - [error_base_name, "error.__bases__[0].__name__.__eq__",       ["Exception"],    true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra75.Pattern_match.qualname:
  description: "re.Pattern.match.__qualname__ == 'Pattern.match'"
  category: method_descriptors
  kind: python_call_eq
  function: Pattern.match.__qualname__.__eq__
  args: ["Pattern.match"]
  expected: true

invariant re_extra75.Pattern_search.qualname:
  description: "re.Pattern.search.__qualname__ == 'Pattern.search'"
  category: method_descriptors
  kind: python_call_eq
  function: Pattern.search.__qualname__.__eq__
  args: ["Pattern.search"]
  expected: true

invariant re_extra75.Match_group.qualname:
  description: "re.Match.group.__qualname__ == 'Match.group'"
  category: method_descriptors
  kind: python_call_eq
  function: Match.group.__qualname__.__eq__
  args: ["Match.group"]
  expected: true

invariant re_extra75.Pattern_dict.mappingproxy:
  description: "re.Pattern.__dict__.__class__.__name__ == 'mappingproxy'"
  category: class_dict
  kind: python_call_eq
  function: Pattern.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant re_extra75.error.name_is_PatternError:
  description: "re.error.__name__ == 'PatternError' — renamed in Python 3.13+"
  category: class_names
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["PatternError"]
  expected: true
