spec: traceback_extra
version: ">=3.5"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "Python 3 traceback documentation — https://docs.python.org/3/library/traceback.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
  notes:
    - "Covers class __name__ and __module__ checks for TracebackException, StackSummary, and FrameSummary."
    - "Covers __name__ checks for traceback utility functions not duplicated with exact IDs from traceback.zspec.zsdl."
    - "TracebackException, StackSummary, and FrameSummary were added in Python 3.5."
    - "All __name__ and __module__ attributes are static class/function metadata, not dependent on runtime state."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ checks — TracebackException, StackSummary, FrameSummary
# ---------------------------------------------------------------------------

invariant traceback_extra.class_names.tracebackexception:
  description: "traceback.TracebackException.__name__ == 'TracebackException'"
  category: class_names
  kind: python_call_eq
  function: TracebackException.__name__.__eq__
  args: ["TracebackException"]
  expected: true

invariant traceback_extra.class_names.stacksummary:
  description: "traceback.StackSummary.__name__ == 'StackSummary'"
  category: class_names
  kind: python_call_eq
  function: StackSummary.__name__.__eq__
  args: ["StackSummary"]
  expected: true

invariant traceback_extra.class_names.framesummary:
  description: "traceback.FrameSummary.__name__ == 'FrameSummary'"
  category: class_names
  kind: python_call_eq
  function: FrameSummary.__name__.__eq__
  args: ["FrameSummary"]
  expected: true

# ---------------------------------------------------------------------------
# Class __module__ checks
# ---------------------------------------------------------------------------

invariant traceback_extra.class_modules.tracebackexception:
  description: "traceback.TracebackException.__module__ == 'traceback'"
  category: class_modules
  kind: python_call_eq
  function: TracebackException.__module__.__eq__
  args: ["traceback"]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ checks
# ---------------------------------------------------------------------------

table traceback_extra.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [format_exc,       format_exc.__name__.__eq__,       ["format_exc"],       true]
    - [format_tb,        format_tb.__name__.__eq__,        ["format_tb"],        true]
    - [format_exception, format_exception.__name__.__eq__,  ["format_exception"], true]
    - [print_exc,        print_exc.__name__.__eq__,        ["print_exc"],        true]
    - [print_tb,         print_tb.__name__.__eq__,         ["print_tb"],         true]
    - [extract_tb,       extract_tb.__name__.__eq__,       ["extract_tb"],       true]
    - [extract_stack,    extract_stack.__name__.__eq__,    ["extract_stack"],    true]
    - [clear_frames,     clear_frames.__name__.__eq__,     ["clear_frames"],     true]
