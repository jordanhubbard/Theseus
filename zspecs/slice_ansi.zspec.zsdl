spec: slice_ansi
version: ">=7.0.0"
backend: node(slice-ansi)

docs: https://github.com/chalk/slice-ansi#readme

provenance:
  derived_from:
    - "slice-ansi README — https://github.com/chalk/slice-ansi#readme"
    - "Test vectors verified with slice-ansi via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "slice-ansi source"
  notes:
    - "Slices a string while respecting ANSI escape codes — used by chalk, ora, ink, and other CLI tools."
    - "Install: npm install slice-ansi"
    - "v7 is ESM with a CJS shim; default export is the function: sliceAnsi(input, start, end?)."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on string input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table slice_ansi.slice:
  kind: node_chain_eq
  category: slice
  entry: named
  function: default
  id_prefix: slice

  columns: [id, entry_args, chain, expected]
  rows:
    - [first_5_chars,
       ["hello world", 0, 5],
       [],
       "hello"]

    - [middle_slice,
       ["foo bar", 4, 7],
       [],
       "bar"]

    - [from_zero_to_end,
       ["plain", 0, 5],
       [],
       "plain"]

    - [empty_string_unchanged,
       ["", 0, 0],
       [],
       ""]

    - [start_only_to_end,
       ["abcdef", 3],
       [],
       "def"]

    - [out_of_bounds_clipped,
       ["abc", 0, 100],
       [],
       "abc"]
