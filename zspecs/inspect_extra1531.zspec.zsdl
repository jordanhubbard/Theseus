spec: inspect_extra1531
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "Wave 549 theme: comparison operator dict-presence checks via __dict__.__contains__ for inspect classes."
    - "inspect.Parameter.__dict__.__contains__('__eq__') == True — Parameter defines __eq__ in its own __dict__ for value-based equality. Verified with Python 3.14."
    - "inspect.Parameter.__dict__.__contains__('__hash__') == True — Parameter defines __hash__ in its own __dict__; it is hashable. Verified with Python 3.14."
    - "inspect.Parameter.__dict__.__contains__('__lt__') == False — Parameter does not define any ordering operators. Verified with Python 3.14."
    - "inspect.Signature.__dict__.__contains__('__eq__') == True — Signature defines __eq__ in its own __dict__ for value-based equality. Verified with Python 3.14."
    - "inspect.Signature.__dict__.__contains__('__hash__') == True — Signature defines __hash__ in its own __dict__. Verified with Python 3.14."
    - "inspect.BoundArguments.__dict__.__contains__('__eq__') == True — BoundArguments defines __eq__ in its own __dict__. Verified with Python 3.14."
    - "inspect.BoundArguments.__dict__.__contains__('__hash__') == True — BoundArguments defines __hash__ in its own __dict__. Verified with Python 3.14."
    - "inspect.FullArgSpec.__dict__.__contains__ returns False for all comparison dunder methods — FullArgSpec is a namedtuple that inherits comparison operators from tuple, not overriding them in its own __dict__. Verified with Python 3.14."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter — comparison operator dict-presence checks
#
# Wave 549 theme: Parameter is a Python class that defines __eq__ and __hash__
# in its own __dict__ for value-based comparison of parameter objects.
# It does not define ordering operators (__lt__, __le__, __gt__, __ge__).
# __ne__ is also absent from __dict__ (inherited from object).
# ---------------------------------------------------------------------------

table inspect_extra1531.parameter_dict_contains:
  description: "inspect.Parameter.__dict__.__contains__: __eq__ True, __hash__ True, ordering ops False; wave 549; new to extra1531"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1531pa

  columns: [id, function, args, expected, description]
  rows:
    - ["in1531pa001",
       "Parameter.__dict__.__contains__",
       ["__lt__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__lt__') == False — Parameter does not define __lt__ in its own class __dict__; it defines no ordering operators; wave 549; new to extra1531"]
    - ["in1531pa002",
       "Parameter.__dict__.__contains__",
       ["__le__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__le__') == False — Parameter does not define __le__ in its own class __dict__; wave 549; new to extra1531"]
    - ["in1531pa003",
       "Parameter.__dict__.__contains__",
       ["__gt__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__gt__') == False — Parameter does not define __gt__ in its own class __dict__; wave 549; new to extra1531"]
    - ["in1531pa004",
       "Parameter.__dict__.__contains__",
       ["__ge__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__ge__') == False — Parameter does not define __ge__ in its own class __dict__; wave 549; new to extra1531"]
    - ["in1531pa005",
       "Parameter.__dict__.__contains__",
       ["__ne__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__ne__') == False — Parameter does not define __ne__ in its own class __dict__; __ne__ is inherited from object; wave 549; new to extra1531"]
    - ["in1531pa006",
       "Parameter.__dict__.__contains__",
       ["__eq__"],
       true,
       "inspect.Parameter.__dict__.__contains__('__eq__') == True — Parameter defines __eq__ in its own class __dict__ for value-based equality of parameter objects; wave 549; new to extra1531"]
    - ["in1531pa007",
       "Parameter.__dict__.__contains__",
       ["__hash__"],
       true,
       "inspect.Parameter.__dict__.__contains__('__hash__') == True — Parameter defines __hash__ in its own class __dict__; Parameter objects are hashable; wave 549; new to extra1531"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Signature — comparison operator dict-presence checks
#
# Wave 549 theme: Signature is a Python class that defines __eq__ and __hash__
# in its own __dict__ for value-based equality comparison. Like Parameter,
# it does not define ordering operators.
# ---------------------------------------------------------------------------

table inspect_extra1531.signature_dict_contains:
  description: "inspect.Signature.__dict__.__contains__: __eq__ True, __hash__ True, ordering ops False; wave 549; new to extra1531"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1531si

  columns: [id, function, args, expected, description]
  rows:
    - ["in1531si001",
       "Signature.__dict__.__contains__",
       ["__lt__"],
       false,
       "inspect.Signature.__dict__.__contains__('__lt__') == False — Signature does not define __lt__ in its own class __dict__; wave 549; new to extra1531"]
    - ["in1531si002",
       "Signature.__dict__.__contains__",
       ["__le__"],
       false,
       "inspect.Signature.__dict__.__contains__('__le__') == False — Signature does not define __le__ in its own class __dict__; wave 549; new to extra1531"]
    - ["in1531si003",
       "Signature.__dict__.__contains__",
       ["__gt__"],
       false,
       "inspect.Signature.__dict__.__contains__('__gt__') == False — Signature does not define __gt__ in its own class __dict__; wave 549; new to extra1531"]
    - ["in1531si004",
       "Signature.__dict__.__contains__",
       ["__ge__"],
       false,
       "inspect.Signature.__dict__.__contains__('__ge__') == False — Signature does not define __ge__ in its own class __dict__; wave 549; new to extra1531"]
    - ["in1531si005",
       "Signature.__dict__.__contains__",
       ["__ne__"],
       false,
       "inspect.Signature.__dict__.__contains__('__ne__') == False — Signature does not define __ne__ in its own class __dict__; __ne__ is inherited from object; wave 549; new to extra1531"]
    - ["in1531si006",
       "Signature.__dict__.__contains__",
       ["__eq__"],
       true,
       "inspect.Signature.__dict__.__contains__('__eq__') == True — Signature defines __eq__ in its own class __dict__ for value-based equality comparison of signatures; wave 549; new to extra1531"]
    - ["in1531si007",
       "Signature.__dict__.__contains__",
       ["__hash__"],
       true,
       "inspect.Signature.__dict__.__contains__('__hash__') == True — Signature defines __hash__ in its own class __dict__; Signature objects are hashable; wave 549; new to extra1531"]

# ---------------------------------------------------------------------------
# Table 3: inspect.BoundArguments — comparison operator dict-presence checks
#
# Wave 549 theme: BoundArguments is a Python class returned by
# Signature.bind() that defines __eq__ and __hash__ in its own __dict__.
# It does not define ordering operators, consistent with the other inspect
# value-comparison classes.
# ---------------------------------------------------------------------------

table inspect_extra1531.bound_arguments_dict_contains:
  description: "inspect.BoundArguments.__dict__.__contains__: __eq__ True, __hash__ True, ordering ops False; wave 549; new to extra1531"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1531ba

  columns: [id, function, args, expected, description]
  rows:
    - ["in1531ba001",
       "BoundArguments.__dict__.__contains__",
       ["__lt__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__lt__') == False — BoundArguments does not define __lt__ in its own class __dict__; wave 549; new to extra1531"]
    - ["in1531ba002",
       "BoundArguments.__dict__.__contains__",
       ["__le__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__le__') == False — BoundArguments does not define __le__ in its own class __dict__; wave 549; new to extra1531"]
    - ["in1531ba003",
       "BoundArguments.__dict__.__contains__",
       ["__gt__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__gt__') == False — BoundArguments does not define __gt__ in its own class __dict__; wave 549; new to extra1531"]
    - ["in1531ba004",
       "BoundArguments.__dict__.__contains__",
       ["__ge__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__ge__') == False — BoundArguments does not define __ge__ in its own class __dict__; wave 549; new to extra1531"]
    - ["in1531ba005",
       "BoundArguments.__dict__.__contains__",
       ["__ne__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__ne__') == False — BoundArguments does not define __ne__ in its own class __dict__; __ne__ is inherited from object; wave 549; new to extra1531"]
    - ["in1531ba006",
       "BoundArguments.__dict__.__contains__",
       ["__eq__"],
       true,
       "inspect.BoundArguments.__dict__.__contains__('__eq__') == True — BoundArguments defines __eq__ in its own class __dict__ for value-based equality comparison; wave 549; new to extra1531"]
    - ["in1531ba007",
       "BoundArguments.__dict__.__contains__",
       ["__hash__"],
       true,
       "inspect.BoundArguments.__dict__.__contains__('__hash__') == True — BoundArguments defines __hash__ in its own class __dict__; BoundArguments objects are hashable; wave 549; new to extra1531"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1531
# ---------------------------------------------------------------------------

invariant inspect_extra1531.parameter_has_eq:
  description: "inspect.Parameter.__dict__.__contains__('__eq__') == True — Parameter defines __eq__ for value equality; wave 549; new to extra1531"
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["__eq__"]
  expected: true

invariant inspect_extra1531.parameter_has_hash:
  description: "inspect.Parameter.__dict__.__contains__('__hash__') == True — Parameter defines __hash__; objects are hashable; wave 549; new to extra1531"
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["__hash__"]
  expected: true

invariant inspect_extra1531.parameter_no_lt:
  description: "inspect.Parameter.__dict__.__contains__('__lt__') == False — Parameter defines no ordering operators; wave 549; new to extra1531"
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["__lt__"]
  expected: false

invariant inspect_extra1531.signature_has_eq:
  description: "inspect.Signature.__dict__.__contains__('__eq__') == True — Signature defines __eq__ for value equality; wave 549; new to extra1531"
  kind: python_call_eq
  function: Signature.__dict__.__contains__
  args: ["__eq__"]
  expected: true

invariant inspect_extra1531.signature_has_hash:
  description: "inspect.Signature.__dict__.__contains__('__hash__') == True — Signature defines __hash__; objects are hashable; wave 549; new to extra1531"
  kind: python_call_eq
  function: Signature.__dict__.__contains__
  args: ["__hash__"]
  expected: true

invariant inspect_extra1531.signature_no_lt:
  description: "inspect.Signature.__dict__.__contains__('__lt__') == False — Signature defines no ordering operators; wave 549; new to extra1531"
  kind: python_call_eq
  function: Signature.__dict__.__contains__
  args: ["__lt__"]
  expected: false

invariant inspect_extra1531.bound_arguments_has_eq:
  description: "inspect.BoundArguments.__dict__.__contains__('__eq__') == True — BoundArguments defines __eq__ for value equality; wave 549; new to extra1531"
  kind: python_call_eq
  function: BoundArguments.__dict__.__contains__
  args: ["__eq__"]
  expected: true

invariant inspect_extra1531.bound_arguments_has_hash:
  description: "inspect.BoundArguments.__dict__.__contains__('__hash__') == True — BoundArguments defines __hash__; objects are hashable; wave 549; new to extra1531"
  kind: python_call_eq
