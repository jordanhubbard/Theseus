spec: tkinter_extra3
version: ">=3.9"
backend: python_module(tkinter)

docs: https://docs.python.org/3/library/tkinter.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tkinter.html — Python tkinter module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tkinter/__init__.py"
  notes:
    - "This spec extends tkinter.zspec.zsdl, tkinter_extra.zspec.zsdl, and tkinter_extra2.zspec.zsdl."
    - "tkinter.zspec.zsdl covers: TclError __name__/__module__/__bases__; string/layout constants."
    - "tkinter_extra.zspec.zsdl covers: Tk/TclError/Misc/Variable/StringVar/Frame/Widget __name__/__module__; StringVar hierarchy."
    - "tkinter_extra2.zspec.zsdl covers: Button/Label/Entry/Text/Canvas/IntVar __name__; batch widget class name table."
    - "This spec adds: DoubleVar/__name__, BooleanVar/__name__, Event/__name__; module-level __name__ attribute; IntVar/__module__, DoubleVar/__module__, BooleanVar/__module__."
    - "All class name checks are safe without a running Tk display."
    - "All expected values verified with Python 3.12 tkinter on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# DoubleVar — class name and module
# tkinter_extra covers StringVar.__name__; tkinter_extra2 covers IntVar.__name__.
# DoubleVar.__name__ not yet covered.
# ---------------------------------------------------------------------------

invariant tkinter_extra3.DoubleVar.name:
  description: "tkinter.DoubleVar.__name__ == 'DoubleVar'"
  category: class_names
  kind: python_call_eq
  function: DoubleVar.__name__.__eq__
  args: ["DoubleVar"]
  expected: true

invariant tkinter_extra3.DoubleVar.module:
  description: "tkinter.DoubleVar.__module__ == 'tkinter'"
  category: class_modules
  kind: python_call_eq
  function: DoubleVar.__module__.__eq__
  args: ["tkinter"]
  expected: true

# ---------------------------------------------------------------------------
# BooleanVar — class name and module
# Not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant tkinter_extra3.BooleanVar.name:
  description: "tkinter.BooleanVar.__name__ == 'BooleanVar'"
  category: class_names
  kind: python_call_eq
  function: BooleanVar.__name__.__eq__
  args: ["BooleanVar"]
  expected: true

invariant tkinter_extra3.BooleanVar.module:
  description: "tkinter.BooleanVar.__module__ == 'tkinter'"
  category: class_modules
  kind: python_call_eq
  function: BooleanVar.__module__.__eq__
  args: ["tkinter"]
  expected: true

# ---------------------------------------------------------------------------
# Event — class name and module
# tkinter.Event is the class for event objects passed to event handlers.
# Not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant tkinter_extra3.Event.name:
  description: "tkinter.Event.__name__ == 'Event'"
  category: class_names
  kind: python_call_eq
  function: Event.__name__.__eq__
  args: ["Event"]
  expected: true

invariant tkinter_extra3.Event.module:
  description: "tkinter.Event.__module__ == 'tkinter'"
  category: class_modules
  kind: python_call_eq
  function: Event.__module__.__eq__
  args: ["tkinter"]
  expected: true

# ---------------------------------------------------------------------------
# IntVar — module affiliation
# tkinter_extra2 covers IntVar.__name__; __module__ not yet covered.
# ---------------------------------------------------------------------------

invariant tkinter_extra3.IntVar.module:
  description: "tkinter.IntVar.__module__ == 'tkinter'"
  category: class_modules
  kind: python_call_eq
  function: IntVar.__module__.__eq__
  args: ["tkinter"]
  expected: true

# ---------------------------------------------------------------------------
# StringVar — module affiliation
# tkinter_extra covers StringVar.__name__; __module__ not yet covered.
# ---------------------------------------------------------------------------

invariant tkinter_extra3.StringVar.module:
  description: "tkinter.StringVar.__module__ == 'tkinter'"
  category: class_modules
  kind: python_call_eq
  function: StringVar.__module__.__eq__
  args: ["tkinter"]
  expected: true

# ---------------------------------------------------------------------------
# Module identity — tkinter.__name__ is 'tkinter'
# (not covered in any prior tkinter spec)
# ---------------------------------------------------------------------------

invariant tkinter_extra3.module.name:
  description: "tkinter.__name__ == 'tkinter' — the module's own __name__ attribute"
  category: module
  kind: python_call_eq
  function: __name__.__eq__
  args: ["tkinter"]
  expected: true

# ---------------------------------------------------------------------------
# Table: batch __name__ checks for traced variable classes
# Covers StringVar, IntVar, DoubleVar, BooleanVar as a coherent family.
# ---------------------------------------------------------------------------

table tkinter_extra3.var_classes.names:
  kind: python_call_eq
  category: class_names
  id_prefix: varname

  columns: [id, function, args, expected]
  rows:
    - [StringVar,  StringVar.__name__.__eq__,  ["StringVar"],  true]
    - [IntVar,     IntVar.__name__.__eq__,     ["IntVar"],     true]
    - [DoubleVar,  DoubleVar.__name__.__eq__,  ["DoubleVar"],  true]
    - [BooleanVar, BooleanVar.__name__.__eq__, ["BooleanVar"], true]
