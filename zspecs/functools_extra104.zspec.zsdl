spec: functools_extra104
version: ">=3.9"
backend: python_module(functools)
extends: functools_extra99

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra99.zspec.zsdl."
    - "This spec covers: functools.WRAPPER_UPDATES and WRAPPER_ASSIGNMENTS tuple identity; functools.reduce and cmp_to_key C-level builtin identity; functools.lru_cache, cache, total_ordering Python function identity; functools.partial and partialmethod class identity (Wave 256)."
    - "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple' — WRAPPER_UPDATES is a module-level tuple constant. Verified with Python 3.14.3."
    - "len(functools.WRAPPER_UPDATES) == 1 — WRAPPER_UPDATES contains only '__dict__'. Verified with Python 3.14.3."
    - "len(functools.WRAPPER_ASSIGNMENTS) == 6 — WRAPPER_ASSIGNMENTS lists the six attrs copied by wraps(): __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__. Verified with Python 3.14.3."
    - "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is implemented in C via _functools. Verified with Python 3.14.3."
    - "functools.reduce.__module__ == '_functools' — reduce lives in the C extension module _functools. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method' — cmp_to_key is a C builtin. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__module__ == '_functools' — cmp_to_key is in the C extension _functools. Verified with Python 3.14.3."
    - "functools.lru_cache.__class__.__name__ == 'function' — lru_cache is a pure-Python decorator factory. Verified with Python 3.14.3."
    - "functools.lru_cache.__code__.co_argcount == 2 — lru_cache(maxsize=128, typed=False) takes two positional args. Verified with Python 3.14.3."
    - "functools.lru_cache.__module__ == 'functools'. Verified with Python 3.14.3."
    - "functools.cache.__class__.__name__ == 'function' — cache is a pure-Python function (thin wrapper over lru_cache). Verified with Python 3.14.3."
    - "functools.total_ordering.__class__.__name__ == 'function' — total_ordering is a class decorator implemented as a Python function. Verified with Python 3.14.3."
    - "functools.total_ordering.__code__.co_argcount == 1 — takes one argument (cls). Verified with Python 3.14.3."
    - "functools.partial.__class__.__name__ == 'type' — partial is a C extension type, not a function. Verified with Python 3.14.3."
    - "functools.partial.__module__ == 'functools' — partial's __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.partialmethod.__class__.__name__ == 'type' — partialmethod is a Python class. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__bases__[0].__name__ == 'object' — singledispatchmethod inherits directly from object. Verified with Python 3.14.3."
    - "len(functools.singledispatchmethod.__mro__) == 2 — MRO is [singledispatchmethod, object]. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: WRAPPER_UPDATES and WRAPPER_ASSIGNMENTS tuple identity
#
# Wave 256 theme: functools module-level tuple constants.
#
# functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple'
# len(functools.WRAPPER_UPDATES) == 1     (contains '__dict__')
# functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'
# len(functools.WRAPPER_ASSIGNMENTS) == 6
#
# WRAPPER_UPDATES and WRAPPER_ASSIGNMENTS are module-level tuple constants
# that control which attributes wraps() copies from the wrapped function.
# New to extra104.
# ---------------------------------------------------------------------------

table functools_extra104.wrapper_constants_identity:
  description: "functools.WRAPPER_UPDATES and WRAPPER_ASSIGNMENTS class names and lengths; module-level tuple constants controlling wraps() attribute copying; wave 256; new to extra104"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolswrapper104

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_updates_class_name_eq_tuple,
       "WRAPPER_UPDATES.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.WRAPPER_UPDATES.__class__.__name__.__eq__('tuple') == True — WRAPPER_UPDATES is a module-level constant defined in Lib/functools.py; it is a plain Python tuple listing the attributes updated (not just copied) by functools.wraps(); __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra104"]
    - [wrapper_updates_len_eq_1,
       "WRAPPER_UPDATES.__len__",
       [],
       1,
       "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES contains a single element: '__dict__'; the update step merges the wrapped function's __dict__ into the wrapper's __dict__; len(WRAPPER_UPDATES) is 1; int.__eq__(1) returns True; new to extra104"]
    - [wrapper_assignments_class_name_eq_tuple,
       "WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('tuple') == True — WRAPPER_ASSIGNMENTS is a module-level constant tuple listing the function attributes copied by functools.wraps(); includes __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__; __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra104"]
    - [wrapper_assignments_len_eq_6,
       "WRAPPER_ASSIGNMENTS.__len__",
       [],
       6,
       "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — WRAPPER_ASSIGNMENTS lists 6 attributes: '__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'; Python 3.14 added __annotate__ and __type_params__ to the default set; len(WRAPPER_ASSIGNMENTS) is 6; new to extra104"]

# ---------------------------------------------------------------------------
# Table 2: functools.reduce and cmp_to_key C-level builtin identity
#
# Wave 256 theme: functools C extension builtins.
#
# functools.reduce.__class__.__name__ == 'builtin_function_or_method'
# functools.reduce.__module__ == '_functools'
# functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method'
# functools.cmp_to_key.__module__ == '_functools'
#
# Both reduce and cmp_to_key are implemented in the C extension module
# _functools (Modules/_functoolsmodule.c) for performance. New to extra104.
# ---------------------------------------------------------------------------

table functools_extra104.reduce_cmptokey_identity:
  description: "functools.reduce and cmp_to_key are C builtins in _functools; __class__.__name__ == 'builtin_function_or_method'; __module__ == '_functools'; wave 256; new to extra104"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolswrapper104

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_class_name_eq_builtin,
       "reduce.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — functools.reduce is implemented in C in Modules/_functoolsmodule.c; it is exposed as a C-level builtin function; __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra104"]
    - [reduce_module_eq_functools_c,
       "reduce.__module__.__eq__",
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — reduce is implemented in the C extension module _functools (Modules/_functoolsmodule.c) rather than the pure-Python Lib/functools.py; its __module__ attribute is '_functools'; str.__eq__('_functools') returns True; new to extra104"]
    - [cmp_to_key_class_name_eq_builtin,
       "cmp_to_key.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.cmp_to_key.__class__.__name__.__eq__('builtin_function_or_method') == True — cmp_to_key is implemented in C in Modules/_functoolsmodule.c; it converts a comparison function to a key function for use in sort; __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra104"]
    - [cmp_to_key_module_eq_functools_c,
       "cmp_to_key.__module__.__eq__",
       ["_functools"],
       true,
       "functools.cmp_to_key.__module__.__eq__('_functools') == True — cmp_to_key is a C builtin in the _functools extension module; __module__ is '_functools'; str.__eq__('_functools') returns True; new to extra104"]

# ---------------------------------------------------------------------------
# Table 3: lru_cache, cache, total_ordering Python function identity
#
# Wave 256 theme: functools pure-Python decorator factories.
#
# functools.lru_cache.__class__.__name__ == 'function'
# functools.lru_cache.__code__.co_argcount == 2
# functools.lru_cache.__module__ == 'functools'
# functools.cache.__class__.__name__ == 'function'
# functools.cache.__module__ == 'functools'
# functools.total_ordering.__class__.__name__ == 'function'
# functools.total_ordering.__code__.co_argcount == 1
#
# lru_cache, cache, and total_ordering are pure-Python functions.
# lru_cache takes maxsize and typed. New to extra104.
# ---------------------------------------------------------------------------

table functools_extra104.decorator_factory_identity:
  description: "functools.lru_cache/cache/total_ordering are pure-Python functions; lru_cache co_argcount==2; total_ordering co_argcount==1; wave 256; new to extra104"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolswrapper104

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_class_name_eq_function,
       "lru_cache.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.lru_cache.__class__.__name__.__eq__('function') == True — lru_cache is a pure-Python decorator factory defined in Lib/functools.py; it wraps a callable with memoization; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra104"]
    - [lru_cache_co_argcount_eq_2,
       "lru_cache.__code__.co_argcount.__eq__",
       [2],
       true,
       "functools.lru_cache.__code__.co_argcount.__eq__(2) == True — lru_cache(maxsize=128, typed=False) accepts two positional parameters; co_argcount counts all positional args including those with defaults; int.__eq__(2) returns True; new to extra104"]
    - [lru_cache_module_eq_functools,
       "lru_cache.__module__.__eq__",
       ["functools"],
       true,
       "functools.lru_cache.__module__.__eq__('functools') == True — lru_cache is defined in Lib/functools.py; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra104"]
    - [cache_class_name_eq_function,
       "cache.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.cache.__class__.__name__.__eq__('function') == True — functools.cache is a pure-Python function added in 3.9 as a simpler unbounded-cache alternative to lru_cache(maxsize=None); it is defined in Lib/functools.py; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra104"]
    - [cache_module_eq_functools,
       "cache.__module__.__eq__",
       ["functools"],
       true,
       "functools.cache.__module__.__eq__('functools') == True — cache is defined in Lib/functools.py; __module__ is 'functools'; str.__eq__('functools') returns True; new to extra104"]
    - [total_ordering_class_name_eq_function,
       "total_ordering.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.total_ordering.__class__.__name__.__eq__('function') == True — total_ordering is a class decorator implemented as a plain Python function in Lib/functools.py; it fills in missing comparison methods given __eq__ and one of __lt__/__le__/__gt__/__ge__; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra104"]
    - [total_ordering_co_argcount_eq_1,
       "total_ordering.__code__.co_argcount.__eq__",
       [1],
       true,
       "functools.total_ordering.__code__.co_argcount.__eq__(1) == True — total_ordering(cls) takes a single positional argument (the class to decorate); co_argcount is 1; int.__eq__(1) returns True; new to extra104"]

# ---------------------------------------------------------------------------
# Table 4: partial, partialmethod class identity; singledispatchmethod MRO
#
# Wave 256 theme: functools partial types and singledispatchmethod MRO.
#
# functools.partial.__class__.__name__ == 'type'
# functools.partial.__module__ == 'functools'
# functools.partialmethod.__class__.__name__ == 'type'
# functools.partialmethod.__module__ == 'functools'
# functools.singledispatchmethod.__bases__[0].__name__ == 'object'
# len(functools.singledispatchmethod.__mro__) == 2
#
# partial is a C extension type; partialmethod is a pure-Python class.
# singledispatchmethod inherits only from object. New to extra104.
# ---------------------------------------------------------------------------

table functools_extra104.partial_partialmethod_identity:
  description: "functools.partial is a C type; functools.partialmethod is a Python class; both __module__=='functools'; singledispatchmethod MRO length 2; wave 256; new to extra104"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolswrapper104

  columns: [id, function, args, expected, description]
  rows:
    - [partial_class_name_eq_type,
       "partial.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.partial.__class__.__name__.__eq__('type') == True — functools.partial is a C extension type defined in Modules/_functoolsmodule.c and exposed as functools.partial; it is a proper class whose metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra104"]
    - [partial_module_eq_functools,
       "partial.__module__.__eq__",
       ["functools"],
       true,
       "functools.partial.__module__.__eq__('functools') == True — even though partial is implemented in C, its __module__ attribute is set to 'functools' by the module setup; str.__eq__('functools') returns True; new to extra104"]
    - [partialmethod_class_name_eq_type,
       "partialmethod.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.partialmethod.__class__.__name__.__eq__('type') == True — partialmethod is a pure-Python class defined with 'class partialmethod:' in Lib/functools.py; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra104"]
    - [partialmethod_module_eq_functools,
       "partialmethod.__module__.__eq__",
       ["functools"],
       true,
       "functools.partialmethod.__module__.__eq__('functools') == True — partialmethod is defined in Lib/functools.py; __module__ is 'functools'; str.__eq__('functools') returns True; new to extra104"]
    - [singledispatchmethod_bases_first_eq_object,
       "singledispatchmethod.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.singledispatchmethod.__bases__[0].__name__.__eq__('object') == True — singledispatchmethod is defined as 'class singledispatchmethod:' with no explicit base in Lib/functools.py; it therefore inherits only from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra104"]
    - [singledispatchmethod_mro_len_eq_2,
       "singledispatchmethod.__mro__.__len__",
       [],
       2,
       "functools.singledispatchmethod.__mro__.__len__() == 2 — the MRO of singledispatchmethod is [singledispatchmethod, object]; it has no intermediate base classes; len(__mro__) is 2; int.__eq__(2) returns True; new to extra104"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra104
# ---------------------------------------------------------------------------

invariant functools_extra104.wrapper_updates_len:
  description: "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES tuple contains only '__dict__'; wave 256; new to extra104"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1

invariant functools_extra104.wrapper_assignments_len:
  description: "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — six attributes copied by wraps(): __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__; wave 256; new to extra104"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

invariant functools_extra104.reduce_module:
  description: "functools.reduce.__module__ == '_functools' — reduce is a C builtin in the _functools extension module; wave 256; new to extra104"
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra104.lru_cache_co_argcount:
  description: "functools.lru_cache.__code__.co_argcount == 2 — lru_cache(maxsize=128, typed=False) takes two positional parameters; wave 256; new to extra104"
  kind: python_call_eq
  function: lru_cache.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant functools_extra104.partial_class_name:
  description: "functools.partial.__class__.__name__ == 'type' — partial is a C extension type, not a factory function; wave 256; new to extra104"
  kind: python_call_eq
  function: partial.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra104.singledispatchmethod_mro_len:
  description: "functools.singledispatchmethod.__mro__.__len__() == 2 — MRO is [singledispatchmethod, object]; no intermediate bases; wave 256; new to extra104"
  kind: python_call_eq
  function: singledispatchmethod.__mro__.__len__
  args: []
  expected: 2
