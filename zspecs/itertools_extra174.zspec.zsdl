  category: identity
  id_prefix: itermro174

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_mro_len_2,
       "groupby.__mro__.__len__",
       [],
       2,
       "itertools.groupby.__mro__.__len__() == 2 — itertools.groupby is a C extension type defined in itertoolsmodule.c that makes an iterator returning consecutive keys and groups from an iterable; it inherits directly from object with no intermediate base classes; its __mro__ is (groupby, object), a tuple of length 2; tuple.__len__() returns 2; new to extra174"]
    - ["groupby_mro_0_groupby",
       "groupby.__mro__[0].__name__.__eq__",
       ["groupby"],
       true,
       "itertools.groupby.__mro__[0].__name__.__eq__('groupby') == True — the first entry in groupby.__mro__ is the groupby class itself; its __name__ is 'groupby'; str.__eq__('groupby') returns True; new to extra174"]
    - [product_mro_len_2,
       "product.__mro__.__len__",
       [],
       2,
       "itertools.product.__mro__.__len__() == 2 — itertools.product is a C extension type defined in itertoolsmodule.c that computes the Cartesian product of input iterables (equivalent to nested for-loops); it inherits directly from object; its __mro__ is (product, object), a tuple of length 2; tuple.__len__() returns 2; new to extra174"]
    - ["product_mro_1_object",
       "product.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "itertools.product.__mro__[1].__name__.__eq__('object') == True — the second entry in product.__mro__ is the base class object; its __name__ is 'object'; this confirms product inherits directly from object with no intermediate classes; str.__eq__('object') returns True; new to extra174"]

