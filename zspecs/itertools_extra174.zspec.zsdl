# ---------------------------------------------------------------------------
# Table 1: itertools.chain.__doc__ class and length
#
# itertools.chain.__doc__.__class__.__name__ == 'str'
# itertools.chain.__doc__.__class__.__name__ != 'NoneType'
# itertools.chain.__doc__.__len__() == 190
# itertools.chain.__doc__.__contains__('chain') == True
#
# itertools.chain is a C extension type defined in itertoolsmodule.c. Like
# most C types, it has a docstring describing its behavior. On Python 3.14.3
# the docstring begins "Return a chain object whose .__next__() method returns
# elements from the first iterable until it is exhausted...". It is 190
# characters long and is a str instance. New to extra174.
# ---------------------------------------------------------------------------

table itertools_extra174.chain_doc_class_and_len:
  description: "itertools.chain.__doc__ class 'str', not NoneType; len 190; contains 'chain'; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: itermro174

  columns: [id, function, args, expected, description]
  rows:
    - [chain_doc_class_str,
       "chain.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.chain.__doc__.__class__.__name__.__eq__('str') == True — itertools.chain is a C extension type with a docstring; its __doc__ attribute is a str instance; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra174"]
    - [chain_doc_class_not_nonetype,
       "chain.__doc__.__class__.__name__.__eq__",
       ["NoneType"],
       false,
       "itertools.chain.__doc__.__class__.__name__.__eq__('NoneType') == False — chain.__doc__ is a non-None str (chain has a real docstring); its __class__.__name__ is 'str', not 'NoneType'; str.__eq__('NoneType') returns False; new to extra174"]
    - [chain_doc_len_190,
       "chain.__doc__.__len__",
       [],
       190,
       "itertools.chain.__doc__.__len__() == 190 — the chain docstring ('Return a chain object whose .__next__() method returns elements from the first iterable until it is exhausted...') has exactly 190 characters on Python 3.14.3; str.__len__() returns 190; new to extra174"]
    - [chain_doc_contains_chain,
       "chain.__doc__.__contains__",
       ["chain"],
       true,
       "itertools.chain.__doc__.__contains__('chain') == True — the word 'chain' appears in itertools.chain's docstring ('Return a chain object...'); str.__contains__('chain') returns True; new to extra174"]

# ---------------------------------------------------------------------------
# Table 2: itertools.chain and itertools.islice __module__ identity
#
# itertools.chain.__module__ == 'itertools'
# itertools.islice.__module__ == 'itertools'
# itertools.chain.__module__.__len__() == 9
# itertools.chain.__module__.__class__.__name__ == 'str'
#
# Both chain and islice are C extension types defined in the itertools module
# (itertoolsmodule.c). Their __module__ attribute is the string 'itertools',
# which is 9 characters long. New to extra174.
# ---------------------------------------------------------------------------

table itertools_extra174.chain_islice_module:
  description: "itertools.chain.__module__ 'itertools'; islice.__module__ 'itertools'; module len 9; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: itermro174

  columns: [id, function, args, expected, description]
  rows:
    - [chain_module_itertools,
       "chain.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.chain.__module__.__eq__('itertools') == True — itertools.chain is a C extension type defined in the itertools module (itertoolsmodule.c); its __module__ attribute is the string 'itertools'; str.__eq__('itertools') returns True; new to extra174"]
    - [islice_module_itertools,
       "islice.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.islice.__module__.__eq__('itertools') == True — itertools.islice is a C extension type defined in the itertools module (itertoolsmodule.c); its __module__ attribute is the string 'itertools'; str.__eq__('itertools') returns True; new to extra174"]
    - [chain_module_len_9,
       "chain.__module__.__len__",
       [],
       9,
       "itertools.chain.__module__.__len__() == 9 — the module name 'itertools' has exactly 9 characters: i-t-e-r-t-o-o-l-s; str.__len__() returns 9; new to extra174"]
    - [chain_module_class_str,
       "chain.__module__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.chain.__module__.__class__.__name__.__eq__('str') == True — chain.__module__ is the string 'itertools', a str instance; its __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra174"]

# ---------------------------------------------------------------------------
# Table 3: itertools.chain and itertools.islice __mro__.__len__() == 2
#
# itertools.chain.__mro__.__len__() == 2
# itertools.chain.__mro__[0].__name__ == 'chain'
# itertools.islice.__mro__.__len__() == 2
# itertools.islice.__mro__[0].__name__ == 'islice'
#
# All itertools classes are C extension types defined in itertoolsmodule.c.
# They inherit directly from object with no intermediate base classes. Their
# __mro__ tuples have exactly 2 entries: (TypeName, object). New to extra174.
# ---------------------------------------------------------------------------

table itertools_extra174.chain_islice_mro_len:
  description: "itertools.chain.__mro__.__len__() 2, mro[0] 'chain'; islice mro len 2, mro[0] 'islice'; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: itermro174

  columns: [id, function, args, expected, description]
  rows:
    - [chain_mro_len_2,
       "chain.__mro__.__len__",
       [],
       2,
       "itertools.chain.__mro__.__len__() == 2 — itertools.chain is a C extension type defined in itertoolsmodule.c that chains multiple iterables together; it inherits directly from object with no intermediate base classes; its __mro__ is (chain, object), a tuple of length 2; tuple.__len__() returns 2; new to extra174"]
    - ["chain_mro_0_chain",
       "chain.__mro__[0].__name__.__eq__",
       ["chain"],
       true,
       "itertools.chain.__mro__[0].__name__.__eq__('chain') == True — the first entry in chain.__mro__ is the chain class itself; its __name__ is 'chain'; str.__eq__('chain') returns True; new to extra174"]
    - [islice_mro_len_2,
       "islice.__mro__.__len__",
       [],
       2,
       "itertools.islice.__mro__.__len__() == 2 — itertools.islice is a C extension type defined in itertoolsmodule.c that makes an iterator returning selected elements by index range; it inherits directly from object; its __mro__ is (islice, object), a tuple of length 2; tuple.__len__() returns 2; new to extra174"]
    - ["islice_mro_0_islice",
       "islice.__mro__[0].__name__.__eq__",
       ["islice"],
       true,
       "itertools.islice.__mro__[0].__name__.__eq__('islice') == True — the first entry in islice.__mro__ is the islice class itself; its __name__ is 'islice'; str.__eq__('islice') returns True; new to extra174"]

# ---------------------------------------------------------------------------
# Table 4: itertools.groupby and itertools.product __mro__.__len__() == 2
#
# itertools.groupby.__mro__.__len__() == 2
# itertools.groupby.__mro__[0].__name__ == 'groupby'
# itertools.product.__mro__.__len__() == 2
# itertools.product.__mro__[1].__name__ == 'object'
#
# groupby(iterable, key) makes an iterator returning consecutive keys and
# groups. product(*iterables) computes the Cartesian product. Both are C
# extension types in itertoolsmodule.c with MRO length 2. New to extra174.
# ---------------------------------------------------------------------------

table itertools_extra174.groupby_product_mro_len:
  description: "itertools.groupby.__mro__.__len__() 2, mro[0] 'groupby'; product mro len 2, mro[1] 'object'; new to extra174"
