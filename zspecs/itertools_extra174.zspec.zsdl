  notes:
    - "This spec covers: itertools.chain.__doc__ properties — class 'str', non-empty; itertools.chain.__mro__.__len__()==2 (chain > object — C type); itertools.islice.__mro__.__len__()==2; itertools.groupby.__mro__.__len__()==2; itertools.product.__mro__.__len__()==2; itertools.chain.__module__=='itertools'; itertools.islice.__module__=='itertools'."
