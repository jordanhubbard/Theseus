spec: copy_extra8
version: ">=3.9"
backend: python_module(copy)

docs: https://docs.python.org/3/library/copy.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/copy.html — Python copy module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/copy.py"
  notes:
    - "This spec extends copy.zspec.zsdl through copy_extra7.zspec.zsdl."
    - "copy_extra4 covers __name__/__module__/__qualname__/__class__.__name__ for copy/deepcopy and Error.__name__/__module__."
    - "copy_extra7 covers Error.__mro__.__len__() == 4 and Error.__mro__[1].__name__ == 'Exception'."
    - "No prior copy spec covers __name__.__len__() for copy/deepcopy/Error."
    - "No prior copy spec covers Error.__mro__[2].__name__ or Error.__mro__[3].__name__."
    - "copy.copy.__name__.__len__() == 4 — the name 'copy' has 4 characters."
    - "copy.deepcopy.__name__.__len__() == 8 — the name 'deepcopy' has 8 characters."
    - "copy.Error.__name__.__len__() == 5 — the name 'Error' has 5 characters."
    - "copy.Error.__mro__[2].__name__ == 'BaseException' — third entry in MRO."
    - "copy.Error.__mro__[3].__name__ == 'object' — fourth entry in MRO (root)."
    - "MRO for copy.Error: [Error, Exception, BaseException, object]."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name length — copy, deepcopy
#
# copy_extra4 covers __name__ values for copy and deepcopy. No prior spec
# checks the length of those name strings. The length of the name string is
# a distinct axis: it verifies the string is exactly as long as expected,
# ruling out truncation or aliasing to a differently-named function.
# ---------------------------------------------------------------------------

invariant copy_extra8.copy.name_len:
  description: "copy.copy.__name__.__len__() == 4 — name 'copy' is 4 characters"
  category: function_names
  kind: python_call_eq
  function: copy.__name__.__len__
  args: []
  expected: 4

invariant copy_extra8.deepcopy.name_len:
  description: "copy.deepcopy.__name__.__len__() == 8 — name 'deepcopy' is 8 characters"
  category: function_names
  kind: python_call_eq
  function: deepcopy.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# Error class name length
#
# copy_extra4 covers Error.__name__ == 'Error'. No prior spec checks the
# length of Error.__name__. This confirms the name string is exactly 5
# characters, matching 'Error' and no other spelling.
# ---------------------------------------------------------------------------

invariant copy_extra8.Error.name_len:
  description: "copy.Error.__name__.__len__() == 5 — name 'Error' is 5 characters"
  category: error_names
  kind: python_call_eq
  function: Error.__name__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# copy.Error MRO — entries at index 2 and 3
#
# copy_extra7 covers Error.__mro__.__len__() == 4 and Error.__mro__[1].__name__
# == 'Exception'. No prior spec checks indices 2 and 3. The full MRO is:
# [Error, Exception, BaseException, object]. Index 2 is BaseException and
# index 3 is object (the root of all Python classes).
# ---------------------------------------------------------------------------

invariant copy_extra8.Error.mro_2_is_BaseException:
  description: "copy.Error.__mro__[2].__name__ == 'BaseException' — third MRO entry is BaseException"
  category: error_hierarchy
  kind: python_call_eq
  function: Error.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "BaseException"

invariant copy_extra8.Error.mro_3_is_object:
  description: "copy.Error.__mro__[3].__name__ == 'object' — fourth MRO entry is object (root)"
  category: error_hierarchy
  kind: python_call_eq
  function: Error.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "object"
