spec: syllable
version: ">=5.0.1"
backend: node(syllable)

docs: https://www.npmjs.com/package/syllable

provenance:
  derived_from:
    - "syllable README — https://www.npmjs.com/package/syllable"
    - "Test vectors verified with syllable via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "syllable source"
  notes:
    - "syllable is an npm package. Install: npm install syllable"
    - "Returns the number of syllables in an English word."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an integer."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table syllable.count:
  kind: node_module_call_eq
  function: syllable
  category: text
  id_prefix: syll

  columns: [id, args, expected]
  rows:
    - [hello,      ["hello"],      2]
    - [beautiful,  ["beautiful"],  3]
    - [world,      ["world"],      1]
