spec: pathlib_extra293
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — PurePath method and property identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py, Lib/pathlib/_abc.py"
  notes:
    - "PurePath provides pure path manipulation without I/O"
    - "__qualname__ attributes verified for methods; property class verified via __class__.__name__"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table pathlib_extra293.purepath_method_qualnames:
  description: "PurePath method __qualname__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: plm293

  columns: [id, function, args, expected, description]
  rows:
    - [plm293_001, pathlib.PurePath.with_name.__qualname__, [], "PurePath.with_name", "PurePath.with_name qualname"]
    - [plm293_002, pathlib.PurePath.with_suffix.__qualname__, [], "PurePath.with_suffix", "PurePath.with_suffix qualname"]
    - [plm293_003, pathlib.PurePath.with_stem.__qualname__, [], "PurePath.with_stem", "PurePath.with_stem qualname"]
    - [plm293_004, pathlib.PurePath.relative_to.__qualname__, [], "PurePath.relative_to", "PurePath.relative_to qualname"]
    - [plm293_005, pathlib.PurePath.is_relative_to.__qualname__, [], "PurePath.is_relative_to", "PurePath.is_relative_to qualname"]
    - [plm293_006, pathlib.PurePath.joinpath.__qualname__, [], "PurePath.joinpath", "PurePath.joinpath qualname"]
    - [plm293_007, pathlib.PurePath.match.__qualname__, [], "PurePath.match", "PurePath.match qualname"]

table pathlib_extra293.purepath_property_classes:
  description: "PurePath property class name checks"
  kind: python_call_eq
  category: identity
  id_prefix: plp293

  columns: [id, function, args, expected, description]
  rows:
    - [plp293_001, pathlib.PurePath.name.__class__.__name__, [], "property", "PurePath.name is a property"]
    - [plp293_002, pathlib.PurePath.suffix.__class__.__name__, [], "property", "PurePath.suffix is a property"]
    - [plp293_003, pathlib.PurePath.suffixes.__class__.__name__, [], "property", "PurePath.suffixes is a property"]
    - [plp293_004, pathlib.PurePath.stem.__class__.__name__, [], "property", "PurePath.stem is a property"]
    - [plp293_005, pathlib.PurePath.parent.__class__.__name__, [], "property", "PurePath.parent is a property"]
    - [plp293_006, pathlib.PurePath.parents.__class__.__name__, [], "property", "PurePath.parents is a property"]
    - [plp293_007, pathlib.PurePath.parts.__class__.__name__, [], "property", "PurePath.parts is a property"]
    - [plp293_008, pathlib.PurePath.root.__class__.__name__, [], "property", "PurePath.root is a property"]
    - [plp293_009, pathlib.PurePath.anchor.__class__.__name__, [], "property", "PurePath.anchor is a property"]
    - [plp293_010, pathlib.PurePath.drive.__class__.__name__, [], "property", "PurePath.drive is a property"]

invariant pathlib_extra293.with_name_qualname:
  description: "PurePath.with_name qualname is confirmed"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.with_name.__qualname__
  args: []
  expected: "PurePath.with_name"

invariant pathlib_extra293.joinpath_qualname:
  description: "PurePath.joinpath qualname is confirmed"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.joinpath.__qualname__
  args: []
  expected: "PurePath.joinpath"

invariant pathlib_extra293.name_is_property:
  description: "PurePath.name is confirmed to be a property descriptor"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.name.__class__.__name__
  args: []
  expected: "property"

invariant pathlib_extra293.drive_is_property:
  description: "PurePath.drive is confirmed to be a property descriptor"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.drive.__class__.__name__
  args: []
  expected: "property"
