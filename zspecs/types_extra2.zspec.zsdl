spec: types_extra2
version: ">=3.10"
backend: python_module(types)

docs: https://docs.python.org/3/library/types.html

provenance:
  derived_from:
    - "Python types documentation — https://docs.python.org/3/library/types.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/types.py"
  notes:
    - "Complements types_extra.zspec.zsdl with __module__ and __bases__ coverage."
    - "types_extra.zspec.zsdl covers __name__ checks for all major types types."
    - "Most types types are C-level builtins; their __module__ is 'builtins' except SimpleNamespace which is 'types'."
    - "FunctionType.__module__ == 'builtins' — function is a C-level type."
    - "SimpleNamespace.__module__ == 'types' — SimpleNamespace is defined in Lib/types.py."
    - "All documented types types inherit directly from object: __bases__[0].__name__ == 'object'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __module__ checks
# C-level types report __module__ == 'builtins'; SimpleNamespace reports 'types'
# ---------------------------------------------------------------------------

table types_extra2.class_modules:
  kind: python_call_eq
  category: class_modules
  id_prefix: mod

  columns: [id, function, args, expected]
  rows:
    - [functiontype,         FunctionType.__module__.__eq__,         ["builtins"], true]
    - [lambdatype,           LambdaType.__module__.__eq__,           ["builtins"], true]
    - [generatortype,        GeneratorType.__module__.__eq__,        ["builtins"], true]
    - [coroutinetype,        CoroutineType.__module__.__eq__,        ["builtins"], true]
    - [asyncgeneratortype,   AsyncGeneratorType.__module__.__eq__,   ["builtins"], true]
    - [codetype,             CodeType.__module__.__eq__,             ["builtins"], true]
    - [frametype,            FrameType.__module__.__eq__,            ["builtins"], true]
    - [tracebacktype,        TracebackType.__module__.__eq__,        ["builtins"], true]
    - [moduletype,           ModuleType.__module__.__eq__,           ["builtins"], true]
    - [methodtype,           MethodType.__module__.__eq__,           ["builtins"], true]
    - [builtinfunctiontype,  BuiltinFunctionType.__module__.__eq__,  ["builtins"], true]
    - [simplenamespace,      SimpleNamespace.__module__.__eq__,      ["types"],    true]

# ---------------------------------------------------------------------------
# Class __bases__ checks — all documented types types inherit from object
# ---------------------------------------------------------------------------

table types_extra2.class_bases:
  kind: python_call_eq
  category: hierarchy
  id_prefix: base

  columns: [id, function, args, method, expected]
  rows:
    - [functiontype,        FunctionType.__bases__.__getitem__,        [0], __name__, "object"]
    - [generatortype,       GeneratorType.__bases__.__getitem__,       [0], __name__, "object"]
    - [coroutinetype,       CoroutineType.__bases__.__getitem__,       [0], __name__, "object"]
    - [asyncgeneratortype,  AsyncGeneratorType.__bases__.__getitem__,  [0], __name__, "object"]
    - [codetype,            CodeType.__bases__.__getitem__,            [0], __name__, "object"]
    - [frametype,           FrameType.__bases__.__getitem__,           [0], __name__, "object"]
    - [tracebacktype,       TracebackType.__bases__.__getitem__,       [0], __name__, "object"]
    - [moduletype,          ModuleType.__bases__.__getitem__,          [0], __name__, "object"]
    - [methodtype,          MethodType.__bases__.__getitem__,          [0], __name__, "object"]
    - [simplenamespace,     SimpleNamespace.__bases__.__getitem__,     [0], __name__, "object"]
