spec: builtins
version: ">=3.0"
backend: python_module(builtins)

docs: https://docs.python.org/3/library/builtins.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/builtins.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/bltinmodule.c"
  notes:
    - "The builtins module exposes all built-in functions, exceptions, and types that are always available in the Python interpreter."
    - "builtins.IOError is an alias for builtins.OSError; IOError.__name__ == 'OSError'."
    - "builtins.True_ and builtins.None_ do not exist as names; the constants True, False, None are accessed directly."
    - "divmod(7, 3) returns the tuple (2, 1); the harness can extract elements via __getitem__."
    - "hex(255) == '0xff', oct(8) == '0o10', bin(4) == '0b100'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Exception class name checks
#
# The builtins module provides all standard exception classes. Each has a
# __name__ attribute equal to its canonical class name.
# Note: IOError is an alias for OSError; IOError.__name__ == 'OSError'.
# ---------------------------------------------------------------------------

table builtins.exception_names:
  kind: python_call_eq
  category: exception_names
  id_prefix: exc

  columns: [id, function, args, expected]
  rows:
    - [exception,          Exception.__name__.__eq__,          ["Exception"],          true]
    - [valueerror,         ValueError.__name__.__eq__,         ["ValueError"],         true]
    - [typeerror,          TypeError.__name__.__eq__,          ["TypeError"],          true]
    - [keyerror,           KeyError.__name__.__eq__,           ["KeyError"],           true]
    - [indexerror,         IndexError.__name__.__eq__,         ["IndexError"],         true]
    - [attributeerror,     AttributeError.__name__.__eq__,     ["AttributeError"],     true]
    - [nameerror,          NameError.__name__.__eq__,          ["NameError"],          true]
    - [runtimeerror,       RuntimeError.__name__.__eq__,       ["RuntimeError"],       true]
    - [stopiteration,      StopIteration.__name__.__eq__,      ["StopIteration"],      true]
    - [notimplementederror, NotImplementedError.__name__.__eq__, ["NotImplementedError"], true]
    - [zerodivisionerror,  ZeroDivisionError.__name__.__eq__,  ["ZeroDivisionError"],  true]
    - [filenotfounderror,  FileNotFoundError.__name__.__eq__,  ["FileNotFoundError"],  true]
    - [importerror,        ImportError.__name__.__eq__,        ["ImportError"],        true]
    - [modulenotfounderror, ModuleNotFoundError.__name__.__eq__, ["ModuleNotFoundError"], true]
    - [oserror,            OSError.__name__.__eq__,            ["OSError"],            true]
    - [arithmeticerror,    ArithmeticError.__name__.__eq__,    ["ArithmeticError"],    true]
    - [lookuperror,        LookupError.__name__.__eq__,        ["LookupError"],        true]
    - [assertionerror,     AssertionError.__name__.__eq__,     ["AssertionError"],     true]
    - [syntaxerror,        SyntaxError.__name__.__eq__,        ["SyntaxError"],        true]

# IOError is an alias for OSError — its __name__ reflects the canonical class
invariant builtins.exception_names.ioerror_alias:
  description: "builtins.IOError.__name__ == 'OSError' — IOError is an alias for OSError"
  category: exception_names
  kind: python_call_eq
  function: IOError.__name__.__eq__
  args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# Built-in type class name checks
# ---------------------------------------------------------------------------

table builtins.type_names:
  kind: python_call_eq
  category: type_names
  id_prefix: tname

  columns: [id, function, args, expected]
  rows:
    - [int,         int.__name__.__eq__,         ["int"],         true]
    - [str,         str.__name__.__eq__,          ["str"],         true]
    - [list,        list.__name__.__eq__,         ["list"],        true]
    - [dict,        dict.__name__.__eq__,         ["dict"],        true]
    - [set,         set.__name__.__eq__,          ["set"],         true]
    - [tuple,       tuple.__name__.__eq__,        ["tuple"],       true]
    - [bool,        bool.__name__.__eq__,         ["bool"],        true]
    - [float,       float.__name__.__eq__,        ["float"],       true]
    - [bytes,       bytes.__name__.__eq__,        ["bytes"],       true]
    - [bytearray,   bytearray.__name__.__eq__,    ["bytearray"],   true]
    - [complex,     complex.__name__.__eq__,      ["complex"],     true]
    - [object,      object.__name__.__eq__,       ["object"],      true]
    - [property,    property.__name__.__eq__,     ["property"],    true]
    - [enumerate,   enumerate.__name__.__eq__,    ["enumerate"],   true]
    - [zip,         zip.__name__.__eq__,          ["zip"],         true]
    - [map,         map.__name__.__eq__,          ["map"],         true]
    - [filter,      filter.__name__.__eq__,       ["filter"],      true]

# ---------------------------------------------------------------------------
# Built-in function name checks
# ---------------------------------------------------------------------------

table builtins.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [len,       len.__name__.__eq__,       ["len"],       true]
    - [abs,       abs.__name__.__eq__,        ["abs"],       true]
    - [hex,       hex.__name__.__eq__,        ["hex"],       true]
    - [oct,       oct.__name__.__eq__,        ["oct"],       true]
    - [bin,       bin.__name__.__eq__,        ["bin"],       true]
    - [chr,       chr.__name__.__eq__,        ["chr"],       true]
    - [ord,       ord.__name__.__eq__,        ["ord"],       true]
    - [sorted,    sorted.__name__.__eq__,     ["sorted"],    true]
    - [max,       max.__name__.__eq__,        ["max"],       true]
    - [min,       min.__name__.__eq__,        ["min"],       true]
    - [sum,       sum.__name__.__eq__,        ["sum"],       true]
    - [round,     round.__name__.__eq__,      ["round"],     true]
    - [pow,       pow.__name__.__eq__,        ["pow"],       true]
    - [divmod,    divmod.__name__.__eq__,     ["divmod"],    true]
    - [hash,      hash.__name__.__eq__,       ["hash"],      true]
    - [repr,      repr.__name__.__eq__,       ["repr"],      true]
    - [callable,  callable.__name__.__eq__,   ["callable"],  true]
    - [isinstance, isinstance.__name__.__eq__, ["isinstance"], true]
    - [issubclass, issubclass.__name__.__eq__, ["issubclass"], true]
    - [getattr,   getattr.__name__.__eq__,    ["getattr"],   true]
    - [setattr,   setattr.__name__.__eq__,    ["setattr"],   true]
    - [hasattr,   hasattr.__name__.__eq__,    ["hasattr"],   true]
    - [iter,      iter.__name__.__eq__,       ["iter"],      true]
    - [next,      next.__name__.__eq__,       ["next"],      true]

# ---------------------------------------------------------------------------
# len() — list length
# ---------------------------------------------------------------------------

invariant builtins.len.list_3:
  description: "builtins.len([1, 2, 3]) == 3"
  category: function_calls
  kind: python_call_eq
  function: len
  args: [[1, 2, 3]]
  expected: 3

invariant builtins.len.empty:
  description: "builtins.len([]) == 0"
  category: function_calls
  kind: python_call_eq
  function: len
  args: [[]]
  expected: 0

# ---------------------------------------------------------------------------
# abs() — absolute value
# ---------------------------------------------------------------------------

invariant builtins.abs.negative:
  description: "builtins.abs(-5) == 5"
  category: function_calls
  kind: python_call_eq
  function: abs
  args: [-5]
  expected: 5

invariant builtins.abs.positive:
  description: "builtins.abs(7) == 7"
  category: function_calls
  kind: python_call_eq
  function: abs
  args: [7]
  expected: 7

# ---------------------------------------------------------------------------
# hex(), oct(), bin() — integer base conversions
# ---------------------------------------------------------------------------

invariant builtins.hex.ff:
  description: "builtins.hex(255) == '0xff'"
  category: function_calls
  kind: python_call_eq
  function: hex
  args: [255]
  expected: "0xff"

invariant builtins.oct.eight:
  description: "builtins.oct(8) == '0o10'"
  category: function_calls
  kind: python_call_eq
  function: oct
  args: [8]
  expected: "0o10"

invariant builtins.bin.four:
  description: "builtins.bin(4) == '0b100'"
  category: function_calls
  kind: python_call_eq
  function: bin
  args: [4]
  expected: "0b100"

# ---------------------------------------------------------------------------
# chr() and ord() — character/codepoint conversions
# ---------------------------------------------------------------------------

invariant builtins.chr.65:
  description: "builtins.chr(65) == 'A'"
  category: function_calls
  kind: python_call_eq
  function: chr
  args: [65]
  expected: "A"

invariant builtins.chr.97:
  description: "builtins.chr(97) == 'a'"
  category: function_calls
  kind: python_call_eq
  function: chr
  args: [97]
  expected: "a"

invariant builtins.ord.A:
  description: "builtins.ord('A') == 65"
  category: function_calls
  kind: python_call_eq
  function: ord
  args: ["A"]
  expected: 65

invariant builtins.ord.a:
  description: "builtins.ord('a') == 97"
  category: function_calls
  kind: python_call_eq
  function: ord
  args: ["a"]
  expected: 97

# ---------------------------------------------------------------------------
# divmod() — quotient and remainder
#
# divmod(7, 3) returns (2, 1). Extract elements via __getitem__.
# ---------------------------------------------------------------------------

invariant builtins.divmod.quotient:
  description: "builtins.divmod(7, 3)[0] == 2 — quotient"
  category: function_calls
  kind: python_call_eq
  function: divmod
  args: [7, 3]
  method: __getitem__
  method_args: [0]
  expected: 2

invariant builtins.divmod.remainder:
  description: "builtins.divmod(7, 3)[1] == 1 — remainder"
  category: function_calls
  kind: python_call_eq
  function: divmod
  args: [7, 3]
  method: __getitem__
  method_args: [1]
  expected: 1

