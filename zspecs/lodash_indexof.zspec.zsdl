spec: lodash_indexof
version: ">=4.0.0"
backend: node(lodash.indexof)

docs: https://lodash.com/docs/#indexOf

provenance:
  derived_from:
    - "lodash.indexof README — https://www.npmjs.com/package/lodash.indexof"
    - "Test vectors verified with lodash.indexof@4.0.5 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.indexof exports the _.indexOf function directly as module.exports."
    - "indexOf(array, value, fromIndex) returns the index of the first occurrence."
    - "Returns -1 if value is not found."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns integer index. Returns -1 if not found."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_indexof.indexof:
  kind: node_module_call_eq
  function: ~
  category: indexof
  id_prefix: liof

  columns: [id, args, expected]
  rows:
    - [found,        [[1, 2, 3, 2], 2],     1]
    - [not_found,    [[1, 2, 3], 4],        -1]
    - [from_index,   [[1, 2, 3, 2], 2, 2],  3]
    - [first,        [[5, 1, 2, 3], 5],     0]

