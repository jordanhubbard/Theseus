spec: uuid_extra257
version: ">=3.2"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid documentation"
    - "RFC 9562 — Universally Unique IDentifiers (UUID)"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra256.zspec.zsdl — covers uuid4() version/variant statistical properties; UUID.__eq__/__ne__/__lt__ comparison method identity; UUID equality/ordering behavioral contracts."
    - "uuid_extra255.zspec.zsdl — covers uuid module identity (__name__, __package__, __spec__, __loader__); UUID repr/hash/bytes/bytes_le; UUID.__repr__/__hash__ method identity."
    - "uuid_extra.zspec.zsdl — covers UUID class name/module; uuid1/3/4/5 function names; uuid4 return class and version; NAMESPACE_* class names; UUID.int and hex class names."
  notes:
    - "uuid.uuid1.__name__ == 'uuid1' and __module__ == 'uuid' and __class__.__name__ == 'function' — uuid1 is a pure-Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.uuid3.__name__ == 'uuid3' and __module__ == 'uuid' and __class__.__name__ == 'function' — uuid3 is a pure-Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.uuid4.__name__ == 'uuid4' and __module__ == 'uuid' and __class__.__name__ == 'function' — uuid4 is a pure-Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.uuid5.__name__ == 'uuid5' and __module__ == 'uuid' and __class__.__name__ == 'function' — uuid5 is a pure-Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' — NAMESPACE_DNS is a UUID instance. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.NAMESPACE_DNS.variant == 'specified in RFC 4122' — namespace constants use the RFC 4122 variant. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID' — NAMESPACE_URL is a UUID instance. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.NAMESPACE_OID.__class__.__name__ == 'UUID' — NAMESPACE_OID is a UUID instance. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.NAMESPACE_X500.__class__.__name__ == 'UUID' — NAMESPACE_X500 is a UUID instance. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__name__ == 'UUID' and __module__ == 'uuid' and __bases__[0].__name__ == 'object' — UUID class hierarchy. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid function identity — uuid1, uuid3, uuid4, uuid5
# All four are pure-Python functions defined in Lib/uuid.py:
# __class__.__name__ == 'function', __module__ == 'uuid'
# ---------------------------------------------------------------------------

table uuid_extra257.uuid_function_identity:
  description: "uuid.uuid1/uuid3/uuid4/uuid5 function __name__, __module__, __class__.__name__ — all are pure-Python functions in Lib/uuid.py; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: uuidfn257

  columns: [id, function, args, expected, description]
  rows:
    - [uuid1_name,    uuid1.__name__.__eq__,               ["uuid1"],    true, "uuid.uuid1.__name__ == 'uuid1'"]
    - [uuid1_module,  uuid1.__module__.__eq__,             ["uuid"],     true, "uuid.uuid1.__module__ == 'uuid' — defined in Lib/uuid.py"]
    - [uuid1_class,   uuid1.__class__.__name__.__eq__,      ["function"], true, "uuid.uuid1.__class__.__name__ == 'function' — pure-Python function"]
    - [uuid3_name,    uuid3.__name__.__eq__,               ["uuid3"],    true, "uuid.uuid3.__name__ == 'uuid3'"]
    - [uuid3_module,  uuid3.__module__.__eq__,             ["uuid"],     true, "uuid.uuid3.__module__ == 'uuid' — defined in Lib/uuid.py"]

# ---------------------------------------------------------------------------
# uuid4 and uuid5 function identity
# ---------------------------------------------------------------------------

table uuid_extra257.uuid45_function_identity:
  description: "uuid.uuid4/uuid5 function __name__, __module__, __class__.__name__; namespace constant __class__.__name__ and variant; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: uuidfn257b

  columns: [id, function, args, expected, description]
  rows:
    - [uuid4_name,       uuid4.__name__.__eq__,                   ["uuid4"],                true, "uuid.uuid4.__name__ == 'uuid4'"]
    - [uuid4_module,     uuid4.__module__.__eq__,                 ["uuid"],                 true, "uuid.uuid4.__module__ == 'uuid' — defined in Lib/uuid.py"]
    - [uuid4_class,      uuid4.__class__.__name__.__eq__,          ["function"],             true, "uuid.uuid4.__class__.__name__ == 'function' — pure-Python function"]
    - [uuid5_name,       uuid5.__name__.__eq__,                   ["uuid5"],                true, "uuid.uuid5.__name__ == 'uuid5'"]
    - [uuid5_module,     uuid5.__module__.__eq__,                 ["uuid"],                 true, "uuid.uuid5.__module__ == 'uuid' — defined in Lib/uuid.py"]

# ---------------------------------------------------------------------------
# Namespace constant identity — NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID, NAMESPACE_X500
# All are UUID instances; their variant is 'specified in RFC 4122'
# ---------------------------------------------------------------------------

invariant uuid_extra257.NAMESPACE_DNS_class:
  description: "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' — NAMESPACE_DNS is a UUID instance"
  category: identity
  kind: python_call_eq
  function: NAMESPACE_DNS.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true

invariant uuid_extra257.NAMESPACE_DNS_variant:
  description: "uuid.NAMESPACE_DNS.variant == 'specified in RFC 4122' — DNS namespace constant uses RFC 4122 variant"
  category: identity
  kind: python_call_eq
  function: NAMESPACE_DNS.variant.__eq__
  args: ["specified in RFC 4122"]
  expected: true

invariant uuid_extra257.NAMESPACE_URL_class:
  description: "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID' — NAMESPACE_URL is a UUID instance"
  category: identity
  kind: python_call_eq
  function: NAMESPACE_URL.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true

invariant uuid_extra257.NAMESPACE_URL_variant:
  description: "uuid.NAMESPACE_URL.variant == 'specified in RFC 4122' — URL namespace constant uses RFC 4122 variant"
  category: identity
  kind: python_call_eq
  function: NAMESPACE_URL.variant.__eq__
  args: ["specified in RFC 4122"]
  expected: true

invariant uuid_extra257.NAMESPACE_OID_class:
  description: "uuid.NAMESPACE_OID.__class__.__name__ == 'UUID' — NAMESPACE_OID is a UUID instance"
  category: identity
  kind: python_call_eq
  function: NAMESPACE_OID.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true

invariant uuid_extra257.NAMESPACE_X500_class:
  description: "uuid.NAMESPACE_X500.__class__.__name__ == 'UUID' — NAMESPACE_X500 is a UUID instance"
  category: identity
  kind: python_call_eq
  function: NAMESPACE_X500.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# UUID class identity
# uuid.UUID.__name__ == 'UUID', __module__ == 'uuid', __bases__[0].__name__ == 'object'
# ---------------------------------------------------------------------------

invariant uuid_extra257.UUID_class_name:
  description: "uuid.UUID.__name__ == 'UUID' — the UUID class name"
  category: identity
  kind: python_call_eq
  function: UUID.__name__.__eq__
  args: ["UUID"]
  expected: true

invariant uuid_extra257.UUID_class_module:
  description: "uuid.UUID.__module__ == 'uuid' — UUID class is defined in Lib/uuid.py"
  category: identity
  kind: python_call_eq
  function: UUID.__module__.__eq__
  args: ["uuid"]
  expected: true

invariant uuid_extra257.UUID_class_base:
  description: "uuid.UUID.__bases__[0].__name__ == 'object' — UUID inherits directly from object"
  category: identity
  kind: python_call_eq
  function: "UUID.__bases__.__getitem__(0).__class__.__name__.__eq__"
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# uuid3 and uuid5 class name
# ---------------------------------------------------------------------------

invariant uuid_extra257.uuid3_class_eq:
  description: "uuid.uuid3.__class__.__name__ == 'function' — uuid3 is a pure-Python function"
  category: identity
  kind: python_call_eq
  function: uuid3.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant uuid_extra257.uuid5_class_eq:
  description: "uuid.uuid5.__class__.__name__ == 'function' — uuid5 is a pure-Python function"
  category: identity
  kind: python_call_eq
  function: uuid5.__class__.__name__.__eq__
  args: ["function"]
  expected: true
