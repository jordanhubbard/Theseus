spec: bz2_extra16
version: ">=3.9"
backend: python_module(bz2)

docs: https://docs.python.org/3/library/bz2.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bz2.html — Python bz2 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_bz2module.c"
    - "CPython source: Lib/bz2.py"
    - "bz2_extra15.zspec.zsdl — covers BZ2File.read/write/seek/close __qualname__ (method qualnames, extra15); BZ2Compressor/BZ2Decompressor __qualname__ standalone (extra15); open/compress/decompress __qualname__ (extra15 anchor)."
    - "bz2_extra14.zspec.zsdl — covers BZ2File/BZ2Compressor/BZ2Decompressor __qualname__ standalone (extra14); open/compress/decompress __qualname__ standalone (extra14); bz2.__name__ standalone (extra14)."
    - "bz2_extra4.zspec.zsdl — covers BZ2File/BZ2Compressor/BZ2Decompressor __qualname__ table; open/compress/decompress __qualname__ table."
    - "bz2_extra2.zspec.zsdl — covers BZ2File.read/__name__, BZ2File.write/__name__, BZ2File.close/__name__ in a method names table."
    - "bz2_extra8.zspec.zsdl — covers BZ2Compressor.compress/__name__, BZ2Compressor.flush/__name__, BZ2Decompressor.decompress/__name__ in a method names table."
  notes:
    - "This spec extends bz2 through bz2_extra15; it does NOT duplicate invariants present in those files."
    - "Focus: method __qualname__ invariants for BZ2File.__init__, BZ2File.readable, BZ2File.writable, BZ2File.seekable, BZ2Compressor.compress, BZ2Compressor.flush, and BZ2Decompressor.decompress — not covered by any prior bz2 spec."
    - "extra8 covers BZ2Compressor.compress/__name__ and BZ2Compressor.flush/__name__ (method __name__); this spec adds __qualname__ for those same methods — a distinct axis. Verified 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BZ2File.__init__ __qualname__ — standalone, extra16 anchor
#
# No prior bz2 spec checks BZ2File.__init__.__qualname__. Prior specs cover
# BZ2File.read/write/seek/close qualnames (extra15) but not __init__.
# ---------------------------------------------------------------------------

invariant bz2_extra16.BZ2File.init.qualname:
  description: "bz2.BZ2File.__init__.__qualname__ == 'BZ2File.__init__' — constructor qualname encodes class context (extra16)"
  category: qualnames
  kind: python_call_eq
  function: "BZ2File.__init__.__qualname__.__eq__"
  args: ["BZ2File.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# BZ2File.readable __qualname__ — standalone, extra16 anchor
#
# No prior bz2 spec checks BZ2File.readable.__qualname__.
# ---------------------------------------------------------------------------

invariant bz2_extra16.BZ2File.readable.qualname:
  description: "bz2.BZ2File.readable.__qualname__ == 'BZ2File.readable' — method qualname encodes class context (extra16)"
  category: qualnames
  kind: python_call_eq
  function: BZ2File.readable.__qualname__.__eq__
  args: ["BZ2File.readable"]
  expected: true

# ---------------------------------------------------------------------------
# BZ2File.writable __qualname__ — standalone, extra16 anchor
#
# No prior bz2 spec checks BZ2File.writable.__qualname__.
# ---------------------------------------------------------------------------

invariant bz2_extra16.BZ2File.writable.qualname:
  description: "bz2.BZ2File.writable.__qualname__ == 'BZ2File.writable' — method qualname encodes class context (extra16)"
  category: qualnames
  kind: python_call_eq
  function: BZ2File.writable.__qualname__.__eq__
  args: ["BZ2File.writable"]
  expected: true

# ---------------------------------------------------------------------------
# BZ2File.seekable __qualname__ — standalone, extra16 anchor
#
# No prior bz2 spec checks BZ2File.seekable.__qualname__.
# ---------------------------------------------------------------------------

invariant bz2_extra16.BZ2File.seekable.qualname:
  description: "bz2.BZ2File.seekable.__qualname__ == 'BZ2File.seekable' — method qualname encodes class context (extra16)"
  category: qualnames
  kind: python_call_eq
  function: BZ2File.seekable.__qualname__.__eq__
  args: ["BZ2File.seekable"]
  expected: true

# ---------------------------------------------------------------------------
# BZ2Compressor.compress __qualname__ — standalone, extra16 anchor
#
# extra8 covers BZ2Compressor.compress.__name__ == 'compress' (method __name__).
# No prior bz2 spec checks BZ2Compressor.compress.__qualname__.
# ---------------------------------------------------------------------------

invariant bz2_extra16.BZ2Compressor.compress.qualname:
  description: "bz2.BZ2Compressor.compress.__qualname__ == 'BZ2Compressor.compress' — method qualname encodes class context (extra16)"
  category: qualnames
  kind: python_call_eq
  function: BZ2Compressor.compress.__qualname__.__eq__
  args: ["BZ2Compressor.compress"]
  expected: true

# ---------------------------------------------------------------------------
# BZ2Compressor.flush __qualname__ — standalone, extra16 anchor
#
# extra8 covers BZ2Compressor.flush.__name__ == 'flush' (method __name__).
# No prior bz2 spec checks BZ2Compressor.flush.__qualname__.
# ---------------------------------------------------------------------------

invariant bz2_extra16.BZ2Compressor.flush.qualname:
  description: "bz2.BZ2Compressor.flush.__qualname__ == 'BZ2Compressor.flush' — method qualname encodes class context (extra16)"
  category: qualnames
  kind: python_call_eq
  function: BZ2Compressor.flush.__qualname__.__eq__
  args: ["BZ2Compressor.flush"]
  expected: true

# ---------------------------------------------------------------------------
# BZ2Decompressor.decompress __qualname__ — standalone, extra16 anchor
#
# extra8 covers BZ2Decompressor.decompress.__name__ == 'decompress' (method __name__).
# No prior bz2 spec checks BZ2Decompressor.decompress.__qualname__.
# ---------------------------------------------------------------------------

invariant bz2_extra16.BZ2Decompressor.decompress.qualname:
  description: "bz2.BZ2Decompressor.decompress.__qualname__ == 'BZ2Decompressor.decompress' — method qualname encodes class context (extra16)"
  category: qualnames
  kind: python_call_eq
  function: BZ2Decompressor.decompress.__qualname__.__eq__
  args: ["BZ2Decompressor.decompress"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ table — BZ2File special + IO methods + compressor methods (extra16)
#
# No prior bz2 spec presents __init__, readable, writable, seekable qualnames
# or BZ2Compressor/BZ2Decompressor method qualnames in any table.
# This table anchors all seven identifiers from the extra16 namespace.
# ---------------------------------------------------------------------------

table bz2_extra16.method_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qn16

  columns: [id, function, args, expected]
  rows:
    - [BZ2File.__init__,           "BZ2File.__init__.__qualname__.__eq__",           ["BZ2File.__init__"],           true]
    - [BZ2File.readable,           BZ2File.readable.__qualname__.__eq__,             ["BZ2File.readable"],           true]
    - [BZ2File.writable,           BZ2File.writable.__qualname__.__eq__,             ["BZ2File.writable"],           true]
    - [BZ2File.seekable,           BZ2File.seekable.__qualname__.__eq__,             ["BZ2File.seekable"],           true]
    - [BZ2Compressor.compress,     BZ2Compressor.compress.__qualname__.__eq__,       ["BZ2Compressor.compress"],     true]
    - [BZ2Compressor.flush,        BZ2Compressor.flush.__qualname__.__eq__,          ["BZ2Compressor.flush"],        true]
    - [BZ2Decompressor.decompress, BZ2Decompressor.decompress.__qualname__.__eq__,   ["BZ2Decompressor.decompress"], true]
