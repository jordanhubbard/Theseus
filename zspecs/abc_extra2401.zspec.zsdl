  id_prefix: ab2401

  columns: [id, function, args, expected]
  rows:
    - ["ab2401007", ABCMeta.__hash__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - ["ab2401008", ABCMeta.__eq__.__class__.__name__.__eq__,    ["wrapper_descriptor"], true]
    - ["ab2401009", ABCMeta.__hash__.__class__.__name__.__len__, [], 18]
    - ["ab2401010", ABCMeta.__eq__.__class__.__name__.__len__,   [], 18]
    - ["ab2401011", ABCMeta.__dict__.__contains__,               ["__hash__"], false]
    - ["ab2401012", ABCMeta.__dict__.__contains__,               ["__eq__"], false]

# ---------------------------------------------------------------------------
# Table 3: abc.abstractmethod __hash__ and __eq__ implementation type
#
# abstractmethod is a plain Python function, not a class. Accessing __hash__
# or __eq__ on a function object yields 'method-wrapper' — these are bound
# method wrappers on the function instance, not unbound slot wrappers.
# This distinguishes functions from classes in the hash/eq type taxonomy.
# abstractmethod.__dict__ contains neither '__hash__' nor '__eq__'.
# ---------------------------------------------------------------------------

table abc_extra2401.abstractmethod_hash_eq:
  description: "abc.abstractmethod __hash__ and __eq__ implementation type classification — function yields method-wrapper"
  kind: python_call_eq
  category: hash_eq_type
  id_prefix: ab2401

  columns: [id, function, args, expected]
  rows:
    - ["ab2401013", abstractmethod.__hash__.__class__.__name__.__eq__,  ["method-wrapper"], true]
    - ["ab2401014", abstractmethod.__eq__.__class__.__name__.__eq__,    ["method-wrapper"], true]
    - ["ab2401015", abstractmethod.__hash__.__class__.__name__.__len__, [], 14]
    - ["ab2401016", abstractmethod.__eq__.__class__.__name__.__len__,   [], 14]
    - ["ab2401017", abstractmethod.__dict__.__contains__,               ["__hash__"], false]
    - ["ab2401018", abstractmethod.__dict__.__contains__,               ["__eq__"], false]

