spec: abc_extra2401
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Theme: __hash__ and __eq__ implementation type classification via .__hash__.__class__.__name__ and .__eq__.__class__.__name__."
    - "abc.ABC is a class (metaclass ABCMeta); __hash__ and __eq__ are 'wrapper_descriptor' (slot wrappers inherited from object)."
    - "abc.ABCMeta is a metaclass (subclass of type); __hash__ and __eq__ are 'wrapper_descriptor' (slot wrappers from type/object)."
    - "abc.abstractmethod is a plain Python function, not a class; its __hash__ and __eq__ are 'method-wrapper' (bound method wrappers on the function object itself)."
    - "abc.abstractclassmethod, abc.abstractstaticmethod, abc.abstractproperty are deprecated but still present; all are classes with __hash__ and __eq__ as 'wrapper_descriptor'."
    - "None of these set __hash__ = None, so __hash__.__class__.__name__ is never 'NoneType'."
    - "The 'method-wrapper' vs 'wrapper_descriptor' distinction: class-level attribute lookup yields 'wrapper_descriptor'; instance-level (or function-level) yields 'method-wrapper'."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: abc.ABC __hash__ and __eq__ implementation type
#
# ABC is an ordinary class with ABCMeta as its metaclass. __hash__ and __eq__
# are 'wrapper_descriptor' slot wrappers inherited from object. ABC.__dict__
# contains neither '__hash__' nor '__eq__'.
# ---------------------------------------------------------------------------

table abc_extra2401.abc_hash_eq:
  description: "abc.ABC __hash__ and __eq__ implementation type classification"
  kind: python_call_eq
  category: hash_eq_type
  id_prefix: ab2401

  columns: [id, function, args, expected]
  rows:
    - ["ab2401001", ABC.__hash__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - ["ab2401002", ABC.__eq__.__class__.__name__.__eq__,    ["wrapper_descriptor"], true]
    - ["ab2401003", ABC.__hash__.__class__.__name__.__len__, [], 18]
    - ["ab2401004", ABC.__eq__.__class__.__name__.__len__,   [], 18]
    - ["ab2401005", ABC.__dict__.__contains__,               ["__hash__"], false]
    - ["ab2401006", ABC.__dict__.__contains__,               ["__eq__"], false]

# ---------------------------------------------------------------------------
# Table 2: abc.ABCMeta __hash__ and __eq__ implementation type
#
# ABCMeta is a metaclass (subclass of type). __hash__ and __eq__ are
# 'wrapper_descriptor' inherited from type/object. ABCMeta.__dict__ contains
# neither '__hash__' nor '__eq__'.
# ---------------------------------------------------------------------------

table abc_extra2401.abcmeta_hash_eq:
  description: "abc.ABCMeta __hash__ and __eq__ implementation type classification"
  kind: python_call_eq
