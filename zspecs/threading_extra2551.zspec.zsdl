spec: threading_extra2551
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/threading.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2551 (_extra2551): __reduce__, __reduce_ex__, __getnewargs__ dict-presence checks."
    - "threading synchronisation primitives (Lock, Event, Condition, Semaphore, BoundedSemaphore, Barrier, RLock) define NONE of the three pickling dunders — threading objects are intentionally not picklable."
    - "threading.Thread and threading.Timer also define none of the three."
    - "threading.ExceptHookArgs is a namedtuple and defines __reduce__ (via namedtuple machinery for ExceptHookArgs) — verified True on Python 3.14."
    - "threading._deque (alias for collections.deque in the threading module) defines __reduce__ — inherited from the deque C type."
    - "threading.local defines no pickling dunders — thread-local storage cannot be meaningfully pickled."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __reduce__ dict-presence for threading synchronisation types
#
# Lock, Event, Condition, Semaphore, BoundedSemaphore, Barrier are not
# picklable and define no __reduce__ in their __dict__.
# Thread and Timer (subclasses of Thread) also lack __reduce__.
# ---------------------------------------------------------------------------

table threading_extra2551.reduce_protocol_sync:
  description: "threading synchronisation types __reduce__ dict-presence checks — all False — wave 2551 _extra2551"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2551

  columns: [id, function, args, expected]
  rows:
    - ["th2551001", "threading.Lock.__dict__.__contains__", ["__reduce__"], false]
    - ["th2551002", "threading.Event.__dict__.__contains__", ["__reduce__"], false]
    - ["th2551003", "threading.Condition.__dict__.__contains__", ["__reduce__"], false]
    - ["th2551004", "threading.Semaphore.__dict__.__contains__", ["__reduce__"], false]
    - ["th2551005", "threading.BoundedSemaphore.__dict__.__contains__", ["__reduce__"], false]
    - ["th2551006", "threading.Barrier.__dict__.__contains__", ["__reduce__"], false]
    - ["th2551007", "threading.Thread.__dict__.__contains__", ["__reduce__"], false]
    - ["th2551008", "threading.Timer.__dict__.__contains__", ["__reduce__"], false]
    - ["th2551009", "threading.local.__dict__.__contains__", ["__reduce__"], false]

# ---------------------------------------------------------------------------
# Table 2: __reduce__ dict-presence for threading utility types
#
# threading.ExceptHookArgs is a namedtuple — it defines __reduce__ via
# the namedtuple machinery.
# threading._deque is collections.deque re-exported — its C type defines
# __reduce__ for pickle support.
# threading.ThreadError and threading.BrokenBarrierError (exceptions) do not
# define __reduce__ in their own __dict__.
# ---------------------------------------------------------------------------

table threading_extra2551.reduce_protocol_util:
  description: "threading utility types __reduce__ dict-presence checks — wave 2551 _extra2551"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2551

  columns: [id, function, args, expected]
  rows:
    - ["th2551010", "threading.ExceptHookArgs.__dict__.__contains__", ["__reduce__"], true]
    - ["th2551011", "threading._deque.__dict__.__contains__", ["__reduce__"], true]
    - ["th2551012", "threading.ThreadError.__dict__.__contains__", ["__reduce__"], false]
    - ["th2551013", "threading.BrokenBarrierError.__dict__.__contains__", ["__reduce__"], false]

# ---------------------------------------------------------------------------
# Table 3: __reduce_ex__ dict-presence for threading types
#
# No threading type defines __reduce_ex__ in its own __dict__.
# __reduce_ex__ is inherited from object throughout.
# ---------------------------------------------------------------------------

table threading_extra2551.reduce_ex_protocol:
  description: "threading types __reduce_ex__ dict-presence checks — all False — wave 2551 _extra2551"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2551

  columns: [id, function, args, expected]
  rows:
    - ["th2551014", "threading.Lock.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["th2551015", "threading.Event.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["th2551016", "threading.Condition.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["th2551017", "threading.Semaphore.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["th2551018", "threading.Thread.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["th2551019", "threading.ExceptHookArgs.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["th2551020", "threading._deque.__dict__.__contains__", ["__reduce_ex__"], false]

# ---------------------------------------------------------------------------
# Table 4: __getnewargs__ dict-presence for threading types
#
# No threading type defines __getnewargs__ in its own __dict__.
# threading.ExceptHookArgs is a namedtuple but uses __reduce__, not
# __getnewargs__, for its pickling path on Python 3.14.
# ---------------------------------------------------------------------------

table threading_extra2551.getnewargs_protocol:
  description: "threading types __getnewargs__ dict-presence checks — all False — wave 2551 _extra2551"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2551

  columns: [id, function, args, expected]
  rows:
    - ["th2551021", "threading.Lock.__dict__.__contains__", ["__getnewargs__"], false]
    - ["th2551022", "threading.Event.__dict__.__contains__", ["__getnewargs__"], false]
    - ["th2551023", "threading.Condition.__dict__.__contains__", ["__getnewargs__"], false]
    - ["th2551024", "threading.Semaphore.__dict__.__contains__", ["__getnewargs__"], false]
    - ["th2551025", "threading.BoundedSemaphore.__dict__.__contains__", ["__getnewargs__"], false]
    - ["th2551026", "threading.Barrier.__dict__.__contains__", ["__getnewargs__"], false]
    - ["th2551027", "threading.Thread.__dict__.__contains__", ["__getnewargs__"], false]
    - ["th2551028", "threading.local.__dict__.__contains__", ["__getnewargs__"], false]
    - ["th2551029", "threading.ExceptHookArgs.__dict__.__contains__", ["__getnewargs__"], false]
    - ["th2551030", "threading._deque.__dict__.__contains__", ["__getnewargs__"], false]
