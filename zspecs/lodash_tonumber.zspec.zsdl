spec: lodash_tonumber
version: ">=4.0.0"
backend: node(lodash.tonumber)

docs: https://lodash.com/docs/#toNumber

provenance:
  derived_from:
    - "lodash.tonumber README — https://www.npmjs.com/package/lodash.tonumber"
    - "Test vectors verified with lodash.tonumber@4.0.3 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.tonumber exports the _.toNumber function directly as module.exports."
    - "toNumber converts value to a number."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_tonumber.tonumber:
  kind: node_module_call_eq
  function: ~
  category: tonumber
  id_prefix: lton

  columns: [id, args, expected]
  rows:
    - [str_float,    ["3.14"],  3.14]
    - [str_int,      ["5"],     5]
    - [already_num,  [3.14],    3.14]
    - [integer,      [7],       7]

