spec: asyncio_extra214
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "This spec covers: __doc__ string contains checks for asyncio.Lock and asyncio.Semaphore (new objects vs wave 379), plus new words for asyncio.sleep, asyncio.Task, and asyncio.Queue not used in wave 379."
    - "asyncio.sleep.__doc__ == 'Coroutine that completes after a given time (in seconds).' (len=57). NEW words: 'time'==True, 'given'==True, 'completes'==True. Wave 379 used 'seconds','Coroutine'. Verified with Python 3.14.3."
    - "asyncio.Task.__doc__ == 'A coroutine wrapped in a Future.' (len=32). NEW words: 'wrap'==True, 'wrapped'==True. Wave 379 used 'Task','result'. Verified with Python 3.14.3."
    - "asyncio.Queue.__doc__ starts 'A queue, useful for coordinating producer and consumer coroutines.' (len=490). NEW words: 'item'==True, 'put'==True, 'get'==True, 'consumer'==True. Wave 379 used 'Queue','maxsize'. Verified with Python 3.14.3."
    - "asyncio.Lock.__doc__ (len=1437): 'lock'==True, 'primitive'==True, 'acquire'==True, 'unlocked'==True. New object not covered in wave 379. Verified with Python 3.14.3."
    - "asyncio.Semaphore.__doc__ (len=494): 'semaphore'==True, 'counter'==True, 'acquire'==True, 'release'==True. New object not covered in wave 379. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.sleep __doc__ new-word contains checks — extra214
#
# asyncio.sleep.__doc__ == 'Coroutine that completes after a given time (in seconds).'
# len == 57
# NEW (not in wave 379): 'time'==True, 'given'==True, 'completes'==True
# ---------------------------------------------------------------------------

table asyncio_extra214.asyncio_sleep_doc_new_words:
  description: "asyncio.sleep.__doc__ contains checks using words NOT in wave 379 — ae214sleep: 'time'==True ('a given time (in seconds).'); 'given'==True; 'completes'==True ('that completes after'); wave 379 covered 'seconds' and 'Coroutine'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ae214sleep

  columns: [id, function, args, expected, description]
  rows:
    - [sleep_doc_has_time,      asyncio.sleep.__doc__.__contains__, ["time"],      true, "asyncio.sleep.__doc__.__contains__('time') == True; 'a given time (in seconds).'; verified with Python 3.14.3"]
    - [sleep_doc_has_given,     asyncio.sleep.__doc__.__contains__, ["given"],     true, "asyncio.sleep.__doc__.__contains__('given') == True; 'after a given time'; verified with Python 3.14.3"]
    - [sleep_doc_has_completes, asyncio.sleep.__doc__.__contains__, ["completes"], true, "asyncio.sleep.__doc__.__contains__('completes') == True; 'Coroutine that completes'; verified with Python 3.14.3"]
    - [sleep_doc_no_delay,      asyncio.sleep.__doc__.__contains__, ["delay"],     false, "asyncio.sleep.__doc__.__contains__('delay') == False; 'delay' not in brief docstring; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Task __doc__ new-word contains checks — extra214
#
# asyncio.Task.__doc__ == 'A coroutine wrapped in a Future.'
# len == 32
# NEW (not in wave 379): 'wrap'==True, 'wrapped'==True
# ---------------------------------------------------------------------------

table asyncio_extra214.asyncio_task_doc_new_words:
  description: "asyncio.Task.__doc__ contains checks using words NOT in wave 379 — ae214task: 'wrap'==True ('A coroutine wrapped in a Future.'); 'wrapped'==True (same); wave 379 covered 'Task','result'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ae214task

  columns: [id, function, args, expected, description]
  rows:
    - [task_doc_has_wrap,    asyncio.Task.__doc__.__contains__, ["wrap"],    true,  "asyncio.Task.__doc__.__contains__('wrap') == True; 'A coroutine wrapped in a Future.'; verified with Python 3.14.3"]
    - [task_doc_has_wrapped, asyncio.Task.__doc__.__contains__, ["wrapped"], true,  "asyncio.Task.__doc__.__contains__('wrapped') == True; 'wrapped in a Future.'; verified with Python 3.14.3"]
    - [task_doc_no_schedule, asyncio.Task.__doc__.__contains__, ["schedule"], false, "asyncio.Task.__doc__.__contains__('schedule') == False; not in the 32-char docstring; verified with Python 3.14.3"]
    - [task_doc_len,         asyncio.Task.__doc__.__len__,      [],           32,    "asyncio.Task.__doc__.__len__() == 32; full doc: 'A coroutine wrapped in a Future.'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Queue __doc__ new-word contains checks — extra214
#
# asyncio.Queue.__doc__ (len=490) covers producer-consumer pattern
# NEW (not in wave 379): 'item'==True, 'put'==True, 'get'==True, 'consumer'==True
# ---------------------------------------------------------------------------

table asyncio_extra214.asyncio_queue_doc_new_words:
  description: "asyncio.Queue.__doc__ contains checks using words NOT in wave 379 — ae214queue: 'item'==True (items are put/gotten from queue); 'put'==True; 'get'==True; 'consumer'==True ('producer and consumer coroutines'); wave 379 covered 'Queue','maxsize'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ae214queue

  columns: [id, function, args, expected, description]
  rows:
    - [queue_doc_has_item,     asyncio.Queue.__doc__.__contains__, ["item"],     true, "asyncio.Queue.__doc__.__contains__('item') == True; items flow through the queue; verified with Python 3.14.3"]
    - [queue_doc_has_put,      asyncio.Queue.__doc__.__contains__, ["put"],      true, "asyncio.Queue.__doc__.__contains__('put') == True; 'await put()' mentioned in docstring; verified with Python 3.14.3"]
    - [queue_doc_has_get,      asyncio.Queue.__doc__.__contains__, ["get"],      true, "asyncio.Queue.__doc__.__contains__('get') == True; 'get()' method described in docstring; verified with Python 3.14.3"]
    - [queue_doc_has_consumer, asyncio.Queue.__doc__.__contains__, ["consumer"], true, "asyncio.Queue.__doc__.__contains__('consumer') == True; 'producer and consumer coroutines'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Lock __doc__ contains checks — extra214 (new object, not in wave 379)
#
# asyncio.Lock.__doc__ (len=1437): describes primitive lock synchronization
# 'lock'==True, 'primitive'==True, 'acquire'==True, 'unlocked'==True
# ---------------------------------------------------------------------------

table asyncio_extra214.asyncio_lock_doc_contains:
  description: "asyncio.Lock.__doc__ contains checks — ae214lock: new object not covered in wave 379; 'lock'==True; 'primitive'==True ('Primitive lock objects.'); 'acquire'==True; 'unlocked'==True ('locked or unlocked'); len==1437; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ae214lock

  columns: [id, function, args, expected, description]
  rows:
    - [lock_doc_has_lock,      asyncio.Lock.__doc__.__contains__, ["lock"],      true, "asyncio.Lock.__doc__.__contains__('lock') == True; 'Primitive lock objects.'; verified with Python 3.14.3"]
    - [lock_doc_has_primitive, asyncio.Lock.__doc__.__contains__, ["primitive"], true, "asyncio.Lock.__doc__.__contains__('primitive') == True; 'A primitive lock is a synchronization primitive'; verified with Python 3.14.3"]
    - [lock_doc_has_acquire,   asyncio.Lock.__doc__.__contains__, ["acquire"],   true, "asyncio.Lock.__doc__.__contains__('acquire') == True; acquire() method described; verified with Python 3.14.3"]
    - [lock_doc_has_unlocked,  asyncio.Lock.__doc__.__contains__, ["unlocked"],  true, "asyncio.Lock.__doc__.__contains__('unlocked') == True; 'locked or unlocked' states described; verified with Python 3.14.3"]
    - [lock_doc_len,           asyncio.Lock.__doc__.__len__,      [],            1437, "asyncio.Lock.__doc__.__len__() == 1437; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Semaphore __doc__ contains checks — extra214 (new object, not in wave 379)
#
# asyncio.Semaphore.__doc__ (len=494): internal counter decremented/incremented
# 'semaphore'==True, 'counter'==True, 'acquire'==True, 'release'==True
# ---------------------------------------------------------------------------

table asyncio_extra214.asyncio_semaphore_doc_contains:
  description: "asyncio.Semaphore.__doc__ contains checks — ae214sem: new object not covered in wave 379; 'semaphore'==True; 'counter'==True ('manages an internal counter'); 'acquire'==True; 'release'==True; len==494; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ae214sem

  columns: [id, function, args, expected, description]
  rows:
    - [sem_doc_has_semaphore, asyncio.Semaphore.__doc__.__contains__, ["semaphore"], true, "asyncio.Semaphore.__doc__.__contains__('semaphore') == True; 'A Semaphore implementation.'; verified with Python 3.14.3"]
    - [sem_doc_has_counter,   asyncio.Semaphore.__doc__.__contains__, ["counter"],   true, "asyncio.Semaphore.__doc__.__contains__('counter') == True; 'manages an internal counter'; verified with Python 3.14.3"]
    - [sem_doc_has_acquire,   asyncio.Semaphore.__doc__.__contains__, ["acquire"],   true, "asyncio.Semaphore.__doc__.__contains__('acquire') == True; 'decremented by each acquire() call'; verified with Python 3.14.3"]
    - [sem_doc_has_release,   asyncio.Semaphore.__doc__.__contains__, ["release"],   true, "asyncio.Semaphore.__doc__.__contains__('release') == True; 'incremented by each release() call'; verified with Python 3.14.3"]
    - [sem_doc_len,           asyncio.Semaphore.__doc__.__len__,      [],            494,  "asyncio.Semaphore.__doc__.__len__() == 494; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra214
# ---------------------------------------------------------------------------

invariant asyncio_extra214.lock_doc_has_primitive:
  description: "asyncio.Lock.__doc__.__contains__('primitive') returns True — asyncio.Lock.__doc__ opens with 'Primitive lock objects.' and also contains 'A primitive lock is a synchronization primitive that is not owned by a particular task when locked.' (len=1437); new word not used for asyncio.Lock in wave 379; Lock not covered in wave 379 at all; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Lock.__doc__.__contains__
  args: ["primitive"]
  expected: true

invariant asyncio_extra214.semaphore_doc_has_counter:
  description: "asyncio.Semaphore.__doc__.__contains__('counter') returns True — asyncio.Semaphore.__doc__ states 'A semaphore manages an internal counter which is decremented by each acquire() call and incremented by each release() call.' (len=494); Semaphore not covered in wave 379; counter tracks permits/slots available; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Semaphore.__doc__.__contains__
  args: ["counter"]
  expected: true

invariant asyncio_extra214.queue_doc_has_consumer:
  description: "asyncio.Queue.__doc__.__contains__('consumer') returns True — asyncio.Queue.__doc__ opens with 'A queue, useful for coordinating producer and consumer coroutines.' (len=490); 'consumer' not used for asyncio.Queue in wave 379 (wave 379 used 'Queue','maxsize'); this new word deepens coverage of the Queue docstring; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Queue.__doc__.__contains__
  args: ["consumer"]
  expected: true

invariant asyncio_extra214.sleep_doc_has_completes:
  description: "asyncio.sleep.__doc__.__contains__('completes') returns True — asyncio.sleep.__doc__ is 'Coroutine that completes after a given time (in seconds).' (len=57); 'completes' not used for asyncio.sleep in wave 379 (wave 379 used 'seconds','Coroutine'); 'delay' is False (not in the short docstring); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.sleep.__doc__.__contains__
  args: ["completes"]
  expected: true

