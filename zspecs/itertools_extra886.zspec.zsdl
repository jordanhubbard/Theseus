spec: itertools_extra886
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "Python standard library itertools module"
    - "CPython source: Modules/itertoolsmodule.c"
  not_derived_from:
    - "any third-party itertools extension"
    - "more-itertools or similar packages"
  notes:
    - "Covers __iter__ and __next__ qualname checks for C-implemented itertools iterator types"
    - "All covered types are C extension types whose iterator methods expose __qualname__"
    - "qualnames follow the pattern '<ClassName>.__iter__' and '<ClassName>.__next__'"
  created_at: "2026-04-12"

table itertools_extra886.count_protocol:
  description: "Verify __iter__ and __next__ qualnames for itertools.count"
  kind: python_call_eq
  category: iterator_protocol
  id_prefix: it886co
  columns: [id, function, args, expected]
  rows:
    - [it886co001, itertools.count.__iter__.__qualname__.__eq__, ["count.__iter__"], true]
    - [it886co002, itertools.count.__next__.__qualname__.__eq__, ["count.__next__"], true]

