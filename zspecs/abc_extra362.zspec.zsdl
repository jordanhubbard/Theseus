spec: abc_extra362
version: ">=3.9"
backend: python_module(collections.abc)
docs: https://docs.python.org/3/library/collections.abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc ABCs documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "All ABCs in this spec live in module collections.abc"
    - "MutableSequence derives from Sequence"
    - "MutableMapping derives from Mapping"
    - "MutableSet derives from Set"
    - "Sized and Container both derive directly from object"
    - "Collection has three bases: Sized, Iterable, Container; __bases__[0] is Sized"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra362.abc_names:
  description: "Verify __name__ attribute of collections.abc mutable and sized ABCs"
  kind: python_call_eq
  category: identity
  id_prefix: abc362n

  columns: [id, function, args, expected]
  rows:
    - [abc362n001, collections.abc.MutableSequence.__name__.__eq__, ["MutableSequence"], true]
    - [abc362n002, collections.abc.MutableMapping.__name__.__eq__, ["MutableMapping"], true]
    - [abc362n003, collections.abc.MutableSet.__name__.__eq__, ["MutableSet"], true]
    - [abc362n004, collections.abc.Sized.__name__.__eq__, ["Sized"], true]
    - [abc362n005, collections.abc.Container.__name__.__eq__, ["Container"], true]
    - [abc362n006, collections.abc.Collection.__name__.__eq__, ["Collection"], true]

table abc_extra362.abc_modules:
  description: "Verify __module__ attribute of collections.abc mutable and sized ABCs"
  kind: python_call_eq
  category: identity
  id_prefix: abc362m

  columns: [id, function, args, expected]
  rows:
    - [abc362m001, collections.abc.MutableSequence.__module__.__eq__, ["collections.abc"], true]
    - [abc362m002, collections.abc.MutableMapping.__module__.__eq__, ["collections.abc"], true]
    - [abc362m003, collections.abc.MutableSet.__module__.__eq__, ["collections.abc"], true]
    - [abc362m004, collections.abc.Sized.__module__.__eq__, ["collections.abc"], true]
    - [abc362m005, collections.abc.Container.__module__.__eq__, ["collections.abc"], true]
    - [abc362m006, collections.abc.Collection.__module__.__eq__, ["collections.abc"], true]

table abc_extra362.abc_bases:
  description: "Verify __bases__[0].__name__ (first immediate base class name) of collections.abc mutable and sized ABCs"
  kind: python_call_eq
  category: identity
  id_prefix: abc362b

  columns: [id, function, args, expected]
  rows:
    - ["abc362b001", "collections.abc.MutableSequence.__bases__[0].__name__.__eq__", ["Sequence"], true]
    - ["abc362b002", "collections.abc.MutableMapping.__bases__[0].__name__.__eq__", ["Mapping"], true]
    - ["abc362b003", "collections.abc.MutableSet.__bases__[0].__name__.__eq__", ["Set"], true]
    - ["abc362b004", "collections.abc.Sized.__bases__[0].__name__.__eq__", ["object"], true]
    - ["abc362b005", "collections.abc.Container.__bases__[0].__name__.__eq__", ["object"], true]
    - ["abc362b006", "collections.abc.Collection.__bases__[0].__name__.__eq__", ["Sized"], true]
