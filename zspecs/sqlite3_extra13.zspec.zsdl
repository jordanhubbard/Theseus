spec: sqlite3_extra13
version: ">=3.9"
backend: python_module(sqlite3)

docs: https://docs.python.org/3/library/sqlite3.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sqlite3.html — Python sqlite3 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sqlite3/__init__.py"
    - "CPython source: Modules/_sqlite/module.c"
    - "CPython source: Modules/_sqlite/connection.c"
  notes:
    - "This spec extends sqlite3.zspec.zsdl and prior extras through sqlite3_extra12.zspec.zsdl."
    - "sqlite3_extra12 covers: paramstyle value/class_name; version class_name; Warning/InterfaceError/ProgrammingError __name__; Error/DatabaseError __module__; connect __qualname__; Row.__name__."
    - "sqlite3_extra11 covers: sqlite_version class_name; apilevel value/class_name; threadsafety class_name/ge1; exception __name__ table (Error/DatabaseError/IntegrityError/OperationalError/NotSupportedError); sqlite_version_info class_name/len."
    - "sqlite3_extra10 covers: Connection/Cursor/Row __class__.__name__ == 'type'; connect __class__.__name__ == 'builtin_function_or_method'."
    - "sqlite3_extra9 covers: SQLITE_ABORT/SQLITE_CONSTRAINT/SQLITE_RANGE; complete_statement __name__/__module__; DatabaseError/Error MRO[1]; PARSE_DECLTYPES/PARSE_COLNAMES type; version/__len__."
    - "sqlite3_extra8 covers: SQLITE_BUSY/SQLITE_LOCKED/SQLITE_MISUSE/SQLITE_NOTADB; connect/__name__/__module__; Warning/__name__/__module__."
    - "Focus: new axes — in-memory Connection object attributes; sqlite_version/version_info bounds; version_info type/len."
    - "sqlite3.connect(':memory:').__class__.__name__ == 'Connection' — Connection class identity via invariant with method_chain."
    - "sqlite3.connect(':memory:').in_transaction == False — a freshly opened connection has no active transaction."
    - "sqlite3.connect(':memory:').total_changes == 0 — no changes have been made on a new connection."
    - "sqlite3.sqlite_version.__class__.__name__ == 'str' — sqlite_version is a string; extra11 checks class_name in a different way."
    - "sqlite3.sqlite_version.__len__() >= 5 — shortest plausible version strings like '3.7.0' are 5 chars."
    - "sqlite3.version.__len__() >= 5 — Python wrapper version string also at least 5 chars (e.g. '2.6.0')."
    - "sqlite3.sqlite_version_info.__class__.__name__ == 'tuple' — sqlite_version_info is a tuple."
    - "sqlite3.sqlite_version_info.__len__() == 3 — tuple is (major, minor, patch)."
    - "sqlite3.version_info.__class__.__name__ == 'tuple' — version_info for the Python wrapper is also a tuple."
    - "sqlite3.version_info.__len__() == 3 — Python wrapper version_info is (major, minor, patch)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# In-memory Connection object attributes
#
# No prior sqlite3 spec tests attributes of a live Connection object returned
# by connect(':memory:'). The invariant block uses method_chain to traverse
# the attribute chain on the returned connection object.
# ---------------------------------------------------------------------------

invariant sqlite3_extra13.connect.class_name:
  description: "sqlite3.connect(':memory:').__class__.__name__ == 'Connection'"
  category: connection_attrs
  kind: python_call_eq
  function: connect
  args: [":memory:"]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["Connection"]
  expected: true

invariant sqlite3_extra13.connect.not_in_transaction:
  description: "sqlite3.connect(':memory:').in_transaction == False — no active transaction on new connection"
  category: connection_attrs
  kind: python_call_eq
  function: connect
  args: [":memory:"]
  method: in_transaction.__eq__
  method_args: [false]
  expected: true

invariant sqlite3_extra13.connect.total_changes_zero:
  description: "sqlite3.connect(':memory:').total_changes == 0 — no changes on a fresh connection"
  category: connection_attrs
  kind: python_call_eq
  function: connect
  args: [":memory:"]
  method: total_changes.__eq__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.sqlite_version — type and length
#
# sqlite3_extra11 checks sqlite_version.__class__.__name__ via a table row.
# No prior spec checks sqlite_version.__len__() or version.__len__() as
# lower-bound invariants (extra9 checks version.__len__ but as exact or
# specific value; this spec adds __ge__ variants for forward-compatibility).
# ---------------------------------------------------------------------------

invariant sqlite3_extra13.sqlite_version.class_name:
  description: "sqlite3.sqlite_version.__class__.__name__ == 'str' — sqlite_version is a string"
  category: module_attrs
  kind: python_call_eq
  function: sqlite_version.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant sqlite3_extra13.sqlite_version.len_ge5:
  description: "sqlite3.sqlite_version.__len__() >= 5 — version string is at least 5 chars (e.g. '3.7.0')"
  category: module_attrs
  kind: python_call_eq
  function: sqlite_version.__len__.__ge__
  args: [5]
  expected: true

invariant sqlite3_extra13.version.len_ge5:
  description: "sqlite3.version.__len__() >= 5 — Python wrapper version string is at least 5 chars (e.g. '2.6.0')"
  category: module_attrs
  kind: python_call_eq
  function: version.__len__.__ge__
  args: [5]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.sqlite_version_info and sqlite3.version_info — type and length
#
# sqlite3_extra11 checks sqlite_version_info.__class__.__name__ and __len__.
# No prior spec checks version_info (the Python wrapper's version_info tuple)
# for __class__.__name__ or __len__.
# ---------------------------------------------------------------------------

invariant sqlite3_extra13.sqlite_version_info.class_name:
  description: "sqlite3.sqlite_version_info.__class__.__name__ == 'tuple' — sqlite_version_info is a tuple"
  category: module_attrs
  kind: python_call_eq
  function: sqlite_version_info.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant sqlite3_extra13.sqlite_version_info.len:
  description: "sqlite3.sqlite_version_info.__len__() == 3 — tuple is (major, minor, patch)"
  category: module_attrs
  kind: python_call_eq
  function: sqlite_version_info.__len__.__eq__
  args: [3]
  expected: true

invariant sqlite3_extra13.version_info.class_name:
  description: "sqlite3.version_info.__class__.__name__ == 'tuple' — Python wrapper version_info is a tuple"
  category: module_attrs
  kind: python_call_eq
  function: version_info.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant sqlite3_extra13.version_info.len:
  description: "sqlite3.version_info.__len__() == 3 — Python wrapper version_info is (major, minor, patch)"
  category: module_attrs
  kind: python_call_eq
  function: version_info.__len__.__eq__
  args: [3]
  expected: true
