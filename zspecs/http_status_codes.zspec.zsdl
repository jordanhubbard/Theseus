spec: http_status_codes
version: ">=2.0.0"
backend: node(http-status-codes)

docs: https://github.com/prettymuchbryce/http-status-codes#readme

provenance:
  derived_from:
    - "http-status-codes README — https://github.com/prettymuchbryce/http-status-codes#readme"
    - "RFC 9110 §15 — HTTP Status Codes"
    - "Test vectors verified with http-status-codes via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "http-status-codes source"
  notes:
    - "Constants and lookup helpers for HTTP status codes — StatusCodes / ReasonPhrases enums + getStatusCode / getReasonPhrase / getStatusText."
    - "Install: npm install http-status-codes"
    - "v2 CJS; named exports."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws on unknown phrase/code lookups."
  stderr: "null"
  stickiness: "N/A — read-only data."
  codes: {}

invariant http_status_codes.has_StatusCodes:
  description: "StatusCodes enum object exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "StatusCodes.constructor.name"}
  expected: "Object"

invariant http_status_codes.StatusCodes_OK:
  description: "StatusCodes.OK is 200"
  category: enum
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "StatusCodes.OK"}
  expected: 200

invariant http_status_codes.StatusCodes_NOT_FOUND:
  description: "StatusCodes.NOT_FOUND is 404"
  category: enum
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "StatusCodes.NOT_FOUND"}
  expected: 404

invariant http_status_codes.getReasonPhrase_200:
  description: "getReasonPhrase(200) is 'OK'"
  category: lookup
  kind: node_chain_eq
  entry: named
  function: getReasonPhrase
  entry_args: [200]
  chain: []
  expected: "OK"

invariant http_status_codes.getReasonPhrase_404:
  description: "getReasonPhrase(404) is 'Not Found'"
  category: lookup
  kind: node_chain_eq
  entry: named
  function: getReasonPhrase
  entry_args: [404]
  chain: []
  expected: "Not Found"

invariant http_status_codes.getStatusCode_OK:
  description: "getStatusCode('OK') is 200"
  category: lookup
  kind: node_chain_eq
  entry: named
  function: getStatusCode
  entry_args: ["OK"]
  chain: []
  expected: 200

invariant http_status_codes.getStatusCode_NOT_FOUND:
  description: "getStatusCode('Not Found') is 404"
  category: lookup
  kind: node_chain_eq
  entry: named
  function: getStatusCode
  entry_args: ["Not Found"]
  chain: []
  expected: 404

invariant http_status_codes.has_ACCEPTED_top_level:
  description: "ACCEPTED is exported at the top level (alias of StatusCodes.ACCEPTED)"
  category: enum
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: ACCEPTED}
  expected: 202
