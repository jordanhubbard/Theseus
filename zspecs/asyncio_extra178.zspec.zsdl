spec: asyncio_extra178
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-queue.html — Python asyncio Queue documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "This spec covers: asyncio.Queue method names — asyncio.Queue.put.__name__=='put' (len=3); asyncio.Queue.get.__name__=='get' (len=3; same as put); asyncio.Queue.put_nowait.__name__=='put_nowait' (len=10); asyncio.Queue.get_nowait.__name__=='get_nowait' (len=10; same as put_nowait); asyncio.Queue.empty.__name__=='empty' (len=5); asyncio.Queue.full.__name__=='full' (len=4); asyncio.Queue.qsize.__name__=='qsize' (len=5; same as empty); asyncio.Queue.task_done.__name__=='task_done' (len=9); asyncio.Queue.join.__name__=='join' (len=4; same as full). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Queue.put.__name__ == 'put' (len=3: p-u-t). asyncio.Queue.get.__name__ == 'get' (len=3: g-e-t). Both put and get have the same name length of 3, as they are the symmetric producer/consumer methods of the queue. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Queue.put_nowait.__name__ == 'put_nowait' (len=10: 'put'=3+'_nowait'=7=10). asyncio.Queue.get_nowait.__name__ == 'get_nowait' (len=10: 'get'=3+'_nowait'=7=10). Both nowait variants have the same length of 10. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Queue.empty.__name__ == 'empty' (len=5: e-m-p-t-y). asyncio.Queue.full.__name__ == 'full' (len=4: f-u-l-l). asyncio.Queue.qsize.__name__ == 'qsize' (len=5: q-s-i-z-e; same as empty). NAME LENGTHS: full=4 < empty=qsize=5. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Queue.task_done.__name__ == 'task_done' (len=9: 'task'=4+'_done'=5=9). asyncio.Queue.join.__name__ == 'join' (len=4: j-o-i-n; same as full). task_done() marks a task as done after a consumer retrieves and processes an item; join() blocks until all tasks are done. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.Queue.put and asyncio.Queue.get __name__ identity
#
# asyncio.Queue.put.__name__ == 'put' (len=3)
# asyncio.Queue.get.__name__ == 'get' (len=3; same as put)
#
# put() and get() are the primary producer/consumer coroutines of asyncio.Queue.
# put(item) adds an item to the queue; get() removes and returns an item.
# Both names have length 3 as they are symmetric short method names.
# New to extra178.
# ---------------------------------------------------------------------------

table asyncio_extra178.queue_put_get_names:
  description: "asyncio.Queue.put.__name__ 'put' len 3; asyncio.Queue.get.__name__ 'get' len 3 (same); new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioqueue178

  columns: [id, function, args, expected, description]
  rows:
    - [put_name_eq,
       asyncio.Queue.put.__name__.__eq__,
       ["put"],
       true,
       "asyncio.Queue.put.__name__.__eq__('put') == True — asyncio.Queue.put(item) is a coroutine that puts an item into the queue; blocks until a free slot is available if the queue is full; its __name__ is 'put' (3 chars: p-u-t); str.__eq__('put') returns True; new to extra178"]
    - [put_name_len_3,
       asyncio.Queue.put.__name__.__len__,
       [],
       3,
       "asyncio.Queue.put.__name__.__len__() == 3 — 'put' has exactly 3 characters: p-u-t; same length as 'get'=3; shortest method names on asyncio.Queue alongside get and join; str.__len__() returns 3; new to extra178"]
    - [get_name_eq,
       asyncio.Queue.get.__name__.__eq__,
       ["get"],
       true,
       "asyncio.Queue.get.__name__.__eq__('get') == True — asyncio.Queue.get() is a coroutine that removes and returns an item from the queue; blocks until an item is available if the queue is empty; its __name__ is 'get' (3 chars: g-e-t); str.__eq__('get') returns True; new to extra178"]
    - [get_name_len_3,
       asyncio.Queue.get.__name__.__len__,
       [],
       3,
       "asyncio.Queue.get.__name__.__len__() == 3 — 'get' has exactly 3 characters: g-e-t; same length as 'put'=3; put and get are symmetric producer/consumer methods; str.__len__() returns 3; new to extra178"]
    - [put_get_same_len,
       asyncio.Queue.put.__name__.__len__,
       [],
       3,
       "asyncio.Queue.put.__name__.__len__() == 3 confirming put and get share name length 3; both 'put' and 'get' are exactly 3 chars; they are the symmetric asyncio Queue I/O coroutines; new to extra178"]

# ---------------------------------------------------------------------------
# Table 2: asyncio.Queue nowait variant __name__ identity
#
# asyncio.Queue.put_nowait.__name__ == 'put_nowait' (len=10)
# asyncio.Queue.get_nowait.__name__ == 'get_nowait' (len=10; same as put_nowait)
# asyncio.Queue.empty.__name__ == 'empty' (len=5)
# asyncio.Queue.full.__name__ == 'full' (len=4)
# asyncio.Queue.qsize.__name__ == 'qsize' (len=5; same as empty)
#
# put_nowait and get_nowait are non-blocking synchronous alternatives that raise
# QueueFull or QueueEmpty if the operation cannot complete immediately.
# NAME LENGTHS: full=4 < empty=qsize=5 < put_nowait=get_nowait=10.
# New to extra178.
# ---------------------------------------------------------------------------

table asyncio_extra178.queue_nowait_and_state_names:
  description: "put_nowait.__name__ 'put_nowait' len 10; get_nowait.__name__ 'get_nowait' len 10 (same); empty.__name__ 'empty' len 5; full.__name__ 'full' len 4; qsize.__name__ 'qsize' len 5; new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioqueue178

  columns: [id, function, args, expected, description]
  rows:
    - [put_nowait_name_eq,
       asyncio.Queue.put_nowait.__name__.__eq__,
       ["put_nowait"],
       true,
       "asyncio.Queue.put_nowait.__name__.__eq__('put_nowait') == True — asyncio.Queue.put_nowait(item) is a synchronous method that puts an item into the queue without blocking; raises QueueFull if no free slot is available; its __name__ is 'put_nowait' (10 chars: 'put'=3+'_nowait'=7=10); str.__eq__('put_nowait') returns True; new to extra178"]
    - [put_nowait_name_len_10,
       asyncio.Queue.put_nowait.__name__.__len__,
       [],
       10,
       "asyncio.Queue.put_nowait.__name__.__len__() == 10 — 'put_nowait' has 10 characters: 'put'=3+'_nowait'=7=10; same length as 'get_nowait'=10; str.__len__() returns 10; new to extra178"]
    - [get_nowait_name_eq,
       asyncio.Queue.get_nowait.__name__.__eq__,
       ["get_nowait"],
       true,
       "asyncio.Queue.get_nowait.__name__.__eq__('get_nowait') == True — asyncio.Queue.get_nowait() is a synchronous method that removes and returns an item without blocking; raises QueueEmpty if no item is available; its __name__ is 'get_nowait' (10 chars: 'get'=3+'_nowait'=7=10); str.__eq__('get_nowait') returns True; new to extra178"]
    - [get_nowait_name_len_10,
       asyncio.Queue.get_nowait.__name__.__len__,
       [],
       10,
       "asyncio.Queue.get_nowait.__name__.__len__() == 10 — 'get_nowait' has 10 characters: 'get'=3+'_nowait'=7=10; same length as 'put_nowait'=10; both nowait variants share name length 10; str.__len__() returns 10; new to extra178"]
    - [empty_name_eq,
       asyncio.Queue.empty.__name__.__eq__,
       ["empty"],
       true,
       "asyncio.Queue.empty.__name__.__eq__('empty') == True — asyncio.Queue.empty() returns True if the queue is empty; it is a synchronous predicate method; its __name__ is 'empty' (5 chars: e-m-p-t-y); str.__eq__('empty') returns True; new to extra178"]
    - [empty_name_len_5,
       asyncio.Queue.empty.__name__.__len__,
       [],
       5,
       "asyncio.Queue.empty.__name__.__len__() == 5 — 'empty' has 5 characters: e-m-p-t-y; same length as 'qsize'=5; NAME LENGTHS: full=4 < empty=qsize=5 < put_nowait=get_nowait=10; str.__len__() returns 5; new to extra178"]
    - [full_name_eq,
       asyncio.Queue.full.__name__.__eq__,
       ["full"],
       true,
       "asyncio.Queue.full.__name__.__eq__('full') == True — asyncio.Queue.full() returns True if the queue is full; meaningful only when maxsize>0; its __name__ is 'full' (4 chars: f-u-l-l); str.__eq__('full') returns True; new to extra178"]
    - [full_name_len_4,
       asyncio.Queue.full.__name__.__len__,
       [],
       4,
       "asyncio.Queue.full.__name__.__len__() == 4 — 'full' has 4 characters: f-u-l-l; same length as 'join'=4; shortest state-query method name in this spec; NAME LENGTHS: full=join=4 < empty=qsize=5; str.__len__() returns 4; new to extra178"]

# ---------------------------------------------------------------------------
# Table 3: asyncio.Queue.qsize, task_done, and join __name__ identity
#
# asyncio.Queue.qsize.__name__ == 'qsize' (len=5; same as empty)
# asyncio.Queue.task_done.__name__ == 'task_done' (len=9)
# asyncio.Queue.join.__name__ == 'join' (len=4; same as full)
#
# qsize() returns the number of items in the queue. task_done() signals that
# a formerly enqueued task is complete. join() blocks until all items in the
# queue have been gotten and task_done() called for each one.
# NAME LENGTHS: join=4 < qsize=5 < task_done=9. New to extra178.
# ---------------------------------------------------------------------------

table asyncio_extra178.queue_qsize_task_done_join_names:
  description: "qsize.__name__ 'qsize' len 5; task_done.__name__ 'task_done' len 9; join.__name__ 'join' len 4; new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioqueue178

  columns: [id, function, args, expected, description]
  rows:
    - [qsize_name_eq,
       asyncio.Queue.qsize.__name__.__eq__,
       ["qsize"],
       true,
       "asyncio.Queue.qsize.__name__.__eq__('qsize') == True — asyncio.Queue.qsize() returns the number of items currently in the queue; it is a synchronous method; its __name__ is 'qsize' (5 chars: q-s-i-z-e); same length as 'empty'=5; str.__eq__('qsize') returns True; new to extra178"]
    - [qsize_name_len_5,
       asyncio.Queue.qsize.__name__.__len__,
       [],
       5,
       "asyncio.Queue.qsize.__name__.__len__() == 5 — 'qsize' has 5 characters: q-s-i-z-e; same length as 'empty'=5; NAME LENGTHS: full=join=4 < qsize=empty=5 < task_done=9; str.__len__() returns 5; new to extra178"]
    - [task_done_name_eq,
       asyncio.Queue.task_done.__name__.__eq__,
       ["task_done"],
       true,
       "asyncio.Queue.task_done.__name__.__eq__('task_done') == True — asyncio.Queue.task_done() signals that a formerly enqueued task is complete; called by consumer coroutines after processing each item; its __name__ is 'task_done' (9 chars: 'task'=4+'_done'=5=9); str.__eq__('task_done') returns True; new to extra178"]
    - [task_done_name_len_9,
       asyncio.Queue.task_done.__name__.__len__,
       [],
       9,
       "asyncio.Queue.task_done.__name__.__len__() == 9 — 'task_done' has 9 characters: 'task'=4+'_done'=5=9; longest method name in table 3 (join=4 < qsize=5 < task_done=9); str.__len__() returns 9; new to extra178"]
    - [join_name_eq,
       asyncio.Queue.join.__name__.__eq__,
       ["join"],
       true,
       "asyncio.Queue.join.__name__.__eq__('join') == True — asyncio.Queue.join() is a coroutine that blocks until all items in the queue have been received and task_done() called; its __name__ is 'join' (4 chars: j-o-i-n); same length as 'full'=4; str.__eq__('join') returns True; new to extra178"]
    - [join_name_len_4,
       asyncio.Queue.join.__name__.__len__,
       [],
       4,
       "asyncio.Queue.join.__name__.__len__() == 4 — 'join' has 4 characters: j-o-i-n; same length as 'full'=4; both join and full have the shortest names (4 chars) among Queue methods; str.__len__() returns 4; new to extra178"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra178
# ---------------------------------------------------------------------------

invariant asyncio_extra178.queue_put_name_put:
  description: "asyncio.Queue.put.__name__ == 'put' — primary producer coroutine; __name__ is 'put' (3 chars: p-u-t); same length as get (3); new to extra178"
  category: identity
  kind: python_call_eq
  function: asyncio.Queue.put.__name__.__eq__
  args: ["put"]
  expected: true

invariant asyncio_extra178.queue_get_name_len_3:
  description: "asyncio.Queue.get.__name__.__len__() == 3 — 'get' has 3 chars; same as put (3); shortest Queue method names; new to extra178"
  category: identity
  kind: python_call_eq
  function: asyncio.Queue.get.__name__.__len__
  args: []
  expected: 3

invariant asyncio_extra178.queue_put_nowait_name_len_10:
  description: "asyncio.Queue.put_nowait.__name__.__len__() == 10 — 'put_nowait' has 10 chars ('put'=3+'_nowait'=7=10); same as get_nowait (10); new to extra178"
  category: identity
  kind: python_call_eq
  function: asyncio.Queue.put_nowait.__name__.__len__
  args: []
  expected: 10

invariant asyncio_extra178.queue_get_nowait_name_eq:
  description: "asyncio.Queue.get_nowait.__name__ == 'get_nowait' — non-blocking get; raises QueueEmpty if empty; __name__ len=10 ('get'=3+'_nowait'=7=10); same len as put_nowait; new to extra178"
  category: identity
  kind: python_call_eq
  function: asyncio.Queue.get_nowait.__name__.__eq__
  args: ["get_nowait"]
  expected: true

invariant asyncio_extra178.queue_empty_name_len_5:
  description: "asyncio.Queue.empty.__name__.__len__() == 5 — 'empty' has 5 chars (e-m-p-t-y); same as qsize (5); both state predicates have len 5; new to extra178"
  category: identity
  kind: python_call_eq
  function: asyncio.Queue.empty.__name__.__len__
  args: []
  expected: 5

invariant asyncio_extra178.queue_full_name_len_4:
  description: "asyncio.Queue.full.__name__.__len__() == 4 — 'full' has 4 chars (f-u-l-l); same as join (4); shortest Queue method names; new to extra178"
  category: identity
  kind: python_call_eq
  function: asyncio.Queue.full.__name__.__len__
  args: []
  expected: 4

invariant asyncio_extra178.queue_task_done_name_eq:
  description: "asyncio.Queue.task_done.__name__ == 'task_done' — signals task completion; used with join(); __name__ len=9 ('task'=4+'_done'=5=9); new to extra178"
  category: identity
  kind: python_call_eq
  function: asyncio.Queue.task_done.__name__.__eq__
  args: ["task_done"]
  expected: true

invariant asyncio_extra178.queue_join_name_join:
  description: "asyncio.Queue.join.__name__ == 'join' — coroutine that blocks until all tasks are done; __name__ is 'join' (4 chars: j-o-i-n); same len as full (4); new to extra178"
  category: identity
  kind: python_call_eq
  function: asyncio.Queue.join.__name__.__eq__
  args: ["join"]
  expected: true
