spec: obj_flatten
version: ">=2.0.7"
backend: node(obj-flatten)

docs: https://www.npmjs.com/package/obj-flatten

provenance:
  derived_from:
    - "obj-flatten README — https://www.npmjs.com/package/obj-flatten"
    - "Test vectors verified with obj-flatten via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "obj-flatten source"
  notes:
    - "obj-flatten is an npm package. Install: npm install obj-flatten"
    - "Flattens a nested object into dot-notation keys."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a flat object with dot-notation keys."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table obj_flatten.flatten:
  kind: node_module_call_eq
  function: ~
  category: object
  id_prefix: objfl

  columns: [id, args, expected]
  rows:
    - [two_level,   [{"a": {"b": 1, "c": 2}}],   {"a.b": 1, "a.c": 2}]
    - [three_level, [{"a": {"b": {"c": 3}}}],     {"a.b.c": 3}]
    - [flat,        [{"x": 1, "y": 2}],           {"x": 1, "y": 2}]
