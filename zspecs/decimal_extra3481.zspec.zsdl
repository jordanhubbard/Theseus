  notes:
    - "Wave 679 (dc3481): __enter__, __exit__, __call__ dict-presence checks for decimal types."
    - "Classes covered: decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow."
    - "Theme: __enter__/__exit__/__call__ dict-presence (context manager / callable protocol)."
    - "No decimal class defines __enter__ in its own __dict__: decimal types are numeric and exception types, not context managers."
    - "No decimal class defines __exit__ in its own __dict__: decimal types do not implement the context manager exit protocol."
    - "No decimal class defines __call__ in its own __dict__: decimal types are not callable objects."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Consistent with prior waves: all context manager and callable protocols absent from decimal class __dict__s."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __enter__ dict-presence — operator.contains(Cls.__dict__, '__enter__')
#
# No decimal class defines __enter__ in its own __dict__; all false.
# decimal.Decimal is a numeric type; decimal.Context is a precision/rounding
# configuration object; the exception subclasses are error types.
# None are context managers.
# ---------------------------------------------------------------------------

table dc3481.enter:
  description: "decimal types __enter__ dict-presence checks; wave 679"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3481

  columns: [id, function, args, expected]
  rows:
    - ["dc3481001", operator.contains, [decimal.Decimal.__dict__,          "__enter__"], false]
    - ["dc3481002", operator.contains, [decimal.Context.__dict__,           "__enter__"], false]
    - ["dc3481003", operator.contains, [decimal.DecimalException.__dict__,  "__enter__"], false]
    - ["dc3481004", operator.contains, [decimal.InvalidOperation.__dict__,  "__enter__"], false]
    - ["dc3481005", operator.contains, [decimal.Overflow.__dict__,          "__enter__"], false]
    - ["dc3481006", operator.contains, [decimal.Underflow.__dict__,         "__enter__"], false]

# ---------------------------------------------------------------------------
