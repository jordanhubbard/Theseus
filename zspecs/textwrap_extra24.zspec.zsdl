spec: textwrap_extra24
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
  notes:
    - "This spec extends textwrap.zspec.zsdl and prior extras through textwrap_extra23.zspec.zsdl."
    - "textwrap_extra14 covers: TextWrapper.__qualname__ == 'TextWrapper' standalone invariant."
    - "textwrap_extra17 covers: wrap/fill/dedent/indent/shorten __qualname__ standalone invariants and table."
    - "textwrap_extra22 covers: wrap/fill/dedent/indent/shorten __qualname__ (extra22 anchor); TextWrapper.wrap/fill/__qualname__; TextWrapper.__qualname__."
    - "textwrap_extra23 covers: TextWrapper._wrap_chunks/_split/_split_chunks/__repr__/__init__ __qualname__."
    - "No prior spec covers TextWrapper.__module__ as a standalone invariant."
    - "No prior spec covers TextWrapper.__bases__[0].__name__ as a standalone invariant."
    - "No prior spec covers wrap/__module__, fill/__module__, dedent/__module__, indent/__module__, or shorten/__module__ as standalone invariants."
    - "No prior spec covers TextWrapper._handle_long_word.__qualname__ or TextWrapper._munge_whitespace.__qualname__ as standalone invariants."
    - "textwrap.TextWrapper.__module__ == 'textwrap' — class is defined in the textwrap module. Verified at runtime."
    - "textwrap.TextWrapper.__bases__[0].__name__ == 'object' — TextWrapper directly inherits from object. Verified at runtime."
    - "textwrap.wrap.__module__ == 'textwrap' — module-level function defined in textwrap. Verified at runtime."
    - "textwrap.fill.__module__ == 'textwrap' — module-level function defined in textwrap. Verified at runtime."
    - "textwrap.dedent.__module__ == 'textwrap' — module-level function defined in textwrap. Verified at runtime."
    - "textwrap.indent.__module__ == 'textwrap' — module-level function defined in textwrap. Verified at runtime."
    - "textwrap.shorten.__module__ == 'textwrap' — module-level function defined in textwrap. Verified at runtime."
    - "textwrap.TextWrapper._handle_long_word.__qualname__ == 'TextWrapper._handle_long_word' — private method qualname includes owning class. Verified at runtime."
    - "textwrap.TextWrapper._munge_whitespace.__qualname__ == 'TextWrapper._munge_whitespace' — private method qualname includes owning class. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# textwrap.TextWrapper — __module__
#
# textwrap_extra14 covers TextWrapper.__qualname__ == 'TextWrapper'. No prior
# spec verifies TextWrapper.__module__ as a standalone invariant. TextWrapper
# is defined in the textwrap module, so __module__ == 'textwrap'.
# Verified at runtime: 'textwrap'.
# ---------------------------------------------------------------------------

invariant textwrap_extra24.TextWrapper.module:
  description: "textwrap.TextWrapper.__module__ == 'textwrap' — class is defined in the textwrap module"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper.__module__.__eq__
  args: ["textwrap"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.TextWrapper — __bases__[0].__name__
#
# No prior spec verifies TextWrapper.__bases__[0].__name__ as a standalone
# invariant. TextWrapper has no explicit base class other than object, so
# __bases__[0].__name__ == 'object'. Verified at runtime: 'object'.
# ---------------------------------------------------------------------------

invariant textwrap_extra24.TextWrapper.base_name:
  description: "textwrap.TextWrapper.__bases__[0].__name__ == 'object' — TextWrapper directly inherits from object"
  category: class_identity
  kind: python_call_eq
  function: "TextWrapper.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.wrap — __module__
#
# textwrap_extra17/extra22 cover wrap.__qualname__ == 'wrap'. No prior spec
# verifies wrap.__module__ as a standalone invariant. wrap is a module-level
# function defined in textwrap, so __module__ == 'textwrap'.
# Verified at runtime: 'textwrap'.
# ---------------------------------------------------------------------------

invariant textwrap_extra24.wrap.module:
  description: "textwrap.wrap.__module__ == 'textwrap' — module-level function defined in textwrap"
  category: function_identity
  kind: python_call_eq
  function: wrap.__module__.__eq__
  args: ["textwrap"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.fill — __module__
#
# No prior spec verifies fill.__module__ as a standalone invariant. fill is a
# module-level function defined in textwrap, so __module__ == 'textwrap'.
# Verified at runtime: 'textwrap'.
# ---------------------------------------------------------------------------

invariant textwrap_extra24.fill.module:
  description: "textwrap.fill.__module__ == 'textwrap' — module-level function defined in textwrap"
  category: function_identity
  kind: python_call_eq
  function: fill.__module__.__eq__
  args: ["textwrap"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.dedent — __module__
#
# No prior spec verifies dedent.__module__ as a standalone invariant. dedent is
# a module-level function defined in textwrap, so __module__ == 'textwrap'.
# Verified at runtime: 'textwrap'.
# ---------------------------------------------------------------------------

invariant textwrap_extra24.dedent.module:
  description: "textwrap.dedent.__module__ == 'textwrap' — module-level function defined in textwrap"
  category: function_identity
  kind: python_call_eq
  function: dedent.__module__.__eq__
  args: ["textwrap"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.indent — __module__
#
# No prior spec verifies indent.__module__ as a standalone invariant. indent is
# a module-level function defined in textwrap, so __module__ == 'textwrap'.
# Verified at runtime: 'textwrap'.
# ---------------------------------------------------------------------------

invariant textwrap_extra24.indent.module:
  description: "textwrap.indent.__module__ == 'textwrap' — module-level function defined in textwrap"
  category: function_identity
  kind: python_call_eq
  function: indent.__module__.__eq__
  args: ["textwrap"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.shorten — __module__
#
# No prior spec verifies shorten.__module__ as a standalone invariant. shorten
# is a module-level function defined in textwrap, so __module__ == 'textwrap'.
# Verified at runtime: 'textwrap'.
# ---------------------------------------------------------------------------

invariant textwrap_extra24.shorten.module:
  description: "textwrap.shorten.__module__ == 'textwrap' — module-level function defined in textwrap"
  category: function_identity
  kind: python_call_eq
  function: shorten.__module__.__eq__
  args: ["textwrap"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.TextWrapper._handle_long_word — __qualname__
#
# No prior spec verifies TextWrapper._handle_long_word.__qualname__ as a
# standalone invariant. For a private method defined in class TextWrapper,
# __qualname__ takes the form 'TextWrapper._handle_long_word'.
# Verified at runtime: 'TextWrapper._handle_long_word'.
# ---------------------------------------------------------------------------

invariant textwrap_extra24.TextWrapper.handle_long_word_qualname:
  description: "textwrap.TextWrapper._handle_long_word.__qualname__ == 'TextWrapper._handle_long_word' — private method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: "TextWrapper._handle_long_word.__qualname__.__eq__"
  args: ["TextWrapper._handle_long_word"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.TextWrapper._munge_whitespace — __qualname__
#
# No prior spec verifies TextWrapper._munge_whitespace.__qualname__ as a
# standalone invariant. For a private method defined in class TextWrapper,
# __qualname__ takes the form 'TextWrapper._munge_whitespace'.
# Verified at runtime: 'TextWrapper._munge_whitespace'.
# ---------------------------------------------------------------------------

invariant textwrap_extra24.TextWrapper.munge_whitespace_qualname:
  description: "textwrap.TextWrapper._munge_whitespace.__qualname__ == 'TextWrapper._munge_whitespace' — private method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: "TextWrapper._munge_whitespace.__qualname__.__eq__"
  args: ["TextWrapper._munge_whitespace"]
  expected: true

# ---------------------------------------------------------------------------
# Table: TextWrapper class identity and module-level function __module__ values
#
# Groups TextWrapper.__module__, TextWrapper.__bases__[0].__name__, and the
# five module-level function __module__ checks into a single table.
# All values verified at runtime.
# ---------------------------------------------------------------------------

table textwrap_extra24.module_and_base_checks:
  description: "textwrap TextWrapper class identity and module-level function __module__ values"
  kind: python_call_eq
  category: class_identity
  columns: [id, function, args, expected, description]
  rows:
    - [TextWrapper_module,
       TextWrapper.__module__.__eq__,
       ["textwrap"],
       true,
       "TextWrapper.__module__ == 'textwrap'"]
    - [TextWrapper_base,
       "TextWrapper.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "TextWrapper.__bases__[0].__name__ == 'object'"]
    - [wrap_module,
       wrap.__module__.__eq__,
       ["textwrap"],
       true,
       "wrap.__module__ == 'textwrap'"]
    - [fill_module,
       fill.__module__.__eq__,
       ["textwrap"],
       true,
       "fill.__module__ == 'textwrap'"]
    - [dedent_module,
       dedent.__module__.__eq__,
       ["textwrap"],
       true,
       "dedent.__module__ == 'textwrap'"]
    - [indent_module,
       indent.__module__.__eq__,
       ["textwrap"],
       true,
       "indent.__module__ == 'textwrap'"]
    - [shorten_module,
       shorten.__module__.__eq__,
       ["textwrap"],
       true,
       "shorten.__module__ == 'textwrap'"]

# ---------------------------------------------------------------------------
# Table: TextWrapper additional private method __qualname__ values
#
# No prior spec groups _handle_long_word and _munge_whitespace __qualname__
# checks. These are the two remaining documented private handler methods in
# TextWrapper that have not appeared in any prior extra spec.
# All values verified at runtime.
# ---------------------------------------------------------------------------

table textwrap_extra24.private_method_qualnames:
  description: "textwrap.TextWrapper additional private method __qualname__ values — _handle_long_word and _munge_whitespace"
  kind: python_call_eq
  category: function_identity
  columns: [id, function, args, expected, description]
  rows:
    - [handle_long_word,
       "TextWrapper._handle_long_word.__qualname__.__eq__",
       ["TextWrapper._handle_long_word"],
       true,
       "TextWrapper._handle_long_word.__qualname__ == 'TextWrapper._handle_long_word'"]
    - [munge_whitespace,
       "TextWrapper._munge_whitespace.__qualname__.__eq__",
       ["TextWrapper._munge_whitespace"],
       true,
       "TextWrapper._munge_whitespace.__qualname__ == 'TextWrapper._munge_whitespace'"]
