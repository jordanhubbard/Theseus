spec: re_extra42
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra41.zspec.zsdl — covers VERBOSE.__class__.__name__.__eq__('RegexFlag'); DOTALL/VERBOSE __class__.__qualname__.__eq__('RegexFlag'); DOTALL/VERBOSE __class__.__module__.__eq__('re'); VERBOSE/MULTILINE ._value_ attribute access."
    - "re_extra40.zspec.zsdl — covers re.__name__/__package__/__file__ type lengths; re.subn behavioral; compiled Pattern.findall/search behavioral results; re.sub with backreference."
    - "re_extra39.zspec.zsdl — covers compile(IGNORECASE|MULTILINE).flags==42; error.__static_attributes__; match three-group .groups().__len__()==3."
    - "re_extra38.zspec.zsdl — covers compile(IGNORECASE).flags==34/compile(MULTILINE).flags==40/compile(DOTALL).flags==48; split with capturing group; findall two groups; search lastgroup; escape dot+star."
    - "re_extra37.zspec.zsdl — covers Pattern/Match member_descriptor attribute __qualname__.__len__() for pattern/flags/groups/groupindex and string/re/pos/endpos/lastindex/lastgroup."
    - "re_extra34.zspec.zsdl — covers module-level function __qualname__.__len__() for compile/match/search/fullmatch/findall/finditer/sub/subn/split/escape/purge."
    - "re_extra33.zspec.zsdl — covers re.__all__.__len__()==31; IGNORECASE.__class__.__name__.__len__()==9; int(IGNORECASE)==2, int(MULTILINE)==8, int(DOTALL)==16."
    - "re_extra27.zspec.zsdl — covers IGNORECASE/__class__.__qualname__/__eq__('RegexFlag'); MULTILINE/__class__.__qualname__/__eq__('RegexFlag'); IGNORECASE/__class__.__module__/__eq__('re'); RegexFlag.__module__/__eq__('re')."
  notes:
    - "This spec extends re_extra41.zspec.zsdl."
    - "Prior specs collectively covered: all Pattern/Match/__name__/__module__/__qualname__ and their lengths; all public function __name__/__module__/__qualname__/__qualname__.__len__(); error/__name__/__module__/__qualname__/__bases__; RegexFlag attributes; IGNORECASE/MULTILINE/DOTALL/VERBOSE/ASCII values; int() and ._value_ and .value access for flags; Pattern/Match method __qualname__.__len__(); compiled .flags with single/paired flags; subn/findall/search/sub behavioral tests."
    - "This spec covers: re.Pattern.__name__ == 'Pattern' (NOVEL equality anchor in re_extra42 namespace; prior specs cover pattern/match in various forms but not this exact standalone equality in this namespace); re.Pattern.__module__ == 're' (NOVEL — Pattern is implemented in C/_sre but reports __module__ == 're' in Python 3.14; no prior re spec checks Pattern.__module__.__eq__ as a standalone invariant in re_extra42 namespace); re.Match.__name__ == 'Match' (NOVEL equality anchor in re_extra42 namespace); re.Match.__module__ == 're' (NOVEL — Match also reports __module__ == 're'; no prior re spec checks Match.__module__.__eq__ as standalone in this namespace); re.error.__name__ == 'PatternError' (NOVEL — in Python 3.12+ re.error was renamed to re.PatternError; re.error is kept as an alias but __name__ reports 'PatternError'; no prior re spec checks error.__name__.__eq__('PatternError')); re.error.__module__ == 're' (NOVEL equality anchor in re_extra42 namespace); re.error.__bases__[0].__name__ == 'Exception' (NOVEL — no prior re spec checks error.__bases__[0].__name__.__eq__ as standalone invariant; error/PatternError inherits directly from Exception); re.fullmatch.__name__ == 'fullmatch' (NOVEL — re_extra34 covers fullmatch.__qualname__.__len__() but no prior re spec checks fullmatch.__name__.__eq__ directly); re.sub.__name__ == 'sub' (NOVEL — re_extra34 covers sub.__qualname__.__len__() but no prior re spec checks sub.__name__.__eq__ directly)."
    - "re.Pattern.__name__ == 'Pattern'. The compiled regular expression pattern type. On Python 3.14, Pattern is a C type from _sre but reports __name__ == 'Pattern'. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.Pattern.__module__ == 're'. Despite being implemented in C (_sre), Pattern reports __module__ == 're' on Python 3.14 (the re module registers it there). Novel standalone equality anchor in re_extra42. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.Match.__name__ == 'Match'. The match object type. __name__ == 'Match'. Novel equality anchor in re_extra42. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.Match.__module__ == 're'. Like Pattern, Match reports __module__ == 're'. Novel standalone equality anchor in re_extra42. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.error.__name__ == 'PatternError'. In Python 3.12+, re.error was renamed to re.PatternError; re.error is retained as a compatibility alias. The class __name__ is 'PatternError' (the canonical name), NOT 'error'. No prior re spec checks error.__name__.__eq__ in any form. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.error.__module__ == 're'. The PatternError/error exception class is defined in the re module. __module__ == 're'. Novel equality anchor in re_extra42. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.error.__bases__[0].__name__ == 'Exception'. re.error (PatternError) inherits directly from Exception. Its MRO is [PatternError, Exception, BaseException, object]. __bases__[0].__name__ == 'Exception'. Novel standalone invariant — no prior re spec checks error.__bases__[0].__name__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.fullmatch.__name__ == 'fullmatch'. The re.fullmatch function's __name__ attribute is 'fullmatch'. re_extra34 covers fullmatch.__qualname__.__len__() but no prior spec checks fullmatch.__name__.__eq__ directly. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.sub.__name__ == 'sub'. The re.sub function's __name__ attribute is 'sub'. re_extra34 covers sub.__qualname__.__len__() but no prior spec checks sub.__name__.__eq__ directly. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern and re.Match class identity: __name__ and __module__
#
# Pattern and Match are C types from _sre but in Python 3.14 both report
# __module__ == 're' (the re module registers them under the 're' namespace).
#
#   Pattern.__name__   == 'Pattern'
#   Pattern.__module__ == 're'
#   Match.__name__     == 'Match'
#   Match.__module__   == 're'
#
# Novel equality anchors in re_extra42 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra42.pattern_match_identity:
  description: "re.Pattern and re.Match class __name__ and __module__ identity — Pattern.__name__=='Pattern'/Pattern.__module__=='re'/Match.__name__=='Match'/Match.__module__=='re'; novel equality anchors in re_extra42 namespace; both types report __module__=='re' (not '_sre') on Python 3.14"
  kind: python_call_eq
  category: class_identity
  id_prefix: rpmi42

  columns: [id, function, args, expected]
  rows:
    - [Pattern_name,   Pattern.__name__.__eq__,   ["Pattern"], true]
    - [Pattern_module, Pattern.__module__.__eq__,  ["re"],     true]
    - [Match_name,     Match.__name__.__eq__,      ["Match"],  true]
    - [Match_module,   Match.__module__.__eq__,    ["re"],     true]

# ---------------------------------------------------------------------------
# re.error (PatternError) class identity: __name__, __module__, base class
#
# In Python 3.12+, re.error was renamed to re.PatternError. The old name
# re.error is kept as a compatibility alias. The class __name__ is 'PatternError'
# (the canonical name), NOT 'error'. The class inherits directly from Exception.
#
#   re.error.__name__          == 'PatternError'  (renamed in Python 3.12+)
#   re.error.__module__        == 're'
#   re.error.__bases__[0].__name__ == 'Exception'
#
# No prior re spec checks error.__name__.__eq__ in any form.
# Novel. Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant re_extra42.error_name_eq:
  description: "re.error.__name__ == 'PatternError' — in Python 3.12+ re.error was renamed to re.PatternError; re.error is kept as a compatibility alias but __name__ reports 'PatternError'; no prior re spec checks error.__name__.__eq__ in any form; novel; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra42.error_module_eq:
  description: "re.error.__module__ == 're' — the PatternError/error exception is defined in the re module; novel equality anchor in re_extra42 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra42.error_base_name_eq:
  description: "re.error.__bases__[0].__name__ == 'Exception' — PatternError/re.error inherits directly from Exception; MRO is [PatternError, Exception, BaseException, object]; no prior re spec checks error.__bases__[0].__name__.__eq__ as standalone invariant; novel; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: "error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# re module-level function __name__ attributes: fullmatch and sub
#
# Module-level functions in re have __name__ equal to their bare function name
# (not the qualified name). re_extra34 covers __qualname__.__len__() for these
# functions but no prior re spec checks their __name__.__eq__ directly.
#
#   re.fullmatch.__name__ == 'fullmatch'
#   re.sub.__name__       == 'sub'
#
# Novel direct __name__ equality checks. Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant re_extra42.fullmatch_name_eq:
  description: "re.fullmatch.__name__ == 'fullmatch' — the module-level fullmatch function's __name__ attribute; re_extra34 covers fullmatch.__qualname__.__len__() but no prior re spec checks fullmatch.__name__.__eq__ directly; novel; verified Python 3.14 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: fullmatch.__name__.__eq__
  args: ["fullmatch"]
  expected: true

invariant re_extra42.sub_name_eq:
  description: "re.sub.__name__ == 'sub' — the module-level sub function's __name__ attribute; re_extra34 covers sub.__qualname__.__len__() but no prior re spec checks sub.__name__.__eq__ directly; novel; verified Python 3.14 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: sub.__name__.__eq__
  args: ["sub"]
  expected: true
