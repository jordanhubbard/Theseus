spec: email_extra5
version: ">=3.6"
backend: python_module(email)

docs: https://docs.python.org/3/library/email.html

provenance:
  derived_from:
    - "Python 3 email package documentation — https://docs.python.org/3/library/email.html"
    - "Python 3 email.headerregistry documentation — https://docs.python.org/3/library/email.headerregistry.html"
    - "Python 3 email.errors documentation — https://docs.python.org/3/library/email.errors.html"
    - "Python 3 email.policy documentation — https://docs.python.org/3/library/email.policy.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/email/__init__.py"
    - "email_extra.zspec.zsdl — covers email.__name__; message_from_string/bytes/file/binary_file __name__ and parsing"
    - "email_extra2.zspec.zsdl — covers email.policy EmailPolicy/SMTP/SMTPUTF8/HTTP class names; email.errors HeaderParseError/MessageError/MessageDefect names; email.contentmanager.get_content_manager name; email.generator Generator/BytesGenerator names and modules; SMTPUTF8.utf8 and SMTP.linesep"
    - "email_extra3.zspec.zsdl — covers function __qualname__ and __module__; email.__spec__.name; email.message.Message/EmailMessage names via email.message chain"
    - "email_extra4.zspec.zsdl — covers email.policy EmailPolicy/Policy/Compat32 qualnames; EmailPolicy.__module__ and Policy.__module__; email.errors MessageError/HeaderParseError/MessageDefect qualnames and __module__; email.generator Generator/BytesGenerator qualnames and hierarchy; email.utils parseaddr/formataddr qualnames and __module__; email.headerregistry.Address name/qualname/module"
  notes:
    - "This spec extends email_extra.zspec.zsdl through email_extra4.zspec.zsdl."
    - "Focus: new axes not yet tested in any prior email spec."
    - "email.headerregistry.Group is the companion to Address for group syntax (RFC 5322 section 3.4); not tested in any prior spec."
    - "email.errors.BoundaryError/__qualname__ — extra4 covers MessageError/HeaderParseError/MessageDefect qualnames; BoundaryError and CharsetError qualnames are new."
    - "email.errors.MultipartConversionError/__qualname__ — not tested in any prior spec."
    - "email.policy.Compat32.__module__ — extra4 verifies Compat32.__qualname__ but not __module__; Compat32 is defined in email._policybase."
    - "email.contentmanager.get_content_manager.__qualname__ and __module__ — extra2 checks only __name__; these attributes are new."
    - "email.headerregistry.Address.__bases__[0].__name__ — hierarchy for Address not tested in any prior spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# email.headerregistry.Group — name, qualname, module
# (email_extra4 covers Address; Group is the companion class for group
#  syntax and is not tested in any prior spec)
# ---------------------------------------------------------------------------

invariant email_extra5.headerregistry.Group.name:
  description: "email.headerregistry.Group.__name__ == 'Group'"
  category: headerregistry
  kind: python_call_eq
  function: headerregistry.Group.__name__.__eq__
  args: ["Group"]
  expected: true

invariant email_extra5.headerregistry.Group.qualname:
  description: "email.headerregistry.Group.__qualname__ == 'Group'"
  category: headerregistry
  kind: python_call_eq
  function: headerregistry.Group.__qualname__.__eq__
  args: ["Group"]
  expected: true

invariant email_extra5.headerregistry.Group.module:
  description: "email.headerregistry.Group.__module__ == 'email.headerregistry'"
  category: headerregistry
  kind: python_call_eq
  function: headerregistry.Group.__module__.__eq__
  args: ["email.headerregistry"]
  expected: true

# ---------------------------------------------------------------------------
# email.headerregistry.Address hierarchy
# (email_extra4 checks Address name/qualname/module but not its base class)
# ---------------------------------------------------------------------------

invariant email_extra5.headerregistry.Address.base:
  description: "email.headerregistry.Address.__bases__[0].__name__ == 'object' — Address has no structured base"
  category: hierarchy
  kind: python_call_eq
  function: headerregistry.Address.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# email.errors — __qualname__ for BoundaryError, CharsetError,
# MultipartConversionError
# (email_extra4 covers MessageError/HeaderParseError/MessageDefect qualnames;
#  the remaining error-hierarchy classes are new in this spec)
# ---------------------------------------------------------------------------

table email_extra5.errors_qualnames_extra:
  kind: python_call_eq
  category: qualnames
  id_prefix: eqname

  columns: [id, function, args, expected]
  rows:
    - [BoundaryError,            errors.BoundaryError.__qualname__.__eq__,            ["BoundaryError"],            true]
    - [CharsetError,             errors.CharsetError.__qualname__.__eq__,             ["CharsetError"],             true]
    - [MultipartConversionError, errors.MultipartConversionError.__qualname__.__eq__, ["MultipartConversionError"], true]

# ---------------------------------------------------------------------------
# email.errors.BoundaryError and CharsetError __module__
# (email_extra4 covers MessageError/HeaderParseError/MessageDefect __module__;
#  BoundaryError and CharsetError __module__ are new)
# ---------------------------------------------------------------------------

table email_extra5.errors_modules_extra:
  kind: python_call_eq
  category: modules
  id_prefix: emod

  columns: [id, function, args, expected]
  rows:
    - [BoundaryError, errors.BoundaryError.__module__.__eq__, ["email.errors"], true]
    - [CharsetError,  errors.CharsetError.__module__.__eq__,  ["email.errors"], true]

# ---------------------------------------------------------------------------
# email.policy.Compat32.__module__
# (email_extra4 tests Compat32.__qualname__ but NOT __module__;
#  Compat32 is defined in email._policybase, same as Policy)
# ---------------------------------------------------------------------------

invariant email_extra5.policy.Compat32.module:
  description: "email.policy.Compat32.__module__ == 'email._policybase' — Compat32 defined in private submodule"
  category: modules
  kind: python_call_eq
  function: policy.Compat32.__module__.__eq__
  args: ["email._policybase"]
  expected: true

# ---------------------------------------------------------------------------
# email.contentmanager.get_content_manager — __qualname__ and __module__
# (email_extra2 checks __name__ only; qualname and module are new)
# ---------------------------------------------------------------------------

invariant email_extra5.contentmanager.get_content_manager.qualname:
  description: "email.contentmanager.get_content_manager.__qualname__ == 'get_content_manager'"
  category: contentmanager
  kind: python_call_eq
  function: contentmanager.get_content_manager.__qualname__.__eq__
  args: ["get_content_manager"]
  expected: true

invariant email_extra5.contentmanager.get_content_manager.module:
  description: "email.contentmanager.get_content_manager.__module__ == 'email.contentmanager'"
  category: contentmanager
  kind: python_call_eq
  function: contentmanager.get_content_manager.__module__.__eq__
  args: ["email.contentmanager"]
  expected: true
