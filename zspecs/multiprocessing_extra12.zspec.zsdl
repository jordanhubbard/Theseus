spec: multiprocessing_extra12
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/synchronize.py"
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec extends multiprocessing.zspec.zsdl and prior extras through multiprocessing_extra11.zspec.zsdl."
    - "multiprocessing_extra covers: Process/__name__, Queue/__name__, Pipe/__name__ (top-level __name__ checks)."
    - "multiprocessing_extra3 covers: Lock/__module__, Event/__module__, Value/__module__, Array/__module__."
    - "multiprocessing_extra5 covers: Value/__qualname__ == 'BaseContext.Value', Array/__qualname__ == 'BaseContext.Array'."
    - "multiprocessing_extra7 covers: Lock/__module__, Event/__module__, Semaphore/__module__, Queue/__module__."
    - "multiprocessing_extra9 covers: RLock/__qualname__ == 'BaseContext.RLock'."
    - "No prior spec accesses synchronize module classes directly via multiprocessing.synchronize."
    - "NOT yet covered in any prior spec: synchronize.Lock.__name__ == 'Lock' — the underlying class (not the context method)."
    - "NOT yet covered: synchronize.Lock.__qualname__ == 'Lock' — qualname is 'Lock' not 'BaseContext.Lock'."
    - "NOT yet covered: synchronize.Lock.__module__ == 'multiprocessing.synchronize'."
    - "NOT yet covered: synchronize.Lock.__bases__[0].__name__ == 'SemLock'."
    - "NOT yet covered: synchronize.Semaphore.__name__ == 'Semaphore'."
    - "NOT yet covered: synchronize.Semaphore.__module__ == 'multiprocessing.synchronize'."
    - "NOT yet covered: synchronize.Semaphore.__bases__[0].__name__ == 'SemLock'."
    - "NOT yet covered: synchronize.Event.__name__ == 'Event'."
    - "NOT yet covered: synchronize.Event.__module__ == 'multiprocessing.synchronize'."
    - "NOT yet covered: synchronize.Event.__bases__[0].__name__ == 'object'."
    - "NOT yet covered: synchronize.Barrier.__name__ == 'Barrier'."
    - "NOT yet covered: synchronize.Barrier.__module__ == 'multiprocessing.synchronize'."
    - "NOT yet covered: synchronize.SemLock.__name__ == 'SemLock'."
    - "NOT yet covered: process.BaseProcess.__name__ == 'BaseProcess'."
    - "NOT yet covered: process.BaseProcess.__qualname__ == 'BaseProcess'."
    - "NOT yet covered: process.BaseProcess.__module__ == 'multiprocessing.process'."
    - "NOT yet covered: process.BaseProcess.__class__.__name__ == 'type'."
    - "multiprocessing.synchronize.Lock.__qualname__ == 'Lock' — the synchronize module class has a simple qualname."
    - "multiprocessing.synchronize.Lock.__bases__[0].__name__ == 'SemLock' — Lock extends SemLock in synchronize."
    - "multiprocessing.process.BaseProcess.__module__ == 'multiprocessing.process'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.synchronize classes — __name__ and __module__
#
# The multiprocessing top-level namespace exposes Lock/Semaphore/Event/Barrier
# as context-bound methods (Lock.__qualname__ == 'BaseContext.Lock', etc.).
# No prior spec accesses the underlying classes via multiprocessing.synchronize.
# The synchronize module classes have simple __name__ and __qualname__.
# ---------------------------------------------------------------------------

table multiprocessing_extra12.synchronize_class_names:
  description: "multiprocessing.synchronize classes have correct __name__ values"
  kind: python_call_eq
  category: class_names
  id_prefix: synccname

  columns: [id, function, args, expected]
  rows:
    - [Lock,      synchronize.Lock.__name__.__eq__,      ["Lock"],      true]
    - [Semaphore, synchronize.Semaphore.__name__.__eq__, ["Semaphore"], true]
    - [Event,     synchronize.Event.__name__.__eq__,     ["Event"],     true]
    - [Barrier,   synchronize.Barrier.__name__.__eq__,   ["Barrier"],   true]
    - [SemLock,   synchronize.SemLock.__name__.__eq__,   ["SemLock"],   true]

table multiprocessing_extra12.synchronize_class_modules:
  description: "multiprocessing.synchronize classes have __module__ == 'multiprocessing.synchronize'"
  kind: python_call_eq
  category: class_modules
  id_prefix: syncmod

  columns: [id, function, args, expected]
  rows:
    - [Lock,      synchronize.Lock.__module__.__eq__,      ["multiprocessing.synchronize"], true]
    - [Semaphore, synchronize.Semaphore.__module__.__eq__, ["multiprocessing.synchronize"], true]
    - [Event,     synchronize.Event.__module__.__eq__,     ["multiprocessing.synchronize"], true]
    - [Barrier,   synchronize.Barrier.__module__.__eq__,   ["multiprocessing.synchronize"], true]

# ---------------------------------------------------------------------------
# synchronize class hierarchy — __bases__[0].__name__
#
# Lock and Semaphore inherit from SemLock; Event inherits from object.
# No prior spec checks these base class relationships via the synchronize module.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra12.synchronize_Lock.base:
  description: "multiprocessing.synchronize.Lock.__bases__[0].__name__ == 'SemLock'"
  category: class_hierarchy
  kind: python_call_eq
  function: synchronize.Lock.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "SemLock"

invariant multiprocessing_extra12.synchronize_Semaphore.base:
  description: "multiprocessing.synchronize.Semaphore.__bases__[0].__name__ == 'SemLock'"
  category: class_hierarchy
  kind: python_call_eq
  function: synchronize.Semaphore.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "SemLock"

invariant multiprocessing_extra12.synchronize_Event.base:
  description: "multiprocessing.synchronize.Event.__bases__[0].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: synchronize.Event.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# process.BaseProcess class identity checks
#
# multiprocessing_extra9 covers Process.__mro__[1].__name__ == 'BaseProcess'.
# No prior spec accesses BaseProcess directly via multiprocessing.process.
# BaseProcess is the real class; the top-level multiprocessing.Process is a
# context-bound subclass whose __bases__[0] is BaseProcess.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra12.BaseProcess.name:
  description: "multiprocessing.process.BaseProcess.__name__ == 'BaseProcess'"
  category: class_names
  kind: python_call_eq
  function: process.BaseProcess.__name__.__eq__
  args: ["BaseProcess"]
  expected: true

invariant multiprocessing_extra12.BaseProcess.qualname:
  description: "multiprocessing.process.BaseProcess.__qualname__ == 'BaseProcess'"
  category: class_names
  kind: python_call_eq
  function: process.BaseProcess.__qualname__.__eq__
  args: ["BaseProcess"]
  expected: true

invariant multiprocessing_extra12.BaseProcess.module:
  description: "multiprocessing.process.BaseProcess.__module__ == 'multiprocessing.process'"
  category: class_modules
  kind: python_call_eq
  function: process.BaseProcess.__module__.__eq__
  args: ["multiprocessing.process"]
  expected: true

invariant multiprocessing_extra12.BaseProcess.metaclass:
  description: "multiprocessing.process.BaseProcess.__class__.__name__ == 'type'"
  category: class_types
  kind: python_call_eq
  function: process.BaseProcess.__class__.__name__.__eq__
  args: ["type"]
  expected: true
