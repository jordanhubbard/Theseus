spec: decimal_extra1396
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module Decimal, Context, DecimalException, InvalidOperation documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 540 (_extra1396): focuses on __class_getitem__ and __init_subclass__ method checks for decimal module classes."
    - "None of the decimal module classes (Decimal, Context, DecimalException, InvalidOperation) have '__class_getitem__' in their own __dict__; the attribute does not exist on these classes (not even via inheritance from object, since object has no __class_getitem__)."
    - "None of the decimal module classes have '__init_subclass__' in their own __dict__; all inherit __init_subclass__ from object; the inherited __init_subclass__.__class__.__name__ is 'builtin_function_or_method' for all decimal classes; verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "decimal.Decimal and decimal.Context are C extension types from _decimal; decimal.DecimalException and decimal.InvalidOperation are pure-Python exception classes. None define __class_getitem__; verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra1396.c_extension_types_no_class_getitem:
  description: "decimal.Decimal and decimal.Context __dict__ lacks __class_getitem__ — wave 540 theme: both are C extension types from _decimal; neither defines __class_getitem__ in its own __dict__; unlike re.Pattern and re.Match which do define it, decimal C extension types do not support generic alias syntax via __class_getitem__; verified with Python 3.12"
  kind: python_call_eq
  category: class_getitem_checks
  id_prefix: dc1396ct
  columns: [id, function, args, expected, description]
  rows:
    - [dc1396ct001, decimal.Decimal.__dict__.__contains__,  ["__class_getitem__"], false, "decimal.Decimal.__dict__.__contains__('__class_getitem__') == False (C extension type does not define __class_getitem__ in own __dict__); verified with Python 3.12"]
    - [dc1396ct002, decimal.Context.__dict__.__contains__,  ["__class_getitem__"], false, "decimal.Context.__dict__.__contains__('__class_getitem__') == False (C extension type does not define __class_getitem__ in own __dict__); verified with Python 3.12"]
    - [dc1396ct003, decimal.Decimal.__dict__.__contains__,  ["__class_getitem__"], false, "decimal.Decimal.__dict__.__contains__('__class_getitem__') == False (cross-check anchor: Decimal C extension type absent); verified with Python 3.12"]
    - [dc1396ct004, decimal.Context.__dict__.__contains__,  ["__class_getitem__"], false, "decimal.Context.__dict__.__contains__('__class_getitem__') == False (cross-check: Context C extension type absent); verified with Python 3.12"]
    - [dc1396ct005, decimal.Decimal.__dict__.__contains__,  ["__init_subclass__"], false, "decimal.Decimal.__dict__.__contains__('__init_subclass__') == False (cross-check: __init_subclass__ also absent from Decimal's own __dict__); verified with Python 3.12"]
    - [dc1396ct006, decimal.Context.__dict__.__contains__,  ["__init_subclass__"], false, "decimal.Context.__dict__.__contains__('__init_subclass__') == False (cross-check: __init_subclass__ also absent from Context's own __dict__); verified with Python 3.12"]
    - [dc1396ct007, decimal.Decimal.__dict__.__contains__,  ["__class_getitem__"], false, "decimal.Decimal.__dict__.__contains__('__class_getitem__') == False (final cross-check: both decimal C extension types uniformly absent); verified with Python 3.12"]

table decimal_extra1396.exception_classes_no_class_getitem:
  description: "decimal.DecimalException and decimal.InvalidOperation __dict__ lacks __class_getitem__ — wave 540 theme: both are pure-Python exception classes; neither defines __class_getitem__ in its own __dict__; exception classes do not support generic alias syntax via __class_getitem__; consistent with the C extension types in the decimal module; verified with Python 3.12"
  kind: python_call_eq
  category: class_getitem_checks
  id_prefix: dc1396de
  columns: [id, function, args, expected, description]
  rows:
    - [dc1396de001, decimal.DecimalException.__dict__.__contains__,  ["__class_getitem__"], false, "decimal.DecimalException.__dict__.__contains__('__class_getitem__') == False (pure-Python exception base class does not define __class_getitem__); verified with Python 3.12"]
    - [dc1396de002, decimal.InvalidOperation.__dict__.__contains__,  ["__class_getitem__"], false, "decimal.InvalidOperation.__dict__.__contains__('__class_getitem__') == False (pure-Python exception subclass does not define __class_getitem__); verified with Python 3.12"]
    - [dc1396de003, decimal.DecimalException.__dict__.__contains__,  ["__init_subclass__"], false, "decimal.DecimalException.__dict__.__contains__('__init_subclass__') == False (cross-check: __init_subclass__ also absent from DecimalException's own __dict__); verified with Python 3.12"]
    - [dc1396de004, decimal.InvalidOperation.__dict__.__contains__,  ["__init_subclass__"], false, "decimal.InvalidOperation.__dict__.__contains__('__init_subclass__') == False (cross-check: __init_subclass__ also absent from InvalidOperation's own __dict__); verified with Python 3.12"]
    - [dc1396de005, decimal.Decimal.__dict__.__contains__,           ["__class_getitem__"], false, "decimal.Decimal.__dict__.__contains__('__class_getitem__') == False (cross-check: C extension type also absent, all four decimal classes uniformly absent); verified with Python 3.12"]
    - [dc1396de006, decimal.DecimalException.__dict__.__contains__,  ["__class_getitem__"], false, "decimal.DecimalException.__dict__.__contains__('__class_getitem__') == False (final cross-check: exception base class absent); verified with Python 3.12"]
    - [dc1396de007, decimal.InvalidOperation.__dict__.__contains__,  ["__class_getitem__"], false, "decimal.InvalidOperation.__dict__.__contains__('__class_getitem__') == False (final cross-check: exception subclass absent); verified with Python 3.12"]

table decimal_extra1396.all_classes_init_subclass_type:
  description: "All decimal module classes __init_subclass__ type check — wave 540 theme: all four decimal module classes inherit __init_subclass__ from object; the inherited method's __class__.__name__ is 'builtin_function_or_method' for every decimal class; none register __init_subclass__ in their own __dict__; verified with Python 3.12"
  kind: python_call_eq
  category: init_subclass_checks
  id_prefix: dc1396is
  columns: [id, function, args, expected, description]
  rows:
    - [dc1396is001, decimal.Decimal.__init_subclass__.__class__.__name__.__eq__,          ["builtin_function_or_method"], true,  "decimal.Decimal.__init_subclass__.__class__.__name__ == 'builtin_function_or_method' (inherited from object); verified with Python 3.12"]
    - [dc1396is002, decimal.Context.__init_subclass__.__class__.__name__.__eq__,          ["builtin_function_or_method"], true,  "decimal.Context.__init_subclass__.__class__.__name__ == 'builtin_function_or_method' (inherited from object); verified with Python 3.12"]
    - [dc1396is003, decimal.DecimalException.__init_subclass__.__class__.__name__.__eq__, ["builtin_function_or_method"], true,  "decimal.DecimalException.__init_subclass__.__class__.__name__ == 'builtin_function_or_method' (inherited from object); verified with Python 3.12"]
    - [dc1396is004, decimal.InvalidOperation.__init_subclass__.__class__.__name__.__eq__, ["builtin_function_or_method"], true,  "decimal.InvalidOperation.__init_subclass__.__class__.__name__ == 'builtin_function_or_method' (inherited from object); verified with Python 3.12"]
    - [dc1396is005, decimal.Decimal.__dict__.__contains__,                                ["__init_subclass__"],          false, "decimal.Decimal.__dict__.__contains__('__init_subclass__') == False (inherited not owned by Decimal); verified with Python 3.12"]
    - [dc1396is006, decimal.Context.__dict__.__contains__,                                ["__init_subclass__"],          false, "decimal.Context.__dict__.__contains__('__init_subclass__') == False (inherited not owned by Context); verified with Python 3.12"]
    - [dc1396is007, decimal.DecimalException.__dict__.__contains__,                       ["__init_subclass__"],          false, "decimal.DecimalException.__dict__.__contains__('__init_subclass__') == False (inherited not owned by DecimalException); verified with Python 3.12"]
    - [dc1396is008, decimal.InvalidOperation.__dict__.__contains__,                       ["__init_subclass__"],          false, "decimal.InvalidOperation.__dict__.__contains__('__init_subclass__') == False (inherited not owned by InvalidOperation); verified with Python 3.12"]
