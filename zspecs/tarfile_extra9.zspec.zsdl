spec: tarfile_extra9
version: ">=3.9"
backend: python_module(tarfile)

docs: https://docs.python.org/3/library/tarfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tarfile.html — Python tarfile documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tarfile.py"
  notes:
    - "This spec extends tarfile.zspec.zsdl through tarfile_extra8.zspec.zsdl."
    - "tarfile_extra8 covers: TarInfo uid/gid/mode defaults; GNU flag __class__.__name__=='bytes'; is_tarfile __module__/__class__.__name__; open __class__.__name__=='method'."
    - "tarfile_extra7 covers: LNKTYPE/CHRTYPE/BLKTYPE/FIFOTYPE eq bool form; ENCODING eq bool form; BLOCKSIZE/RECORDSIZE class names; TarFile/TarInfo/TarError/ReadError/CompressionError __class__.__name__=='type'; StreamError __name__; TarInfo('readme.md').name."
    - "tarfile_extra6 covers: GNU extension flag decode; ExFileObject metadata; ExtractError/CompressionError/HeaderError/StreamError __module__ and bases."
    - "tarfile_extra5 covers: TarInfo/__module__, TarError/__module__, ReadError/__module__; TarFile/TarInfo __bases__[0].__name__=='object'; tarfile.__name__."
    - "No prior spec covers: TarInfo.devmajor == 0 — default devmajor on freshly constructed TarInfo."
    - "No prior spec covers: TarInfo.devminor == 0 — default devminor on freshly constructed TarInfo."
    - "No prior spec covers: TarInfo.size == 0 — default size on freshly constructed TarInfo."
    - "No prior spec covers: TarInfo.mtime == 0 — default mtime on freshly constructed TarInfo."
    - "No prior spec covers: tarfile.AREGTYPE.__class__.__name__ == 'bytes' — AREGTYPE is an alias for b'\\x00'."
    - "No prior spec covers: tarfile.AREGTYPE.__eq__(b'\\x00') == True — AREGTYPE is the alternate regular file flag."
    - "No prior spec covers: tarfile.TarError.__mro__[1].__name__ == 'Exception' — TarError MRO depth 1."
    - "No prior spec covers: tarfile.TarError.__mro__[2].__name__ == 'BaseException' — TarError MRO depth 2."
    - "No prior spec covers: tarfile.ExFileObject.__class__.__name__ == 'type' — ExFileObject is a class object."
    - "tarfile.TarInfo defaults: devmajor=0, devminor=0, size=0, mtime=0 — all zero on construction."
    - "tarfile.AREGTYPE == b'\\x00' — the alternate regular file type flag byte (POSIX-1003.1 spec form)."
    - "tarfile.TarError.__mro__: [TarError, Exception, BaseException, object]."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TarInfo additional default field values — devmajor, devminor, size, mtime
# tarfile_extra8 covers uid=0, gid=0, mode=420 for TarInfo defaults.
# tarfile_extra7 covers TarInfo('readme.md').name.
# devmajor, devminor, size, and mtime defaults have not appeared in any prior spec.
# All default to 0 on a freshly constructed TarInfo.
# ---------------------------------------------------------------------------

table tarfile_extra9.TarInfo_extra_defaults:
  description: "TarInfo() additional default field values: devmajor=0, devminor=0, size=0, mtime=0"
  kind: python_call_eq
  category: tarinfo
  id_prefix: tidef9

  columns: [id, function, args, expected, method]
  rows:
    - [devmajor, TarInfo, ["test.txt"], 0, devmajor]
    - [devminor, TarInfo, ["test.txt"], 0, devminor]
    - [size,     TarInfo, ["test.txt"], 0, size]
    - [mtime,    TarInfo, ["test.txt"], 0, mtime]

# ---------------------------------------------------------------------------
# AREGTYPE — alternate regular file type flag
# tarfile (base) covers REGTYPE (b'0'), LNKTYPE (b'1'), SYMTYPE (b'2'),
# CHRTYPE, BLKTYPE, DIRTYPE, FIFOTYPE. AREGTYPE (b'\x00') is not in any prior spec.
# AREGTYPE is an alias for b'\x00' — the NUL byte indicating alternate regular file.
# ---------------------------------------------------------------------------

invariant tarfile_extra9.AREGTYPE.class_name:
  description: "tarfile.AREGTYPE.__class__.__name__ == 'bytes' — AREGTYPE is a bytes constant"
  category: type_flags
  kind: python_call_eq
  function: AREGTYPE.__class__.__name__.__eq__
  args: ["bytes"]
  expected: true

invariant tarfile_extra9.AREGTYPE.value:
  description: "tarfile.AREGTYPE == b'\\x00' — alternate regular file type flag is NUL byte"
  category: type_flags
  kind: python_call_eq
  function: AREGTYPE.__eq__
  args: [!hex "00"]
  expected: true

# ---------------------------------------------------------------------------
# TarError MRO depth 1 and depth 2
# tarfile_extra5 covers TarError.__module__ and __bases__[0].__name__ (bases form).
# No prior spec checks TarError.__mro__[N].__name__ for any N.
# TarError.__mro__: [TarError, Exception, BaseException, object]
# ---------------------------------------------------------------------------

invariant tarfile_extra9.TarError.mro_index1:
  description: "tarfile.TarError.__mro__[1].__name__ == 'Exception' — TarError MRO depth 1"
  category: class_hierarchy
  kind: python_call_eq
  function: TarError.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "Exception"

invariant tarfile_extra9.TarError.mro_index2:
  description: "tarfile.TarError.__mro__[2].__name__ == 'BaseException' — TarError MRO depth 2"
  category: class_hierarchy
  kind: python_call_eq
  function: TarError.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "BaseException"

# ---------------------------------------------------------------------------
# ExFileObject __class__.__name__ == 'type'
# tarfile_extra6 covers ExFileObject __name__/__module__/__qualname__/__bases__[0].__name__.
# No prior spec checks ExFileObject.__class__.__name__ == 'type'.
# ExFileObject is a class object, so __class__.__name__ == 'type'.
# ---------------------------------------------------------------------------

invariant tarfile_extra9.ExFileObject.class_is_type:
  description: "tarfile.ExFileObject.__class__.__name__ == 'type' — ExFileObject is a class object"
  category: type_identity
  kind: python_call_eq
  function: ExFileObject.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# TarInfo construction — 'archive.tar' filename vector
# base covers 'test.txt'; extra7 covers 'readme.md'.
# 'archive.tar' is a fresh vector confirming generality and tar-relevant names.
# ---------------------------------------------------------------------------

invariant tarfile_extra9.TarInfo.filename_archive_tar:
  description: "tarfile.TarInfo('archive.tar').name == 'archive.tar'"
  category: tarinfo
  kind: python_call_eq
  function: TarInfo
  args: ["archive.tar"]
  method: name
  expected: "archive.tar"

# ---------------------------------------------------------------------------
# TarInfo.linkname default — empty string
# tarfile (base) covers name, size, mtime via construction checks.
# No prior spec checks TarInfo.linkname default value.
# A freshly constructed TarInfo has linkname == '' (empty string).
# ---------------------------------------------------------------------------

invariant tarfile_extra9.TarInfo.linkname_default:
  description: "tarfile.TarInfo('test.tar').linkname == '' — default linkname is empty string"
  category: tarinfo
  kind: python_call_eq
  function: TarInfo
  args: ["test.tar"]
  method: linkname
  expected: ""
