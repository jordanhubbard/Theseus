spec: decimal_extra158
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal __int__, __float__, __complex__ method qualnames, and Decimal.to_eng_string and Decimal.as_tuple qualnames."
    - "All Decimal method qualnames follow the 'Decimal.<method>' pattern. The 'Decimal.' prefix is 8 characters."
    - "decimal.Decimal.__int__.__qualname__ == 'Decimal.__int__' (len=15; 'Decimal.' (8) + '__int__' (7) = 15)."
    - "decimal.Decimal.__float__.__qualname__ == 'Decimal.__float__' (len=17; 'Decimal.' (8) + '__float__' (9) = 17)."
    - "decimal.Decimal.__complex__.__qualname__ == 'Decimal.__complex__' (len=19; 'Decimal.' (8) + '__complex__' (11) = 19)."
    - "decimal.Decimal.to_eng_string.__qualname__ == 'Decimal.to_eng_string' (len=21; 'Decimal.' (8) + 'to_eng_string' (13) = 21; the longest qualname in this spec)."
    - "decimal.Decimal.as_tuple.__qualname__ == 'Decimal.as_tuple' (len=16; 'Decimal.' (8) + 'as_tuple' (8) = 16)."
    - "Length ranking: __int__=15, as_tuple=16, __float__=17, __complex__=19, to_eng_string=21."
    - "All five qualnames are distinct lengths — no ties in this spec."
    - "The three numeric type conversion dunders (__int__, __float__, __complex__) have increasing qualname lengths: 15, 17, 19 (stepping by 2 each time)."
    - "to_eng_string (21) is the longest qualname in this spec and among the longest Decimal method qualnames across all decimal_extra15x specs."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal numeric type conversion dunder __qualname__ values
# __int__ = 'Decimal.__int__' (len=15)
# __float__ = 'Decimal.__float__' (len=17)
# __complex__ = 'Decimal.__complex__' (len=19)
# Lengths increase by 2 at each step: 15, 17, 19.
# ---------------------------------------------------------------------------

table decimal_extra158.Decimal_type_conversion_qualnames:
  description: "decimal.Decimal numeric type conversion dunder qualnames: __int__='Decimal.__int__' (len=15), __float__='Decimal.__float__' (len=17), __complex__='Decimal.__complex__' (len=19); lengths increase by 2 from __int__ to __float__ to __complex__"
  kind: python_call_eq
  category: qualname
  id_prefix: decconv158

  columns: [id, function, args, expected, description]
  rows:
    - [int_qeq,      "Decimal.__int__.__qualname__.__eq__",      ["Decimal.__int__"],      true, "decimal.Decimal.__int__.__qualname__ == 'Decimal.__int__' (Decimal.__int__() implements the int() built-in for Decimal objects; int(Decimal('3.7')) == 3 — truncates towards zero; for Decimal, __int__() discards the fractional part without rounding; 'Decimal.__int__' has 15 characters: 'Decimal.' (8) + '__int__' (7) = 15; __int__ (15) is the shortest of the three type conversion dunders in this spec; the dunder '__int__' (7 chars) is shorter than '__float__' (9) and '__complex__' (11); length 15 equals __abs__/__neg__/__pos__ (also 15) from decimal_extra157 — a recurring tie at 15 for 7-char dunders under the 8-char 'Decimal.' prefix)"]
    - [float_qeq,    "Decimal.__float__.__qualname__.__eq__",    ["Decimal.__float__"],    true, "decimal.Decimal.__float__.__qualname__ == 'Decimal.__float__' (Decimal.__float__() implements the float() built-in for Decimal objects; float(Decimal('3.14')) returns the nearest IEEE 754 double-precision float; this conversion may lose precision because Decimal supports arbitrary precision while float is limited to 53 bits of significand; 'Decimal.__float__' has 17 characters: 'Decimal.' (8) + '__float__' (9) = 17; __float__ (17) is 2 characters longer than __int__ (15) and 2 shorter than __complex__ (19); the lengths step by 2: int(7)->float(9)->complex(11) chars in the dunder name)"]
    - [complex_qeq,  "Decimal.__complex__.__qualname__.__eq__",  ["Decimal.__complex__"],  true, "decimal.Decimal.__complex__.__qualname__ == 'Decimal.__complex__' (Decimal.__complex__() implements the complex() built-in for Decimal objects; complex(Decimal('3.14')) returns a complex number with the Decimal value as the real part and zero as the imaginary part; 'Decimal.__complex__' has 19 characters: 'Decimal.' (8) + '__complex__' (11) = 19; __complex__ (19) is the longest of the three type conversion dunders in this spec; '__complex__' (11 chars) is the longest of the three dunder names; length 19 equals Decimal.__truediv__.__qualname__ length (19) from decimal_extra155 — both are 11-char dunders under 'Decimal.' prefix)"]
    - [int_qlen,     "Decimal.__int__.__qualname__.__len__",     [],                       15,   "decimal.Decimal.__int__.__qualname__.__len__() == 15 ('Decimal.__int__' has 15 characters: 'Decimal.' (8) + '__int__' (7) = 15; the shortest of the three type conversion dunders in this spec; the three lengths form an arithmetic sequence: 15, 17, 19 — each step adds 2 characters because each successive dunder name is 2 characters longer: '__int__' (7), '__float__' (9), '__complex__' (11); length 15 is also shared by __abs__, __neg__, __pos__ from decimal_extra157 — all 7-char dunders under 'Decimal.' (8) produce qualname length 15)"]

# ---------------------------------------------------------------------------
# decimal.Decimal to_eng_string and as_tuple __qualname__ values
# to_eng_string = 'Decimal.to_eng_string' (len=21, the longest in this spec)
# as_tuple = 'Decimal.as_tuple' (len=16)
# ---------------------------------------------------------------------------

table decimal_extra158.Decimal_output_method_qualnames:
  description: "decimal.Decimal output method qualnames: to_eng_string='Decimal.to_eng_string' (len=21, longest in spec), as_tuple='Decimal.as_tuple' (len=16); to_eng_string has the longest qualname of any Decimal method in this spec"
  kind: python_call_eq
  category: qualname
  id_prefix: decconv158

  columns: [id, function, args, expected, description]
  rows:
    - [eng_qeq,   Decimal.to_eng_string.__qualname__.__eq__,  ["Decimal.to_eng_string"],  true, "decimal.Decimal.to_eng_string.__qualname__ == 'Decimal.to_eng_string' (to_eng_string() converts the Decimal to a string using engineering notation, where the exponent is always a multiple of 3; Decimal('1.23E+10').to_eng_string() == '12.3E+9'; 'Decimal.to_eng_string' has 21 characters: 'Decimal.' (8) + 'to_eng_string' (13) = 21; the longest qualname in this spec; 'to_eng_string' (13 chars) is a descriptive underscore-separated method name; the underscores in 'to_eng_string' contribute 2 characters to the method name length beyond the alphabetic characters)"]
    - [tuple_qeq,  Decimal.as_tuple.__qualname__.__eq__,       ["Decimal.as_tuple"],       true, "decimal.Decimal.as_tuple.__qualname__ == 'Decimal.as_tuple' (as_tuple() returns the Decimal value as a named tuple DecimalTuple(sign, digits, exponent); Decimal('3.14').as_tuple() == DecimalTuple(sign=0, digits=(3, 1, 4), exponent=-2); 'Decimal.as_tuple' has 16 characters: 'Decimal.' (8) + 'as_tuple' (8) = 16; the 'Decimal.' prefix (8 chars) and the 'as_tuple' method name (8 chars) are equal in length, making this a symmetric qualname: 8 + 8 = 16; length 16 equals Decimal.__bool__ (16) from decimal_extra157 and Context.__init__ and Context.__repr__ (both 16) from decimal_extra156)"]
    - [eng_qlen,  Decimal.to_eng_string.__qualname__.__len__,  [],                         21,   "decimal.Decimal.to_eng_string.__qualname__.__len__() == 21 ('Decimal.to_eng_string' has 21 characters: 'Decimal.' (8) + 'to_eng_string' (13) = 21; 21 is the longest qualname in this spec and among the longest seen across all decimal_extra15x specs; compare: Decimal.__format__ (18, from decimal_extra156), Decimal.__truediv__ (19, from decimal_extra155), Decimal.__complex__ (19) — to_eng_string (21) exceeds them all; 'to_eng_string' (13 chars) owes its length to the underscore-separated descriptive naming convention; engineering notation is a variant of scientific notation where exponents are multiples of 3)"]
    - [tuple_qlen, Decimal.as_tuple.__qualname__.__len__,       [],                         16,   "decimal.Decimal.as_tuple.__qualname__.__len__() == 16 ('Decimal.as_tuple' has 16 characters: 'Decimal.' (8) + 'as_tuple' (8) = 16; a symmetric qualname where prefix and method name have equal length (8 each); complete length ranking in this spec: __int__=15, as_tuple=16, __float__=17, __complex__=19, to_eng_string=21; all five qualname lengths are distinct — no ties in this spec; 'as_tuple' (8 chars) contains one underscore; the as_tuple() result is a DecimalTuple named tuple with sign (0 or 1), digits (tuple of ints), and exponent (int or special string) fields)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra158.Decimal_int_float_complex_step_by_2:
  description: "decimal.Decimal.__int__.__qualname__.__len__() == 15 — the three numeric type conversion dunders form an arithmetic sequence: __int__ (15), __float__ (17), __complex__ (19); each successive dunder is 2 characters longer because '__int__' (7), '__float__' (9), and '__complex__' (11) each differ by 2 characters; all three use the 'Decimal.' prefix (8 chars); the step-by-2 pattern arises because 'int' (3), 'float' (5), and 'complex' (7) are all odd-length type names that differ by 2, and the double-underscore wrapping '__xxx__' adds 4 chars; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: "Decimal.__int__.__qualname__.__len__"
  args: []
  expected: 15

invariant decimal_extra158.Decimal_to_eng_string_is_longest_at_21:
  description: "decimal.Decimal.to_eng_string.__qualname__.__len__() == 21 — 'Decimal.to_eng_string' is the longest qualname in this spec at 21 characters: 'Decimal.' (8) + 'to_eng_string' (13) = 21; to_eng_string (21) is longer than Decimal.__complex__ (19), Decimal.__truediv__ (19 from decimal_extra155), and Decimal.__format__ (18 from decimal_extra156); the 13-character method name 'to_eng_string' reflects the full descriptive name of the engineering notation formatting method; engineering notation (exponent always a multiple of 3) is used in SI unit contexts; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: Decimal.to_eng_string.__qualname__.__len__
  args: []
  expected: 21

invariant decimal_extra158.Decimal_as_tuple_symmetric_at_16:
  description: "decimal.Decimal.as_tuple.__qualname__.__len__() == 16 — 'Decimal.as_tuple' has 16 characters; notably symmetric: the 'Decimal.' prefix (8 chars) equals the 'as_tuple' method name (8 chars); both halves of the qualname have equal length 8; length 16 is shared with Decimal.__bool__ (from decimal_extra157), Context.__init__ and Context.__repr__ (from decimal_extra156) — a recurring length-16 pattern for various Decimal and Context method qualnames; the as_tuple() method returns a DecimalTuple named tuple decomposition of the Decimal value; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: Decimal.as_tuple.__qualname__.__len__
  args: []
  expected: 16

invariant decimal_extra158.Decimal_complex_qualname_eq:
  description: "decimal.Decimal.__complex__.__qualname__ == 'Decimal.__complex__' — __complex__ implements the complex() conversion for Decimal; 'Decimal.__complex__' has 19 characters: 'Decimal.' (8) + '__complex__' (11) = 19; it is the longest of the three type conversion dunders (__int__=15, __float__=17, __complex__=19); '__complex__' (11 chars) is the longest dunder name in this spec — 'complex' (7 chars) wrapped in double underscores gives 11 chars; length 19 equals Decimal.__truediv__.__qualname__ length (19) from decimal_extra155 — both are 11-char dunders under the 8-char 'Decimal.' prefix; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: "Decimal.__complex__.__qualname__.__eq__"
  args: ["Decimal.__complex__"]
  expected: true

