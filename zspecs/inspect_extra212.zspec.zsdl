spec: inspect_extra212
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect_extra211.zspec.zsdl — covers inspect attribute checks prior to extra212"
    - "inspect_signature.zspec.zsdl — covers inspect.Signature behavior"
    - "inspect.zspec.zsdl — covers core inspect function behavior"
  notes:
    - "inspect.Parameter.__qualname__ == 'Parameter' — Parameter is a class defined in inspect; its __qualname__ is 'Parameter' (9 characters). Verified with Python 3.14.3."
    - "inspect.Signature.__qualname__ == 'Signature' — Signature is a class defined in inspect; its __qualname__ is 'Signature' (9 characters). Verified with Python 3.14.3."
    - "inspect.BoundArguments.__qualname__ == 'BoundArguments' — BoundArguments is a class defined in inspect; its __qualname__ is 'BoundArguments' (14 characters). Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__qualname__ == 'FullArgSpec' — FullArgSpec is a namedtuple-derived class; its __qualname__ is 'FullArgSpec' (11 characters). Verified with Python 3.14.3."
    - "inspect.ArgInfo.__qualname__ == 'ArgInfo' — ArgInfo is a namedtuple-derived class; its __qualname__ is 'ArgInfo' (7 characters). Verified with Python 3.14.3."
    - "inspect.Parameter.__qualname__.__len__() == 9 — 'Parameter' has 9 characters. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__qualname__.__len__() == 14 — 'BoundArguments' has 14 characters. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__qualname__.__len__() == 11 — 'FullArgSpec' has 11 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect __qualname__ equality checks — Parameter, Signature, BoundArguments
#
# Parameter.__qualname__.__eq__('Parameter')         == True
# Signature.__qualname__.__eq__('Signature')         == True
# BoundArguments.__qualname__.__eq__('BoundArguments') == True
# Signature.__qualname__.__eq__('signature')         == False  (case-sensitive)
# ---------------------------------------------------------------------------

table inspect_extra212.qualname_eq_group1:
  description: "inspect __qualname__ equality checks for Parameter, Signature, and BoundArguments in inspectqualname212g1 namespace — Parameter.__qualname__ is 'Parameter' (True), Signature.__qualname__ is 'Signature' (True), BoundArguments.__qualname__ is 'BoundArguments' (True), and Signature.__qualname__.__eq__('signature') is False (case-sensitive); all four rows verified with Python 3.14.3"
  kind: python_call_eq
  category: qualname
  id_prefix: inspectqualname212g1

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_qualname_eq,
       "Parameter.__qualname__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__qualname__.__eq__('Parameter') == True — Parameter is a class defined in inspect; its __qualname__ is 'Parameter' (9 characters); __eq__('Parameter') returns True; verified with Python 3.14.3"]
    - [signature_qualname_eq,
       "Signature.__qualname__.__eq__",
       ["Signature"],
       true,
       "inspect.Signature.__qualname__.__eq__('Signature') == True — Signature is a class defined in inspect; its __qualname__ is 'Signature' (9 characters); __eq__('Signature') returns True; verified with Python 3.14.3"]
    - [boundarguments_qualname_eq,
       "BoundArguments.__qualname__.__eq__",
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__qualname__.__eq__('BoundArguments') == True — BoundArguments is a class defined in inspect; its __qualname__ is 'BoundArguments' (14 characters); __eq__('BoundArguments') returns True; verified with Python 3.14.3"]
    - [signature_qualname_neq_lowercase,
       "Signature.__qualname__.__eq__",
       ["signature"],
       false,
       "inspect.Signature.__qualname__.__eq__('signature') == False — __qualname__ is 'Signature' (capital S); comparing against 'signature' (lowercase s) returns False because __eq__ is case-sensitive; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: inspect __qualname__ equality checks — FullArgSpec, ArgInfo
# plus contains checks
#
# FullArgSpec.__qualname__.__eq__('FullArgSpec')     == True
# ArgInfo.__qualname__.__eq__('ArgInfo')             == True
# BoundArguments.__qualname__.__contains__('Bound')  == True
# FullArgSpec.__qualname__.__contains__('ArgSpec')   == True
# ---------------------------------------------------------------------------

table inspect_extra212.qualname_eq_group2:
  description: "inspect __qualname__ equality and contains checks for FullArgSpec and ArgInfo in inspectqualname212g2 namespace — FullArgSpec.__qualname__ is 'FullArgSpec' (True), ArgInfo.__qualname__ is 'ArgInfo' (True), BoundArguments.__qualname__.__contains__('Bound') is True, FullArgSpec.__qualname__.__contains__('ArgSpec') is True; all four rows verified with Python 3.14.3"
  kind: python_call_eq
  category: qualname
  id_prefix: inspectqualname212g2

  columns: [id, function, args, expected, description]
  rows:
    - [fullargspec_qualname_eq,
       "FullArgSpec.__qualname__.__eq__",
       ["FullArgSpec"],
       true,
       "inspect.FullArgSpec.__qualname__.__eq__('FullArgSpec') == True — FullArgSpec is a namedtuple-derived class in inspect; its __qualname__ is 'FullArgSpec' (11 characters); __eq__('FullArgSpec') returns True; verified with Python 3.14.3"]
    - [arginfo_qualname_eq,
       "ArgInfo.__qualname__.__eq__",
       ["ArgInfo"],
       true,
       "inspect.ArgInfo.__qualname__.__eq__('ArgInfo') == True — ArgInfo is a namedtuple-derived class in inspect; its __qualname__ is 'ArgInfo' (7 characters); __eq__('ArgInfo') returns True; verified with Python 3.14.3"]
    - [boundarguments_qualname_has_bound,
       "BoundArguments.__qualname__.__contains__",
       ["Bound"],
       true,
       "inspect.BoundArguments.__qualname__.__contains__('Bound') == True — the string 'BoundArguments' begins with 'Bound'; __contains__('Bound') returns True; verified with Python 3.14.3"]
    - [fullargspec_qualname_has_argspec,
       "FullArgSpec.__qualname__.__contains__",
       ["ArgSpec"],
       true,
       "inspect.FullArgSpec.__qualname__.__contains__('ArgSpec') == True — the string 'FullArgSpec' contains 'ArgSpec'; __contains__('ArgSpec') returns True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: inspect __qualname__ length checks
#
# Parameter.__qualname__.__len__()       == 9
# Signature.__qualname__.__len__()       == 9
# BoundArguments.__qualname__.__len__()  == 14
# FullArgSpec.__qualname__.__len__()     == 11
# ---------------------------------------------------------------------------

table inspect_extra212.qualname_len:
  description: "inspect __qualname__ length checks in inspectqualname212ln namespace — Parameter has len 9, Signature has len 9, BoundArguments has len 14, FullArgSpec has len 11; all four rows verified with Python 3.14.3"
  kind: python_call_eq
  category: qualname
  id_prefix: inspectqualname212ln

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_qualname_len,
       "Parameter.__qualname__.__len__",
       [],
       9,
       "inspect.Parameter.__qualname__.__len__() == 9 — the string 'Parameter' has exactly 9 characters; verified with Python 3.14.3"]
    - [signature_qualname_len,
       "Signature.__qualname__.__len__",
       [],
       9,
       "inspect.Signature.__qualname__.__len__() == 9 — the string 'Signature' has exactly 9 characters; verified with Python 3.14.3"]
    - [boundarguments_qualname_len,
       "BoundArguments.__qualname__.__len__",
       [],
       14,
       "inspect.BoundArguments.__qualname__.__len__() == 14 — the string 'BoundArguments' has exactly 14 characters; verified with Python 3.14.3"]
    - [fullargspec_qualname_len,
       "FullArgSpec.__qualname__.__len__",
       [],
       11,
       "inspect.FullArgSpec.__qualname__.__len__() == 11 — the string 'FullArgSpec' has exactly 11 characters; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — inspect_extra212
# ---------------------------------------------------------------------------

invariant inspect_extra212.parameter_qualname_eq:
  description: "inspect.Parameter.__qualname__.__eq__('Parameter') == True — Parameter is a class in inspect with __qualname__ 'Parameter'; new to extra212; verified with Python 3.14.3"
  category: qualname
  kind: python_call_eq
  function: "Parameter.__qualname__.__eq__"
  args: ["Parameter"]
  expected: true

invariant inspect_extra212.signature_qualname_eq:
  description: "inspect.Signature.__qualname__.__eq__('Signature') == True — Signature is a class in inspect with __qualname__ 'Signature'; new to extra212; verified with Python 3.14.3"
  category: qualname
  kind: python_call_eq
  function: "Signature.__qualname__.__eq__"
  args: ["Signature"]
  expected: true

invariant inspect_extra212.boundarguments_qualname_eq:
  description: "inspect.BoundArguments.__qualname__.__eq__('BoundArguments') == True — BoundArguments is a class in inspect with __qualname__ 'BoundArguments' (14 chars); new to extra212; verified with Python 3.14.3"
  category: qualname
  kind: python_call_eq
  function: "BoundArguments.__qualname__.__eq__"
  args: ["BoundArguments"]
  expected: true

invariant inspect_extra212.fullargspec_qualname_eq:
  description: "inspect.FullArgSpec.__qualname__.__eq__('FullArgSpec') == True — FullArgSpec is a namedtuple-derived class in inspect with __qualname__ 'FullArgSpec' (11 chars); new to extra212; verified with Python 3.14.3"
  category: qualname
  kind: python_call_eq
  function: "FullArgSpec.__qualname__.__eq__"
  args: ["FullArgSpec"]
  expected: true

invariant inspect_extra212.arginfo_qualname_eq:
  description: "inspect.ArgInfo.__qualname__.__eq__('ArgInfo') == True — ArgInfo is a namedtuple-derived class in inspect with __qualname__ 'ArgInfo' (7 chars); new to extra212; verified with Python 3.14.3"
  category: qualname
  kind: python_call_eq
  function: "ArgInfo.__qualname__.__eq__"
  args: ["ArgInfo"]
  expected: true

invariant inspect_extra212.parameter_qualname_len:
  description: "inspect.Parameter.__qualname__.__len__() == 9 — the string 'Parameter' has exactly 9 characters; new to extra212; verified with Python 3.14.3"
  category: qualname
  kind: python_call_eq
  function: "Parameter.__qualname__.__len__"
  args: []
  expected: 9

invariant inspect_extra212.boundarguments_qualname_len:
  description: "inspect.BoundArguments.__qualname__.__len__() == 14 — the string 'BoundArguments' has exactly 14 characters; new to extra212; verified with Python 3.14.3"
  category: qualname
  kind: python_call_eq
  function: "BoundArguments.__qualname__.__len__"
  args: []
  expected: 14

invariant inspect_extra212.arginfo_qualname_len:
  description: "inspect.ArgInfo.__qualname__.__len__() == 7 — the string 'ArgInfo' has exactly 7 characters; new to extra212; verified with Python 3.14.3"
  category: qualname
  kind: python_call_eq
  function: "ArgInfo.__qualname__.__len__"
  args: []
  expected: 7
