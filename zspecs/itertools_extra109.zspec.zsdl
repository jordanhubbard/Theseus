# ---------------------------------------------------------------------------
# Table 1: itertools C-extension type __new__ method type names — group 1
#
# Wave 261 theme: all itertools types are implemented in C
# (Modules/itertoolsmodule.c). Their __new__ allocator slots are exposed as
# 'builtin_function_or_method' objects — the same type as ordinary C builtin
# functions like len or print. This table covers count, cycle, repeat, chain,
# compress, islice, starmap.
#
# type(itertools.count.__new__).__name__ == 'builtin_function_or_method'
# type(itertools.cycle.__new__).__name__ == 'builtin_function_or_method'
# type(itertools.repeat.__new__).__name__ == 'builtin_function_or_method'
# type(itertools.chain.__new__).__name__ == 'builtin_function_or_method'
# type(itertools.compress.__new__).__name__ == 'builtin_function_or_method'
# type(itertools.islice.__new__).__name__ == 'builtin_function_or_method'
# type(itertools.starmap.__new__).__name__ == 'builtin_function_or_method'
#
# New to extra109.
# ---------------------------------------------------------------------------

table itertools_extra109.new_method_type_group1:
  description: "itertools C-extension type __new__ type name is 'builtin_function_or_method' for count/cycle/repeat/chain/compress/islice/starmap; wave 261; new to extra109"
  kind: python_call_eq
  category: type_identity
  id_prefix: itertoolsnew109

  columns: [id, function, args, expected, description]
  rows:
    - [count_new_type_builtin,
       "count.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.count.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — itertools.count is a C-extension type implemented in Modules/itertoolsmodule.c; its __new__ allocator is a C-level tp_new slot exposed as a 'builtin_function_or_method'; this is the standard type for C-implemented callables; str.__eq__('builtin_function_or_method') returns True; new to extra109"]
    - [cycle_new_type_builtin,
       "cycle.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.cycle.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — itertools.cycle is a C-extension type; its __new__ allocator is exposed as a 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra109"]
    - [repeat_new_type_builtin,
       "repeat.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.repeat.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — itertools.repeat is a C-extension type; its __new__ allocator is exposed as a 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra109"]
    - [chain_new_type_builtin,
       "chain.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.chain.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — itertools.chain is a C-extension type; its __new__ allocator is exposed as a 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra109"]
    - [compress_new_type_builtin,
       "compress.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.compress.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — itertools.compress is a C-extension type; its __new__ allocator is exposed as a 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra109"]
    - [islice_new_type_builtin,
       "islice.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.islice.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — itertools.islice is a C-extension type; its __new__ allocator is exposed as a 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra109"]
    - [starmap_new_type_builtin,
       "starmap.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.starmap.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — itertools.starmap is a C-extension type; its __new__ allocator is exposed as a 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra109"]

