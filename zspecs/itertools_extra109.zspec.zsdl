# ---------------------------------------------------------------------------
# Table 3: itertools C-extension type __new__ qualnames
#
# Wave 261 theme: each itertools C-extension type's __new__ method has a
# __qualname__ following the 'TypeName.__new__' pattern. For example,
# itertools.count.__new__.__qualname__ == 'count.__new__'. This qualname is
# set by CPython when the C type is initialized. All verified types show this
# consistent pattern.
#
# itertools.count.__new__.__qualname__ == 'count.__new__'
# itertools.cycle.__new__.__qualname__ == 'cycle.__new__'
# itertools.repeat.__new__.__qualname__ == 'repeat.__new__'
# itertools.product.__new__.__qualname__ == 'product.__new__'
# itertools.combinations.__new__.__qualname__ == 'combinations.__new__'
# itertools.accumulate.__new__.__qualname__ == 'accumulate.__new__'
# itertools.pairwise.__new__.__qualname__ == 'pairwise.__new__'
#
# New to extra109.
# ---------------------------------------------------------------------------

