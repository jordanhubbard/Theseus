       ["count.__new__"],
       true,
       "itertools.count.__new__.__qualname__.__eq__('count.__new__') == True — itertools.count.__new__ is the C-level allocator for count objects; CPython sets __qualname__ to 'count.__new__' for C type __new__ slots; the dotted form indicates class membership; str.__eq__('count.__new__') returns True; new to extra109"]
    - [cycle_new_qualname_eq,
