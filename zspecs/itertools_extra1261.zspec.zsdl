spec: itertools_extra1261
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Wave 531: itertools has no __all__ (pure C extension); coverage uses __class__.__name__ eq 'type' and __module__ eq 'itertools' for all iterator types, plus __qualname__ identity checks"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table itertools_extra1261.class_name_is_type:
  description: "All itertools iterator objects have __class__.__name__ equal to 'type' (they are C-level type objects)"
  kind: python_call_eq
  category: class_name_type
  id_prefix: it1261cn
  columns: [id, function, args, expected]
  rows:
    - [it1261cn001, itertools.chain.__class__.__name__.__eq__,                        ["type"], true]
    - [it1261cn002, itertools.count.__class__.__name__.__eq__,                        ["type"], true]
    - [it1261cn003, itertools.cycle.__class__.__name__.__eq__,                        ["type"], true]
    - [it1261cn004, itertools.repeat.__class__.__name__.__eq__,                       ["type"], true]
    - [it1261cn005, itertools.accumulate.__class__.__name__.__eq__,                   ["type"], true]
    - [it1261cn006, itertools.compress.__class__.__name__.__eq__,                     ["type"], true]
    - [it1261cn007, itertools.islice.__class__.__name__.__eq__,                       ["type"], true]
    - [it1261cn008, itertools.product.__class__.__name__.__eq__,                      ["type"], true]
    - [it1261cn009, itertools.permutations.__class__.__name__.__eq__,                 ["type"], true]
    - [it1261cn010, itertools.combinations.__class__.__name__.__eq__,                 ["type"], true]
    - [it1261cn011, itertools.dropwhile.__class__.__name__.__eq__,                    ["type"], true]
    - [it1261cn012, itertools.takewhile.__class__.__name__.__eq__,                    ["type"], true]
    - [it1261cn013, itertools.starmap.__class__.__name__.__eq__,                      ["type"], true]
