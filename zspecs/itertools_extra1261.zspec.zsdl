    - [it1261cn015, itertools.groupby.__class__.__name__.__eq__,                      ["type"], true]
    - [it1261cn016, itertools.filterfalse.__class__.__name__.__eq__,                  ["type"], true]
    - [it1261cn017, itertools.pairwise.__class__.__name__.__eq__,                     ["type"], true]
    - [it1261cn018, itertools.combinations_with_replacement.__class__.__name__.__eq__, ["type"], true]

