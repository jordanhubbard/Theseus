spec: copyreg_extra5
version: ">=3.9"
backend: python_module(copyreg)

docs: https://docs.python.org/3/library/copyreg.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/copyreg.html — Python copyreg module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/copyreg.py"
  notes:
    - "This spec extends copyreg.zspec.zsdl through copyreg_extra4.zspec.zsdl."
    - "copyreg covers: dispatch_table type check; pickle/constructor/add_extension/remove_extension/clear_extension_cache __name__ and __module__."
    - "copyreg_extra covers: dispatch_table is dict; __name__ for pickle/constructor/add_extension/remove_extension/clear_extension_cache/__newobj__/__newobj_ex__."
    - "copyreg_extra2 covers: __name__/__module__/__class__.__name__=='function' for pickle/add_extension/remove_extension/clear_extension_cache."
    - "copyreg_extra3 covers: __qualname__ for all seven public functions (pickle/constructor/add_extension/remove_extension/clear_extension_cache/__newobj__/__newobj_ex__)."
    - "copyreg_extra4 covers: __class__.__name__=='function' for constructor/__newobj__/__newobj_ex__; __module__ for __newobj__/__newobj_ex__; constructor.__module__; dispatch_table.__len__(); dispatch_table metaclass; pickle.__doc__ class; __newobj__ qualname len."
    - "NEW in this spec: _reconstructor.__name__, _reconstructor.__qualname__, _reconstructor.__module__, _reconstructor.__class__.__name__ — not covered in any prior copyreg spec; pickle_complex.__name__, pickle_complex.__qualname__, pickle_complex.__module__, pickle_complex.__class__.__name__ — not covered in any prior spec."
    - "copyreg._reconstructor.__name__ == '_reconstructor' — internal helper used by pickle to reconstruct instances."
    - "copyreg._reconstructor.__qualname__ == '_reconstructor' — top-level function, qualname equals name."
    - "copyreg._reconstructor.__module__ == 'copyreg' — defined in the copyreg module."
    - "copyreg._reconstructor.__class__.__name__ == 'function' — a plain Python function."
    - "copyreg.pickle_complex.__name__ == 'pickle_complex' — reducer for complex numbers registered in dispatch_table."
    - "copyreg.pickle_complex.__qualname__ == 'pickle_complex' — top-level function, qualname equals name."
    - "copyreg.pickle_complex.__module__ == 'copyreg' — defined in the copyreg module."
    - "copyreg.pickle_complex.__class__.__name__ == 'function' — a plain Python function."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# _reconstructor — name, qualname, module, class
#
# copyreg._reconstructor is the internal helper function used by pickle
# to reconstruct class instances via __reduce__/__reduce_ex__. No prior
# copyreg spec covers any attribute of _reconstructor.
# ---------------------------------------------------------------------------

invariant copyreg_extra5._reconstructor.name:
  description: "copyreg._reconstructor.__name__ == '_reconstructor' — internal pickle reconstruction helper"
  category: function_names
  kind: python_call_eq
  function: _reconstructor.__name__.__eq__
  args: ["_reconstructor"]
  expected: true

invariant copyreg_extra5._reconstructor.qualname:
  description: "copyreg._reconstructor.__qualname__ == '_reconstructor' — top-level function, qualname equals name"
  category: qualname
  kind: python_call_eq
  function: _reconstructor.__qualname__.__eq__
  args: ["_reconstructor"]
  expected: true

invariant copyreg_extra5._reconstructor.module:
  description: "copyreg._reconstructor.__module__ == 'copyreg' — defined at module top level"
  category: module
  kind: python_call_eq
  function: _reconstructor.__module__.__eq__
  args: ["copyreg"]
  expected: true

invariant copyreg_extra5._reconstructor.class_name:
  description: "copyreg._reconstructor.__class__.__name__ == 'function' — _reconstructor is a plain Python function"
  category: callable_type
  kind: python_call_eq
  function: _reconstructor.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# pickle_complex — name, qualname, module, class
#
# copyreg.pickle_complex is the reducer registered in dispatch_table for the
# built-in complex type. No prior copyreg spec covers any attribute of
# pickle_complex. Like all module-level copyreg functions, its qualname equals
# its name and its module is 'copyreg'.
# ---------------------------------------------------------------------------

invariant copyreg_extra5.pickle_complex.name:
  description: "copyreg.pickle_complex.__name__ == 'pickle_complex' — reducer for complex numbers"
  category: function_names
  kind: python_call_eq
  function: pickle_complex.__name__.__eq__
  args: ["pickle_complex"]
  expected: true

invariant copyreg_extra5.pickle_complex.qualname:
  description: "copyreg.pickle_complex.__qualname__ == 'pickle_complex' — top-level function, qualname equals name"
  category: qualname
  kind: python_call_eq
  function: pickle_complex.__qualname__.__eq__
  args: ["pickle_complex"]
  expected: true

invariant copyreg_extra5.pickle_complex.module:
  description: "copyreg.pickle_complex.__module__ == 'copyreg' — defined at module top level"
  category: module
  kind: python_call_eq
  function: pickle_complex.__module__.__eq__
  args: ["copyreg"]
  expected: true

invariant copyreg_extra5.pickle_complex.class_name:
  description: "copyreg.pickle_complex.__class__.__name__ == 'function' — pickle_complex is a plain Python function"
  category: callable_type
  kind: python_call_eq
  function: pickle_complex.__class__.__name__.__eq__
  args: ["function"]
  expected: true
