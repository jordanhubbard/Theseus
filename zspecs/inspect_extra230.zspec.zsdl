spec: inspect_extra230
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers inspect.stack, inspect.currentframe, and inspect.getframeinfo identity contracts."
    - "inspect.stack.__name__ == 'stack' — top-level function in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.stack.__module__ == 'inspect' — defined in the inspect module. Verified with Python 3.14.3."
    - "inspect.currentframe.__name__ == 'currentframe' — built-in function from sys module exposed via inspect. Verified with Python 3.14.3."
    - "inspect.currentframe.__module__ == 'inspect' — currentframe is re-exported via inspect. Verified with Python 3.14.3."
    - "inspect.getframeinfo.__name__ == 'getframeinfo' — top-level function in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.getframeinfo.__module__ == 'inspect' — defined in the inspect module. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__name__ == 'FrameInfo' — named tuple class for frame information. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__module__ == 'inspect' — FrameInfo is defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.currentframe.__name__.__len__() == 12 — 'currentframe' has 12 characters. Verified with Python 3.14.3."
    - "inspect.getframeinfo.__name__.__len__() == 12 — 'getframeinfo' has 12 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.stack identity contracts
#
# inspect.stack.__name__ == 'stack'
# inspect.stack.__qualname__ == 'stack'
# inspect.stack.__module__ == 'inspect'
# inspect.stack.__name__.__len__() == 5
# inspect.stack.__qualname__.__len__() == 5
#
# New to extra230.
# ---------------------------------------------------------------------------

table inspect_extra230.stack_identity:
  description: "inspect.stack identity contracts: __name__, __qualname__, __module__, name length; new to extra230"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra230stackid

  columns: [id, function, args, expected, description]
  rows:
    - [stack_name_eq,
       stack.__name__.__eq__,
       ["stack"],
       true,
       "inspect.stack.__name__ == 'stack' — stack is a top-level function in Lib/inspect.py that returns the call stack; __name__.__eq__('stack') returns True; new to extra230"]
    - [stack_qualname_eq,
       stack.__qualname__.__eq__,
       ["stack"],
       true,
       "inspect.stack.__qualname__ == 'stack' — stack is a top-level function with unqualified qualname 'stack'; __qualname__.__eq__('stack') returns True; new to extra230"]
    - [stack_module_eq,
       stack.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.stack.__module__ == 'inspect' — stack is defined in the Python inspect module (Lib/inspect.py); __module__.__eq__('inspect') returns True; new to extra230"]
    - [stack_name_len_5,
       stack.__name__.__len__,
       [],
       5,
       "inspect.stack.__name__.__len__() == 5 — 'stack' has exactly 5 characters (s-t-a-c-k); __len__() returns 5; new to extra230"]
    - [stack_qualname_len_5,
       stack.__qualname__.__len__,
       [],
       5,
       "inspect.stack.__qualname__.__len__() == 5 — qualname 'stack' has exactly 5 characters; __len__() returns 5; new to extra230"]

# ---------------------------------------------------------------------------
# Table 2: inspect.currentframe identity contracts
#
# inspect.currentframe.__name__ == 'currentframe'
# inspect.currentframe.__module__ == 'inspect'
# inspect.currentframe.__name__.__len__() == 12
# inspect.getframeinfo.__name__ == 'getframeinfo'
# inspect.getframeinfo.__module__ == 'inspect'
#
# New to extra230.
# ---------------------------------------------------------------------------

table inspect_extra230.currentframe_getframeinfo_identity:
  description: "inspect.currentframe and getframeinfo identity contracts: __name__, __module__, name lengths; new to extra230"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra230cframeid

  columns: [id, function, args, expected, description]
  rows:
    - [currentframe_name_eq,
       currentframe.__name__.__eq__,
       ["currentframe"],
       true,
       "inspect.currentframe.__name__ == 'currentframe' — currentframe is a built-in function re-exported via Lib/inspect.py to return the current stack frame; __name__.__eq__('currentframe') returns True; new to extra230"]
    - [currentframe_module_eq,
       currentframe.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.currentframe.__module__ == 'inspect' — currentframe is re-exported through Lib/inspect.py and reports its module as 'inspect'; __module__.__eq__('inspect') returns True; new to extra230"]
    - [currentframe_name_len_12,
       currentframe.__name__.__len__,
       [],
       12,
       "inspect.currentframe.__name__.__len__() == 12 — 'currentframe' has exactly 12 characters (c-u-r-r-e-n-t-f-r-a-m-e); __len__() returns 12; new to extra230"]
    - [getframeinfo_name_eq,
       getframeinfo.__name__.__eq__,
       ["getframeinfo"],
       true,
       "inspect.getframeinfo.__name__ == 'getframeinfo' — getframeinfo is a top-level function in Lib/inspect.py that returns a named tuple describing a frame; __name__.__eq__('getframeinfo') returns True; new to extra230"]
    - [getframeinfo_module_eq,
       getframeinfo.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getframeinfo.__module__ == 'inspect' — getframeinfo is defined in the Python inspect module (Lib/inspect.py); __module__.__eq__('inspect') returns True; new to extra230"]

# ---------------------------------------------------------------------------
# Table 3: inspect.FrameInfo and getframeinfo length contracts
#
# inspect.FrameInfo.__name__ == 'FrameInfo'
# inspect.FrameInfo.__module__ == 'inspect'
# inspect.getframeinfo.__name__.__len__() == 12
# inspect.getframeinfo.__qualname__ == 'getframeinfo'
# inspect.FrameInfo.__name__.__len__() == 9
#
# New to extra230.
# ---------------------------------------------------------------------------

table inspect_extra230.frameinfo_class_identity:
  description: "inspect.FrameInfo class identity and getframeinfo length contracts; new to extra230"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra230frameinfoclass

  columns: [id, function, args, expected, description]
  rows:
    - [FrameInfo_name_eq,
       FrameInfo.__name__.__eq__,
       ["FrameInfo"],
       true,
       "inspect.FrameInfo.__name__ == 'FrameInfo' — FrameInfo is a named tuple class in Lib/inspect.py for describing call stack frames; __name__.__eq__('FrameInfo') returns True; new to extra230"]
    - [FrameInfo_module_eq,
       FrameInfo.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.FrameInfo.__module__ == 'inspect' — FrameInfo is defined in Lib/inspect.py; __module__.__eq__('inspect') returns True; new to extra230"]
    - [getframeinfo_name_len_12,
       getframeinfo.__name__.__len__,
       [],
       12,
       "inspect.getframeinfo.__name__.__len__() == 12 — 'getframeinfo' has exactly 12 characters (g-e-t-f-r-a-m-e-i-n-f-o); __len__() returns 12; new to extra230"]
    - [getframeinfo_qualname_eq,
       getframeinfo.__qualname__.__eq__,
       ["getframeinfo"],
       true,
       "inspect.getframeinfo.__qualname__ == 'getframeinfo' — getframeinfo is a top-level function with unqualified qualname; __qualname__.__eq__('getframeinfo') returns True; new to extra230"]
    - [FrameInfo_name_len_9,
       FrameInfo.__name__.__len__,
       [],
       9,
       "inspect.FrameInfo.__name__.__len__() == 9 — 'FrameInfo' has exactly 9 characters (F-r-a-m-e-I-n-f-o); __len__() returns 9; new to extra230"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra230
# ---------------------------------------------------------------------------

invariant inspect_extra230.stack_name_eq:
  description: "inspect.stack.__name__ == 'stack'; new to extra230"
  kind: python_call_eq
  function: stack.__name__.__eq__
  args: ["stack"]
  expected: true

invariant inspect_extra230.stack_qualname_eq:
  description: "inspect.stack.__qualname__ == 'stack'; new to extra230"
  kind: python_call_eq
  function: stack.__qualname__.__eq__
  args: ["stack"]
  expected: true

invariant inspect_extra230.stack_module_eq:
  description: "inspect.stack.__module__ == 'inspect'; new to extra230"
  kind: python_call_eq
  function: stack.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra230.stack_name_len_5:
  description: "inspect.stack.__name__.__len__() == 5 — 'stack' has 5 characters; new to extra230"
  kind: python_call_eq
  function: stack.__name__.__len__
  args: []
  expected: 5

invariant inspect_extra230.currentframe_name_eq:
  description: "inspect.currentframe.__name__ == 'currentframe'; new to extra230"
  kind: python_call_eq
  function: currentframe.__name__.__eq__
  args: ["currentframe"]
  expected: true

invariant inspect_extra230.currentframe_module_eq:
  description: "inspect.currentframe.__module__ == 'inspect'; new to extra230"
  kind: python_call_eq
  function: currentframe.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra230.currentframe_name_len_12:
  description: "inspect.currentframe.__name__.__len__() == 12 — 'currentframe' has 12 characters; new to extra230"
  kind: python_call_eq
  function: currentframe.__name__.__len__
  args: []
  expected: 12

invariant inspect_extra230.getframeinfo_name_eq:
  description: "inspect.getframeinfo.__name__ == 'getframeinfo'; new to extra230"
  kind: python_call_eq
  function: getframeinfo.__name__.__eq__
  args: ["getframeinfo"]
  expected: true

invariant inspect_extra230.getframeinfo_module_eq:
  description: "inspect.getframeinfo.__module__ == 'inspect'; new to extra230"
  kind: python_call_eq
  function: getframeinfo.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra230.getframeinfo_name_len_12:
  description: "inspect.getframeinfo.__name__.__len__() == 12 — 'getframeinfo' has 12 characters; new to extra230"
  kind: python_call_eq
  function: getframeinfo.__name__.__len__
  args: []
  expected: 12

invariant inspect_extra230.FrameInfo_name_eq:
  description: "inspect.FrameInfo.__name__ == 'FrameInfo'; new to extra230"
  kind: python_call_eq
  function: FrameInfo.__name__.__eq__
  args: ["FrameInfo"]
  expected: true

invariant inspect_extra230.FrameInfo_module_eq:
  description: "inspect.FrameInfo.__module__ == 'inspect'; new to extra230"
  kind: python_call_eq
  function: FrameInfo.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra230.FrameInfo_name_len_9:
  description: "inspect.FrameInfo.__name__.__len__() == 9 — 'FrameInfo' has 9 characters; new to extra230"
  kind: python_call_eq
  function: FrameInfo.__name__.__len__
  args: []
  expected: 9
