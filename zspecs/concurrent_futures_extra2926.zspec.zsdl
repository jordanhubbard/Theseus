spec: cf2926
version: ">=3.9"
error_model: python_exceptions
provenance:
  derived_from: [concurrent.futures source, Python docs, https://docs.python.org/3/library/concurrent.futures.html]
  not_derived_from: [any external dataset, concurrent_futures_extra2911.zspec.zsdl — covers __ilshift__/__irshift__/__ipow__ dict-presence, concurrent_futures_extra2896.zspec.zsdl — covers __itruediv__/__ifloordiv__/__imod__ dict-presence, concurrent_futures_extra2881.zspec.zsdl — covers __iadd__/__isub__/__imul__ dict-presence, concurrent_futures_extra2866.zspec.zsdl — covers __rand__/__ror__/__rxor__ dict-presence]
  notes: [Wave 642 theme — __iand__/__ior__/__ixor__ dict-presence checks for concurrent.futures types. In-place bitwise AND, OR, XOR operators. Future/ThreadPoolExecutor/ProcessPoolExecutor/CancelledError/TimeoutError/BrokenExecutor/InvalidStateError are concurrency primitives not set or bitfield types — none define these dunders. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0 2026-04-13.]
  created_at: "2026-04-13"

table cf2926.iand:
  kind: python_call_eq
  columns: [id, function, args, expected]
  rows:
    - ["cf2926001", operator.contains, [concurrent.futures.Future.__dict__, "__iand__"], false]
    - ["cf2926002", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__, "__iand__"], false]
    - ["cf2926003", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__iand__"], false]
    - ["cf2926004", operator.contains, [concurrent.futures.CancelledError.__dict__, "__iand__"], false]
