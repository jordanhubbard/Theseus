# ---------------------------------------------------------------------------
# Standalone invariants — extra1441
# ---------------------------------------------------------------------------

invariant itertools_extra1441.chain_subclasshook_is_builtin:
  description: "itertools.chain.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — inherited from object; wave 543; new to extra1441"
  kind: python_call_eq
  function: chain.__subclasshook__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant itertools_extra1441.chain_subclasshook_not_in_dict:
  description: "'__subclasshook__' not in itertools.chain.__dict__ — chain does not override __subclasshook__; wave 543; new to extra1441"
  kind: python_call_eq
  function: chain.__dict__.__contains__
  args: ["__subclasshook__"]
  expected: false

invariant itertools_extra1441.chain_instancecheck_not_in_dict:
  description: "'__instancecheck__' not in itertools.chain.__dict__ — chain does not define __instancecheck__; wave 543; new to extra1441"
  kind: python_call_eq
  function: chain.__dict__.__contains__
  args: ["__instancecheck__"]
  expected: false

invariant itertools_extra1441.chain_subclasscheck_not_in_dict:
  description: "'__subclasscheck__' not in itertools.chain.__dict__ — chain does not define __subclasscheck__; wave 543; new to extra1441"
