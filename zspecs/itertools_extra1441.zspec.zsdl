spec: itertools_extra1441
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "itertools_extra1426.zspec.zsdl — covers __format__ and __dir__ checks for itertools classes"
  notes:
    - "Wave 543 (_extra1441): focuses on __subclasshook__, __instancecheck__, and __subclasscheck__ ABC-machinery checks for itertools classes."
    - "itertools.chain.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — chain is a C extension type; __subclasshook__ inherited from object. Verified Python 3.14.3."
    - "itertools.count.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3."
    - "itertools.cycle.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3."
    - "itertools.repeat.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3."
    - "itertools.accumulate.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3."
    - "itertools.combinations.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3."
    - "itertools.product.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3."
    - "itertools.islice.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3."
    - "None of chain, count, cycle, repeat, accumulate, combinations, product, islice define '__subclasshook__', '__instancecheck__', or '__subclasscheck__' in their own __dict__. Verified Python 3.14.3."
    - "All itertools classes are C extension types with metaclass=type; none use ABCMeta. Verified Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools class __subclasshook__ method type checks
#
# Wave 543 theme: __subclasshook__.__class__.__name__ checks for itertools
# classes. All eight classes — chain, count, cycle, repeat, accumulate,
# combinations, product, islice — inherit __subclasshook__ from object.
# The attribute resolves as 'builtin_function_or_method'.
# ---------------------------------------------------------------------------

table itertools_extra1441.subclasshook_class_name:
  description: "itertools classes: __subclasshook__.__class__.__name__ == 'builtin_function_or_method' for chain, count, cycle, repeat, accumulate, combinations, product, islice; wave 543; new to extra1441"
  kind: python_call_eq
  category: subclasshook_class_name
  id_prefix: it1441sc

  columns: [id, function, args, expected, description]
  rows:
    - [it1441sc001,
       "chain.__subclasshook__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.chain.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') == True — chain is a C extension type; __subclasshook__ inherited from object, not ABCMeta; new to extra1441"]
    - [it1441sc002,
       "count.__subclasshook__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.count.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') == True — count inherits __subclasshook__ from object; new to extra1441"]
    - [it1441sc003,
       "cycle.__subclasshook__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.cycle.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') == True — cycle inherits __subclasshook__ from object; new to extra1441"]
    - [it1441sc004,
       "repeat.__subclasshook__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.repeat.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') == True — repeat inherits __subclasshook__ from object; new to extra1441"]
    - [it1441sc005,
       "accumulate.__subclasshook__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.accumulate.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') == True — accumulate inherits __subclasshook__ from object; new to extra1441"]
    - [it1441sc006,
       "combinations.__subclasshook__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.combinations.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') == True — combinations inherits __subclasshook__ from object; new to extra1441"]
    - [it1441sc007,
       "product.__subclasshook__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
