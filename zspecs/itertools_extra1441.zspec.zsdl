#
# Wave 543 theme: '__subclasshook__' not in own __dict__ for itertools classes.
# All eight classes are C extension types with no ABC hooks in their own dicts.
# ---------------------------------------------------------------------------

table itertools_extra1441.subclasshook_dict_membership:
  description: "itertools classes: '__subclasshook__' not in own __dict__ for chain, count, cycle, repeat, accumulate, combinations, product, islice; wave 543; new to extra1441"
