spec: re3166
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 658 (re3166): __add__, __sub__, __mul__ dict-presence checks for re types."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "No re class defines __add__ in its own __dict__: re.RegexFlag is an IntFlag but does not define __add__ directly in its __dict__."
    - "No re class defines __sub__ in its own __dict__: compiled patterns and match objects are read-only; RegexFlag inherits arithmetic if any."
    - "No re class defines __mul__ in its own __dict__: re types have no arithmetic protocol."
    - "re.RegexFlag is an IntFlag subclass; arithmetic operators are inherited from int/IntFlag base classes, not defined in re.RegexFlag.__dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __add__ dict-presence — operator.contains(Cls.__dict__, '__add__')
#
# No re class defines __add__ in its own __dict__; all false.
# re.Pattern and re.Match are read-only objects; re.RegexFlag is an IntFlag whose
# arithmetic operators are inherited from base classes, not stored in its own __dict__.
# ---------------------------------------------------------------------------

table re3166.add:
  description: "re types __add__ dict-presence checks; wave 658"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3166

  columns: [id, function, args, expected]
  rows:
    - ["re3166001", operator.contains, [re.Pattern.__dict__,   "__add__"], false]
    - ["re3166002", operator.contains, [re.Match.__dict__,     "__add__"], false]
    - ["re3166003", operator.contains, [re.RegexFlag.__dict__, "__add__"], false]

