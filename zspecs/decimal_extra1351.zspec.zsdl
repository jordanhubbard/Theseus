spec: decimal_extra1351
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module Decimal, Context, DecimalException, InvalidOperation, DivisionByZero, Overflow documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 537 (_extra1351): focuses on __slots__ and __weakref__ attribute checks at the class __dict__ level."
    - "decimal.Decimal is a C extension type (_decimal module); it does not define __slots__, __weakref__, or __dict__ in its class __dict__."
    - "decimal.Context is a C extension type; it does not define __slots__, __weakref__, or __dict__ in its class __dict__."
    - "decimal.DecimalException is a pure-Python exception class at the top of the decimal exception hierarchy; it defines __weakref__ in its own __dict__ (True) because it is the first Python-level class in its MRO that is not already adding __weakref__."
    - "decimal.InvalidOperation, decimal.DivisionByZero, and decimal.Overflow are all subclasses of decimal.DecimalException; they do not define __weakref__ in their own __dict__ because __weakref__ is already provided by their parent DecimalException."
    - "None of the decimal exception subclasses define __slots__ or __dict__ in their own class __dict__."
    - "decimal.Decimal.__dict__.__contains__('__slots__') is False — C extension type; decimal.DecimalException.__dict__.__contains__('__weakref__') is True — top-level Python exception class."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table decimal_extra1351.Decimal_Context_slots_weakref_dict:
  description: "decimal.Decimal and decimal.Context __slots__, __weakref__, and __dict__ membership in class __dict__: both are C extension types; neither defines __slots__, __weakref__, or __dict__ in their own class __dict__; verified with Python 3.12"
  kind: python_call_eq
  category: slots_weakref_dict_checks
  id_prefix: dc1351dc
  columns: [id, function, args, expected]
  rows:
    - [dc1351dc001, decimal.Decimal.__dict__.__contains__, ["__slots__"],   false]
    - [dc1351dc002, decimal.Decimal.__dict__.__contains__, ["__weakref__"], false]
    - [dc1351dc003, decimal.Decimal.__dict__.__contains__, ["__dict__"],    false]
    - [dc1351dc004, decimal.Context.__dict__.__contains__, ["__slots__"],   false]
    - [dc1351dc005, decimal.Context.__dict__.__contains__, ["__weakref__"], false]
    - [dc1351dc006, decimal.Context.__dict__.__contains__, ["__dict__"],    false]

table decimal_extra1351.DecimalException_slots_weakref_dict:
  description: "decimal.DecimalException __slots__, __weakref__, and __dict__ checks: DecimalException is a pure-Python exception class at the top of the decimal exception hierarchy; it defines __weakref__ (True) but not __slots__ or __dict__; verified with Python 3.12"
  kind: python_call_eq
  category: slots_weakref_dict_checks
  id_prefix: dc1351de
  columns: [id, function, args, expected]
  rows:
    - [dc1351de001, decimal.DecimalException.__dict__.__contains__, ["__slots__"],   false]
    - [dc1351de002, decimal.DecimalException.__dict__.__contains__, ["__weakref__"], true]
    - [dc1351de003, decimal.DecimalException.__dict__.__contains__, ["__dict__"],    false]
    - [dc1351de004, decimal.InvalidOperation.__dict__.__contains__, ["__slots__"],   false]
    - [dc1351de005, decimal.InvalidOperation.__dict__.__contains__, ["__weakref__"], false]
    - [dc1351de006, decimal.InvalidOperation.__dict__.__contains__, ["__dict__"],    false]

table decimal_extra1351.DivisionByZero_Overflow_slots_weakref_dict:
  description: "decimal.DivisionByZero and decimal.Overflow __slots__, __weakref__, and __dict__ checks: both are subclasses of DecimalException; neither defines __slots__, __weakref__, or __dict__ in their own class __dict__ (__weakref__ is inherited from DecimalException); verified with Python 3.12"
  kind: python_call_eq
  category: slots_weakref_dict_checks
  id_prefix: dc1351do
  columns: [id, function, args, expected]
  rows:
    - [dc1351do001, decimal.DivisionByZero.__dict__.__contains__, ["__slots__"],   false]
    - [dc1351do002, decimal.DivisionByZero.__dict__.__contains__, ["__weakref__"], false]
    - [dc1351do003, decimal.DivisionByZero.__dict__.__contains__, ["__dict__"],    false]
    - [dc1351do004, decimal.Overflow.__dict__.__contains__, ["__slots__"],   false]
    - [dc1351do005, decimal.Overflow.__dict__.__contains__, ["__weakref__"], false]
    - [dc1351do006, decimal.Overflow.__dict__.__contains__, ["__dict__"],    false]
