spec: functools_extra2206
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2206: rich comparison operator protocol dict-presence — __lt__, __le__, __gt__, __ge__, __eq__, __ne__."
    - "functools.partial does NOT define any of the six comparison operators in its own __dict__. It is a C extension type that inherits comparison from object."
    - "functools.partialmethod does NOT define any comparison operators in its own __dict__. It is a pure-Python class that relies on inherited object identity comparison."
    - "functools.cached_property does NOT define any comparison operators in its own __dict__. It is a descriptor class with no ordering semantics."
    - "functools._lru_cache_wrapper does NOT define any comparison operators in its own __dict__. It is a C extension type wrapping a callable."
    - "functools.partial does define __call__, __repr__, __reduce__, __get__, __new__, __dict__, __module__, __doc__, __class_getitem__, __setstate__."
    - "functools.partialmethod does define __get__, __repr__, __new__, __dict__, __module__, __doc__, __weakref__, __isabstractmethod__, __class_getitem__."
    - "functools.cached_property does define __get__, __set_name__, __init__, __dict__, __module__, __doc__, __weakref__, __class_getitem__."
    - "functools._lru_cache_wrapper does define __call__, __get__, __copy__, __deepcopy__, __reduce__, __new__, __dict__, __module__, __doc__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table functools_extra2206.partial_comparison_protocol:
  description: "functools.partial dict-presence — no comparison operators defined; inherits from object"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2206

  columns: [id, function, args, expected]
  rows:
    - ["ft2206001", "functools.partial.__dict__.__contains__", ["__lt__"], false]
    - ["ft2206002", "functools.partial.__dict__.__contains__", ["__le__"], false]
    - ["ft2206003", "functools.partial.__dict__.__contains__", ["__gt__"], false]
    - ["ft2206004", "functools.partial.__dict__.__contains__", ["__ge__"], false]
    - ["ft2206005", "functools.partial.__dict__.__contains__", ["__eq__"], false]
    - ["ft2206006", "functools.partial.__dict__.__contains__", ["__ne__"], false]
    - ["ft2206007", "functools.partial.__dict__.__contains__", ["__call__"], true]
    - ["ft2206008", "functools.partial.__dict__.__contains__", ["__repr__"], true]

