spec: array_extra25
version: ">=3.9"
backend: python_module(array)

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/array.html — Python array module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/arraymodule.c"
    - "array_extra21.zspec.zsdl — covers __qualname__ for append/extend/pop/insert/remove/reverse/tolist/tobytes/frombytes."
    - "array_extra22.zspec.zsdl — covers __qualname__ for buffer_info/byteswap/index; array.__qualname__; ArrayType.__qualname__."
    - "array_extra23.zspec.zsdl — covers __qualname__ for count/fromlist/fromfile/tofile/__len__/__iter__."
    - "array_extra24.zspec.zsdl — covers __qualname__ for __add__/__contains__/__repr__/__eq__/__mul__/__getitem__/__setitem__/__delitem__; module __name__/__package__ attrs."
  notes:
    - "This spec extends array_extra24.zspec.zsdl."
    - "Focus: __qualname__ for in-place and comparison operator dunders (__iadd__/__imul__/__rmul__/__ne__/__lt__/__le__/__gt__/__ge__); utility methods fromunicode/tounicode/clear; allocation dunders __new__/__sizeof__."
    - "array.array.__iadd__.__qualname__ == 'array.__iadd__' — in-place addition; not covered in extra21-24. Verified."
    - "array.array.__imul__.__qualname__ == 'array.__imul__' — in-place multiplication. Verified."
    - "array.array.__rmul__.__qualname__ == 'array.__rmul__' — reflected multiplication. Verified."
    - "array.array.__ne__.__qualname__ == 'array.__ne__' — inequality comparison. Verified."
    - "array.array.__lt__.__qualname__ == 'array.__lt__' — less-than comparison. Verified."
    - "array.array.__le__.__qualname__ == 'array.__le__' — less-than-or-equal comparison. Verified."
    - "array.array.__gt__.__qualname__ == 'array.__gt__' — greater-than comparison. Verified."
    - "array.array.__ge__.__qualname__ == 'array.__ge__' — greater-than-or-equal comparison. Verified."
    - "array.array.fromunicode.__qualname__ == 'array.fromunicode' — unicode data import method. Verified."
    - "array.array.tounicode.__qualname__ == 'array.tounicode' — unicode data export method. Verified."
    - "array.array.clear.__qualname__ == 'array.clear' — clears all items. Verified."
    - "array.array.__new__.__qualname__ == 'array.__new__' — allocation dunder. Verified."
    - "array.array.__sizeof__.__qualname__ == 'array.__sizeof__' — memory-size dunder. Verified."
    - "len('array.__iadd__') == 14, len('array.__imul__') == 14, len('array.__rmul__') == 14."
    - "len('array.__ne__') == 12, len('array.__lt__') == 12, len('array.__le__') == 12."
    - "len('array.__gt__') == 12, len('array.__ge__') == 12."
    - "len('array.fromunicode') == 17, len('array.tounicode') == 15, len('array.clear') == 11."
    - "len('array.__new__') == 13, len('array.__sizeof__') == 16. All verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __qualname__ for in-place and reflected operator dunders
#
# array_extra24 covers: __add__, __contains__, __repr__, __eq__, __mul__,
#   __getitem__, __setitem__, __delitem__.
# No prior spec covers __qualname__ for: __iadd__, __imul__, __rmul__,
#   __ne__, __lt__, __le__, __gt__, __ge__.
# These are the in-place, reflected, and remaining comparison operator methods.
# All have qualname of the form 'array.<method_name>'.
# Verified: all eight yield expected qualnames.
# ---------------------------------------------------------------------------

table array_extra25.inplace_and_comparison_qualnames:
  description: "array.array in-place/reflected/comparison operator dunder __qualname__ values — not covered in extra21-24"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: aqn25a

  columns: [id, function, args, expected]
  rows:
    - [iadd, "array.__iadd__.__qualname__.__eq__", ["array.__iadd__"], true]
    - [imul, "array.__imul__.__qualname__.__eq__", ["array.__imul__"], true]
    - [rmul, "array.__rmul__.__qualname__.__eq__", ["array.__rmul__"], true]
    - [ne,   "array.__ne__.__qualname__.__eq__",   ["array.__ne__"],   true]
    - [lt,   "array.__lt__.__qualname__.__eq__",   ["array.__lt__"],   true]
    - [le,   "array.__le__.__qualname__.__eq__",   ["array.__le__"],   true]
    - [gt,   "array.__gt__.__qualname__.__eq__",   ["array.__gt__"],   true]
    - [ge,   "array.__ge__.__qualname__.__eq__",   ["array.__ge__"],   true]

# ---------------------------------------------------------------------------
# Table: __qualname__.__len__() for in-place and comparison operator dunders
#
# No prior spec checks qualname lengths for any of these eight dunders.
# Length checks provide an independent cross-validation axis.
# Verified: __iadd__=14, __imul__=14, __rmul__=14, __ne__=12,
#   __lt__=12, __le__=12, __gt__=12, __ge__=12.
# ---------------------------------------------------------------------------

table array_extra25.inplace_and_comparison_qualname_lengths:
  description: "array.array in-place/comparison dunder __qualname__.__len__() — length cross-checks"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: aqlen25a

  columns: [id, function, args, expected]
  rows:
    - [iadd, "array.__iadd__.__qualname__.__len__", [], 14]
    - [imul, "array.__imul__.__qualname__.__len__", [], 14]
    - [rmul, "array.__rmul__.__qualname__.__len__", [], 14]
    - [ne,   "array.__ne__.__qualname__.__len__",   [], 12]
    - [lt,   "array.__lt__.__qualname__.__len__",   [], 12]
    - [le,   "array.__le__.__qualname__.__len__",   [], 12]
    - [gt,   "array.__gt__.__qualname__.__len__",   [], 12]
    - [ge,   "array.__ge__.__qualname__.__len__",   [], 12]

# ---------------------------------------------------------------------------
# Table: __qualname__ for fromunicode/tounicode/clear/__new__/__sizeof__
#
# No prior spec covers __qualname__ for these methods. fromunicode and
# tounicode handle unicode-mode arrays ('u' typecode). clear was added in
# Python 3.13 but is present in earlier versions via the C implementation.
# __new__ and __sizeof__ are allocation/introspection dunders.
# Verified: fromunicode='array.fromunicode', tounicode='array.tounicode',
#   clear='array.clear', __new__='array.__new__', __sizeof__='array.__sizeof__'.
# ---------------------------------------------------------------------------

table array_extra25.utility_and_alloc_qualnames:
  description: "array.array fromunicode/tounicode/clear/__new__/__sizeof__ __qualname__ values"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: aqn25b

  columns: [id, function, args, expected]
  rows:
    - [fromunicode, "array.fromunicode.__qualname__.__eq__", ["array.fromunicode"], true]
    - [tounicode,   "array.tounicode.__qualname__.__eq__",   ["array.tounicode"],   true]
    - [clear,       "array.clear.__qualname__.__eq__",       ["array.clear"],       true]
    - [new,         "array.__new__.__qualname__.__eq__",     ["array.__new__"],     true]
    - [sizeof,      "array.__sizeof__.__qualname__.__eq__",  ["array.__sizeof__"],  true]

# ---------------------------------------------------------------------------
# Table: __qualname__.__len__() for fromunicode/tounicode/clear/__new__/__sizeof__
#
# No prior spec covers qualname lengths for these methods.
# Verified: fromunicode=17, tounicode=15, clear=11, __new__=13, __sizeof__=16.
# ---------------------------------------------------------------------------

table array_extra25.utility_and_alloc_qualname_lengths:
  description: "array.array fromunicode/tounicode/clear/__new__/__sizeof__ __qualname__.__len__() — length cross-checks"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: aqlen25b

  columns: [id, function, args, expected]
  rows:
    - [fromunicode, "array.fromunicode.__qualname__.__len__", [], 17]
    - [tounicode,   "array.tounicode.__qualname__.__len__",   [], 15]
    - [clear,       "array.clear.__qualname__.__len__",       [], 11]
    - [new,         "array.__new__.__qualname__.__len__",     [], 13]
    - [sizeof,      "array.__sizeof__.__qualname__.__len__",  [], 16]

# ---------------------------------------------------------------------------
# Standalone: array.array.__iadd__.__qualname__ == 'array.__iadd__'
#
# __iadd__ implements the += in-place addition operator for array objects.
# extra24 covers __add__ but not __iadd__. No prior spec covers any in-place
# operator dunder for array.array. This standalone anchors the pattern.
# Verified: array.array.__iadd__.__qualname__ == 'array.__iadd__'.
# ---------------------------------------------------------------------------

invariant array_extra25.array.iadd_qualname:
  description: "array.array.__iadd__.__qualname__ == 'array.__iadd__' — in-place addition operator; first in-place dunder covered in array specs"
  category: method_qualnames
  kind: python_call_eq
  function: "array.__iadd__.__qualname__.__eq__"
  args: ["array.__iadd__"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: array.array.__new__.__qualname__ == 'array.__new__'
#
# __new__ is the object allocation hook for array instances. No prior spec
# covers any allocation-related dunder for array.array. The qualname follows
# the standard 'array.<method>' pattern for C extension type dunders.
# Verified: array.array.__new__.__qualname__ == 'array.__new__'.
# ---------------------------------------------------------------------------

invariant array_extra25.array.new_qualname:
  description: "array.array.__new__.__qualname__ == 'array.__new__' — object allocation dunder; len == 13"
  category: method_qualnames
  kind: python_call_eq
  function: "array.__new__.__qualname__.__eq__"
  args: ["array.__new__"]
  expected: true
