# ---------------------------------------------------------------------------
# Cross-class table: __name__ for all four view classes
# ---------------------------------------------------------------------------

table abc_extra256.view_class_names:
  description: "__name__ of all four mapping-view ABCs in collections.abc"
  kind: python_call_eq
  category: identity
  id_prefix: vname

  columns: [id, function, args, expected, description]
  rows:
    - [mapping_view, MappingView.__name__.__eq__, ["MappingView"], true, "collections.abc.MappingView.__name__"]
    - [keys_view,    KeysView.__name__.__eq__,    ["KeysView"],    true, "collections.abc.KeysView.__name__"]
    - [values_view,  ValuesView.__name__.__eq__,  ["ValuesView"],  true, "collections.abc.ValuesView.__name__"]
    - [items_view,   ItemsView.__name__.__eq__,   ["ItemsView"],   true, "collections.abc.ItemsView.__name__"]

# ---------------------------------------------------------------------------
# Cross-class table: __module__ for all four view classes
# ---------------------------------------------------------------------------

table abc_extra256.view_class_modules:
  description: "All four view classes are defined in the collections.abc module"
  kind: python_call_eq
  category: identity
  id_prefix: vmod

  columns: [id, function, args, expected, description]
  rows:
    - [mapping_view, MappingView.__module__.__eq__, ["collections.abc"], true, "MappingView.__module__"]
    - [keys_view,    KeysView.__module__.__eq__,    ["collections.abc"], true, "KeysView.__module__"]
    - [values_view,  ValuesView.__module__.__eq__,  ["collections.abc"], true, "ValuesView.__module__"]
    - [items_view,   ItemsView.__module__.__eq__,   ["collections.abc"], true, "ItemsView.__module__"]

# ---------------------------------------------------------------------------
# Cross-class table: __bases__[0].__name__ — first base is always MappingView
# (except MappingView itself, whose first base is Sized)
# ---------------------------------------------------------------------------

table abc_extra256.view_first_base_names:
  description: "First base class name for each view class"
  kind: python_call_eq
  category: identity
  id_prefix: vbase0

  columns: [id, function, args, expected, description]
  rows:
    - [mapping_view, "MappingView.__bases__[0].__name__.__eq__", ["Sized"],       true, "MappingView inherits from Sized"]
    - [keys_view,    "KeysView.__bases__[0].__name__.__eq__",    ["MappingView"], true, "KeysView inherits from MappingView (first base)"]
    - [values_view,  "ValuesView.__bases__[0].__name__.__eq__",  ["MappingView"], true, "ValuesView inherits from MappingView (first base)"]
    - [items_view,   "ItemsView.__bases__[0].__name__.__eq__",   ["MappingView"], true, "ItemsView inherits from MappingView (first base)"]

# ---------------------------------------------------------------------------
# Cross-class table: __abstractmethods__ length is 0 for all four
# ---------------------------------------------------------------------------

table abc_extra256.view_abstractmethods_len:
  description: "All four view classes have empty __abstractmethods__ frozensets"
  kind: python_call_eq
  category: identity
  id_prefix: vam

  columns: [id, function, args, expected, description]
  rows:
    - [mapping_view, MappingView.__abstractmethods__.__len__, [], 0, "MappingView.__abstractmethods__ is empty"]
    - [keys_view,    KeysView.__abstractmethods__.__len__,    [], 0, "KeysView.__abstractmethods__ is empty"]
    - [values_view,  ValuesView.__abstractmethods__.__len__,  [], 0, "ValuesView.__abstractmethods__ is empty"]
    - [items_view,   ItemsView.__abstractmethods__.__len__,   [], 0, "ItemsView.__abstractmethods__ is empty"]
