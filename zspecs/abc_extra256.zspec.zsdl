spec: abc_extra256
version: ">=3.9"
backend: python_module(collections.abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "All four view classes (MappingView, KeysView, ValuesView, ItemsView) report __module__ == 'collections.abc'."
    - "MappingView has a single base: Sized. KeysView, ValuesView, and ItemsView each have two bases."
    - "KeysView.__bases__ == (MappingView, Set); ValuesView.__bases__ == (MappingView, Collection); ItemsView.__bases__ == (MappingView, Set)."
    - "All four classes have empty __abstractmethods__ frozensets on CPython 3.14 — concrete implementations are provided."
    - "MappingView.__abstractmethods__.__len__() == 0 (frozenset())."
    - "The __bases__[0].__name__ for KeysView, ValuesView, and ItemsView is always 'MappingView'."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# MappingView — class identity
# ---------------------------------------------------------------------------

invariant abc_extra256.MappingView.__name__:
  description: "collections.abc.MappingView.__name__ == 'MappingView'"
  category: identity
  kind: python_call_eq
  function: MappingView.__name__.__eq__
  args: ["MappingView"]
  expected: true

invariant abc_extra256.MappingView.__module__:
  description: "collections.abc.MappingView.__module__ == 'collections.abc'"
  category: identity
  kind: python_call_eq
  function: MappingView.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra256.MappingView.__bases__0.__name__:
  description: "collections.abc.MappingView.__bases__[0].__name__ == 'Sized'"
  category: identity
  kind: python_call_eq
  function: "MappingView.__bases__[0].__name__.__eq__"
  args: ["Sized"]
  expected: true

invariant abc_extra256.MappingView.__abstractmethods__.__len__:
  description: "collections.abc.MappingView.__abstractmethods__ is empty — len == 0"
  category: identity
  kind: python_call_eq
  function: MappingView.__abstractmethods__.__len__
  args: []
  expected: 0

