spec: abc_extra170
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: abc.ABCMeta methods — abc.ABCMeta.register.__name__=='register' (len=8); abc.ABCMeta.__instancecheck__.__name__=='__instancecheck__' (len=17: '__'=2+'instancecheck'=13+'__'=2=17); abc.ABCMeta.__subclasscheck__.__name__=='__subclasscheck__' (len=17: '__'=2+'subclasscheck'=13+'__'=2=17; same len as __instancecheck__); abc.ABCMeta.__abstractmethods__ — ABCMeta itself has no __abstractmethods__ attribute as a metaclass (it is not an ABC in the user sense); abc.ABCMeta.__dict__.__class__.__name__=='mappingproxy'; abc.ABC.__dict__.__class__.__name__=='mappingproxy'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.register.__name__.__len__() == 8. 'register' is 8 characters: 'r'+'e'+'g'+'i'+'s'+'t'+'e'+'r'=8. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__instancecheck__.__name__.__len__() == 17. '__instancecheck__' is 17 characters: '__'=2+'instancecheck'=13+'__'=2=17. Same length as '__subclasscheck__'=17. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__dict__.__class__.__name__ == 'mappingproxy'. Class __dict__ objects are always mappingproxy instances in CPython to prevent direct mutation. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta method name identity — extra170
#
# abc.ABCMeta.register.__name__.__eq__('register')                == True (len=8)
# abc.ABCMeta.__instancecheck__.__name__.__eq__('__instancecheck__')  == True (len=17)
# abc.ABCMeta.__subclasscheck__.__name__.__eq__('__subclasscheck__')  == True (len=17; same as __instancecheck__)
# ---------------------------------------------------------------------------

table abc_extra170.abcmeta_method_names:
  description: "abc.ABCMeta method name identity checks in abcmeta170methods namespace — abc.ABCMeta.register.__name__.__eq__('register')==True ('register'=8: 'r'+'e'+'g'+'i'+'s'+'t'+'e'+'r'=8; ABCMeta.register(cls, subclass) registers subclass as a virtual subclass of cls — an isinstance() and issubclass() check will return True for the registered class even if it does not inherit from cls); abc.ABCMeta.register.__name__.__len__()==8; abc.ABCMeta.__instancecheck__.__name__.__eq__('__instancecheck__')==True ('__instancecheck__'=17: '__'=2+'instancecheck'=13+'__'=2=17; ABCMeta.__instancecheck__ overrides isinstance() behavior; isinstance(x, cls) calls type(cls).__instancecheck__(cls, x)); abc.ABCMeta.__instancecheck__.__name__.__len__()==17; abc.ABCMeta.__subclasscheck__.__name__.__eq__('__subclasscheck__')==True ('__subclasscheck__'=17: '__'=2+'subclasscheck'=13+'__'=2=17; same length as '__instancecheck__'=17; 'instancecheck'=13 and 'subclasscheck'=13 have the same character count); abc.ABCMeta.__subclasscheck__.__name__.__len__()==17; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmeta170methods

  columns: [id, function, args, expected, description]
  rows:
    - [reg_name_eq,    abc.ABCMeta.register.__name__.__eq__,             ["register"],           true,  "ABCMeta.register.__name__ == 'register' (len=8); verified with Python 3.14.3"]
    - [reg_name_len,   abc.ABCMeta.register.__name__.__len__,            [],                     8,     "ABCMeta.register.__name__.__len__() == 8 ('register'=8); verified with Python 3.14.3"]
    - [ic_name_eq,     "abc.ABCMeta.__instancecheck__.__name__.__eq__",  ["__instancecheck__"],  true,  "ABCMeta.__instancecheck__.__name__ == '__instancecheck__' (len=17: '__'=2+'instancecheck'=13+'__'=2=17); verified with Python 3.14.3"]
    - [ic_name_len,    "abc.ABCMeta.__instancecheck__.__name__.__len__", [],                     17,    "ABCMeta.__instancecheck__.__name__.__len__() == 17 ('__instancecheck__'=17); verified with Python 3.14.3"]
    - [sc_name_eq,     "abc.ABCMeta.__subclasscheck__.__name__.__eq__",  ["__subclasscheck__"],  true,  "ABCMeta.__subclasscheck__.__name__ == '__subclasscheck__' (len=17; same as __instancecheck__=17); verified with Python 3.14.3"]
    - [sc_name_len,    "abc.ABCMeta.__subclasscheck__.__name__.__len__", [],                     17,    "ABCMeta.__subclasscheck__.__name__.__len__() == 17 ('__subclasscheck__'=17; same as __instancecheck__=17); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta and abc.ABC __dict__ class identity — extra170
#
# abc.ABCMeta.__dict__.__class__.__name__.__eq__('mappingproxy')  == True
# abc.ABC.__dict__.__class__.__name__.__eq__('mappingproxy')      == True
# ---------------------------------------------------------------------------

table abc_extra170.abcmeta_abc_dict_class:
  description: "abc.ABCMeta and abc.ABC __dict__ class name identity checks in abcmeta170dict namespace — abc.ABCMeta.__dict__.__class__.__name__.__eq__('mappingproxy')==True ('mappingproxy'=12: 'mapping'=7+'proxy'=5=12; class __dict__ objects are always types.MappingProxyType instances in CPython; the mappingproxy wraps the underlying dict and makes it read-only from Python code — preventing external mutation of class attributes via __dict__[key]=value); abc.ABCMeta.__dict__.__class__.__name__.__len__()==12; abc.ABC.__dict__.__class__.__name__.__eq__('mappingproxy')==True (abc.ABC is a helper class with ABCMeta as its metaclass; its __dict__ is also a mappingproxy like any other class); abc.ABC.__dict__.__class__.__name__.__len__()==12; CROSS-CHECK: both ABCMeta (the metaclass) and ABC (the helper base class) share the same mappingproxy __dict__ type — all Python class objects use mappingproxy for __dict__ regardless of metaclass; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmeta170dict

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_dict_cls_eq,   abc.ABCMeta.__dict__.__class__.__name__.__eq__,  ["mappingproxy"],  true,  "abc.ABCMeta.__dict__.__class__.__name__ == 'mappingproxy' (len=12: 'mapping'=7+'proxy'=5=12); verified with Python 3.14.3"]
    - [abcmeta_dict_cls_len,  abc.ABCMeta.__dict__.__class__.__name__.__len__, [],                12,    "abc.ABCMeta.__dict__.__class__.__name__.__len__() == 12 ('mappingproxy'=12); verified with Python 3.14.3"]
    - [abc_dict_cls_eq,       abc.ABC.__dict__.__class__.__name__.__eq__,      ["mappingproxy"],  true,  "abc.ABC.__dict__.__class__.__name__ == 'mappingproxy' (same as ABCMeta; all class __dicts__ are mappingproxy); verified with Python 3.14.3"]
    - [abc_dict_cls_len,      abc.ABC.__dict__.__class__.__name__.__len__,     [],                12,    "abc.ABC.__dict__.__class__.__name__.__len__() == 12 (same as ABCMeta=12); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta name and module identity — extra170
#
# abc.ABCMeta.__name__.__eq__('ABCMeta')  == True (len=7)
# abc.ABCMeta.__module__.__eq__('abc')    == True (len=3)
# ---------------------------------------------------------------------------

table abc_extra170.abcmeta_class_identity:
  description: "abc.ABCMeta class name and module identity checks in abcmeta170cls namespace — abc.ABCMeta.__name__.__eq__('ABCMeta')==True ('ABCMeta'=7: 'ABC'=3+'Meta'=4=7; ABCMeta is the metaclass that provides the Abstract Base Class machinery; a class using ABCMeta as its metaclass can declare abstract methods via @abstractmethod; ABCMeta is both a metaclass (instance of type) and itself an instance of type — type(ABCMeta).__name__=='type'); abc.ABCMeta.__name__.__len__()==7; abc.ABCMeta.__module__.__eq__('abc')==True ('abc'=3: 'a'+'b'+'c'=3; ABCMeta is defined in Lib/abc.py — even though the implementation delegates to _abc C extension for performance; abc.__module__=='abc' for ABCMeta itself); abc.ABCMeta.__module__.__len__()==3; NAME LENGTH COMPARISON: 'abc'=3 (module) < 'ABCMeta'=7 < 'register'=8 < 'mappingproxy'=12 < '__instancecheck__'=17 == '__subclasscheck__'=17; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmeta170cls

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_name_eq,    abc.ABCMeta.__name__.__eq__,    ["ABCMeta"],  true,  "abc.ABCMeta.__name__ == 'ABCMeta' (len=7: 'ABC'=3+'Meta'=4=7); verified with Python 3.14.3"]
    - [abcmeta_name_len,   abc.ABCMeta.__name__.__len__,   [],           7,     "abc.ABCMeta.__name__.__len__() == 7 ('ABCMeta'=7: 'ABC'=3+'Meta'=4=7); verified with Python 3.14.3"]
    - [abcmeta_mod_eq,     abc.ABCMeta.__module__.__eq__,  ["abc"],      true,  "abc.ABCMeta.__module__ == 'abc' (len=3; defined in Lib/abc.py); verified with Python 3.14.3"]
    - [abcmeta_mod_len,    abc.ABCMeta.__module__.__len__, [],           3,     "abc.ABCMeta.__module__.__len__() == 3 ('abc'=3; shortest module path in spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra170
# ---------------------------------------------------------------------------

invariant abc_extra170.abcmeta_register_name_eq:
  description: "abc.ABCMeta.register.__name__.__eq__('register') returns True — abc.ABCMeta.register.__name__=='register' (len=8: 'r'+'e'+'g'+'i'+'s'+'t'+'e'+'r'=8); ABCMeta.register(cls, subclass) marks subclass as a 'virtual subclass' of cls; virtual subclasses appear to be subclasses (isinstance and issubclass return True) without actually inheriting from cls; this supports duck typing and allows third-party classes to be registered as implementing an ABC interface without modifying their source code; ABCMeta.register() also triggers the cache token increment (see get_cache_token()); 'register'=8 == 'shutdown'=8 (from concurrent_futures_extra172; coincidence — same length); NEW in extra170: first standalone ABCMeta.register.__name__ invariant in abcmeta170methods namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.register.__name__.__eq__
  args: ["register"]
  expected: true

invariant abc_extra170.abcmeta_instancecheck_name_len:
  description: "abc.ABCMeta.__instancecheck__.__name__.__len__() == 17 — abc.ABCMeta.__instancecheck__.__name__ is '__instancecheck__' (17 characters: '__'=2+'instancecheck'=13+'__'=2=17); '__instancecheck__' and '__subclasscheck__' both have length 17 because 'instancecheck'=13 and 'subclasscheck'=13 have the same character count; ABCMeta.__instancecheck__(cls, instance) is called by isinstance(instance, cls) when cls has a metaclass defining __instancecheck__; the ABCMeta implementation checks both real inheritance (via the MRO) and virtual subclass registration (via the ABCMeta registry); '__instancecheck__'=17 equals asyncio.AbstractEventLoop.__name__.__len__()==17 (from asyncio_extra175; both are 17 chars; coincidence); NEW in extra170: first standalone ABCMeta.__instancecheck__.__name__.__len__ invariant in abcmeta170methods namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "abc.ABCMeta.__instancecheck__.__name__.__len__"
  args: []
  expected: 17

invariant abc_extra170.abcmeta_subclasscheck_name_eq:
  description: "abc.ABCMeta.__subclasscheck__.__name__.__eq__('__subclasscheck__') returns True — abc.ABCMeta.__subclasscheck__.__name__=='__subclasscheck__' (len=17: '__'=2+'subclasscheck'=13+'__'=2=17; same length as '__instancecheck__'=17); ABCMeta.__subclasscheck__(cls, subclass) is called by issubclass(subclass, cls) when cls has a metaclass defining __subclasscheck__; the ABCMeta implementation checks both real inheritance and virtual subclass registration (classes registered via ABCMeta.register()); '__subclasscheck__'=17 == '__instancecheck__'=17 — the inner terms 'subclasscheck'=13 and 'instancecheck'=13 both have 13 chars; 'subclasscheck': 'sub'=3+'class'=5+'check'=5=13; 'instancecheck': 'instance'=8+'check'=5=13; NEW in extra170: first standalone ABCMeta.__subclasscheck__.__name__ invariant in abcmeta170methods namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "abc.ABCMeta.__subclasscheck__.__name__.__eq__"
  args: ["__subclasscheck__"]
  expected: true

invariant abc_extra170.abcmeta_dict_class_is_mappingproxy:
  description: "abc.ABCMeta.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — abc.ABCMeta.__dict__.__class__.__name__=='mappingproxy' (len=12: 'mapping'=7+'proxy'=5=12); every Python class object's __dict__ is an instance of types.MappingProxyType — a read-only view of the underlying dict; this prevents external code from directly mutating class namespaces via __dict__[key]=value (which would bypass descriptors and other class machinery); ABCMeta is itself a class (its metaclass is 'type'), so its __dict__ is a mappingproxy; ABCMeta.__dict__ contains the ABCMeta methods: register, __instancecheck__, __subclasscheck__, and others; 'mappingproxy'=12 > 'ABCMeta'=7 by 5; NEW in extra170: first standalone ABCMeta.__dict__.__class__.__name__ invariant in abcmeta170dict namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant abc_extra170.abc_dict_class_is_mappingproxy:
  description: "abc.ABC.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — abc.ABC.__dict__.__class__.__name__=='mappingproxy' (len=12; same as ABCMeta.__dict__.__class__.__name__=='mappingproxy'); abc.ABC is a helper base class with ABCMeta as its metaclass; abc.ABC is defined as: class ABC(metaclass=ABCMeta): pass; its __dict__ is a mappingproxy wrapping a dict that contains only the inherited members visible in ABC's own namespace; abc.ABC.__dict__ is minimal (mostly just __doc__ and __weakref__); the mappingproxy type applies to ALL Python class objects regardless of their metaclass — ABCMeta, type, or any custom metaclass; abc.ABC.__dict__.__class__.__name__=='mappingproxy' holds for the same reason abc.ABCMeta.__dict__.__class__.__name__=='mappingproxy' holds; NEW in extra170: first standalone ABC.__dict__.__class__.__name__ invariant in abcmeta170dict namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant abc_extra170.abcmeta_name_eq:
  description: "abc.ABCMeta.__name__.__eq__('ABCMeta') returns True — abc.ABCMeta.__name__=='ABCMeta' (len=7: 'ABC'=3+'Meta'=4=7; 'ABC' stands for Abstract Base Class; 'Meta' signals that ABCMeta is a metaclass — a class whose instances are classes); ABCMeta is the primary mechanism for defining Abstract Base Classes in Python; a class uses ABCMeta as its metaclass to gain the ability to declare abstract methods (@abstractmethod) and abstract properties (@abstractproperty, @abstractclassmethod, @abstractstaticmethod); ABCMeta is defined in Lib/abc.py; type(abc.ABCMeta).__name__=='type' (ABCMeta's own metaclass is 'type' — the standard metaclass); ABCMeta is NOT itself abstract (it has no abstractmethods); 'ABCMeta'=7 > 'abc'=3 (module) by 4; NEW in extra170: first standalone ABCMeta.__name__ invariant in abcmeta170cls namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__name__.__eq__
  args: ["ABCMeta"]
  expected: true
