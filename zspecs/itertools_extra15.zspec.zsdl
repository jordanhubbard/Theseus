spec: itertools_extra15
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools.zspec.zsdl and prior extras through itertools_extra14.zspec.zsdl."
    - "itertools_extra14 covers: __module__.__eq__ for chain, cycle, repeat, count, accumulate, zip_longest, product, permutations, combinations, groupby, islice; module_len cross-checks."
    - "itertools.zspec.zsdl covers __name__.__eq__ for chain, islice, count, cycle, repeat, accumulate, compress, starmap, product, combinations, permutations, dropwhile, takewhile, zip_longest."
    - "itertools_extra13 covers __qualname__.__eq__ for chain, cycle, repeat, count, zip_longest, product, permutations, combinations, combinations_with_replacement, groupby, islice."
    - "No prior itertools spec covers __name__.__len__() for any type as a standalone length cross-check."
    - "No prior itertools spec covers __module__.__eq__ for compress, dropwhile, takewhile, filterfalse, or starmap."
    - "itertools.compress.__module__ == 'itertools' — C-level type in the itertools extension."
    - "itertools.dropwhile.__module__ == 'itertools' — C-level type in the itertools extension."
    - "itertools.takewhile.__module__ == 'itertools' — C-level type in the itertools extension."
    - "itertools.filterfalse.__module__ == 'itertools' — C-level type in the itertools extension."
    - "itertools.starmap.__module__ == 'itertools' — C-level type in the itertools extension."
    - "Name lengths: chain==5, cycle==5, repeat==6, count==5, zip_longest==12, product==7, permutations==12, combinations==12, groupby==7, islice==6."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ for compress, dropwhile, takewhile, filterfalse, starmap
#
# itertools_extra14 covers __module__ for chain, cycle, repeat, count,
# accumulate, zip_longest, product, permutations, combinations, groupby,
# islice. No prior spec covers __module__ for compress, dropwhile, takewhile,
# filterfalse, or starmap — all five are C-level types in the itertools module.
# ---------------------------------------------------------------------------

invariant itertools_extra15.compress.module:
  description: "itertools.compress.__module__ == 'itertools' — C-level type, module attribute"
  category: module_attrs
  kind: python_call_eq
  function: compress.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra15.dropwhile.module:
  description: "itertools.dropwhile.__module__ == 'itertools' — C-level type, module attribute"
  category: module_attrs
  kind: python_call_eq
  function: dropwhile.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra15.takewhile.module:
  description: "itertools.takewhile.__module__ == 'itertools' — C-level type, module attribute"
  category: module_attrs
  kind: python_call_eq
  function: takewhile.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra15.filterfalse.module:
  description: "itertools.filterfalse.__module__ == 'itertools' — C-level type, module attribute"
  category: module_attrs
  kind: python_call_eq
  function: filterfalse.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra15.starmap.module:
  description: "itertools.starmap.__module__ == 'itertools' — C-level type, module attribute"
  category: module_attrs
  kind: python_call_eq
  function: starmap.__module__.__eq__
  args: ["itertools"]
  expected: true

# ---------------------------------------------------------------------------
# __name__.__len__() cross-checks for selected itertools types
#
# No prior itertools spec records __name__.__len__() for any type.
# These provide a second behavioral axis (string length) for the name attribute,
# complementing the __name__.__eq__ checks in itertools.zspec.zsdl.
# ---------------------------------------------------------------------------

invariant itertools_extra15.chain.name_len:
  description: "itertools.chain.__name__.__len__() == 5 — len('chain')"
  category: name_lengths
  kind: python_call_eq
  function: chain.__name__.__len__
  args: []
  expected: 5

invariant itertools_extra15.repeat.name_len:
  description: "itertools.repeat.__name__.__len__() == 6 — len('repeat')"
  category: name_lengths
  kind: python_call_eq
  function: repeat.__name__.__len__
  args: []
  expected: 6

invariant itertools_extra15.zip_longest.name_len:
  description: "itertools.zip_longest.__name__.__len__() == 12 — len('zip_longest')"
  category: name_lengths
  kind: python_call_eq
  function: zip_longest.__name__.__len__
  args: []
  expected: 12

invariant itertools_extra15.permutations.name_len:
  description: "itertools.permutations.__name__.__len__() == 12 — len('permutations')"
  category: name_lengths
  kind: python_call_eq
  function: permutations.__name__.__len__
  args: []
  expected: 12

invariant itertools_extra15.combinations.name_len:
  description: "itertools.combinations.__name__.__len__() == 12 — len('combinations')"
  category: name_lengths
  kind: python_call_eq
  function: combinations.__name__.__len__
  args: []
  expected: 12

invariant itertools_extra15.groupby.name_len:
  description: "itertools.groupby.__name__.__len__() == 7 — len('groupby')"
  category: name_lengths
  kind: python_call_eq
  function: groupby.__name__.__len__
  args: []
  expected: 7

invariant itertools_extra15.islice.name_len:
  description: "itertools.islice.__name__.__len__() == 6 — len('islice')"
  category: name_lengths
  kind: python_call_eq
  function: islice.__name__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# repeat — iterator class name cross-check via method_chain
#
# No prior itertools spec checks the __class__.__name__ of a repeat instance.
# repeat(1, 3).__class__.__name__ == 'repeat' — the instance is of type repeat.
# ---------------------------------------------------------------------------

invariant itertools_extra15.repeat.three_ones_class:
  description: "repeat(1, 3).__class__.__name__ == 'repeat'"
  category: instance_class
  kind: python_call_eq
  function: repeat
  args: [1, 3]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["repeat"]
  expected: true
