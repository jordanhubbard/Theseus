spec: currency_codes
version: ">=2.0.0"
backend: node(currency-codes)

docs: https://www.npmjs.com/package/currency-codes

provenance:
  derived_from:
    - "currency-codes README — https://www.npmjs.com/package/currency-codes"
    - "Test vectors verified with currency-codes via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "currency-codes source"
  notes:
    - "currency-codes is an npm package. Install: npm install currency-codes"
    - "cc.code(str) returns the ISO 4217 currency info for a code like 'USD'."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns currency info object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table currency_codes.code:
  kind: node_module_call_eq
  function: code
  category: lookup
  id_prefix: cccode

  columns: [id, args, expected]
  rows:
    - [usd, ["USD"],
       {"code": "USD", "number": "840", "digits": 2, "currency": "US Dollar",
        "countries": ["American Samoa","Bonaire, Sint Eustatius and Saba",
          "British Indian Ocean Territory (The)","Ecuador","El Salvador","Guam",
          "Haiti","Marshall Islands (The)","Micronesia (Federated States Of)",
          "Northern Mariana Islands (The)","Palau","Panama","Puerto Rico",
          "Timor-Leste","Turks and Caicos Islands (The)",
          "United States Minor Outlying Islands (The)",
          "United States of America (The)","Virgin Islands (British)",
          "Virgin Islands (u.s.)"]}]
    - [eur, ["EUR"],
       {"code": "EUR", "number": "978", "digits": 2, "currency": "Euro",
        "countries": ["Åland Islands","Andorra","Austria","Belgium",
          "Croatia","Cyprus","Estonia","European Union","Finland","France",
          "French Guiana","French Southern Territories (The)","Germany",
          "Greece","Guadeloupe","Holy See (The)","Ireland","Italy",
          "Latvia","Lithuania","Luxembourg","Malta","Martinique","Mayotte",
          "Monaco","Montenegro","Netherlands (The)","Portugal","Réunion",
          "Saint Barthélemy","Saint Martin (French Part)",
          "Saint Pierre and Miquelon","San Marino","Slovakia","Slovenia",
          "Spain"]}]
