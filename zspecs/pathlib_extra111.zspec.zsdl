spec: pathlib_extra111
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends pathlib_extra110.zspec.zsdl."
    - "This spec covers: pathlib.Path property fget __qualname__ values and Path method __qualname__ string equality."
    - "Path.parent is a property on PurePath; Path.parent.fget.__qualname__ == 'PurePath.parent' (length 15)."
    - "Path.name is a property on PurePath; Path.name.fget.__qualname__ == 'PurePath.name' (length 13)."
    - "Path.suffix is a property on PurePath; Path.suffix.fget.__qualname__ == 'PurePath.suffix' (length 15)."
    - "Path.stem is a property on PurePath; Path.stem.fget.__qualname__ == 'PurePath.stem' (length 13)."
    - "Path.iterdir is a regular function with __qualname__ == 'Path.iterdir' (length 12)."
    - "Path.glob is a regular function with __qualname__ == 'Path.glob' (length 9)."
    - "Path.rglob is a regular function with __qualname__ == 'Path.rglob' (length 10)."
    - "Path.open is a regular function with __qualname__ == 'Path.open' (length 9)."
    - "Path.read_text is a regular function with __qualname__ == 'Path.read_text' (length 14)."
    - "Path.write_text is a regular function with __qualname__ == 'Path.write_text' (length 15)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path property fget __qualname__ values
# Path.parent, Path.name, Path.suffix, Path.stem are all properties defined
# on PurePath. Their fget.__qualname__ uses the 'PurePath' prefix, not 'Path'.
# parent/suffix have len=15; name/stem have len=13.
# ---------------------------------------------------------------------------

table pathlib_extra111.Path_property_fget_qualnames:
  description: "pathlib.Path property fget __qualname__ values: parent.fget='PurePath.parent', name.fget='PurePath.name', suffix.fget='PurePath.suffix', stem.fget='PurePath.stem'"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibqual111a

  columns: [id, function, args, expected, description]
  rows:
    - [parent_fget_qn,  "Path.parent.fget.__qualname__.__eq__",  ["PurePath.parent"],  true,  "pathlib.Path.parent.fget.__qualname__ == 'PurePath.parent' (property defined on PurePath)"]
    - [name_fget_qn,    "Path.name.fget.__qualname__.__eq__",    ["PurePath.name"],    true,  "pathlib.Path.name.fget.__qualname__ == 'PurePath.name' (property defined on PurePath)"]
    - [suffix_fget_qn,  "Path.suffix.fget.__qualname__.__eq__",  ["PurePath.suffix"],  true,  "pathlib.Path.suffix.fget.__qualname__ == 'PurePath.suffix' (property defined on PurePath)"]
    - [stem_fget_qn,    "Path.stem.fget.__qualname__.__eq__",    ["PurePath.stem"],    true,  "pathlib.Path.stem.fget.__qualname__ == 'PurePath.stem' (property defined on PurePath)"]
    - [parent_not_path, "Path.parent.fget.__qualname__.__eq__",  ["Path.parent"],      false, "pathlib.Path.parent.fget.__qualname__ != 'Path.parent' (fget is defined on PurePath, not Path)"]
    - [name_not_path,   "Path.name.fget.__qualname__.__eq__",    ["Path.name"],        false, "pathlib.Path.name.fget.__qualname__ != 'Path.name' (fget is defined on PurePath, not Path)"]

# ---------------------------------------------------------------------------
# pathlib.Path method __qualname__ values
# iterdir, glob, rglob, open, read_text, write_text are regular Python
# functions defined directly on Path. Their __qualname__ uses 'Path.' prefix.
# ---------------------------------------------------------------------------

table pathlib_extra111.Path_method_qualnames:
  description: "pathlib.Path method __qualname__ values: iterdir='Path.iterdir', glob='Path.glob', rglob='Path.rglob', open='Path.open', read_text='Path.read_text', write_text='Path.write_text'"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibqual111b

  columns: [id, function, args, expected, description]
  rows:
    - [iterdir_qn,    Path.iterdir.__qualname__.__eq__,   ["Path.iterdir"],   true,  "pathlib.Path.iterdir.__qualname__ == 'Path.iterdir'"]
    - [glob_qn,       Path.glob.__qualname__.__eq__,      ["Path.glob"],      true,  "pathlib.Path.glob.__qualname__ == 'Path.glob'"]
    - [rglob_qn,      Path.rglob.__qualname__.__eq__,     ["Path.rglob"],     true,  "pathlib.Path.rglob.__qualname__ == 'Path.rglob'"]
    - [open_qn,       Path.open.__qualname__.__eq__,      ["Path.open"],      true,  "pathlib.Path.open.__qualname__ == 'Path.open'"]
    - [read_text_qn,  Path.read_text.__qualname__.__eq__,  ["Path.read_text"],  true,  "pathlib.Path.read_text.__qualname__ == 'Path.read_text'"]
    - [write_text_qn, Path.write_text.__qualname__.__eq__, ["Path.write_text"], true,  "pathlib.Path.write_text.__qualname__ == 'Path.write_text'"]
    - [glob_not_rglob, Path.glob.__qualname__.__eq__,     ["Path.rglob"],     false, "pathlib.Path.glob.__qualname__ != 'Path.rglob' (glob and rglob are distinct methods)"]

# ---------------------------------------------------------------------------
# pathlib.Path property fget __qualname__ lengths
# parent/suffix fget __qualname__ len=15; name/stem fget __qualname__ len=13.
# iterdir len=12; glob/open len=9; rglob len=10; read_text len=14; write_text len=15.
# ---------------------------------------------------------------------------

table pathlib_extra111.qualname_lengths:
  description: "pathlib.Path property fget and method __qualname__ lengths: parent/suffix fget=15, name/stem fget=13, iterdir=12, glob/open=9, rglob=10, read_text=14, write_text=15"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibqual111c

  columns: [id, function, args, expected, description]
  rows:
    - [parent_fget_len,  "Path.parent.fget.__qualname__.__len__",  [], 15, "pathlib.Path.parent.fget.__qualname__.__len__() == 15 ('PurePath.parent' has 15 chars)"]
    - [name_fget_len,    "Path.name.fget.__qualname__.__len__",    [], 13, "pathlib.Path.name.fget.__qualname__.__len__() == 13 ('PurePath.name' has 13 chars)"]
    - [suffix_fget_len,  "Path.suffix.fget.__qualname__.__len__",  [], 15, "pathlib.Path.suffix.fget.__qualname__.__len__() == 15 ('PurePath.suffix' has 15 chars)"]
    - [stem_fget_len,    "Path.stem.fget.__qualname__.__len__",    [], 13, "pathlib.Path.stem.fget.__qualname__.__len__() == 13 ('PurePath.stem' has 13 chars)"]
    - [iterdir_len,      Path.iterdir.__qualname__.__len__,        [], 12, "pathlib.Path.iterdir.__qualname__.__len__() == 12 ('Path.iterdir' has 12 chars)"]
    - [glob_len,         Path.glob.__qualname__.__len__,           [], 9,  "pathlib.Path.glob.__qualname__.__len__() == 9 ('Path.glob' has 9 chars)"]
    - [rglob_len,        Path.rglob.__qualname__.__len__,          [], 10, "pathlib.Path.rglob.__qualname__.__len__() == 10 ('Path.rglob' has 10 chars)"]
    - [read_text_len,    Path.read_text.__qualname__.__len__,      [], 14, "pathlib.Path.read_text.__qualname__.__len__() == 14 ('Path.read_text' has 14 chars)"]
    - [write_text_len,   Path.write_text.__qualname__.__len__,     [], 15, "pathlib.Path.write_text.__qualname__.__len__() == 15 ('Path.write_text' has 15 chars)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra111.Path.parent_fget_qualname:
  description: "pathlib.Path.parent.fget.__qualname__ == 'PurePath.parent' (the parent property is defined on PurePath, the abstract base; Path inherits it, so the fget function's qualname carries the PurePath prefix)"
  category: qualnames
  kind: python_call_eq
  function: Path.parent.fget.__qualname__.__eq__
  args: ["PurePath.parent"]
  expected: true

invariant pathlib_extra111.Path.name_fget_qualname:
  description: "pathlib.Path.name.fget.__qualname__ == 'PurePath.name' (the name property is defined on PurePath; fget.__qualname__ reflects the defining class, not the accessing class)"
  category: qualnames
  kind: python_call_eq
  function: Path.name.fget.__qualname__.__eq__
  args: ["PurePath.name"]
  expected: true

invariant pathlib_extra111.Path.glob_qualname:
  description: "pathlib.Path.glob.__qualname__ == 'Path.glob' (glob is defined directly on Path, not on PurePath; its __qualname__ uses the 'Path.' prefix)"
  category: qualnames
  kind: python_call_eq
  function: Path.glob.__qualname__.__eq__
  args: ["Path.glob"]
  expected: true

invariant pathlib_extra111.Path.write_text_qualname_len:
  description: "pathlib.Path.write_text.__qualname__.__len__() == 15 ('Path.write_text' has 15 characters; the longest __qualname__ among Path methods tested here)"
  category: qualnames
  kind: python_call_eq
  function: Path.write_text.__qualname__.__len__
  args: []
  expected: 15

invariant pathlib_extra111.Path.iterdir_qualname:
  description: "pathlib.Path.iterdir.__qualname__ == 'Path.iterdir' (iterdir yields directory contents; it is defined on Path, not PurePath, and its __qualname__ uses the 'Path.' prefix)"
  category: qualnames
  kind: python_call_eq
  function: Path.iterdir.__qualname__.__eq__
  args: ["Path.iterdir"]
  expected: true

