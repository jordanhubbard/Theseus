spec: hashlib_extra537
version: ">=3.9"
backend: python_module(hashlib)
docs: "Behavioral specs for hashlib.shake_128 and shake_256 method identity"
provenance:
  derived_from:
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"
error_model: strict

table hashlib_extra537.shake_128_method_names:
  description: "shake_128 method __name__ identity checks"
  kind: python_call_eq
  category: method_identity
  id_prefix: s128m
  columns: [id, function, args, expected]
  rows:
    - [s128m001, hashlib.shake_128.copy.__name__.__eq__, ["copy"], true]
    - [s128m002, hashlib.shake_128.digest.__name__.__eq__, ["digest"], true]
    - [s128m003, hashlib.shake_128.hexdigest.__name__.__eq__, ["hexdigest"], true]
    - [s128m004, hashlib.shake_128.update.__name__.__eq__, ["update"], true]

table hashlib_extra537.shake_256_method_names:
  description: "shake_256 method __name__ identity checks"
  kind: python_call_eq
  category: method_identity
  id_prefix: s256m
  columns: [id, function, args, expected]
  rows:
    - [s256m001, hashlib.shake_256.copy.__name__.__eq__, ["copy"], true]
    - [s256m002, hashlib.shake_256.digest.__name__.__eq__, ["digest"], true]
    - [s256m003, hashlib.shake_256.hexdigest.__name__.__eq__, ["hexdigest"], true]
    - [s256m004, hashlib.shake_256.update.__name__.__eq__, ["update"], true]

table hashlib_extra537.shake_qualname_module:
  description: "shake_128 and shake_256 __qualname__ and __module__ identity checks"
  kind: python_call_eq
  category: module_identity
  id_prefix: shkqm
  columns: [id, function, args, expected]
  rows:
    - [shkqm001, hashlib.shake_128.__qualname__.__eq__, ["shake_128"], true]
    - [shkqm002, hashlib.shake_256.__qualname__.__eq__, ["shake_256"], true]
    - [shkqm003, hashlib.shake_128.__module__.__eq__, ["_sha3"], true]
    - [shkqm004, hashlib.shake_256.__module__.__eq__, ["_sha3"], true]
