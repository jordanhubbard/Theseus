spec: functools_extra82
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec extends functools_extra81.zspec.zsdl."
    - "This spec covers: functools partialmethod class identity + WRAPPER_UPDATES constant (Wave 243)."
    - "partialmethod.__name__ == 'partialmethod' — partialmethod is a pure-Python class in Lib/functools.py. Verified with Python 3.14.3."
    - "partialmethod.__module__ == 'functools' — defined in the functools module. Verified with Python 3.14.3."
    - "partialmethod.__qualname__ == 'partialmethod' — top-level class, qualname equals name. Verified with Python 3.14.3."
    - "partialmethod.__bases__[0].__name__ == 'object' — partialmethod inherits directly from object. Verified with Python 3.14.3."
    - "partialmethod.__mro__.__len__() == 2 — MRO is [partialmethod, object]. Verified with Python 3.14.3."
    - "partialmethod.__class__.__name__ == 'type' — partialmethod is a class, its metaclass is type. Verified with Python 3.14.3."
    - "partialmethod.__dict__.__class__.__name__ == 'mappingproxy' — class namespace is a mappingproxy. Verified with Python 3.14.3."
    - "partialmethod.__dict__.__contains__('__get__') == True — partialmethod is a descriptor and implements __get__. Verified with Python 3.14.3."
    - "WRAPPER_UPDATES.__class__.__name__ == 'tuple' — WRAPPER_UPDATES is a module-level tuple constant ('__dict__',). Verified with Python 3.14.3."
    - "WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES has exactly one element. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# partialmethod basic class identity — extra82
#
# Wave 243 theme: partialmethod singledispatch registered implementations +
# partialmethod class identity.
#
# functools.partialmethod.__name__     == 'partialmethod'
# functools.partialmethod.__module__   == 'functools'
# functools.partialmethod.__qualname__ == 'partialmethod'
#
# No prior functools spec checks partialmethod.__name__ via functoolsmore82. New to extra82.
# ---------------------------------------------------------------------------

table functools_extra82.partialmethod_basic_identity:
  description: "partialmethod.__name__=='partialmethod', __module__=='functools', __qualname__=='partialmethod'; wave 243 partialmethod class identity; new to extra82"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsmore82

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_name_eq_partialmethod,
       partialmethod.__name__.__eq__,
       ["partialmethod"],
       true,
       "functools.partialmethod.__name__.__eq__('partialmethod') == True — partialmethod is a pure-Python class defined in Lib/functools.py; its __name__ attribute is the simple class name 'partialmethod' (13 chars); str.__eq__('partialmethod') returns True; no prior functools spec checks partialmethod.__name__ via functoolsmore82; new to extra82"]
    - [partialmethod_module_eq_functools,
       partialmethod.__module__.__eq__,
       ["functools"],
       true,
       "functools.partialmethod.__module__.__eq__('functools') == True — partialmethod is defined in Lib/functools.py and its __module__ attribute records the module name 'functools' (9 chars); str.__eq__('functools') returns True; no prior functools spec checks partialmethod.__module__ via functoolsmore82; new to extra82"]
    - [partialmethod_qualname_eq_partialmethod,
       partialmethod.__qualname__.__eq__,
       ["partialmethod"],
       true,
       "functools.partialmethod.__qualname__.__eq__('partialmethod') == True — partialmethod is a top-level class in functools so its qualified name equals its simple name; str.__eq__('partialmethod') returns True; no prior functools spec checks partialmethod.__qualname__ via functoolsmore82; new to extra82"]

# ---------------------------------------------------------------------------
# partialmethod bases and MRO — extra82
#
# Wave 243 theme: partialmethod inherits from object; MRO length is 2.
#
# functools.partialmethod.__bases__[0].__name__ == 'object'
# functools.partialmethod.__mro__.__len__()     == 2
#
# No prior functools spec checks partialmethod.__bases__[0].__name__ via functoolsmore82. New to extra82.
# ---------------------------------------------------------------------------

table functools_extra82.partialmethod_bases_mro:
  description: "partialmethod.__bases__[0].__name__=='object', __mro__.__len__()==2; wave 243 partialmethod bases/MRO; new to extra82"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsmore82

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_bases_0_name_eq_object,
       "partialmethod.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partialmethod.__bases__[0].__name__.__eq__('object') == True — partialmethod has a single base class, object; __bases__ is a tuple with one element; __bases__[0].__name__ == 'object' (6 chars); str.__eq__('object') returns True; no prior functools spec checks partialmethod.__bases__[0].__name__ via functoolsmore82; new to extra82"]
    - [partialmethod_mro_len_eq_2,
       partialmethod.__mro__.__len__,
       [],
       2,
       "functools.partialmethod.__mro__.__len__() == 2 — partialmethod's MRO is [partialmethod, object], exactly 2 entries; tuple.__len__() returns 2; no prior functools spec checks partialmethod.__mro__.__len__ via functoolsmore82; new to extra82"]

# ---------------------------------------------------------------------------
# partialmethod metaclass and __dict__ class — extra82
#
# Wave 243 theme: partialmethod metaclass is 'type'; __dict__ is a mappingproxy.
#
# functools.partialmethod.__class__.__name__       == 'type'
# functools.partialmethod.__dict__.__class__.__name__ == 'mappingproxy'
# functools.partialmethod.__dict__.__contains__('__get__') == True
#
# No prior functools spec checks partialmethod.__class__.__name__ via functoolsmore82. New to extra82.
# ---------------------------------------------------------------------------

table functools_extra82.partialmethod_metaclass_dict:
  description: "partialmethod.__class__.__name__=='type', __dict__.__class__.__name__=='mappingproxy', __dict__.__contains__('__get__')==True; wave 243 partialmethod metaclass/dict; new to extra82"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsmore82

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_class_name_eq_type,
       partialmethod.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.partialmethod.__class__.__name__.__eq__('type') == True — partialmethod is a class whose metaclass is the built-in type; __class__.__name__ == 'type' (4 chars); str.__eq__('type') returns True; no prior functools spec checks partialmethod.__class__.__name__ via functoolsmore82; new to extra82"]
    - [partialmethod_dict_class_name_eq_mappingproxy,
       partialmethod.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "functools.partialmethod.__dict__.__class__.__name__.__eq__('mappingproxy') == True — the class namespace of partialmethod is a read-only mappingproxy; __dict__.__class__.__name__ == 'mappingproxy' (12 chars); str.__eq__('mappingproxy') returns True; no prior functools spec checks partialmethod.__dict__.__class__.__name__ via functoolsmore82; new to extra82"]
    - [partialmethod_dict_contains_get,
       partialmethod.__dict__.__contains__,
       ["__get__"],
       true,
       "functools.partialmethod.__dict__.__contains__('__get__') == True — partialmethod is a descriptor class; it defines __get__ in its class body so it can be used as a method descriptor on other classes; mappingproxy.__contains__('__get__') returns True; no prior functools spec checks partialmethod.__dict__.__contains__('__get__') via functoolsmore82; new to extra82"]

# ---------------------------------------------------------------------------
# WRAPPER_UPDATES constant — extra82
#
# Wave 243 theme: WRAPPER_UPDATES is a tuple with one element.
#
# functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple'
# functools.WRAPPER_UPDATES.__len__()          == 1
#
# No prior functools spec checks WRAPPER_UPDATES via functoolsmore82. New to extra82.
# ---------------------------------------------------------------------------

table functools_extra82.WRAPPER_UPDATES_constant:
  description: "WRAPPER_UPDATES.__class__.__name__=='tuple', WRAPPER_UPDATES.__len__()==1; wave 243 WRAPPER_UPDATES constant; new to extra82"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsmore82

  columns: [id, function, args, expected, description]
  rows:
    - [WRAPPER_UPDATES_class_name_eq_tuple,
       WRAPPER_UPDATES.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.WRAPPER_UPDATES.__class__.__name__.__eq__('tuple') == True — WRAPPER_UPDATES is a module-level constant defined in Lib/functools.py as ('__dict__',); its type is tuple; __class__.__name__ == 'tuple' (5 chars); str.__eq__('tuple') returns True; no prior functools spec checks WRAPPER_UPDATES.__class__.__name__ via functoolsmore82; new to extra82"]
    - [WRAPPER_UPDATES_len_eq_1,
       WRAPPER_UPDATES.__len__,
       [],
       1,
       "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES is defined as ('__dict__',) in Lib/functools.py; it contains exactly one element, the string '__dict__'; tuple.__len__() returns 1; no prior functools spec checks WRAPPER_UPDATES.__len__ via functoolsmore82; new to extra82"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra82
# ---------------------------------------------------------------------------

invariant functools_extra82.partialmethod_name:
  description: "functools.partialmethod.__name__.__eq__('partialmethod') == True — partialmethod class name is 'partialmethod'; wave 243 partialmethod class identity; new to extra82"
  kind: python_call_eq
  function: partialmethod.__name__.__eq__
  args: ["partialmethod"]
  expected: true

invariant functools_extra82.partialmethod_module:
  description: "functools.partialmethod.__module__.__eq__('functools') == True — partialmethod is defined in the functools module; wave 243 partialmethod class identity; new to extra82"
  kind: python_call_eq
  function: partialmethod.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra82.partialmethod_mro_len:
  description: "functools.partialmethod.__mro__.__len__() == 2 — partialmethod MRO is [partialmethod, object]; wave 243 partialmethod bases/MRO; new to extra82"
  kind: python_call_eq
  function: partialmethod.__mro__.__len__
  args: []
  expected: 2

invariant functools_extra82.partialmethod_dict_contains_get:
  description: "functools.partialmethod.__dict__.__contains__('__get__') == True — partialmethod implements the descriptor __get__ hook; wave 243 partialmethod metaclass/dict; new to extra82"
  kind: python_call_eq
  function: partialmethod.__dict__.__contains__
  args: ["__get__"]
  expected: true

invariant functools_extra82.WRAPPER_UPDATES_len:
  description: "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES is ('__dict__',), a single-element tuple; wave 243 WRAPPER_UPDATES constant; new to extra82"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1
