  kind: python_call_eq
  function: Thread.run.__qualname__.__eq__
  args: ["Thread.run"]
  expected: true

invariant threading_extra198.thread_join_qualname:
  description: "threading.Thread.join.__qualname__ == 'Thread.join' — blocks until thread terminates; class method qualname includes class prefix; new to extra198"
