invariant threading_extra198.thread_getname_qualname:
  description: "threading.Thread.getName.__qualname__ == 'Thread.getName' — deprecated method still present in Python 3.14.3; new to extra198"
  kind: python_call_eq
  function: Thread.getName.__qualname__.__eq__
  args: ["Thread.getName"]
  expected: true

invariant threading_extra198.thread_setname_qualname:
  description: "threading.Thread.setName.__qualname__ == 'Thread.setName' — deprecated method still present in Python 3.14.3; new to extra198"
  kind: python_call_eq
