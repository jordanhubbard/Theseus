  description: "threading.Thread.start.__qualname__ == 'Thread.start' — class method qualname includes class prefix; new to extra198"
  kind: python_call_eq
  function: Thread.start.__qualname__.__eq__
  args: ["Thread.start"]
  expected: true

invariant threading_extra198.thread_run_qualname:
