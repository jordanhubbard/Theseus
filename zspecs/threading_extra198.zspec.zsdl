  args: ["Thread.setName"]
  expected: true

invariant threading_extra198.thread_name_property:
  description: "threading.Thread.name.__class__.__name__ == 'property' — property descriptor replacing deprecated getName/setName; new to extra198"
  kind: python_call_eq
  function: Thread.name.__class__.__name__.__eq__
