spec: threading_extra198
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "This spec covers: threading.Thread method qualnames and property descriptor class names."
    - "threading.Thread.start.__qualname__ == 'Thread.start' — start is a method of class Thread in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Thread.run.__qualname__ == 'Thread.run' — run is the overrideable method that contains the thread activity. Verified with Python 3.14.3."
    - "threading.Thread.join.__qualname__ == 'Thread.join' — join blocks until the thread terminates. Verified with Python 3.14.3."
    - "threading.Thread.is_alive.__qualname__ == 'Thread.is_alive' — is_alive returns True if the thread is alive. Verified with Python 3.14.3."
    - "threading.Thread.getName.__qualname__ == 'Thread.getName' — getName is deprecated but still present; returns the thread name. Verified with Python 3.14.3."
    - "threading.Thread.setName.__qualname__ == 'Thread.setName' — setName is deprecated but still present; sets the thread name. Verified with Python 3.14.3."
    - "threading.Thread.name.__class__.__name__ == 'property' — name is a property descriptor on Thread. Verified with Python 3.14.3."
    - "threading.Thread.daemon.__class__.__name__ == 'property' — daemon is a property descriptor on Thread. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread method qualnames — start, run, join, is_alive
#
# threading.Thread.start.__qualname__.__eq__('Thread.start') == True
# threading.Thread.run.__qualname__.__eq__('Thread.run') == True
# threading.Thread.join.__qualname__.__eq__('Thread.join') == True
# threading.Thread.is_alive.__qualname__.__eq__('Thread.is_alive') == True
#
# Thread is a pure-Python class in Lib/threading.py; its methods have
# __qualname__ of the form 'Thread.method_name'. New to extra198.
# ---------------------------------------------------------------------------

table threading_extra198.thread_method_qualnames_1:
  description: "threading.Thread start/run/join/is_alive __qualname__; pure-Python class methods with 'Thread.' prefix qualname; new to extra198"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingthreadmethods198

  columns: [id, function, args, expected, description]
  rows:
    - [thread_start_qualname,
       Thread.start.__qualname__.__eq__,
       ["Thread.start"],
       true,
       "threading.Thread.start.__qualname__.__eq__('Thread.start') == True — start is defined in class Thread in Lib/threading.py; it starts the thread's activity and may only be called once; __qualname__ is 'Thread.start'; str.__eq__('Thread.start') returns True; new to extra198"]
    - [thread_run_qualname,
       Thread.run.__qualname__.__eq__,
       ["Thread.run"],
       true,
       "threading.Thread.run.__qualname__.__eq__('Thread.run') == True — run is the overrideable method that contains the thread activity; subclasses override this method; __qualname__ is 'Thread.run'; str.__eq__('Thread.run') returns True; new to extra198"]
    - [thread_join_qualname,
       Thread.join.__qualname__.__eq__,
       ["Thread.join"],
       true,
       "threading.Thread.join.__qualname__.__eq__('Thread.join') == True — join blocks the calling thread until the thread terminates; it accepts an optional timeout; __qualname__ is 'Thread.join'; str.__eq__('Thread.join') returns True; new to extra198"]
    - [thread_is_alive_qualname,
       Thread.is_alive.__qualname__.__eq__,
       ["Thread.is_alive"],
       true,
       "threading.Thread.is_alive.__qualname__.__eq__('Thread.is_alive') == True — is_alive returns True if the thread is alive (started but not yet terminated); __qualname__ is 'Thread.is_alive'; str.__eq__('Thread.is_alive') returns True; new to extra198"]

# ---------------------------------------------------------------------------
# Table 2: threading.Thread deprecated method qualnames — getName, setName
#
# threading.Thread.getName.__qualname__.__eq__('Thread.getName') == True
# threading.Thread.setName.__qualname__.__eq__('Thread.setName') == True
#
# getName and setName are deprecated since Python 3.10 in favor of the name
# property, but they remain present in Python 3.14.3 and have __qualname__
# of the form 'Thread.getName' / 'Thread.setName'. New to extra198.
# ---------------------------------------------------------------------------

table threading_extra198.thread_deprecated_method_qualnames:
  description: "threading.Thread getName/setName __qualname__; deprecated methods still present in Python 3.14.3; new to extra198"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingthreadmethods198

  columns: [id, function, args, expected, description]
  rows:
    - [thread_getname_qualname,
       Thread.getName.__qualname__.__eq__,
       ["Thread.getName"],
       true,
       "threading.Thread.getName.__qualname__.__eq__('Thread.getName') == True — getName is a deprecated method (since 3.10) that returns the thread name; it remains present in Python 3.14.3; __qualname__ is 'Thread.getName'; str.__eq__('Thread.getName') returns True; new to extra198"]
    - [thread_setname_qualname,
       Thread.setName.__qualname__.__eq__,
       ["Thread.setName"],
       true,
       "threading.Thread.setName.__qualname__.__eq__('Thread.setName') == True — setName is a deprecated method (since 3.10) that sets the thread name; it remains present in Python 3.14.3; __qualname__ is 'Thread.setName'; str.__eq__('Thread.setName') returns True; new to extra198"]

# ---------------------------------------------------------------------------
# Table 3: threading.Thread property descriptor class names — name, daemon
#
# threading.Thread.name.__class__.__name__.__eq__('property') == True
# threading.Thread.daemon.__class__.__name__.__eq__('property') == True
#
# Both name and daemon are defined as property descriptors on Thread using
# @property in Lib/threading.py. They replaced the deprecated getName/setName
# and isDaemon/setDaemon accessors. New to extra198.
# ---------------------------------------------------------------------------

table threading_extra198.thread_property_class_names:
  description: "threading.Thread name/daemon __class__.__name__=='property'; both are property descriptors defined with @property in Lib/threading.py; new to extra198"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingthreadmethods198

  columns: [id, function, args, expected, description]
  rows:
    - [thread_name_property,
       Thread.name.__class__.__name__.__eq__,
       ["property"],
       true,
       "threading.Thread.name.__class__.__name__.__eq__('property') == True — name is a property descriptor on Thread defined with @property in Lib/threading.py; it replaced the deprecated getName/setName methods; __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra198"]
    - [thread_daemon_property,
       Thread.daemon.__class__.__name__.__eq__,
       ["property"],
       true,
       "threading.Thread.daemon.__class__.__name__.__eq__('property') == True — daemon is a property descriptor on Thread defined with @property in Lib/threading.py; it replaced the deprecated isDaemon/setDaemon methods; __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra198"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra198
# ---------------------------------------------------------------------------

