spec: uuid_extra1546
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra1531.zspec.zsdl — covers comparison operator dict-presence checks on UUID and SafeUUID."
    - "uuid_extra1516.zspec.zsdl — covers arithmetic operator absence (__add__ through __pow__) for UUID and SafeUUID."
    - "uuid_extra1501.zspec.zsdl — covers bitwise operator absence on UUID and SafeUUID (earlier wave)."
  notes:
    - "This spec is wave 550 / suffix _extra1546. Theme: bitwise operator dict-presence checks on uuid.UUID and uuid.SafeUUID."
    - "uuid.UUID wraps a 128-bit integer. While it stores an integer internally (the .int property), it does not expose integer arithmetic or bitwise operations in its own __dict__."
    - "uuid.UUID does NOT define __and__, __or__, __xor__, __invert__, __lshift__, __rshift__ in UUID.__dict__. It is not designed to be used as a bitmask or bitfield."
    - "uuid.SafeUUID is an enum.Enum subclass (NOT enum.Flag or enum.IntFlag). Despite the common confusion with flag enums, SafeUUID has exactly three values (safe=0, unsafe=-1, unknown=None) and defines no bitwise operators in its own __dict__."
    - "SafeUUID inherits from enum.Enum (not IntFlag or Flag), so no bitwise combination operators are inherited either."
    - "Verified: '__and__' in uuid.UUID.__dict__ == False."
    - "Verified: '__or__' in uuid.UUID.__dict__ == False."
    - "Verified: '__xor__' in uuid.UUID.__dict__ == False."
    - "Verified: '__invert__' in uuid.UUID.__dict__ == False."
    - "Verified: '__lshift__' in uuid.UUID.__dict__ == False."
    - "Verified: '__rshift__' in uuid.UUID.__dict__ == False."
    - "Verified: '__rand__' in uuid.UUID.__dict__ == False."
    - "Verified: '__ror__' in uuid.UUID.__dict__ == False."
    - "Verified: '__rxor__' in uuid.UUID.__dict__ == False."
    - "Verified: uuid.SafeUUID.__bases__ == (<enum 'Enum'>,) — plain Enum, not Flag."
    - "Verified: '__and__' in uuid.SafeUUID.__dict__ == False (through __rxor__) == False."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID — bitwise operator absence checks
#
# uuid.UUID stores a 128-bit integer internally (accessible via .int), but
# it is an identity value type, not a numeric type. No bitwise operators
# (__and__, __or__, __xor__, __invert__, __lshift__, __rshift__) are defined
# in UUID.__dict__. The reflected variants (__rand__, __ror__, __rxor__) are
# also absent — UUID cannot serve as the right operand in a bitwise
# expression with an integer. The True entries (__eq__, __lt__, __hash__,
# __init__) confirm that dict-presence lookups on UUID work correctly.
# Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-12.
# ---------------------------------------------------------------------------

table uuid_extra1546.UUID_bitwise_absent:
  description: "Bitwise operator dunders absent from uuid.UUID.__dict__ — UUID is an identity type, not numeric"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu1546ua

  columns: [id, function, args, expected]
  rows:
    - ["uu1546ua001", "UUID.__dict__.__contains__", ["__and__"],    false]
    - ["uu1546ua002", "UUID.__dict__.__contains__", ["__or__"],     false]
    - ["uu1546ua003", "UUID.__dict__.__contains__", ["__xor__"],    false]
    - ["uu1546ua004", "UUID.__dict__.__contains__", ["__invert__"], false]
    - ["uu1546ua005", "UUID.__dict__.__contains__", ["__lshift__"], false]
    - ["uu1546ua006", "UUID.__dict__.__contains__", ["__rshift__"], false]
    - ["uu1546ua007", "UUID.__dict__.__contains__", ["__rand__"],   false]
    - ["uu1546ua008", "UUID.__dict__.__contains__", ["__ror__"],    false]
    - ["uu1546ua009", "UUID.__dict__.__contains__", ["__rxor__"],   false]
    - ["uu1546ua010", "UUID.__dict__.__contains__", ["__eq__"],     true]
    - ["uu1546ua011", "UUID.__dict__.__contains__", ["__lt__"],     true]
    - ["uu1546ua012", "UUID.__dict__.__contains__", ["__hash__"],   true]

# ---------------------------------------------------------------------------
# uuid.SafeUUID — bitwise operator absence checks
#
# uuid.SafeUUID is defined as class SafeUUID(enum.Enum) — a plain Enum, NOT
# an IntFlag or Flag subclass. Despite the name suggesting safety flags, it
# is a simple three-valued enum: safe (0), unsafe (-1), unknown (None). None
# of the bitwise dunders (__and__, __or__, __xor__, __invert__, __lshift__,
# __rshift__, __rand__, __ror__, __rxor__) are defined in SafeUUID.__dict__.
# The True entries (safe, unsafe, unknown, __new__, __doc__) confirm that
# dict-presence lookups on SafeUUID work correctly.
# Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-12.
# ---------------------------------------------------------------------------

table uuid_extra1546.SafeUUID_bitwise_absent:
  description: "Bitwise operator dunders absent from uuid.SafeUUID.__dict__ — plain Enum, not IntFlag"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu1546sb

  columns: [id, function, args, expected]
  rows:
    - ["uu1546sb001", "SafeUUID.__dict__.__contains__", ["__and__"],    false]
    - ["uu1546sb002", "SafeUUID.__dict__.__contains__", ["__or__"],     false]
    - ["uu1546sb003", "SafeUUID.__dict__.__contains__", ["__xor__"],    false]
    - ["uu1546sb004", "SafeUUID.__dict__.__contains__", ["__invert__"], false]
    - ["uu1546sb005", "SafeUUID.__dict__.__contains__", ["__lshift__"], false]
    - ["uu1546sb006", "SafeUUID.__dict__.__contains__", ["__rshift__"], false]
    - ["uu1546sb007", "SafeUUID.__dict__.__contains__", ["__rand__"],   false]
    - ["uu1546sb008", "SafeUUID.__dict__.__contains__", ["__ror__"],    false]
    - ["uu1546sb009", "SafeUUID.__dict__.__contains__", ["__rxor__"],   false]
    - ["uu1546sb010", "SafeUUID.__dict__.__contains__", ["safe"],       true]
    - ["uu1546sb011", "SafeUUID.__dict__.__contains__", ["unsafe"],     true]
    - ["uu1546sb012", "SafeUUID.__dict__.__contains__", ["unknown"],    true]

# ---------------------------------------------------------------------------
# uuid.UUID — reflected bitwise operator absence cross-check
#
# This table provides a cross-check focused on the reflected (right-hand)
# bitwise operator variants and also confirms that the arithmetic dunders
# absent from UUID extend to __floordiv__ and __mod__ (for completeness).
# It also verifies that UUID's useful properties (bytes, hex, int, urn) are
# present in __dict__, establishing that the class has a rich value interface
# despite lacking bitwise operators.
# ---------------------------------------------------------------------------

table uuid_extra1546.UUID_reflected_bitwise_and_props:
  description: "Reflected bitwise dunders absent and value-property dunders present in uuid.UUID.__dict__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu1546rp

  columns: [id, function, args, expected]
  rows:
    - ["uu1546rp001", "UUID.__dict__.__contains__", ["__rand__"],   false]
    - ["uu1546rp002", "UUID.__dict__.__contains__", ["__ror__"],    false]
    - ["uu1546rp003", "UUID.__dict__.__contains__", ["__rxor__"],   false]
    - ["uu1546rp004", "UUID.__dict__.__contains__", ["__add__"],    false]
    - ["uu1546rp005", "UUID.__dict__.__contains__", ["__mul__"],    false]
    - ["uu1546rp006", "UUID.__dict__.__contains__", ["bytes"],      true]
    - ["uu1546rp007", "UUID.__dict__.__contains__", ["hex"],        true]
    - ["uu1546rp008", "UUID.__dict__.__contains__", ["int"],        true]
    - ["uu1546rp009", "UUID.__dict__.__contains__", ["urn"],        true]
    - ["uu1546rp010", "UUID.__dict__.__contains__", ["variant"],    true]
    - ["uu1546rp011", "UUID.__dict__.__contains__", ["version"],    true]
    - ["uu1546rp012", "UUID.__dict__.__contains__", ["is_safe"],    true]
