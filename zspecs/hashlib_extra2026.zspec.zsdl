spec: hashlib_extra2026
version: ">=3.9"
backend: python_module(_hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/hashlib.html"
    - "CPython source: Modules/_hashopenssl.c"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 582 (_extra2026): __truediv__, __floordiv__, __mod__, __pow__, __divmod__ dict-presence checks."
    - "_hashlib.HASH is a cryptographic digest type, not an arithmetic type; it defines none of these division, modulo, or exponentiation protocols."
    - "hashlib.blake2b and hashlib.blake2s are real type objects; they are also non-arithmetic."
    - "All division/modulo/exponentiation dunder methods are absent from all three hashlib hash type dicts."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table hashlib_extra2026.hash_truediv_protocol:
  description: "_hashlib.HASH __truediv__/__rtruediv__/__itruediv__ dict-presence checks (HASH is not arithmetic)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2026

  columns: [id, function, args, expected]
  rows:
    - ["hl2026001", "_hashlib.HASH.__dict__.__contains__", ["__truediv__"], false]
    - ["hl2026002", "_hashlib.HASH.__dict__.__contains__", ["__rtruediv__"], false]
    - ["hl2026003", "_hashlib.HASH.__dict__.__contains__", ["__itruediv__"], false]

