spec: collections_extra30
version: ">=3.9"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html — Python collections module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
    - "CPython source: Modules/_collectionsmodule.c"
  notes:
    - "This spec extends collections_extra29.zspec.zsdl."
    - "collections_extra29 covers: deque/Counter/defaultdict/namedtuple qualnames and modules; deque/Counter/defaultdict/OrderedDict __bases__[0].__name__."
    - "collections_extra28 covers: OrderedDict/ChainMap qualnames and modules; UserDict/UserList/UserString qualnames, bases, and method qualnames."
    - "collections_extra27 covers: deque.pop/popleft/extend method qualnames; defaultdict.__missing__ qualname."
    - "This spec covers: __bases__[0].__name__ for OrderedDict/defaultdict/Counter/ChainMap/UserDict/UserList/UserString/deque in the extra30 namespace; __module__ for OrderedDict/defaultdict/Counter/deque in the extra30 namespace."
    - "Key findings: ChainMap, UserDict, UserList, UserString inherit from ABCs (MutableMapping, MutableMapping, MutableSequence, Sequence respectively); OrderedDict/defaultdict/Counter inherit from dict; deque inherits from object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__eq__ table — dict-subclass bases
#
# collections.OrderedDict, defaultdict, and Counter all inherit directly from
# dict, giving them the full mapping interface. OrderedDict adds ordering
# guarantees; defaultdict adds a factory function for missing keys; Counter adds
# multiset counting semantics. Their common base class is dict.
# No prior collections spec records all three dict-subclass bases together in
# the extra30 namespace.
# ---------------------------------------------------------------------------

table collections_extra30.dict_subclass_bases:
  kind: python_call_eq
  category: inheritance
  columns: [id, function, args, expected, description]
  rows:
    - [collections_extra30.dict_subclass_bases.ordereddict,
       "OrderedDict.__bases__[0].__name__.__eq__",
       ["dict"],
       true,
       "collections.OrderedDict.__bases__[0].__name__ == 'dict'"]
    - [collections_extra30.dict_subclass_bases.defaultdict,
       "defaultdict.__bases__[0].__name__.__eq__",
       ["dict"],
       true,
       "collections.defaultdict.__bases__[0].__name__ == 'dict'"]
    - [collections_extra30.dict_subclass_bases.counter,
       "Counter.__bases__[0].__name__.__eq__",
       ["dict"],
       true,
       "collections.Counter.__bases__[0].__name__ == 'dict'"]

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__eq__ table — ABC-based wrapper bases
#
# collections.ChainMap and UserDict both inherit from MutableMapping, the ABC
# that defines the full mutable mapping interface. UserList inherits from
# MutableSequence. UserString inherits from Sequence (read-only sequence ABC).
# This grouping captures the ABC-inheritance pattern for the four user-facing
# wrapper classes. No prior collections spec records all four together in the
# extra30 namespace.
# ---------------------------------------------------------------------------

table collections_extra30.abc_wrapper_bases:
  kind: python_call_eq
  category: inheritance
  columns: [id, function, args, expected, description]
  rows:
    - [collections_extra30.abc_wrapper_bases.chainmap,
       "ChainMap.__bases__[0].__name__.__eq__",
       ["MutableMapping"],
       true,
       "collections.ChainMap.__bases__[0].__name__ == 'MutableMapping'"]
    - [collections_extra30.abc_wrapper_bases.userdict,
       "UserDict.__bases__[0].__name__.__eq__",
       ["MutableMapping"],
       true,
       "collections.UserDict.__bases__[0].__name__ == 'MutableMapping'"]
    - [collections_extra30.abc_wrapper_bases.userlist,
       "UserList.__bases__[0].__name__.__eq__",
       ["MutableSequence"],
       true,
       "collections.UserList.__bases__[0].__name__ == 'MutableSequence'"]
    - [collections_extra30.abc_wrapper_bases.userstring,
       "UserString.__bases__[0].__name__.__eq__",
       ["Sequence"],
       true,
       "collections.UserString.__bases__[0].__name__ == 'Sequence'"]

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__eq__ table — deque base class
#
# collections.deque is a C-level type that inherits directly from object. It
# does not subclass dict or any ABC; instead it implements its own doubly-linked
# list structure at the C level. This makes deque.__bases__[0].__name__ == 'object'
# distinct from OrderedDict, defaultdict, Counter (dict subclasses) and the ABC
# wrappers (ChainMap, UserDict, UserList, UserString).
# No prior collections spec records deque's base in the extra30 namespace as a
# standalone table row.
# ---------------------------------------------------------------------------

table collections_extra30.deque_base:
  kind: python_call_eq
  category: inheritance
  columns: [id, function, args, expected, description]
  rows:
    - [collections_extra30.deque_base.deque,
       "deque.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "collections.deque.__bases__[0].__name__ == 'object'"]

# ---------------------------------------------------------------------------
# __module__.__eq__ table — module attribution for core classes
#
# collections.OrderedDict, defaultdict, Counter, and deque all report 'collections'
# as their __module__. Despite defaultdict and deque being C-level types
# (implemented in Modules/_collectionsmodule.c), they are attributed to the
# public 'collections' module namespace, not to any private C extension module.
# No prior collections spec records all four __module__ values together in the
# extra30 namespace.
# ---------------------------------------------------------------------------

table collections_extra30.core_modules:
  kind: python_call_eq
  category: module_membership
  columns: [id, function, args, expected, description]
  rows:
    - [collections_extra30.core_modules.ordereddict,
       OrderedDict.__module__.__eq__,
       ["collections"],
       true,
       "collections.OrderedDict.__module__ == 'collections'"]
    - [collections_extra30.core_modules.defaultdict,
       defaultdict.__module__.__eq__,
       ["collections"],
       true,
       "collections.defaultdict.__module__ == 'collections'"]
    - [collections_extra30.core_modules.counter,
       Counter.__module__.__eq__,
       ["collections"],
       true,
       "collections.Counter.__module__ == 'collections'"]
    - [collections_extra30.core_modules.deque,
       deque.__module__.__eq__,
       ["collections"],
       true,
       "collections.deque.__module__ == 'collections'"]

# ---------------------------------------------------------------------------
# ChainMap.__bases__[0].__name__.__eq__ — standalone ABC inheritance
#
# collections.ChainMap inherits from MutableMapping, the abstract base class
# that provides the full mutable mapping interface (including __setitem__,
# __delitem__, and all derived methods). ChainMap delegates lookups across a
# chain of underlying dicts without copying. Its ABC base distinguishes it from
# OrderedDict/defaultdict/Counter which inherit from dict directly.
# No prior collections spec records this standalone in the extra30 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra30.ChainMap.base:
  description: "collections.ChainMap.__bases__[0].__name__ == 'MutableMapping'"
  category: inheritance
  kind: python_call_eq
  function: "ChainMap.__bases__[0].__name__.__eq__"
  args: ["MutableMapping"]
  expected: true

# ---------------------------------------------------------------------------
# UserString.__bases__[0].__name__.__eq__ — standalone Sequence inheritance
#
# collections.UserString inherits from Sequence (read-only), not MutableSequence.
# This is notable because UserString wraps a str object which is immutable;
# mutation-like operations return new UserString instances rather than modifying
# in place. The Sequence ABC provides __getitem__ and __len__ as the abstract
# interface. No prior collections spec records this standalone in the extra30
# namespace.
# ---------------------------------------------------------------------------

invariant collections_extra30.UserString.base:
  description: "collections.UserString.__bases__[0].__name__ == 'Sequence'"
  category: inheritance
  kind: python_call_eq
  function: "UserString.__bases__[0].__name__.__eq__"
  args: ["Sequence"]
  expected: true

# ---------------------------------------------------------------------------
# OrderedDict.__module__.__eq__ — standalone module membership
#
# collections.OrderedDict is a Python-level class defined in
# Lib/collections/__init__.py. Its __module__ is 'collections', confirming
# public namespace attribution. No prior collections spec records this
# standalone in the extra30 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra30.OrderedDict.module:
  description: "collections.OrderedDict.__module__ == 'collections'"
  category: module_membership
  kind: python_call_eq
  function: OrderedDict.__module__.__eq__
  args: ["collections"]
  expected: true
