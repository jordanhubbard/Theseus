spec: hashlib_extra138
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "CPython source: Modules/_blake2module.c"
    - "hashlib_extra137.zspec.zsdl — covers hashlib.pbkdf2_hmac __name__/__qualname__/__module__/__class__.__name__ / sha256.__doc__ class and length / new.__code__.co_name and co_varnames[0] and co_varnames.__len__() / algorithms_guaranteed and algorithms_available class names and lengths (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers blake2b/__class__.__name__=='type' / blake2s/__class__.__name__=='type' / blake2b/__module__=='_blake2' / blake2s/__module__=='_blake2' / blake2b/__qualname__=='blake2b' / blake2s/__qualname__=='blake2s' (table + invariants)."
    - "hashlib_extra98.zspec.zsdl — covers sha3_*/shake_* constructor __qualname__ and __module__ equality / sha3_*/shake_* __class__.__name__=='builtin_function_or_method' / file_digest function identity / hashlib.__all__ class name and length (table + invariants)."
    - "hashlib_extra97.zspec.zsdl — covers hashlib.algorithms_guaranteed membership / new/__qualname__/__len__() (table + invariants)."
    - "hashlib_extra96.zspec.zsdl — covers hashlib.__name__/__package__/__spec__/__loader__/__doc__ module identity / sha256/sha512/sha1/md5 __module__ cross-checks (table + invariants)."
    - "hashlib_extra95.zspec.zsdl — covers hashlib.new/__qualname__ / sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__ and __module__ (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior hashlib spec files."
    - "Wave 353 theme: hashlib.blake2b and blake2s C-type class constants (PERSON_SIZE, SALT_SIZE, MAX_KEY_SIZE, MAX_DIGEST_SIZE) / blake2b/blake2s __bases__[0].__name__ and MRO / hashlib.scrypt __name__/__qualname__/__module__/__class__.__name__."
    - "hashlib.blake2b.PERSON_SIZE == 16. The personalization string size for blake2b. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.SALT_SIZE == 16. The salt size for blake2b. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.MAX_KEY_SIZE == 64. blake2b supports up to 64-byte keys. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.MAX_DIGEST_SIZE == 64. blake2b produces digests up to 64 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.PERSON_SIZE == 8. Personalization string size for blake2s (half of blake2b). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.SALT_SIZE == 8. Salt size for blake2s (half of blake2b). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.MAX_KEY_SIZE == 32. blake2s supports up to 32-byte keys (half of blake2b). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.MAX_DIGEST_SIZE == 32. blake2s produces digests up to 32 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__bases__[0].__name__ == 'object'. blake2b directly subclasses object (C extension type). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__bases__[0].__name__ == 'object'. blake2s directly subclasses object. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__mro__[0].__name__ == 'blake2b'. First entry in blake2b MRO is blake2b itself. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__mro__[1].__name__ == 'object'. blake2b has a 2-entry MRO: (blake2b, object). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__name__ == 'scrypt'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__qualname__ == 'scrypt'. scrypt is a top-level C builtin. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__module__ == '_hashlib'. scrypt is implemented in the _hashlib C extension. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__class__.__name__ == 'builtin_function_or_method'. scrypt is a C builtin (like pbkdf2_hmac), NOT a C-extension type (unlike blake2b/blake2s). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: extra99 anchors blake2b/blake2s __class__.__name__=='type', __module__=='_blake2', __qualname__ equality. This spec is the first to anchor blake2b/blake2s class constants (PERSON_SIZE, SALT_SIZE, MAX_KEY_SIZE, MAX_DIGEST_SIZE), MRO entries, and scrypt identity (__name__/__qualname__/__module__/__class__.__name__) under hashlibblake138."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.blake2b.PERSON_SIZE.__eq__(16)
# hashlib.blake2b.SALT_SIZE.__eq__(16)
# hashlib.blake2b.MAX_KEY_SIZE.__eq__(64)
# hashlib.blake2b.MAX_DIGEST_SIZE.__eq__(64)
# hashlib.blake2s.PERSON_SIZE.__eq__(8)
#
# Wave 353 theme: blake2b/blake2s class-level size constants.
#
# hashlib.blake2b and hashlib.blake2s are C-extension type objects from the
# _blake2 module (their __class__.__name__ is 'type'). As C types, they expose
# class-level integer constants for their algorithmic parameters: PERSON_SIZE
# (personalization string length), SALT_SIZE (salt length), MAX_KEY_SIZE
# (maximum HMAC key length), and MAX_DIGEST_SIZE (maximum output size). blake2b
# uses 128-bit (16-byte) fields and 64-byte digests; blake2s uses 64-bit (8-byte)
# fields and 32-byte digests — exactly half of blake2b in all dimensions. No
# prior hashlib spec anchors these class constants via __eq__ under hashlibblake138.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra138.blake2b_constants:
  description: "hashlib.blake2b/PERSON_SIZE.__eq__(16)==True / blake2b/SALT_SIZE.__eq__(16)==True / blake2b/MAX_KEY_SIZE.__eq__(64)==True / blake2b/MAX_DIGEST_SIZE.__eq__(64)==True / blake2s/PERSON_SIZE.__eq__(8)==True — blake2b is a C-extension type with class-level parameter constants; PERSON_SIZE and SALT_SIZE are 16 (128-bit); MAX_KEY_SIZE and MAX_DIGEST_SIZE are 64 bytes; blake2s PERSON_SIZE is 8 (64-bit, half of blake2b); extra99 anchors blake2b class identity; first hashlibblake138 anchor for class constants"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibblake138

  columns: [id, function, args, expected, description]
  rows:
    - [b2b_person_size,  blake2b.PERSON_SIZE.__eq__,    [16],  true, "blake2b.PERSON_SIZE is 16 (16-byte / 128-bit personalization string)"]
    - [b2b_salt_size,    blake2b.SALT_SIZE.__eq__,       [16],  true, "blake2b.SALT_SIZE is 16 (16-byte / 128-bit salt)"]
    - [b2b_max_key,      blake2b.MAX_KEY_SIZE.__eq__,    [64],  true, "blake2b.MAX_KEY_SIZE is 64 (64-byte maximum keyed-hashing key)"]
    - [b2b_max_digest,   blake2b.MAX_DIGEST_SIZE.__eq__,  [64],  true, "blake2b.MAX_DIGEST_SIZE is 64 (64-byte / 512-bit maximum output)"]
    - [b2s_person_size,  blake2s.PERSON_SIZE.__eq__,    [8],   true, "blake2s.PERSON_SIZE is 8 (8-byte / 64-bit; half of blake2b's 16)"]

# ---------------------------------------------------------------------------
# hashlib.blake2s.SALT_SIZE.__eq__(8)
# hashlib.blake2s.MAX_KEY_SIZE.__eq__(32)
# hashlib.blake2s.MAX_DIGEST_SIZE.__eq__(32)
# hashlib.blake2b.__bases__[0].__name__.__eq__('object')
# hashlib.blake2s.__bases__[0].__name__.__eq__('object')
#
# Wave 353 theme: blake2s constants and blake2 base class identity.
#
# blake2s mirrors blake2b in structure but with half the parameter sizes: 8-byte
# personalization/salt fields and 32-byte maximum key/digest. Like blake2b, blake2s
# is a C-extension type that directly subclasses object (no intermediate Python
# base). Its __bases__ is (object,) with __bases__[0].__name__ == 'object'. The
# 2-entry MRO (blake2s, object) can be confirmed via __bases__[0].__name__. No
# prior hashlib spec anchors blake2s SALT_SIZE/MAX_KEY_SIZE/MAX_DIGEST_SIZE or
# blake2b/blake2s __bases__[0].__name__ under hashlibblake138.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra138.blake2s_constants_and_bases:
  description: "hashlib.blake2s/SALT_SIZE.__eq__(8)==True / blake2s/MAX_KEY_SIZE.__eq__(32)==True / blake2s/MAX_DIGEST_SIZE.__eq__(32)==True / blake2b/__bases__[0]/__name__.__eq__('object')==True / blake2s/__bases__[0]/__name__.__eq__('object')==True — blake2s constants are half of blake2b (8-byte salt, 32-byte key/digest); both blake2b and blake2s directly subclass object (C types with minimal MRO); extra99 anchors blake2b module and qualname; first hashlibblake138 anchor for blake2s constants and bases"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibblake138

  columns: [id, function, args, expected, description]
  rows:
    - [b2s_salt_size,    blake2s.SALT_SIZE.__eq__,                       [8],       true, "blake2s.SALT_SIZE is 8 (8-byte / 64-bit salt; half of blake2b's 16)"]
    - [b2s_max_key,      blake2s.MAX_KEY_SIZE.__eq__,                    [32],      true, "blake2s.MAX_KEY_SIZE is 32 (32-byte maximum key; half of blake2b's 64)"]
    - [b2s_max_digest,   blake2s.MAX_DIGEST_SIZE.__eq__,                  [32],      true, "blake2s.MAX_DIGEST_SIZE is 32 (32-byte / 256-bit maximum output; half of blake2b's 64)"]
    - [b2b_base_name,    "blake2b.__bases__[0].__name__.__eq__",         ["object"], true, "blake2b.__bases__[0].__name__ is 'object' (blake2b is a C type directly subclassing object)"]
    - [b2s_base_name,    "blake2s.__bases__[0].__name__.__eq__",         ["object"], true, "blake2s.__bases__[0].__name__ is 'object' (blake2s directly subclasses object; 2-entry MRO)"]

# ---------------------------------------------------------------------------
# hashlib.scrypt.__name__.__eq__('scrypt')
# hashlib.scrypt.__qualname__.__eq__('scrypt')
# hashlib.scrypt.__module__.__eq__('_hashlib')
# hashlib.scrypt.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.blake2b.__mro__[0].__name__.__eq__('blake2b')
#
# Wave 353 theme: hashlib.scrypt C builtin identity and blake2b MRO.
#
# hashlib.scrypt is the memory-hard password-hashing function based on the
# scrypt algorithm (RFC 7914). Unlike blake2b and blake2s (which are C-extension
# TYPES with __class__.__name__=='type'), scrypt is a C builtin FUNCTION from
# _hashlib with __class__.__name__=='builtin_function_or_method'. This is the
# same category as pbkdf2_hmac. scrypt.__module__=='_hashlib' (not 'hashlib').
# blake2b.__mro__[0].__name__ == 'blake2b' confirms blake2b is the first entry in
# its own MRO (as is always the case for the type itself). No prior hashlib spec
# anchors scrypt __name__/__qualname__/__module__/__class__.__name__ via __eq__
# under hashlibblake138. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra138.scrypt_identity_and_blake2b_mro:
  description: "hashlib.scrypt/__name__.__eq__('scrypt')==True / scrypt/__qualname__.__eq__('scrypt')==True / scrypt/__module__.__eq__('_hashlib')==True / scrypt/__class__/__name__.__eq__('builtin_function_or_method')==True / blake2b/__mro__[0]/__name__.__eq__('blake2b')==True — scrypt is a C builtin (like pbkdf2_hmac) not a type (like blake2b); scrypt lives in _hashlib; blake2b.__mro__[0] is blake2b itself; extra137 anchors pbkdf2_hmac identity; first hashlibblake138 anchor for scrypt identity and blake2b MRO entry"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibblake138

  columns: [id, function, args, expected, description]
  rows:
    - [scrypt_name,     scrypt.__name__.__eq__,                        ["scrypt"],                      true, "scrypt.__name__ is 'scrypt' (6 chars; top-level C function name)"]
    - [scrypt_qualname, scrypt.__qualname__.__eq__,                    ["scrypt"],                      true, "scrypt.__qualname__ is 'scrypt' (no class prefix; same as __name__ for top-level C builtins)"]
    - [scrypt_module,   scrypt.__module__.__eq__,                      ["_hashlib"],                    true, "scrypt.__module__ is '_hashlib' (C extension, same as pbkdf2_hmac)"]
    - [scrypt_class,    scrypt.__class__.__name__.__eq__,              ["builtin_function_or_method"],  true, "scrypt.__class__.__name__ is 'builtin_function_or_method' (C builtin; contrasts with blake2b which is 'type')"]
    - [b2b_mro0,        "blake2b.__mro__[0].__name__.__eq__",          ["blake2b"],                     true, "blake2b.__mro__[0].__name__ is 'blake2b' (first entry in MRO is the type itself)"]

# ---------------------------------------------------------------------------
# hashlib.blake2b.PERSON_SIZE.__eq__(16) — standalone
#
# hashlib.blake2b.PERSON_SIZE is 16. The BLAKE2b algorithm uses 128-bit (16-byte)
# personalization strings. Personalization is an optional, fixed-length parameter
# that allows domain separation — two applications using the same key and input
# can produce different outputs by specifying different personalization strings.
# This is a class-level constant on the C-extension type hashlib.blake2b (from
# _blake2). No prior hashlib spec anchors blake2b.PERSON_SIZE via __eq__ as a
# standalone under hashlibblake138. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra138.blake2b_PERSON_SIZE:
  description: "hashlib.blake2b.PERSON_SIZE.__eq__(16) == True — blake2b accepts 16-byte (128-bit) personalization strings for domain separation; class-level constant on the C-extension type from _blake2; blake2s.PERSON_SIZE==8 (half); extra99 anchors blake2b class identity; first standalone for blake2b.PERSON_SIZE.__eq__ under hashlibblake138"
  category: type_identity
  kind: python_call_eq
  function: blake2b.PERSON_SIZE.__eq__
  args: [16]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.MAX_DIGEST_SIZE.__eq__(64) — standalone
#
# hashlib.blake2b.MAX_DIGEST_SIZE is 64. BLAKE2b can produce digests from 1 to
# 64 bytes (512 bits). The full 64-byte output is 512 bits, making it equivalent
# in output length to SHA-512 but faster on 64-bit platforms. This contrasts with
# blake2s.MAX_DIGEST_SIZE == 32 (256 bits, SHA-256 equivalent). The MAX_DIGEST_SIZE
# class constant allows callers to query the maximum supported digest size without
# constructing an instance. No prior hashlib spec anchors blake2b.MAX_DIGEST_SIZE
# via __eq__ as a standalone under hashlibblake138.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra138.blake2b_MAX_DIGEST_SIZE:
  description: "hashlib.blake2b.MAX_DIGEST_SIZE.__eq__(64) == True — blake2b produces up to 64-byte (512-bit) digests (SHA-512 equivalent length; faster than SHA-512 on 64-bit); contrasts with blake2s.MAX_DIGEST_SIZE==32 (256-bit); class constant on C-extension type; first standalone for blake2b.MAX_DIGEST_SIZE.__eq__ under hashlibblake138"
  category: type_identity
  kind: python_call_eq
  function: blake2b.MAX_DIGEST_SIZE.__eq__
  args: [64]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2s.MAX_DIGEST_SIZE.__eq__(32) — standalone
#
# hashlib.blake2s.MAX_DIGEST_SIZE is 32. BLAKE2s produces digests from 1 to 32
# bytes (256 bits), making it equivalent in output length to SHA-256. BLAKE2s is
# optimized for 8-bit to 32-bit platforms (hence the 's' suffix for "small"),
# while BLAKE2b is optimized for 64-bit platforms. Its parameters are exactly
# half of BLAKE2b's: 32-byte max digest, 32-byte max key, 8-byte salt, 8-byte
# personalization. No prior hashlib spec anchors blake2s.MAX_DIGEST_SIZE via
# __eq__ as a standalone under hashlibblake138.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra138.blake2s_MAX_DIGEST_SIZE:
  description: "hashlib.blake2s.MAX_DIGEST_SIZE.__eq__(32) == True — blake2s produces up to 32-byte (256-bit) digests (SHA-256 equivalent; optimized for 32-bit/small platforms); exactly half of blake2b.MAX_DIGEST_SIZE==64; class constant on C-extension type from _blake2; first standalone for blake2s.MAX_DIGEST_SIZE.__eq__ under hashlibblake138"
  category: type_identity
  kind: python_call_eq
  function: blake2s.MAX_DIGEST_SIZE.__eq__
  args: [32]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.scrypt.__module__.__eq__('_hashlib') — standalone
#
# hashlib.scrypt.__module__ is '_hashlib'. The scrypt algorithm (RFC 7914) is a
# memory-hard key derivation function that requires significant RAM in addition
# to CPU work, making brute-force attacks with GPU/ASIC hardware much more
# expensive than with PBKDF2. Like hashlib.pbkdf2_hmac, scrypt is implemented
# as a C builtin in the _hashlib extension module rather than as a pure Python
# function. Its __module__ attribute reveals its C-level origin. extra137 anchors
# pbkdf2_hmac.__module__=='_hashlib' as a standalone; this is the first standalone
# for scrypt.__module__.__eq__('_hashlib') under hashlibblake138.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra138.scrypt_module:
  description: "hashlib.scrypt.__module__.__eq__('_hashlib') == True — scrypt is C-implemented in _hashlib (not pure Python); memory-hard KDF per RFC 7914; like pbkdf2_hmac, not a C-extension type (unlike blake2b); extra137 anchors pbkdf2_hmac.__module__=='_hashlib'; first standalone for scrypt.__module__.__eq__ under hashlibblake138"
  category: type_identity
  kind: python_call_eq
  function: scrypt.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__mro__[1].__name__.__eq__('object') — standalone
#
# hashlib.blake2b.__mro__[1].__name__ is 'object'. blake2b is a C-extension type
# from the _blake2 module that directly subclasses object (no intermediate Python
# base class). Its MRO is (blake2b, object) — just 2 entries, the minimum possible
# for a non-trivial Python type. This confirms blake2b's minimal type hierarchy:
# unlike sha3_256 (which might have different inheritance), blake2b is a standalone
# C type with no Python-level mixin or parent beyond object. No prior hashlib spec
# anchors blake2b.__mro__[1].__name__ via __eq__ as a standalone under hashlibblake138.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra138.blake2b_mro1_object:
  description: "hashlib.blake2b.__mro__[1].__name__.__eq__('object') == True — blake2b.__mro__ is (blake2b, object); 2-entry minimal MRO; C-extension type directly subclassing object with no intermediate Python base; extra99 anchors blake2b module and class identity; first standalone for blake2b.__mro__[1].__name__.__eq__ under hashlibblake138"
  category: type_identity
  kind: python_call_eq
  function: "blake2b.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true
