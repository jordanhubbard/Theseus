spec: importlib_machinery
version: ">=3.4"
backend: python_module(importlib.machinery)

docs: https://docs.python.org/3/library/importlib.html#importlib.machinery

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/importlib.html#importlib.machinery"
    - "PEP 302 — New Import Hooks"
    - "PEP 451 — A ModuleSpec Type for the Import System"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/importlib/_bootstrap_external.py (internal implementation)"
    - "importlib.zspec.zsdl — covers top-level importlib functions"
    - "importlib_abc.zspec.zsdl — covers importlib.abc abstract base classes"
    - "importlib_util.zspec.zsdl — covers importlib.util helpers"
    - "importlib_extra.zspec.zsdl — covers importlib top-level module identity"
  notes:
    - "importlib.machinery exposes the concrete import machinery classes and suffix lists."
    - "ModuleSpec is defined in importlib._bootstrap (the private bootstrap internals), not importlib.machinery."
    - "FileFinder, SourceFileLoader, SourcelessFileLoader, ExtensionFileLoader are defined in importlib._bootstrap_external."
    - "BuiltinImporter and FrozenImporter handle built-in and frozen modules respectively."
    - "PathFinder is the meta path finder for sys.path and sys.path_hooks."
    - "SOURCE_SUFFIXES, BYTECODE_SUFFIXES, and EXTENSION_SUFFIXES are lists of file extension strings."
    - "all_suffixes() returns a list combining SOURCE_SUFFIXES + BYTECODE_SUFFIXES + EXTENSION_SUFFIXES."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks — all importlib.machinery classes
# ---------------------------------------------------------------------------

table importlib_machinery.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [ModuleSpec,             ModuleSpec.__name__.__eq__,             ["ModuleSpec"],             true]
    - [FileFinder,             FileFinder.__name__.__eq__,             ["FileFinder"],             true]
    - [SourceFileLoader,       SourceFileLoader.__name__.__eq__,       ["SourceFileLoader"],       true]
    - [SourcelessFileLoader,   SourcelessFileLoader.__name__.__eq__,   ["SourcelessFileLoader"],   true]
    - [ExtensionFileLoader,    ExtensionFileLoader.__name__.__eq__,    ["ExtensionFileLoader"],    true]
    - [BuiltinImporter,        BuiltinImporter.__name__.__eq__,        ["BuiltinImporter"],        true]
    - [FrozenImporter,         FrozenImporter.__name__.__eq__,         ["FrozenImporter"],         true]
    - [PathFinder,             PathFinder.__name__.__eq__,             ["PathFinder"],             true]

# ---------------------------------------------------------------------------
# Module membership — ModuleSpec is defined in importlib._bootstrap
# ---------------------------------------------------------------------------

invariant importlib_machinery.ModuleSpec.module:
  description: "importlib.machinery.ModuleSpec.__module__ == 'importlib._bootstrap'"
  category: modules
  kind: python_call_eq
  function: ModuleSpec.__module__.__eq__
  args: ["importlib._bootstrap"]
  expected: true

# ---------------------------------------------------------------------------
# Suffix list type checks — SOURCE_SUFFIXES, BYTECODE_SUFFIXES, EXTENSION_SUFFIXES
# ---------------------------------------------------------------------------

table importlib_machinery.suffix_types:
  kind: python_call_eq
  category: suffixes
  id_prefix: suftype

  columns: [id, function, args, expected]
  rows:
    - [source_suffixes,    SOURCE_SUFFIXES.__class__.__name__.__eq__,    ["list"], true]
    - [bytecode_suffixes,  BYTECODE_SUFFIXES.__class__.__name__.__eq__,  ["list"], true]
    - [extension_suffixes, EXTENSION_SUFFIXES.__class__.__name__.__eq__, ["list"], true]

# ---------------------------------------------------------------------------
# all_suffixes() — returns a list
# ---------------------------------------------------------------------------

invariant importlib_machinery.all_suffixes.returns_list:
  description: "importlib.machinery.all_suffixes().__class__.__name__ == 'list'"
  category: suffixes
  kind: python_call_eq
  function: all_suffixes
  args: []
  method: __class__.__name__.__eq__
  method_args: ["list"]
  expected: true

