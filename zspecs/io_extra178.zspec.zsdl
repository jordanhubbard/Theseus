spec: io_extra178
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/textio.c"
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec covers: io module-level identity (__name__, __package__, __spec__.__class__.__name__, __doc__.__class__.__name__) and io.TextIOWrapper class identity (__name__, __module__, __bases__[0].__name__, __name__.__len__())."
    - "io.__name__ == 'io' (len=2) — the public module name."
    - "io.__package__ == '' (len=0: empty string) — io is a top-level module with no parent package."
    - "io.__spec__.__class__.__name__ == 'ModuleSpec' (len=10: 'Module'(6)+'Spec'(4)=10)."
    - "io.__doc__.__class__.__name__ == 'str' (len=3)."
    - "io.TextIOWrapper.__name__ == 'TextIOWrapper' (len=13: 'Text'(4)+'IO'(2)+'Wrapper'(7)=13)."
    - "io.TextIOWrapper.__module__ == '_io' (len=3) — concrete C extension class."
    - "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' (len=11: '_'(1)+'Text'(4)+'IO'(2)+'Base'(4)=11)."
    - "io.TextIOWrapper.__name__.__len__() == 13 — 'TextIOWrapper' has 13 characters: 'Text'(4)+'IO'(2)+'Wrapper'(7)=13."
    - "io.__name__ (2 chars) == io.__module__ at the C level; 'io' is the shortest standard library module name tied with 're' (2 chars)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io module-level identity: __name__ and __package__
# io.__name__ == 'io' (len=2)
# io.__package__ == '' (len=0) — top-level module, no package
# io.__name__ (2) is the minimum module name length in standard library
# ---------------------------------------------------------------------------

table io_extra178.module_name_package:
  description: "io.__name__=='io' (len=2); io.__package__=='' (len=0: empty string); 'io' is a top-level module with no parent package; io.__name__ (2) == len('re') (2): the io and re module names are both 2-character standard library module names; io.__package__ (empty) contrasts with pathlib.__package__=='pathlib' (7 chars)"
  kind: python_call_eq
  category: identity
  id_prefix: iomod178

  columns: [id, function, args, expected, description]
  rows:
    - [io_name_eq,    io.__name__.__eq__,       ["io"], true,  "io.__name__ == 'io' — the public name of the io module; 'io' has 2 characters: 'i-o'; io.__name__ (2 chars) == re.__name__ (2 chars: 'r-e'): both io and re have the shortest possible 2-character module names among the standard library modules in this spec series; io (2 chars) < decimal (7 chars) < pathlib (7 chars) in module name length; the 2-character name 'io' serves as both the public module name and the module identifier for the abstract base classes (IOBase, RawIOBase, BufferedIOBase, TextIOBase all report __module__ == 'io'); io.__name__ (2 chars) == io.RawIOBase.__module__ (2 chars) — the module name ties with the ABC module attribute; confirmed Python 3.14.3 macOS"]
    - [io_name_len,   io.__name__.__len__,       [],    2,     "io.__name__.__len__() == 2 — 'io' has exactly 2 characters; io.__name__ (2 chars) is the minimum module name length in this spec series: io(2) < re(2) == decimal(7) — actually io(2)==re(2) < pathlib(7)==decimal(7); io.__name__ (2 chars) == len('io') (2 chars): 'i-o' is the alphabetic pair representing input-output; io (2 chars) < '_io' (3 chars) by 1: the public module name is 1 character shorter than the C extension module name; io.__name__.__len__() (2) == re.__name__.__len__() (2): the two shortest standard library module names in this spec series share length 2; confirmed Python 3.14.3 macOS"]
    - [io_pkg_eq,     io.__package__.__eq__,     [""],  true,  "io.__package__ == '' — io is a top-level module with an empty string package attribute; io.__package__ (len=0: empty string) contrasts with pathlib.__package__ (len=7: 'pathlib') and re.__package__ (len=2: 're'); a top-level module with __package__ == '' is a module that is not part of any package hierarchy; io.__package__ (empty) encodes that io sits directly under the Python standard library root, not inside a sub-package; io.__package__ == '' (empty) while io.TextIOWrapper.__module__ == '_io' (3 chars): the module-level and class-level module attributes differ in kind; confirmed Python 3.14.3 macOS"]
    - [io_pkg_len,    io.__package__.__len__,    [],    0,     "io.__package__.__len__() == 0 — io.__package__ is the empty string, which has length 0; io.__package__ (len=0) < io.__name__ (len=2) by 2: the package attribute is 2 characters shorter than the name attribute (empty vs 'io'); io.__package__ (len=0) == decimal.__package__ (len=0): both io and decimal have empty __package__ attributes — both are top-level modules; the 0-length package contrasts with re.__package__ == 're' (len=2) and pathlib.__package__ == 'pathlib' (len=7); io and decimal share the empty-package pattern while re and pathlib differ; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# io module-level identity: __spec__.__class__.__name__ and __doc__.__class__.__name__
# io.__spec__.__class__.__name__ == 'ModuleSpec' (len=10)
# io.__doc__.__class__.__name__ == 'str' (len=3)
# ModuleSpec (10) > str (3) by 7
# ---------------------------------------------------------------------------

table io_extra178.module_spec_doc_class:
  description: "io.__spec__.__class__.__name__=='ModuleSpec' (len=10); io.__doc__.__class__.__name__=='str' (len=3); 'ModuleSpec'='Module'(6)+'Spec'(4)=10; ModuleSpec(10) > str(3) by 7; both class names apply uniformly across io, pathlib, re, decimal modules"
  kind: python_call_eq
  category: identity
  id_prefix: iospec178

  columns: [id, function, args, expected, description]
  rows:
    - [io_spec_cls,  io.__spec__.__class__.__name__.__eq__,  ["ModuleSpec"], true, "io.__spec__.__class__.__name__ == 'ModuleSpec' — io.__spec__ is an instance of importlib.machinery.ModuleSpec; 'ModuleSpec' has 10 characters: 'Module'(6)+'Spec'(4)=10; io.__spec__.__class__.__name__ (10: 'ModuleSpec') == pathlib.__spec__.__class__.__name__ (10: 'ModuleSpec') == re.__spec__.__class__.__name__ (10: 'ModuleSpec') == decimal.__spec__.__class__.__name__ (10: 'ModuleSpec'): a four-module cross-spec tie at 'ModuleSpec' (10 chars); the ModuleSpec object holds metadata about a module: name, origin, submodule_search_locations, etc.; 'Module' (6 chars) == len('FileIO') (6 chars) from io_extra176 — within-module tie at 6; confirmed Python 3.14.3 macOS"]
    - [io_spec_len,  io.__spec__.__class__.__name__.__len__, [],             10,   "io.__spec__.__class__.__name__.__len__() == 10 — 'ModuleSpec' has 10 characters: 'Module'(6)+'Spec'(4)=10; 10 is the consistent length for the spec class name across all standard library modules; 'Spec' (4 chars) == len('open') (4 chars) from io_extra176 — within-module tie: the second component of 'ModuleSpec' ties with the open function name; 'Module' (6 chars) == len('object') (6 chars) == len('FileIO') (6 chars) — the first component of 'ModuleSpec' ties with the Python root type and the FileIO concrete class name; ModuleSpec (10) > '_TextIOBase' (11) by... actually ModuleSpec (10) < '_TextIOBase' (11) by 1; confirmed Python 3.14.3 macOS"]
    - [io_doc_cls,   io.__doc__.__class__.__name__.__eq__,   ["str"],        true, "io.__doc__.__class__.__name__ == 'str' — io.__doc__ is a non-None docstring of type str; 'str' has 3 characters; io.__doc__.__class__.__name__ (3: 'str') == re.Pattern.__doc__.__class__.__name__ (3: 'str') from re_extra172 and == re.Match.__doc__.__class__.__name__ (3: 'str') — a cross-module and cross-type tie at 'str' (3 chars) for the docstring class name; the io module provides a docstring: io.__doc__ is a string describing the module's classes and functions; io.__doc__.__class__.__name__ (3: 'str') < io.__spec__.__class__.__name__ (10: 'ModuleSpec') by 7: the doc class name is 7 characters shorter than the spec class name; confirmed Python 3.14.3 macOS"]
    - [io_doc_ne,    io.__doc__.__class__.__name__.__eq__,   ["NoneType"],   false, "io.__doc__.__class__.__name__.__eq__('NoneType') == False — io.__doc__ is NOT NoneType; io.__doc__ is a str (3 chars), not NoneType (8 chars); 'NoneType' (8 chars) > 'str' (3 chars) by 5: the absent-doc class name is 5 characters longer than the present-doc class name; io provides a module-level docstring, unlike some C extension modules that set __doc__ = None; the False assertion encodes that the io module is self-documenting; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# io.TextIOWrapper class identity: __name__ and __module__
# __name__ == 'TextIOWrapper' (len=13: 'Text'(4)+'IO'(2)+'Wrapper'(7)=13)
# __module__ == '_io' (len=3)
# TextIOWrapper (13) > FileIO (6) by 7 — the longest concrete io class name in this spec series
# ---------------------------------------------------------------------------

table io_extra178.TextIOWrapper_name_module:
  description: "io.TextIOWrapper.__name__=='TextIOWrapper' (len=13); io.TextIOWrapper.__module__=='_io' (len=3); 'TextIOWrapper'='Text'(4)+'IO'(2)+'Wrapper'(7)=13; TextIOWrapper(13) is the longest concrete io class name in this spec series; module '_io'(3) vs 'io'(2): concrete vs ABC"
  kind: python_call_eq
  category: identity
  id_prefix: tioname178

  columns: [id, function, args, expected, description]
  rows:
    - [tiow_name_eq,   io.TextIOWrapper.__name__.__eq__,   ["TextIOWrapper"], true, "io.TextIOWrapper.__name__ == 'TextIOWrapper' — the concrete text-mode buffered stream class; 'TextIOWrapper' has 13 characters: 'Text'(4)+'IO'(2)+'Wrapper'(7)=13; TextIOWrapper (13 chars) is the longest concrete io class name in this spec series: FileIO(6) < BytesIO(7) < StringIO(8) < TextIOWrapper(13); the three-component structure 'Text'+'IO'+'Wrapper' describes the class precisely: it wraps an I/O stream (BufferedIOBase) to provide text-mode access; TextIOWrapper (13) - IncrementalNewlineDecoder (25 chars from io_extra176): TextIOWrapper (13) < IncrementalNewlineDecoder (25) by 12 within the io module; confirmed Python 3.14.3 macOS"]
    - [tiow_name_len,  io.TextIOWrapper.__name__.__len__,  [],               13,   "io.TextIOWrapper.__name__.__len__() == 13 — 'TextIOWrapper' has 13 characters: 'Text'(4)+'IO'(2)+'Wrapper'(7)=13; 13 is the length of the primary concrete text-mode stream class name; 'Wrapper' (7 chars) == len('Decimal') (7 chars) == len('Pattern') (7 chars): the third component of 'TextIOWrapper' ties with primary class names across modules; 'Text' (4 chars) == len('open') (4 chars) from io_extra176 and len('glob') (4 chars) from pathlib_extra177 — cross-module ties at 4 for the first component of TextIOWrapper; TextIOWrapper (13) == len('TextIOWrapper') (13): self-referential — the class name length equals 13; confirmed Python 3.14.3 macOS"]
    - [tiow_mod_eq,    io.TextIOWrapper.__module__.__eq__, ["_io"],           true, "io.TextIOWrapper.__module__ == '_io' — TextIOWrapper is a C extension concrete class in '_io' (3 chars); TextIOWrapper.__module__ (3: '_io') == io.FileIO.__module__ (3: '_io') from io_extra176: all concrete io classes share the '_io' (3-char) C extension module; '_io' (3 chars) < 'TextIOWrapper' (13 chars) by 10: the module name is 10 characters shorter than the class name — a 10-character gap; TextIOWrapper.__module__ (3: '_io') != 'io' (2 chars): TextIOWrapper is a concrete class in '_io', not an ABC in 'io'; the concrete/ABC module split: concrete ('_io', 3 chars) vs abstract ('io', 2 chars); confirmed Python 3.14.3 macOS"]
    - [tiow_mod_len,   io.TextIOWrapper.__module__.__len__, [],               3,    "io.TextIOWrapper.__module__.__len__() == 3 — '_io' has 3 characters; '_io' (3 chars) > 'io' (2 chars) by 1: the C extension module is one character longer than the public module; TextIOWrapper.__module__ (3: '_io') == io.FileIO.__module__ (3: '_io') == io.open.__module__ (3: '_io') == io.open_code.__module__ (3: '_io') from io_extra176: the 3-character module '_io' is uniform across all concrete io classes and functions; '_io' (3 chars) < 'ModuleSpec' (10 chars) by 7: the C extension module name is 7 characters shorter than the spec class name for this module; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# io.TextIOWrapper class identity: __bases__[0].__name__ and __name__.__len__()
# __bases__[0].__name__ == '_TextIOBase' (len=11: '_'(1)+'Text'(4)+'IO'(2)+'Base'(4)=11)
