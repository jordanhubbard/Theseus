# ---------------------------------------------------------------------------

table io_extra178.TextIOWrapper_bases_len:
  description: "io.TextIOWrapper.__bases__[0].__name__=='_TextIOBase' (len=11); io.TextIOWrapper.__name__.__len__()==13; '_TextIOBase'='_'(1)+'Text'(4)+'IO'(2)+'Base'(4)=11; _TextIOBase(11) < TextIOWrapper(13) by 2; __bases__[0] is the C-level text I/O base class"
  kind: python_call_eq
  category: identity
  id_prefix: tiowbase178

  columns: [id, function, args, expected, description]
  rows:
    - [tiow_base_eq,   "io.TextIOWrapper.__bases__[0].__name__.__eq__",  ["_TextIOBase"], true, "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' — TextIOWrapper's immediate C-level base is '_TextIOBase' (11 chars); '_TextIOBase' has 11 characters: '_'(1)+'Text'(4)+'IO'(2)+'Base'(4)=11; '_TextIOBase' (11 chars) < 'TextIOWrapper' (13 chars) by 2: the base class name is 2 characters shorter than the derived class name — an unusual reversal where the derived class name is longer than its base; '_TextIOBase' (11 chars) == len('write_bytes') (11 chars) from pathlib_extra176 — cross-module tie at 11: the C-level text I/O base class name ties with the pathlib binary write method name; '_TextIOBase' (11 chars) == len('__truediv__') (11 chars) from decimal_extra166 — cross-module tie at 11; confirmed Python 3.14.3 macOS"]
    - [tiow_base_len,  "io.TextIOWrapper.__bases__[0].__name__.__len__", [],              11,   "io.TextIOWrapper.__bases__[0].__name__.__len__() == 11 — '_TextIOBase' has 11 characters: '_'(1)+'Text'(4)+'IO'(2)+'Base'(4)=11; 11 is the name length of the C-level text I/O base class; '_TextIOBase' (11) < 'TextIOWrapper' (13) by 2: the base is 2 characters shorter than the class it underlies; '_TextIOBase' (11 chars) > '_RawIOBase' (10 chars from io_extra176) by 1: the text base is 1 character longer than the raw base; within the C-level io base hierarchy: '_RawIOBase'(10) < '_TextIOBase'(11) < '_BufferedIOBase'(15); confirmed Python 3.14.3 macOS"]
    - [tiow_name_13,   io.TextIOWrapper.__name__.__len__,               [],              13,   "io.TextIOWrapper.__name__.__len__() == 13 — 'TextIOWrapper' has 13 characters: 'Text'(4)+'IO'(2)+'Wrapper'(7)=13; 13 is the length of the primary text-mode stream class in the io module; TextIOWrapper (13) > '_TextIOBase' (11) by 2: the concrete class name is 2 characters longer than its C-level base class name; TextIOWrapper (13) > '_RawIOBase' (10) by 3 and > '_BufferedIOBase' (15) by -2 (TextIOWrapper is shorter than the buffered I/O base by 2); TextIOWrapper (13 chars) == len('IncrementalNew') (13 chars): the first 13 characters of IncrementalNewlineDecoder match the TextIOWrapper name length; confirmed Python 3.14.3 macOS"]
    - [base_ne_tiob,   "io.TextIOWrapper.__bases__[0].__name__.__eq__",  ["TextIOBase"],  false, "io.TextIOWrapper.__bases__[0].__name__.__eq__('TextIOBase') == False — TextIOWrapper's C-level base is '_TextIOBase' (11 chars), NOT 'TextIOBase' (10 chars); '_TextIOBase' (11 chars, with underscore prefix) is the C-level implementation while 'TextIOBase' (10 chars, without underscore) is the Python-level ABC visible as io.TextIOBase; the underscore prefix distinguishes C implementation classes from their Python wrappers; '_TextIOBase' (11 chars) > 'TextIOBase' (10 chars) by 1: the C version is one character longer due to the underscore prefix; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra178.io_name_is_io:
  description: "io.__name__ == 'io' — the public module name; 'io' has 2 characters; io.__name__ (2 chars) == re.__name__ (2 chars: 're'): the two shortest standard library module names in this spec series are io (2) and re (2); io (2 chars) < pathlib (7 chars) and < decimal (7 chars) in module name length; io.__name__ (2 chars) == io.RawIOBase.__module__ (2 chars): the module name attribute and the ABC module attribute are both 'io' (2 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.__name__.__eq__
  args: ["io"]
  expected: true

invariant io_extra178.io_package_is_empty:
  description: "io.__package__ == '' — io is a top-level module with an empty string package; io.__package__ (len=0: empty) == decimal.__package__ (len=0: empty): both io and decimal are top-level modules with no parent package; io.__package__ (len=0) != re.__package__ (len=2: 're') and != pathlib.__package__ (len=7: 'pathlib'); top-level io: __package__ == '' (empty), not None (which would indicate a non-package module); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.__package__.__eq__
  args: [""]
  expected: true

invariant io_extra178.io_spec_class_is_ModuleSpec:
  description: "io.__spec__.__class__.__name__ == 'ModuleSpec' — io.__spec__ is an importlib.machinery.ModuleSpec instance; 'ModuleSpec' has 10 characters: 'Module'(6)+'Spec'(4)=10; io.__spec__.__class__.__name__ (10: 'ModuleSpec') == pathlib.__spec__.__class__.__name__ (10: 'ModuleSpec') == re.__spec__.__class__.__name__ (10: 'ModuleSpec') == decimal.__spec__.__class__.__name__ (10: 'ModuleSpec'): a four-module cross-spec tie at 'ModuleSpec' (10 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.__spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant io_extra178.io_doc_class_is_str:
  description: "io.__doc__.__class__.__name__ == 'str' — io has a non-None module docstring of type str; 'str' has 3 characters; io.__doc__.__class__.__name__ (3: 'str') == re.Pattern.__doc__.__class__.__name__ (3: 'str') == re.Match.__doc__.__class__.__name__ (3: 'str') from re_extra172: the doc class name 'str' is consistent across the io module and re types; io (2 chars) < 'str' (3 chars) by 1: the module name is shorter than the docstring type name; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant io_extra178.TextIOWrapper_name_is_TextIOWrapper:
  description: "io.TextIOWrapper.__name__ == 'TextIOWrapper' — the concrete text-mode buffered stream class; 'TextIOWrapper' has 13 characters: 'Text'(4)+'IO'(2)+'Wrapper'(7)=13; TextIOWrapper (13) is the longest concrete io class name in this spec series; the three-component structure: 'Text'(4)+'IO'(2)+'Wrapper'(7)=13 precisely describes the class role: it wraps an I/O object for text access; 'Wrapper' (7 chars) == len('Decimal') (7 chars) — cross-module tie at 7 for the suffix; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.TextIOWrapper.__name__.__eq__
  args: ["TextIOWrapper"]
  expected: true

invariant io_extra178.TextIOWrapper_module_is__io:
  description: "io.TextIOWrapper.__module__ == '_io' — TextIOWrapper is a C extension concrete class in '_io' (3 chars); '_io' (3 chars) > 'io' (2 chars) by 1: the C extension module is one character longer than the public module; TextIOWrapper.__module__ (3: '_io') == io.FileIO.__module__ (3: '_io') == io.open.__module__ (3: '_io'): the 3-char C extension module is uniform across all concrete io classes and functions; TextIOWrapper (13 chars) vs '_io' (3 chars): 10-character gap between class name and module name; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.TextIOWrapper.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra178.TextIOWrapper_base_is__TextIOBase:
  description: "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' — TextIOWrapper's C-level base is '_TextIOBase' (11 chars); '_TextIOBase' = '_'(1)+'Text'(4)+'IO'(2)+'Base'(4) = 11; '_TextIOBase' (11 chars) < 'TextIOWrapper' (13 chars) by 2: the base is shorter than the derived class; '_TextIOBase' is the C-level implementation base that sits beneath the Python-level io.TextIOBase (10 chars, without underscore); '_TextIOBase' (11 chars) == len('write_bytes') (11 chars) from pathlib_extra176 and len('__truediv__') (11 chars) from decimal_extra166 — cross-module ties at 11; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "io.TextIOWrapper.__bases__[0].__name__.__eq__"
  args: ["_TextIOBase"]
  expected: true

invariant io_extra178.TextIOWrapper_name_len_is_13:
  description: "io.TextIOWrapper.__name__.__len__() == 13 — 'TextIOWrapper' has 13 characters: 'Text'(4)+'IO'(2)+'Wrapper'(7)=13; 13 is the length of the primary text-mode concrete stream class name in the io module; TextIOWrapper (13) > '_TextIOBase' (11) by 2: the derived class name exceeds its base class name by 2; TextIOWrapper (13) < IncrementalNewlineDecoder (25 from io_extra176) by 12: the most extreme name length gap within the io module; 'Wrapper' (7 chars) == len('Pattern') (7 chars) == len('Decimal') (7 chars): the suffix of TextIOWrapper ties with primary class names across re and decimal modules; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.TextIOWrapper.__name__.__len__
  args: []
  expected: 13

