spec: contextlib_extra7
version: ">=3.9"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html — Python contextlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
  notes:
    - "This spec extends contextlib.zspec.zsdl, contextlib_extra.zspec.zsdl, contextlib_extra2.zspec.zsdl, contextlib_extra3.zspec.zsdl, contextlib_extra4.zspec.zsdl, contextlib_extra5.zspec.zsdl, contextlib_extra6.zspec.zsdl, and contextlib_suppress.zspec.zsdl."
    - "contextlib_extra3 covers __qualname__ for: AsyncExitStack, asynccontextmanager, aclosing, AbstractAsyncContextManager, nullcontext, ExitStack, suppress, closing, contextmanager, AbstractContextManager, redirect_stdout, redirect_stderr, AsyncContextDecorator."
    - "contextlib_extra6 covers __qualname__ in a table for contextmanager/asynccontextmanager/closing/suppress/ExitStack; AsyncExitStack and redirect_stdout/redirect_stderr as individual invariants; AbstractContextManager name/module; AbstractAsyncContextManager name."
    - "This spec focuses on contextlib.ContextDecorator — never covered in any prior contextlib spec — plus __bases__ hierarchy checks and the chained_generators/chained context pattern."
    - "contextlib.ContextDecorator.__name__ == 'ContextDecorator' — mixin class for context managers used as decorators."
    - "contextlib.ContextDecorator.__qualname__ == 'ContextDecorator' — top-level class definition."
    - "contextlib.ContextDecorator.__module__ == 'contextlib' — defined in Lib/contextlib.py."
    - "contextlib.AbstractContextManager.__bases__[0].__name__ in ('ABC', 'object') — ABCMeta-based hierarchy."
    - "contextlib.suppress.__bases__[0].__name__ == 'AbstractContextManager' — suppress inherits from it."
    - "contextlib.closing.__bases__[0].__name__ == 'AbstractContextManager' — closing inherits from it."
    - "contextlib.ExitStack.__bases__[0].__name__ == 'AbstractContextManager' — ExitStack inherits from it."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# contextlib.ContextDecorator — name, qualname, and module
#
# ContextDecorator is a mixin class that allows context managers to also be
# used as decorators. It has not been covered in any prior contextlib spec.
# AsyncContextDecorator was covered in contextlib_extra3 (Python 3.10+);
# this spec adds the base ContextDecorator (available since Python 3.2).
# ---------------------------------------------------------------------------

invariant contextlib_extra7.ContextDecorator.name:
  description: "contextlib.ContextDecorator.__name__ == 'ContextDecorator'"
  category: ContextDecorator
  kind: python_call_eq
  function: ContextDecorator.__name__.__eq__
  args: ["ContextDecorator"]
  expected: true

invariant contextlib_extra7.ContextDecorator.qualname:
  description: "contextlib.ContextDecorator.__qualname__ == 'ContextDecorator'"
  category: ContextDecorator
  kind: python_call_eq
  function: ContextDecorator.__qualname__.__eq__
  args: ["ContextDecorator"]
  expected: true

invariant contextlib_extra7.ContextDecorator.module:
  description: "contextlib.ContextDecorator.__module__ == 'contextlib'"
  category: ContextDecorator
  kind: python_call_eq
  function: ContextDecorator.__module__.__eq__
  args: ["contextlib"]
  expected: true

# ---------------------------------------------------------------------------
# Inheritance hierarchy — __bases__ checks
#
# These verify the class hierarchy via __bases__[0].__name__ for key classes.
# None of these specific __bases__ checks appear in any prior contextlib spec.
# ---------------------------------------------------------------------------

invariant contextlib_extra7.suppress.base_name:
  description: "contextlib.suppress.__bases__[0].__name__ == 'AbstractContextManager'"
  category: class_hierarchy
  kind: python_call_eq
  function: suppress.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "AbstractContextManager"

invariant contextlib_extra7.closing.base_name:
  description: "contextlib.closing.__bases__[0].__name__ == 'AbstractContextManager'"
  category: class_hierarchy
  kind: python_call_eq
  function: closing.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "AbstractContextManager"

invariant contextlib_extra7.ExitStack.base_name:
  description: "contextlib.ExitStack.__bases__[0].__name__ == 'AbstractContextManager'"
  category: class_hierarchy
  kind: python_call_eq
  function: ExitStack.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "AbstractContextManager"

# ---------------------------------------------------------------------------
# AbstractContextManager — base class count
#
# AbstractContextManager is an ABC. Verify it has exactly one base class
# (the ABC infrastructure base). This is a new structural check.
# ---------------------------------------------------------------------------

invariant contextlib_extra7.AbstractContextManager.bases_len:
  description: "contextlib.AbstractContextManager.__bases__ has exactly 1 element"
  category: class_hierarchy
  kind: python_call_eq
  function: AbstractContextManager.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# AbstractAsyncContextManager — module check
#
# contextlib_extra6 covered __name__ for AbstractAsyncContextManager but did
# not cover __module__. contextlib_extra4 covered the __module__ for the
# non-async variant. This adds the async variant's __module__ check.
# ---------------------------------------------------------------------------

invariant contextlib_extra7.AbstractAsyncContextManager.module:
  description: "contextlib.AbstractAsyncContextManager.__module__ == 'contextlib'"
  category: module
  kind: python_call_eq
  function: AbstractAsyncContextManager.__module__.__eq__
  args: ["contextlib"]
  expected: true

# ---------------------------------------------------------------------------
# contextlib.ExitStack — class identity checks beyond name/qualname/module
#
# Verify ExitStack is a subclass of AbstractContextManager via issubclass.
# Since issubclass is not in the backend, we verify the bases chain instead.
# This adds the __qualname__ of ExitStack's base — a new vector.
# ---------------------------------------------------------------------------

invariant contextlib_extra7.ExitStack.base_qualname:
  description: "contextlib.ExitStack.__bases__[0].__qualname__ == 'AbstractContextManager'"
  category: class_hierarchy
  kind: python_call_eq
  function: ExitStack.__bases__.__getitem__
  args: [0]
  method: __qualname__
  expected: "AbstractContextManager"
