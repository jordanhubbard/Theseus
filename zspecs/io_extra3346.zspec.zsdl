spec: io3346
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io: Core tools for working with streams"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 670 (io3346): __neg__, __pos__, __abs__ dict-presence checks for io types."
    - "Classes covered: io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.FileIO, io.BytesIO, io.StringIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.BufferedRWPair, io.TextIOWrapper."
    - "Theme: __neg__, __pos__, __abs__ dict-presence (unary operators: -x, +x, abs(x))."
    - "No io class defines __neg__ in its own __dict__: stream I/O classes are sequential I/O abstractions, not numeric types, and do not implement unary negation."
    - "No io class defines __pos__ in its own __dict__: stream I/O classes do not implement unary plus; the +x operator has no meaning for I/O streams."
    - "No io class defines __abs__ in its own __dict__: stream I/O classes do not implement abs(); magnitude is not a concept defined for I/O stream objects."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Consistent with prior waves: all unary arithmetic operators absent from io class __dict__s."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __neg__ dict-presence — operator.contains(Cls.__dict__, '__neg__')
#
# No io class defines __neg__ in its own __dict__; all false.
# io stream classes are sequential I/O abstractions, not numeric types,
# and do not implement the unary negation operator (-x).
# ---------------------------------------------------------------------------

table io3346.neg:
  description: "io types __neg__ dict-presence checks; wave 670"
