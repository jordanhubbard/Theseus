spec: struct_extra265
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra264.zspec.zsdl — covers struct.calcsize for multi-format network-order strings and module function class identity."
    - "struct_extra263.zspec.zsdl — covers struct.error class identity and pack/unpack error cases."
  notes:
    - "struct.calcsize('<I') == 4 — little-endian unsigned int is 4 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('>I') == 4 — big-endian unsigned int is 4 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('!I') == 4 — network byte order unsigned int is 4 bytes (network == big-endian). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('=I') == 4 — native standard size unsigned int is 4 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('<H') == 2 — little-endian unsigned short is 2 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('>H') == 2 — big-endian unsigned short is 2 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('<Q') == 8 — little-endian unsigned long long is 8 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('>Q') == 8 — big-endian unsigned long long is 8 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('<f') == 4 — little-endian float is 4 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('>f') == 4 — big-endian float is 4 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('<d') == 8 — little-endian double is 8 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('>d') == 8 — big-endian double is 8 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "The '<', '>', '!', '=' prefixes all use standard sizes; @/native may differ on platform. Standard sizes: B=1, H=2, I=4, Q=8, f=4, d=8."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.calcsize — little-endian byte order prefix '<'
# All standard-size types have the same size regardless of byte order prefix.
# '<' = little-endian, forces standard size; same as '>' for calcsize.
# ---------------------------------------------------------------------------

table struct_extra265.calcsize_little_endian_sizes:
  description: "struct.calcsize little-endian '<' prefix sizes — I=4, H=2, Q=8, f=4, d=8; standard-size types have identical sizes for all byte-order prefixes; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: structle265

  columns: [id, function, args, expected, description]
  rows:
    - [le_uint,   calcsize, ["<I"], 4, "struct.calcsize('<I') == 4 — little-endian unsigned int is 4 bytes (standard size)"]
    - [le_ushort, calcsize, ["<H"], 2, "struct.calcsize('<H') == 2 — little-endian unsigned short is 2 bytes (standard size)"]
    - [le_ullong, calcsize, ["<Q"], 8, "struct.calcsize('<Q') == 8 — little-endian unsigned long long is 8 bytes (standard size)"]
    - [le_float,  calcsize, ["<f"], 4, "struct.calcsize('<f') == 4 — little-endian IEEE 754 float is 4 bytes"]
    - [le_double, calcsize, ["<d"], 8, "struct.calcsize('<d') == 8 — little-endian IEEE 754 double is 8 bytes"]

# ---------------------------------------------------------------------------
# struct.calcsize — big-endian / network byte order prefixes '>' and '!'
# '>' = big-endian; '!' = network (big-endian); '=' = native standard size.
# All produce the same sizes as '<' for standard-size types.
# ---------------------------------------------------------------------------

table struct_extra265.calcsize_big_endian_sizes:
  description: "struct.calcsize big-endian '>' and network '!' prefix sizes — I=4, H=2, Q=8, f=4, d=8; same as little-endian for standard-size types; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: structbe265

  columns: [id, function, args, expected, description]
  rows:
    - [be_uint,     calcsize, [">I"], 4, "struct.calcsize('>I') == 4 — big-endian unsigned int is 4 bytes (standard size)"]
    - [net_uint,    calcsize, ["!I"], 4, "struct.calcsize('!I') == 4 — network byte order unsigned int is 4 bytes (network == big-endian)"]
    - [nat_uint,    calcsize, ["=I"], 4, "struct.calcsize('=I') == 4 — native standard size unsigned int is 4 bytes"]
    - [be_ushort,   calcsize, [">H"], 2, "struct.calcsize('>H') == 2 — big-endian unsigned short is 2 bytes (standard size)"]
    - [be_ullong,   calcsize, [">Q"], 8, "struct.calcsize('>Q') == 8 — big-endian unsigned long long is 8 bytes (standard size)"]

# ---------------------------------------------------------------------------
# Standalone invariants — struct.calcsize byte order prefix semantics
# ---------------------------------------------------------------------------

invariant struct_extra265.calcsize_le_I_eq:
  description: "struct.calcsize('<I') == 4 — little-endian unsigned int; standard size 4 bytes; same result on all platforms; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: calcsize
  args: ["<I"]
  expected: 4

invariant struct_extra265.calcsize_be_I_eq:
  description: "struct.calcsize('>I') == 4 — big-endian unsigned int; standard size 4 bytes; same result on all platforms; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: calcsize
  args: [">I"]
  expected: 4

invariant struct_extra265.calcsize_net_I_eq:
  description: "struct.calcsize('!I') == 4 — network byte order (big-endian) unsigned int; standard size 4 bytes; '!' is an alias for '>' per RFC 1700; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: calcsize
  args: ["!I"]
  expected: 4

invariant struct_extra265.calcsize_nat_I_eq:
  description: "struct.calcsize('=I') == 4 — native standard size unsigned int; uses native byte order but standard type sizes; always 4 bytes; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: calcsize
  args: ["=I"]
  expected: 4

invariant struct_extra265.calcsize_le_H_eq:
  description: "struct.calcsize('<H') == 2 — little-endian unsigned short; standard size 2 bytes; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: calcsize
  args: ["<H"]
  expected: 2

invariant struct_extra265.calcsize_net_H_eq:
  description: "struct.calcsize('!H') == 2 — network byte order unsigned short; standard size 2 bytes; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: calcsize
  args: ["!H"]
  expected: 2

invariant struct_extra265.calcsize_le_Q_eq:
  description: "struct.calcsize('<Q') == 8 — little-endian unsigned long long; standard size 8 bytes; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: calcsize
  args: ["<Q"]
  expected: 8

invariant struct_extra265.calcsize_be_Q_eq:
  description: "struct.calcsize('>Q') == 8 — big-endian unsigned long long; standard size 8 bytes; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: calcsize
  args: [">Q"]
  expected: 8

invariant struct_extra265.calcsize_le_f_eq:
  description: "struct.calcsize('<f') == 4 — little-endian IEEE 754 single-precision float; always 4 bytes; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: calcsize
  args: ["<f"]
  expected: 4

invariant struct_extra265.calcsize_be_f_eq:
  description: "struct.calcsize('>f') == 4 — big-endian IEEE 754 single-precision float; always 4 bytes; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: calcsize
  args: [">f"]
  expected: 4

invariant struct_extra265.calcsize_le_d_eq:
  description: "struct.calcsize('<d') == 8 — little-endian IEEE 754 double-precision float; always 8 bytes; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: calcsize
  args: ["<d"]
  expected: 8

invariant struct_extra265.calcsize_be_d_eq:
  description: "struct.calcsize('>d') == 8 — big-endian IEEE 754 double-precision float; always 8 bytes; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: calcsize
  args: [">d"]
  expected: 8
