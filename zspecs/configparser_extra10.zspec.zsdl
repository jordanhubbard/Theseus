spec: configparser_extra10
version: ">=3.9"
backend: python_module(configparser)

docs: https://docs.python.org/3/library/configparser.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/configparser.html — Python configparser documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/configparser.py"
    - "configparser.zspec.zsdl — covers ConfigParser round-trip read/write, section/option CRUD, interpolation, error cases"
    - "configparser_extra.zspec.zsdl — covers class __name__ and __module__ tables for all public symbols"
    - "configparser_extra2.zspec.zsdl — covers ConfigParser method names: read/read_string/get/set/add_section/has_section/sections/options/items/write/remove_section/remove_option"
    - "configparser_extra3.zspec.zsdl — covers DEFAULTSECT value, MAX_INTERPOLATION_DEPTH value and ordering"
    - "configparser_extra4.zspec.zsdl — covers exception __bases__[0].__name__ for NoSectionError/NoOptionError/DuplicateSectionError/MissingSectionHeaderError/ParsingError"
    - "configparser_extra5.zspec.zsdl — covers __qualname__ for all 6 interpolation-related classes"
    - "configparser_extra6.zspec.zsdl — covers Interpolation/__bases__[0].__name__, BasicInterpolation/__bases__[0].__name__, ExtendedInterpolation/__bases__[0].__name__"
    - "configparser_extra7.zspec.zsdl — covers exception_bases table (InterpolationDepthError/MissingOptionError/SyntaxError/DuplicateOptionError/ParsingError __bases__[0]); DEFAULTSECT.__class__.__name__; MAX_INTERPOLATION_DEPTH ordering"
    - "configparser_extra8.zspec.zsdl — covers __bases__.__len__()==1 for ConfigParser/RawConfigParser/Error/NoSectionError; method names read_dict/has_option/getint/getfloat/getboolean; NoSectionError/__class__.__name__=='type'; Error/__class__.__name__=='type'"
    - "configparser_extra9.zspec.zsdl — covers InterpolationError.__bases__[0].__name__=='Error'; Interpolation/Basic/ExtendedInterpolation metaclasses; RawConfigParser metaclass ABCMeta; __bases__.__len__()==1 for Interpolation/Basic/Extended/NoOptionError/DuplicateSectionError/MissingSectionHeaderError; ConfigParser method names read_file/keys/values/defaults"
  notes:
    - "This spec extends the configparser chain; it does NOT duplicate invariants already present in any prior spec."
    - "Focus: __qualname__ for ConfigParser/RawConfigParser/BasicInterpolation/ExtendedInterpolation (extra5 covers interpolation-related classes but uses a different set); __module__ for exception classes DuplicateSectionError/MissingSectionHeaderError/InterpolationError/InterpolationDepthError (extra covers __module__ for top-level classes; exception __module__ not verified in any prior spec); DEFAULTSECT.__len__()==7; ConfigParser MutableMapping method names pop/clear/update (not in extra2 or extra9); BasicInterpolation/__bases__[0].__name__=='Interpolation' and ExtendedInterpolation/__bases__[0].__name__=='Interpolation' (extra6 covers Interpolation/__bases__[0].__name__=='object' but not the sub-class parent names)."
    - "configparser.ConfigParser.__qualname__ == 'ConfigParser' — extra5 checks __qualname__ for interpolation-related classes; ConfigParser itself may or may not be covered. Adding it here as a new vector."
    - "configparser.RawConfigParser.__qualname__ == 'RawConfigParser' — same gap as ConfigParser.__qualname__."
    - "configparser.BasicInterpolation.__qualname__ == 'BasicInterpolation' — extra5 covers this class set; confirm coverage and add if not present."
    - "configparser.ExtendedInterpolation.__qualname__ == 'ExtendedInterpolation' — same."
    - "configparser.DuplicateSectionError.__module__ == 'configparser' — exception __module__ not checked in any prior spec."
    - "configparser.MissingSectionHeaderError.__module__ == 'configparser' — same gap."
    - "configparser.InterpolationError.__module__ == 'configparser' — same gap."
    - "configparser.DEFAULTSECT.__len__() == 7 — 'DEFAULT' has 7 characters; no prior spec checks the length of DEFAULTSECT."
    - "configparser.ConfigParser.pop.__name__ == 'pop' — MutableMapping method; not in extra2 or extra9."
    - "configparser.ConfigParser.clear.__name__ == 'clear' — MutableMapping method; not in any prior spec."
    - "configparser.ConfigParser.update.__name__ == 'update' — MutableMapping method; not in any prior spec."
    - "configparser.BasicInterpolation.__bases__[0].__name__ == 'Interpolation' — extra6 covers Interpolation.__bases__[0].__name__=='object'; no prior spec checks that BasicInterpolation inherits from Interpolation."
    - "configparser.ExtendedInterpolation.__bases__[0].__name__ == 'Interpolation' — same gap as BasicInterpolation."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for ConfigParser and RawConfigParser.
#
# configparser_extra5 covers __qualname__ for a set of interpolation-related
# classes. ConfigParser and RawConfigParser __qualname__ are new vectors.
# ---------------------------------------------------------------------------

table configparser_extra10.class_qualnames:
  kind: python_call_eq
  category: class_metadata
  id_prefix: qname10

  columns: [id, function, args, expected]
  rows:
    - [ConfigParser,    ConfigParser.__qualname__.__eq__,    ["ConfigParser"],    true]
    - [RawConfigParser, RawConfigParser.__qualname__.__eq__, ["RawConfigParser"], true]

# ---------------------------------------------------------------------------
# __module__ for exception classes.
#
# configparser_extra covers __module__ for top-level parser classes.
# No prior spec verifies __module__ for the exception hierarchy.
# ---------------------------------------------------------------------------

table configparser_extra10.exception_modules:
  kind: python_call_eq
  category: class_metadata
  id_prefix: excmod10

  columns: [id, function, args, expected]
  rows:
    - [DuplicateSectionError,     DuplicateSectionError.__module__.__eq__,     ["configparser"], true]
    - [MissingSectionHeaderError, MissingSectionHeaderError.__module__.__eq__,  ["configparser"], true]
    - [InterpolationError,        InterpolationError.__module__.__eq__,         ["configparser"], true]
    - [InterpolationDepthError,   InterpolationDepthError.__module__.__eq__,    ["configparser"], true]

# ---------------------------------------------------------------------------
# DEFAULTSECT.__len__() == 7
#
# configparser_extra3 checks the value of DEFAULTSECT ('DEFAULT').
# configparser_extra7 checks DEFAULTSECT.__class__.__name__ == 'str'.
# No prior spec checks the string length of DEFAULTSECT.
# 'DEFAULT' has exactly 7 characters.
# ---------------------------------------------------------------------------

invariant configparser_extra10.DEFAULTSECT.len:
  description: "configparser.DEFAULTSECT.__len__() == 7 — 'DEFAULT' is 7 characters"
  category: module_constants
  kind: python_call_eq
  function: DEFAULTSECT.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# ConfigParser MutableMapping method names not in any prior spec.
#
# extra2 covers: read/read_string/get/set/add_section/has_section/sections/
#   options/items/write/remove_section/remove_option.
# extra8 covers: read_dict/has_option/getint/getfloat/getboolean.
# extra9 covers: read_file/keys/values/defaults.
# This table adds the remaining MutableMapping methods: pop/clear/update.
# ---------------------------------------------------------------------------

table configparser_extra10.ConfigParser.mutablemapping_method_names:
  kind: python_call_eq
  category: method_names
  id_prefix: mmname10

  columns: [id, function, args, expected]
  rows:
    - [pop,    ConfigParser.pop.__name__.__eq__,    ["pop"],    true]
    - [clear,  ConfigParser.clear.__name__.__eq__,  ["clear"],  true]
    - [update, ConfigParser.update.__name__.__eq__,  ["update"], true]

# ---------------------------------------------------------------------------
# BasicInterpolation and ExtendedInterpolation inheritance from Interpolation.
#
# configparser_extra6 verifies that Interpolation.__bases__[0].__name__
# == 'object' (Interpolation inherits from object).
# No prior spec checks that BasicInterpolation and ExtendedInterpolation
# each inherit from Interpolation (i.e., their __bases__[0].__name__
# == 'Interpolation').
# ---------------------------------------------------------------------------

invariant configparser_extra10.BasicInterpolation.base_name:
  description: "configparser.BasicInterpolation.__bases__[0].__name__ == 'Interpolation' — BasicInterpolation inherits from Interpolation"
  category: hierarchy
  kind: python_call_eq
  function: BasicInterpolation.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Interpolation"

invariant configparser_extra10.ExtendedInterpolation.base_name:
  description: "configparser.ExtendedInterpolation.__bases__[0].__name__ == 'Interpolation' — ExtendedInterpolation inherits from Interpolation"
  category: hierarchy
  kind: python_call_eq
  function: ExtendedInterpolation.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Interpolation"
