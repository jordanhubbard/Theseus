spec: decimal_extra238
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal_extra237.zspec.zsdl — covers Decimal.__str__ and __repr__ method identity"
  notes:
    - "This spec covers: decimal rounding mode string constants — ROUND_HALF_UP, ROUND_HALF_DOWN, ROUND_CEILING, ROUND_FLOOR."
    - "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP' — plain str value; length 13; verified Python 3.14.3 macOS."
    - "decimal.ROUND_HALF_DOWN == 'ROUND_HALF_DOWN' — plain str value; length 15; verified Python 3.14.3 macOS."
    - "decimal.ROUND_CEILING == 'ROUND_CEILING' — plain str value; length 13; verified Python 3.14.3 macOS."
    - "decimal.ROUND_FLOOR == 'ROUND_FLOOR' — plain str value; length 11; verified Python 3.14.3 macOS."
    - "ROUND_HALF_UP.__class__.__name__ == 'str' — rounding constants are plain Python strings; verified Python 3.14.3 macOS."
    - "ROUND_HALF_DOWN.__class__.__name__ == 'str' — verified Python 3.14.3 macOS."
    - "ROUND_CEILING.__class__.__name__ == 'str' — verified Python 3.14.3 macOS."
    - "ROUND_FLOOR.__class__.__name__ == 'str' — verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal rounding constant string values
# ROUND_HALF_UP='ROUND_HALF_UP', ROUND_HALF_DOWN='ROUND_HALF_DOWN',
# ROUND_CEILING='ROUND_CEILING', ROUND_FLOOR='ROUND_FLOOR'.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table decimal_extra238.rounding_constant_values:
  description: "decimal rounding constants string values: ROUND_HALF_UP, ROUND_HALF_DOWN, ROUND_CEILING, ROUND_FLOOR; verified Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: decround238

  columns: [id, function, args, expected]
  rows:
    - [half_up_eq,    ROUND_HALF_UP.__eq__,   ["ROUND_HALF_UP"],   true]
    - [half_down_eq,  ROUND_HALF_DOWN.__eq__,  ["ROUND_HALF_DOWN"], true]
    - [ceiling_eq,    ROUND_CEILING.__eq__,   ["ROUND_CEILING"],   true]
    - [floor_eq,      ROUND_FLOOR.__eq__,     ["ROUND_FLOOR"],     true]
    - [half_up_not,   ROUND_HALF_UP.__eq__,   ["ROUND_HALF_DOWN"], false]

# ---------------------------------------------------------------------------
# decimal rounding constant __class__.__name__ == 'str'
# All rounding mode constants are plain Python str instances.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table decimal_extra238.rounding_constant_class_names:
  description: "decimal rounding constants __class__.__name__ == 'str' for all four constants; verified Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: decround238

  columns: [id, function, args, expected]
  rows:
    - [half_up_class_eq,    ROUND_HALF_UP.__class__.__name__.__eq__,   ["str"], true]
    - [half_down_class_eq,  ROUND_HALF_DOWN.__class__.__name__.__eq__,  ["str"], true]
    - [ceiling_class_eq,    ROUND_CEILING.__class__.__name__.__eq__,   ["str"], true]
    - [floor_class_eq,      ROUND_FLOOR.__class__.__name__.__eq__,     ["str"], true]
    - [class_not_bytes,     ROUND_HALF_UP.__class__.__name__.__eq__,   ["bytes"], false]

# ---------------------------------------------------------------------------
# decimal rounding constant string lengths
# ROUND_HALF_UP len=13, ROUND_HALF_DOWN len=15, ROUND_CEILING len=13, ROUND_FLOOR len=11.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table decimal_extra238.rounding_constant_lengths:
  description: "decimal rounding constants string lengths: ROUND_HALF_UP=13, ROUND_HALF_DOWN=15, ROUND_CEILING=13, ROUND_FLOOR=11; verified Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: decround238

  columns: [id, function, args, expected]
  rows:
    - [half_up_len,   ROUND_HALF_UP.__len__,   [], 13]
    - [half_down_len, ROUND_HALF_DOWN.__len__,  [], 15]
    - [ceiling_len,   ROUND_CEILING.__len__,   [], 13]
    - [floor_len,     ROUND_FLOOR.__len__,     [], 11]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra238.ROUND_HALF_UP.value_eq:
  description: "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP' — the rounding constant string value; verified Python 3.14.3 macOS"
  category: constants
  kind: python_call_eq
  function: ROUND_HALF_UP.__eq__
  args: ["ROUND_HALF_UP"]
  expected: true

invariant decimal_extra238.ROUND_HALF_UP.class_name_eq:
  description: "decimal.ROUND_HALF_UP.__class__.__name__ == 'str' — rounding constants are plain Python str instances; verified Python 3.14.3 macOS"
  category: constants
  kind: python_call_eq
  function: ROUND_HALF_UP.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant decimal_extra238.ROUND_HALF_UP.len:
  description: "len(decimal.ROUND_HALF_UP) == 13 — 'ROUND_HALF_UP' has 13 characters; verified Python 3.14.3 macOS"
  category: constants
  kind: python_call_eq
  function: ROUND_HALF_UP.__len__
  args: []
  expected: 13

