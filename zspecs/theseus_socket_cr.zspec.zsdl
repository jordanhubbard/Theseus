spec: theseus_socket_cr
version: ">=3.0"
backend: python_cleanroom(theseus_socket_cr)
blocks: socket

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/socket.html"
  not_derived_from:
    - "CPython source: Lib/socket.py"
  notes:
    - "Clean-room socket module. Do NOT import socket."

error_model: python_exceptions

invariant theseus_socket_cr.socket2_constants:
  description: "Socket constants have correct values"
  category: behavior
  kind: python_call_eq
  function: socket2_constants
  args: []
  expected: true

invariant theseus_socket_cr.socket2_gethostname:
  description: "gethostname() returns a non-empty string"
  category: behavior
  kind: python_call_eq
  function: socket2_gethostname
  args: []
  expected: true

invariant theseus_socket_cr.socket2_addr:
  description: "inet_aton/inet_ntoa round-trip works"
  category: behavior
  kind: python_call_eq
  function: socket2_addr
  args: []
  expected: true
