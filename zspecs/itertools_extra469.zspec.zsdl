spec: itertools_extra469
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "All itertools iterators are C-level types inheriting from object"
    - "pairwise was added in Python 3.10; version guard applied at spec level"
    - "combinations_with_replacement name is long but stable"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table itertools_extra469.class_names:
  description: "Name attribute identity for itertools iterator classes"
  kind: python_call_eq
  category: identity
  id_prefix: IE469N

  columns: [id, function, args, expected]
  rows:
