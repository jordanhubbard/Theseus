    - [IE469N002, itertools.filterfalse.__name__.__eq__, ["filterfalse"], true]
    - [IE469N003, itertools.zip_longest.__name__.__eq__, ["zip_longest"], true]
    - [IE469N004, itertools.accumulate.__name__.__eq__, ["accumulate"], true]
    - [IE469N005, itertools.combinations_with_replacement.__name__.__eq__, ["combinations_with_replacement"], true]
    - [IE469N006, itertools.dropwhile.__name__.__eq__, ["dropwhile"], true]
    - [IE469N007, itertools.takewhile.__name__.__eq__, ["takewhile"], true]
    - [IE469N008, itertools.islice.__name__.__eq__, ["islice"], true]
    - [IE469N009, itertools.chain.__name__.__eq__, ["chain"], true]
    - [IE469N010, itertools.product.__name__.__eq__, ["product"], true]

