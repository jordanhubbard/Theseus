spec: random_extra17
version: ">=3.9"
backend: python_module(random)

docs: https://docs.python.org/3/library/random.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/random.html — Python random module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/random.py"
  notes:
    - "This spec extends random.zspec.zsdl and prior extras through random_extra16.zspec.zsdl."
    - "random_extra16 covers __qualname__ via class attribute path for Random.seed/random/randint/choice/shuffle/uniform."
    - "No prior spec covers __qualname__ via class attribute path for Random.sample/gauss/normalvariate."
    - "random.Random.sample.__qualname__ == 'Random.sample' — method qualname includes class prefix."
    - "random.Random.gauss.__qualname__ == 'Random.gauss' — method qualname includes class prefix."
    - "random.Random.normalvariate.__qualname__ == 'Random.normalvariate' — method qualname includes class prefix."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# random.Random method __qualname__ via class attribute path — extra17 set
#
# random_extra16 covers Random.seed/random/randint/choice/shuffle/uniform via
# class attribute path. No prior spec checks __qualname__ via the class
# attribute path for Random.sample, Random.gauss, or Random.normalvariate.
# These three are pure-Python methods; their qualname carries the 'Random.'
# prefix just as the methods covered in random_extra16 do.
# ---------------------------------------------------------------------------

table random_extra17.class_method_qualnames:
  description: "__qualname__ for random.Random.sample/gauss/normalvariate via class attribute path"
  kind: python_call_eq
  category: function_identity
  id_prefix: rmqn17

  columns: [id, function, args, expected]
  rows:
    - [sample,       "Random.sample.__qualname__.__eq__",       ["Random.sample"],       true]
    - [gauss,        "Random.gauss.__qualname__.__eq__",        ["Random.gauss"],        true]
    - [normalvariate, "Random.normalvariate.__qualname__.__eq__", ["Random.normalvariate"], true]
