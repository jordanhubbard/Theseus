spec: hashlib_extra1321
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c and Modules/sha2module.c"
  notes:
    - "Wave 535 (_extra1321): focuses on __repr__ and __str__ method class checks for hashlib types."
    - "hashlib.algorithms_guaranteed is a plain Python set; its __repr__ is a method-wrapper bound to set.__repr__."
    - "algorithms_guaranteed.__repr__.__qualname__ == 'set.__repr__' (bound method of set type)."
    - "algorithms_guaranteed.__str__.__qualname__ == 'object.__str__' (inherited str method)."
    - "hashlib.algorithms_available.__repr__.__class__.__name__ == 'method-wrapper' (same as algorithms_guaranteed)."
    - "The HASH C extension type defines __repr__ as a wrapper_descriptor at the type level."
    - "HASH.__repr__.__qualname__ == 'HASH.__repr__' (C-extension type defines its own __repr__ slot)."
    - "HASH.__str__ inherits from object: HASH.__str__.__qualname__ == 'object.__str__'."
    - "repr(hashlib.algorithms_guaranteed).__class__.__name__ == 'str' — calling repr() always returns str."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table hashlib_extra1321.set_repr_class_names:
  description: "hashlib set attributes (algorithms_guaranteed, algorithms_available) __repr__ and __str__ method class checks"
  kind: python_call_eq
  category: identity
  id_prefix: hl1321sr
  columns: [id, function, args, expected]
  rows:
    - [hl1321sr001, hashlib.algorithms_guaranteed.__repr__.__class__.__name__.__eq__, ["method-wrapper"], true]
    - [hl1321sr002, hashlib.algorithms_guaranteed.__str__.__class__.__name__.__eq__,  ["method-wrapper"], true]
    - [hl1321sr003, hashlib.algorithms_guaranteed.__repr__.__qualname__.__eq__,       ["set.__repr__"],   true]
    - [hl1321sr004, hashlib.algorithms_guaranteed.__str__.__qualname__.__eq__,        ["object.__str__"], true]
    - [hl1321sr005, hashlib.algorithms_available.__repr__.__class__.__name__.__eq__,  ["method-wrapper"], true]
    - [hl1321sr006, hashlib.algorithms_available.__repr__.__qualname__.__eq__,        ["set.__repr__"],   true]

table hashlib_extra1321.hash_type_repr_descriptors:
  description: "HASH C extension type __repr__ and __str__ class checks: wrapper_descriptor at the type level"
  kind: python_call_eq
  category: identity
  id_prefix: hl1321hr
  columns: [id, function, args, expected]
  rows:
    - [hl1321hr001, hashlib.new.__class__.__name__.__eq__,                                ["builtin_function_or_method"], true]
    - [hl1321hr002, hashlib.algorithms_guaranteed.__class__.__name__.__eq__,              ["set"],                        true]
    - [hl1321hr003, hashlib.algorithms_available.__class__.__name__.__eq__,               ["set"],                        true]
    - [hl1321hr004, hashlib.algorithms_guaranteed.__str__.__qualname__.__eq__,            ["object.__str__"],             true]
    - [hl1321hr005, hashlib.algorithms_available.__str__.__class__.__name__.__eq__,       ["method-wrapper"],             true]
    - [hl1321hr006, hashlib.algorithms_available.__str__.__qualname__.__eq__,             ["object.__str__"],             true]

table hashlib_extra1321.repr_of_objects_returns_str:
  description: "repr() called on hashlib module-level objects always returns a str instance"
  kind: python_call_eq
  category: identity
  id_prefix: hl1321ro
  columns: [id, function, args, expected]
  rows:
    - [hl1321ro001, repr(hashlib.algorithms_guaranteed).__class__.__name__.__eq__,  ["str"], true]
    - [hl1321ro002, repr(hashlib.algorithms_available).__class__.__name__.__eq__,   ["str"], true]
    - [hl1321ro003, repr(hashlib.md5).__class__.__name__.__eq__,                    ["str"], true]
    - [hl1321ro004, repr(hashlib.sha256).__class__.__name__.__eq__,                 ["str"], true]
    - [hl1321ro005, repr(hashlib.sha512).__class__.__name__.__eq__,                 ["str"], true]
    - [hl1321ro006, repr(hashlib.new).__class__.__name__.__eq__,                    ["str"], true]
