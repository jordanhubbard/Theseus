spec: lodash_gt
version: ">=3.9.2"
backend: node(lodash.gt)

docs: https://lodash.com/docs/#gt

provenance:
  derived_from:
    - "lodash.gt README — https://www.npmjs.com/package/lodash.gt"
    - "Test vectors verified with lodash.gt@3.9.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.gt exports the _.gt function directly as module.exports."
    - "gt(value, other) checks if value is greater than other."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_gt.gt:
  kind: node_module_call_eq
  function: ~
  category: gt
  id_prefix: lgt

  columns: [id, args, expected]
  rows:
    - [greater,  [3, 1],    true]
    - [equal,    [3, 3],    false]
    - [less,     [1, 3],    false]

