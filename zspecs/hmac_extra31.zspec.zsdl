spec: hmac_extra31
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html
rfcs:
  - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"

provenance:
  derived_from:
    - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication, February 1997"
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
    - "hmac_extra30.zspec.zsdl — covers HMAC.copy/__name__.__len__()==4; HMAC.update/digest/hexdigest/copy __qualname__.__len__(); HMAC.__init__/__name__.__len__()==8 and __qualname__.__len__()==13; HMAC.update/digest/hexdigest/copy/__init__ __module__.__len__()==4."
  notes:
    - "This spec extends hmac through hmac_extra30; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: HMAC/__name__/__module__/__qualname__/__bases__[0].__name__ (multiple specs); hmac.new/digest/compare_digest __name__/__module__/__qualname__ and their __len__() variants (extra23, extra29); HMAC.update/digest/hexdigest/copy/__init__ __name__/__qualname__/__module__.__len__() (extra29, extra30); HMAC.__mro__.__len__()==2 (extra22); HMAC.__module__.__len__()==4 (extra21, extra29)."
    - "This spec covers: hmac.__name__.__len__() (NOVEL — no prior spec checks __len__() for the module's own __name__); hmac.__package__.__len__() (NOVEL — hmac.__package__=='' so len==0); HMAC.__bases__[0].__name__.__len__() (NOVEL — 'object' has 6 characters; prior specs check __eq__ but not __len__()); hmac.trans_36.__class__.__name__.__len__() (NOVEL — trans_36 is a bytes constant, 'bytes' has 5 characters); hmac.trans_5C.__class__.__name__.__len__() (NOVEL — also a bytes constant, 'bytes' has 5 characters); HMAC.__dict__.__class__.__name__.__len__() (NOVEL — mappingproxy has 12 characters)."
    - "hmac.__name__ == 'hmac' (len 4). No prior spec checks __len__() for the module's own __name__ attribute. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.__package__ == '' (len 0). hmac is a pure-Python module with no parent package; __package__ is the empty string. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.__bases__[0].__name__ == 'object' (len 6). Prior specs (extra2, extra17, extra27) check __bases__[0].__name__.__eq__('object') but none check __len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.trans_36 is a 256-byte XOR pad used internally; __class__.__name__ == 'bytes' (len 5). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.trans_5C is a 256-byte XOR pad used internally; __class__.__name__ == 'bytes' (len 5). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.__dict__.__class__.__name__ == 'mappingproxy' (len 12). Class __dict__ is always a mappingproxy in CPython. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hmac module __name__.__len__() and __package__.__len__()
#
# No prior spec checks __len__() for the hmac module's own __name__ or
# __package__ attributes. hmac.__name__ == 'hmac' (len 4); hmac.__package__
# == '' (len 0, since hmac is a top-level module with no parent package).
# ---------------------------------------------------------------------------

invariant hmac_extra31.module.name.len:
  description: "hmac.__name__.__len__() == 4 — 'hmac' has 4 characters, novel invariant for module-level identity"
  category: string_length
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 4

invariant hmac_extra31.module.package.len:
  description: "hmac.__package__.__len__() == 0 — empty string; hmac is a top-level module with no parent package, novel invariant"
  category: string_length
  kind: python_call_eq
  function: __package__.__len__
  args: []
  expected: 0

# ---------------------------------------------------------------------------
# hmac.HMAC.__bases__[0].__name__.__len__()
#
# Prior specs (extra2, extra17, extra27) verify HMAC.__bases__[0].__name__
# equals 'object'. No prior spec checks the length of that string.
# len('object') == 6. Novel.
# ---------------------------------------------------------------------------

invariant hmac_extra31.HMAC.bases0.name_len:
  description: "hmac.HMAC.__bases__[0].__name__.__len__() == 6 — 'object' has 6 characters, novel invariant"
  category: class_hierarchy
  kind: python_call_eq
  function: "HMAC.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# hmac.trans_36 and hmac.trans_5C — __class__.__name__.__len__()
#
# trans_36 and trans_5C are module-level bytes constants used as HMAC XOR
# pads. No prior spec covers any attribute of these constants.
# Both are bytes objects: __class__.__name__ == 'bytes' (len 5).
# ---------------------------------------------------------------------------

invariant hmac_extra31.trans_36.classname_len:
  description: "hmac.trans_36.__class__.__name__.__len__() == 5 — 'bytes' has 5 characters; trans_36 is a bytes XOR pad, novel invariant"
  category: string_length
  kind: python_call_eq
  function: trans_36.__class__.__name__.__len__
  args: []
  expected: 5

invariant hmac_extra31.trans_5C.classname_len:
  description: "hmac.trans_5C.__class__.__name__.__len__() == 5 — 'bytes' has 5 characters; trans_5C is a bytes XOR pad, novel invariant"
  category: string_length
  kind: python_call_eq
  function: trans_5C.__class__.__name__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# Table: hmac module bytes constants — __class__.__name__.__len__()
#
# Groups the two XOR pad constants. Both novel (no prior spec touches them).
# Adds a length sanity check: both pads are exactly 256 bytes.
# ---------------------------------------------------------------------------

table hmac_extra31.xor_pad_class_name_lengths:
  description: "hmac.trans_36 and hmac.trans_5C __class__.__name__.__len__() == 5 — both are bytes, novel invariants"
  kind: python_call_eq
  category: string_length
  id_prefix: hmxpcnl31

  columns: [id, function, args, expected]
  rows:
    - [trans_36_classname_len, trans_36.__class__.__name__.__len__, [], 5]
    - [trans_5C_classname_len, trans_5C.__class__.__name__.__len__, [], 5]
    - [trans_36_len,           trans_36.__len__,                   [], 256]
    - [trans_5C_len,           trans_5C.__len__,                   [], 256]

# ---------------------------------------------------------------------------
# hmac.HMAC.__dict__.__class__.__name__.__len__()
#
# No prior spec checks HMAC.__dict__.__class__.__name__ or its length.
# In CPython, class __dict__ is always a mappingproxy; len('mappingproxy') == 12.
# ---------------------------------------------------------------------------

table hmac_extra31.HMAC_dict_classname:
  description: "hmac.HMAC.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has 12 characters, novel invariant"
  kind: python_call_eq
  category: string_length
  id_prefix: hmhdcnl31

  columns: [id, function, args, expected]
  rows:
    - [HMAC_dict_classname_len, HMAC.__dict__.__class__.__name__.__len__, [], 12]
    - [module_name_len,         __name__.__len__,                         [], 4]
    - [module_package_len,      __package__.__len__,                      [], 0]
