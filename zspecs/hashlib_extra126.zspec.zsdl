spec: hashlib_extra126
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra125.zspec.zsdl — covers md5()/sha256()/sha1().__class__.__name__.__eq__('HASH') / md5().__class__.__module__.__eq__('_hashlib') / md5().__class__.__qualname__.__eq__('HASH') / md5().update/digest/hexdigest/copy __class__.__name__.__eq__('builtin_function_or_method') / md5().update/digest/hexdigest/copy __qualname__.__eq__ / md5().update.__qualname__.__len__()==11 (table + invariants)."
    - "hashlib_extra124.zspec.zsdl — covers pbkdf2_hmac and scrypt __class__.__name__.__len__()==26 / __doc__.__class__.__module__.__eq__('builtins') (table + invariants)."
    - "hashlib_extra123.zspec.zsdl — covers sha256.__doc__.__class__.__module__.__eq__('builtins') / sha256().__class__.__qualname__.__eq__('HASH') and __len__()==4 (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 constructor __class__.__name__ and __name__ / blake2b/blake2s class identity / new function class / algorithms_guaranteed length (table + invariants)."
  notes:
    - "This spec extends hashlib through hashlib_extra125; it does NOT duplicate invariants present in those files."
    - "Wave 289 theme: hashlib HASH instance method qualname lengths and instance attribute class names — md5().digest/__qualname__.__len__()==11 / hexdigest/__qualname__.__len__()==14 / copy/__qualname__.__len__()==9 / md5().digest_size/__class__.__name__=='int' / md5().block_size/__class__.__name__=='int' / md5().name/__class__.__name__=='str' / md5().digest_size==16 / sha256().digest_size==32."
    - "hashlib.md5().digest.__qualname__.__len__() == 11. len('HASH.digest')==11 ('HASH.'=5 + 'digest'=6). extra125 anchors md5().update.__qualname__.__len__()==11 but NOT digest. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().hexdigest.__qualname__.__len__() == 14. len('HASH.hexdigest')==14 ('HASH.'=5 + 'hexdigest'=9). extra125 anchors hexdigest.__qualname__.__eq__('HASH.hexdigest') but NOT the length. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().copy.__qualname__.__len__() == 9. len('HASH.copy')==9 ('HASH.'=5 + 'copy'=4). extra125 anchors copy.__qualname__.__eq__('HASH.copy') but NOT the length. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().digest_size.__class__.__name__ == 'int'. digest_size is a Python int attribute on the HASH instance (the number of bytes in the raw digest: md5==16, sha1==20, sha256==32). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().block_size.__class__.__name__ == 'int'. block_size is a Python int attribute (64 for md5, sha1, sha256). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().name.__class__.__name__ == 'str'. name is a Python str attribute ('md5', 'sha256', etc.) identifying the algorithm. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5().digest_size == 16. MD5 produces a 128-bit (16-byte) digest. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256().digest_size == 32. SHA-256 produces a 256-bit (32-byte) digest. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1().digest_size == 20. SHA-1 produces a 160-bit (20-byte) digest. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: update and digest both have qualname length 11 ('HASH.'=5 + 'update'=6 and 'HASH.'=5 + 'digest'=6). hexdigest is 14 ('HASH.'=5 + 'hexdigest'=9). copy is 9 ('HASH.'=5 + 'copy'=4). The digest_size, block_size, and name attributes are plain Python ints/strs exposed on the HASH instance — they do NOT have the complex qualname structure of methods. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.md5().digest.__qualname__.__len__()==11
# hashlib.md5().hexdigest.__qualname__.__len__()==14
# hashlib.md5().copy.__qualname__.__len__()==9
# hashlib.sha256().digest.__qualname__.__len__()==11
# hashlib.sha256().hexdigest.__qualname__.__len__()==14
#
# Wave 289 theme: HASH instance method qualname lengths.
#
# extra125 anchors md5().update.__qualname__.__len__()==11 as the only length;
# it also anchors __qualname__.__eq__ for all four methods. This table anchors
# the lengths for the remaining three methods (digest, hexdigest, copy) plus
# cross-checks via sha256(). update and digest share length 11; hexdigest is 14;
# copy is the shortest at 9. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra126.HASH_method_qualname_lengths:
  description: "md5().digest/__qualname__/__len__()==11 / md5().hexdigest/__qualname__/__len__()==14 / md5().copy/__qualname__/__len__()==9 / sha256().digest/__qualname__/__len__()==11 / sha256().hexdigest/__qualname__/__len__()==14 — extra125 anchors update.__qualname__.__len__()==11 and all four __qualname__.__eq__ values; this table anchors the remaining three method qualname lengths; update and digest share length 11; hexdigest is 14; copy is 9 (shortest); cross-checks confirm sha256() shares the same lengths; first hashmlen126 anchor"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: hashmlen126

  columns: [id, function, args, expected, description]
  rows:
    - [digest_qlen,     "md5().digest.__qualname__.__len__",     [], 11, "len('HASH.digest')==11 ('HASH.'=5 + 'digest'=6; same length as update qualname; extra125 anchors digest.__qualname__.__eq__('HASH.digest') but NOT the length)"]
    - [hexdigest_qlen,  "md5().hexdigest.__qualname__.__len__",  [], 14, "len('HASH.hexdigest')==14 ('HASH.'=5 + 'hexdigest'=9; longest HASH method qualname; extra125 anchors hexdigest.__qualname__.__eq__ but NOT the length)"]
    - [copy_qlen,       "md5().copy.__qualname__.__len__",       [], 9,  "len('HASH.copy')==9 ('HASH.'=5 + 'copy'=4; shortest HASH method qualname; extra125 anchors copy.__qualname__.__eq__ but NOT the length)"]
    - [sha256_dig_qlen, "sha256().digest.__qualname__.__len__",  [], 11, "len('HASH.digest')==11 for sha256() instance; same as md5() because all algorithms share the HASH class and its method qualnames"]
    - [sha256_hex_qlen, "sha256().hexdigest.__qualname__.__len__", [], 14, "len('HASH.hexdigest')==14 for sha256() instance; confirms qualname lengths are algorithm-independent (HASH class is shared)"]

# ---------------------------------------------------------------------------
# hashlib.md5().digest_size.__class__.__name__.__eq__('int')
# hashlib.md5().block_size.__class__.__name__.__eq__('int')
# hashlib.md5().name.__class__.__name__.__eq__('str')
# hashlib.md5().digest_size.__eq__(16)
# hashlib.sha256().digest_size.__eq__(32)
#
# Wave 289 theme: HASH instance attribute class names and digest_size values.
#
# The HASH instance exposes digest_size, block_size, and name as plain Python
# objects: digest_size and block_size are Python ints, name is a Python str.
# digest_size is 16 for md5 (128-bit digest), 20 for sha1 (160-bit), 32 for
# sha256 (256-bit). block_size is 64 for md5, sha1, and sha256 (512-bit block).
# No prior hashlib spec anchors these attribute class names or digest_size values
# under hashmlen126. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra126.HASH_instance_attr_class_names:
  description: "md5().digest_size/__class__.__name__.__eq__('int')==True / md5().block_size/__class__.__name__.__eq__('int')==True / md5().name/__class__.__name__.__eq__('str')==True / md5().digest_size.__eq__(16)==True / sha256().digest_size.__eq__(32)==True — digest_size and block_size are Python ints; name is a Python str; md5 digest_size==16 (128-bit), sha256 digest_size==32 (256-bit); no prior spec anchors HASH instance attribute class names; first hashmlen126 attr anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashmlen126

  columns: [id, function, args, expected, description]
  rows:
    - [digest_size_class,  "md5().digest_size.__class__.__name__.__eq__", ["int"], true, "md5().digest_size.__class__.__name__ is 'int' (Python int; MD5 produces 16-byte digest; no prior spec anchors digest_size class name)"]
    - [block_size_class,   "md5().block_size.__class__.__name__.__eq__",  ["int"], true, "md5().block_size.__class__.__name__ is 'int' (Python int; MD5 uses 64-byte / 512-bit blocks; no prior spec anchors block_size class name)"]
    - [name_class,         "md5().name.__class__.__name__.__eq__",        ["str"], true, "md5().name.__class__.__name__ is 'str' (Python str; md5().name is 'md5'; no prior spec anchors name class name)"]
    - [md5_digest_size,    "md5().digest_size.__eq__",                    [16],   true, "md5().digest_size == 16 (128-bit == 16 bytes; first spec to anchor md5 digest_size value; no prior spec anchors digest_size equality)"]
    - [sha256_digest_size, "sha256().digest_size.__eq__",                 [32],   true, "sha256().digest_size == 32 (256-bit == 32 bytes; first spec to anchor sha256 digest_size value; no prior spec anchors digest_size equality)"]

# ---------------------------------------------------------------------------
# hashlib.md5().digest_size.__eq__(16)
# hashlib.sha1().digest_size.__eq__(20)
# hashlib.sha256().digest_size.__eq__(32)
# hashlib.md5().block_size.__eq__(64)
# hashlib.sha256().block_size.__eq__(64)
#
# Wave 289 theme: HASH instance digest_size and block_size values.
#
# The three most common hash algorithms have distinct digest sizes: md5==16,
# sha1==20, sha256==32. All three share the same block_size==64 (512-bit block).
# The digest_size values reflect the output size in bytes (algorithm security
# parameter), while block_size reflects the internal compression block.
# No prior hashlib spec anchors any of these values under hashmlen126.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra126.HASH_digest_block_sizes:
  description: "md5().digest_size.__eq__(16)==True / sha1().digest_size.__eq__(20)==True / sha256().digest_size.__eq__(32)==True / md5().block_size.__eq__(64)==True / sha256().block_size.__eq__(64)==True — md5 digest_size=16 (128-bit), sha1=20 (160-bit), sha256=32 (256-bit); all three share block_size=64 (512-bit block); no prior spec anchors digest_size or block_size values; first hashmlen126 size anchor"
  kind: python_call_eq
  category: numeric_values
  id_prefix: hashmlen126

  columns: [id, function, args, expected, description]
  rows:
    - [md5_dig,    "md5().digest_size.__eq__",    [16], true, "md5().digest_size is 16 (128-bit output; MD5 is a 128-bit message digest; no prior spec anchors this value)"]
    - [sha1_dig,   "sha1().digest_size.__eq__",   [20], true, "sha1().digest_size is 20 (160-bit output; SHA-1 is a 160-bit secure hash; no prior spec anchors this value)"]
    - [sha256_dig, "sha256().digest_size.__eq__", [32], true, "sha256().digest_size is 32 (256-bit output; SHA-256 is a 256-bit secure hash; no prior spec anchors this value)"]
    - [md5_blk,    "md5().block_size.__eq__",     [64], true, "md5().block_size is 64 (512-bit block; MD5 processes in 512-bit chunks; same as sha1 and sha256)"]
    - [sha256_blk, "sha256().block_size.__eq__",  [64], true, "sha256().block_size is 64 (512-bit block; SHA-256 uses 512-bit input blocks; same as md5 and sha1)"]

# ---------------------------------------------------------------------------
# hashlib.md5().digest.__qualname__.__len__()==11 — standalone
#
# hashlib.md5().digest.__qualname__.__len__() is 11. 'HASH.digest' has 11 chars:
# 'HASH.'=5 + 'digest'=6. update and digest share the same qualname length (11),
# even though they are different methods with very different behaviors: update
# modifies the hash state while digest reads the current digest value. extra125
# anchors md5().update.__qualname__.__len__()==11 but NOT digest. No prior
# hashlib spec anchors md5().digest.__qualname__.__len__()==11 as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra126.md5_digest_qualname_len_11:
  description: "hashlib.md5().digest.__qualname__.__len__() == 11 — len('HASH.digest')==11 ('HASH.'=5 + 'digest'=6); update and digest share qualname length 11 despite different behaviors (update modifies state, digest reads it); extra125 anchors update length==11 and digest.__qualname__.__eq__('HASH.digest'); no prior spec anchors digest qualname length as standalone; first standalone under hashmlen126"
  category: method_qualnames
  kind: python_call_eq
  function: "md5().digest.__qualname__.__len__"
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# hashlib.md5().hexdigest.__qualname__.__len__()==14 — standalone
#
# hashlib.md5().hexdigest.__qualname__.__len__() is 14. 'HASH.hexdigest' has 14
# chars: 'HASH.'=5 + 'hexdigest'=9. hexdigest is the longest qualname among the
# four core HASH instance methods (update/digest/hexdigest/copy), 14 chars vs 11,
# 11, and 9 respectively. extra125 anchors hexdigest.__qualname__.__eq__('HASH.hexdigest')
# but NOT the length. No prior hashlib spec anchors md5().hexdigest.__qualname__.__len__()
# as a standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra126.md5_hexdigest_qualname_len_14:
  description: "hashlib.md5().hexdigest.__qualname__.__len__() == 14 — len('HASH.hexdigest')==14 ('HASH.'=5 + 'hexdigest'=9; longest HASH method qualname: 14 > 11 > 11 > 9 for hexdigest/update/digest/copy); extra125 anchors hexdigest.__qualname__.__eq__('HASH.hexdigest') but NOT the length; no prior spec anchors hexdigest qualname length as standalone; first standalone under hashmlen126"
  category: method_qualnames
  kind: python_call_eq
  function: "md5().hexdigest.__qualname__.__len__"
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# hashlib.md5().copy.__qualname__.__len__()==9 — standalone
#
# hashlib.md5().copy.__qualname__.__len__() is 9. 'HASH.copy' has 9 chars:
# 'HASH.'=5 + 'copy'=4. copy is the shortest qualname among the four core HASH
# instance methods (9 chars vs 11, 11, 14 for digest, update, hexdigest). The
# copy method returns a duplicate HASH with the same state — useful for computing
# multiple digests from a common prefix. extra125 anchors copy.__qualname__.__eq__
# ('HASH.copy') but NOT the length. No prior hashlib spec anchors this as a
# standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra126.md5_copy_qualname_len_9:
  description: "hashlib.md5().copy.__qualname__.__len__() == 9 — len('HASH.copy')==9 ('HASH.'=5 + 'copy'=4; shortest HASH method qualname: 9 < 11 = 11 < 14 for copy/digest/update/hexdigest); copy duplicates the HASH state for computing multiple digests from a common prefix; extra125 anchors copy.__qualname__.__eq__('HASH.copy') but NOT the length; no prior spec anchors copy qualname length as standalone; first standalone under hashmlen126"
  category: method_qualnames
  kind: python_call_eq
  function: "md5().copy.__qualname__.__len__"
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# hashlib.md5().digest_size.__class__.__name__.__eq__('int') — standalone
#
# hashlib.md5().digest_size.__class__.__name__ is 'int'. The digest_size attribute
# is a plain Python int (not a C-level descriptor object) exposed on the HASH
# instance. For md5, digest_size is 16 (the 128-bit / 16-byte MD5 output size).
# This contrasts with the methods (update/digest/hexdigest/copy) which are
# C-level builtin_function_or_method objects. No prior hashlib spec anchors
# md5().digest_size.__class__.__name__ in any form.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra126.md5_digest_size_class_int:
  description: "hashlib.md5().digest_size.__class__.__name__.__eq__('int') == True — digest_size is a plain Python int attribute on the HASH instance (not a C-level descriptor or builtin_function_or_method); for md5, digest_size==16 (128-bit output); contrasts with methods which are builtin_function_or_method; no prior spec anchors digest_size.__class__.__name__ in any form; first standalone under hashmlen126"
  category: type_identity
  kind: python_call_eq
  function: "md5().digest_size.__class__.__name__.__eq__"
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5().name.__class__.__name__.__eq__('str') — standalone
#
# hashlib.md5().name.__class__.__name__ is 'str'. The name attribute is a plain
# Python str on the HASH instance, identifying the algorithm (e.g., 'md5',
# 'sha256', 'sha1'). The name value for md5 instances is 'md5' (3 chars). This
# attribute is useful for introspecting which algorithm a HASH object implements,
# especially when a HASH object is passed to another function. No prior hashlib
# spec anchors md5().name.__class__.__name__ in any form.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra126.md5_name_class_str:
  description: "hashlib.md5().name.__class__.__name__.__eq__('str') == True — name is a plain Python str attribute on the HASH instance identifying the algorithm (md5().name=='md5', sha256().name=='sha256'); useful for introspecting which algorithm a HASH object implements; contrasts with methods which are builtin_function_or_method; no prior spec anchors name.__class__.__name__ in any form; first standalone under hashmlen126"
  category: type_identity
  kind: python_call_eq
  function: "md5().name.__class__.__name__.__eq__"
  args: ["str"]
  expected: true

