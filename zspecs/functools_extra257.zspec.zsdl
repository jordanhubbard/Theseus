spec: functools_extra257
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec covers: functools.WRAPPER_ASSIGNMENTS and functools.WRAPPER_UPDATES constant identity and membership behavioral contracts."
    - "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple' — WRAPPER_ASSIGNMENTS is a tuple constant listing attribute names copied by wraps/update_wrapper. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — In Python 3.14.3 the tuple contains: '__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'. Note: '__annotations__' and '__wrapped__' are NOT present in 3.14.3. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True — '__module__' is the first element of WRAPPER_ASSIGNMENTS. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True — '__name__' is in WRAPPER_ASSIGNMENTS. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True — '__qualname__' is in WRAPPER_ASSIGNMENTS. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True — '__doc__' is in WRAPPER_ASSIGNMENTS. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__contains__('__annotate__') == True — '__annotate__' is in WRAPPER_ASSIGNMENTS (Python 3.14+). Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__contains__('__type_params__') == True — '__type_params__' is in WRAPPER_ASSIGNMENTS (Python 3.14+). Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__contains__('__annotations__') == False — '__annotations__' is NOT in WRAPPER_ASSIGNMENTS in Python 3.14.3 (replaced by '__annotate__'). Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple' — WRAPPER_UPDATES is a tuple constant listing attributes merged by update_wrapper. Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES contains only '__dict__'. Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES.__contains__('__dict__') == True — '__dict__' is the sole element of WRAPPER_UPDATES. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.WRAPPER_ASSIGNMENTS type and length identity
#
# functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'
# functools.WRAPPER_ASSIGNMENTS.__len__() == 6
#
# WRAPPER_ASSIGNMENTS is a module-level tuple constant; in Python 3.14.3 it
# contains 6 elements: __module__, __name__, __qualname__, __doc__,
# __annotate__, __type_params__. New to extra257.
# ---------------------------------------------------------------------------

table functools_extra257.wrapper_assignments_type_len:
  description: "functools.WRAPPER_ASSIGNMENTS type (__class__.__name__) and length (__len__) identity contracts; new to extra257"
  kind: python_call_eq
  category: identity
  id_prefix: wrpassign257

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_assignments_class_name_eq,
       WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('tuple') == True — WRAPPER_ASSIGNMENTS is a tuple of attribute name strings copied by update_wrapper; __class__.__name__ is 'tuple'; new to extra257"]
    - [wrapper_assignments_len_6,
       WRAPPER_ASSIGNMENTS.__len__,
       [],
       6,
       "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — In Python 3.14.3 WRAPPER_ASSIGNMENTS contains 6 elements: __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__; new to extra257"]
    - [wrapper_updates_class_name_eq,
       WRAPPER_UPDATES.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.WRAPPER_UPDATES.__class__.__name__.__eq__('tuple') == True — WRAPPER_UPDATES is a tuple of attribute names merged (not replaced) by update_wrapper; __class__.__name__ is 'tuple'; new to extra257"]
    - [wrapper_updates_len_1,
       WRAPPER_UPDATES.__len__,
       [],
       1,
       "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES contains only '__dict__'; new to extra257"]
    - [wrapper_updates_contains_dict,
       WRAPPER_UPDATES.__contains__,
       ["__dict__"],
       true,
       "functools.WRAPPER_UPDATES.__contains__('__dict__') == True — '__dict__' is the sole element of WRAPPER_UPDATES; new to extra257"]

# ---------------------------------------------------------------------------
# Table 2: functools.WRAPPER_ASSIGNMENTS membership for core attributes
#
# WRAPPER_ASSIGNMENTS.__contains__('__module__') == True
# WRAPPER_ASSIGNMENTS.__contains__('__name__') == True
# WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True
# WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True
#
# These four attributes have been in WRAPPER_ASSIGNMENTS since early Python 3.
# New to extra257.
# ---------------------------------------------------------------------------

table functools_extra257.wrapper_assignments_core_membership:
  description: "functools.WRAPPER_ASSIGNMENTS membership checks for __module__, __name__, __qualname__, __doc__; all True in Python 3.14.3; new to extra257"
  kind: python_call_eq
  category: identity
  id_prefix: wrpassignmem257

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_assignments_has_module,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__module__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True — '__module__' is the first element of WRAPPER_ASSIGNMENTS; new to extra257"]
    - [wrapper_assignments_has_name,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__name__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True — '__name__' is in WRAPPER_ASSIGNMENTS; new to extra257"]
    - [wrapper_assignments_has_qualname,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__qualname__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True — '__qualname__' is in WRAPPER_ASSIGNMENTS; new to extra257"]
    - [wrapper_assignments_has_doc,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__doc__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True — '__doc__' is in WRAPPER_ASSIGNMENTS; new to extra257"]
    - [wrapper_assignments_no_annotations,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__annotations__"],
       false,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__annotations__') == False — '__annotations__' is NOT in WRAPPER_ASSIGNMENTS in Python 3.14.3; it was replaced by '__annotate__'; new to extra257"]

# ---------------------------------------------------------------------------
# Table 3: functools.WRAPPER_ASSIGNMENTS Python 3.14+ new attributes
#
# WRAPPER_ASSIGNMENTS.__contains__('__annotate__') == True
# WRAPPER_ASSIGNMENTS.__contains__('__type_params__') == True
#
# __annotate__ and __type_params__ were added to WRAPPER_ASSIGNMENTS in
# Python 3.14. New to extra257.
# ---------------------------------------------------------------------------

table functools_extra257.wrapper_assignments_new_attrs:
  description: "functools.WRAPPER_ASSIGNMENTS membership checks for Python 3.14+ attributes __annotate__ and __type_params__; new to extra257"
  kind: python_call_eq
  category: identity
  id_prefix: wrpassignnew257

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_assignments_has_annotate,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__annotate__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__annotate__') == True — '__annotate__' is in WRAPPER_ASSIGNMENTS in Python 3.14.3 (added in 3.14, replaces __annotations__); new to extra257"]
    - [wrapper_assignments_has_type_params,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__type_params__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__type_params__') == True — '__type_params__' is in WRAPPER_ASSIGNMENTS in Python 3.14.3 (added in 3.14 for PEP 695 type parameters); new to extra257"]
    - [wrapper_assignments_no_wrapped,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__wrapped__"],
       false,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__wrapped__') == False — '__wrapped__' is NOT in WRAPPER_ASSIGNMENTS; it is set by update_wrapper but is not listed in this tuple; new to extra257"]
    - [wrapper_assignments_module_len_10,
       WRAPPER_ASSIGNMENTS.__class__.__name__.__len__,
       [],
       5,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__len__() == 5 — 'tuple' has 5 characters; new to extra257"]
    - [wrapper_updates_dict_len_8,
       WRAPPER_UPDATES.__len__,
       [],
       1,
       "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES is a 1-element tuple; new to extra257"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra257
# ---------------------------------------------------------------------------

invariant functools_extra257.WRAPPER_ASSIGNMENTS.class_is_tuple:
  description: "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple' — WRAPPER_ASSIGNMENTS is a tuple of attribute names copied by update_wrapper; new to extra257"
  category: identity
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra257.WRAPPER_ASSIGNMENTS.len_6:
  description: "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — In Python 3.14.3 WRAPPER_ASSIGNMENTS has 6 elements; new to extra257"
  category: identity
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

invariant functools_extra257.WRAPPER_ASSIGNMENTS.has_module:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True — '__module__' is in WRAPPER_ASSIGNMENTS; new to extra257"
  category: identity
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__module__"]
  expected: true

invariant functools_extra257.WRAPPER_ASSIGNMENTS.has_name:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True — '__name__' is in WRAPPER_ASSIGNMENTS; new to extra257"
  category: identity
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__name__"]
  expected: true

invariant functools_extra257.WRAPPER_ASSIGNMENTS.has_qualname:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True — '__qualname__' is in WRAPPER_ASSIGNMENTS; new to extra257"
  category: identity
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__qualname__"]
  expected: true

invariant functools_extra257.WRAPPER_ASSIGNMENTS.has_doc:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True — '__doc__' is in WRAPPER_ASSIGNMENTS; new to extra257"
  category: identity
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__doc__"]
  expected: true

invariant functools_extra257.WRAPPER_ASSIGNMENTS.has_annotate:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__annotate__') == True — '__annotate__' added in Python 3.14 replaces '__annotations__' in WRAPPER_ASSIGNMENTS; new to extra257"
  category: identity
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__annotate__"]
  expected: true

invariant functools_extra257.WRAPPER_ASSIGNMENTS.has_type_params:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__type_params__') == True — '__type_params__' added in Python 3.14 for PEP 695 type parameters; new to extra257"
  category: identity
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__type_params__"]
  expected: true

invariant functools_extra257.WRAPPER_ASSIGNMENTS.no_annotations:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__annotations__') == False — '__annotations__' is NOT in WRAPPER_ASSIGNMENTS in Python 3.14.3; new to extra257"
  category: identity
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__annotations__"]
  expected: false

invariant functools_extra257.WRAPPER_UPDATES.class_is_tuple:
  description: "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple' — WRAPPER_UPDATES is a tuple of attribute names merged by update_wrapper; new to extra257"
  category: identity
  kind: python_call_eq
  function: WRAPPER_UPDATES.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra257.WRAPPER_UPDATES.len_1:
  description: "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES contains only '__dict__'; new to extra257"
  category: identity
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1

invariant functools_extra257.WRAPPER_UPDATES.has_dict:
  description: "functools.WRAPPER_UPDATES.__contains__('__dict__') == True — '__dict__' is the sole element of WRAPPER_UPDATES; new to extra257"
  category: identity
  kind: python_call_eq
  function: WRAPPER_UPDATES.__contains__
  args: ["__dict__"]
  expected: true
