spec: struct_extra164
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra163.zspec.zsdl — covers struct.pack/__unpack __class__.__name__=='builtin_function_or_method' / Struct.__dict__.__contains__ for pack/unpack/size/format/pack_into/iter_unpack/unpack_from / Struct.__dict__.__len__()==16 (table + invariants)."
    - "struct_extra162.zspec.zsdl — covers struct.pack/__unpack/__pack_into/__unpack_from/__iter_unpack/__calcsize .__name__/__module__ (module-level function identity); pack.__class__.__name__=='builtin_function_or_method' (table + invariants)."
    - "struct_extra161.zspec.zsdl — covers struct.error/__Struct class identity (__name__/__module__/__bases__) and lengths (table + invariants)."
    - "struct_extra160.zspec.zsdl — covers struct.Struct.__dict__ membership (pack/unpack/pack_into/unpack_from/iter_unpack/size/format) and meta-attributes (__len__()==16/__class__.__name__=='mappingproxy') (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra163."
    - "Wave 350 theme: struct module-level function __name__ lengths. struct_extra162 anchors pack.__name__=='pack' and unpack.__name__=='unpack' as __eq__ calls; this spec anchors the __len__() integer values for all six module-level function names as the primary novel content. Name length ordering: 'pack'(4) < 'unpack'(6) < 'calcsize'(8) < 'pack_into'(9) < 'unpack_from'(11) == 'iter_unpack'(11)."
    - "struct.pack.__name__.__len__() == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__name__.__len__() == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__name__.__len__() == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__name__.__len__() == 9. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__name__.__len__() == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__name__.__len__() == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: Name length ordering: 'pack'(4) < 'unpack'(6) < 'calcsize'(8) < 'pack_into'(9) < 'unpack_from'(11) == 'iter_unpack'(11). The shortest name is 'pack'(4), the longest two are tied at 11 chars each. 'calcsize'(8) is the only name whose length does not share a value with another function name: 4 (pack), 6 (unpack), 8 (calcsize), 9 (pack_into), 11 (unpack_from == iter_unpack)."
    - "Note: struct.pack.__name__.__len__() == 4 ('pack' = 4 chars; 'p'=1+'a'=1+'c'=1+'k'=1). struct_extra162 anchors pack.__name__.__len__()==4 as a table row under structfn162; this spec anchors it as a standalone and in focused length-comparison tables under structlen164."
    - "Note: struct.unpack.__name__.__len__() == 6 ('unpack' = 'un'=2 + 'pack'=4 = 6). 'unpack'(6) > 'pack'(4) by 2 chars — the 'un' prefix adds 2."
    - "Note: struct.calcsize.__name__.__len__() == 8 ('calcsize' = 'calc'=4 + 'size'=4 = 8). 'calcsize'(8) > 'unpack'(6) > 'pack'(4). Only odd name length among these six: 4, 6, 8, 9, 11, 11 — calcsize at 8 is the only one with no tie."
    - "Note: struct.pack_into.__name__.__len__() == 9 ('pack_into' = 'pack'=4 + '_into'=5 = 9). 'pack_into'(9) > 'calcsize'(8) by 1. The '_into' suffix means 'write into buffer'. struct_extra162 anchors pack.__name__.__len__()==4 and unpack_from.__name__.__len__()==11 as table rows; this spec anchors all six lengths together."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack.__name__.__len__()==4
# struct.unpack.__name__.__len__()==6
# struct.calcsize.__name__.__len__()==8
# struct.pack_into.__name__.__len__()==9
#
# Wave 350 theme: module-level struct function name lengths — shortest four.
#
# pack.__name__.__len__() == 4 ('pack' = 4 chars; shortest name).
# unpack.__name__.__len__() == 6 ('unpack' = 6 chars; 'pack' + 'un' prefix).
# calcsize.__name__.__len__() == 8 ('calcsize' = 8 chars; 'calc'=4 + 'size'=4).
# pack_into.__name__.__len__() == 9 ('pack_into' = 9 chars; 'pack'=4 + '_into'=5).
# struct_extra162 anchors pack.__name__.__len__()==4 as a table row;
# this spec anchors all six in focused length tables under structlen164.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra164.fn_name_lengths_shortest_four:
  description: "struct.pack.__name__.__len__()==4 / unpack.__name__.__len__()==6 / calcsize.__name__.__len__()==8 / pack_into.__name__.__len__()==9 — pack.__name__.__len__() is 4 ('pack' = 4 chars; shortest module-level function name; 'p'+'a'+'c'+'k' = 4; all four chars are unique letters in the name; struct_extra162 anchors pack.__name__.__len__()==4 as a table row under structfn162; this spec provides a fresh anchor under structlen164 focusing on the integer length values); unpack.__name__.__len__() is 6 ('unpack' = 'un'=2 + 'pack'=4 = 6 chars; the 'un' prefix adds exactly 2 chars to 'pack'; 'unpack'(6) > 'pack'(4) by 2; 'un' is a common negation/reversal prefix in English); calcsize.__name__.__len__() is 8 ('calcsize' = 'calc'=4 + 'size'=4 = 8 chars; 'calc' from 'calculate' and 'size'; each half of the compound word is 4 chars; calcsize is the only module-level function that computes rather than packs/unpacks; 'calcsize'(8) > 'unpack'(6) by 2 chars; 8 = 4 + 4 = twice the length of 'pack'); pack_into.__name__.__len__() is 9 ('pack_into' = 'pack'=4 + '_into'=5 = 9 chars; the '_into' suffix signals in-place writing into a buffer; 'pack_into'(9) > 'calcsize'(8) by 1 char; 9 is an odd number; length ordering so far: 4 < 6 < 8 < 9; first structlen164 anchor for shortest four name lengths)"
  kind: python_call_eq
  category: identity
  id_prefix: structlen164

  columns: [id, function, args, expected, description]
  rows:
    - [pack_name_len_4,       "pack.__name__.__len__",      [], 4, "struct.pack.__name__.__len__() is 4 ('pack' = 4 chars; shortest name; struct_extra162 anchors this as table row; confirmed here under structlen164)"]
    - [unpack_name_len_6,     "unpack.__name__.__len__",    [], 6, "struct.unpack.__name__.__len__() is 6 ('unpack' = 'un'=2 + 'pack'=4 = 6; 'un' prefix adds 2 chars to 'pack'; 'unpack'(6) > 'pack'(4) by 2)"]
    - [calcsize_name_len_8,   "calcsize.__name__.__len__",  [], 8, "struct.calcsize.__name__.__len__() is 8 ('calcsize' = 'calc'=4 + 'size'=4 = 8; both halves are 4 chars; 8 = 2 * 4 = twice 'pack'(4))"]
    - [pack_into_name_len_9,  "pack_into.__name__.__len__", [], 9, "struct.pack_into.__name__.__len__() is 9 ('pack_into' = 'pack'=4 + '_into'=5 = 9; '_into' signals in-place buffer writing; 'pack_into'(9) > 'calcsize'(8) by 1)"]

# ---------------------------------------------------------------------------
# struct.unpack_from.__name__.__len__()==11
# struct.iter_unpack.__name__.__len__()==11
# struct.pack.__name__.__len__()==4 (confirmed)
# struct.calcsize.__name__.__len__()==8 (confirmed)
#
# Wave 350 theme: the two longest module-level struct function names are both 11 chars.
#
# unpack_from.__name__.__len__() == 11 ('unpack_from' = 'unpack'=6 + '_from'=5).
# iter_unpack.__name__.__len__() == 11 ('iter_unpack' = 'iter_'=5 + 'unpack'=6).
# Both tied at 11 chars as the longest module-level struct function names.
# struct_extra162 anchors unpack_from.__name__.__len__()==11 as a table row under structfn162;
# this spec also anchors iter_unpack.__name__.__len__()==11. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra164.fn_name_lengths_tied_longest:
  description: "struct.unpack_from.__name__.__len__()==11 / iter_unpack.__name__.__len__()==11 / pack.__name__.__len__()==4 / calcsize.__name__.__len__()==8 — unpack_from.__name__.__len__() is 11 ('unpack_from' = 'unpack'=6 + '_from'=5 = 11 chars; the '_from' suffix mirrors '_into' from 'pack_into': pack_into writes into a buffer (9 chars), unpack_from reads from a buffer (11 chars); 'unpack_from'(11) > 'pack_into'(9) by 2 because 'unpack'(6) > 'pack'(4) by 2 and '_from'(5)=='_into'(5); struct_extra162 anchors unpack_from.__name__.__len__()==11 as table row; confirmed here under structlen164); iter_unpack.__name__.__len__() is 11 ('iter_unpack' = 'iter_'=5 + 'unpack'=6 = 11 chars; the 'iter_' prefix signals iterator-based output; 'iter_unpack'(11) == 'unpack_from'(11) — tied as longest module-level function names; both names are 11-char compounds: 'iter_'=5+'unpack'=6 vs 'unpack'=6+'_from'=5; symmetric: prefix 5 + root 6 vs root 6 + suffix 5; struct_extra162 does not anchor iter_unpack.__name__.__len__() as a standalone — this spec provides the first anchor); pack.__name__.__len__() is 4 (confirmed; 'pack' = 4 chars; shortest name; 'pack'(4) << 'unpack_from'/'iter_unpack'(11) by 7 chars); calcsize.__name__.__len__() is 8 (confirmed; 'calcsize' = 8 chars; 4 < 6 < 8 < 9 < 11: the complete length ordering; first structlen164 anchor for the 11-char tie between unpack_from and iter_unpack)"
  kind: python_call_eq
  category: identity
  id_prefix: structlen164

  columns: [id, function, args, expected, description]
  rows:
    - [unpack_from_name_len_11,  "unpack_from.__name__.__len__",  [], 11, "struct.unpack_from.__name__.__len__() is 11 ('unpack_from' = 'unpack'=6 + '_from'=5 = 11; struct_extra162 anchors; tied longest with iter_unpack=11)"]
    - [iter_unpack_name_len_11,  "iter_unpack.__name__.__len__",  [], 11, "struct.iter_unpack.__name__.__len__() is 11 ('iter_unpack' = 'iter_'=5 + 'unpack'=6 = 11; tied longest with unpack_from=11; symmetric: 5+6 vs 6+5)"]
    - [pack_name_len_4_b,        "pack.__name__.__len__",         [], 4,  "struct.pack.__name__.__len__() is 4 (confirmed; shortest name; 'pack'(4) << longest names(11) by 7)"]
    - [calcsize_name_len_8_b,    "calcsize.__name__.__len__",     [], 8,  "struct.calcsize.__name__.__len__() is 8 (confirmed; 8 is unique: no other name has this length; 4<6<8<9<11)"]

# ---------------------------------------------------------------------------
# All six name lengths in ascending order
#
# Wave 350 theme: complete name length ordering for all six module-level struct functions.
#
# pack(4) < unpack(6) < calcsize(8) < pack_into(9) < unpack_from(11) == iter_unpack(11).
# pack.__name__.__len__() == 4 (shortest).
# unpack.__name__.__len__() == 6.
# pack_into.__name__.__len__() == 9.
# unpack_from.__name__.__len__() == 11 (tied longest).
# No prior struct spec anchors this complete length ordering as a single table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra164.fn_name_lengths_complete_ordering:
  description: "struct.pack.__name__.__len__()==4 / unpack.__name__.__len__()==6 / pack_into.__name__.__len__()==9 / unpack_from.__name__.__len__()==11 — pack.__name__.__len__() is 4 (confirmed; 'pack'=4; shortest of all six module-level function names; length ordering: 'pack'(4) < 'unpack'(6) < 'calcsize'(8) < 'pack_into'(9) < 'unpack_from'(11) == 'iter_unpack'(11); the lengths form a strict ascending sequence except for the 11-11 tie at the top); unpack.__name__.__len__() is 6 (confirmed; 'unpack'=6; second-shortest; 'unpack'(6) = 'pack'(4) + 2 — the 'un' reversal prefix adds 2 chars; 6 > 4 by 2); pack_into.__name__.__len__() is 9 (confirmed; 'pack_into'=9; fourth in the ordering; 9 > 8 (calcsize) by 1; 9 < 11 (unpack_from/iter_unpack) by 2; 9 = 4 + 5 = 'pack'(4) + '_into'(5)); unpack_from.__name__.__len__() is 11 (confirmed; 'unpack_from'=11; tied longest with iter_unpack=11; 11 > 9 (pack_into) by 2; the gap from pack(4) to unpack_from(11) is 7 chars; struct_extra162 anchors unpack_from.__name__.__len__()==11 as table row; full length set: {4, 6, 8, 9, 11} where 11 is counted twice; first structlen164 anchor for complete ordering across pack/unpack/pack_into/unpack_from in one table)"
  kind: python_call_eq
  category: identity
  id_prefix: structlen164

  columns: [id, function, args, expected, description]
  rows:
    - [pack_len_4_c,          "pack.__name__.__len__",         [], 4,  "struct.pack.__name__.__len__() is 4 (confirmed; 'pack'=4; shortest; length ordering: 4 < 6 < 8 < 9 < 11)"]
    - [unpack_len_6_c,        "unpack.__name__.__len__",       [], 6,  "struct.unpack.__name__.__len__() is 6 (confirmed; 'unpack'=6; 'un' prefix +2; 6 > 4 by 2)"]
    - [pack_into_len_9_c,     "pack_into.__name__.__len__",    [], 9,  "struct.pack_into.__name__.__len__() is 9 (confirmed; 'pack_into'=9; 'pack'(4)+'_into'(5)=9; between calcsize(8) and unpack_from(11))"]
    - [unpack_from_len_11_c,  "unpack_from.__name__.__len__",  [], 11, "struct.unpack_from.__name__.__len__() is 11 (confirmed; 'unpack_from'=11; tied longest with iter_unpack=11; struct_extra162 anchors)"]

# ---------------------------------------------------------------------------
# Function module lengths (all six share _struct, 7 chars)
#
# Wave 350 theme: all six module-level functions share __module__=='_struct'(7 chars).
#
# pack.__module__.__len__() == 7 ('_struct' = 7 chars; confirmed).
# unpack.__module__.__len__() == 7 (same module as pack).
# iter_unpack.__module__.__len__() == 7 (same module).
# calcsize.__module__.__len__() == 7 (same module).
# struct_extra162 anchors pack.__module__.__len__()==7 as a table row in struct_extra163;
# this spec provides a combined module-length table. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra164.fn_module_lengths_all_seven:
  description: "struct.pack.__module__.__len__()==7 / unpack.__module__.__len__()==7 / iter_unpack.__module__.__len__()==7 / calcsize.__module__.__len__()==7 — pack.__module__.__len__() is 7 ('_struct' = '_'=1 + 'struct'=6 = 7 chars; all six module-level struct functions share __module__=='_struct'(7 chars); 7 < 9 (pack_into name len) < 11 (unpack_from/iter_unpack name len); the module name length 7 is between pack_into(9) and calcsize(8) in name lengths — no, 7 < 8 < 9 < 11; struct_extra163 anchors pack.__module__.__len__()==7 as a table row); unpack.__module__.__len__() is 7 ('_struct' = 7 chars; same C extension module as pack; struct_extra162 anchors unpack.__module__=='_struct' as a table row; __len__()==7 is confirmed here); iter_unpack.__module__.__len__() is 7 ('_struct' = 7 chars; iter_unpack is from the same C extension as all other module-level functions; 'iter_unpack'(11) > '_struct'(7) by 4: the function's name is longer than its module name); calcsize.__module__.__len__() is 7 ('_struct' = 7 chars; calcsize shares the same C extension module; '_struct'(7) < 'calcsize'(8) by 1: the module name is 1 char shorter than calcsize's own name; all six functions: pack/unpack/pack_into/unpack_from/iter_unpack/calcsize all have __module__.__len__()==7; first structlen164 anchor for combined module lengths)"
  kind: python_call_eq
  category: identity
  id_prefix: structlen164

  columns: [id, function, args, expected, description]
  rows:
    - [pack_module_len_7,         "pack.__module__.__len__",         [], 7, "struct.pack.__module__.__len__() is 7 ('_struct' = '_'=1 + 'struct'=6 = 7; struct_extra163 anchors; all six functions share this)"]
    - [unpack_module_len_7,       "unpack.__module__.__len__",       [], 7, "struct.unpack.__module__.__len__() is 7 ('_struct' = 7 chars; same C extension as pack; struct_extra162 anchors __module__=='_struct')"]
    - [iter_unpack_module_len_7,  "iter_unpack.__module__.__len__",  [], 7, "struct.iter_unpack.__module__.__len__() is 7 ('_struct' = 7 chars; 'iter_unpack'(11) > '_struct'(7) by 4: name longer than module)"]
    - [calcsize_module_len_7,     "calcsize.__module__.__len__",     [], 7, "struct.calcsize.__module__.__len__() is 7 ('_struct' = 7 chars; '_struct'(7) < 'calcsize'(8) by 1: module 1 char shorter than function name)"]

# ---------------------------------------------------------------------------
# struct.pack.__name__.__len__()==4 — standalone
#
# struct.pack.__name__.__len__() is 4. 'pack' is the shortest module-level struct function
# name (4 chars). struct_extra162 anchors pack.__name__.__len__()==4 as a table row under
# structfn162; this spec provides a dedicated standalone under structlen164.
# The length ordering begins with pack(4): 4 < 6 < 8 < 9 < 11 = 11.
# 'pack'(4) is a 4-letter word that is also the root of 'unpack'(6), 'pack_into'(9).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra164.pack_name_len_4:
  description: "struct.pack.__name__.__len__() == 4 — 'pack' = 4 chars (shortest module-level struct function name; root word used in: 'pack'(4), 'unpack'(6), 'pack_into'(9), 'unpack_from'(11); struct_extra162 anchors this as table row under structfn162; complete length ordering: 'pack'(4) < 'unpack'(6) < 'calcsize'(8) < 'pack_into'(9) < 'unpack_from'/'iter_unpack'(11); the set of lengths is {4, 6, 8, 9, 11} with 11 repeated; first structlen164 standalone for pack.__name__.__len__()==4"
  category: identity
  kind: python_call_eq
  function: pack.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# struct.unpack.__name__.__len__()==6 — standalone
#
# struct.unpack.__name__.__len__() is 6. 'unpack' (6 chars) = 'un'=2 + 'pack'=4.
# The 'un' prefix reversal adds 2 chars to 'pack'(4), making unpack(6) = pack(4) + 2.
# 'unpack'(6) is the second-shortest module-level struct function name.
# struct_extra162 anchors unpack.__name__=='unpack' as a table row; this spec anchors
# the length value 6. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra164.unpack_name_len_6:
  description: "struct.unpack.__name__.__len__() == 6 — 'unpack' = 6 chars = 'un'=2 + 'pack'=4 (second-shortest name; 'un' prefix adds 2 chars to 'pack'(4); 'unpack'(6) > 'pack'(4) by 2; 'unpack'(6) is also the root of 'unpack_from'(11) and 'iter_unpack'(11) — both 11-char names contain 'unpack'(6); struct_extra162 anchors unpack.__name__=='unpack' as table row; first structlen164 standalone for unpack.__name__.__len__()==6"
  category: identity
  kind: python_call_eq
  function: unpack.__name__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# struct.calcsize.__name__.__len__()==8 — standalone
#
# struct.calcsize.__name__.__len__() is 8. 'calcsize' (8 chars) = 'calc'=4 + 'size'=4.
# calcsize is the only module-level struct function whose name does not contain 'pack' or
# 'unpack' — it is purely a size-computation function. Its 8-char name sits uniquely at
# position 3 in the length ordering (4 < 6 < 8 < 9 < 11 = 11). No other function name
# has length 8. struct_extra162 anchors calcsize.__name__=='calcsize' as a table row.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra164.calcsize_name_len_8:
  description: "struct.calcsize.__name__.__len__() == 8 — 'calcsize' = 8 chars = 'calc'=4 + 'size'=4 (the only module-level struct function whose name contains neither 'pack' nor 'unpack'; purely a size-computation function; 8 is the only non-repeated length in the set {4, 6, 8, 9, 11, 11} — no other function name is 8 chars; 'calcsize'(8) = 2 * 'pack'(4) in char count; struct_extra162 anchors calcsize.__name__=='calcsize' as table row; first structlen164 standalone for calcsize.__name__.__len__()==8"
  category: identity
  kind: python_call_eq
  function: calcsize.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# struct.pack_into.__name__.__len__()==9 — standalone
#
# struct.pack_into.__name__.__len__() is 9. 'pack_into' (9 chars) = 'pack'=4 + '_into'=5.
# 'pack_into' is the fourth-longest name (4 < 6 < 8 < 9 < 11). The '_into' suffix signals
# in-place writing into a buffer (as opposed to returning a new bytes object like pack()).
# struct_extra162 anchors pack_into.__name__=='pack_into' as a table row.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra164.pack_into_name_len_9:
  description: "struct.pack_into.__name__.__len__() == 9 — 'pack_into' = 9 chars = 'pack'=4 + '_into'=5 ('_into' signals in-place writing into existing buffer; pack() returns new bytes, pack_into() writes into buffer at offset; 9 > 8 (calcsize) by 1; 9 < 11 (unpack_from/iter_unpack) by 2; 'pack_into'(9) has '_into' suffix mirrored by 'unpack_from' having '_from' suffix; struct_extra162 anchors pack_into.__name__=='pack_into' as table row; first structlen164 standalone for pack_into.__name__.__len__()==9"
  category: identity
  kind: python_call_eq
  function: pack_into.__name__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# struct.unpack_from.__name__.__len__()==11 — standalone
#
# struct.unpack_from.__name__.__len__() is 11. 'unpack_from' (11 chars) = 'unpack'=6 +
# '_from'=5. Tied with 'iter_unpack'(11) as the longest module-level struct function name.
# struct_extra162 anchors unpack_from.__name__.__len__()==11 as a table row under structfn162;
# this spec provides a dedicated standalone under structlen164.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra164.unpack_from_name_len_11:
  description: "struct.unpack_from.__name__.__len__() == 11 — 'unpack_from' = 11 chars = 'unpack'=6 + '_from'=5 (tied longest with 'iter_unpack'=11; '_from' suffix mirrors '_into' from 'pack_into': pack_into(9 chars) writes into buffer, unpack_from(11 chars) reads from buffer; 'unpack_from'(11) > 'pack_into'(9) by 2 because 'unpack'(6) > 'pack'(4) by 2 and '_from'(5)=='_into'(5); struct_extra162 anchors unpack_from.__name__.__len__()==11 as table row; first structlen164 standalone for unpack_from.__name__.__len__()==11"
  category: identity
  kind: python_call_eq
  function: unpack_from.__name__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# struct.iter_unpack.__name__.__len__()==11 — standalone
#
# struct.iter_unpack.__name__.__len__() is 11. 'iter_unpack' (11 chars) = 'iter_'=5 +
# 'unpack'=6. Tied with 'unpack_from'(11) as the longest module-level struct function name.
# The 'iter_' prefix signals iterator-based output. The symmetric structure:
# 'iter_unpack' = prefix(5) + root(6) vs 'unpack_from' = root(6) + suffix(5).
# struct_extra162 does not anchor iter_unpack.__name__.__len__() as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra164.iter_unpack_name_len_11:
  description: "struct.iter_unpack.__name__.__len__() == 11 — 'iter_unpack' = 11 chars = 'iter_'=5 + 'unpack'=6 (tied longest with 'unpack_from'=11; symmetric construction: 'iter_unpack' = prefix(5)+'unpack'(6) vs 'unpack_from' = 'unpack'(6)+suffix(5); both 11-char names contain 'unpack'(6) as a component; 'iter_' signals iterator output, returning tuples lazily from a buffer; added in Python 3.4; struct_extra162 anchors iter_unpack.__name__=='iter_unpack' as table row but not __len__()==11 as standalone; first structlen164 standalone for iter_unpack.__name__.__len__()==11"
  category: identity
  kind: python_call_eq
  function: iter_unpack.__name__.__len__
  args: []
  expected: 11
