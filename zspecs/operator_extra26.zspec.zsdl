spec: operator_extra26
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator_extra25.zspec.zsdl."
    - "operator_extra25 covers: bitwise operator qualnames (and_/or_/xor/invert/lshift/rshift); length_hint qualname."
    - "operator_extra24 covers: attrgetter/itemgetter/methodcaller __call__ slot qualnames; not_/truth/is_/is_not/contains qualnames."
    - "operator_extra23 covers: arithmetic function qualnames (add/sub/mul/truediv/floordiv/mod); attrgetter/itemgetter/methodcaller class qualnames."
    - "operator_extra21 covers: attrgetter/itemgetter/methodcaller __bases__[0].__name__ and __module__ as standalone invariants."
    - "No prior operator spec records __module__ for attrgetter/itemgetter/methodcaller, or __bases__[0].__name__ together in a table, in the extra26 namespace."
    - "No prior operator spec records qualnames for sequence/item functions (concat/getitem/setitem/delitem) or unary functions (neg/pos/abs/pow) together in the extra26 namespace."
    - "Focus: __module__ for the three callable classes; __bases__[0].__name__ for callable classes; sequence and unary operator function qualnames."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "Note: attrgetter/itemgetter/methodcaller __module__ == 'operator' (public name); sequence/unary functions __module__ == '_operator' (C extension)."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__eq__ table — callable class module membership
#
# operator.attrgetter, itemgetter, and methodcaller are C-level types exposed
# via the public 'operator' module. Their __module__ is 'operator', the public
# module name. operator_extra21 records these as standalone invariants only;
# this table groups them in the extra26 namespace.
# No prior operator spec records all three callable class __module__ values
# together in a table in the extra26 namespace.
# ---------------------------------------------------------------------------

table operator_extra26.callable_class_modules:
  kind: python_call_eq
  category: module_membership
  columns: [id, function, args, expected, description]
  rows:
    - [operator_extra26.callable_class_modules.attrgetter,
       attrgetter.__module__.__eq__,
       ["operator"],
       true,
       "operator.attrgetter.__module__ == 'operator'"]
    - [operator_extra26.callable_class_modules.itemgetter,
       itemgetter.__module__.__eq__,
       ["operator"],
       true,
       "operator.itemgetter.__module__ == 'operator'"]
    - [operator_extra26.callable_class_modules.methodcaller,
       methodcaller.__module__.__eq__,
       ["operator"],
       true,
       "operator.methodcaller.__module__ == 'operator'"]

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__eq__ table — base classes for callable types
#
# attrgetter, itemgetter, and methodcaller are C-level extension types that
# inherit directly from object. Their __bases__[0].__name__ is 'object'.
# operator_extra21 records these as standalone invariants; this table groups
# all three in the extra26 namespace.
# No prior operator spec records all three __bases__[0].__name__ values
# together in a table in the extra26 namespace.
# ---------------------------------------------------------------------------

table operator_extra26.callable_class_bases:
  kind: python_call_eq
  category: inheritance
  columns: [id, function, args, expected, description]
  rows:
    - [operator_extra26.callable_class_bases.attrgetter,
       "attrgetter.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "operator.attrgetter.__bases__[0].__name__ == 'object'"]
    - [operator_extra26.callable_class_bases.itemgetter,
       "itemgetter.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "operator.itemgetter.__bases__[0].__name__ == 'object'"]
    - [operator_extra26.callable_class_bases.methodcaller,
       "methodcaller.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "operator.methodcaller.__bases__[0].__name__ == 'object'"]

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — sequence/item operator function qualnames
#
# operator.concat, getitem, setitem, and delitem are C-level functions in
# _operator that operate on sequences and mappings. Each has a simple qualname
# equal to its attribute name. No prior operator spec records all four together
# in the extra26 namespace.
# ---------------------------------------------------------------------------

table operator_extra26.sequence_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [operator_extra26.sequence_qualnames.concat,
       concat.__qualname__.__eq__,
       ["concat"],
       true,
       "operator.concat.__qualname__ == 'concat'"]
    - [operator_extra26.sequence_qualnames.getitem,
       getitem.__qualname__.__eq__,
       ["getitem"],
       true,
       "operator.getitem.__qualname__ == 'getitem'"]
    - [operator_extra26.sequence_qualnames.setitem,
       setitem.__qualname__.__eq__,
       ["setitem"],
       true,
       "operator.setitem.__qualname__ == 'setitem'"]
    - [operator_extra26.sequence_qualnames.delitem,
       delitem.__qualname__.__eq__,
       ["delitem"],
       true,
       "operator.delitem.__qualname__ == 'delitem'"]

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — unary operator function qualnames
#
# operator.neg, pos, abs, and pow are C-level functions in _operator that
# implement unary and power arithmetic operations. Their qualnames are simple
# names equal to their attribute names.
# No prior operator spec records all four unary/power function qualnames
# together in the extra26 namespace.
# ---------------------------------------------------------------------------

table operator_extra26.unary_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [operator_extra26.unary_qualnames.neg,
       neg.__qualname__.__eq__,
       ["neg"],
       true,
       "operator.neg.__qualname__ == 'neg'"]
    - [operator_extra26.unary_qualnames.pos,
       pos.__qualname__.__eq__,
       ["pos"],
       true,
       "operator.pos.__qualname__ == 'pos'"]
    - [operator_extra26.unary_qualnames.abs,
       abs.__qualname__.__eq__,
       ["abs"],
       true,
       "operator.abs.__qualname__ == 'abs'"]
    - [operator_extra26.unary_qualnames.pow,
       pow.__qualname__.__eq__,
       ["pow"],
       true,
       "operator.pow.__qualname__ == 'pow'"]

# ---------------------------------------------------------------------------
# attrgetter.__module__.__eq__ — standalone module membership
#
# operator.attrgetter is a C-level type attributed to the public 'operator'
# module. Its __module__ is 'operator', distinguishing it from the _operator
# C extension functions which have __module__ == '_operator'.
# No prior operator spec records this standalone in the extra26 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra26.attrgetter.module:
  description: "operator.attrgetter.__module__ == 'operator'"
  category: module_membership
  kind: python_call_eq
  function: attrgetter.__module__.__eq__
  args: ["operator"]
  expected: true

# ---------------------------------------------------------------------------
# concat.__qualname__.__eq__ — standalone sequence function qualname
#
# operator.concat is a C-level function in _operator that concatenates two
# sequences. Its qualname is 'concat', a simple name with no enclosing scope.
# No prior operator spec records this standalone in the extra26 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra26.concat.qualname:
  description: "operator.concat.__qualname__ == 'concat'"
  category: qualnames
  kind: python_call_eq
  function: concat.__qualname__.__eq__
  args: ["concat"]
  expected: true

# ---------------------------------------------------------------------------
# neg.__qualname__.__eq__ — standalone unary function qualname
#
# operator.neg is a C-level function that returns the arithmetic negation of
# its argument. Its qualname is 'neg', confirming module-level definition.
# No prior operator spec records this standalone in the extra26 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra26.neg.qualname:
  description: "operator.neg.__qualname__ == 'neg'"
  category: qualnames
  kind: python_call_eq
  function: neg.__qualname__.__eq__
  args: ["neg"]
  expected: true
