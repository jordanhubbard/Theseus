spec: pathlib_extra259
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "This spec covers pathlib.Path property descriptor identity for the ten path component properties."
    - "All ten pathlib.Path properties (name, suffix, stem, parent, parents, parts, suffixes, drive, root, anchor) are Python 'property' objects, not getset_descriptor or member_descriptor."
    - "type(pathlib.Path.name).__name__ == 'property' for all ten properties — they are defined using @property in pure Python."
    - "pathlib.Path.name.__class__.__name__ == 'property' — the same result whether accessed via type() or .__class__."
    - "pathlib.Path.name.fget.__name__ == 'name' — the underlying getter function is named the same as the property."
    - "These properties are inherited from pathlib.PurePath (the abstract base); Path.name etc. resolve via MRO."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib.Path property descriptor __class__.__name__ identity
#
# name, suffix, stem, parent, parents, parts, suffixes, drive, root, anchor
# are all Python 'property' objects defined with @property in pure Python.
# Their __class__.__name__ is 'property', not 'getset_descriptor'.
# ---------------------------------------------------------------------------

table pathlib_extra259.path_property_class_names:
  description: "pathlib.Path property descriptor __class__.__name__ — all ten path components are 'property'; new to extra259"
  kind: python_call_eq
  category: identity
  id_prefix: plxppcn259

  columns: [id, function, args, expected, description]
  rows:
    - [name_class,
       "Path.name.__class__.__name__.__eq__",
       ["property"],
       true,
       "pathlib.Path.name.__class__.__name__.__eq__('property') == True — Path.name is a Python @property descriptor returning the final path component; its __class__.__name__ is 'property', not 'getset_descriptor'; str.__eq__('property') returns True; new to extra259"]
    - [suffix_class,
       "Path.suffix.__class__.__name__.__eq__",
       ["property"],
       true,
       "pathlib.Path.suffix.__class__.__name__.__eq__('property') == True — Path.suffix is a Python @property descriptor returning the file extension including the dot; its __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra259"]
    - [stem_class,
       "Path.stem.__class__.__name__.__eq__",
       ["property"],
       true,
       "pathlib.Path.stem.__class__.__name__.__eq__('property') == True — Path.stem is a Python @property descriptor returning the final component without suffix; its __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra259"]
    - [parent_class,
       "Path.parent.__class__.__name__.__eq__",
       ["property"],
       true,
       "pathlib.Path.parent.__class__.__name__.__eq__('property') == True — Path.parent is a Python @property descriptor returning the logical parent of the path; its __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra259"]
    - [parents_class,
       "Path.parents.__class__.__name__.__eq__",
       ["property"],
       true,
       "pathlib.Path.parents.__class__.__name__.__eq__('property') == True — Path.parents is a Python @property descriptor returning the immutable sequence of logical ancestors; its __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra259"]
    - [parts_class,
       "Path.parts.__class__.__name__.__eq__",
       ["property"],
       true,
       "pathlib.Path.parts.__class__.__name__.__eq__('property') == True — Path.parts is a Python @property descriptor returning a tuple of the path components; its __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra259"]
    - [suffixes_class,
       "Path.suffixes.__class__.__name__.__eq__",
       ["property"],
       true,
       "pathlib.Path.suffixes.__class__.__name__.__eq__('property') == True — Path.suffixes is a Python @property descriptor returning a list of all file extensions; its __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra259"]
    - [drive_class,
       "Path.drive.__class__.__name__.__eq__",
       ["property"],
       true,
       "pathlib.Path.drive.__class__.__name__.__eq__('property') == True — Path.drive is a Python @property descriptor returning the drive letter or name (empty string on POSIX); its __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra259"]
    - [root_class,
       "Path.root.__class__.__name__.__eq__",
       ["property"],
       true,
       "pathlib.Path.root.__class__.__name__.__eq__('property') == True — Path.root is a Python @property descriptor returning the root component (e.g., '/' on POSIX); its __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra259"]
    - [anchor_class,
       "Path.anchor.__class__.__name__.__eq__",
       ["property"],
       true,
       "pathlib.Path.anchor.__class__.__name__.__eq__('property') == True — Path.anchor is a Python @property descriptor returning the concatenation of drive and root; its __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra259"]

# ---------------------------------------------------------------------------
# Table 2: pathlib.Path property fget.__name__ identity
#
# For each @property, the underlying getter function is named identically
# to the property itself. Path.name.fget.__name__ == 'name', etc.
# ---------------------------------------------------------------------------

table pathlib_extra259.path_property_fget_names:
  description: "pathlib.Path property fget.__name__ identity — getter name matches property name for all ten properties; new to extra259"
  kind: python_call_eq
  category: identity
  id_prefix: plxppfn259

  columns: [id, function, args, expected, description]
  rows:
    - [name_fget,
       "Path.name.fget.__name__.__eq__",
       ["name"],
       true,
       "pathlib.Path.name.fget.__name__.__eq__('name') == True — the getter function underlying the name property is named 'name'; str.__eq__('name') returns True; new to extra259"]
    - [suffix_fget,
       "Path.suffix.fget.__name__.__eq__",
       ["suffix"],
       true,
       "pathlib.Path.suffix.fget.__name__.__eq__('suffix') == True — the getter function underlying the suffix property is named 'suffix'; str.__eq__('suffix') returns True; new to extra259"]
    - [stem_fget,
       "Path.stem.fget.__name__.__eq__",
       ["stem"],
       true,
       "pathlib.Path.stem.fget.__name__.__eq__('stem') == True — the getter function underlying the stem property is named 'stem'; str.__eq__('stem') returns True; new to extra259"]
    - [parent_fget,
       "Path.parent.fget.__name__.__eq__",
       ["parent"],
       true,
       "pathlib.Path.parent.fget.__name__.__eq__('parent') == True — the getter function underlying the parent property is named 'parent'; str.__eq__('parent') returns True; new to extra259"]
    - [parents_fget,
       "Path.parents.fget.__name__.__eq__",
       ["parents"],
       true,
       "pathlib.Path.parents.fget.__name__.__eq__('parents') == True — the getter function underlying the parents property is named 'parents'; str.__eq__('parents') returns True; new to extra259"]
    - [parts_fget,
       "Path.parts.fget.__name__.__eq__",
       ["parts"],
       true,
       "pathlib.Path.parts.fget.__name__.__eq__('parts') == True — the getter function underlying the parts property is named 'parts'; str.__eq__('parts') returns True; new to extra259"]
    - [suffixes_fget,
       "Path.suffixes.fget.__name__.__eq__",
       ["suffixes"],
       true,
       "pathlib.Path.suffixes.fget.__name__.__eq__('suffixes') == True — the getter function underlying the suffixes property is named 'suffixes'; str.__eq__('suffixes') returns True; new to extra259"]
    - [drive_fget,
       "Path.drive.fget.__name__.__eq__",
       ["drive"],
       true,
       "pathlib.Path.drive.fget.__name__.__eq__('drive') == True — the getter function underlying the drive property is named 'drive'; str.__eq__('drive') returns True; new to extra259"]
    - [root_fget,
       "Path.root.fget.__name__.__eq__",
       ["root"],
       true,
       "pathlib.Path.root.fget.__name__.__eq__('root') == True — the getter function underlying the root property is named 'root'; str.__eq__('root') returns True; new to extra259"]
    - [anchor_fget,
       "Path.anchor.fget.__name__.__eq__",
       ["anchor"],
       true,
       "pathlib.Path.anchor.fget.__name__.__eq__('anchor') == True — the getter function underlying the anchor property is named 'anchor'; str.__eq__('anchor') returns True; new to extra259"]

# ---------------------------------------------------------------------------
# Standalone invariants — pathlib_extra259
# ---------------------------------------------------------------------------

invariant pathlib_extra259.path_name_is_property:
  description: "pathlib.Path.name.__class__.__name__ == 'property' — Path.name is a Python @property, not a C-level getset_descriptor; new to extra259"
  kind: python_call_eq
  function: Path.name.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant pathlib_extra259.path_suffix_is_property:
  description: "pathlib.Path.suffix.__class__.__name__ == 'property' — Path.suffix returns the file extension including the leading dot; new to extra259"
  kind: python_call_eq
  function: Path.suffix.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant pathlib_extra259.path_stem_is_property:
  description: "pathlib.Path.stem.__class__.__name__ == 'property' — Path.stem is the final path component without its suffix; new to extra259"
  kind: python_call_eq
  function: Path.stem.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant pathlib_extra259.path_parent_is_property:
  description: "pathlib.Path.parent.__class__.__name__ == 'property' — Path.parent is the logical parent of the path; new to extra259"
  kind: python_call_eq
  function: Path.parent.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant pathlib_extra259.path_parts_is_property:
  description: "pathlib.Path.parts.__class__.__name__ == 'property' — Path.parts returns a tuple of the path's components; new to extra259"
  kind: python_call_eq
  function: Path.parts.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant pathlib_extra259.path_drive_is_property:
  description: "pathlib.Path.drive.__class__.__name__ == 'property' — Path.drive returns the drive letter or name (empty string on POSIX); new to extra259"
  kind: python_call_eq
  function: Path.drive.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant pathlib_extra259.path_anchor_is_property:
  description: "pathlib.Path.anchor.__class__.__name__ == 'property' — Path.anchor is the concatenation of drive and root; new to extra259"
  kind: python_call_eq
  function: Path.anchor.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant pathlib_extra259.path_name_fget_name:
  description: "pathlib.Path.name.fget.__name__ == 'name' — the getter for the name property is a Python function named 'name'; new to extra259"
  kind: python_call_eq
  function: Path.name.fget.__name__.__eq__
  args: ["name"]
  expected: true

invariant pathlib_extra259.path_suffix_fget_name:
  description: "pathlib.Path.suffix.fget.__name__ == 'suffix' — the getter for the suffix property is named 'suffix'; new to extra259"
  kind: python_call_eq
  function: Path.suffix.fget.__name__.__eq__
  args: ["suffix"]
  expected: true

invariant pathlib_extra259.path_parents_is_property:
  description: "pathlib.Path.parents.__class__.__name__ == 'property' — Path.parents returns the immutable sequence of logical ancestors; new to extra259"
  kind: python_call_eq
  function: Path.parents.__class__.__name__.__eq__
  args: ["property"]
  expected: true
