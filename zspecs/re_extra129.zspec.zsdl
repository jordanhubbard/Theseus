spec: re_extra129
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.Pattern and re.Match method __qualname__ and __name__ values."
    - "re.Pattern methods are C extension method_descriptor objects; they have __qualname__ and __name__ but no __code__."
    - "re.Pattern.match.__qualname__ = 'Pattern.match' (length 13)."
    - "re.Pattern.search.__qualname__ = 'Pattern.search' (length 14)."
    - "re.Pattern.sub.__qualname__ = 'Pattern.sub' (length 11)."
    - "re.Pattern.subn.__qualname__ = 'Pattern.subn' (length 12)."
    - "re.Pattern.findall.__qualname__ = 'Pattern.findall' (length 15)."
    - "re.Pattern.finditer.__qualname__ = 'Pattern.finditer' (length 16)."
    - "re.Pattern.split.__qualname__ = 'Pattern.split' (length 13)."
    - "re.Pattern.fullmatch.__qualname__ = 'Pattern.fullmatch' (length 17)."
    - "re.Match.group.__qualname__ = 'Match.group' (length 11)."
    - "re.Match.span.__qualname__ = 'Match.span' (length 10)."
    - "re.Match.start.__qualname__ = 'Match.start' (length 11)."
    - "re.Match.end.__qualname__ = 'Match.end' (length 9)."
    - "re.Match.expand.__qualname__ = 'Match.expand' (length 12)."
    - "re.Match.groupdict.__qualname__ = 'Match.groupdict' (length 15)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern method __qualname__ lengths
# match=13, search=14, sub=11, subn=12.
# findall=15, finditer=16, split=13, fullmatch=17.
# ---------------------------------------------------------------------------

table re_extra129.Pattern_method_qualname_lengths:
  description: "re.Pattern method __qualname__.__len__(): match=13, search=14, sub=11, subn=12, findall=15, finditer=16, split=13, fullmatch=17"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: repatternqualname129

  columns: [id, function, args, expected]
  rows:
    - [pat_match_qlen,     Pattern.match.__qualname__.__len__,     [], 13]
    - [pat_search_qlen,    Pattern.search.__qualname__.__len__,    [], 14]
    - [pat_sub_qlen,       Pattern.sub.__qualname__.__len__,       [], 11]
    - [pat_subn_qlen,      Pattern.subn.__qualname__.__len__,      [], 12]
    - [pat_findall_qlen,   Pattern.findall.__qualname__.__len__,   [], 15]
    - [pat_finditer_qlen,  Pattern.finditer.__qualname__.__len__,  [], 16]
    - [pat_split_qlen,     Pattern.split.__qualname__.__len__,     [], 13]
    - [pat_fullmatch_qlen, Pattern.fullmatch.__qualname__.__len__, [], 17]
    - [pat_match_not_5,    Pattern.match.__qualname__.__len__,     [], 13]

# ---------------------------------------------------------------------------
# re.Pattern method __qualname__ string equality
# Pattern.match.__qualname__ == 'Pattern.match'
# Pattern.search.__qualname__ == 'Pattern.search'
# Pattern.findall.__qualname__ == 'Pattern.findall'
# Pattern.fullmatch.__qualname__ == 'Pattern.fullmatch'
# ---------------------------------------------------------------------------

table re_extra129.Pattern_method_qualname_strings:
  description: "re.Pattern method __qualname__ string equality: match='Pattern.match', search='Pattern.search', findall='Pattern.findall', fullmatch='Pattern.fullmatch'"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: repatternqualname129

  columns: [id, function, args, expected]
  rows:
    - [pat_match_qeq,     Pattern.match.__qualname__.__eq__,     ["Pattern.match"],     true]
    - [pat_search_qeq,    Pattern.search.__qualname__.__eq__,    ["Pattern.search"],    true]
    - [pat_sub_qeq,       Pattern.sub.__qualname__.__eq__,       ["Pattern.sub"],       true]
    - [pat_subn_qeq,      Pattern.subn.__qualname__.__eq__,      ["Pattern.subn"],      true]
    - [pat_findall_qeq,   Pattern.findall.__qualname__.__eq__,   ["Pattern.findall"],   true]
    - [pat_finditer_qeq,  Pattern.finditer.__qualname__.__eq__,  ["Pattern.finditer"],  true]
    - [pat_split_qeq,     Pattern.split.__qualname__.__eq__,     ["Pattern.split"],     true]
    - [pat_fullmatch_qeq, Pattern.fullmatch.__qualname__.__eq__, ["Pattern.fullmatch"], true]
    - [pat_match_not_bare,Pattern.match.__qualname__.__eq__,     ["match"],             false]

# ---------------------------------------------------------------------------
# re.Match method __qualname__ values
# Match.group=11, Match.span=10, Match.start=11, Match.end=9,
# Match.expand=12, Match.groupdict=15.
# ---------------------------------------------------------------------------

table re_extra129.Match_method_qualname_values:
  description: "re.Match method __qualname__ string equality and lengths: group='Match.group'(11), span='Match.span'(10), start='Match.start'(11), end='Match.end'(9), expand='Match.expand'(12), groupdict='Match.groupdict'(15)"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: repatternqualname129

  columns: [id, function, args, expected]
  rows:
    - [mat_group_qeq,    Match.group.__qualname__.__eq__,     ["Match.group"],     true]
    - [mat_group_qlen,   Match.group.__qualname__.__len__,    [],                  11]
    - [mat_span_qeq,     Match.span.__qualname__.__eq__,      ["Match.span"],      true]
    - [mat_span_qlen,    Match.span.__qualname__.__len__,     [],                  10]
    - [mat_start_qeq,    Match.start.__qualname__.__eq__,     ["Match.start"],     true]
    - [mat_start_qlen,   Match.start.__qualname__.__len__,    [],                  11]
    - [mat_end_qeq,      Match.end.__qualname__.__eq__,       ["Match.end"],       true]
    - [mat_end_qlen,     Match.end.__qualname__.__len__,      [],                  9]
    - [mat_expand_qeq,   Match.expand.__qualname__.__eq__,    ["Match.expand"],    true]
    - [mat_expand_qlen,  Match.expand.__qualname__.__len__,   [],                  12]
    - [mat_groupdict_qeq,Match.groupdict.__qualname__.__eq__, ["Match.groupdict"], true]
    - [mat_groupdict_qlen,Match.groupdict.__qualname__.__len__,[],                 15]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra129.Pattern.match_qualname_is_Pattern_match:
  description: "re.Pattern.match.__qualname__ == 'Pattern.match' (C extension method_descriptor qualnames include the class name prefix separated by a dot)"
  category: method_qualnames
  kind: python_call_eq
  function: Pattern.match.__qualname__.__eq__
  args: ["Pattern.match"]
  expected: true

invariant re_extra129.Pattern.fullmatch_qualname_len_17:
  description: "re.Pattern.fullmatch.__qualname__.__len__() == 17 ('Pattern.fullmatch' has 17 characters)"
  category: method_qualnames
  kind: python_call_eq
  function: Pattern.fullmatch.__qualname__.__len__
  args: []
  expected: 17

invariant re_extra129.Pattern.finditer_qualname_len_16:
  description: "re.Pattern.finditer.__qualname__.__len__() == 16 ('Pattern.finditer' has 16 characters)"
  category: method_qualnames
  kind: python_call_eq
  function: Pattern.finditer.__qualname__.__len__
  args: []
  expected: 16

invariant re_extra129.Match.group_qualname_is_Match_group:
  description: "re.Match.group.__qualname__ == 'Match.group' (length 11; C extension method_descriptor qualnames include the class name prefix)"
  category: method_qualnames
  kind: python_call_eq
  function: Match.group.__qualname__.__eq__
  args: ["Match.group"]
  expected: true

invariant re_extra129.Match.end_qualname_len_9:
  description: "re.Match.end.__qualname__.__len__() == 9 ('Match.end' has 9 characters: M-a-t-c-h-.-e-n-d)"
  category: method_qualnames
  kind: python_call_eq
  function: Match.end.__qualname__.__len__
  args: []
  expected: 9
