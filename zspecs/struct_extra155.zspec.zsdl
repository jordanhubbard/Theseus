spec: struct_extra155
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra154.zspec.zsdl — covers struct.Struct method qualnames: Struct.pack/__qualname__.__eq__('Struct.pack') / Struct.unpack/__qualname__.__eq__('Struct.unpack') / Struct.pack_into/__qualname__.__eq__('Struct.pack_into') / Struct.pack.__class__.__name__.__eq__('method_descriptor') (table + invariants)."
    - "struct_extra153.zspec.zsdl — covers struct.Struct.__init__.__qualname__.__eq__('Struct.__init__') / Struct.__init__.__class__.__name__.__eq__('wrapper_descriptor') / Struct.__doc__.__len__()==40 / error.__doc__ NoneType (table + invariants)."
    - "struct_extra152.zspec.zsdl — covers struct.iter_unpack/__class__.__name__/__module__/__name__ / Struct.__name__.__len__()==6 / pack/__unpack/__calcsize/__pack_into __name__ and __name__ lengths (table + invariants)."
    - "struct_extra151.zspec.zsdl — covers struct.__all__.__class__.__name__.__eq__('list') / __all__.__contains__('pack'/'error') / __all__.__len__()==8 / error.__name__/__module__/__qualname__ / pack/__unpack/__calcsize qualnames (table + invariants)."
    - "struct_extra149.zspec.zsdl — covers struct.Struct.pack_into/__unpack_from/__iter_unpack qualnames / Struct.size/__format/__class__.__name__.__eq__('getset_descriptor') (table + invariants)."
    - "struct_extra148.zspec.zsdl — covers struct.Struct.__name__/__module__/__bases__[0].__name__ / Struct.pack/__qualname__ / Struct.unpack/__qualname__ / struct.error.__name__/__module__/__bases__[0].__name__ (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra154."
    - "Wave 341 theme: struct.Struct getset_descriptor attribute identity — Struct.size.__qualname__.__eq__('Struct.size') / Struct.format.__qualname__.__eq__('Struct.format') / Struct.size.__name__.__eq__('size') / Struct.format.__name__.__eq__('format') / Struct.size.__objclass__.__name__.__eq__('Struct') / Struct.format.__objclass__.__name__.__eq__('Struct'); extra149 anchors Struct.size/__format/__class__.__name__=='getset_descriptor' but NOT their qualname strings or objclass."
    - "struct.Struct.size.__qualname__ == 'Struct.size'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__qualname__ == 'Struct.format'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__name__ == 'size'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__name__ == 'format'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__objclass__.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__objclass__.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__qualname__.__len__() == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__qualname__.__len__() == 13. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.Struct.size.__qualname__ == 'Struct.size' (11 chars = 'Struct.'=7 + 'size'=4). Struct.size is a getset_descriptor (extra149 anchors the class name). The qualname follows the standard pattern 'ClassName.attribute_name'. getset_descriptor objects support the __qualname__ attribute (unlike some C-level descriptor types). 'Struct.size' (11 chars) ties 'Struct.pack' (also 11 chars; extra154). The 'size' attribute of a Struct instance returns the number of bytes required to hold the struct data (e.g., struct.Struct('>I').size == 4)."
    - "Note: struct.Struct.format.__qualname__ == 'Struct.format' (13 chars = 'Struct.'=7 + 'format'=6). The 'format' attribute returns the format string used to create the Struct (e.g., struct.Struct('>I').format == '>I'). 'Struct.format' (13 chars) ties 'Struct.unpack' (also 13 chars; extra154). getset_descriptor qualnames: Struct.size(11) < Struct.format(13)."
    - "Note: struct.Struct.size.__objclass__.__name__ == 'Struct' (6 chars). getset_descriptor objects have an __objclass__ attribute that refers to the class they belong to. Struct.size.__objclass__ is the Struct class itself (struct.Struct). __objclass__.__name__ == 'Struct' (6 chars). This confirms the descriptor is defined on the Struct class, not on a base class."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.size.__qualname__.__eq__('Struct.size')
# struct.Struct.format.__qualname__.__eq__('Struct.format')
# struct.Struct.size.__name__.__eq__('size')
# struct.Struct.format.__name__.__eq__('format')
#
# Wave 341 theme: Struct getset_descriptor qualname and __name__ strings.
#
# Struct.size.__qualname__ == 'Struct.size' (11 chars = 'Struct.'=7 + 'size'=4).
# Struct.format.__qualname__ == 'Struct.format' (13 chars = 'Struct.'=7 + 'format'=6).
# Struct.size.__name__ == 'size' (4 chars; the bare attribute name).
# Struct.format.__name__ == 'format' (6 chars; the bare attribute name).
# extra149 anchors Struct.size class name ('getset_descriptor') but NOT qualname/name strings.
# No prior struct spec anchors these getset_descriptor qualnames or names as a table
# under structgs155. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra155.Struct_getset_descriptor_qualnames_and_names:
  description: "struct.Struct.size.__qualname__.__eq__('Struct.size')==True / Struct.format.__qualname__.__eq__('Struct.format')==True / Struct.size.__name__.__eq__('size')==True / Struct.format.__name__.__eq__('format')==True — Struct.size.__qualname__ is 'Struct.size' (11 chars = 'Struct.'=7 + 'size'=4; ties 'Struct.pack' from extra154; size returns byte count for the struct format); Struct.format.__qualname__ is 'Struct.format' (13 chars = 'Struct.'=7 + 'format'=6; ties 'Struct.unpack' from extra154; format returns the format string used to create the Struct); Struct.size.__name__ is 'size' (4 chars; bare attribute name; getset_descriptor __name__ == the attribute name); Struct.format.__name__ is 'format' (6 chars; bare attribute name); extra149 anchors Struct.size/__class__.__name__=='getset_descriptor' but NOT qualname or __name__ strings; first structgs155 anchor for getset_descriptor qualnames and names"
  kind: python_call_eq
  category: identity
  id_prefix: structgs155

  columns: [id, function, args, expected, description]
  rows:
    - [size_qualname_Struct_size,     "Struct.size.__qualname__.__eq__",     ["Struct.size"],   true, "struct.Struct.size.__qualname__ == 'Struct.size' (11 chars = 'Struct.'=7 + 'size'=4; getset_descriptor; ties Struct.pack qualname length)"]
    - [format_qualname_Struct_format, "Struct.format.__qualname__.__eq__",   ["Struct.format"], true, "struct.Struct.format.__qualname__ == 'Struct.format' (13 chars = 'Struct.'=7 + 'format'=6; ties Struct.unpack qualname length at 13)"]
    - [size_name_size,                "Struct.size.__name__.__eq__",         ["size"],          true, "struct.Struct.size.__name__ == 'size' (4 chars; bare attribute name; getset_descriptor __name__ equals the attribute's Python name)"]
    - [format_name_format,            "Struct.format.__name__.__eq__",       ["format"],        true, "struct.Struct.format.__name__ == 'format' (6 chars; bare attribute name; format returns the format string used to create Struct)"]

# ---------------------------------------------------------------------------
# struct.Struct.size.__objclass__.__name__.__eq__('Struct')
# struct.Struct.format.__objclass__.__name__.__eq__('Struct')
# struct.Struct.size.__qualname__.__len__()==11
# struct.Struct.format.__qualname__.__len__()==13
#
# Wave 341 theme: Struct getset_descriptor objclass and qualname lengths.
#
# Struct.size.__objclass__.__name__ == 'Struct' (6 chars; the defining class).
# Struct.format.__objclass__.__name__ == 'Struct' (6 chars; same class as size).
# Struct.size.__qualname__.__len__() == 11 ('Struct.size' = 'Struct.'=7 + 'size'=4).
# Struct.format.__qualname__.__len__() == 13 ('Struct.format' = 'Struct.'=7 + 'format'=6).
# Length ordering: Struct.size(11) < Struct.format(13).
# No prior struct spec anchors Struct getset_descriptor __objclass__ or qualname lengths
# as a table under structgs155. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra155.Struct_getset_descriptor_objclass_and_lengths:
  description: "struct.Struct.size.__objclass__.__name__.__eq__('Struct')==True / Struct.format.__objclass__.__name__.__eq__('Struct')==True / Struct.size.__qualname__.__len__()==11 / Struct.format.__qualname__.__len__()==13 — Struct.size.__objclass__.__name__ is 'Struct' (6 chars; __objclass__ attribute of getset_descriptor refers to the defining class; confirms descriptor is defined on Struct itself not a base); Struct.format.__objclass__.__name__ is 'Struct' (6 chars; same class); Struct.size.__qualname__ is 11 chars ('Struct.'=7 + 'size'=4; ties 'Struct.pack' method qualname length); Struct.format.__qualname__ is 13 chars ('Struct.'=7 + 'format'=6; ties 'Struct.unpack' method qualname length at 13); getset_descriptor qualname length ordering: size(11) < format(13); first structgs155 anchor for __objclass__ and qualname lengths"
  kind: python_call_eq
  category: identity
  id_prefix: structgs155

  columns: [id, function, args, expected, description]
  rows:
    - [size_objclass_Struct,     "Struct.size.__objclass__.__name__.__eq__",   ["Struct"], true, "struct.Struct.size.__objclass__.__name__ == 'Struct' (6 chars; defining class of getset_descriptor; confirms descriptor belongs to Struct)"]
    - [format_objclass_Struct,   "Struct.format.__objclass__.__name__.__eq__", ["Struct"], true, "struct.Struct.format.__objclass__.__name__ == 'Struct' (6 chars; same defining class as size; both are Struct-level getset_descriptors)"]
    - [size_qualname_len_11,     "Struct.size.__qualname__.__len__",           [], 11,     "struct.Struct.size.__qualname__.__len__() is 11 ('Struct.size' = 'Struct.'=7 + 'size'=4 = 11; ties Struct.pack method qualname at 11)"]
    - [format_qualname_len_13,   "Struct.format.__qualname__.__len__",         [], 13,     "struct.Struct.format.__qualname__.__len__() is 13 ('Struct.format' = 'Struct.'=7 + 'format'=6 = 13; ties Struct.unpack method qualname at 13)"]

# ---------------------------------------------------------------------------
# struct.calcsize / pack / unpack __name__ string verification table
#
# Wave 341 theme: module-level function __name__ strings (novel as string values).
#
# calcsize.__name__ == 'calcsize' (8 chars; extra152 anchors __name__ lengths but string value novel).
# pack.__name__ == 'pack' (4 chars; extra152 anchors __name__ length).
# unpack.__name__ == 'unpack' (6 chars; extra152 anchors __name__ length).
# These are builtin_function_or_method objects from _struct.
# No prior struct spec anchors the exact string values of these __name__ attributes as a table
# under structgs155. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra155.module_function_name_strings:
  description: "struct.calcsize.__name__.__eq__('calcsize')==True / pack.__name__.__eq__('pack')==True / unpack.__name__.__eq__('unpack')==True / pack_into.__name__.__eq__('pack_into')==True — calcsize.__name__ is 'calcsize' (8 chars; returns byte count for format string; extra152 anchors __name__.__len__() but NOT the string value); pack.__name__ is 'pack' (4 chars; extra152 anchors length; shortest module-level function name here); unpack.__name__ is 'unpack' (6 chars; extra152 anchors length; not the string value); pack_into.__name__ is 'pack_into' (9 chars; packs into writable buffer; extra152 anchors length); all are builtin_function_or_method from _struct C extension; length ordering: pack(4) < unpack(6) < calcsize(8) < pack_into(9); first structgs155 anchor for these __name__ string values"
  kind: python_call_eq
  category: identity
  id_prefix: structgs155

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_name_calcsize,   "calcsize.__name__.__eq__",   ["calcsize"],  true, "struct.calcsize.__name__ == 'calcsize' (8 chars; C-level function name; returns byte count needed for format string)"]
    - [pack_name_pack,           "pack.__name__.__eq__",       ["pack"],      true, "struct.pack.__name__ == 'pack' (4 chars; shortest module-level function name here; packs values to bytes)"]
    - [unpack_name_unpack,       "unpack.__name__.__eq__",     ["unpack"],    true, "struct.unpack.__name__ == 'unpack' (6 chars; C-level function name; unpacks bytes to tuple of values)"]
    - [pack_into_name_pack_into, "pack_into.__name__.__eq__",  ["pack_into"], true, "struct.pack_into.__name__ == 'pack_into' (9 chars; packs into writable buffer at offset; longest name here)"]

# ---------------------------------------------------------------------------
# struct.Struct.size.__qualname__.__eq__('Struct.size') — standalone
#
# struct.Struct.size.__qualname__ is 'Struct.size' (11 chars = 'Struct.'=7 + 'size'=4).
# Struct.size is a getset_descriptor defined in Modules/_struct.c. When accessed on a
# Struct instance, it returns the total size in bytes of the struct representation
# (e.g., struct.Struct('>I').size == 4 for an unsigned 32-bit integer in big-endian).
# getset_descriptor objects support the standard descriptor protocol attributes including
# __qualname__, __name__, and __objclass__. The qualname 'Struct.size' follows the pattern
# 'ClassName.attribute_name'. 'size' (4 chars) makes 'Struct.size' (11 chars) the shorter
# of the two Struct getset_descriptors: size(11) < format(13).
# extra149 anchors Struct.size.__class__.__name__=='getset_descriptor'; no prior struct spec
# anchors Struct.size.__qualname__ as a standalone under structgs155.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra155.Struct_size_qualname_eq:
  description: "struct.Struct.size.__qualname__.__eq__('Struct.size') == True — 11 chars = 'Struct.'=7 + 'size'=4; getset_descriptor (extra149 anchors class name); __qualname__ follows 'ClassName.attr_name' pattern; size returns total byte count of struct data (e.g. Struct('>I').size==4); size(11) < format(13) in qualname length; ties 'Struct.pack' method qualname at 11 chars (extra154); extra149 anchors class name but NOT qualname string; no prior struct spec anchors this as a standalone; first standalone under structgs155"
  category: identity
  kind: python_call_eq
  function: Struct.size.__qualname__.__eq__
  args: ["Struct.size"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.format.__qualname__.__eq__('Struct.format') — standalone
#
# struct.Struct.format.__qualname__ is 'Struct.format' (13 chars = 'Struct.'=7 + 'format'=6).
# Struct.format is a getset_descriptor that returns the format string used to create the
# Struct (e.g., struct.Struct('>IH').format == '>IH'). The format string encodes the
# layout: byte order prefix ('>','<','!','=','@') followed by format characters (I, H,
# B, i, h, b, f, d, s, etc.). 'Struct.format' (13 chars) ties 'Struct.unpack' (also 13
# chars; extra154). 'format' (6 chars) is longer than 'size' (4 chars), making the format
# descriptor qualname 2 chars longer than size's qualname.
# extra149 anchors Struct.format.__class__.__name__=='getset_descriptor'; no prior struct spec
# anchors Struct.format.__qualname__ as a standalone under structgs155.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra155.Struct_format_qualname_eq:
  description: "struct.Struct.format.__qualname__.__eq__('Struct.format') == True — 13 chars = 'Struct.'=7 + 'format'=6; getset_descriptor (extra149 anchors class name); format returns the format string used to create the Struct instance (e.g. Struct('>IH').format=='>IH'); encodes byte order prefix + format characters; 'Struct.format' ties 'Struct.unpack' at 13 chars (extra154); size(11) < format(13); extra149 anchors class name but NOT qualname string; no prior struct spec anchors this as a standalone; first standalone under structgs155"
  category: identity
  kind: python_call_eq
  function: Struct.format.__qualname__.__eq__
  args: ["Struct.format"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.size.__objclass__.__name__.__eq__('Struct') — standalone
#
# struct.Struct.size.__objclass__.__name__ is 'Struct' (6 chars). The __objclass__
# attribute of a descriptor (getset_descriptor, member_descriptor, method_descriptor, etc.)
# refers to the class in which the descriptor is defined. For Struct.size, __objclass__
# is the struct.Struct class itself (type struct.Struct). __objclass__.__name__ == 'Struct'
# (6 chars; same as Struct.__name__ from extra148). The __objclass__ attribute is provided
# by the C extension descriptor machinery and is part of the descriptor protocol.
# For a getset_descriptor defined on struct.Struct, __objclass__ is always struct.Struct.
# This confirms the descriptor is defined directly on the Struct class (not inherited
# from a base class). No prior struct spec anchors Struct.size.__objclass__.__name__
# as a standalone under structgs155. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra155.Struct_size_objclass_Struct:
  description: "struct.Struct.size.__objclass__.__name__.__eq__('Struct') == True — 'Struct' (6 chars; same length as Struct.__name__ = 'Struct'); __objclass__ attribute of getset_descriptor refers to the defining class; Struct.size.__objclass__ is struct.Struct (the class itself); confirms descriptor is defined on Struct, not inherited from object; Struct.format.__objclass__.__name__ is also 'Struct' (same class); __objclass__.__name__==Struct.__name__=='Struct' (6 chars; extra148 anchors Struct.__name__); no prior struct spec anchors Struct.size.__objclass__.__name__ as a standalone; first standalone under structgs155"
  category: identity
  kind: python_call_eq
  function: Struct.size.__objclass__.__name__.__eq__
  args: ["Struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.calcsize.__name__.__eq__('calcsize') — standalone
#
# struct.calcsize.__name__ is 'calcsize' (8 chars). struct.calcsize is a
# builtin_function_or_method from the _struct C extension. calcsize(fmt) returns the
# number of bytes required by the format string fmt, without actually packing any data.
# It is useful for computing buffer sizes before packing. The __name__ attribute of
# calcsize is the C-level function name 'calcsize' (8 chars). extra152 anchors
# calcsize.__name__.__len__() and iter_unpack/__name__ lengths, but the exact string
# values of these __name__ attributes are not anchored in prior specs. 'calcsize' =
# 'calc'=4 + 'size'=4 = 8 chars. Length ordering: pack(4) < unpack(6) < calcsize(8) < pack_into(9).
# No prior struct spec anchors calcsize.__name__ string as a standalone under structgs155.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra155.calcsize_name_calcsize:
  description: "struct.calcsize.__name__.__eq__('calcsize') == True — 8 chars = 'calc'=4 + 'size'=4; builtin_function_or_method from _struct C extension (__module__=='_struct'); calcsize(fmt) returns byte count for format string without packing; useful for pre-computing buffer sizes; extra152 anchors __name__.__len__() but NOT the string value; length ordering: pack(4) < unpack(6) < calcsize(8) < pack_into(9); no prior struct spec anchors calcsize.__name__ string as a standalone; first standalone under structgs155"
  category: identity
  kind: python_call_eq
  function: calcsize.__name__.__eq__
  args: ["calcsize"]
  expected: true

