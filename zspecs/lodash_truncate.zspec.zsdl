spec: lodash_truncate
version: ">=4.0.0"
backend: node(lodash.truncate)

docs: https://lodash.com/docs/#truncate

provenance:
  derived_from:
    - "lodash.truncate README — https://www.npmjs.com/package/lodash.truncate"
    - "Test vectors verified with lodash.truncate@4.4.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.truncate exports the _.truncate function directly as module.exports."
    - "truncate(string, options) truncates string to options.length (default 30)."
    - "Appends options.omission (default '...') when truncated."
    - "The total length (including omission) is capped at options.length."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns truncated string with omission appended."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_truncate.truncate:
  kind: node_module_call_eq
  function: ~
  category: truncate
  id_prefix: ltrunc

  columns: [id, args, expected]
  rows:
    - [length_8,    ["hello world", {"length": 8}],           "hello..."]
    - [no_trunc,    ["hi", {"length": 10}],                   "hi"]
    - [custom_omit, ["hello world", {"length": 7, "omission": "!"}], "hello !"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:50:01Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
