       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__name__.__eq__('BoundArguments') == True — BoundArguments is a Python class in Lib/inspect.py holding the result of binding a call's positional and keyword arguments to a Signature; its __name__ is 'BoundArguments'; str.__eq__('BoundArguments') returns True; new to extra153"]
    - [bound_arguments_module_eq_inspect,
       "BoundArguments.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.BoundArguments.__module__.__eq__('inspect') == True — BoundArguments is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra153"]
    - ["bound_arguments_bases_0_name_eq_object",
       "BoundArguments.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.BoundArguments.__bases__[0].__name__.__eq__('object') == True — BoundArguments inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra153"]
    - [bound_arguments_qualname_eq,
       "BoundArguments.__qualname__.__eq__",
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__qualname__.__eq__('BoundArguments') == True — BoundArguments is defined at module scope in Lib/inspect.py; its __qualname__ equals its __name__; str.__eq__('BoundArguments') returns True; new to extra153"]

# ---------------------------------------------------------------------------
# Table 3: inspect.FullArgSpec class identity
#
# Wave 282 theme: inspect.FullArgSpec namedtuple class identity.
#
# inspect.FullArgSpec.__name__ == 'FullArgSpec'
# inspect.FullArgSpec.__module__ == 'inspect'
# inspect.FullArgSpec.__class__.__name__ == 'type'
#
# FullArgSpec is a namedtuple created via collections.namedtuple in
# Lib/inspect.py. Although it is a namedtuple, its __class__ is still 'type'
# because namedtuple produces a regular class (a subclass of tuple).
# New to extra153.
# ---------------------------------------------------------------------------

table inspect_extra153.full_arg_spec_class_identity:
  description: "inspect.FullArgSpec: __name__ 'FullArgSpec', __module__ 'inspect', __class__.__name__ 'type'; namedtuple class identity; wave 282; new to extra153"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectfasid153

  columns: [id, function, args, expected, description]
  rows:
    - [full_arg_spec_name_eq,
       "FullArgSpec.__name__.__eq__",
       ["FullArgSpec"],
       true,
       "inspect.FullArgSpec.__name__.__eq__('FullArgSpec') == True — FullArgSpec is a namedtuple class created via collections.namedtuple in Lib/inspect.py representing the full argument specification of a function; its __name__ is 'FullArgSpec'; str.__eq__('FullArgSpec') returns True; new to extra153"]
    - [full_arg_spec_module_eq_inspect,
       "FullArgSpec.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.FullArgSpec.__module__.__eq__('inspect') == True — FullArgSpec is created in Lib/inspect.py and its __module__ is set to 'inspect'; str.__eq__('inspect') returns True; new to extra153"]
    - [full_arg_spec_class_eq_type,
       "FullArgSpec.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.FullArgSpec.__class__.__name__.__eq__('type') == True — FullArgSpec is a class (a namedtuple subclass is still a regular Python class); its metaclass is type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra153"]
    - [full_arg_spec_qualname_eq,
       "FullArgSpec.__qualname__.__eq__",
       ["FullArgSpec"],
       true,
       "inspect.FullArgSpec.__qualname__.__eq__('FullArgSpec') == True — FullArgSpec namedtuple has __qualname__ equal to its __name__ 'FullArgSpec'; str.__eq__('FullArgSpec') returns True; new to extra153"]

