    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.Signature class identity (__name__ 'Signature', __module__ 'inspect', __bases__[0].__name__ 'object'); inspect.BoundArguments class identity (__name__ 'BoundArguments', __module__ 'inspect', __bases__[0].__name__ 'object'); inspect.FullArgSpec class identity (__name__ 'FullArgSpec', __module__ 'inspect', __class__.__name__ 'type') (Wave 282)."
    - "inspect.Signature.__name__ == 'Signature' — Signature is a Python class defined in Lib/inspect.py representing a callable's signature; its __name__ is 'Signature'. Verified with Python 3.14.3."
    - "inspect.Signature.__module__ == 'inspect' — Signature is defined in Lib/inspect.py; its __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.Signature.__bases__[0].__name__ == 'object' — Signature inherits directly from object; __bases__[0].__name__ is 'object'. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__name__ == 'BoundArguments' — BoundArguments is a Python class in Lib/inspect.py representing bound argument mappings; its __name__ is 'BoundArguments'. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__module__ == 'inspect' — BoundArguments is defined in Lib/inspect.py; its __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__bases__[0].__name__ == 'object' — BoundArguments inherits directly from object. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__name__ == 'FullArgSpec' — FullArgSpec is a namedtuple class; its __name__ is 'FullArgSpec'. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__module__ == 'inspect' — FullArgSpec is defined in Lib/inspect.py via collections.namedtuple; its __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__class__.__name__ == 'type' — FullArgSpec is a class (namedtuple subclass); its metaclass is type. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Signature class identity
#
# Wave 282 theme: inspect.Signature and inspect.BoundArguments class identity.
#
# inspect.Signature.__name__ == 'Signature'
# inspect.Signature.__module__ == 'inspect'
# inspect.Signature.__bases__[0].__name__ == 'object'
#
# Signature is a Python class in Lib/inspect.py that represents the call
# signature of a callable. It provides an introspection interface for
# parameters and return annotations. New to extra153.
# ---------------------------------------------------------------------------

table inspect_extra153.signature_class_identity:
  description: "inspect.Signature: __name__ 'Signature', __module__ 'inspect', __bases__[0] 'object'; Python class representing callable signature; wave 282; new to extra153"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectsigid153

  columns: [id, function, args, expected, description]
  rows:
    - [signature_name_eq,
       "Signature.__name__.__eq__",
       ["Signature"],
       true,
       "inspect.Signature.__name__.__eq__('Signature') == True — Signature is a Python class in Lib/inspect.py representing the call signature of a Python callable; its __name__ is 'Signature'; str.__eq__('Signature') returns True; new to extra153"]
    - [signature_module_eq_inspect,
       "Signature.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Signature.__module__.__eq__('inspect') == True — Signature is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra153"]
    - ["signature_bases_0_name_eq_object",
       "Signature.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Signature.__bases__[0].__name__.__eq__('object') == True — Signature inherits directly from object (it does not subclass any intermediate base class); __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra153"]
    - [signature_qualname_eq,
       "Signature.__qualname__.__eq__",
       ["Signature"],
       true,
       "inspect.Signature.__qualname__.__eq__('Signature') == True — Signature is defined at module scope in Lib/inspect.py; its __qualname__ equals its __name__ 'Signature'; str.__eq__('Signature') returns True; new to extra153"]

