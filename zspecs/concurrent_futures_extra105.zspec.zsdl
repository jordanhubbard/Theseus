    - [se_co_name,        concurrent.futures.Future.set_exception.__code__.co_name.__eq__,    ["set_exception"],     true, "Future.set_exception.__code__.co_name == 'set_exception'; verified with Python 3.14.3"]
    - [se_co_argc,        concurrent.futures.Future.set_exception.__code__.co_argcount.__eq__, [2],                   true, "Future.set_exception.__code__.co_argcount == 2 (self and exception); verified with Python 3.14.3"]
