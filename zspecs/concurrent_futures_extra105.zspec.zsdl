#
# Wave 254 theme: Future method qualname lengths compared.
#
# Future.done.__qualname__.__len__()             == 11  (shortest)
# Future.add_done_callback.__qualname__.__len__() == 24  (longest)
# ---------------------------------------------------------------------------

table concurrent_futures_extra105.cf_future_method_qualname_lengths:
  description: "concurrent.futures.Future method qualname length comparison checks in cfmethod105 namespace — wave 254 theme: qualname lengths ordered from shortest to longest: Future.done=11 (shortest: 'Future.'=7+'done'=4=11); Future.cancel=Future.result=13 (tied: 'Future.'=7+'cancel'/'result'=6=13); Future.exception=16 ('Future.'=7+'exception'=9=16); Future.set_result=17 ('Future.'=7+'set_result'=10=17); Future.set_exception=20 ('Future.'=7+'set_exception'=13=20); Future.add_done_callback=24 (longest: 'Future.'=7+'add_done_callback'=17=24); co_argcount groupings: cancel=done=1 (fewest), result=add_done_callback=exception=set_result=set_exception=2 (most); note that add_done_callback has the longest name but same co_argcount (2) as result/exception/set_result/set_exception; qualname lengths for all seven methods: 11, 13, 13, 16, 17, 20, 24; sum=114; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfmethod105b

  columns: [id, function, args, expected, description]
  rows:
    - [done_qn_len2,      concurrent.futures.Future.done.__qualname__.__len__,                [],                    11,   "Future.done.__qualname__.__len__() == 11 ('Future.done'=11, shortest); verified with Python 3.14.3"]
    - [cancel_qn_len,     concurrent.futures.Future.cancel.__qualname__.__len__,              [],                    13,   "Future.cancel.__qualname__.__len__() == 13 ('Future.cancel'=13); verified with Python 3.14.3"]
    - [result_qn_len2,    concurrent.futures.Future.result.__qualname__.__len__,              [],                    13,   "Future.result.__qualname__.__len__() == 13 ('Future.result'=13, tied with cancel); verified with Python 3.14.3"]
    - [exc_qn_len2,       concurrent.futures.Future.exception.__qualname__.__len__,           [],                    16,   "Future.exception.__qualname__.__len__() == 16 ('Future.exception'=16); verified with Python 3.14.3"]
    - [sr_qn_len2,        concurrent.futures.Future.set_result.__qualname__.__len__,          [],                    17,   "Future.set_result.__qualname__.__len__() == 17 ('Future.set_result'=17); verified with Python 3.14.3"]
    - [se_qn_len2,        concurrent.futures.Future.set_exception.__qualname__.__len__,       [],                    20,   "Future.set_exception.__qualname__.__len__() == 20 ('Future.set_exception'=20); verified with Python 3.14.3"]
    - [adc_qn_len2,       concurrent.futures.Future.add_done_callback.__qualname__.__len__,   [],                    24,   "Future.add_done_callback.__qualname__.__len__() == 24 ('Future.add_done_callback'=24, longest); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra105
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra105.Future_result_co_argcount_2:
  description: "concurrent.futures.Future.result.__code__.co_argcount == 2 — result takes self and timeout (timeout=None default); Future.result.__code__.co_name=='result'; Future.result.__qualname__=='Future.result' (len=13); Future.result raises CancelledError if cancelled, TimeoutError if the call times out, and returns the result value or re-raises the exception; compare co_argcount values: cancel=done=1 (fewest), result=add_done_callback=exception=set_result=set_exception=2 (all five have co_argcount==2); result.__qualname__.__len__()==13, tied with cancel=13; NEW in extra105: first standalone Future.result argcount invariant in cfmethod105 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: concurrent.futures.Future.result.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant concurrent_futures_extra105.Future_done_co_argcount_1:
  description: "concurrent.futures.Future.done.__code__.co_argcount == 1 — done takes only self (no additional arguments); Future.done.__code__.co_name=='done'; Future.done.__qualname__=='Future.done' (len=11, shortest method qualname in this spec); compare: Future.cancel.__code__.co_argcount is also 1 (tied for fewest args); all other Future methods in this spec have co_argcount==2; done() returns True if the Future is cancelled or finished; Future.done.__qualname__.__len__()==11 < cancel=result=13 < exception=16 < set_result=17 < set_exception=20 < add_done_callback=24; NEW in extra105: first standalone Future.done argcount invariant in cfmethod105 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: concurrent.futures.Future.done.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant concurrent_futures_extra105.Future_add_done_callback_qualname_len_24:
  description: "concurrent.futures.Future.add_done_callback.__qualname__.__len__() == 24 — 'Future.add_done_callback' = 'Future.'=7 + 'add_done_callback'=17 = 24; this is the longest method qualname in this spec; 'add_done_callback' alone is 17 chars, making it the longest method name prefix in this spec; compare qualname lengths: done=11 (shortest), cancel=result=13, exception=16, set_result=17, set_exception=20, add_done_callback=24 (longest); Future.add_done_callback.__code__.co_argcount==2 (same as result, exception, set_result, set_exception); add_done_callback is called when the future completes (cancelled or finished) and schedules fn to be called with the future as argument; NEW in extra105: first standalone Future.add_done_callback qualname length invariant in cfmethod105 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.add_done_callback.__qualname__.__len__
  args: []
  expected: 24

invariant concurrent_futures_extra105.Future_cancel_co_argcount_1:
  description: "concurrent.futures.Future.cancel.__code__.co_argcount == 1 — cancel takes only self (no additional arguments); Future.cancel.__code__.co_name=='cancel'; Future.cancel.__qualname__=='Future.cancel' (len=13); compare: Future.done.__code__.co_argcount is also 1 (tied for fewest args, both take self only); all other Future methods in this spec (result, add_done_callback, exception, set_result, set_exception) have co_argcount==2; cancel() attempts to cancel the future; if the future has already completed or is not cancellable, it returns False; cancel qualname len=13 > done=11; NEW in extra105: first standalone Future.cancel argcount invariant in cfmethod105 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: concurrent.futures.Future.cancel.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant concurrent_futures_extra105.Future_set_exception_qualname_len_20:
  description: "concurrent.futures.Future.set_exception.__qualname__.__len__() == 20 — 'Future.set_exception' = 'Future.'=7 + 'set_exception'=13 = 20; this is the second-longest method qualname in this spec (after add_done_callback=24); compare: set_result.__qualname__.__len__()==17 (shorter by 3: 'set_result'=10 vs 'set_exception'=13); Future.set_exception.__code__.co_name=='set_exception'; Future.set_exception.__code__.co_argcount==2 (self and exception); set_exception sets the exception to be raised by result() and exception() calls; qualname ordering: done=11 < cancel=result=13 < exception=16 < set_result=17 < set_exception=20 < add_done_callback=24; NEW in extra105: first standalone Future.set_exception qualname length invariant in cfmethod105 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.set_exception.__qualname__.__len__
  args: []
  expected: 20
