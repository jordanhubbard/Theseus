spec: concurrent_futures_extra105
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec extends concurrent_futures_extra104.zspec.zsdl."
    - "This spec covers: wave 254 theme — concurrent.futures.Future method co_name and co_argcount for result, add_done_callback, cancel, done, exception, set_result, set_exception. NEW in extra105: Future.result.__code__.co_name=='result' (co_argcount=2: self, timeout); Future.add_done_callback.__code__.co_name=='add_done_callback' (co_argcount=2: self, fn); Future.cancel.__code__.co_name=='cancel' (co_argcount=1: self only); Future.done.__code__.co_name=='done' (co_argcount=1: self only); Future.exception.__code__.co_name=='exception' (co_argcount=2: self, timeout); Future.set_result.__code__.co_name=='set_result' (co_argcount=2: self, result); Future.set_exception.__code__.co_name=='set_exception' (co_argcount=2: self, exception); qualname lengths: done=11 (shortest), cancel=13, result=13, exception=16, set_result=17, set_exception=20, add_done_callback=24 (longest). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Future.result.__code__.co_argcount == 2. The two parameters are self and timeout (timeout=None). Future.exception.__code__.co_argcount is also 2 (self, timeout). Future.add_done_callback.__code__.co_argcount is also 2 (self, fn). Future.set_result and Future.set_exception are also co_argcount==2. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Future.cancel.__code__.co_argcount == 1 (self only). Future.done.__code__.co_argcount is also 1 (self only). These two methods take no additional arguments. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Future.add_done_callback.__qualname__.__len__() == 24. 'Future.add_done_callback' = 'Future.'=7 + 'add_done_callback'=17 = 24; this is the longest method qualname in this spec. Future.done.__qualname__.__len__()==11 ('Future.done'=11, shortest). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Future method co_name and co_argcount — result, add_done_callback, cancel — extra105
#
# Wave 254 theme: Future method code attributes.
#
# Future.result.__code__.co_name         == 'result'            (co_argcount=2)
# Future.add_done_callback.__code__.co_name == 'add_done_callback' (co_argcount=2)
# Future.cancel.__code__.co_name         == 'cancel'            (co_argcount=1)
# ---------------------------------------------------------------------------

table concurrent_futures_extra105.cf_future_method_coname_a:
  description: "concurrent.futures.Future method co_name and co_argcount checks for result, add_done_callback, and cancel in cfmethod105 namespace — wave 254 theme: Future.result.__code__.co_name.__eq__('result')==True; Future.result.__code__.co_argcount.__eq__(2)==True (params: self and timeout); Future.result.__qualname__.__eq__('Future.result')==True (len=13: 'Future.'=7+'result'=6=13); Future.add_done_callback.__code__.co_name.__eq__('add_done_callback')==True; Future.add_done_callback.__code__.co_argcount.__eq__(2)==True (params: self and fn); Future.add_done_callback.__qualname__.__len__()==24 (longest method qualname in spec: 'Future.'=7+'add_done_callback'=17=24); Future.cancel.__code__.co_name.__eq__('cancel')==True; Future.cancel.__code__.co_argcount.__eq__(1)==True (self only — cancel takes no extra args); Future.cancel.__qualname__.__eq__('Future.cancel')==True (len=13); compare co_argcount values: cancel=1 (fewest), result=add_done_callback=2; add_done_callback qualname=24 (longest in spec), cancel=result=13 (tied shorter); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: cfmethod105

