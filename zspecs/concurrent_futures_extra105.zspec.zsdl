    - [result_qn_eq,      concurrent.futures.Future.result.__qualname__.__eq__,               ["Future.result"],     true, "Future.result.__qualname__ == 'Future.result' (len=13); verified with Python 3.14.3"]
    - [result_qn_len,     concurrent.futures.Future.result.__qualname__.__len__,              [],                    13,   "Future.result.__qualname__.__len__() == 13 ('Future.result'=13); verified with Python 3.14.3"]
    - [adc_co_name,       concurrent.futures.Future.add_done_callback.__code__.co_name.__eq__, ["add_done_callback"], true, "Future.add_done_callback.__code__.co_name == 'add_done_callback'; verified with Python 3.14.3"]
    - [adc_co_argc,       concurrent.futures.Future.add_done_callback.__code__.co_argcount.__eq__, [2],              true, "Future.add_done_callback.__code__.co_argcount == 2 (self and fn); verified with Python 3.14.3"]
    - [adc_qn_len,        concurrent.futures.Future.add_done_callback.__qualname__.__len__,   [],                    24,   "Future.add_done_callback.__qualname__.__len__() == 24 ('Future.add_done_callback'=24, longest in spec); verified with Python 3.14.3"]
    - [cancel_co_name,    concurrent.futures.Future.cancel.__code__.co_name.__eq__,           ["cancel"],            true, "Future.cancel.__code__.co_name == 'cancel'; verified with Python 3.14.3"]
    - [cancel_co_argc,    concurrent.futures.Future.cancel.__code__.co_argcount.__eq__,        [1],                   true, "Future.cancel.__code__.co_argcount == 1 (self only — no extra args); verified with Python 3.14.3"]
    - [cancel_qn_eq,      concurrent.futures.Future.cancel.__qualname__.__eq__,               ["Future.cancel"],     true, "Future.cancel.__qualname__ == 'Future.cancel' (len=13); verified with Python 3.14.3"]

