spec: inspect_extra64
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra63.zspec.zsdl."
    - "Wave 230 theme: __code__ attribute deep chains — co_name, co_argcount values."
    - "inspect.isfunction.__code__.co_name == 'isfunction' — co_name is the function's def-statement name as a str. For isfunction it is the 10-character string 'isfunction'. Verified with Python 3.14.3."
    - "inspect.isclass.__code__.co_name == 'isclass' — 7 characters. Verified with Python 3.14.3."
    - "inspect.ismodule.__code__.co_name == 'ismodule' — 8 characters. Verified with Python 3.14.3."
    - "inspect.signature.__code__.co_name == 'signature' — 9 characters. Verified with Python 3.14.3."
    - "inspect.isfunction.__code__.co_argcount == 1 — isfunction(object) has 1 positional parameter; co_argcount counts positional parameters including those with defaults, excluding *args, **kwargs, and keyword-only parameters. Verified with Python 3.14.3."
    - "inspect.isclass.__code__.co_argcount == 1 — isclass(object) has 1 positional parameter. Verified with Python 3.14.3."
    - "inspect.ismodule.__code__.co_argcount == 1 — ismodule(object) has 1 positional parameter. Verified with Python 3.14.3."
    - "isfunction.__code__.co_name.__class__.__name__ == 'str' — co_name is always a plain str in CPython. Verified with Python 3.14.3."
    - "No prior inspect spec checks co_name or co_argcount for any inspect function. All checks in this spec are new to extra64."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect function __code__.co_name checks — extra64
#
# Wave 230 theme: __code__.co_name deep chains.
#
# co_name is the name field of the code object (PyCodeObject.co_name).
# It is a str equal to the function's name as defined in its def statement.
#
# isfunction.__code__.co_name == 'isfunction'
# isclass.__code__.co_name   == 'isclass'
# ismodule.__code__.co_name  == 'ismodule'
# signature.__code__.co_name == 'signature'
#
# All are pure-Python functions in Lib/inspect.py.
# No prior inspect spec checks co_name. New to extra64.
# ---------------------------------------------------------------------------

table inspect_extra64.co_name_eq:
  description: "inspect function __code__.co_name.__eq__ — co_name matches the def-statement name; wave 230 co_name deep chains; new to extra64"
  kind: python_call_eq
  category: co_name
  id_prefix: inspcode2_64

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_code_co_name_eq_isfunction,
       isfunction.__code__.co_name.__eq__,
       ["isfunction"],
       true,
       "inspect.isfunction.__code__.co_name.__eq__('isfunction') == True — isfunction is a pure-Python function (Lib/inspect.py) defined with 'def isfunction(...)'; the code object attribute co_name (PyCodeObject.co_name) stores the function's name as an interned str; for isfunction it is the 10-character string 'isfunction'; __eq__ on a str returns True when the argument equals the string; no prior inspect spec checks co_name for isfunction; new to extra64"]
    - [isclass_code_co_name_eq_isclass,
       isclass.__code__.co_name.__eq__,
       ["isclass"],
       true,
       "inspect.isclass.__code__.co_name.__eq__('isclass') == True — isclass is a pure-Python function (Lib/inspect.py) defined with 'def isclass(...)'; co_name for isclass is the 7-character string 'isclass'; __eq__ returns True; no prior inspect spec checks co_name for isclass; new to extra64"]
    - [ismodule_code_co_name_eq_ismodule,
       ismodule.__code__.co_name.__eq__,
       ["ismodule"],
       true,
       "inspect.ismodule.__code__.co_name.__eq__('ismodule') == True — ismodule is a pure-Python function (Lib/inspect.py) defined with 'def ismodule(...)'; co_name for ismodule is the 8-character string 'ismodule'; __eq__ returns True; no prior inspect spec checks co_name for ismodule; new to extra64"]
    - [signature_code_co_name_eq_signature,
       signature.__code__.co_name.__eq__,
       ["signature"],
       true,
       "inspect.signature.__code__.co_name.__eq__('signature') == True — signature is a pure-Python function (Lib/inspect.py) defined with 'def signature(...)'; co_name for signature is the 9-character string 'signature'; __eq__ returns True; extra63 checked signature.__code__.__class__.__name__ but NOT co_name; no prior inspect spec checks co_name for signature; new to extra64"]

# ---------------------------------------------------------------------------
# isfunction.__code__.co_argcount — extra64
#
# Wave 230 theme: co_argcount counts positional parameters.
#
# co_argcount (PyCodeObject.co_argcount) counts positional parameters
# including those with defaults, excluding *args, **kwargs, and keyword-only.
#
# isfunction(object)  — 1 positional param → co_argcount == 1
# isclass(object)     — 1 positional param → co_argcount == 1
# ismodule(object)    — 1 positional param → co_argcount == 1
#
# All verified with Python 3.14.3.
#
# No prior inspect spec checks co_argcount for any function. New to extra64.
# ---------------------------------------------------------------------------

table inspect_extra64.co_argcount_eq:
  description: "inspect predicate function __code__.co_argcount — all have 1 positional param; wave 230 co_argcount values; new to extra64"
  kind: python_call_eq
  category: co_argcount
  id_prefix: inspcode2_64

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_code_co_argcount_eq_1,
       isfunction.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.isfunction.__code__.co_argcount.__eq__(1) == True — isfunction is a pure-Python function (Lib/inspect.py) with signature isfunction(object); co_argcount counts positional parameters including those with defaults but excluding *args, **kwargs, and keyword-only parameters; the single parameter 'object' has no default but is positional, giving co_argcount == 1; verified with Python 3.14.3; no prior inspect spec checks co_argcount for isfunction; new to extra64"]
    - [isclass_code_co_argcount_eq_1,
       isclass.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.isclass.__code__.co_argcount.__eq__(1) == True — isclass is a pure-Python function (Lib/inspect.py) with signature isclass(object); its single positional parameter 'object' has no default; co_argcount == 1; verified with Python 3.14.3; no prior inspect spec checks co_argcount for isclass; new to extra64"]
    - [ismodule_code_co_argcount_eq_1,
       ismodule.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.ismodule.__code__.co_argcount.__eq__(1) == True — ismodule is a pure-Python function (Lib/inspect.py) with signature ismodule(object); its single positional parameter 'object' has no default; co_argcount == 1; verified with Python 3.14.3; no prior inspect spec checks co_argcount for ismodule; new to extra64"]

# ---------------------------------------------------------------------------
# isfunction.__code__.co_name.__class__.__name__ — extra64
#
# Wave 230 theme: co_name is always a str.
#
# co_name is stored as a PyObject* in PyCodeObject; in CPython it is always
# an interned str. Therefore co_name.__class__ is the built-in str type and
# str.__name__ == 'str'.
#
# Checking co_name.__class__.__name__.__eq__('str') confirms the type of the
# co_name field without depending on the exact function name string.
#
# No prior inspect spec checks co_name.__class__.__name__. New to extra64.
# ---------------------------------------------------------------------------

table inspect_extra64.co_name_class_name:
  description: "isfunction.__code__.co_name.__class__.__name__.__eq__('str')==true — co_name is always a str object; wave 230 co_name deep chains; new to extra64"
  kind: python_call_eq
  category: co_name
  id_prefix: inspcode2_64

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_code_co_name_class_name_eq_str,
       isfunction.__code__.co_name.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.isfunction.__code__.co_name.__class__.__name__.__eq__('str') == True — isfunction is a pure-Python function (Lib/inspect.py); its __code__ is a PyCodeObject; PyCodeObject.co_name is always an interned str in CPython (the function name is stored as a Python str at compile time); therefore co_name.__class__ is the built-in str type and str.__name__ == 'str' (3 chars); __eq__ returns True; this chain verifies the type of co_name without depending on the function name's content; no prior inspect spec checks co_name.__class__.__name__ for any inspect function; new to extra64"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra64
# ---------------------------------------------------------------------------

invariant inspect_extra64.isfunction_co_name_eq_isfunction:
  description: "inspect.isfunction.__code__.co_name.__eq__('isfunction') == True — co_name is the function's def-statement name; wave 230 co_name deep chains; new to extra64"
  kind: python_call_eq
  function: isfunction.__code__.co_name.__eq__
  args: ["isfunction"]
  expected: true

invariant inspect_extra64.isclass_co_name_eq_isclass:
  description: "inspect.isclass.__code__.co_name.__eq__('isclass') == True — co_name is the function's def-statement name; wave 230 co_name deep chains; new to extra64"
  kind: python_call_eq
  function: isclass.__code__.co_name.__eq__
  args: ["isclass"]
  expected: true

invariant inspect_extra64.isfunction_co_argcount_eq_1:
  description: "inspect.isfunction.__code__.co_argcount.__eq__(1) == True — isfunction(object) has 1 positional parameter; wave 230 co_argcount values; new to extra64"
  kind: python_call_eq
  function: isfunction.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra64.isfunction_co_name_class_eq_str:
  description: "inspect.isfunction.__code__.co_name.__class__.__name__.__eq__('str') == True — co_name is always a str object; wave 230 co_name deep chains; new to extra64"
  kind: python_call_eq
  function: isfunction.__code__.co_name.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant inspect_extra64.signature_co_name_eq_signature:
  description: "inspect.signature.__code__.co_name.__eq__('signature') == True — co_name is the function's def-statement name; wave 230 co_name deep chains; new to extra64"
  kind: python_call_eq
  function: signature.__code__.co_name.__eq__
  args: ["signature"]
  expected: true
