spec: inspect_extra107
version: ">=3.11"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra106.zspec.zsdl."
    - "This spec covers: inspect.signature, inspect.getsource, inspect.getsourcelines, inspect.getsourcefile, inspect.getfile, inspect.getmodule, inspect.getcallargs, inspect.getdoc, inspect.getcomments code attributes (co_name, co_argcount); wave 260."
    - "inspect.signature.__code__.co_name == 'signature'. Verified with Python 3.14.3."
    - "inspect.signature.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.getsource.__code__.co_name == 'getsource'. Verified with Python 3.14.3."
    - "inspect.getsource.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.getsourcelines.__code__.co_name == 'getsourcelines'. Verified with Python 3.14.3."
    - "inspect.getsourcelines.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.getsourcefile.__code__.co_name == 'getsourcefile'. Verified with Python 3.14.3."
    - "inspect.getsourcefile.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.getfile.__code__.co_name == 'getfile'. Verified with Python 3.14.3."
    - "inspect.getfile.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.getmodule.__code__.co_name == 'getmodule'. Verified with Python 3.14.3."
    - "inspect.getmodule.__code__.co_argcount == 2. Verified with Python 3.14.3."
    - "inspect.getcallargs.__code__.co_name == 'getcallargs'. Verified with Python 3.14.3."
    - "inspect.getcallargs.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.getdoc.__code__.co_name == 'getdoc'. Verified with Python 3.14.3."
    - "inspect.getdoc.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.getcomments.__code__.co_name == 'getcomments'. Verified with Python 3.14.3."
    - "inspect.getcomments.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect source retrieval functions — co_name and co_argcount
#
# Wave 260 theme: inspect.signature, inspect.getsource, inspect.getsourcelines,
# and inspect.getsourcefile are pure-Python functions in Lib/inspect.py.
# Each has co_name equal to its function name and co_argcount equal to the
# number of positional parameters. All take exactly 1 positional argument
# (the object to inspect) except getmodule which takes 2.
#
# inspect.signature.__code__.co_name == 'signature'
# inspect.signature.__code__.co_argcount == 1
# inspect.getsource.__code__.co_name == 'getsource'
# inspect.getsource.__code__.co_argcount == 1
# inspect.getsourcelines.__code__.co_name == 'getsourcelines'
# inspect.getsourcelines.__code__.co_argcount == 1
# inspect.getsourcefile.__code__.co_name == 'getsourcefile'
# inspect.getsourcefile.__code__.co_argcount == 1
#
# New to extra107.
# ---------------------------------------------------------------------------

table inspect_extra107.source_functions_code_attrs:
  description: "inspect source functions code attributes: signature/getsource/getsourcelines/getsourcefile have co_name equal to function name and co_argcount == 1; wave 260; new to extra107"
  kind: python_call_eq
  category: code_identity
  id_prefix: inspectsrc107

  columns: [id, function, args, expected, description]
  rows:
    - [signature_co_name_eq,
       "signature.__code__.co_name.__eq__",
       ["signature"],
       true,
       "inspect.signature.__code__.co_name.__eq__('signature') == True — inspect.signature is a pure-Python function defined in Lib/inspect.py; its code object co_name is the function name 'signature'; str.__eq__('signature') returns True; new to extra107"]
    - [signature_co_argcount_1,
       "signature.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.signature.__code__.co_argcount.__eq__(1) == True — inspect.signature takes 1 positional parameter (the callable object to examine); co_argcount counts positional parameters only (not keyword-only or *args/**kwargs); int.__eq__(1) returns True; new to extra107"]
    - [getsource_co_name_eq,
       "getsource.__code__.co_name.__eq__",
       ["getsource"],
       true,
       "inspect.getsource.__code__.co_name.__eq__('getsource') == True — inspect.getsource is a pure-Python function in Lib/inspect.py; its code object co_name is 'getsource'; str.__eq__('getsource') returns True; new to extra107"]
    - [getsource_co_argcount_1,
       "getsource.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getsource.__code__.co_argcount.__eq__(1) == True — inspect.getsource takes 1 positional parameter (the object whose source to retrieve); co_argcount is 1; int.__eq__(1) returns True; new to extra107"]
    - [getsourcelines_co_name_eq,
       "getsourcelines.__code__.co_name.__eq__",
       ["getsourcelines"],
       true,
       "inspect.getsourcelines.__code__.co_name.__eq__('getsourcelines') == True — inspect.getsourcelines is a pure-Python function in Lib/inspect.py; its code object co_name is 'getsourcelines'; str.__eq__('getsourcelines') returns True; new to extra107"]
    - [getsourcelines_co_argcount_1,
       "getsourcelines.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getsourcelines.__code__.co_argcount.__eq__(1) == True — inspect.getsourcelines takes 1 positional parameter (the object whose source lines to retrieve); co_argcount is 1; int.__eq__(1) returns True; new to extra107"]
    - [getsourcefile_co_name_eq,
       "getsourcefile.__code__.co_name.__eq__",
       ["getsourcefile"],
       true,
       "inspect.getsourcefile.__code__.co_name.__eq__('getsourcefile') == True — inspect.getsourcefile is a pure-Python function in Lib/inspect.py; its code object co_name is 'getsourcefile'; str.__eq__('getsourcefile') returns True; new to extra107"]
    - [getsourcefile_co_argcount_1,
       "getsourcefile.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getsourcefile.__code__.co_argcount.__eq__(1) == True — inspect.getsourcefile takes 1 positional parameter (the object whose source file to locate); co_argcount is 1; int.__eq__(1) returns True; new to extra107"]

# ---------------------------------------------------------------------------
# Table 2: inspect file and module functions — co_name and co_argcount
#
# Wave 260 theme: inspect.getfile and inspect.getmodule are pure-Python
# functions in Lib/inspect.py. getfile takes 1 positional argument (the
# object). getmodule is unique: it takes 2 positional arguments (the object
# and an optional filename hint). This makes getmodule the only inspect
# function in these specs with co_argcount == 2.
#
# inspect.getfile.__code__.co_name == 'getfile'
# inspect.getfile.__code__.co_argcount == 1
# inspect.getmodule.__code__.co_name == 'getmodule'
# inspect.getmodule.__code__.co_argcount == 2
#
# New to extra107.
# ---------------------------------------------------------------------------

table inspect_extra107.file_module_functions_code_attrs:
  description: "inspect.getfile and inspect.getmodule code attributes: getfile has co_argcount == 1; getmodule has co_argcount == 2 (object plus optional filename hint); wave 260; new to extra107"
  kind: python_call_eq
  category: code_identity
  id_prefix: inspectfile107

  columns: [id, function, args, expected, description]
  rows:
    - [getfile_co_name_eq,
       "getfile.__code__.co_name.__eq__",
       ["getfile"],
       true,
       "inspect.getfile.__code__.co_name.__eq__('getfile') == True — inspect.getfile is a pure-Python function in Lib/inspect.py returning the file in which an object was defined; its code object co_name is 'getfile'; str.__eq__('getfile') returns True; new to extra107"]
    - [getfile_co_argcount_1,
       "getfile.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getfile.__code__.co_argcount.__eq__(1) == True — inspect.getfile takes 1 positional parameter (the object whose defining file to locate); co_argcount is 1; int.__eq__(1) returns True; new to extra107"]
    - [getmodule_co_name_eq,
       "getmodule.__code__.co_name.__eq__",
       ["getmodule"],
       true,
       "inspect.getmodule.__code__.co_name.__eq__('getmodule') == True — inspect.getmodule is a pure-Python function in Lib/inspect.py returning the module in which an object was defined; its code object co_name is 'getmodule'; str.__eq__('getmodule') returns True; new to extra107"]
    - [getmodule_co_argcount_2,
       "getmodule.__code__.co_argcount.__eq__",
       [2],
       true,
       "inspect.getmodule.__code__.co_argcount.__eq__(2) == True — inspect.getmodule takes 2 positional parameters (the object and an optional filename hint for disambiguation); co_argcount is 2; this makes getmodule unique among the inspect functions covered here; int.__eq__(2) returns True; new to extra107"]
    - [getcallargs_co_name_eq,
       "getcallargs.__code__.co_name.__eq__",
       ["getcallargs"],
       true,
       "inspect.getcallargs.__code__.co_name.__eq__('getcallargs') == True — inspect.getcallargs is a pure-Python function in Lib/inspect.py binding arguments to a function's parameters; its code object co_name is 'getcallargs'; str.__eq__('getcallargs') returns True; new to extra107"]
    - [getcallargs_co_argcount_1,
       "getcallargs.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getcallargs.__code__.co_argcount.__eq__(1) == True — inspect.getcallargs takes 1 positional parameter (the function); remaining arguments are passed via *args/**kwargs; co_argcount is 1; int.__eq__(1) returns True; new to extra107"]

# ---------------------------------------------------------------------------
# Table 3: inspect documentation functions — co_name and co_argcount
#
# Wave 260 theme: inspect.getdoc and inspect.getcomments are pure-Python
# functions in Lib/inspect.py for retrieving documentation strings and
# source comments. Both take 1 positional argument. Their co_name values
# equal their function names.
#
# inspect.getdoc.__code__.co_name == 'getdoc'
# inspect.getdoc.__code__.co_argcount == 1
# inspect.getcomments.__code__.co_name == 'getcomments'
# inspect.getcomments.__code__.co_argcount == 1
#
# New to extra107.
# ---------------------------------------------------------------------------

table inspect_extra107.doc_functions_code_attrs:
  description: "inspect.getdoc and inspect.getcomments code attributes: both have co_name equal to function name and co_argcount == 1; wave 260; new to extra107"
  kind: python_call_eq
  category: code_identity
  id_prefix: inspectdoc107

  columns: [id, function, args, expected, description]
  rows:
    - [getdoc_co_name_eq,
       "getdoc.__code__.co_name.__eq__",
       ["getdoc"],
       true,
       "inspect.getdoc.__code__.co_name.__eq__('getdoc') == True — inspect.getdoc is a pure-Python function in Lib/inspect.py retrieving and cleaning the docstring of an object; its code object co_name is 'getdoc'; str.__eq__('getdoc') returns True; new to extra107"]
    - [getdoc_co_argcount_1,
       "getdoc.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getdoc.__code__.co_argcount.__eq__(1) == True — inspect.getdoc takes 1 positional parameter (the object whose docstring to retrieve); co_argcount is 1; int.__eq__(1) returns True; new to extra107"]
    - [getcomments_co_name_eq,
       "getcomments.__code__.co_name.__eq__",
       ["getcomments"],
       true,
       "inspect.getcomments.__code__.co_name.__eq__('getcomments') == True — inspect.getcomments is a pure-Python function in Lib/inspect.py retrieving lines of comments immediately preceding a function or class definition; its code object co_name is 'getcomments'; str.__eq__('getcomments') returns True; new to extra107"]
    - [getcomments_co_argcount_1,
       "getcomments.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getcomments.__code__.co_argcount.__eq__(1) == True — inspect.getcomments takes 1 positional parameter (the object whose preceding comments to retrieve); co_argcount is 1; int.__eq__(1) returns True; new to extra107"]
    - [signature_co_name_confirms,
       "signature.__code__.co_name.__eq__",
       ["signature"],
       true,
       "inspect.signature.__code__.co_name.__eq__('signature') == True — confirmatory vector: inspect.signature co_name is 'signature'; placed in doc table to confirm pattern that all inspect function code co_name values equal the function name exactly; str.__eq__('signature') returns True; new to extra107"]
    - [getsource_co_name_confirms,
       "getsource.__code__.co_name.__eq__",
       ["getsource"],
       true,
       "inspect.getsource.__code__.co_name.__eq__('getsource') == True — confirmatory vector: inspect.getsource co_name is 'getsource'; confirms that co_name equals the function name for all inspect module functions; str.__eq__('getsource') returns True; new to extra107"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra107
# ---------------------------------------------------------------------------

invariant inspect_extra107.signature_co_argcount:
  description: "inspect.signature.__code__.co_argcount == 1 — signature takes 1 positional arg (the callable); wave 260; new to extra107"
  kind: python_call_eq
  function: signature.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra107.getmodule_co_argcount:
  description: "inspect.getmodule.__code__.co_argcount == 2 — unique among inspect functions: getmodule takes object plus optional filename hint; wave 260; new to extra107"
  kind: python_call_eq
  function: getmodule.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant inspect_extra107.getsourcelines_co_name:
  description: "inspect.getsourcelines.__code__.co_name == 'getsourcelines' — co_name equals function name; wave 260; new to extra107"
  kind: python_call_eq
  function: getsourcelines.__code__.co_name.__eq__
  args: ["getsourcelines"]
  expected: true

invariant inspect_extra107.getdoc_co_argcount:
  description: "inspect.getdoc.__code__.co_argcount == 1 — getdoc takes 1 positional arg (the object); wave 260; new to extra107"
  kind: python_call_eq
  function: getdoc.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra107.getcomments_co_name:
  description: "inspect.getcomments.__code__.co_name == 'getcomments' — co_name equals function name; wave 260; new to extra107"
  kind: python_call_eq
  function: getcomments.__code__.co_name.__eq__
  args: ["getcomments"]
  expected: true

