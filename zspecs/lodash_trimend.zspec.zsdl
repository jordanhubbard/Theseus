spec: lodash_trimend
version: ">=4.0.0"
backend: node(lodash.trimend)

docs: https://lodash.com/docs/#trimEnd

provenance:
  derived_from:
    - "lodash.trimend README — https://www.npmjs.com/package/lodash.trimend"
    - "Test vectors verified with lodash.trimend@4.5.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.trimend exports the _.trimEnd function directly as module.exports."
    - "trimEnd(string, chars) removes trailing chars from string."
    - "Removes whitespace by default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns right-trimmed string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_trimend.trimend:
  kind: node_module_call_eq
  function: ~
  category: trimend
  id_prefix: ltre

  columns: [id, args, expected]
  rows:
    - [spaces,       ["  hello  "],          "  hello"]
    - [custom_char,  ["--hello--", "-"],      "--hello"]
    - [no_change,    ["  hello"],             "  hello"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:49:30Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
