spec: struct_extra183
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/struct.py"
    - "CPython source: Modules/_struct.c"
  notes:
    - "struct.__name__ == 'struct' — len=6; C extension module name."
    - "struct.__package__ == '' — C extension, no package; empty string not None."
    - "struct.error.__name__ == 'error' — len=5; bare name without module prefix."
    - "struct.error.__qualname__ == 'error' — len=5; top-level class, qualname matches __name__."
    - "struct.error.__module__ == 'struct' — defined in the struct module."
    - "struct.error.__bases__ == (Exception,) — direct subclass of Exception."
    - "struct.error.__mro__ length == 4 — [error, Exception, BaseException, object]."
    - "struct.error.__doc__ is None — no docstring; type(None).__name__ == 'NoneType'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: struct module-level name and package identity
#
# struct.__name__     == 'struct'   (len=6)
# struct.__package__  == ''         (C extension, empty string)
#
# struct is a C extension module (_struct.c).  Its __name__ is the public
# module name 'struct' and __package__ is the empty string — C extension
# modules at the top level have no package, unlike pure-Python sub-packages.
# ---------------------------------------------------------------------------

table struct_extra183.module_name_package:
  description: "struct module __name__ and __package__ identity; new to extra183"
  kind: python_call_eq
  category: identity
  id_prefix: structmodule183

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name_eq,
       struct.__name__.__eq__,
       ["struct"],
       true,
       "struct.__name__.__eq__('struct') == True — C extension module name; len=6; new to extra183"]
    - [mod_name_len,
       struct.__name__.__len__,
       [],
       6,
       "struct.__name__.__len__() == 6 — 'struct' has 6 characters; new to extra183"]
    - [mod_pkg_eq,
       struct.__package__.__eq__,
       [""],
       true,
       "struct.__package__.__eq__('') == True — C extension, no package; empty string; new to extra183"]
    - [mod_pkg_len,
       struct.__package__.__len__,
       [],
       0,
       "struct.__package__.__len__() == 0 — empty string has 0 characters; new to extra183"]

# ---------------------------------------------------------------------------
# Table 2: struct.error exception name and qualname identity
#
# struct.error.__name__     == 'error'   (len=5)
# struct.error.__qualname__ == 'error'   (len=5)
# struct.error.__module__   == 'struct'  (len=6)
#
# struct.error is a top-level class within the struct module, so its
# __qualname__ matches __name__ (no enclosing class scope).  Its __module__
# is 'struct', identifying the module in which it was defined.
# ---------------------------------------------------------------------------

table struct_extra183.error_name_qualname_module:
  description: "struct.error __name__, __qualname__, and __module__ identity; new to extra183"
  kind: python_call_eq
  category: identity
  id_prefix: structmodule183

  columns: [id, function, args, expected, description]
  rows:
    - [err_name_eq,
       struct.error.__name__.__eq__,
       ["error"],
       true,
       "struct.error.__name__.__eq__('error') == True — bare exception class name; len=5; new to extra183"]
    - [err_name_len,
       struct.error.__name__.__len__,
       [],
       5,
       "struct.error.__name__.__len__() == 5 — 'error' has 5 characters; new to extra183"]
    - [err_qualname_eq,
       struct.error.__qualname__.__eq__,
       ["error"],
       true,
       "struct.error.__qualname__.__eq__('error') == True — top-level class, qualname == name; len=5; new to extra183"]
    - [err_qualname_len,
       struct.error.__qualname__.__len__,
       [],
       5,
       "struct.error.__qualname__.__len__() == 5 — 'error' has 5 characters; new to extra183"]
    - [err_module_eq,
       struct.error.__module__.__eq__,
       ["struct"],
       true,
       "struct.error.__module__.__eq__('struct') == True — defined in the struct module; len=6; new to extra183"]
    - [err_module_len,
       struct.error.__module__.__len__,
       [],
       6,
       "struct.error.__module__.__len__() == 6 — 'struct' has 6 characters; new to extra183"]

# ---------------------------------------------------------------------------
# Table 3: struct.error exception hierarchy — bases and MRO length
#
# struct.error.__bases__[0].__name__ == 'Exception'   (len=9)
# len(struct.error.__mro__)          == 4
#
# struct.error directly subclasses Exception.  Its MRO is:
#   [error, Exception, BaseException, object]  — 4 entries.
# The __doc__ attribute is None: struct.error has no docstring.
# ---------------------------------------------------------------------------

table struct_extra183.error_hierarchy:
  description: "struct.error exception hierarchy: base class name and MRO length; new to extra183"
  kind: python_call_eq
  category: identity
  id_prefix: structmodule183

  columns: [id, function, args, expected, description]
  rows:
    - [err_base0_name_eq,
       "struct.error.__bases__[0].__name__.__eq__",
       ["Exception"],
       true,
       "struct.error.__bases__[0].__name__.__eq__('Exception') == True — direct subclass of Exception; len=9; new to extra183"]
    - [err_base0_name_len,
       "struct.error.__bases__[0].__name__.__len__",
       [],
       9,
       "struct.error.__bases__[0].__name__.__len__() == 9 — 'Exception' has 9 characters; new to extra183"]
    - [err_mro_len,
       struct.error.__mro__.__len__,
       [],
       4,
       "struct.error.__mro__.__len__() == 4 — MRO is [error, Exception, BaseException, object]; new to extra183"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra183
# ---------------------------------------------------------------------------

invariant struct_extra183.module_name_is_struct:
  description: "struct.__name__ == 'struct' — C extension module name; len=6; new to extra183"
  category: identity
  kind: python_call_eq
  function: struct.__name__.__eq__
  args: ["struct"]
  expected: true

invariant struct_extra183.module_package_is_empty:
  description: "struct.__package__ == '' — C extension at top level has no package; new to extra183"
  category: identity
  kind: python_call_eq
  function: struct.__package__.__eq__
  args: [""]
  expected: true

invariant struct_extra183.error_name_is_error:
  description: "struct.error.__name__ == 'error' — bare exception class name; len=5; new to extra183"
  category: identity
  kind: python_call_eq
  function: struct.error.__name__.__eq__
  args: ["error"]
  expected: true

invariant struct_extra183.error_qualname_is_error:
  description: "struct.error.__qualname__ == 'error' — top-level class qualname matches name; len=5; new to extra183"
  category: identity
  kind: python_call_eq
  function: struct.error.__qualname__.__eq__
  args: ["error"]
  expected: true

invariant struct_extra183.error_module_is_struct:
  description: "struct.error.__module__ == 'struct' — exception defined in the struct module; len=6; new to extra183"
  category: identity
  kind: python_call_eq
  function: struct.error.__module__.__eq__
  args: ["struct"]
  expected: true

invariant struct_extra183.error_base_is_exception:
  description: "struct.error.__bases__[0].__name__ == 'Exception' — direct subclass of Exception; len=9; new to extra183"
  category: identity
  kind: python_call_eq
  function: "struct.error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant struct_extra183.error_mro_len_is_4:
  description: "len(struct.error.__mro__) == 4 — MRO is [error, Exception, BaseException, object]; new to extra183"
  category: identity
  kind: python_call_eq
  function: struct.error.__mro__.__len__
  args: []
  expected: 4

