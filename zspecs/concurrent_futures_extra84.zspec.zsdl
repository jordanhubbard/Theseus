# ---------------------------------------------------------------------------
# concurrent.futures ThreadPoolExecutor method __qualname__ — extra84
#
# Wave 247 theme: executor and future method __qualname__ string equality.
#
# ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit'
# ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown'
# ---------------------------------------------------------------------------

table concurrent_futures_extra84.ThreadPoolExecutor_method_qualnames:
  description: "concurrent.futures ThreadPoolExecutor method __qualname__ string equality checks in cfmqualstr84 namespace — wave 247 theme: executor and future method __qualname__ string equality; ThreadPoolExecutor.submit.__qualname__=='ThreadPoolExecutor.submit'; ThreadPoolExecutor.shutdown.__qualname__=='ThreadPoolExecutor.shutdown'; __qualname__ for class methods includes the class name as a prefix; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfmqualstr84

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_submit_qualname,   ThreadPoolExecutor.submit.__qualname__.__eq__,   ["ThreadPoolExecutor.submit"],   true, "ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit' — includes class prefix; verified with Python 3.14.3"]
    - [tpe_shutdown_qualname, ThreadPoolExecutor.shutdown.__qualname__.__eq__, ["ThreadPoolExecutor.shutdown"], true, "ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown' — includes class prefix; verified with Python 3.14.3"]

