invariant concurrent_futures_extra84.ThreadPoolExecutor_submit_qualname:
  description: "concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__eq__('ThreadPoolExecutor.submit') returns True — __qualname__ for class methods includes the class name as a prefix followed by the method name; NEW in extra84: first standalone __qualname__ equality invariant for ThreadPoolExecutor.submit in cfmqualstr84 namespace; wave 247; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.submit.__qualname__.__eq__
  args: ["ThreadPoolExecutor.submit"]
  expected: true

