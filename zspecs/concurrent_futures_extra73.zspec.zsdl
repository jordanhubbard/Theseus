table concurrent_futures_extra73.InvalidStateError_qualname_and_doc:
  description: "concurrent.futures InvalidStateError __qualname__ and __doc__.__class__.__name__ checks in cfmore73 namespace — wave 242 theme: InvalidStateError identity; InvalidStateError.__qualname__=='InvalidStateError' (simple qualname, not nested); InvalidStateError.__doc__.__class__.__name__=='str' (plain Python string docstring); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfmore73b

  columns: [id, function, args, expected, description]
  rows:
    - [ise_qualname,   InvalidStateError.__qualname__.__eq__,              ["InvalidStateError"], true, "InvalidStateError.__qualname__ == 'InvalidStateError' — simple qualname; not nested; verified with Python 3.14.3"]
    - [ise_doc_class,  InvalidStateError.__doc__.__class__.__name__.__eq__, ["str"],              true, "InvalidStateError.__doc__.__class__.__name__ == 'str' — plain Python string docstring; verified with Python 3.14.3"]

