table concurrent_futures_extra73.ppe_dict_and_broken_cross_check:
  description: "concurrent.futures ProcessPoolExecutor dict class and BrokenExecutor MRO cross-check in cfmore73 namespace — wave 242 theme: ProcessPoolExecutor dict + BrokenExecutor identity; ProcessPoolExecutor.__dict__.__class__.__name__=='mappingproxy'; BrokenExecutor.__mro__.__len__()==5; InvalidStateError.__qualname__=='InvalidStateError'; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: cfmore73c

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_dict_cls_check,    ProcessPoolExecutor.__dict__.__class__.__name__.__eq__, ["mappingproxy"],  true, "ProcessPoolExecutor.__dict__.__class__.__name__ == 'mappingproxy' — cross-check; verified with Python 3.14.3"]
    - [broken_mro_len_check,  BrokenExecutor.__mro__.__len__,                         [],                5,    "BrokenExecutor.__mro__.__len__() == 5 — (BrokenExecutor, RuntimeError, Exception, BaseException, object); cross-check; verified with Python 3.14.3"]
    - [ise_qualname_check,    InvalidStateError.__qualname__.__eq__,                  ["InvalidStateError"], true, "InvalidStateError.__qualname__ == 'InvalidStateError' — cross-check; verified with Python 3.14.3"]

