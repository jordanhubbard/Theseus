invariant concurrent_futures_extra73.ProcessPoolExecutor_dict_has_submit:
  description: "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('submit') returns True — ProcessPoolExecutor defines submit in concurrent/futures/process.py; NEW in extra73: first standalone __contains__('submit') invariant for ProcessPoolExecutor.__dict__ in cfmore73 namespace; wave 242; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: ProcessPoolExecutor.__dict__.__contains__
  args: ["submit"]
  expected: true

invariant concurrent_futures_extra73.ProcessPoolExecutor_dict_has_init:
  description: "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('__init__') returns True — ProcessPoolExecutor defines __init__ in its own __dict__; NEW in extra73: first standalone __contains__('__init__') invariant for ProcessPoolExecutor.__dict__ in cfmore73 namespace; wave 242; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: ProcessPoolExecutor.__dict__.__contains__
  args: ["__init__"]
  expected: true

invariant concurrent_futures_extra73.BrokenExecutor_qualname:
  description: "concurrent.futures.BrokenExecutor.__qualname__.__eq__('BrokenExecutor') returns True — BrokenExecutor has a simple qualname (not nested inside another class); NEW in extra73: first standalone __qualname__ invariant for BrokenExecutor in cfmore73 namespace; wave 242; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: BrokenExecutor.__qualname__.__eq__
  args: ["BrokenExecutor"]
  expected: true

invariant concurrent_futures_extra73.BrokenExecutor_mro_len:
  description: "concurrent.futures.BrokenExecutor.__mro__.__len__() == 5 — MRO is (BrokenExecutor, RuntimeError, Exception, BaseException, object); NEW in extra73: first standalone __mro__.__len__ invariant for BrokenExecutor in cfmore73 namespace; wave 242; verified with Python 3.14.3"
  category: hierarchy
  kind: python_call_eq
  function: BrokenExecutor.__mro__.__len__
  args: []
  expected: 5

invariant concurrent_futures_extra73.InvalidStateError_doc_class_name:
  description: "concurrent.futures.InvalidStateError.__doc__.__class__.__name__.__eq__('str') returns True — InvalidStateError has a plain Python string docstring; __doc__.__class__.__name__ is 'str'; NEW in extra73: first standalone __doc__.__class__.__name__ invariant for InvalidStateError in cfmore73 namespace; wave 242; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: InvalidStateError.__doc__.__class__.__name__.__eq__
