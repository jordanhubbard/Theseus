spec: concurrent_futures_extra73
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra72.zspec.zsdl."
    - "This spec covers: wave 242 theme — concurrent.futures ProcessPoolExecutor.__dict__ content. NEW in extra73: ProcessPoolExecutor.__dict__.__class__.__name__=='mappingproxy'; ProcessPoolExecutor.__dict__.__contains__('submit')==True; ProcessPoolExecutor.__dict__.__contains__('shutdown')==True; ProcessPoolExecutor.__dict__.__contains__('__init__')==True; BrokenExecutor.__name__=='BrokenExecutor'; BrokenExecutor.__module__=='concurrent.futures._base'; BrokenExecutor.__qualname__=='BrokenExecutor'; BrokenExecutor.__mro__.__len__()==5; InvalidStateError.__qualname__=='InvalidStateError'; InvalidStateError.__doc__.__class__.__name__=='str'."
    - "concurrent.futures.ProcessPoolExecutor.__dict__.__class__.__name__ == 'mappingproxy'. ProcessPoolExecutor is defined in Lib/concurrent/futures/process.py; its __dict__ is a read-only mappingproxy. Prior extra51 captured the string equality check; extra73 adds __contains__ checks in cfmore73 namespace. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('submit') == True. ProcessPoolExecutor defines submit directly in its own __dict__ in concurrent/futures/process.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('shutdown') == True. ProcessPoolExecutor defines shutdown directly in its own __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('__init__') == True. ProcessPoolExecutor defines __init__ directly in its own __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.BrokenExecutor.__name__ == 'BrokenExecutor'. BrokenExecutor is defined in concurrent/futures/_base.py; __name__ is 'BrokenExecutor'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base'. BrokenExecutor is defined in the _base submodule; __module__ is 'concurrent.futures._base'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.BrokenExecutor.__qualname__ == 'BrokenExecutor'. BrokenExecutor has a simple qualname (not nested); __qualname__ is 'BrokenExecutor'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.BrokenExecutor.__mro__.__len__() == 5. MRO is (BrokenExecutor, RuntimeError, Exception, BaseException, object) — 5 entries. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.InvalidStateError.__qualname__ == 'InvalidStateError'. InvalidStateError has a simple qualname; __qualname__ is 'InvalidStateError'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.InvalidStateError.__doc__.__class__.__name__ == 'str'. InvalidStateError has a plain Python string docstring; __doc__.__class__.__name__ is 'str'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures ProcessPoolExecutor.__dict__ class name and methods — extra73
#
# Wave 242 theme: ProcessPoolExecutor.__dict__ content.
#
# ProcessPoolExecutor.__dict__.__class__.__name__ == 'mappingproxy'
# ProcessPoolExecutor.__dict__.__contains__('submit') == True
# ProcessPoolExecutor.__dict__.__contains__('shutdown') == True
# ProcessPoolExecutor.__dict__.__contains__('__init__') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra73.ProcessPoolExecutor_dict_content:
  description: "concurrent.futures ProcessPoolExecutor.__dict__ class name and method content checks in cfmore73 namespace — wave 242 theme: ProcessPoolExecutor.__dict__ content; ProcessPoolExecutor.__dict__.__class__.__name__=='mappingproxy' (class __dict__ is read-only mappingproxy in CPython); ProcessPoolExecutor.__dict__.__contains__('submit')==True; ProcessPoolExecutor.__dict__.__contains__('shutdown')==True; ProcessPoolExecutor.__dict__.__contains__('__init__')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: cfmore73

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_dict_class_name,   ProcessPoolExecutor.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true, "ProcessPoolExecutor.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy in CPython; verified with Python 3.14.3"]
    - [ppe_dict_has_submit,   ProcessPoolExecutor.__dict__.__contains__,              ["submit"],       true, "ProcessPoolExecutor.__dict__.__contains__('submit') == True — ProcessPoolExecutor defines submit in concurrent/futures/process.py; verified with Python 3.14.3"]
    - [ppe_dict_has_shutdown, ProcessPoolExecutor.__dict__.__contains__,              ["shutdown"],     true, "ProcessPoolExecutor.__dict__.__contains__('shutdown') == True — ProcessPoolExecutor defines shutdown in its own __dict__; verified with Python 3.14.3"]
    - [ppe_dict_has_init,     ProcessPoolExecutor.__dict__.__contains__,              ["__init__"],     true, "ProcessPoolExecutor.__dict__.__contains__('__init__') == True — ProcessPoolExecutor defines __init__ in its own __dict__; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures BrokenExecutor identity checks — extra73
#
# BrokenExecutor.__name__ == 'BrokenExecutor'
# BrokenExecutor.__module__ == 'concurrent.futures._base'
# BrokenExecutor.__qualname__ == 'BrokenExecutor'
# BrokenExecutor.__mro__.__len__() == 5
# ---------------------------------------------------------------------------

table concurrent_futures_extra73.BrokenExecutor_identity:
  description: "concurrent.futures BrokenExecutor identity checks in cfmore73 namespace — wave 242 theme: BrokenExecutor class identity; BrokenExecutor.__name__=='BrokenExecutor'; BrokenExecutor.__module__=='concurrent.futures._base'; BrokenExecutor.__qualname__=='BrokenExecutor'; BrokenExecutor.__mro__.__len__()==5 (BrokenExecutor, RuntimeError, Exception, BaseException, object); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfmore73a

  columns: [id, function, args, expected, description]
  rows:
    - [broken_name,     BrokenExecutor.__name__.__eq__,     ["BrokenExecutor"],               true, "BrokenExecutor.__name__ == 'BrokenExecutor' — defined in concurrent/futures/_base.py; verified with Python 3.14.3"]
    - [broken_module,   BrokenExecutor.__module__.__eq__,   ["concurrent.futures._base"],     true, "BrokenExecutor.__module__ == 'concurrent.futures._base' — defined in _base submodule; verified with Python 3.14.3"]
    - [broken_qualname, BrokenExecutor.__qualname__.__eq__, ["BrokenExecutor"],               true, "BrokenExecutor.__qualname__ == 'BrokenExecutor' — simple qualname (not nested); verified with Python 3.14.3"]
    - [broken_mro_len,  BrokenExecutor.__mro__.__len__,     [],                               5,    "BrokenExecutor.__mro__.__len__() == 5 — MRO: (BrokenExecutor, RuntimeError, Exception, BaseException, object); verified with Python 3.14.3"]

