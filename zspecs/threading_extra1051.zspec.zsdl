spec: threading_extra1051
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks threading error conditions for Barrier and semaphores, plus class introspection for Thread and Event"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra1051.error_conditions:
  description: "threading error conditions that must raise"
  kind: python_call_raises
  category: error_conditions
  id_prefix: th1051x
  columns: [id, function, args, expected]
  rows:
    - [th1051x001, threading.Barrier,                              [0],                              ValueError]
    - [th1051x002, threading.Barrier,                              [-1],                             ValueError]
    - [th1051x003, threading.Barrier,                              [-100],                           ValueError]
    - [th1051x004, threading.BoundedSemaphore,                     [-1],                             ValueError]
    - [th1051x005, threading.BoundedSemaphore,                     [-50],                            ValueError]
    - [th1051x006, threading.Semaphore,                            [-1],                             ValueError]
    - [th1051x007, threading.Semaphore,                            [-99],                            ValueError]

table threading_extra1051.class_introspection:
  description: "threading class attribute identity checks"
  kind: python_call_eq
  category: class_introspection
  id_prefix: th1051c
  columns: [id, function, args, expected]
  rows:
    - [th1051c001, threading.Thread.__module__.__eq__,                       ["threading"],                   true]
    - [th1051c002, threading.Thread.__qualname__.__eq__,                     ["Thread"],                      true]
    - [th1051c003, threading.Thread.__init_subclass__.__qualname__.__eq__,   ["object.__init_subclass__"],    true]
    - [th1051c004, threading.Event.__module__.__eq__,                        ["threading"],                   true]
    - [th1051c005, threading.Event.__qualname__.__eq__,                      ["Event"],                       true]
    - [th1051c006, threading.Event.__init_subclass__.__qualname__.__eq__,    ["object.__init_subclass__"],    true]
    - [th1051c007, threading.BoundedSemaphore.__module__.__eq__,             ["threading"],                   true]
    - [th1051c008, threading.BoundedSemaphore.__qualname__.__eq__,           ["BoundedSemaphore"],            true]

table threading_extra1051.module_introspection:
  description: "threading module-level name and identity checks"
  kind: python_call_eq
  category: module_introspection
  id_prefix: th1051m
  columns: [id, function, args, expected]
  rows:
    - [th1051m001, threading.Semaphore.__module__.__eq__,                    ["threading"],                   true]
    - [th1051m002, threading.Semaphore.__qualname__.__eq__,                  ["Semaphore"],                   true]
    - [th1051m003, threading.Lock.__class__.__name__.__eq__,                 ["type"],                        true]
    - [th1051m004, threading.RLock.__class__.__name__.__eq__,                ["type"],                        true]
    - [th1051m005, threading.Condition.__module__.__eq__,                    ["threading"],                   true]
    - [th1051m006, threading.Condition.__qualname__.__eq__,                  ["Condition"],                   true]
    - [th1051m007, threading.Timer.__module__.__eq__,                        ["threading"],                   true]
    - [th1051m008, threading.Timer.__qualname__.__eq__,                      ["Timer"],                       true]
