spec: bisect_extra3
version: ">=3.9"
backend: python_module(bisect)

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "Python bisect documentation — https://docs.python.org/3/library/bisect.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/bisect.py"
    - "CPython source: Modules/_bisectmodule.c"
  notes:
    - "This spec extends bisect.zspec.zsdl, bisect_extra.zspec.zsdl, and bisect_extra2.zspec.zsdl."
    - "bisect.zspec.zsdl covers: bisect_left/bisect_right tables; duplicates; bisect alias; lo/hi; bisect_left/__name__; bisect_right/__name__; insort/__name__=='insort_right'."
    - "bisect_extra.zspec.zsdl covers: bisect_left.__name__/__module__=='_bisect'; bisect_right.__name__; insort_left/__name__; insort_right/__name__; bisect.__name__=='bisect_right'; insort.__name__=='insort_right'; behavioral invariants for [1,2,3,4,5] and [1,2,3,3,3,4]."
    - "bisect_extra2.zspec.zsdl covers: insort/__name__; insort_left/__name__; insort_right/__name__; bisect/__name__; bisect_left gap bisect_left([1,3,5,7], 4)==2."
    - "This spec adds: __module__ for bisect/bisect_right/insort/insort_left/insort_right; bisect([1,2,3,4,5], 3)==3; bisect_left([1,2,3,4,5], 3)==2 with [1..5]; bisect_right([1,2,3,4,5], 3)==3 with [1..5]."
    - "bisect.__module__ == '_bisect' — bisect is an alias for bisect_right, the C implementation."
    - "bisect_right.__module__ == '_bisect' — the C extension module implements bisect_right."
    - "insort.__module__ == '_bisect' — insort is an alias for insort_right, the C implementation."
    - "insort_left.__module__ == '_bisect' — insort_left is implemented in the C extension."
    - "insort_right.__module__ == '_bisect' — insort_right is implemented in the C extension."
    - "bisect([1,2,3,4,5], 3) == 3 — bisect is an alias for bisect_right; right insertion point for 3."
    - "bisect_left([1,2,3,4,5], 3) == 2 — left insertion point: index of first occurrence of 3."
    - "bisect_right([1,2,3,4,5], 3) == 3 — right insertion point: one past 3."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ attributes — all C-implemented functions live in '_bisect'
# bisect_left.__module__=='_bisect' is already in bisect_extra; all others are NEW.
# ---------------------------------------------------------------------------

invariant bisect_extra3.bisect.module:
  description: "bisect.bisect.__module__ == '_bisect' — bisect is an alias for the C-implemented bisect_right"
  category: function_modules
  kind: python_call_eq
  function: bisect.__module__.__eq__
  args: ["_bisect"]
  expected: true

invariant bisect_extra3.bisect_right.module:
  description: "bisect.bisect_right.__module__ == '_bisect' — C implementation"
  category: function_modules
  kind: python_call_eq
  function: bisect_right.__module__.__eq__
  args: ["_bisect"]
  expected: true

invariant bisect_extra3.insort.module:
  description: "bisect.insort.__module__ == '_bisect' — insort is an alias for the C-implemented insort_right"
  category: function_modules
  kind: python_call_eq
  function: insort.__module__.__eq__
  args: ["_bisect"]
  expected: true

invariant bisect_extra3.insort_left.module:
  description: "bisect.insort_left.__module__ == '_bisect' — C implementation"
  category: function_modules
  kind: python_call_eq
  function: insort_left.__module__.__eq__
  args: ["_bisect"]
  expected: true

invariant bisect_extra3.insort_right.module:
  description: "bisect.insort_right.__module__ == '_bisect' — C implementation"
  category: function_modules
  kind: python_call_eq
  function: insort_right.__module__.__eq__
  args: ["_bisect"]
  expected: true

# ---------------------------------------------------------------------------
# __name__ attributes — included for completeness alongside __module__
# (Some already in prior specs; included here paired with __module__ invariants)
# ---------------------------------------------------------------------------

invariant bisect_extra3.bisect_left.name:
  description: "bisect.bisect_left.__name__ == 'bisect_left'"
  category: function_names
  kind: python_call_eq
  function: bisect_left.__name__.__eq__
  args: ["bisect_left"]
  expected: true

invariant bisect_extra3.bisect_right.name:
  description: "bisect.bisect_right.__name__ == 'bisect_right'"
  category: function_names
  kind: python_call_eq
  function: bisect_right.__name__.__eq__
  args: ["bisect_right"]
  expected: true

invariant bisect_extra3.insort_left.name:
  description: "bisect.insort_left.__name__ == 'insort_left'"
  category: function_names
  kind: python_call_eq
  function: insort_left.__name__.__eq__
  args: ["insort_left"]
  expected: true

invariant bisect_extra3.insort_right.name:
  description: "bisect.insort_right.__name__ == 'insort_right'"
  category: function_names
  kind: python_call_eq
  function: insort_right.__name__.__eq__
  args: ["insort_right"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral invariants — [1, 2, 3, 4, 5] (distinct, 5 elements)
#
# bisect_extra covers the same list; here we verify the three required
# insertion-point relationships with explicit description annotations.
# ---------------------------------------------------------------------------

invariant bisect_extra3.bisect.right_point_for_3:
  description: "bisect.bisect([1,2,3,4,5], 3) == 3 — right insertion point is one past 3"
  category: behavior
  kind: python_call_eq
  function: bisect
  args: [[1, 2, 3, 4, 5], 3]
  expected: 3

invariant bisect_extra3.bisect_left.left_point_for_3:
  description: "bisect.bisect_left([1,2,3,4,5], 3) == 2 — left insertion point is index of first 3"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[1, 2, 3, 4, 5], 3]
  expected: 2

invariant bisect_extra3.bisect_right.right_point_for_3:
  description: "bisect.bisect_right([1,2,3,4,5], 3) == 3 — right insertion point is one past 3"
  category: behavior
  kind: python_call_eq
  function: bisect_right
  args: [[1, 2, 3, 4, 5], 3]
  expected: 3

# ---------------------------------------------------------------------------
# Behavioral edge cases — bisect on boundary and absent values
# ---------------------------------------------------------------------------

invariant bisect_extra3.bisect.before_all:
  description: "bisect.bisect([1,2,3,4,5], 0) == 0 — right insertion point before all elements"
  category: behavior
  kind: python_call_eq
  function: bisect
  args: [[1, 2, 3, 4, 5], 0]
  expected: 0

invariant bisect_extra3.bisect.after_all:
  description: "bisect.bisect([1,2,3,4,5], 6) == 5 — right insertion point after all elements"
  category: behavior
  kind: python_call_eq
  function: bisect
  args: [[1, 2, 3, 4, 5], 6]
  expected: 5
