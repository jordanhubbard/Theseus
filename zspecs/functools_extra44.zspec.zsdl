spec: functools_extra44
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra43.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for wraps/partial/lru_cache/total_ordering/singledispatch/cached_property/reduce/cmp_to_key/partialmethod/singledispatchmethod/update_wrapper; __qualname__.__len__() for update_wrapper/partialmethod/singledispatchmethod/cache/total_ordering/singledispatch/cmp_to_key/cached_property/lru_cache/wraps/reduce/partial; WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES lengths; __all__ lengths and indexed elements; partial/__class__.__name__; __cached__.__class__.__name__; cached_property.__set_name__/__get__/__init__.__qualname__; total_ordering.__dict__.__class__.__name__; partial/__new__.__qualname__; class __dict__.__class__.__name__.__len__ for partial/partialmethod/singledispatchmethod/cached_property; partial/__doc__/reduce/__doc__; reduce with initial value; lru_cache(128).__ne__(None)==True; C-extension vs pure-Python __module__ lengths for reduce/cmp_to_key/lru_cache/wraps/update_wrapper; lru_cache(maxsize=2) behavioral."
    - "This spec covers: partial.__name__ == 'partial'; partial.__qualname__ == 'partial'; partial.__module__ == 'functools'; WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'; WRAPPER_ASSIGNMENTS.__len__() == 6 (Python 3.12 added __annotate__ and __type_params__ to the original 4-element tuple, making it 6); WRAPPER_UPDATES.__len__() == 1 ('__dict__'); lru_cache.__name__ == 'lru_cache'; lru_cache.__module__ == 'functools'."
    - "Key findings: functools.partial.__name__ and functools.partial.__qualname__ are both 'partial' (7 chars), confirming the C-extension type has no enclosing class scope (__qualname__ == __name__). functools.partial.__module__ is 'functools' (9 chars) — note that partial is a C type defined in _functoolsmodule.c, but its __module__ attribute is set to 'functools' (not '_functools') via the type definition. functools.WRAPPER_ASSIGNMENTS.__len__() is 6 on Python 3.12/3.13: the classic 5 elements (__module__/__name__/__qualname__/__annotations__/__doc__) plus __annotate__ and __type_params__ were added; the task description's expectation of 5 was based on Python <3.12. functools.WRAPPER_UPDATES.__len__() is 1 — only '__dict__' has ever been in this tuple. functools.lru_cache.__name__ is 'lru_cache' (9 chars) and __module__ is 'functools' — consistent with prior spec recording lru_cache.__module__.__len__()==9. No prior functools spec records partial.__name__, partial.__qualname__, partial.__module__, WRAPPER_ASSIGNMENTS class type, WRAPPER_ASSIGNMENTS length, WRAPPER_UPDATES length, lru_cache.__name__, or lru_cache.__module__ as string equality invariants in the extra44 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.partial identity metadata — extra44 namespace
#
# functools.partial.__name__ is 'partial' and functools.partial.__qualname__ is
# 'partial' — for top-level C-extension types, __qualname__ == __name__ because
# there is no enclosing class scope. functools.partial.__module__ is 'functools'
# (9 chars) — although partial is implemented in Modules/_functoolsmodule.c, the
# type's __module__ is explicitly set to 'functools' in the C source, unlike
# functools.reduce and functools.cmp_to_key whose __module__ is '_functools'
# (10 chars). No prior functools spec records these three string equality
# invariants for partial in the extra44 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra44.partial_name:
  description: "functools.partial.__name__ == 'partial' — C-extension type; __name__ is the unqualified type name"
  category: identity
  kind: python_call_eq
  function: partial.__name__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra44.partial_qualname:
  description: "functools.partial.__qualname__ == 'partial' — top-level C type; __qualname__ == __name__ (no enclosing class scope)"
  category: identity
  kind: python_call_eq
  function: partial.__qualname__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra44.partial_module:
  description: "functools.partial.__module__ == 'functools' — C type whose __module__ is set to 'functools', not '_functools' (contrast with reduce/__module__=='_functools')"
  category: module_metadata
  kind: python_call_eq
  function: partial.__module__.__eq__
  args: ["functools"]
  expected: true

# ---------------------------------------------------------------------------
# functools.WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES — extra44 namespace
#
# functools.WRAPPER_ASSIGNMENTS is a tuple (class name 'tuple') with 6 elements
# on Python 3.12+: '__module__', '__name__', '__qualname__', '__doc__',
# '__annotate__', '__type_params__'. The classic documentation lists 5 elements
# (__annotations__ replaced __annotate__ and __type_params__ were added in
# Python 3.12/3.13). functools.WRAPPER_UPDATES is a tuple with 1 element:
# '__dict__'. No prior functools spec records the class type assertion for
# WRAPPER_ASSIGNMENTS or the length-6 assertion in the extra44 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra44.WRAPPER_ASSIGNMENTS_class:
  description: "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple' — the assignments constant is a plain Python tuple"
  category: identity
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra44.WRAPPER_ASSIGNMENTS_len:
  description: "len(functools.WRAPPER_ASSIGNMENTS) == 6 — Python 3.12+ tuple: __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__ (6 elements; prior docs listed 5 before __annotate__/__type_params__ were added)"
  category: module_metadata
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

invariant functools_extra44.WRAPPER_UPDATES_len:
  description: "len(functools.WRAPPER_UPDATES) == 1 — only '__dict__' has ever been in this tuple; update_wrapper merges the wrapped function's __dict__ into the wrapper's __dict__"
  category: module_metadata
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# functools.lru_cache identity metadata — extra44 namespace
#
# functools.lru_cache.__name__ is 'lru_cache' (9 chars) and functools.lru_cache.
# __module__ is 'functools' (9 chars). Prior specs recorded lru_cache.__module__
# .__len__()==9 and lru_cache.__name__.__len__()==9, but not the exact string
# equality invariants. These string-equality invariants confirm that lru_cache
# is the pure-Python decorator whose name and module name happen to share the
# same character count (9). No prior functools spec records these two equality
# invariants for lru_cache in the extra44 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra44.lru_cache_name:
  description: "functools.lru_cache.__name__ == 'lru_cache' — pure-Python decorator; 9-char name matches __module__.__len__()==9"
  category: identity
  kind: python_call_eq
  function: lru_cache.__name__.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra44.lru_cache_module:
  description: "functools.lru_cache.__module__ == 'functools' — pure-Python function in Lib/functools.py; 9-char module name matches lru_cache.__name__.__len__()==9"
  category: module_metadata
  kind: python_call_eq
  function: lru_cache.__module__.__eq__
  args: ["functools"]
  expected: true
