spec: uuid_extra214
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.UUID.__class__.__name__ == 'type' — UUID is a type object."
    - "uuid.UUID.__mro__.__len__() == 2 — UUID MRO: UUID -> object (2 entries)."
    - "uuid.UUID.__mro__[0].__name__ == 'UUID' — first MRO entry is UUID itself."
    - "uuid.UUID.__mro__[1].__name__ == 'object' — second MRO entry is object."
    - "uuid.uuid1.__class__.__name__ == 'function' — uuid1 is a pure Python function."
    - "uuid.uuid4.__class__.__name__ == 'function' — uuid4 is a pure Python function."
    - "uuid.uuid5.__class__.__name__ == 'function' — uuid5 is a pure Python function."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' — NAMESPACE_DNS is a UUID instance."
    - "uuid.UUID.hex.__class__.__name__ == 'property' — hex is a property descriptor."
    - "uuid.UUID.int.__class__.__name__ == 'member_descriptor' — int is a member_descriptor (C-level slot)."
    - "uuid.UUID.version.__class__.__name__ == 'property' — version is a property descriptor."
    - "uuid.UUID.node.__class__.__name__ == 'property' — node is a property descriptor."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid UUID class MRO contracts
#
# uuid.UUID.__class__.__name__      == 'type'
# uuid.UUID.__mro__.__len__()       == 2
# uuid.UUID.__mro__[0].__name__     == 'UUID'
# uuid.UUID.__mro__[1].__name__     == 'object'
# ---------------------------------------------------------------------------

table uuid_extra214.UUID_class_mro_contracts:
  description: "uuid UUID class MRO contracts in uuid214 namespace — wave 214 theme: UUID is a type; MRO is UUID -> object (length 2); uuid1/uuid4/uuid5 are pure Python functions; NAMESPACE_DNS is a UUID instance; hex/version/node are property descriptors; UUID.int is a member_descriptor (C-level slot); verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: uuid214

  columns: [id, function, args, expected, description]
  rows:
    - [UUID_class_name,      uuid.UUID.__class__.__name__.__eq__,            ["type"],             true, "uuid.UUID.__class__.__name__ == 'type' — UUID is a type (metaclass is type)"]
    - [UUID_mro_len,         uuid.UUID.__mro__.__len__,                      [],                   2,    "uuid.UUID.__mro__.__len__() == 2 — UUID MRO has 2 entries: UUID and object"]
    - [UUID_mro_0_name,      "uuid.UUID.__mro__[0].__name__.__eq__",         ["UUID"],             true, "uuid.UUID.__mro__[0].__name__ == 'UUID' — first MRO entry is UUID itself"]
    - [UUID_mro_1_name,      "uuid.UUID.__mro__[1].__name__.__eq__",         ["object"],           true, "uuid.UUID.__mro__[1].__name__ == 'object' — second MRO entry is object; no intermediate bases"]
    - [uuid1_class_name,     uuid.uuid1.__class__.__name__.__eq__,           ["function"],         true, "uuid.uuid1.__class__.__name__ == 'function' — uuid1 is a pure Python function"]
    - [uuid4_class_name,     uuid.uuid4.__class__.__name__.__eq__,           ["function"],         true, "uuid.uuid4.__class__.__name__ == 'function' — uuid4 is a pure Python function"]
    - [uuid5_class_name,     uuid.uuid5.__class__.__name__.__eq__,           ["function"],         true, "uuid.uuid5.__class__.__name__ == 'function' — uuid5 is a pure Python function"]
    - [NAMESPACE_DNS_class,  uuid.NAMESPACE_DNS.__class__.__name__.__eq__,   ["UUID"],             true, "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' — NAMESPACE_DNS is an instance of UUID"]
    - [UUID_hex_class,       uuid.UUID.hex.__class__.__name__.__eq__,        ["property"],         true, "uuid.UUID.hex.__class__.__name__ == 'property' — hex is a property descriptor on the UUID class"]
    - [UUID_int_class,       uuid.UUID.int.__class__.__name__.__eq__,        ["member_descriptor"], true, "uuid.UUID.int.__class__.__name__ == 'member_descriptor' — int is a C-level slot member descriptor"]

# ---------------------------------------------------------------------------
# uuid.UUID property descriptor checks
#
# uuid.UUID.version.__class__.__name__ == 'property'
# uuid.UUID.node.__class__.__name__    == 'property'
# ---------------------------------------------------------------------------

table uuid_extra214.UUID_property_descriptors:
  description: "uuid.UUID property descriptor class checks in uuid214a namespace — wave 214 theme: version and node are property descriptors on the UUID class; these access computed attributes from the internal UUID integer value; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: uuid214a

  columns: [id, function, args, expected, description]
  rows:
    - [UUID_version_class,   uuid.UUID.version.__class__.__name__.__eq__,    ["property"],  true, "uuid.UUID.version.__class__.__name__ == 'property' — version is a property descriptor"]
    - [UUID_node_class,      uuid.UUID.node.__class__.__name__.__eq__,       ["property"],  true, "uuid.UUID.node.__class__.__name__ == 'property' — node is a property descriptor"]

# ---------------------------------------------------------------------------
# Standalone invariants for UUID MRO entries using integer-indexed access
# ---------------------------------------------------------------------------

invariant uuid_extra214.UUID_mro_entry0_name_eq:
  description: "uuid.UUID.__mro__[0].__name__.__eq__('UUID') == True — first MRO entry of UUID is UUID itself; pure Python class defined in Lib/uuid.py; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "uuid.UUID.__mro__[0].__name__.__eq__"
  args: ["UUID"]
  expected: true

invariant uuid_extra214.UUID_mro_entry1_name_eq:
  description: "uuid.UUID.__mro__[1].__name__.__eq__('object') == True — second and final MRO entry is object; UUID has no intermediate base classes; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "uuid.UUID.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true
