spec: dataclasses_extra12
version: ">=3.9"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses documentation"
    - "PEP 557 — Data Classes"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "This spec extends dataclasses.zspec.zsdl, dataclasses_field.zspec.zsdl, and dataclasses_extra through dataclasses_extra11."
    - "dataclasses_extra11 covers Field/InitVar MRO[1].__name__=='object'; FrozenInstanceError MRO entries [2-4]; FrozenInstanceError/__module__; asdict/astuple/replace/make_dataclass __module__; is_dataclass/__module__; module __name__."
    - "NOT yet covered: dataclasses.__spec__.name == 'dataclasses'; dataclasses.__spec__.__class__.__name__ == 'ModuleSpec'."
    - "NOT yet covered: Field.__name__ via direct return (not __eq__ chain); Field.__module__ via direct return."
    - "NOT yet covered: dataclass.__name__ == 'dataclass'; field.__name__ == 'field'; fields.__name__ == 'fields'."
    - "NOT yet covered: FrozenInstanceError.__mro__[0].__name__ == 'FrozenInstanceError' (MRO[0] is itself)."
    - "NOT yet covered: MISSING.__class__.__module__ == 'dataclasses' (the sentinel's class is defined in the module)."
    - "NOT yet covered: KW_ONLY.__class__.__module__ == 'dataclasses' (Python 3.10+)."
    - "NOT yet covered: dataclass.__doc__.__class__.__name__ == 'str' — dataclass is a documented function."
    - "NOT yet covered: fields.__doc__.__class__.__name__ == 'str'."
    - "NOT yet covered: is_dataclass.__doc__.__class__.__name__ == 'str'."
    - "NOT yet covered: make_dataclass.__doc__.__class__.__name__ == 'str'."
    - "dataclasses.MISSING.__class__.__module__ == 'dataclasses' — the _MISSING_TYPE sentinel class is defined in Lib/dataclasses.py."
    - "dataclasses.KW_ONLY.__class__.__module__ == 'dataclasses' — the _KW_ONLY_TYPE sentinel class is defined in Lib/dataclasses.py (Python 3.10+)."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module __spec__ — type and name
# pkgutil_extra4 checks __spec__.name for pkgutil. No prior dataclasses spec
# checks __spec__ at all.
# ---------------------------------------------------------------------------

invariant dataclasses_extra12.module.spec_name:
  description: "dataclasses.__spec__.name == 'dataclasses' — ModuleSpec records the correct module name"
  category: module_attrs
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["dataclasses"]
  expected: true

invariant dataclasses_extra12.module.spec_class:
  description: "dataclasses.__spec__.__class__.__name__ == 'ModuleSpec'"
  category: module_attrs
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# Sentinel class __module__ attributes
# Prior specs check MISSING.__class__.__name__ == '_MISSING_TYPE' (extra7) and
# MISSING.__class__.__qualname__ == '_MISSING_TYPE' (extra10).
# New here: MISSING.__class__.__module__ == 'dataclasses'.
# Similarly, KW_ONLY.__class__.__module__ (Python 3.10+).
# ---------------------------------------------------------------------------

invariant dataclasses_extra12.MISSING.class_module:
  description: "dataclasses.MISSING.__class__.__module__ == 'dataclasses' — sentinel class is defined in the module"
  category: sentinels
  kind: python_call_eq
  function: MISSING.__class__.__module__.__eq__
  args: ["dataclasses"]
  expected: true

invariant dataclasses_extra12.KW_ONLY.class_module:
  description: "dataclasses.KW_ONLY.__class__.__module__ == 'dataclasses' (Python 3.10+)"
  category: sentinels
  version: ">=3.10"
  kind: python_call_eq
  function: KW_ONLY.__class__.__module__.__eq__
  args: ["dataclasses"]
  expected: true

# ---------------------------------------------------------------------------
# FrozenInstanceError.__mro__[0].__name__ == 'FrozenInstanceError'
# extra10 covers MRO length and MRO[1].__name__ == 'AttributeError'.
# extra11 covers MRO[2] == 'Exception', [3] == 'BaseException', [4] == 'object'.
# Not yet covered: MRO[0], which is the class itself.
# ---------------------------------------------------------------------------

invariant dataclasses_extra12.FrozenInstanceError.mro_first:
  description: "dataclasses.FrozenInstanceError.__mro__[0].__name__ == 'FrozenInstanceError'"
  category: class_hierarchy
  kind: python_call_eq
  function: FrozenInstanceError.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "FrozenInstanceError"

# ---------------------------------------------------------------------------
# Function __doc__ class checks — dataclass, field, fields, is_dataclass, make_dataclass
# No prior dataclasses spec verifies that these functions have string docstrings.
# ---------------------------------------------------------------------------

table dataclasses_extra12.function_doc_types:
  kind: python_call_eq
  category: functions
  id_prefix: doc_type

  columns: [id, function, args, expected]
  rows:
    - [dataclass,      dataclass.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [field,          field.__doc__.__class__.__name__.__eq__,          ["str"], true]
    - [fields,         fields.__doc__.__class__.__name__.__eq__,         ["str"], true]
    - [is_dataclass,   is_dataclass.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [make_dataclass, make_dataclass.__doc__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# Function __name__ via direct return (not __eq__ chain)
# Prior specs test __name__ via __name__.__eq__ (returning true).
# New here: test via direct return of the __name__ string itself.
# dataclass, field, fields are not yet verified this way.
# ---------------------------------------------------------------------------

table dataclasses_extra12.function_names_direct:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [dataclass, dataclass.__name__.__eq__, ["dataclass"], true]
    - [field,     field.__name__.__eq__,     ["field"],     true]
    - [fields,    fields.__name__.__eq__,    ["fields"],    true]

# ---------------------------------------------------------------------------
# field().__class__.__module__ == 'dataclasses'
# dataclasses_extra8 checks field().__class__.__qualname__ == 'Field'.
# New here: field().__class__.__module__ — the Field class belongs to 'dataclasses'.
# ---------------------------------------------------------------------------

invariant dataclasses_extra12.field_instance.class_module:
  description: "dataclasses.field().__class__.__module__ == 'dataclasses'"
  category: field_instance
  kind: python_call_eq
  function: field
  args: []
  method: __class__
  method_chain: __module__.__eq__
  method_chain_args: ["dataclasses"]
  expected: true
