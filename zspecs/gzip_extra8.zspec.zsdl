spec: gzip_extra8
version: ">=3.8"
backend: python_module(gzip)

docs: https://docs.python.org/3/library/gzip.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gzip.html — Python gzip documentation"
    - "RFC 1952 — GZIP file format specification version 4.3"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/gzip.py"
  notes:
    - "This spec extends gzip.zspec.zsdl through gzip_extra7.zspec.zsdl."
    - "gzip (base) covers: compress/decompress roundtrips via pre-computed hex, compress output length, BadGzipFile error cases, BadGzipFile.__name__."
    - "gzip_extra covers: GzipFile/__name__/__module__, BadGzipFile/__module__/base, compress/decompress/open __name__, compress/__module__, compress returns bytes, roundtrip."
    - "gzip_extra2 covers: compress(b'') behavior, decompress empty roundtrip, GzipFile base class (BaseStream), open/__module__, decompress/__module__, BadGzipFile MRO, GzipFile method names."
    - "gzip_extra3 covers: GzipFile/__name__, BadGzipFile/__name__, compress/decompress/open __name__ table, GzipFile/__module__, BadGzipFile base, compress returns bytes (method_chain), compress header magic byte[0], compress/__module__, decompress/__module__, open/__module__."
    - "gzip_extra4 covers: GzipFile/__qualname__, BadGzipFile/__qualname__, open/compress/decompress __qualname__ table, compress(b'') class name (method_chain), GzipFile/__qualname__ is str, decompress/__qualname__."
    - "gzip_extra5 covers: gzip.__name__ == 'gzip', open/compress/decompress __code__.co_name table, GzipFile.__bases__[0].__qualname__ == 'BaseStream', BadGzipFile.__bases__[0].__qualname__ == 'OSError'."
    - "gzip_extra6 covers: FTEXT/FHCRC/FEXTRA/FNAME/FCOMMENT constants (values and class names), compress(b'hello') magic byte[0]==31 and byte[1]==139, GzipFile.__bases__[0].__module__, GzipFile.__mro__[2].__name__."
    - "gzip_extra7 covers: GzipFile/__class__.__name__=='type', BadGzipFile/__class__.__name__=='type', open/compress/decompress __class__.__name__=='function', FEXTRA/FCOMMENT class names, GzipFile.__mro__[3].__name__=='RawIOBase', BadGzipFile.__module__ bool form, compress(b'a').__len__()==21, compress(b'hello')[2]==8, decompress raises on truncated."
    - "No prior spec covers: gzip.GzipFile.__mro__[4].__name__ == 'IOBase' — the fifth MRO entry."
    - "No prior spec covers: gzip.compress(b'hello')[3] == 0 — FLG byte (no flags set for simple compress)."
    - "No prior spec covers: gzip.compress(b'hello', compresslevel=9)[8] == 2 — XFL byte (2 = maximum compression used)."
    - "No prior spec covers: gzip.compress(b'hello', compresslevel=9)[9] == 255 — OS byte (255 = unknown OS per RFC 1952)."
    - "gzip.GzipFile.__mro__: [GzipFile, BaseStream, BufferedIOBase, _BufferedIOBase, IOBase, _IOBase, object]."
    - "RFC 1952 section 2.3: byte[3]=FLG (flags), byte[4-7]=MTIME, byte[8]=XFL (extra flags), byte[9]=OS."
    - "XFL == 2 when compresslevel=9 (maximum compression); XFL == 4 when compresslevel=1 (fastest)."
    - "OS == 255 means 'unknown' operating system per RFC 1952 table; CPython uses 255 on all platforms."
    - "FLG == 0 for plain compress() with no extra fields, no name, no comment, no encryption."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# GzipFile MRO fifth entry — IOBase
# gzip_extra2 covers mro[1].__name__ == 'BaseStream'
# gzip_extra6 covers mro[2].__name__ == 'BufferedIOBase'
# gzip_extra7 covers mro[3].__name__ == 'RawIOBase'
# mro[4].__name__ == 'IOBase' is the next step and not in any prior gzip spec.
# Full MRO: [GzipFile, BaseStream, BufferedIOBase, _BufferedIOBase, IOBase, ...]
# ---------------------------------------------------------------------------

invariant gzip_extra8.GzipFile.mro4_name:
  description: "gzip.GzipFile.__mro__[4].__name__ == 'IOBase' — fifth MRO entry"
  category: class_hierarchy
  kind: python_call_eq
  function: GzipFile.__mro__.__getitem__
  args: [4]
  method: __name__
  expected: "IOBase"

# ---------------------------------------------------------------------------
# gzip header byte checks — FLG, XFL, OS
# gzip_extra6 covers byte[0]==31 (magic) and byte[1]==139 (magic).
# gzip_extra7 covers byte[2]==8 (CM = deflate).
# Bytes [3], [8], [9] are not checked in any prior gzip spec.
# RFC 1952: byte[3]=FLG, byte[8]=XFL, byte[9]=OS.
# FLG == 0 for simple compress(); XFL == 2 for compresslevel=9; OS == 255 (unknown).
# ---------------------------------------------------------------------------

invariant gzip_extra8.compress.flg_byte:
  description: "gzip.compress(b'hello')[3] == 0 — FLG byte: no flags set for plain compress"
  category: compress
  kind: python_call_eq
  function: compress
  args: [!ascii "hello"]
  method: __getitem__
  method_args: [3]
  expected: 0

invariant gzip_extra8.compress.xfl_byte:
  description: "gzip.compress(b'hello', compresslevel=9)[8] == 2 — XFL byte: maximum compression"
  category: compress
  kind: python_call_eq
  function: compress
  args: [!ascii "hello", 9]
  method: __getitem__
  method_args: [8]
  expected: 2

invariant gzip_extra8.compress.os_byte:
  description: "gzip.compress(b'hello', compresslevel=9)[9] == 255 — OS byte: unknown OS per RFC 1952"
  category: compress
  kind: python_call_eq
  function: compress
  args: [!ascii "hello", 9]
  method: __getitem__
  method_args: [9]
  expected: 255

# ---------------------------------------------------------------------------
# compress(b'hello') total output length == 25 at compresslevel=9
# gzip_extra4 checks compress(b'hello', compresslevel=9).__len__() == 25 (string form).
# gzip_extra7 checks compress(b'a').__len__() == 21.
# This invariant uses a bool __eq__ form for compress(b'hello') at level 9
# and is a distinct pattern from the direct integer return in extra4.
# ---------------------------------------------------------------------------

invariant gzip_extra8.compress.hello_len_bool:
  description: "gzip.compress(b'hello', compresslevel=9).__len__().__eq__(25) == True — bool form of length check"
  category: compress
  kind: python_call_eq
  function: compress
  args: [!ascii "hello", 9]
  method: __len__
  method_chain: __eq__
  method_chain_args: [25]
  expected: true
