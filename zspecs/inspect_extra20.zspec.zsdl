spec: inspect_extra20
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect_extra19.zspec.zsdl — covers getmembers/__name__/__module__/__qualname__; signature/__name__/__module__/__qualname__; predicate __qualname__ table for ismodule/isclass/isfunction/ismethod/isbuiltin"
    - "inspect_extra18.zspec.zsdl — covers __name__ for isfunction/ismethod/isclass/ismodule/isbuiltin/isgenerator/iscoroutine; __module__ table; predicate-on-value checks"
    - "inspect_extra15.zspec.zsdl — covers __name__ and __qualname__ table for isfunction/isbuiltin/isclass/ismodule/ismethod/ismethoddescriptor; Signature/BoundArguments/Parameter __module__ and __qualname__"
    - "inspect_extra16.zspec.zsdl — covers __qualname__ for isgenerator/iscoroutine/isasyncgen/isabstract; __module__ for isclass/ismodule/isfunction/ismethod etc."
  notes:
    - "This spec extends inspect.zspec.zsdl and prior extras through inspect_extra19.zspec.zsdl."
    - "Focus: class hierarchy for inspect's public class types — __bases__[0].__name__ and __bases__.__len__() for Parameter, Signature, BoundArguments, FullArgSpec, and FrameInfo."
    - "inspect.Parameter.__bases__[0].__name__ == 'object' — Parameter is a plain Python class with no special base."
    - "inspect.Signature.__bases__[0].__name__ == 'object' — Signature is a plain Python class with no special base."
    - "inspect.BoundArguments.__bases__[0].__name__ == 'object' — BoundArguments is a plain Python class with no special base."
    - "inspect.FullArgSpec.__bases__[0].__name__ == 'tuple' — FullArgSpec is a namedtuple, its direct base is tuple."
    - "inspect.FrameInfo.__bases__[0].__name__ == '_FrameInfo' — FrameInfo is a namedtuple subclass wrapping _FrameInfo."
    - "inspect.FullArgSpec.__mro__.__len__() == 3 — MRO is [FullArgSpec, tuple, object]."
    - "inspect.Parameter.__bases__.__len__() == 1 — single direct base (object)."
    - "inspect.Signature.__bases__.__len__() == 1 — single direct base (object)."
    - "inspect.BoundArguments.__bases__.__len__() == 1 — single direct base (object)."
    - "inspect.FullArgSpec.__bases__.__len__() == 1 — single direct base (tuple)."
    - "inspect.FrameInfo.__bases__.__len__() == 1 — single direct base (_FrameInfo)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bases__[0].__name__ for inspect class types — table
#
# No prior inspect spec checks __bases__[0].__name__ for Parameter, Signature,
# BoundArguments, FullArgSpec, or FrameInfo together in a combined table.
# Parameter/Signature/BoundArguments are plain Python classes inheriting from
# object. FullArgSpec is a namedtuple whose direct base is tuple.
# FrameInfo is a namedtuple subclass whose direct base is _FrameInfo.
# ---------------------------------------------------------------------------

table inspect_extra20.class_bases:
  description: "__bases__[0].__name__ for inspect's public class types"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: base0

  columns: [id, function, args, expected]
  rows:
    - [Parameter,      "Parameter.__bases__.__getitem__(0).__name__.__eq__",      ["object"],    true]
    - [Signature,      "Signature.__bases__.__getitem__(0).__name__.__eq__",      ["object"],    true]
    - [BoundArguments, "BoundArguments.__bases__.__getitem__(0).__name__.__eq__", ["object"],    true]
    - [FullArgSpec,    "FullArgSpec.__bases__.__getitem__(0).__name__.__eq__",    ["tuple"],     true]
    - [FrameInfo,      "FrameInfo.__bases__.__getitem__(0).__name__.__eq__",      ["_FrameInfo"], true]

# ---------------------------------------------------------------------------
# __bases__.__len__() for inspect class types — standalone invariants
#
# All five public inspect classes have exactly one direct base class.
# No prior inspect spec covers __bases__.__len__() for any of these classes.
# ---------------------------------------------------------------------------

invariant inspect_extra20.Parameter.bases_len:
  description: "inspect.Parameter.__bases__.__len__() == 1 — single direct base (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: Parameter.__bases__.__len__
  args: []
  expected: 1

invariant inspect_extra20.Signature.bases_len:
  description: "inspect.Signature.__bases__.__len__() == 1 — single direct base (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: Signature.__bases__.__len__
  args: []
  expected: 1

invariant inspect_extra20.BoundArguments.bases_len:
  description: "inspect.BoundArguments.__bases__.__len__() == 1 — single direct base (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: BoundArguments.__bases__.__len__
  args: []
  expected: 1

invariant inspect_extra20.FullArgSpec.bases_len:
  description: "inspect.FullArgSpec.__bases__.__len__() == 1 — single direct base (tuple, via namedtuple)"
  category: class_hierarchy
  kind: python_call_eq
  function: FullArgSpec.__bases__.__len__
  args: []
  expected: 1

invariant inspect_extra20.FrameInfo.bases_len:
  description: "inspect.FrameInfo.__bases__.__len__() == 1 — single direct base (_FrameInfo)"
  category: class_hierarchy
  kind: python_call_eq
  function: FrameInfo.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# __mro__.__len__() for inspect class types — standalone invariants
#
# Parameter/Signature/BoundArguments each have MRO [Class, object] (len==2).
# FullArgSpec has MRO [FullArgSpec, tuple, object] (len==3) because it is a
# namedtuple. No prior inspect spec covers MRO length for any of these classes.
# ---------------------------------------------------------------------------

invariant inspect_extra20.Parameter.mro_len:
  description: "inspect.Parameter.__mro__.__len__() == 2 — MRO is [Parameter, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: Parameter.__mro__.__len__
  args: []
  expected: 2

invariant inspect_extra20.Signature.mro_len:
  description: "inspect.Signature.__mro__.__len__() == 2 — MRO is [Signature, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: Signature.__mro__.__len__
  args: []
  expected: 2

invariant inspect_extra20.BoundArguments.mro_len:
  description: "inspect.BoundArguments.__mro__.__len__() == 2 — MRO is [BoundArguments, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: BoundArguments.__mro__.__len__
  args: []
  expected: 2

invariant inspect_extra20.FullArgSpec.mro_len:
  description: "inspect.FullArgSpec.__mro__.__len__() == 3 — MRO is [FullArgSpec, tuple, object] (namedtuple)"
  category: class_hierarchy
  kind: python_call_eq
  function: FullArgSpec.__mro__.__len__
  args: []
  expected: 3
