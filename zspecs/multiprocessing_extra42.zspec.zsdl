spec: multiprocessing_extra42
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/exceptions.py"
  notes:
    - "This spec extends multiprocessing_extra41.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', Process.__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() tables, Process method __qualname__.__len__() tables, Pool method tables, Process/Pool __mro__.__len__() tables, __all__ metadata, class __dict__ tables, DefaultContext method qualname lengths, BaseProcess metadata, function __name__.__len__() tables, pool result class tables, Process/__name__=='Process' (extra37), Process/__module__=='multiprocessing.context' (extra37), Queue/__name__=='Queue' (extra37), Pipe/__name__=='Pipe' (extra37), Process method qualname lens for start/join/run (extra37), Process.__bases__[0].__name__=='BaseProcess'/__mro__.__len__()==3/Manager.__name__=='Manager' (extra38), function __name__/__module__ string equality for cpu_count/current_process/active_children (extra38), AuthenticationError/__name__/__module__/__bases__[0].__name__, ProcessError/__name__/__bases__[0].__name__, BufferTooShort/__name__, TimeoutError/__name__/__bases__[0].__name__, all four exception __module__ string equality (extra39), ProcessError/__mro__.__len__()==4, exception subclass MRO depths (5), Process/__qualname__=='Process', Process/__qualname__.__len__()==7, context.BaseContext/__name__=='BaseContext', get_start_method/__name__=='get_start_method' (extra40), Queue/__qualname__=='BaseContext.Queue', Pipe/__qualname__=='BaseContext.Pipe', cpu_count/__qualname__=='BaseContext.cpu_count', current_process/__qualname__=='current_process', active_children/__qualname__=='active_children', get_start_method/__qualname__=='DefaultContext.get_start_method', set_start_method/__name__=='set_start_method' (extra41)."
    - "This spec covers: Process/__qualname__.__len__()==7; ProcessError/__qualname__=='ProcessError' (12 chars); ProcessError/__qualname__.__len__()==12; AuthenticationError/__qualname__=='AuthenticationError' (19 chars); AuthenticationError/__qualname__.__len__()==19; TimeoutError/__qualname__=='TimeoutError' (12 chars); BufferTooShort/__qualname__=='BufferTooShort' (14 chars); BufferTooShort/__qualname__.__len__()==14."
    - "multiprocessing.Process.__qualname__.__len__() == 7. Process.__qualname__ == 'Process' (verified in extra40); len('Process') == 7. Extra42 captures this length in a combined exception/class table context."
    - "multiprocessing.ProcessError.__qualname__ == 'ProcessError' (12 chars). ProcessError is a top-level exception class in multiprocessing; __qualname__ equals __name__ for top-level classes. len('ProcessError') == 12: P-r-o-c-e-s-s-E-r-r-o-r = 12."
    - "multiprocessing.ProcessError.__qualname__.__len__() == 12. ProcessError.__qualname__ == 'ProcessError'; len('ProcessError') == 12."
    - "multiprocessing.AuthenticationError.__qualname__ == 'AuthenticationError' (19 chars). AuthenticationError is a top-level exception class; __qualname__ equals __name__. len('AuthenticationError') == 19: A-u-t-h-e-n-t-i-c-a-t-i-o-n-E-r-r-o-r = 19."
    - "multiprocessing.AuthenticationError.__qualname__.__len__() == 19. AuthenticationError.__qualname__ == 'AuthenticationError'; len('AuthenticationError') == 19."
    - "multiprocessing.TimeoutError.__qualname__ == 'TimeoutError' (12 chars). TimeoutError is a top-level exception class; __qualname__ equals __name__. len('TimeoutError') == 12. Note: ProcessError and TimeoutError share the same __qualname__ length of 12."
    - "multiprocessing.BufferTooShort.__qualname__ == 'BufferTooShort' (14 chars). BufferTooShort is a top-level exception class; __qualname__ equals __name__. len('BufferTooShort') == 14: B-u-f-f-e-r-T-o-o-S-h-o-r-t = 14."
    - "multiprocessing.BufferTooShort.__qualname__.__len__() == 14. BufferTooShort.__qualname__ == 'BufferTooShort'; len('BufferTooShort') == 14."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing exception class __qualname__ string equality — extra42 namespace
#
# Four exception classes exposed at the multiprocessing module level:
#   ProcessError.__qualname__        == 'ProcessError'        (12 chars)
#   AuthenticationError.__qualname__ == 'AuthenticationError' (19 chars)
#   TimeoutError.__qualname__        == 'TimeoutError'        (12 chars)
#   BufferTooShort.__qualname__      == 'BufferTooShort'      (14 chars)
# All are top-level classes so __qualname__ equals __name__. ProcessError and
# TimeoutError share the same __qualname__ length of 12.
# AuthenticationError is the longest at 19 characters.
# ---------------------------------------------------------------------------

table multiprocessing_extra42.exception_qualnames:
  description: "multiprocessing exception class __qualname__ string equality in extra42 namespace — ProcessError, AuthenticationError, TimeoutError, BufferTooShort"
  kind: python_call_eq
  category: class_names
  id_prefix: mpexcqualname42

  columns: [id, function, args, expected, description]
  rows:
    - [ProcessError,        ProcessError.__qualname__.__eq__,        ["ProcessError"],        true, "ProcessError.__qualname__ == 'ProcessError' — top-level exception; qualname equals name (12 chars)"]
    - [AuthenticationError, AuthenticationError.__qualname__.__eq__, ["AuthenticationError"], true, "AuthenticationError.__qualname__ == 'AuthenticationError' — top-level exception; qualname equals name (19 chars)"]
    - [TimeoutError,        TimeoutError.__qualname__.__eq__,        ["TimeoutError"],        true, "TimeoutError.__qualname__ == 'TimeoutError' — top-level exception; qualname equals name (12 chars); same length as ProcessError"]
    - [BufferTooShort,      BufferTooShort.__qualname__.__eq__,      ["BufferTooShort"],      true, "BufferTooShort.__qualname__ == 'BufferTooShort' — top-level exception; qualname equals name (14 chars)"]

# ---------------------------------------------------------------------------
# multiprocessing exception class __qualname__ lengths — extra42 namespace
#
# __qualname__.__len__() for Process and the four exception classes:
#   Process.__qualname__.__len__()             ==  7
#   ProcessError.__qualname__.__len__()        == 12
#   AuthenticationError.__qualname__.__len__() == 19
#   TimeoutError.__qualname__.__len__()        == 12
#   BufferTooShort.__qualname__.__len__()      == 14
# Process (7) is the shortest; AuthenticationError (19) is the longest.
# ProcessError and TimeoutError share length 12.
# ---------------------------------------------------------------------------

table multiprocessing_extra42.class_qualname_lengths:
  description: "multiprocessing class __qualname__.__len__() in extra42 namespace — Process, ProcessError, AuthenticationError, TimeoutError, BufferTooShort"
  kind: python_call_eq
  category: class_names
  id_prefix: mpclassqnlen42

  columns: [id, function, args, expected, description]
  rows:
    - [Process,            Process.__qualname__.__len__,            [],  7, "Process.__qualname__.__len__() == 7 — 'Process' has 7 characters"]
    - [ProcessError,       ProcessError.__qualname__.__len__,       [], 12, "ProcessError.__qualname__.__len__() == 12 — 'ProcessError' has 12 characters"]
    - [AuthenticationError, AuthenticationError.__qualname__.__len__, [], 19, "AuthenticationError.__qualname__.__len__() == 19 — 'AuthenticationError' has 19 characters"]
    - [TimeoutError,       TimeoutError.__qualname__.__len__,       [], 12, "TimeoutError.__qualname__.__len__() == 12 — 'TimeoutError' has 12 characters; same as ProcessError"]
    - [BufferTooShort,     BufferTooShort.__qualname__.__len__,     [], 14, "BufferTooShort.__qualname__.__len__() == 14 — 'BufferTooShort' has 14 characters"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra42
# ---------------------------------------------------------------------------

invariant multiprocessing_extra42.Process_qualname_len:
  description: "multiprocessing.Process.__qualname__.__len__() == 7 — 'Process' has 7 characters"
  category: class_names
  kind: python_call_eq
  function: Process.__qualname__.__len__
  args: []
  expected: 7

invariant multiprocessing_extra42.ProcessError_qualname_eq:
  description: "multiprocessing.ProcessError.__qualname__ == 'ProcessError' — top-level exception class; qualname equals name (12 chars)"
  category: class_names
  kind: python_call_eq
  function: ProcessError.__qualname__.__eq__
  args: ["ProcessError"]
  expected: true

invariant multiprocessing_extra42.ProcessError_qualname_len:
  description: "multiprocessing.ProcessError.__qualname__.__len__() == 12 — 'ProcessError' has 12 characters"
  category: class_names
  kind: python_call_eq
  function: ProcessError.__qualname__.__len__
  args: []
  expected: 12

invariant multiprocessing_extra42.AuthenticationError_qualname_eq:
  description: "multiprocessing.AuthenticationError.__qualname__ == 'AuthenticationError' — top-level exception class; qualname equals name (19 chars)"
  category: class_names
  kind: python_call_eq
  function: AuthenticationError.__qualname__.__eq__
  args: ["AuthenticationError"]
  expected: true

invariant multiprocessing_extra42.AuthenticationError_qualname_len:
  description: "multiprocessing.AuthenticationError.__qualname__.__len__() == 19 — 'AuthenticationError' has 19 characters"
  category: class_names
  kind: python_call_eq
  function: AuthenticationError.__qualname__.__len__
  args: []
  expected: 19

invariant multiprocessing_extra42.TimeoutError_qualname_eq:
  description: "multiprocessing.TimeoutError.__qualname__ == 'TimeoutError' — top-level exception class; qualname equals name (12 chars); same length as ProcessError"
  category: class_names
  kind: python_call_eq
  function: TimeoutError.__qualname__.__eq__
  args: ["TimeoutError"]
  expected: true

invariant multiprocessing_extra42.BufferTooShort_qualname_eq:
  description: "multiprocessing.BufferTooShort.__qualname__ == 'BufferTooShort' — top-level exception class; qualname equals name (14 chars)"
  category: class_names
  kind: python_call_eq
  function: BufferTooShort.__qualname__.__eq__
  args: ["BufferTooShort"]
  expected: true

invariant multiprocessing_extra42.BufferTooShort_qualname_len:
  description: "multiprocessing.BufferTooShort.__qualname__.__len__() == 14 — 'BufferTooShort' has 14 characters"
  category: class_names
  kind: python_call_eq
  function: BufferTooShort.__qualname__.__len__
  args: []
  expected: 14
