spec: shutil_extra5
version: ">=3.9"
backend: python_module(shutil)

docs: https://docs.python.org/3/library/shutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shutil.html — Python shutil module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/shutil.py"
    - "shutil.zspec.zsdl — covers core copy/copy2/copyfile/rmtree behaviors and Error raises"
    - "shutil_extra.zspec.zsdl — covers initial __name__ and __module__ checks"
    - "shutil_extra2.zspec.zsdl — covers additional function names"
    - "shutil_extra3.zspec.zsdl — covers additional class and function attributes"
    - "shutil_extra4.zspec.zsdl — covers __name__ for copy/copy2/copyfile/copyfileobj/copytree/rmtree/move/disk_usage/which/get_terminal_size/get_archive_formats/make_archive, Error/SameFileError __name__, Error base, SameFileError base, disk_usage named-tuple class name, disk_usage total>0, get_archive_formats returns list, which.__name__"
  notes:
    - "This spec covers __qualname__ attributes for shutil functions and classes — not covered in prior shutil specs."
    - "shutil.copy.__qualname__ == 'copy' — qualname equals name for top-level function."
    - "shutil.copy2.__qualname__ == 'copy2' — qualname equals name for top-level function."
    - "shutil.copyfile.__qualname__ == 'copyfile' — qualname equals name for top-level function."
    - "shutil.copytree.__qualname__ == 'copytree' — qualname equals name for top-level function."
    - "shutil.rmtree.__qualname__ == 'rmtree' — qualname equals name for top-level function."
    - "shutil.move.__qualname__ == 'move' — qualname equals name for top-level function."
    - "shutil.make_archive.__qualname__ == 'make_archive' — qualname equals name for top-level function."
    - "shutil.unpack_archive.__qualname__ == 'unpack_archive' — qualname equals name for top-level function."
    - "shutil.disk_usage.__qualname__ == 'disk_usage' — qualname equals name for top-level function."
    - "shutil.which.__qualname__ == 'which' — qualname equals name for top-level function."
    - "shutil.get_terminal_size.__qualname__ == 'get_terminal_size' — qualname equals name for top-level function."
    - "shutil.Error.__qualname__ == 'Error' — qualname equals name for top-level exception class."
    - "shutil.copy.__module__ == 'shutil' — function is defined in the shutil module."
    - "shutil.Error.__module__ == 'shutil' — exception class is defined in the shutil module."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for top-level shutil functions
# Not covered in any prior shutil spec (prior specs only used __name__)
# ---------------------------------------------------------------------------

table shutil_extra5.function_qualnames:
  kind: python_call_eq
  category: qualname_attrs
  id_prefix: fqname

  columns: [id, function, args, expected]
  rows:
    - [copy,             copy.__qualname__.__eq__,             ["copy"],             true]
    - [copy2,            copy2.__qualname__.__eq__,            ["copy2"],            true]
    - [copyfile,         copyfile.__qualname__.__eq__,         ["copyfile"],         true]
    - [copytree,         copytree.__qualname__.__eq__,         ["copytree"],         true]
    - [rmtree,           rmtree.__qualname__.__eq__,           ["rmtree"],           true]
    - [move,             move.__qualname__.__eq__,             ["move"],             true]
    - [make_archive,     make_archive.__qualname__.__eq__,     ["make_archive"],     true]
    - [unpack_archive,   unpack_archive.__qualname__.__eq__,   ["unpack_archive"],   true]
    - [disk_usage,       disk_usage.__qualname__.__eq__,       ["disk_usage"],       true]
    - [which,            which.__qualname__.__eq__,            ["which"],            true]
    - [get_terminal_size, get_terminal_size.__qualname__.__eq__, ["get_terminal_size"], true]

# ---------------------------------------------------------------------------
# __qualname__ checks for top-level shutil exception class
# ---------------------------------------------------------------------------

table shutil_extra5.class_qualnames:
  kind: python_call_eq
  category: qualname_attrs
  id_prefix: cqname

  columns: [id, function, args, expected]
  rows:
    - [Error,         Error.__qualname__.__eq__,         ["Error"],         true]
    - [SameFileError, SameFileError.__qualname__.__eq__, ["SameFileError"], true]

# ---------------------------------------------------------------------------
# __module__ checks for shutil functions and classes
# These complement the __name__ checks in shutil_extra4 with module identity.
# ---------------------------------------------------------------------------

table shutil_extra5.function_modules:
  kind: python_call_eq
  category: module_attrs
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [copy,           copy.__module__.__eq__,           ["shutil"], true]
    - [copy2,          copy2.__module__.__eq__,          ["shutil"], true]
    - [copyfile,       copyfile.__module__.__eq__,       ["shutil"], true]
    - [rmtree,         rmtree.__module__.__eq__,         ["shutil"], true]
    - [move,           move.__module__.__eq__,           ["shutil"], true]
    - [which,          which.__module__.__eq__,          ["shutil"], true]
    - [unpack_archive, unpack_archive.__module__.__eq__, ["shutil"], true]

table shutil_extra5.class_modules:
  kind: python_call_eq
  category: module_attrs
  id_prefix: cmod

  columns: [id, function, args, expected]
  rows:
    - [Error,         Error.__module__.__eq__,         ["shutil"], true]
    - [SameFileError, SameFileError.__module__.__eq__, ["shutil"], true]
