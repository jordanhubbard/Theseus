spec: re_extra1741
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra1681.zspec.zsdl — covers __call__, __iter__/__contains__/__len__, __hash__/__eq__ protocol"
    - "re_extra1666.zspec.zsdl — covers __new__ and __init__ construction protocol"
    - "re_extra1651.zspec.zsdl — covers __init_subclass__, __class_getitem__, module attr presence"
  notes:
    - "Wave 563 (_extra1741): descriptor protocol — which re types define __get__, __set__, __delete__, __set_name__ in their own __dict__."
    - "re.Pattern is a C extension type; it does NOT define __get__, __set__, __delete__, or __set_name__ in its own __dict__."
    - "re.Match is a C extension type; it does NOT define descriptor protocol methods in its own __dict__."
    - "re.error (PatternError) is a Python exception class; it does NOT define descriptor protocol methods."
    - "re.RegexFlag is an IntFlag enum subclass; it does NOT define descriptor protocol methods in its own __dict__."
    - "re.Pattern defines __copy__ and __deepcopy__ in its own __dict__ for copy protocol support."
    - "re.Pattern defines __reduce__ in its own __dict__ for pickle protocol support."
    - "re.Match defines __copy__ and __deepcopy__ in its own __dict__ for copy protocol support."
    - "re.Pattern does NOT define __set_name__ — it is not used as a class-level descriptor."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table re_extra1741.descriptor_protocol
# __get__, __set__, __delete__, __set_name__ are absent from every re type's
# own __dict__. Pattern and Match are not descriptors.
# ---------------------------------------------------------------------------

table re_extra1741.descriptor_protocol:
  description: "re types descriptor protocol (__get__/__set__/__delete__/__set_name__) dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1741

  columns: [id, function, args, expected]
  rows:
    - ["re1741001", Pattern.__dict__.__contains__,   ["__get__"],      false]
    - ["re1741002", Pattern.__dict__.__contains__,   ["__set__"],      false]
    - ["re1741003", Pattern.__dict__.__contains__,   ["__delete__"],   false]
    - ["re1741004", Pattern.__dict__.__contains__,   ["__set_name__"], false]
    - ["re1741005", Match.__dict__.__contains__,     ["__get__"],      false]
    - ["re1741006", Match.__dict__.__contains__,     ["__set__"],      false]
    - ["re1741007", Match.__dict__.__contains__,     ["__delete__"],   false]
    - ["re1741008", Match.__dict__.__contains__,     ["__set_name__"], false]
    - ["re1741009", error.__dict__.__contains__,     ["__get__"],      false]
    - ["re1741010", error.__dict__.__contains__,     ["__set__"],      false]
    - ["re1741011", error.__dict__.__contains__,     ["__delete__"],   false]
    - ["re1741012", error.__dict__.__contains__,     ["__set_name__"], false]
    - ["re1741013", RegexFlag.__dict__.__contains__, ["__get__"],      false]
    - ["re1741014", RegexFlag.__dict__.__contains__, ["__set__"],      false]
    - ["re1741015", RegexFlag.__dict__.__contains__, ["__delete__"],   false]
    - ["re1741016", RegexFlag.__dict__.__contains__, ["__set_name__"], false]

# ---------------------------------------------------------------------------
# Table re_extra1741.copy_pickle_protocol
# re.Pattern defines __copy__, __deepcopy__, and __reduce__ in its own __dict__
# for copy and pickle protocol support (compiled patterns are picklable).
# re.Match defines __copy__ and __deepcopy__ for copy support.
# ---------------------------------------------------------------------------

table re_extra1741.copy_pickle_protocol:
  description: "Copy and pickle protocol (__copy__/__deepcopy__/__reduce__) dict-presence checks for re types"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1741

  columns: [id, function, args, expected]
  rows:
    - ["re1741017", Pattern.__dict__.__contains__,   ["__copy__"],     true]
    - ["re1741018", Pattern.__dict__.__contains__,   ["__deepcopy__"], true]
    - ["re1741019", Pattern.__dict__.__contains__,   ["__reduce__"],   true]
    - ["re1741020", Match.__dict__.__contains__,     ["__copy__"],     true]
    - ["re1741021", Match.__dict__.__contains__,     ["__deepcopy__"], true]
    - ["re1741022", Match.__dict__.__contains__,     ["__reduce__"],   false]
    - ["re1741023", error.__dict__.__contains__,     ["__copy__"],     false]
    - ["re1741024", error.__dict__.__contains__,     ["__reduce__"],   false]
    - ["re1741025", RegexFlag.__dict__.__contains__, ["__copy__"],     false]
    - ["re1741026", RegexFlag.__dict__.__contains__, ["__reduce__"],   false]
