spec: theseus_html_cr3
version: ">=3.9"
backend: python_cleanroom(theseus_html_cr3)
blocks: html

docs: https://docs.python.org/3/library/html.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/html.html"
    - "https://html.spec.whatwg.org/multipage/named-characters.html"
  notes:
    - "Clean-room extended HTML utilities. Do NOT import html or html.parser."
    - "escape(s, quote=True): replace &, <, > (and optionally ' and \") with HTML entities."
    - "unescape(s): replace HTML entities with their characters (numeric and named)."
    - "html3_escape_amp(): escape('a & b') == 'a &amp; b'."
    - "html3_escape_quotes(): escape('\"hello\"', quote=True) == '&quot;hello&quot;'."
    - "html3_unescape_numeric(): unescape('&#65;') == 'A' (decimal numeric entity)."
    - "Zero-arg invariant signatures — def html3_escape_amp(): return hardcoded_result"
    - "escape: & -> &amp;, < -> &lt;, > -> &gt;, \" -> &quot; (if quote=True)."
    - "unescape: &#N; -> chr(N), &#xN; -> chr(int(N,16)), &name; -> lookup in table."
    - "Export: escape(s, quote=True), unescape(s)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_html_cr3.escape_amp:
  description: "escape('a & b') == 'a &amp; b'"
  category: escape
  kind: python_call_eq
  function: html3_escape_amp
  args: []
  expected: "a &amp; b"

invariant theseus_html_cr3.escape_quotes:
  description: "escape('\"hello\"', quote=True) == '&quot;hello&quot;'"
  category: escape
  kind: python_call_eq
  function: html3_escape_quotes
  args: []
  expected: "&quot;hello&quot;"

invariant theseus_html_cr3.unescape_numeric:
  description: "unescape('&#65;') == 'A'"
  category: unescape
  kind: python_call_eq
  function: html3_unescape_numeric
  args: []
  expected: "A"
