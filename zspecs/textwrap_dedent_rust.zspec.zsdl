spec: textwrap_dedent_rust
version: ">=3.9"
backend: rust_module(textwrap_dedent_rust)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap documentation"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
  notes:
    - "textwrap.dedent() removes common leading whitespace from each line."
    - "dedent('    hello\\n    world') == 'hello\\nworld' — removes 4-space indent."
    - "dedent('  a\\n  b\\n  c') == 'a\\nb\\nc' — removes 2-space indent."
    - "dedent('no indent') == 'no indent' — nothing to remove."
    - "dedent('  first\\n    second\\n  third') == 'first\\n  second\\nthird' — 2-space common prefix removed."
    - "Mixed indentation: only the common prefix is removed."
    - "All test vectors verified against Python 3.14.3 textwrap module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# dedent — remove common leading whitespace
table textwrap_dedent_rust.dedent.vectors:
  kind: python_call_eq
  category: dedent
  id_prefix: td_ded
  function: dedent

  columns: [id, args, expected]
  rows:
    - [four_space,   ["    hello\n    world"],             "hello\nworld"]
    - [two_space,    ["  a\n  b\n  c"],                   "a\nb\nc"]
    - [no_indent,    ["no indent"],                        "no indent"]
    - [mixed_indent, ["  first\n    second\n  third"],    "first\n  second\nthird"]
    - [single_line,  ["  only one line"],                 "only one line"]
    - [empty,        [""],                                 ""]

