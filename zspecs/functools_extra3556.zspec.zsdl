spec: ft3556
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 684 (ft3556): __reduce__, __reduce_ex__, __getstate__ dict-presence checks for functools types."
    - "functools.partial defines __reduce__ (true): partial implements custom pickle support to preserve func and args."
    - "type(functools.lru_cache(lambda:None)) defines __reduce__ (true): the lru_cache wrapper implements custom pickle support."
    - "functools.partialmethod and functools.cached_property do NOT define __reduce__, __reduce_ex__, or __getstate__ (false)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __reduce__ dict-presence — operator.contains(Cls.__dict__, '__reduce__')
#
# functools.partial and the lru_cache wrapper type define __reduce__.
# ---------------------------------------------------------------------------

table ft3556.reduce:
  description: "functools types __reduce__ dict-presence checks; wave 684"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ft3556
  columns: [id, function, args, expected]
  rows:
    - ["ft3556001", operator.contains, [functools.partial.__dict__,                       "__reduce__"], true]
    - ["ft3556002", operator.contains, [functools.partialmethod.__dict__,                 "__reduce__"], false]
    - ["ft3556003", operator.contains, [functools.cached_property.__dict__,               "__reduce__"], false]
    - ["ft3556004", operator.contains, [type(functools.lru_cache(lambda: None)).__dict__, "__reduce__"], true]

