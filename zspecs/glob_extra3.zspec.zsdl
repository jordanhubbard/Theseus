spec: glob_extra3
version: ">=3.9"
backend: python_module(glob)

docs: https://docs.python.org/3/library/glob.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/glob.html — Python glob module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/glob.py"
  notes:
    - "This spec extends glob.zspec.zsdl, glob_extra.zspec.zsdl, and glob_extra2.zspec.zsdl."
    - "glob.zspec.zsdl covers: glob/iglob/escape __name__ (table), glob no-match/exact-match cases, escape special-char table, iglob generator type check."
    - "glob_extra.zspec.zsdl covers: glob.__module__, glob/iglob/escape __name__ standalone invariants, escape '[abc]'/'a?b'/'a*b' vectors."
    - "glob_extra2.zspec.zsdl covers: glob/iglob/escape/has_magic __name__ standalone invariants, module checks table (all four), has_magic vectors, escape 'normal.txt' and '' vectors."
    - "This spec adds: escape('/path/with[brackets]') — path with brackets (new vector), escape('normal/path') — plain path with slash (new vector vs 'normal.txt'), escape.__class__.__name__ == 'function', iglob.__class__.__name__ == 'function', and a table of function __name__ checks using direct bool comparison."
    - "glob.escape('/path/with[brackets]') == '/path/with[[]brackets[]]' — brackets are escaped to bracket literals."
    - "glob.escape('normal/path') == 'normal/path' — forward slash is not a glob special char; string is unchanged."
    - "glob.escape.__class__.__name__ == 'function' — escape is a plain Python function."
    - "glob.iglob.__class__.__name__ == 'function' — iglob is a plain Python function (not a class or builtin)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ checks — table form
# glob_extra2 covers glob/iglob/escape/has_magic __name__ as standalone invariants.
# This table groups glob, iglob, and escape together for compact verification.
# ---------------------------------------------------------------------------

table glob_extra3.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [glob,   glob.__name__.__eq__,   ["glob"],   true]
    - [iglob,  iglob.__name__.__eq__,  ["iglob"],  true]
    - [escape, escape.__name__.__eq__, ["escape"], true]

# ---------------------------------------------------------------------------
# glob.__module__ == 'glob'
# glob_extra covers glob.__module__ as a standalone invariant.
# This invariant restates it as a cross-spec anchor in extra3 context.
# ---------------------------------------------------------------------------

invariant glob_extra3.glob.module:
  description: "glob.glob.__module__ == 'glob'"
  category: module
  kind: python_call_eq
  function: glob.__module__.__eq__
  args: ["glob"]
  expected: true

# ---------------------------------------------------------------------------
# Function class checks — escape and iglob are plain Python functions
# glob_extra2 does not include __class__.__name__ checks for these two.
# ---------------------------------------------------------------------------

invariant glob_extra3.escape.class_name:
  description: "glob.escape.__class__.__name__ == 'function'"
  category: function_identity
  kind: python_call_eq
  function: escape.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant glob_extra3.iglob.class_name:
  description: "glob.iglob.__class__.__name__ == 'function'"
  category: function_identity
  kind: python_call_eq
  function: iglob.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# escape('/path/with[brackets]') — path containing bracket glob special chars
# glob_extra covers escape('[abc]') (bracket expression alone).
# glob_extra2 covers escape('normal.txt') and escape('').
# This vector uses a full path where brackets appear mid-string.
# ---------------------------------------------------------------------------

invariant glob_extra3.escape.path_with_brackets:
  description: "glob.escape('/path/with[brackets]') == '/path/with[[]brackets[]]'"
  category: escape
  kind: python_call_eq
  function: escape
  args: ["/path/with[brackets]"]
  expected: "/path/with[[]brackets[]]"

# ---------------------------------------------------------------------------
# escape('normal/path') — plain path with slash, no glob specials
# glob_extra2 covers escape('normal.txt'); this adds a path with a slash.
# Forward slash is not a glob special character; string is returned unchanged.
# ---------------------------------------------------------------------------

invariant glob_extra3.escape.normal_path_with_slash:
  description: "glob.escape('normal/path') == 'normal/path' — slash is not a glob special char"
  category: escape
  kind: python_call_eq
  function: escape
  args: ["normal/path"]
  expected: "normal/path"
