spec: traceback_extra4
version: ">=3.9"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/traceback.html — Python traceback module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
  notes:
    - "This spec extends prior traceback specs."
    - "Focus: __module__ and __name__ for traceback classes and functions not yet covered."
    - "traceback.TracebackException.__name__ == 'TracebackException'."
    - "traceback.StackSummary.__name__ == 'StackSummary'."
    - "traceback.FrameSummary.__name__ == 'FrameSummary'."
    - "traceback.print_exc.__name__ == 'print_exc'."
    - "traceback.format_exc.__name__ == 'format_exc'."
    - "traceback.format_tb.__name__ == 'format_tb'."
    - "traceback.print_tb.__name__ == 'print_tb'."
    - "traceback.extract_tb.__name__ == 'extract_tb'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table traceback_extra4.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [TracebackException, TracebackException.__name__.__eq__, ["TracebackException"], true]
    - [StackSummary,       StackSummary.__name__.__eq__,       ["StackSummary"],       true]
    - [FrameSummary,       FrameSummary.__name__.__eq__,       ["FrameSummary"],       true]

table traceback_extra4.class_modules:
  kind: python_call_eq
  category: module
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [TracebackException, TracebackException.__module__.__eq__, ["traceback"], true]
    - [StackSummary,       StackSummary.__module__.__eq__,       ["traceback"], true]
    - [FrameSummary,       FrameSummary.__module__.__eq__,       ["traceback"], true]

table traceback_extra4.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [print_exc,   print_exc.__name__.__eq__,   ["print_exc"],   true]
    - [format_exc,  format_exc.__name__.__eq__,  ["format_exc"],  true]
    - [format_tb,   format_tb.__name__.__eq__,   ["format_tb"],   true]
    - [print_tb,    print_tb.__name__.__eq__,    ["print_tb"],    true]
    - [extract_tb,  extract_tb.__name__.__eq__,  ["extract_tb"],  true]
    - [format_list, format_list.__name__.__eq__, ["format_list"], true]
    - [print_list,  print_list.__name__.__eq__,  ["print_list"],  true]

invariant traceback_extra4.StackSummary.from_list_name:
  description: "traceback.StackSummary.from_list.__func__.__name__ == 'from_list'"
  category: StackSummary
  kind: python_call_eq
  function: StackSummary.from_list.__func__.__name__.__eq__
  args: ["from_list"]
  expected: true

invariant traceback_extra4.TracebackException.base:
  description: "traceback.TracebackException.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: TracebackException.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant traceback_extra4.format_exc.returns_str:
  description: "traceback.format_exc().__class__.__name__ == 'str'"
  category: format_exc
  kind: python_call_eq
  function: format_exc
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["str"]
  expected: true
