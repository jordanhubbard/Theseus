spec: lodash_toupper
version: ">=4.0.0"
backend: node(lodash.toupper)

docs: https://lodash.com/docs/#toUpper

provenance:
  derived_from:
    - "lodash.toupper README — https://www.npmjs.com/package/lodash.toupper"
    - "Test vectors verified with lodash.toupper@4.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.toupper exports the _.toUpper function directly as module.exports."
    - "toUpper(string) converts string to upper case."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns uppercased string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_toupper.toupper:
  kind: node_module_call_eq
  function: ~
  category: toupper
  id_prefix: ltouc

  columns: [id, args, expected]
  rows:
    - [lower,    ["foo bar"],    "FOO BAR"]
    - [mixed,    ["Hello World"], "HELLO WORLD"]
    - [already,  ["HELLO"],      "HELLO"]
