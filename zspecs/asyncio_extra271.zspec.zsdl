spec: asyncio_extra271
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-stream.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-stream.html — asyncio streams documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/streams.py"
  notes:
    - "asyncio.StreamReader and asyncio.StreamWriter are defined in asyncio.streams; __module__ == 'asyncio.streams'."
    - "Both StreamReader and StreamWriter inherit directly from object; __bases__[0].__name__ == 'object'."
    - "StreamReader read methods (read, readline, readexactly, readuntil) carry __qualname__ prefixed with 'StreamReader.'."
    - "StreamWriter write methods (write, drain, close) carry __qualname__ prefixed with 'StreamWriter.'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# StreamReader class identity — table
#
# asyncio.StreamReader: class name, module, base class, and method __name__.
# ---------------------------------------------------------------------------

table asyncio_extra271.stream_reader_identity:
  description: "asyncio.StreamReader class identity and method __name__ values"
  kind: python_call_eq
  category: identity
  id_prefix: srid

  columns: [id, function, args, expected, description]
  rows:
    - [sr_name,           StreamReader.__name__.__eq__,              ["StreamReader"],       true, "asyncio.StreamReader.__name__ == 'StreamReader'"]
    - [sr_module,         StreamReader.__module__.__eq__,            ["asyncio.streams"],    true, "asyncio.StreamReader.__module__ == 'asyncio.streams'"]
    - [sr_read_name,      StreamReader.read.__name__.__eq__,         ["read"],               true, "asyncio.StreamReader.read.__name__ == 'read'"]
    - [sr_readline_name,  StreamReader.readline.__name__.__eq__,     ["readline"],           true, "asyncio.StreamReader.readline.__name__ == 'readline'"]
    - [sr_readexact_name, StreamReader.readexactly.__name__.__eq__,  ["readexactly"],        true, "asyncio.StreamReader.readexactly.__name__ == 'readexactly'"]

# ---------------------------------------------------------------------------
# StreamWriter class identity — table
#
# asyncio.StreamWriter: class name, module, base class, and method __name__.
# ---------------------------------------------------------------------------

table asyncio_extra271.stream_writer_identity:
  description: "asyncio.StreamWriter class identity and method __name__ values"
  kind: python_call_eq
  category: identity
  id_prefix: swid

  columns: [id, function, args, expected, description]
  rows:
    - [sw_name,           StreamWriter.__name__.__eq__,              ["StreamWriter"],       true, "asyncio.StreamWriter.__name__ == 'StreamWriter'"]
    - [sw_module,         StreamWriter.__module__.__eq__,            ["asyncio.streams"],    true, "asyncio.StreamWriter.__module__ == 'asyncio.streams'"]
    - [sw_write_name,     StreamWriter.write.__name__.__eq__,        ["write"],              true, "asyncio.StreamWriter.write.__name__ == 'write'"]
    - [sw_drain_name,     StreamWriter.drain.__name__.__eq__,        ["drain"],              true, "asyncio.StreamWriter.drain.__name__ == 'drain'"]
    - [sw_close_name,     StreamWriter.close.__name__.__eq__,        ["close"],              true, "asyncio.StreamWriter.close.__name__ == 'close'"]

# ---------------------------------------------------------------------------
# StreamReader.__bases__[0] is object — standalone invariant
# ---------------------------------------------------------------------------

invariant asyncio_extra271.StreamReader.bases0_name:
  description: "asyncio.StreamReader.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: "StreamReader.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# StreamWriter.__bases__[0] is object — standalone invariant
# ---------------------------------------------------------------------------

invariant asyncio_extra271.StreamWriter.bases0_name:
  description: "asyncio.StreamWriter.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: "StreamWriter.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# StreamReader.readuntil __name__ — standalone invariant
# ---------------------------------------------------------------------------

invariant asyncio_extra271.StreamReader.readuntil_name:
  description: "asyncio.StreamReader.readuntil.__name__ == 'readuntil'"
  category: identity
  kind: python_call_eq
  function: StreamReader.readuntil.__name__.__eq__
  args: ["readuntil"]
  expected: true

# ---------------------------------------------------------------------------
# StreamReader method __qualname__ — standalone invariants
# ---------------------------------------------------------------------------

invariant asyncio_extra271.StreamReader.read_qualname:
  description: "asyncio.StreamReader.read.__qualname__ == 'StreamReader.read'"
  category: identity
  kind: python_call_eq
  function: StreamReader.read.__qualname__.__eq__
  args: ["StreamReader.read"]
  expected: true

invariant asyncio_extra271.StreamReader.readline_qualname:
  description: "asyncio.StreamReader.readline.__qualname__ == 'StreamReader.readline'"
  category: identity
  kind: python_call_eq
  function: StreamReader.readline.__qualname__.__eq__
  args: ["StreamReader.readline"]
  expected: true

invariant asyncio_extra271.StreamWriter.write_qualname:
  description: "asyncio.StreamWriter.write.__qualname__ == 'StreamWriter.write'"
  category: identity
  kind: python_call_eq
  function: StreamWriter.write.__qualname__.__eq__
  args: ["StreamWriter.write"]
  expected: true

invariant asyncio_extra271.StreamWriter.drain_qualname:
  description: "asyncio.StreamWriter.drain.__qualname__ == 'StreamWriter.drain'"
  category: identity
  kind: python_call_eq
  function: StreamWriter.drain.__qualname__.__eq__
  args: ["StreamWriter.drain"]
  expected: true
