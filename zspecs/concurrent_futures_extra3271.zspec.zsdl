    - ["cf3271011", operator.contains, [concurrent.futures.Future.__dict__,              "__ror__"], false]
    - ["cf3271012", operator.contains, [concurrent.futures.Future.__dict__,              "__rxor__"], false]
    - ["cf3271013", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__rand__"], false]
    - ["cf3271014", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__ror__"], false]
    - ["cf3271015", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__rxor__"], false]
    - ["cf3271016", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__rand__"], false]
    - ["cf3271017", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__ror__"], false]
    - ["cf3271018", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__rxor__"], false]
