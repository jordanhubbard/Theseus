spec: socket_extra2311
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/socket.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 601 (_extra2311): __abstractmethods__ absence checks and additional dict-presence."
    - "socket.socket is a pure-Python wrapper over _socket.socket (C extension); no abstract methods."
    - "socket.error is an alias for OSError; no abstract methods."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses; no abstract methods."
    - "__abstractmethods__ is absent from all four class dicts; accessing it raises AttributeError."
    - "socket.socket low-level methods (settimeout, gettimeout, fileno, etc.) are defined on the C base class _socket.socket and are NOT present in socket.socket.__dict__ directly."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __abstractmethods__ absence from __dict__ — all four socket types
#
# None of the four socket module types are abstract. All expected false.
# ---------------------------------------------------------------------------

table socket_extra2311.socket_abstract:
  description: "socket types __abstractmethods__ absence — wave 601 _extra2311"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2311
  columns: [id, function, args, expected]
  rows:
    - ["sk2311001", "socket.socket.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["sk2311002", "socket.error.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["sk2311003", "socket.AddressFamily.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["sk2311004", "socket.SocketKind.__dict__.__contains__", ["__abstractmethods__"], false]

# ---------------------------------------------------------------------------
# Table 2: __abstractmethods__ direct attribute access raises AttributeError
#
# __abstractmethods__ is absent from all four class dicts and is not inherited
# from any base class in their MROs. Accessing it raises AttributeError.
# ---------------------------------------------------------------------------

table socket_extra2311.socket_abstract_attr_error:
  description: "socket types raise AttributeError on __abstractmethods__ access — wave 601 _extra2311"
  kind: python_call_raises
  category: attribute_access
  id_prefix: sk2311
  columns: [id, function, args, expected]
  rows:
    - ["sk2311005", "socket.socket.__abstractmethods__.__len__", [], "AttributeError"]
    - ["sk2311006", "socket.error.__abstractmethods__.__len__", [], "AttributeError"]
    - ["sk2311007", "socket.AddressFamily.__abstractmethods__.__len__", [], "AttributeError"]
    - ["sk2311008", "socket.SocketKind.__abstractmethods__.__len__", [], "AttributeError"]
    - ["sk2311009", "socket.socket.__abstractmethods__.__contains__", ["send"], "AttributeError"]
    - ["sk2311010", "socket.AddressFamily.__abstractmethods__.__contains__", ["value"], "AttributeError"]

# ---------------------------------------------------------------------------
# Table 3: socket.socket dict-presence for methods inherited from _socket.socket
#
# socket.socket wraps _socket.socket. Low-level socket methods (settimeout,
# gettimeout, setblocking, fileno, setsockopt, getsockopt, shutdown,
# getpeername, getsockname) are defined on the C base class and are NOT
# present in socket.socket.__dict__ directly. All expected false.
# ---------------------------------------------------------------------------

table socket_extra2311.socket_dict_contains:
  description: "socket.socket dict-presence for methods defined on _socket.socket base — wave 601 _extra2311"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2311
  columns: [id, function, args, expected]
  rows:
    - ["sk2311011", "socket.socket.__dict__.__contains__", ["settimeout"], false]
    - ["sk2311012", "socket.socket.__dict__.__contains__", ["gettimeout"], false]
    - ["sk2311013", "socket.socket.__dict__.__contains__", ["setblocking"], false]
    - ["sk2311014", "socket.socket.__dict__.__contains__", ["fileno"], false]
    - ["sk2311015", "socket.socket.__dict__.__contains__", ["setsockopt"], false]
    - ["sk2311016", "socket.socket.__dict__.__contains__", ["getsockopt"], false]
    - ["sk2311017", "socket.socket.__dict__.__contains__", ["shutdown"], false]
    - ["sk2311018", "socket.socket.__dict__.__contains__", ["getpeername"], false]
    - ["sk2311019", "socket.socket.__dict__.__contains__", ["getsockname"], false]

# ---------------------------------------------------------------------------
# Table 4: socket.AddressFamily and socket.SocketKind dict-presence checks
#
# IntEnum subclasses do not define sequence or numeric dunders directly on
# the subclass dict itself; those come from the Enum/int MRO. All false.
# ---------------------------------------------------------------------------

table socket_extra2311.socket_enum_dict_contains:
  description: "socket.AddressFamily and socket.SocketKind dict-presence for protocol dunders — wave 601 _extra2311"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2311
  columns: [id, function, args, expected]
  rows:
    - ["sk2311020", "socket.AddressFamily.__dict__.__contains__", ["__format__"], false]
    - ["sk2311021", "socket.AddressFamily.__dict__.__contains__", ["__bytes__"], false]
    - ["sk2311022", "socket.AddressFamily.__dict__.__contains__", ["__len__"], false]
    - ["sk2311023", "socket.AddressFamily.__dict__.__contains__", ["__iter__"], false]
    - ["sk2311024", "socket.AddressFamily.__dict__.__contains__", ["__contains__"], false]
    - ["sk2311025", "socket.SocketKind.__dict__.__contains__", ["__format__"], false]
    - ["sk2311026", "socket.SocketKind.__dict__.__contains__", ["__bytes__"], false]
    - ["sk2311027", "socket.SocketKind.__dict__.__contains__", ["__len__"], false]
    - ["sk2311028", "socket.SocketKind.__dict__.__contains__", ["__iter__"], false]
    - ["sk2311029", "socket.SocketKind.__dict__.__contains__", ["__contains__"], false]
