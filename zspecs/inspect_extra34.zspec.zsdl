spec: inspect_extra34
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra33.zspec.zsdl."
    - "Prior specs covered: ismodule/isclass/isfunction/ismethod/isbuiltin/isroutine __qualname__.__len__(); getmembers/getfile/getsource/getsourcelines/getmodule/getargs/signature/stack/currentframe/getfullargspec __qualname__.__len__(); Parameter/__mro__.__len__()/Signature/__mro__.__len__()/BoundArguments/__mro__.__len__() (all 2); class __bases__[0].__name__.__len__() for Parameter/Signature/BoundArguments (all 6); __dict__.__class__.__name__.__len__() for Parameter/Signature/BoundArguments/FrameInfo (all 12); Parameter.__name__.__len__()==9/Signature.__name__.__len__()==9/BoundArguments.__name__.__len__()==14/FullArgSpec.__name__.__len__()==11; isfunction.__name__.__len__()==10/ismethod.__name__.__len__()==8; Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__len__()==14."
    - "This spec covers: isclass.__name__.__len__() (7 — 'isclass'); ismodule.__name__.__len__() (8 — 'ismodule'); isbuiltin.__name__.__len__() (9 — 'isbuiltin'); getmembers.__name__.__len__() (10 — 'getmembers'); getdoc.__name__.__len__() (6 — 'getdoc'); getsource.__name__.__len__() (9 — 'getsource'); signature.__name__.__len__() (9 — 'signature'); currentframe.__name__.__len__() (12 — 'currentframe'); getframeinfo.__name__.__len__() (12 — 'getframeinfo'); Parameter.empty.__class__.__name__.__len__() (4 — 'type', the sentinel _empty is a class object)."
    - "Key findings: isclass.__name__ is 'isclass' (7 chars), matching __qualname__. isbuiltin.__name__ is 'isbuiltin' (9 chars), same as getsource and signature. getmembers.__name__ is 'getmembers' (10 chars), same length as isfunction. currentframe.__name__ and getframeinfo.__name__ are both 12 chars — the longest inspect predicate/helper names. Parameter.empty is itself a class object; Parameter.empty.__class__.__name__ is 'type' (4 chars), not 'NoneType' or '_empty'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Predicate __name__.__len__() table — isclass/ismodule/isbuiltin — extra34 namespace
#
# inspect.isclass.__name__ is 'isclass' (7 chars). inspect.ismodule.__name__ is
# 'ismodule' (8 chars). inspect.isbuiltin.__name__ is 'isbuiltin' (9 chars).
# Prior specs recorded __qualname__.__len__() for isclass(7)/ismodule(8)/isbuiltin(9)
# but not their __name__.__len__() as a standalone group (for plain module-level
# functions __name__ == __qualname__). Prior extra33 recorded isfunction(10) and
# ismethod(8) __name__.__len__(). No prior inspect spec records these three
# __name__.__len__() values together in a combined table in the extra34 namespace.
# ---------------------------------------------------------------------------

table inspect_extra34.predicate_name_lengths:
  description: "inspect predicate __name__.__len__() for isclass/ismodule/isbuiltin"
  kind: python_call_eq
  category: string_properties
  id_prefix: prednamelen34

  columns: [id, function, args, expected, description]
  rows:
    - [isclass,
       isclass.__name__.__len__,
       [],
       7,
       "len(inspect.isclass.__name__) == 7 — 'isclass' (matches __qualname__)"]
    - [ismodule,
       ismodule.__name__.__len__,
       [],
       8,
       "len(inspect.ismodule.__name__) == 8 — 'ismodule' (matches __qualname__)"]
    - [isbuiltin,
       isbuiltin.__name__.__len__,
       [],
       9,
       "len(inspect.isbuiltin.__name__) == 9 — 'isbuiltin' (matches __qualname__)"]

# ---------------------------------------------------------------------------
# Helper function __name__.__len__() table — getmembers/getdoc/getsource — extra34 namespace
#
# inspect.getmembers.__name__ is 'getmembers' (10 chars). inspect.getdoc.__name__
# is 'getdoc' (6 chars). inspect.getsource.__name__ is 'getsource' (9 chars).
# Prior specs recorded __qualname__.__len__() for getmembers(10)/getdoc(6)/getsource(9),
# but not their __name__.__len__() as a group in the extra34 namespace. For plain
# module-level functions __name__ == __qualname__. No prior inspect spec records
# these three __name__.__len__() values together in the extra34 namespace.
# ---------------------------------------------------------------------------

table inspect_extra34.helper_name_lengths:
  description: "inspect helper function __name__.__len__() for getmembers/getdoc/getsource"
  kind: python_call_eq
  category: string_properties
  id_prefix: helpernamelen34

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers,
       getmembers.__name__.__len__,
       [],
       10,
       "len(inspect.getmembers.__name__) == 10 — 'getmembers' (matches __qualname__)"]
    - [getdoc,
       getdoc.__name__.__len__,
       [],
       6,
       "len(inspect.getdoc.__name__) == 6 — 'getdoc' (matches __qualname__)"]
    - [getsource,
       getsource.__name__.__len__,
       [],
       9,
       "len(inspect.getsource.__name__) == 9 — 'getsource' (matches __qualname__)"]

# ---------------------------------------------------------------------------
# Long-name helper __name__.__len__() table — signature/currentframe/getframeinfo
#
# inspect.signature.__name__ is 'signature' (9 chars). inspect.currentframe.__name__
# is 'currentframe' (12 chars). inspect.getframeinfo.__name__ is 'getframeinfo'
# (12 chars). currentframe and getframeinfo share the same length (12) — the longest
# names among the core inspect helpers. Prior specs recorded their __qualname__.__len__()
# values but not __name__.__len__() explicitly in the extra34 namespace.
# No prior inspect spec records these three values together in the extra34 namespace.
# ---------------------------------------------------------------------------

table inspect_extra34.long_helper_name_lengths:
  description: "inspect helper __name__.__len__() for signature/currentframe/getframeinfo"
  kind: python_call_eq
  category: string_properties
  id_prefix: longhelpernamelen34

  columns: [id, function, args, expected, description]
  rows:
    - [signature,
       signature.__name__.__len__,
       [],
       9,
       "len(inspect.signature.__name__) == 9 — 'signature' (matches __qualname__)"]
    - [currentframe,
       currentframe.__name__.__len__,
       [],
       12,
       "len(inspect.currentframe.__name__) == 12 — 'currentframe' (matches __qualname__, longest helper name)"]
    - [getframeinfo,
       getframeinfo.__name__.__len__,
       [],
       12,
       "len(inspect.getframeinfo.__name__) == 12 — 'getframeinfo' (matches __qualname__, same length as currentframe)"]

# ---------------------------------------------------------------------------
# Parameter.empty.__class__.__name__.__len__() — standalone invariant
#
# inspect.Parameter.empty is a sentinel class object (the _empty class itself, not
# an instance). Parameter.empty.__class__.__name__ is 'type' (4 chars) — because
# Parameter.empty is a class, and the class of a class is 'type' in Python's
# metaclass system. This is distinct from Parameter.empty.__qualname__.__len__()
# which would give the name of _empty itself. No prior inspect spec records
# Parameter.empty.__class__.__name__.__len__() as a standalone in the extra34 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra34.Parameter_empty_classname_len:
  description: "len(inspect.Parameter.empty.__class__.__name__) == 4 — 'type' (Parameter.empty is a class object, not an instance)"
  category: class_structure
  kind: python_call_eq
  function: Parameter.empty.__class__.__name__.__len__
  args: []
  expected: 4
