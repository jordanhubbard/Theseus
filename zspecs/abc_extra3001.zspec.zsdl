spec: ab3001
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Wave 647 — theme: __getitem__, __setitem__, __delitem__ dict-presence (item access/mutation protocol)."
    - "Tests operator.contains(SomeClass.__dict__, '__getitem__') etc. for abc module classes."
    - "Classes covered: ABC, ABCMeta, abstractmethod, abstractproperty, abstractclassmethod, abstractstaticmethod."
    - "None of these abc classes define __getitem__, __setitem__, or __delitem__ in their own __dict__."
    - "abc.abstractmethod is a plain function (type 'function'); its __dict__ has no item-access protocol slots."
    - "ABC uses ABCMeta as its metaclass; ABCMeta.__dict__ also defines no item-access protocol slots."
    - "abstractproperty, abstractclassmethod, abstractstaticmethod are deprecated since Python 3.3 but still present in CPython 3.14."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __getitem__ dict-presence — operator.contains(Cls.__dict__, '__getitem__')
#
# No abc class defines __getitem__; all results are false.
# abc classes are metaclass machinery, not sequences or mappings.
# ---------------------------------------------------------------------------

table ab3001.getitem:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: item_getitem
  id_prefix: gi

  columns: [id, function, args, expected]
  rows:
    - ["gi_ABC",                  operator.contains, [ABC.__dict__,                  "__getitem__"], false]
    - ["gi_ABCMeta",              operator.contains, [ABCMeta.__dict__,              "__getitem__"], false]
    - ["gi_abstractmethod",       operator.contains, [abstractmethod.__dict__,       "__getitem__"], false]
    - ["gi_abstractproperty",     operator.contains, [abstractproperty.__dict__,     "__getitem__"], false]
    - ["gi_abstractclassmethod",  operator.contains, [abstractclassmethod.__dict__,  "__getitem__"], false]
    - ["gi_abstractstaticmethod", operator.contains, [abstractstaticmethod.__dict__, "__getitem__"], false]

# ---------------------------------------------------------------------------
