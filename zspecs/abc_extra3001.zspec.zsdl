    - ["si_ABCMeta",              operator.contains, [ABCMeta.__dict__,              "__setitem__"], false]
    - ["si_abstractmethod",       operator.contains, [abstractmethod.__dict__,       "__setitem__"], false]
    - ["si_abstractproperty",     operator.contains, [abstractproperty.__dict__,     "__setitem__"], false]
    - ["si_abstractclassmethod",  operator.contains, [abstractclassmethod.__dict__,  "__setitem__"], false]
    - ["si_abstractstaticmethod", operator.contains, [abstractstaticmethod.__dict__, "__setitem__"], false]

# ---------------------------------------------------------------------------
