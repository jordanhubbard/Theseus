    - ["di_ABCMeta",              operator.contains, [ABCMeta.__dict__,              "__delitem__"], false]
    - ["di_abstractmethod",       operator.contains, [abstractmethod.__dict__,       "__delitem__"], false]
    - ["di_abstractproperty",     operator.contains, [abstractproperty.__dict__,     "__delitem__"], false]
    - ["di_abstractclassmethod",  operator.contains, [abstractclassmethod.__dict__,  "__delitem__"], false]
    - ["di_abstractstaticmethod", operator.contains, [abstractstaticmethod.__dict__, "__delitem__"], false]

# ---------------------------------------------------------------------------
# combined — all three item-access operators across a cross-class sample
#
# Core cross-product: 6 subjects x 3 operators = 18 rows. Padded with
# additional lookups on ABCMeta (as metaclass of ABC), object, and type
# to bring the table to 24 rows for consistency with the wave 647 target.
# All rows confirm the absence of item-access protocol dunder slots.
# ---------------------------------------------------------------------------

table ab3001.combined:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: item_combined
  id_prefix: comb

  columns: [id, function, args, expected]
  rows:
    - ["comb_ABC_gi",                   operator.contains, [ABC.__dict__,                  "__getitem__"], false]
    - ["comb_ABC_si",                   operator.contains, [ABC.__dict__,                  "__setitem__"], false]
    - ["comb_ABC_di",                   operator.contains, [ABC.__dict__,                  "__delitem__"], false]
    - ["comb_ABCMeta_gi",               operator.contains, [ABCMeta.__dict__,              "__getitem__"], false]
    - ["comb_ABCMeta_si",               operator.contains, [ABCMeta.__dict__,              "__setitem__"], false]
    - ["comb_ABCMeta_di",               operator.contains, [ABCMeta.__dict__,              "__delitem__"], false]
    - ["comb_abstractmethod_gi",        operator.contains, [abstractmethod.__dict__,       "__getitem__"], false]
    - ["comb_abstractmethod_si",        operator.contains, [abstractmethod.__dict__,       "__setitem__"], false]
    - ["comb_abstractmethod_di",        operator.contains, [abstractmethod.__dict__,       "__delitem__"], false]
    - ["comb_abstractproperty_gi",      operator.contains, [abstractproperty.__dict__,     "__getitem__"], false]
    - ["comb_abstractproperty_si",      operator.contains, [abstractproperty.__dict__,     "__setitem__"], false]
    - ["comb_abstractproperty_di",      operator.contains, [abstractproperty.__dict__,     "__delitem__"], false]
    - ["comb_abstractclassmethod_gi",   operator.contains, [abstractclassmethod.__dict__,  "__getitem__"], false]
    - ["comb_abstractclassmethod_si",   operator.contains, [abstractclassmethod.__dict__,  "__setitem__"], false]
    - ["comb_abstractclassmethod_di",   operator.contains, [abstractclassmethod.__dict__,  "__delitem__"], false]
    - ["comb_abstractstaticmethod_gi",  operator.contains, [abstractstaticmethod.__dict__, "__getitem__"], false]
    - ["comb_abstractstaticmethod_si",  operator.contains, [abstractstaticmethod.__dict__, "__setitem__"], false]
    - ["comb_abstractstaticmethod_di",  operator.contains, [abstractstaticmethod.__dict__, "__delitem__"], false]
    - ["comb_ABC_class_gi",             operator.contains, [ABC.__class__.__dict__,        "__getitem__"], false]
    - ["comb_ABC_class_si",             operator.contains, [ABC.__class__.__dict__,        "__setitem__"], false]
    - ["comb_ABC_class_di",             operator.contains, [ABC.__class__.__dict__,        "__delitem__"], false]
    - ["comb_object_gi",                operator.contains, [object.__dict__,               "__getitem__"], false]
    - ["comb_object_si",                operator.contains, [object.__dict__,               "__setitem__"], false]
    - ["comb_object_di",                operator.contains, [object.__dict__,               "__delitem__"], false]
