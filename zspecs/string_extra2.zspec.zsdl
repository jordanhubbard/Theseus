spec: string_extra2
version: ">=3.0"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/string.py"
  notes:
    - "This spec covers aspects not in string.zspec.zsdl or string_extra.zspec.zsdl."
    - "Template.template stores the original pattern string passed to the constructor."
    - "Template.safe_substitute leaves missing keys as-is rather than raising KeyError."
    - "Formatter.format supports both positional ({0}, {1}) and keyword ({name}) placeholders."
    - "capwords('hello world') == 'Hello World' — simple two-word case."
    - "capwords with explicit sep=' ' preserves doubled spaces between words (no collapse)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# capwords — behavioral invariants (simple cases)
# ---------------------------------------------------------------------------

invariant string_extra2.capwords.hello_world:
  description: "capwords('hello world') == 'Hello World'"
  category: capwords
  kind: python_call_eq
  function: capwords
  args: ["hello world"]
  expected: "Hello World"

invariant string_extra2.capwords.empty_string:
  description: "capwords('') == '' — empty string yields empty string"
  category: capwords
  kind: python_call_eq
  function: capwords
  args: [""]
  expected: ""

# ---------------------------------------------------------------------------
# Template — template attribute stores original pattern
# ---------------------------------------------------------------------------

invariant string_extra2.template.attribute_stores_original:
  description: "Template('$x is $y').template == '$x is $y'"
  category: template
  kind: python_call_eq
  function: Template
  args: ["$x is $y"]
  method: template.__eq__
  method_args: ["$x is $y"]
  expected: true

invariant string_extra2.template.attribute_simple:
  description: "Template('$x').template == '$x'"
  category: template
  kind: python_call_eq
  function: Template
  args: ["$x"]
  method: template.__eq__
  method_args: ["$x"]
  expected: true

# ---------------------------------------------------------------------------
# Template.safe_substitute — substitutes present keys, leaves missing as-is
# ---------------------------------------------------------------------------

invariant string_extra2.template.safe_substitute_single:
  description: "Template('$x').safe_substitute(x='hello') == 'hello'"
  category: template
  kind: python_call_eq
  function: Template
  args: ["$x"]
  method: safe_substitute
  method_args: []
  method_kwargs: {x: "hello"}
  expected: "hello"

invariant string_extra2.template.safe_substitute_missing_left_as_is:
  description: "Template('$x $y').safe_substitute(x='hello') == 'hello $y' — missing var left unchanged"
  category: template
  kind: python_call_eq
  function: Template
  args: ["$x $y"]
  method: safe_substitute
  method_args: []
  method_kwargs: {x: "hello"}
  expected: "hello $y"

invariant string_extra2.template.safe_substitute_no_vars:
  description: "Template('hello').safe_substitute() == 'hello' — no placeholders, no kwargs"
  category: template
  kind: python_call_eq
  function: Template
  args: ["hello"]
  method: safe_substitute
  method_args: []
  expected: "hello"

# ---------------------------------------------------------------------------
# Formatter.format — positional and keyword placeholders
# ---------------------------------------------------------------------------

invariant string_extra2.formatter.format_positional:
  description: "Formatter().format('{0} {1}', 'a', 'b') == 'a b'"
  category: formatter
  kind: python_call_eq
  function: Formatter
  args: []
  method: format
  method_args: ["{0} {1}", "a", "b"]
  expected: "a b"

invariant string_extra2.formatter.format_keyword:
  description: "Formatter().format('{name}', name='world') == 'world'"
  category: formatter
  kind: python_call_eq
  function: Formatter
  args: []
  method: format
  method_args: ["{name}"]
  method_kwargs: {name: "world"}
  expected: "world"

invariant string_extra2.formatter.format_empty:
  description: "Formatter().format('hello') == 'hello' — no placeholders"
  category: formatter
  kind: python_call_eq
  function: Formatter
  args: []
  method: format
  method_args: ["hello"]
  expected: "hello"
