spec: reprlib_extra
version: ">=3.2"
backend: python_module(reprlib)

docs: https://docs.python.org/3/library/reprlib.html

provenance:
  derived_from:
    - "Python reprlib documentation — https://docs.python.org/3/library/reprlib.html"
    - "Test vectors verified by running Python 3.14.3 reprlib module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/reprlib.py"
  notes:
    - "This spec covers aspects of the reprlib module not in reprlib.zspec.zsdl."
    - "reprlib.aRepr is a module-level Repr() instance used by the module-level repr() function."
    - "reprlib.repr is a bound method of reprlib.aRepr — its __name__ is 'repr'."
    - "reprlib.recursive_repr is a decorator factory; its __name__ is 'recursive_repr'."
    - "Repr.__module__ == 'reprlib' — the class is defined in the reprlib module."
    - "aRepr.maxstring, aRepr.maxlist, and aRepr.maxdict are plain int attributes."
    - "aRepr.maxtuple is a plain int (default 6) — same as maxlist and maxdict on the module-level Repr instance."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Repr class — module attribute
# ---------------------------------------------------------------------------

invariant reprlib_extra.Repr.module:
  description: "reprlib.Repr.__module__ == 'reprlib'"
  category: classnames
  kind: python_call_eq
  function: Repr.__module__.__eq__
  args: ["reprlib"]
  expected: true

# ---------------------------------------------------------------------------
# recursive_repr — function name attribute
# ---------------------------------------------------------------------------

invariant reprlib_extra.recursive_repr.name:
  description: "reprlib.recursive_repr.__name__ == 'recursive_repr'"
  category: funcnames
  kind: python_call_eq
  function: recursive_repr.__name__.__eq__
  args: ["recursive_repr"]
  expected: true

# ---------------------------------------------------------------------------
# module-level repr — function name attribute
#
# reprlib.repr is a bound method of reprlib.aRepr; its __name__ is 'repr'.
# ---------------------------------------------------------------------------

invariant reprlib_extra.repr.name:
  description: "reprlib.repr.__name__ == 'repr'"
  category: funcnames
  kind: python_call_eq
  function: repr.__name__.__eq__
  args: ["repr"]
  expected: true

# ---------------------------------------------------------------------------
# aRepr — module-level Repr instance type
# ---------------------------------------------------------------------------

invariant reprlib_extra.aRepr.class_name:
  description: "reprlib.aRepr.__class__.__name__ == 'Repr' — aRepr is a Repr instance"
  category: aRepr
  kind: python_call_eq
  function: aRepr.__class__.__name__.__eq__
  args: ["Repr"]
  expected: true

# ---------------------------------------------------------------------------
# aRepr — attribute types
#
# maxstring, maxlist, and maxdict are all plain int attributes on aRepr.
# ---------------------------------------------------------------------------

invariant reprlib_extra.aRepr.maxstring_is_int:
  description: "reprlib.aRepr.maxstring.__class__.__name__ == 'int'"
  category: aRepr
  kind: python_call_eq
  function: aRepr.maxstring.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant reprlib_extra.aRepr.maxlist_is_int:
  description: "reprlib.aRepr.maxlist.__class__.__name__ == 'int'"
  category: aRepr
  kind: python_call_eq
  function: aRepr.maxlist.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant reprlib_extra.aRepr.maxdict_is_int:
  description: "reprlib.aRepr.maxdict.__class__.__name__ == 'int'"
  category: aRepr
  kind: python_call_eq
  function: aRepr.maxdict.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# aRepr — maxtuple attribute type
#
# aRepr.maxtuple is a plain int (default 6); verifies that the module-level
# instance exposes this attribute as an integer like maxlist and maxdict.
# ---------------------------------------------------------------------------

invariant reprlib_extra.aRepr.maxtuple_is_int:
  description: "reprlib.aRepr.maxtuple.__class__.__name__ == 'int'"
  category: aRepr
  kind: python_call_eq
  function: aRepr.maxtuple.__class__.__name__.__eq__
  args: ["int"]
  expected: true
