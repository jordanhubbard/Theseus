spec: re_extra256
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers re.RegexFlag enum class identity and member name/value checks."
    - "re.RegexFlag.__name__ == 'RegexFlag' — the enum class name."
    - "re.RegexFlag.__module__ == 're' — RegexFlag is defined in the re module."
    - "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' — RegexFlag inherits from enum.IntFlag."
    - "re.RegexFlag.IGNORECASE: name == 'IGNORECASE', value == 2."
    - "re.RegexFlag.MULTILINE: name == 'MULTILINE', value == 8."
    - "re.RegexFlag.DOTALL: name == 'DOTALL', value == 16."
    - "re.RegexFlag.VERBOSE: name == 'VERBOSE', value == 64."
    - "re.RegexFlag.UNICODE: name == 'UNICODE', value == 32."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re.RegexFlag class identity
#
# RegexFlag is an IntFlag subclass defined in the re module.
# Its __name__, __module__, and first base class are checked here.
# ---------------------------------------------------------------------------

table re_extra256.regexflag_class_identity:
  description: "re.RegexFlag class identity — __name__, __module__, and base class; new to extra256"
  kind: python_call_eq
  category: identity
  id_prefix: rexrfci256

  columns: [id, function, args, expected, description]
  rows:
    - [class_name,
       "RegexFlag.__name__.__eq__",
       ["RegexFlag"],
       true,
       "re.RegexFlag.__name__.__eq__('RegexFlag') == True — the enum class name is 'RegexFlag'; str.__eq__('RegexFlag') returns True; new to extra256"]
    - [class_module,
       "RegexFlag.__module__.__eq__",
       ["re"],
       true,
       "re.RegexFlag.__module__.__eq__('re') == True — RegexFlag is defined in the re module; its __module__ is 're'; str.__eq__('re') returns True; new to extra256"]
    - [base_class_name,
       "RegexFlag.__bases__.__getitem__",
       [0],
       "IntFlag",
       "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' — RegexFlag inherits from enum.IntFlag, combining integer and flag semantics; __getitem__(0).__name__ is 'IntFlag'; new to extra256"]

# ---------------------------------------------------------------------------
# Table 2: re.RegexFlag member name checks
#
# Each RegexFlag member's .name attribute equals its symbolic string name.
# IGNORECASE, MULTILINE, DOTALL, VERBOSE, UNICODE are the five core flags.
# ---------------------------------------------------------------------------

table re_extra256.regexflag_member_names:
  description: "re.RegexFlag member .name attribute — each flag's name matches its symbolic identifier; new to extra256"
  kind: python_call_eq
  category: identity
  id_prefix: rexrfmn256

  columns: [id, function, args, expected, description]
  rows:
    - [ignorecase_name,
       "RegexFlag.IGNORECASE.name.__eq__",
       ["IGNORECASE"],
       true,
       "re.RegexFlag.IGNORECASE.name.__eq__('IGNORECASE') == True — the IGNORECASE flag's .name is 'IGNORECASE'; this flag enables case-insensitive matching; str.__eq__('IGNORECASE') returns True; new to extra256"]
    - [multiline_name,
       "RegexFlag.MULTILINE.name.__eq__",
       ["MULTILINE"],
       true,
       "re.RegexFlag.MULTILINE.name.__eq__('MULTILINE') == True — the MULTILINE flag's .name is 'MULTILINE'; this flag makes ^ and $ match at line boundaries; str.__eq__('MULTILINE') returns True; new to extra256"]
    - [dotall_name,
       "RegexFlag.DOTALL.name.__eq__",
       ["DOTALL"],
       true,
       "re.RegexFlag.DOTALL.name.__eq__('DOTALL') == True — the DOTALL flag's .name is 'DOTALL'; this flag makes . match any character including newline; str.__eq__('DOTALL') returns True; new to extra256"]
    - [verbose_name,
       "RegexFlag.VERBOSE.name.__eq__",
       ["VERBOSE"],
       true,
       "re.RegexFlag.VERBOSE.name.__eq__('VERBOSE') == True — the VERBOSE flag's .name is 'VERBOSE'; this flag allows whitespace and comments in patterns; str.__eq__('VERBOSE') returns True; new to extra256"]
    - [unicode_name,
       "RegexFlag.UNICODE.name.__eq__",
       ["UNICODE"],
       true,
       "re.RegexFlag.UNICODE.name.__eq__('UNICODE') == True — the UNICODE flag's .name is 'UNICODE'; this flag enables Unicode matching (default for str patterns); str.__eq__('UNICODE') returns True; new to extra256"]

# ---------------------------------------------------------------------------
# Table 3: re.RegexFlag member value checks
#
# Numeric values: IGNORECASE=2, MULTILINE=8, DOTALL=16, UNICODE=32, VERBOSE=64.
# These are powers of 2 / distinct bit positions in the integer flag field.
# ---------------------------------------------------------------------------

table re_extra256.regexflag_member_values:
  description: "re.RegexFlag member .value attribute — each flag's integer bit value; new to extra256"
  kind: python_call_eq
  category: identity
  id_prefix: rexrfmv256

  columns: [id, function, args, expected, description]
  rows:
    - [ignorecase_value,
       "RegexFlag.IGNORECASE.value.__eq__",
       [2],
       true,
       "re.RegexFlag.IGNORECASE.value.__eq__(2) == True — IGNORECASE has integer value 2 (bit 1); int.__eq__(2) returns True; new to extra256"]
    - [multiline_value,
       "RegexFlag.MULTILINE.value.__eq__",
       [8],
       true,
       "re.RegexFlag.MULTILINE.value.__eq__(8) == True — MULTILINE has integer value 8 (bit 3); int.__eq__(8) returns True; new to extra256"]
    - [dotall_value,
       "RegexFlag.DOTALL.value.__eq__",
       [16],
       true,
       "re.RegexFlag.DOTALL.value.__eq__(16) == True — DOTALL has integer value 16 (bit 4); int.__eq__(16) returns True; new to extra256"]
    - [unicode_value,
       "RegexFlag.UNICODE.value.__eq__",
       [32],
       true,
       "re.RegexFlag.UNICODE.value.__eq__(32) == True — UNICODE has integer value 32 (bit 5); int.__eq__(32) returns True; new to extra256"]
    - [verbose_value,
       "RegexFlag.VERBOSE.value.__eq__",
       [64],
       true,
       "re.RegexFlag.VERBOSE.value.__eq__(64) == True — VERBOSE has integer value 64 (bit 6); int.__eq__(64) returns True; new to extra256"]

# ---------------------------------------------------------------------------
# Standalone invariants — re_extra256
# ---------------------------------------------------------------------------

invariant re_extra256.regexflag_name:
  description: "re.RegexFlag.__name__ == 'RegexFlag' — the enum class name; new to extra256"
  kind: python_call_eq
  function: RegexFlag.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra256.regexflag_module:
  description: "re.RegexFlag.__module__ == 're' — RegexFlag is defined in the re module; new to extra256"
  kind: python_call_eq
  function: RegexFlag.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra256.regexflag_base_is_intflag:
  description: "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' — RegexFlag inherits from enum.IntFlag; new to extra256"
  kind: python_call_eq
  function: "RegexFlag.__bases__[0].__name__.__eq__"
  args: ["IntFlag"]
  expected: true

invariant re_extra256.ignorecase_name:
  description: "re.RegexFlag.IGNORECASE.name == 'IGNORECASE' — the IGNORECASE flag enables case-insensitive pattern matching; new to extra256"
  kind: python_call_eq
  function: RegexFlag.IGNORECASE.name.__eq__
  args: ["IGNORECASE"]
  expected: true

invariant re_extra256.ignorecase_value:
  description: "re.RegexFlag.IGNORECASE.value == 2 — IGNORECASE occupies bit 1 in the flag integer; new to extra256"
  kind: python_call_eq
  function: RegexFlag.IGNORECASE.value.__eq__
  args: [2]
  expected: true

invariant re_extra256.multiline_value:
  description: "re.RegexFlag.MULTILINE.value == 8 — MULTILINE occupies bit 3 in the flag integer; new to extra256"
  kind: python_call_eq
  function: RegexFlag.MULTILINE.value.__eq__
  args: [8]
  expected: true

invariant re_extra256.dotall_value:
  description: "re.RegexFlag.DOTALL.value == 16 — DOTALL occupies bit 4 in the flag integer; new to extra256"
  kind: python_call_eq
  function: RegexFlag.DOTALL.value.__eq__
  args: [16]
  expected: true

invariant re_extra256.unicode_value:
  description: "re.RegexFlag.UNICODE.value == 32 — UNICODE occupies bit 5 in the flag integer; new to extra256"
  kind: python_call_eq
  function: RegexFlag.UNICODE.value.__eq__
  args: [32]
  expected: true

invariant re_extra256.verbose_value:
  description: "re.RegexFlag.VERBOSE.value == 64 — VERBOSE occupies bit 6 in the flag integer; new to extra256"
  kind: python_call_eq
  function: RegexFlag.VERBOSE.value.__eq__
  args: [64]
  expected: true
