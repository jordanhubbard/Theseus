provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "concurrent.futures.as_completed.__name__ == 'as_completed' (len=12: 'as_completed'=12)."
    - "concurrent.futures.as_completed.__module__ == 'concurrent.futures._base' (len=24: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'_base'=5=24)."
    - "concurrent.futures.as_completed.__qualname__ == 'as_completed' (len=12); qualname equals name for a module-level function."
    - "concurrent.futures.wait.__name__ == 'wait' (len=4)."
    - "concurrent.futures.wait.__module__ == 'concurrent.futures._base' (len=24); same module as as_completed."
    - "concurrent.futures.wait.__qualname__ == 'wait' (len=4); qualname equals name for a module-level function."
    - "concurrent.futures.FIRST_COMPLETED.__class__.__name__ == 'str' — FIRST_COMPLETED is a plain string constant ('FIRST_COMPLETED', len=15)."
    - "concurrent.futures.ALL_COMPLETED.__class__.__name__ == 'str' — ALL_COMPLETED is a plain string constant ('ALL_COMPLETED', len=13)."
    - "Length ordering: wait.__name__ (4) << as_completed.__name__ (12) == as_completed.__qualname__ (12); ALL_COMPLETED value (13) < FIRST_COMPLETED value (15)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

