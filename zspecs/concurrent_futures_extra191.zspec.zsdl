    - [first_value_eq,   concurrent.futures.FIRST_COMPLETED.__eq__,                   ["FIRST_COMPLETED"], true, "concurrent.futures.FIRST_COMPLETED == 'FIRST_COMPLETED' (len=15: 'FIRST_'=6+'COMPLETED'=9=15); verified Python 3.14.3"]
    - [first_value_len,  concurrent.futures.FIRST_COMPLETED.__len__,                  [],       15,   "concurrent.futures.FIRST_COMPLETED.__len__() == 15 ('FIRST_COMPLETED'=15: 'FIRST_'=6+'COMPLETED'=9=15); verified Python 3.14.3"]
