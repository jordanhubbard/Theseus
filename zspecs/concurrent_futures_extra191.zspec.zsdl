  category: identity
  id_prefix: cfwait191

  columns: [id, function, args, expected, description]
  rows:
    - [asc_name_eq,     concurrent.futures.as_completed.__name__.__eq__,     ["as_completed"],               true, "concurrent.futures.as_completed.__name__ == 'as_completed' (len=12; yields futures as they complete); verified Python 3.14.3"]
