    - [asc_module_len,  concurrent.futures.as_completed.__module__.__len__,  [],                             24,   "concurrent.futures.as_completed.__module__.__len__() == 24 ('concurrent.futures._base'=24: concurrent=10+.=1+futures=7+.=1+_base=5=24); verified Python 3.14.3"]
    - [asc_qualname_eq, concurrent.futures.as_completed.__qualname__.__eq__, ["as_completed"],               true, "concurrent.futures.as_completed.__qualname__ == 'as_completed' (len=12; qualname equals name for module-level function); verified Python 3.14.3"]

