table concurrent_futures_extra191.cf_wait_constants_identity:
  description: "concurrent.futures wait-state string constants identity in cfwait191 namespace — FIRST_COMPLETED.__class__.__name__=='str' (value='FIRST_COMPLETED', len=15: 'FIRST_'=6+'COMPLETED'=9=15; passed to wait() to return as soon as the first future finishes); ALL_COMPLETED.__class__.__name__=='str' (value='ALL_COMPLETED', len=13: 'ALL_'=4+'COMPLETED'=9=13; passed to wait() to block until all futures finish, the default return_when value); both constants are plain str objects (not enum members) — they are module-level string sentinels in concurrent.futures._base; ALL_COMPLETED (13) < FIRST_COMPLETED (15) by 2; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfwait191

  columns: [id, function, args, expected, description]
