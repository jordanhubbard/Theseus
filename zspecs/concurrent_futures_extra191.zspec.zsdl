    - [all_value_len,    concurrent.futures.ALL_COMPLETED.__len__,                     [],       13,   "concurrent.futures.ALL_COMPLETED.__len__() == 13 ('ALL_COMPLETED'=13: 'ALL_'=4+'COMPLETED'=9=13); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra191
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra191.cf_as_completed_name_eq:
  description: "concurrent.futures.as_completed.__name__.__eq__('as_completed') returns True — concurrent.futures.as_completed.__name__=='as_completed' (len=12: 'as_completed'=12; 'as_'=3+'completed'=9=12); as_completed is a generator function that takes an iterable of futures and yields them one by one as they complete, regardless of submission order; it is the primary pattern for processing results as soon as they are ready without waiting for the entire batch; as_completed.__name__ (12) == as_completed.__qualname__ (12) — confirming it is a module-level function; NEW in cfwait191: first standalone as_completed.__name__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.as_completed.__name__.__eq__
  args: ["as_completed"]
  expected: true

invariant concurrent_futures_extra191.cf_as_completed_module_eq:
  description: "concurrent.futures.as_completed.__module__.__eq__('concurrent.futures._base') returns True — as_completed.__module__=='concurrent.futures._base' (len=24: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'_base'=5=24); as_completed is defined in the private _base submodule of concurrent.futures alongside wait(), Future, Executor, and the exception classes; as_completed.__module__ (24) == wait.__module__ (24) — both functions share the _base module; as_completed.__module__ (24) >> len('concurrent.futures') (18) — the private _base suffix adds 6 characters; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.as_completed.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra191.cf_as_completed_qualname_eq:
  description: "concurrent.futures.as_completed.__qualname__.__eq__('as_completed') returns True — as_completed.__qualname__=='as_completed' (len=12); for a module-level function the qualname is identical to __name__; if as_completed were a nested function or method the qualname would include the enclosing class or function name separated by '.'; as_completed.__qualname__ (12) == as_completed.__name__ (12) — confirming module-level scope; compare a method qualname like 'Condition.wait' (14) which includes the class prefix; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.as_completed.__qualname__.__eq__
  args: ["as_completed"]
  expected: true

invariant concurrent_futures_extra191.cf_wait_name_eq:
  description: "concurrent.futures.wait.__name__.__eq__('wait') returns True — concurrent.futures.wait.__name__=='wait' (len=4: w(1)a(2)i(3)t(4)); wait() takes an iterable of futures and an optional timeout and return_when argument; it blocks until the specified condition is met, returning a named 2-tuple (done, not_done) of sets; wait.__name__ (4) << as_completed.__name__ (12) by 8 — 'wait' is one of the shortest Python stdlib function names; NEW in cfwait191: first standalone wait.__name__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.wait.__name__.__eq__
  args: ["wait"]
  expected: true

invariant concurrent_futures_extra191.cf_wait_module_eq:
  description: "concurrent.futures.wait.__module__.__eq__('concurrent.futures._base') returns True — wait.__module__=='concurrent.futures._base' (len=24); wait() is defined in the private _base submodule of concurrent.futures, the same module as as_completed(); wait.__module__ (24) == as_completed.__module__ (24) — both utility functions share the _base implementation module; the public concurrent.futures namespace re-exports both from _base via __init__.py; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.wait.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra191.cf_FIRST_COMPLETED_class_is_str:
  description: "concurrent.futures.FIRST_COMPLETED.__class__.__name__.__eq__('str') returns True — FIRST_COMPLETED.__class__.__name__=='str'; FIRST_COMPLETED is a plain string sentinel constant with value 'FIRST_COMPLETED' (len=15); it is passed as the return_when argument to wait() to indicate that the function should return when any future finishes or is cancelled; FIRST_COMPLETED is not an enum member — it is a raw str, unlike Python 3 enum-style constants; FIRST_COMPLETED (15) > ALL_COMPLETED (13) by 2; NEW in cfwait191: first standalone FIRST_COMPLETED class check; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.FIRST_COMPLETED.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra191.cf_ALL_COMPLETED_class_is_str:
  description: "concurrent.futures.ALL_COMPLETED.__class__.__name__.__eq__('str') returns True — ALL_COMPLETED.__class__.__name__=='str'; ALL_COMPLETED is a plain string sentinel with value 'ALL_COMPLETED' (len=13: 'ALL_'=4+'COMPLETED'=9=13); it is the default value for the return_when argument of wait(), meaning wait() blocks until every future in the input set has completed or been cancelled; ALL_COMPLETED (13) < FIRST_COMPLETED (15) by 2; ALL_COMPLETED.__class__.__name__=='str' (3) — both constants are raw str objects sharing the same class name length; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ALL_COMPLETED.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra191.cf_wait_qualname_eq:
  description: "concurrent.futures.wait.__qualname__.__eq__('wait') returns True — wait.__qualname__=='wait' (len=4: w(1)a(2)i(3)t(4)); for a module-level function the qualname is identical to __name__; wait.__qualname__ (4) == wait.__name__ (4) — confirming module-level scope with no enclosing class or function; compare as_completed.__qualname__ (12) == as_completed.__name__ (12) — both follow the same pattern; a method qualname like 'Condition.wait' (14) would include the class prefix; wait.__qualname__ (4) is the shortest qualname in this spec; NEW in cfwait191: completing 8-invariant coverage for concurrent.futures wait function and constant identity; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.wait.__qualname__.__eq__
  args: ["wait"]
  expected: true

