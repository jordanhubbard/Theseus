spec: theseus_urllib_response_cr
version: ">=3.0"
backend: python_cleanroom(theseus_urllib_response_cr)
blocks: urllib.response

docs: https://docs.python.org/3/library/urllib.response.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/urllib.response.html"
  not_derived_from:
    - "CPython source: Lib/urllib/response.py"
  notes:
    - "Clean-room urllib.response module. Do NOT import urllib.response."

error_model: python_exceptions

invariant theseus_urllib_response_cr.urlresponse2_addinfo:
  description: "addinfo() wrapper class exists"
  category: behavior
  kind: python_call_eq
  function: urlresponse2_addinfo
  args: []
  expected: true

invariant theseus_urllib_response_cr.urlresponse2_addinfourl:
  description: "addinfourl class exists with url/headers/code attrs"
  category: behavior
  kind: python_call_eq
  function: urlresponse2_addinfourl
  args: []
  expected: true

invariant theseus_urllib_response_cr.urlresponse2_methods:
  description: "addinfourl has read/info/geturl methods"
  category: behavior
  kind: python_call_eq
  function: urlresponse2_methods
  args: []
  expected: true
