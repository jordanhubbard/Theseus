spec: hashlib_extra96
version: ">=3.9"
extends: hashlib_extra95
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra95.zspec.zsdl — covers hashlib.new/__qualname__.__eq__('__hash_new') / new/__code__/co_name.__eq__ / new/__code__/co_argcount.__eq__(1) / new/__module__.__eq__('hashlib') / sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__.__eq__ and __module__.__eq__('_hashlib') (table + invariants)."
    - "hashlib_extra94.zspec.zsdl — covers hashlib.algorithms_available/algorithms_guaranteed set class identity and membership / sha256/sha512/sha1/md5 constructor __class__.__name__=='builtin_function_or_method' (table + invariants)."
    - "hashlib_extra93.zspec.zsdl — covers hashlib.blake2b and blake2s integer class constants MAX_DIGEST_SIZE/MAX_KEY_SIZE/SALT_SIZE/PERSON_SIZE class identity and values (table + invariants)."
    - "hashlib_extra92.zspec.zsdl — covers hashlib.sha256/sha512/md5/sha1/sha224/sha384 class identity (__class__.__name__=='builtin_function_or_method', __module__=='_hashlib', __qualname__) (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra95; it does NOT duplicate invariants present in those files."
    - "Wave 257 theme: hashlib module identity (__name__, __package__, __loader__, __spec__, __doc__) + HASH type identity via sha256 instance type."
    - "hashlib.__name__ == 'hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__package__ == '' (empty string). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__loader__.__class__.__name__ == 'SourceFileLoader'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.__class__.__name__ == 'ModuleSpec'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.sha256()).__name__ == 'HASH'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.sha256()).__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.sha256()).__bases__[0].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.sha256()).__mro__.__len__() == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.HASH does not exist as a module-level attr; the HASH type is accessible only via type(hashlib.sha256()). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.__name__.__eq__('hashlib')
# hashlib.__package__.__eq__('')
#
# Wave 257 theme: hashlib module string identity (__name__, __package__).
#
# hashlib.__name__ is 'hashlib' and __package__ is '' (empty string). Early
# hashlib specs first anchor these; this table cross-checks them together
# under hashlibmodule96. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra96.hashlib_module_string_identity:
  description: "hashlib.__name__.__eq__('hashlib')==True / hashlib.__package__.__eq__('')==True — hashlib module __name__ is 'hashlib' and __package__ is empty string (top-level module); early hashlib specs first anchor these; this table cross-checks both together under hashlibmodule96; first hashlibmodule96 anchor for hashlib module string identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: hashlibmodule96

  columns: [id, function, args, expected]
  rows:
    - [hashlib_name_eq,    __name__.__eq__,    ["hashlib"], true]
    - [hashlib_package_eq, __package__.__eq__, [""],        true]

# ---------------------------------------------------------------------------
# hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec')
# hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader')
# hashlib.__doc__.__class__.__name__.__eq__('str')
#
# Wave 257 theme: hashlib __spec__, __loader__, and __doc__ class names.
#
# hashlib.__spec__ is a ModuleSpec instance. hashlib.__loader__ is a
# SourceFileLoader because hashlib is a Python module (Lib/hashlib.py).
# hashlib.__doc__ is a str (the module docstring). No prior hashlib spec
# anchors these three together under hashlibmodule96.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra96.hashlib_spec_loader_doc_class_names:
  description: "hashlib.__spec__/__class__/__name__.__eq__('ModuleSpec')==True / hashlib.__loader__/__class__/__name__.__eq__('SourceFileLoader')==True / hashlib.__doc__/__class__/__name__.__eq__('str')==True — hashlib.py is loaded by SourceFileLoader; its spec is a ModuleSpec; the module docstring is a str; no prior hashlib spec anchors these together under hashlibmodule96; first hashlibmodule96 anchor for hashlib spec/loader/doc class names"
  kind: python_call_eq
  category: module_identity
  id_prefix: hashlibmodule96

  columns: [id, function, args, expected]
  rows:
    - [hashlib_spec_class_eq,   __spec__.__class__.__name__.__eq__,   ["ModuleSpec"],       true]
    - [hashlib_loader_class_eq, __loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true]
    - [hashlib_doc_class_eq,    __doc__.__class__.__name__.__eq__,    ["str"],               true]

# ---------------------------------------------------------------------------
# hashlib.new.__qualname__.__eq__('__hash_new') (cross-check)
# hashlib.new.__module__.__eq__('hashlib') (cross-check)
# hashlib.new.__code__.co_argcount.__eq__(1) (cross-check)
#
# Wave 257 theme: hashlib.new function identity cross-checks.
#
# hashlib.new is the Python-level dispatch function with qualname '__hash_new'
# and module 'hashlib'. Its co_argcount is 1 (the required 'name' argument).
# hashlib_extra95 first anchors these; this table cross-checks all three
# together under hashlibmodule96. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra96.hashlib_new_func_identity:
  description: "hashlib.new/__qualname__.__eq__('__hash_new')==True / hashlib.new/__module__.__eq__('hashlib')==True / hashlib.new/__code__/co_argcount.__eq__(1)==True — hashlib.new is a Python wrapper with qualname '__hash_new', module 'hashlib', and co_argcount 1; hashlib_extra95 first anchors these; this table cross-checks all three together under hashlibmodule96; first hashlibmodule96 anchor for hashlib.new function identity"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibmodule96

  columns: [id, function, args, expected]
  rows:
    - [new_qualname_xchk,    new.__qualname__.__eq__,         ["__hash_new"], true]
    - [new_module_xchk,      new.__module__.__eq__,           ["hashlib"],    true]
    - [new_co_argcount_xchk, new.__code__.co_argcount.__eq__, [1],            true]

# ---------------------------------------------------------------------------
# hashlib.sha256/__module__.__eq__('_hashlib')
# hashlib.sha512/__module__.__eq__('_hashlib')
# hashlib.sha1/__module__.__eq__('_hashlib')
# hashlib.md5/__module__.__eq__('_hashlib')
#
# Wave 257 theme: sha256/sha512/sha1/md5 __module__ equality to '_hashlib'.
#
# All four OpenSSL-backed constructors sha256, sha512, sha1, and md5 have
# __module__ == '_hashlib' (the C extension). hashlib_extra95 anchors all
# eight constructors in one table; this table cross-checks the four most
# common ones under hashlibmodule96. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra96.sha256_sha512_sha1_md5_module_xchk:
  description: "hashlib.sha256/__module__.__eq__('_hashlib')==True / sha512/__module__.__eq__('_hashlib')==True / sha1/__module__.__eq__('_hashlib')==True / md5/__module__.__eq__('_hashlib')==True — sha256/sha512/sha1/md5 are all implemented in the _hashlib C extension; __module__ is '_hashlib' for each; hashlib_extra95 anchors all eight constructors; this table cross-checks the four most common under hashlibmodule96; first hashlibmodule96 anchor for sha256/sha512/sha1/md5 __module__ equality"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibmodule96

  columns: [id, function, args, expected]
  rows:
    - [sha256_module_xchk, sha256.__module__.__eq__, ["_hashlib"], true]
    - [sha512_module_xchk, sha512.__module__.__eq__, ["_hashlib"], true]
    - [sha1_module_xchk,   sha1.__module__.__eq__,   ["_hashlib"], true]
    - [md5_module_xchk,    md5.__module__.__eq__,    ["_hashlib"], true]

# ---------------------------------------------------------------------------
# hashlib.__name__.__eq__('hashlib') — standalone
#
# hashlib.__name__ is 'hashlib'. Early hashlib specs first anchor this; this
# standalone re-anchors it under hashlibmodule96. The module name is the
# canonical identifier used in import statements. First standalone for
# hashlib.__name__ under hashlibmodule96.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra96.hashlib_name_eq:
  description: "hashlib.__name__.__eq__('hashlib') == True — hashlib is a top-level stdlib module; its __name__ is 'hashlib'; early hashlib specs first anchor this; this standalone re-anchors under hashlibmodule96; first standalone for hashlib.__name__ under hashlibmodule96"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__package__.__eq__('') — standalone
#
# hashlib.__package__ is '' (empty string). hashlib is a top-level module,
# not part of any package. No prior hashlib spec anchors __package__.__eq__('')
# as a standalone under hashlibmodule96. First standalone for hashlib.__package__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra96.hashlib_package_eq:
  description: "hashlib.__package__.__eq__('') == True — hashlib is a top-level stdlib module; its __package__ is empty string (not part of any package); no prior hashlib spec anchors this as a standalone under hashlibmodule96; first standalone for hashlib.__package__ under hashlibmodule96"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec') — standalone
#
# hashlib.__spec__.__class__.__name__ is 'ModuleSpec'. hashlib is a pure-Python
# module loaded by importlib, so its __spec__ is an importlib.machinery.ModuleSpec
# instance. No prior hashlib spec anchors __spec__.__class__.__name__.__eq__ as
# a standalone under hashlibmodule96. First standalone for hashlib __spec__ class.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra96.hashlib_spec_class_eq:
  description: "hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — hashlib is a pure-Python module; its __spec__ is an importlib.machinery.ModuleSpec instance with class name 'ModuleSpec'; no prior hashlib spec anchors this as a standalone; first standalone for hashlib.__spec__ class under hashlibmodule96"
  category: module_identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') — standalone
#
# hashlib.__loader__.__class__.__name__ is 'SourceFileLoader'. hashlib.py is
# a pure-Python source file loaded by importlib.machinery.SourceFileLoader.
# No prior hashlib spec anchors __loader__.__class__.__name__.__eq__ as a
# standalone under hashlibmodule96. First standalone for hashlib __loader__ class.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra96.hashlib_loader_class_eq:
  description: "hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — hashlib.py is a pure-Python source file loaded by importlib.machinery.SourceFileLoader; its __loader__.__class__.__name__ is 'SourceFileLoader'; no prior hashlib spec anchors this as a standalone; first standalone for hashlib.__loader__ class under hashlibmodule96"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__doc__.__class__.__name__.__eq__('str') — standalone
#
# hashlib.__doc__.__class__.__name__ is 'str'. The module docstring is a
# plain Python string. No prior hashlib spec anchors __doc__.__class__.__name__.__eq__
# as a standalone under hashlibmodule96. First standalone for hashlib __doc__ class.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra96.hashlib_doc_class_eq:
  description: "hashlib.__doc__.__class__.__name__.__eq__('str') == True — the hashlib module has a docstring; its __class__.__name__ is 'str'; no prior hashlib spec anchors this as a standalone under hashlibmodule96; first standalone for hashlib.__doc__ class under hashlibmodule96"
  category: module_identity
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
