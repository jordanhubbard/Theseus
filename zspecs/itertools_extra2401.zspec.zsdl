spec: itertools_extra2401
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/itertools.html"
    - "CPython source — Modules/itertoolsmodule.c"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 607 (_extra2401): __hash__ and __eq__ implementation type classification."
    - "All itertools types are C extension types that inherit __hash__ and __eq__ from object."
    - "All itertools classes have __hash__.__class__.__name__ == 'wrapper_descriptor' (inherited from object)."
    - "All itertools classes have __eq__.__class__.__name__ == 'wrapper_descriptor' (inherited from object)."
    - "None of the itertools classes define __hash__ or __eq__ in their own __dict__."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

