spec: just_diff
version: ">=3.0.0"
backend: node(just-diff)

docs: https://www.npmjs.com/package/just-diff

provenance:
  derived_from:
    - "just-diff README — https://www.npmjs.com/package/just-diff"
    - "Test vectors verified with just-diff via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "just-diff source"
  notes:
    - "just-diff is an npm package. Install: npm install just-diff"
    - "diff(original, updated) returns an array of JSON Patch operations (RFC 6902 style)."
    - "Each operation has: op (add|remove|replace), path (array of keys/indices), value (for add/replace)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array of patch operations."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_diff.diff:
  kind: node_module_call_eq
  function: diff
  category: diff
  id_prefix: jdiff

  columns: [id, args, expected]
  rows:
    - [replace, [{"a": 1, "b": 2}, {"a": 1, "b": 3}],
       [{"op": "replace", "path": ["b"], "value": 3}]]
    - [add,     [{"a": 1}, {"a": 1, "c": 3}],
       [{"op": "add", "path": ["c"], "value": 3}]]
    - [remove,  [{"a": 1, "b": 2}, {"a": 1}],
       [{"op": "remove", "path": ["b"]}]]
    - [array,   [[1, 2, 3], [1, 4, 3]],
       [{"op": "replace", "path": [1], "value": 4}]]
    - [same,    [{"a": 1}, {"a": 1}],
       []]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:07:38Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
