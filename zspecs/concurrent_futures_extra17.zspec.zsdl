spec: concurrent_futures_extra17
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures.zspec.zsdl and prior extras through concurrent_futures_extra16.zspec.zsdl."
    - "extra covers: Future/Executor/ThreadPoolExecutor/ProcessPoolExecutor __name__; wait/__name__; as_completed/__name__."
    - "extra15 covers: Future/Executor/ThreadPoolExecutor/ProcessPoolExecutor __module__ table; wait/as_completed __module__."
    - "extra16 covers: class_qualnames table; class_modules table; as_completed/__name__; wait/__name__; FIRST_COMPLETED class name."
    - "NOT yet covered in any prior spec: concurrent.futures.Future.__name__ == 'Future' as standalone extra17-namespace __eq__ invariant."
    - "NOT yet covered: concurrent.futures.Executor.__name__ == 'Executor' as standalone extra17-namespace __eq__ invariant."
    - "NOT yet covered: concurrent.futures.ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor' as standalone extra17-namespace __eq__ invariant."
    - "NOT yet covered: concurrent.futures.ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor' as standalone extra17-namespace __eq__ invariant."
    - "NOT yet covered: concurrent.futures.CancelledError.__name__ == 'CancelledError' as standalone __eq__ invariant."
    - "NOT yet covered: concurrent.futures.TimeoutError.__name__ == 'TimeoutError' as standalone __eq__ invariant."
    - "NOT yet covered: concurrent.futures.Future.__module__ == 'concurrent.futures._base' as standalone extra17-namespace __eq__ invariant."
    - "NOT yet covered: concurrent.futures.CancelledError.__module__ == 'concurrent.futures._base' as standalone invariant."
    - "NOT yet covered: concurrent.futures.BrokenExecutor.__name__ == 'BrokenExecutor' and BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'."
    - "concurrent.futures.CancelledError.__bases__[0].__name__ == 'Error' — CancelledError inherits from the concurrent.futures._base Error class."
    - "concurrent.futures.TimeoutError.__module__ == 'builtins' — TimeoutError is an alias for the built-in TimeoutError."
    - "concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError' — verified Python 3.12 on macOS."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ checks — Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor
#
# extra and extra16 cover these values in tables. These standalone invariants
# provide independent extra17-namespace anchors for all four executor classes.
# ---------------------------------------------------------------------------

table concurrent_futures_extra17.class_names:
  description: "concurrent.futures executor and future classes have correct __name__ attributes"
  kind: python_call_eq
  category: class_names
  id_prefix: clsn17

  columns: [id, function, args, expected]
  rows:
    - [Future,              Future.__name__.__eq__,              ["Future"],              true]
    - [Executor,            Executor.__name__.__eq__,            ["Executor"],            true]
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__name__.__eq__,  ["ThreadPoolExecutor"],  true]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__name__.__eq__, ["ProcessPoolExecutor"], true]

# ---------------------------------------------------------------------------
# CancelledError and TimeoutError __name__ — standalone invariants
#
# No prior spec checks CancelledError/__name__ or TimeoutError/__name__ as
# standalone __eq__ invariants. Both are public exception types in the module.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra17.CancelledError.name:
  description: "concurrent.futures.CancelledError.__name__ == 'CancelledError'"
  category: class_names
  kind: python_call_eq
  function: CancelledError.__name__.__eq__
  args: ["CancelledError"]
  expected: true

invariant concurrent_futures_extra17.TimeoutError.name:
  description: "concurrent.futures.TimeoutError.__name__ == 'TimeoutError'"
  category: class_names
  kind: python_call_eq
  function: TimeoutError.__name__.__eq__
  args: ["TimeoutError"]
  expected: true

# ---------------------------------------------------------------------------
# Future.__module__ — standalone extra17-namespace invariant
#
# extra15 and extra16 both cover Future/__module__ in tables. This standalone
# invariant provides independent extra17-namespace confirmation that
# Future is defined in concurrent.futures._base.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra17.Future.module:
  description: "concurrent.futures.Future.__module__ == 'concurrent.futures._base'"
  category: class_modules
  kind: python_call_eq
  function: Future.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

# ---------------------------------------------------------------------------
# CancelledError.__module__ — standalone invariant
#
# CancelledError is defined in concurrent.futures._base alongside Future.
# No prior spec checks CancelledError/__module__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra17.CancelledError.module:
  description: "concurrent.futures.CancelledError.__module__ == 'concurrent.futures._base'"
  category: class_modules
  kind: python_call_eq
  function: CancelledError.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

# ---------------------------------------------------------------------------
# BrokenExecutor — __name__ and base class hierarchy
#
# concurrent.futures.BrokenExecutor is a public exception introduced in
# Python 3.7 for executors that cannot be used due to fatal errors.
# No prior spec checks BrokenExecutor/__name__ or BrokenExecutor/__bases__[0].
# BrokenExecutor.__bases__[0].__name__ == 'RuntimeError' — verified Python 3.12.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra17.BrokenExecutor.name:
  description: "concurrent.futures.BrokenExecutor.__name__ == 'BrokenExecutor'"
  category: class_names
  kind: python_call_eq
  function: BrokenExecutor.__name__.__eq__
  args: ["BrokenExecutor"]
  expected: true

invariant concurrent_futures_extra17.BrokenExecutor.base_is_RuntimeError:
  description: "concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'"
  category: class_hierarchy
  kind: python_call_eq
  function: BrokenExecutor.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "RuntimeError"
