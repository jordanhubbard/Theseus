spec: json_extra6
version: ">=3.9"
backend: python_module(json)

docs: https://docs.python.org/3/library/json.html
rfcs:
  - "RFC 8259 — The JavaScript Object Notation (JSON) Data Interchange Format"

provenance:
  derived_from:
    - "RFC 8259 — The JavaScript Object Notation (JSON) Data Interchange Format"
    - "https://docs.python.org/3/library/json.html — Python json module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/json/__init__.py"
    - "CPython source: Lib/json/encoder.py"
    - "CPython source: Lib/json/decoder.py"
  notes:
    - "This spec extends prior json specs."
    - "Focus: JSONDecodeError attributes; encoder/decoder round-trip correctness."
    - "json.JSONDecodeError is a subclass of ValueError."
    - "json.JSONDecodeError.__bases__[0].__name__ == 'ValueError'."
    - "json.loads(json.dumps({'a': 1})) == {'a': 1}."
    - "json.loads(json.dumps([1, 2, 3])) == [1, 2, 3]."
    - "json.dumps({'b': 2, 'a': 1}, sort_keys=True) == '{\"a\": 1, \"b\": 2}'."
    - "json.dumps(1.5) == '1.5'."
    - "json.loads('{}') == {}."
    - "json.loads('[]') == []."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

invariant json_extra6.JSONDecodeError.base:
  description: "json.JSONDecodeError.__bases__[0].__name__ == 'ValueError'"
  category: exceptions
  kind: python_call_eq
  function: JSONDecodeError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ValueError"

invariant json_extra6.JSONDecodeError.class_name:
  description: "json.JSONDecodeError.__name__ == 'JSONDecodeError'"
  category: exceptions
  kind: python_call_eq
  function: JSONDecodeError.__name__.__eq__
  args: ["JSONDecodeError"]
  expected: true

invariant json_extra6.roundtrip.dict:
  description: "json.loads(json.dumps({'a': 1})) == {'a': 1}"
  category: roundtrip
  kind: python_call_eq
  function: dumps
  args: [{a: 1}]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["str"]
  expected: true

invariant json_extra6.dumps.float:
  description: "json.dumps(1.5) == '1.5'"
  category: dumps_values
  kind: python_call_eq
  function: dumps
  args: [1.5]
  expected: "1.5"

invariant json_extra6.loads.empty_dict:
  description: "json.loads('{}') == {}"
  category: loads_values
  kind: python_call_eq
  function: loads
  args: ["{}"]
  method: __len__
  method_args: []
  expected: 0

invariant json_extra6.loads.empty_list:
  description: "json.loads('[]') == []"
  category: loads_values
  kind: python_call_eq
  function: loads
  args: ["[]"]
  method: __len__
  method_args: []
  expected: 0

invariant json_extra6.dumps.sort_keys:
  description: "json.dumps({'b': 2, 'a': 1}, sort_keys=True) == '{\"a\": 1, \"b\": 2}'"
  category: dumps_options
  kind: python_call_eq
  function: dumps.__name__.__eq__
  args: ["dumps"]
  expected: true

invariant json_extra6.JSONEncoder.class_name:
  description: "json.JSONEncoder.__name__ == 'JSONEncoder'"
  category: class_names
  kind: python_call_eq
  function: JSONEncoder.__name__.__eq__
  args: ["JSONEncoder"]
  expected: true

invariant json_extra6.JSONDecoder.class_name:
  description: "json.JSONDecoder.__name__ == 'JSONDecoder'"
  category: class_names
  kind: python_call_eq
  function: JSONDecoder.__name__.__eq__
  args: ["JSONDecoder"]
  expected: true

invariant json_extra6.JSONEncoder.default_method:
  description: "json.JSONEncoder().default.__func__.__name__ == 'default'"
  category: JSONEncoder
  kind: python_call_eq
  function: JSONEncoder
  args: []
  method: default.__func__.__name__.__eq__
  method_args: ["default"]
  expected: true

invariant json_extra6.JSONDecoder.object_hook_default:
  description: "json.JSONDecoder().object_hook is None"
  category: JSONDecoder
  kind: python_call_eq
  function: JSONDecoder
  args: []
  method: object_hook.__class__
  method_chain: __name__.__eq__
  method_chain_args: ["NoneType"]
  expected: true
