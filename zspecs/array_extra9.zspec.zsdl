spec: array_extra9
version: ">=3.9"
backend: python_module(array)

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/array.html — Python array module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/arraymodule.c"
  notes:
    - "This spec extends array.zspec.zsdl through array_extra8.zspec.zsdl."
    - "array_extra covers: array.__name__/__module__, ArrayType.__name__, typecodes is str, itemsize b/h, typecode b, length/getitem/tolist for 'b'."
    - "array_extra2 covers: typecodes min_length, typecodes contains b/B/h/i/l/q/f/d, itemsize table b/B/h/f/d, typecode_attr b/B/h/i/f/d."
    - "array_extra3 covers: ArrayType.__module__, itemsize H/I, typecode H/d, buffer_info, tolist/count/index on 'i', unsigned short tolist."
    - "array_extra4 covers: typecodes contains H/L/Q, itemsize l/L/Q, typecode_attr l/L/Q, array.__qualname__, bases_object, getitem B[1]."
    - "array_extra5 covers: ArrayType.__qualname__, typecodes contains 'I', tobytes class/length for 'b', itemsize lower-bound guard."
    - "array_extra6 covers: array metaclass (type), MRO length 2, typecodes contains 'u'/'w', class identity table, arraytype_alias table, float array tolist/length/typecode for 'f'."
    - "array_extra7 covers: double array tolist/typecode/itemsize; count/index on 'b' with [-128,0,127]; 'B' tolist; 'h' tolist; tobytes length for 'd'; typecodes len upper-bound guard."
    - "array_extra8 covers: typecodes.__class__.__name__ standalone; array.__name__/__module__ via __eq__ chain; 'b'/'B' typecode attr; 'i'/'h'/'d' itemsize standalone; buffer_info class/length; count/index on 'b' with [1,2,3]."
    - "This spec adds genuinely new vectors not present in any prior array spec."
    - "array.array.__name__ grouped into a class_names table with id_prefix aname9 (new table ID and namespace anchor; prior tables used id_prefix aident in extra6)."
    - "array.ArrayType.__name__ == 'array' — array.ArrayType is an alias for array.array; __name__ is 'array'; verified via table row in aname9 namespace."
    - "array.typecodes.__class__.__name__ == 'str' — verified via table row in aname9 namespace (distinct from extra8 standalone invariant)."
    - "array.array.typecodes — module attribute accessed via the class object; typecodes is also reachable as array.array.typecodes and equals array.typecodes."
    - "array.array('i', [10, 20, 30]).tolist() == [10, 20, 30] — signed int tolist; 'i' typecode appeared in count/index (extra3) and itemsize checks but never in a tolist behavioral test."
    - "array.array('l', [100, 200]).tolist() == [100, 200] — signed long tolist; 'l' appeared in itemsize/typecode_attr checks but never in tolist behavioral test."
    - "array.array('q', [0, -1]).tolist() == [0, -1] — signed long long tolist; 'q' appeared in typecodes contains (extra2) and itemsize but never in tolist behavioral test."
    - "array.array('f', [0.5]).itemsize == 4 — float is 4 bytes per element; extra6 verified float tolist but not itemsize standalone invariant in extra9 namespace."
    - "array.array('b', [5, 10, 15]).__len__() == 3 — signed byte array of three elements has length 3; uses a new fixture distinct from prior length checks."
    - "array.array('i', [1, 2, 3]).index(1) == 0 — 'i' typecode index(); extra3 covered count/index on 'i' with [1,2,3] but tested index(3)==2; index(1)==0 is new."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class names table — array_extra9 namespace, id_prefix aname9
#
# array_extra6 uses id_prefix aident in a class identity table covering
# __name__/__module__/__qualname__ for array.array.
# This table uses id_prefix aname9 and covers three new structural anchors:
#   - array.array.__name__ (extra9 namespace)
#   - array.ArrayType.__name__ (extra9 namespace — ArrayType alias for array.array)
#   - array.typecodes class name (extra9 namespace table form, distinct from
#     the standalone invariant in extra8)
# ---------------------------------------------------------------------------

table array_extra9.class_names:
  kind: python_call_eq
  category: class_identity
  id_prefix: aname9

  columns: [id, function, args, expected]
  rows:
    - [array_name,      array.__name__.__eq__,              ["array"],  true]
    - [arraytype_name,  ArrayType.__name__.__eq__,          ["array"],  true]
    - [typecodes_class, typecodes.__class__.__name__.__eq__, ["str"],   true]

# ---------------------------------------------------------------------------
# array.typecodes reachable via the class object — array.array.typecodes
#
# array.typecodes is the module-level attribute. array.array.typecodes accesses
# the same attribute via the class object (array.array is the type). Prior specs
# access typecodes directly; this spec verifies that the class-path accessor also
# returns a string instance.
# ---------------------------------------------------------------------------

invariant array_extra9.array_class.typecodes_is_str:
  description: "array.array.typecodes.__class__.__name__ == 'str' — typecodes is accessible via the class object and is a str"
  category: typecodes
  kind: python_call_eq
  function: array.typecodes.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral vectors — typecodes 'i', 'l', 'q' (signed integer types)
#
# These typecodes appeared in prior specs for itemsize and typecode_attr checks
# but have never been exercised in tolist behavioral tests:
#   'i' (signed int) — extra3 used count/index; no tolist for 'i'
#   'l' (signed long) — extra4 covered itemsize/typecode_attr; no tolist
#   'q' (signed long long) — extra2 confirmed typecodes contains 'q'; no tolist
# ---------------------------------------------------------------------------

invariant array_extra9.signed_int_array.tolist:
  description: "array.array('i', [10, 20, 30]).tolist() == [10, 20, 30] — signed int array round-trip"
  category: behavior
  kind: python_call_eq
  function: array
  args: ["i", [10, 20, 30]]
  method: tolist
  method_args: []
  expected: [10, 20, 30]

invariant array_extra9.signed_long_array.tolist:
  description: "array.array('l', [100, 200]).tolist() == [100, 200] — signed long array round-trip"
  category: behavior
  kind: python_call_eq
  function: array
  args: ["l", [100, 200]]
  method: tolist
  method_args: []
  expected: [100, 200]

invariant array_extra9.signed_longlong_array.tolist:
  description: "array.array('q', [0, -1]).tolist() == [0, -1] — signed long long array round-trip with negative value"
  category: behavior
  kind: python_call_eq
  function: array
  args: ["q", [0, -1]]
  method: tolist
  method_args: []
  expected: [0, -1]

# ---------------------------------------------------------------------------
# itemsize — typecode 'f' standalone invariant in extra9 namespace
#
# array_extra6 verifies float array tolist and length; no prior spec checks
# 'f' itemsize via a standalone invariant (extra2 used a table for 'f').
# ---------------------------------------------------------------------------

invariant array_extra9.float_array.itemsize:
  description: "array.array('f', [0.5]).itemsize == 4 — float is 4 bytes per element"
  category: itemsize
  kind: python_call_eq
  function: array
  args: ["f", [0.5]]
  method: itemsize.__eq__
  method_args: [4]
  expected: true

# ---------------------------------------------------------------------------
# Length check — typecode 'b' with distinct fixture [5, 10, 15]
#
# Prior specs check length on 'b' only in array_extra (tolist length test with
# fixture [1,2,3]). The fixture [5, 10, 15] is new.
# ---------------------------------------------------------------------------

invariant array_extra9.signed_byte_array.len:
  description: "array.array('b', [5, 10, 15]).__len__() == 3 — three-element signed byte array has length 3"
  category: behavior
  kind: python_call_eq
  function: array
  args: ["b", [5, 10, 15]]
  method: __len__
  method_args: []
  expected: 3

# ---------------------------------------------------------------------------
# index() — typecode 'i' with index(1) == 0
#
# array_extra3 covers index() on 'i' with [1,2,3] testing index(3)==2.
# The value index(1)==0 (first element) is a new vector for 'i'.
# ---------------------------------------------------------------------------

invariant array_extra9.signed_int_array.index_first:
  description: "array.array('i', [1, 2, 3]).index(1) == 0 — 1 is at index 0 in a signed int array"
  category: behavior
  kind: python_call_eq
  function: array
  args: ["i", [1, 2, 3]]
  method: index
  method_args: [1]
  expected: 0
