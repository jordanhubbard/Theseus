    - [ziplongest_module_eq,
       zip_longest.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.zip_longest.__module__.__eq__('itertools') == True — zip_longest is a C-implemented type that reports __module__ as 'itertools'; str.__eq__('itertools') returns True; new to extra182"]
    - [ziplongest_qualname_eq,
       zip_longest.__qualname__.__eq__,
       ["zip_longest"],
       true,
       "itertools.zip_longest.__qualname__.__eq__('zip_longest') == True — zip_longest is a module-level type so __qualname__ equals __name__ 'zip_longest' (11 chars); str.__eq__('zip_longest') returns True; new to extra182"]

