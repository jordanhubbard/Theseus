    - [filterfalse_module_eq,
       filterfalse.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.filterfalse.__module__.__eq__('itertools') == True — filterfalse is a C-implemented type that reports __module__ as 'itertools'; str.__eq__('itertools') returns True; new to extra182"]
    - [filterfalse_qualname_eq,
       filterfalse.__qualname__.__eq__,
       ["filterfalse"],
       true,
       "itertools.filterfalse.__qualname__.__eq__('filterfalse') == True — filterfalse is a module-level type so __qualname__ equals __name__ 'filterfalse' (11 chars); str.__eq__('filterfalse') returns True; new to extra182"]

# ---------------------------------------------------------------------------
# Table 3: itertools.zip_longest __name__ and __module__
#
# itertools.zip_longest.__name__ == 'zip_longest'
# itertools.zip_longest.__name__.__len__() == 11
# itertools.zip_longest.__module__ == 'itertools'
# itertools.zip_longest.__qualname__ == 'zip_longest'
#
# itertools.zip_longest is a C-implemented iterator class that aggregates
# elements from iterables of unequal length, padding shorter iterables with
# a configurable fillvalue. Its __name__ is 'zip_longest' (11 chars —
# same length as 'filterfalse'). New to extra182.
# ---------------------------------------------------------------------------

table itertools_extra182.zip_longest_identity:
  description: "itertools.zip_longest.__name__ 'zip_longest' len 11; __module__ 'itertools'; __qualname__ 'zip_longest' equals __name__; new to extra182"
