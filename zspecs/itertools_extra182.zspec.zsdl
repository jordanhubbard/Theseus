spec: itertools_extra182
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.dropwhile and itertools.filterfalse identity attributes — itertools.dropwhile.__name__=='dropwhile' (len=9); itertools.dropwhile.__module__=='itertools'; itertools.dropwhile.__qualname__=='dropwhile'; itertools.filterfalse.__name__=='filterfalse' (len=11); itertools.filterfalse.__module__=='itertools'; itertools.filterfalse.__qualname__=='filterfalse'; itertools.zip_longest.__name__=='zip_longest' (len=11); itertools.zip_longest.__module__=='itertools'."
    - "itertools.dropwhile.__name__ == 'dropwhile' — dropwhile is a C-implemented iterator type in Modules/itertoolsmodule.c that drops elements from the iterable while a predicate is true, then yields the rest; its __name__ is 'dropwhile', 9 characters. Verified with Python 3.14.3."
    - "itertools.dropwhile.__module__ == 'itertools' — despite being implemented in C, dropwhile reports its __module__ as 'itertools' (not '_itertools' or 'builtins'); this is set explicitly in the C type struct. Verified with Python 3.14.3."
    - "itertools.dropwhile.__qualname__ == 'dropwhile' — dropwhile is a module-level type; its __qualname__ equals its __name__ 'dropwhile'. Verified with Python 3.14.3."
    - "itertools.filterfalse.__name__ == 'filterfalse' — filterfalse is a C-implemented iterator type in Modules/itertoolsmodule.c that yields elements for which a predicate is False (the complement of filter()); its __name__ is 'filterfalse', 11 characters. Verified with Python 3.14.3."
    - "itertools.filterfalse.__module__ == 'itertools' — filterfalse reports __module__ as 'itertools'. Verified with Python 3.14.3."
    - "itertools.filterfalse.__qualname__ == 'filterfalse' — module-level type so __qualname__ equals __name__ 'filterfalse'. Verified with Python 3.14.3."
    - "itertools.zip_longest.__name__ == 'zip_longest' — zip_longest is a C-implemented iterator type that zips iterables of unequal length, filling missing values with a fillvalue; its __name__ is 'zip_longest', 11 characters (same length as 'filterfalse'). Verified with Python 3.14.3."
    - "itertools.zip_longest.__module__ == 'itertools' — zip_longest reports __module__ as 'itertools'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.dropwhile __name__, __module__, __qualname__
#
# itertools.dropwhile.__name__ == 'dropwhile'
# itertools.dropwhile.__name__.__len__() == 9
# itertools.dropwhile.__module__ == 'itertools'
# itertools.dropwhile.__qualname__ == 'dropwhile'
#
# itertools.dropwhile is a C-implemented iterator class in
# Modules/itertoolsmodule.c. It drops elements from an iterable while
# a predicate is True, then yields all remaining elements unchanged.
# Its __name__ is 'dropwhile' (9 chars). New to extra182.
# ---------------------------------------------------------------------------

table itertools_extra182.dropwhile_identity:
  description: "itertools.dropwhile.__name__ 'dropwhile' len 9; __module__ 'itertools'; __qualname__ 'dropwhile' equals __name__; new to extra182"
  kind: python_call_eq
  category: identity
  id_prefix: iterdropfilter182

  columns: [id, function, args, expected, description]
  rows:
    - [dropwhile_name_eq,
       dropwhile.__name__.__eq__,
       ["dropwhile"],
       true,
       "itertools.dropwhile.__name__.__eq__('dropwhile') == True — dropwhile is a C-implemented iterator class in Modules/itertoolsmodule.c that drops elements from the iterable as long as the predicate is True, then yields all remaining elements; its __name__ is 'dropwhile'; str.__eq__('dropwhile') returns True; new to extra182"]
    - [dropwhile_name_len_9,
       dropwhile.__name__.__len__,
       [],
       9,
       "itertools.dropwhile.__name__.__len__() == 9 — the name 'dropwhile' has exactly 9 characters: d-r-o-p-w-h-i-l-e; str.__len__() returns 9; new to extra182"]
    - [dropwhile_module_eq,
       dropwhile.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.dropwhile.__module__.__eq__('itertools') == True — dropwhile is a C-implemented type but reports __module__ as 'itertools' (set explicitly in the C type struct), not '_itertools' or 'builtins'; str.__eq__('itertools') returns True; new to extra182"]
    - [dropwhile_qualname_eq,
       dropwhile.__qualname__.__eq__,
       ["dropwhile"],
       true,
       "itertools.dropwhile.__qualname__.__eq__('dropwhile') == True — dropwhile is a module-level type (not nested), so its __qualname__ equals its __name__ 'dropwhile' (9 chars); str.__eq__('dropwhile') returns True; new to extra182"]

