spec: functools_extra321
version: ">=3.2"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "singledispatch.__name__ == 'singledispatch' — it is a Python function (decorator factory)."
    - "singledispatch.__module__ == 'functools'."
    - "functools.singledispatch(lambda x: x).__class__.__name__ == 'function' — the returned dispatcher is a plain Python function."
    - "dispatch and register attributes on a singledispatch object are both plain functions (not bound methods) on Python 3.14."
    - "registry attribute is a mappingproxy — read-only view of the registered implementations."
    - "__wrapped__ attribute exposes the original unwrapped function; its __class__.__name__ == 'function'."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# singledispatch identity — __name__ and __module__
#
# singledispatch is a plain Python function (decorator factory) defined in
# the functools module. Its __name__ is 'singledispatch'.
# ---------------------------------------------------------------------------

invariant functools_extra321.singledispatch.name:
  description: "functools.singledispatch.__name__ == 'singledispatch'"
  category: singledispatch_identity
  kind: python_call_eq
  function: singledispatch.__name__.__eq__
  args: ["singledispatch"]
  expected: true

invariant functools_extra321.singledispatch.module:
  description: "functools.singledispatch.__module__ == 'functools'"
  category: singledispatch_identity
  kind: python_call_eq
  function: singledispatch.__module__.__eq__
  args: ["functools"]
  expected: true

# ---------------------------------------------------------------------------
# singledispatch instance — class name of the returned dispatcher
#
# Calling singledispatch(lambda x: x) returns a decorated function object.
# On Python 3.14, that object's __class__.__name__ is 'function'.
# ---------------------------------------------------------------------------

invariant functools_extra321.singledispatch.instance_class_name:
  description: "functools.singledispatch(lambda x: x).__class__.__name__ == 'function'"
  category: singledispatch_instance
  kind: python_call_eq
  function: singledispatch
  args: [lambda x: x]
  method: __class__
  method_args: []
  method_chain: __name__.__eq__
  method_chain_args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# singledispatch instance — dispatch attribute class name
#
# The .dispatch attribute of a singledispatch object is a plain function on
# Python 3.14 (not a bound method as type() might suggest).
# Verified: functools.singledispatch(lambda x: x).dispatch.__class__.__name__
#           == 'function'
# ---------------------------------------------------------------------------

invariant functools_extra321.singledispatch.dispatch_class_name:
  description: "functools.singledispatch(lambda x: x).dispatch.__class__.__name__ == 'function'"
  category: singledispatch_attrs
  kind: python_call_eq
  function: singledispatch
  args: [lambda x: x]
  method: dispatch
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# singledispatch instance — register attribute class name
#
# The .register attribute is also a plain function on Python 3.14.
# ---------------------------------------------------------------------------

invariant functools_extra321.singledispatch.register_class_name:
  description: "functools.singledispatch(lambda x: x).register.__class__.__name__ == 'function'"
  category: singledispatch_attrs
  kind: python_call_eq
  function: singledispatch
  args: [lambda x: x]
  method: register
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# singledispatch instance — registry attribute class name
#
# The .registry attribute is a mappingproxy (read-only view of registered
# implementations, keyed by type).
# ---------------------------------------------------------------------------

invariant functools_extra321.singledispatch.registry_class_name:
  description: "functools.singledispatch(lambda x: x).registry.__class__.__name__ == 'mappingproxy'"
  category: singledispatch_attrs
  kind: python_call_eq
  function: singledispatch
  args: [lambda x: x]
  method: registry
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# singledispatch instance — __wrapped__ attribute class name
#
# The __wrapped__ attribute exposes the original function passed to
# singledispatch. Its __class__.__name__ is 'function'.
# ---------------------------------------------------------------------------

invariant functools_extra321.singledispatch.wrapped_class_name:
  description: "functools.singledispatch(lambda x: x).__wrapped__.__class__.__name__ == 'function'"
  category: singledispatch_attrs
  kind: python_call_eq
  function: singledispatch
  args: [lambda x: x]
  method: __wrapped__
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["function"]
  expected: true
