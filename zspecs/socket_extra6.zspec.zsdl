spec: socket_extra6
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html
rfcs:
  - "RFC 793 — Transmission Control Protocol"
  - "RFC 768 — User Datagram Protocol"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
    - "socket.zspec.zsdl — AF_INET/6/UNIX values; SOCK_*/IPPROTO_* values; SOL_SOCKET; SHUT_*; socket/herror/gaierror __name__; function names; getdefaulttimeout; inet_aton; htonl"
    - "socket_extra.zspec.zsdl — create_connection/create_server/setdefaulttimeout/htons/ntohs names; inet_aton/inet_ntoa vectors; htonl(1)"
    - "socket_extra2.zspec.zsdl — AddressFamily class names; SocketKind class names; gethostname/getfqdn return type; socket.error/__name__=='OSError'; socket.timeout name/base"
    - "socket_extra3.zspec.zsdl — AddressFamily/__name__; SocketKind/__name__; herror/gaierror bases; IPPROTO_TCP/UDP int class; socket.socket.__module__"
    - "socket_extra4.zspec.zsdl — getaddrinfo/getnameinfo/gethostbyname/gethostbyaddr/getservbyname/getprotobyname/getfqdn names; SHUT_* int class; SOL_SOCKET int; IPPROTO_IP int"
    - "socket_extra5.zspec.zsdl — socket.socket base class ('object'); exception __module__; socket qualname; create_connection/create_server modules; gaierror/herror/error qualnames; inet_pton/inet_ntop names"
  notes:
    - "This spec extends the socket chain; it does NOT duplicate invariants present in any prior spec."
    - "socket.zspec.zsdl covers AF_INET == 2, AF_INET6 == 10, AF_UNIX == 1, SOCK_STREAM == 1, SOCK_DGRAM == 2, IPPROTO_TCP == 6 as integer values."
    - "socket_extra2.zspec.zsdl covers AF_INET.__class__.__name__ == 'AddressFamily', AF_INET6.__class__.__name__, AF_UNIX.__class__.__name__, SOCK_STREAM.__class__.__name__, SOCK_DGRAM.__class__.__name__."
    - "socket_extra3.zspec.zsdl covers AddressFamily.__name__ == 'AddressFamily' and SocketKind.__name__ == 'SocketKind'."
    - "This spec adds: AddressFamily.__bases__[0].__name__ == 'IntEnum'; SocketKind.__bases__[0].__name__ == 'IntEnum'; SOCK_RAW.__class__.__name__ == 'SocketKind'; AddressFamily.__module__; SocketKind.__module__; IPPROTO_TCP.__class__.__name__ (not yet tested — extra3 checks int, this checks class name); SOCK_STREAM.value == 1; SOCK_DGRAM.value == 2."
    - "socket_extra3 checks IPPROTO_TCP.__class__.__name__ == 'int' in a table; we add IPPROTO_TCP.value == 6 which tests the enum value accessor (not the integer equality tested in socket.zspec)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "socket raises OSError (and subclasses herror, gaierror, timeout) for I/O failures. All invariants here are pure attribute reads and do not open connections."
  stderr: "null"
  stickiness: "N/A — all tested invariants are stateless class attribute reads."
  codes: {}

# ---------------------------------------------------------------------------
# AddressFamily — base class and module
# socket_extra3 checks AddressFamily.__name__; this spec adds the base class
# and module (neither tested previously).
# ---------------------------------------------------------------------------

invariant socket_extra6.AddressFamily.base:
  description: "socket.AddressFamily.__bases__[0].__name__ == 'IntEnum' — AddressFamily is an IntEnum"
  category: hierarchy
  kind: python_call_eq
  function: AddressFamily.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "IntEnum"

invariant socket_extra6.AddressFamily.module:
  description: "socket.AddressFamily.__module__ == 'socket'"
  category: modules
  kind: python_call_eq
  function: AddressFamily.__module__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# SocketKind — base class and module
# socket_extra3 checks SocketKind.__name__; this spec adds the base class
# and module (neither tested previously).
# ---------------------------------------------------------------------------

invariant socket_extra6.SocketKind.base:
  description: "socket.SocketKind.__bases__[0].__name__ == 'IntEnum' — SocketKind is an IntEnum"
  category: hierarchy
  kind: python_call_eq
  function: SocketKind.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "IntEnum"

invariant socket_extra6.SocketKind.module:
  description: "socket.SocketKind.__module__ == 'socket'"
  category: modules
  kind: python_call_eq
  function: SocketKind.__module__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# SOCK_RAW — class name check
# socket_extra2 checks SOCK_STREAM, SOCK_DGRAM, but not SOCK_RAW.
# socket.zspec.zsdl checks SOCK_RAW as integer value.
# We add the __class__.__name__ check for SOCK_RAW.
# ---------------------------------------------------------------------------

invariant socket_extra6.SOCK_RAW.class_name:
  description: "socket.SOCK_RAW.__class__.__name__ == 'SocketKind'"
  category: constants
  kind: python_call_eq
  function: SOCK_RAW.__class__.__name__.__eq__
  args: ["SocketKind"]
  expected: true

# ---------------------------------------------------------------------------
# SOCK_STREAM and SOCK_DGRAM — .value accessor
# socket.zspec.zsdl checks the integer equality; this spec checks the .value
# attribute which is the canonical IntEnum accessor (not yet tested).
# ---------------------------------------------------------------------------

invariant socket_extra6.SOCK_STREAM.value:
  description: "socket.SOCK_STREAM.value == 1"
  category: constants
  kind: python_call_eq
  function: SOCK_STREAM.value.__eq__
  args: [1]
  expected: true

invariant socket_extra6.SOCK_DGRAM.value:
  description: "socket.SOCK_DGRAM.value == 2"
  category: constants
  kind: python_call_eq
  function: SOCK_DGRAM.value.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# AF_INET — .value accessor and __module__ of the class
# socket.zspec.zsdl checks AF_INET == 2 (integer equality).
# socket_extra2 checks AF_INET.__class__.__name__ == 'AddressFamily'.
# We add AF_INET.value == 2 via the .value accessor.
# ---------------------------------------------------------------------------

invariant socket_extra6.AF_INET.value:
  description: "socket.AF_INET.value == 2"
  category: constants
  kind: python_call_eq
  function: AF_INET.value.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# IPPROTO_TCP — .value accessor
# socket.zspec.zsdl checks IPPROTO_TCP == 6 as integer.
# socket_extra3 checks IPPROTO_TCP.__class__.__name__ == 'int'.
# We add IPPROTO_TCP.value == 6 (IntEnum .value accessor; not yet tested).
# ---------------------------------------------------------------------------

invariant socket_extra6.IPPROTO_TCP.value:
  description: "socket.IPPROTO_TCP.value == 6"
  category: constants
  kind: python_call_eq
  function: IPPROTO_TCP.value.__eq__
  args: [6]
  expected: true

# ---------------------------------------------------------------------------
# AddressFamily and SocketKind — __qualname__ checks
# No prior spec tests __qualname__ for these enum classes.
# ---------------------------------------------------------------------------

invariant socket_extra6.AddressFamily.qualname:
  description: "socket.AddressFamily.__qualname__ == 'AddressFamily'"
  category: class_metadata
  kind: python_call_eq
  function: AddressFamily.__qualname__.__eq__
  args: ["AddressFamily"]
  expected: true

invariant socket_extra6.SocketKind.qualname:
  description: "socket.SocketKind.__qualname__ == 'SocketKind'"
  category: class_metadata
  kind: python_call_eq
  function: SocketKind.__qualname__.__eq__
  args: ["SocketKind"]
  expected: true

# ---------------------------------------------------------------------------
# AF_UNIX — class name check (POSIX only)
# socket_extra2.zspec.zsdl checks AF_UNIX.__class__.__name__ but this spec
# adds a .value accessor check to confirm the integer representation.
# AF_UNIX == 1 on Linux; == 1 on macOS as well.
# ---------------------------------------------------------------------------

invariant socket_extra6.AF_UNIX.value:
  description: "socket.AF_UNIX.value == 1 on POSIX (Linux and macOS)"
  category: constants
  kind: python_call_eq
  function: AF_UNIX.value.__eq__
  args: [1]
  expected: true
