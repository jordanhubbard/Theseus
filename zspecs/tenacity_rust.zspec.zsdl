spec: tenacity_rust
version: ">=3.9"
backend: rust_module(tenacity_rust)

docs: https://tenacity.readthedocs.io/

provenance:
  derived_from:
    - "https://tenacity.readthedocs.io/ — tenacity retry library"
  notes:
    - "tenacity provides retry logic for Python."
    - "tenacity.retry decorator is callable."
    - "tenacity.stop_after_attempt is present."
    - "tenacity.wait_fixed is present."
    - "tenacity.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant tenacity_rust.has_retry:
  description: "tenacity has retry decorator"
  category: presence
  kind: python_call_eq
  function: tenacity_has_retry
  args: []
  expected: true

invariant tenacity_rust.has_stop:
  description: "tenacity has stop_after_attempt"
  category: presence
  kind: python_call_eq
  function: tenacity_has_stop
  args: []
  expected: true

invariant tenacity_rust.version_nonempty:
  description: "tenacity.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: tenacity_version_nonempty
  args: []
  expected: true

