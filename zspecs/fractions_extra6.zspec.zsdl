spec: fractions_extra6
version: ">=3.9"
backend: python_module(fractions)

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html — Python fractions documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fractions.py"
  notes:
    - "This spec extends fractions.zspec.zsdl and prior extras (fractions_extra through fractions_extra5)."
    - "fractions.zspec covers: class name, constructor, numerator/denominator, arithmetic (__add__/__sub__/__mul__/__truediv__/__neg__/__abs__), comparison (__lt__/__le__/__eq__/__gt__), limit_denominator, error cases."
    - "fractions_extra2 covers: __module__, MRO[1]==Rational, repr, limit_denominator (alt vectors), Fraction(6,4) reduction, subtraction with Fraction arg, zero/int-1 class names, integer equality, __add__.__name__."
    - "fractions_extra3 covers: __qualname__, __module__, bases, Fraction(1,3) instance, Fraction(2,4) reduction, Fraction('3/5') from string."
    - "fractions_extra4 covers: __name__/__module__/__qualname__, Fraction(1,3) class/num/den, Fraction(2,4) reduction, Fraction(0,5).numerator, Fraction(-1,3) num/den."
    - "fractions_extra5 covers: __bases__.__len__==1, MRO[2]==Real, Fraction(4,8)/(5,15)/(9,12)/(8,12) reductions, reduction __str__ table."
    - "New axes: MRO length (__mro__.__len__), MRO[0] and MRO[3] entries, __float__ conversion, __floor__/__ceil__/__round__ (numeric tower), __bool__, comparison __ge__ and __ne__, __pow__ exponentiation."
    - "fractions.Fraction.__mro__.__len__() == 6 — [Fraction, Rational, Real, Complex, Number, object]."
    - "fractions.Fraction.__mro__[0].__name__ == 'Fraction' — first MRO entry is Fraction itself."
    - "fractions.Fraction.__mro__[3].__name__ == 'Complex' — fourth MRO entry is numbers.Complex."
    - "float(Fraction(1, 2)) == 0.5 — __float__ produces exact binary float for 1/2."
    - "Fraction(3, 4).__floor__() == 0 — floor of 3/4 is 0."
    - "Fraction(3, 4).__ceil__() == 1 — ceil of 3/4 is 1."
    - "Fraction(3, 4).__round__() == 1 — round of 3/4 rounds to nearest even (1)."
    - "Fraction(1, 2).__round__() == 0 — 0.5 rounds to nearest even (0)."
    - "bool(Fraction(0)) == False — zero Fraction is falsy."
    - "bool(Fraction(1, 3)) == True — nonzero Fraction is truthy."
    - "Fraction(3, 4).__ge__(0) == True — 3/4 >= 0."
    - "Fraction(1, 4).__ne__(1) == True — 1/4 != 1."
    - "Fraction(1, 2).__pow__(2).__str__() == '1/4' — (1/2)^2 == 1/4."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# MRO length and spot entries
# fractions_extra2 covers MRO[1] == Rational; fractions_extra5 covers MRO[2] == Real.
# New here: __mro__.__len__, MRO[0] (Fraction itself), MRO[3] (Complex).
# ---------------------------------------------------------------------------

invariant fractions_extra6.Fraction.mro_len:
  description: "fractions.Fraction.__mro__.__len__() == 6 — MRO is [Fraction, Rational, Real, Complex, Number, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: Fraction.__mro__.__len__
  args: []
  expected: 6

invariant fractions_extra6.Fraction.mro_0_self:
  description: "fractions.Fraction.__mro__[0].__name__ == 'Fraction' — first MRO entry is Fraction itself"
  category: class_hierarchy
  kind: python_call_eq
  function: Fraction.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "Fraction"

invariant fractions_extra6.Fraction.mro_3_complex:
  description: "fractions.Fraction.__mro__[3].__name__ == 'Complex' — fourth MRO entry is numbers.Complex"
  category: class_hierarchy
  kind: python_call_eq
  function: Fraction.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "Complex"

# ---------------------------------------------------------------------------
# __float__ conversion
# fractions.zspec covers float constructor (Fraction(0.5)); this covers __float__.
# ---------------------------------------------------------------------------

invariant fractions_extra6.Fraction.to_float:
  description: "Fraction(1, 2).__float__() == 0.5 — exact binary float conversion"
  category: conversion
  kind: python_call_eq
  function: Fraction
  args: [1, 2]
  method: __float__
  expected: 0.5

invariant fractions_extra6.Fraction.to_float_quarter:
  description: "Fraction(1, 4).__float__() == 0.25 — exact binary float conversion for 1/4"
  category: conversion
  kind: python_call_eq
  function: Fraction
  args: [1, 4]
  method: __float__
  expected: 0.25

# ---------------------------------------------------------------------------
# __floor__, __ceil__, __round__ — numeric tower integration
# Not covered in any prior fractions spec.
# ---------------------------------------------------------------------------

invariant fractions_extra6.Fraction.floor:
  description: "Fraction(3, 4).__floor__() == 0 — floor of 3/4 is 0"
  category: rounding
  kind: python_call_eq
  function: Fraction
  args: [3, 4]
  method: __floor__
  expected: 0

invariant fractions_extra6.Fraction.ceil:
  description: "Fraction(3, 4).__ceil__() == 1 — ceil of 3/4 is 1"
  category: rounding
  kind: python_call_eq
  function: Fraction
  args: [3, 4]
  method: __ceil__
  expected: 1

invariant fractions_extra6.Fraction.round_three_quarters:
  description: "Fraction(3, 4).__round__() == 1 — round of 3/4 rounds to nearest even (1)"
  category: rounding
  kind: python_call_eq
  function: Fraction
  args: [3, 4]
  method: __round__
  expected: 1

invariant fractions_extra6.Fraction.round_half_even:
  description: "Fraction(1, 2).__round__() == 0 — banker's rounding: 0.5 rounds to nearest even (0)"
  category: rounding
  kind: python_call_eq
  function: Fraction
  args: [1, 2]
  method: __round__
  expected: 0

# ---------------------------------------------------------------------------
# __bool__ — truthiness of Fraction
# Not covered in any prior fractions spec.
# ---------------------------------------------------------------------------

invariant fractions_extra6.Fraction.bool_zero:
  description: "Fraction(0).__bool__() == False — zero Fraction is falsy"
  category: bool
  kind: python_call_eq
  function: Fraction
  args: [0]
  method: __bool__
  expected: false

invariant fractions_extra6.Fraction.bool_nonzero:
  description: "Fraction(1, 3).__bool__() == True — nonzero Fraction is truthy"
  category: bool
  kind: python_call_eq
  function: Fraction
  args: [1, 3]
  method: __bool__
  expected: true

# ---------------------------------------------------------------------------
# __ge__ and __ne__ — comparison operators not in prior specs
# fractions.zspec covers __lt__, __le__, __eq__, __gt__.
# New here: __ge__, __ne__.
# ---------------------------------------------------------------------------

invariant fractions_extra6.Fraction.ge_true:
  description: "Fraction(3, 4).__ge__(0) == True — 3/4 >= 0"
  category: comparison
  kind: python_call_eq
  function: Fraction
  args: [3, 4]
  method: __ge__
  method_args: [0]
  expected: true

invariant fractions_extra6.Fraction.ne_true:
  description: "Fraction(1, 4).__ne__(1) == True — 1/4 != 1"
  category: comparison
  kind: python_call_eq
  function: Fraction
  args: [1, 4]
  method: __ne__
  method_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# __pow__ — exponentiation of Fraction by integer
# Not covered in any prior fractions spec.
# ---------------------------------------------------------------------------

invariant fractions_extra6.Fraction.pow_two:
  description: "Fraction(1, 2).__pow__(2).__str__() == '1/4' — (1/2)^2 == 1/4"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [1, 2]
  method: __pow__
  method_args: [2]
  method_chain: __str__
  expected: "1/4"

invariant fractions_extra6.Fraction.pow_zero:
  description: "Fraction(3, 4).__pow__(0).__str__() == '1' — x^0 == 1 for any nonzero Fraction"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [3, 4]
  method: __pow__
  method_args: [0]
  method_chain: __str__
  expected: "1"
