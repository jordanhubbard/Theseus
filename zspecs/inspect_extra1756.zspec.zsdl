spec: inspect_extra1756
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/inspect.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 564 (_extra1756): arithmetic operator protocol dict-presence checks."
    - "inspect.Parameter: data container class — not a numeric type; all eight arithmetic dunders absent from __dict__."
    - "inspect.Signature: introspection class — not a numeric type; all eight arithmetic dunders absent."
    - "inspect.BoundArguments: result of Signature.bind() — not a numeric type; all eight arithmetic dunders absent."
    - "Complementary checks: inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ is 'ParameterKind' (an IntEnum member)."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: arithmetic operator protocol dict-presence checks for inspect types
#
# Wave 564 theme: which inspect types define __add__, __sub__, __mul__,
# __truediv__, __floordiv__, __pow__, __neg__, __pos__ in their own __dict__.
#
# inspect.Parameter: immutable data container for a single parameter in a
#   function signature (name, kind, default, annotation) — not numeric, no
#   arithmetic operators defined.
# inspect.Signature: represents a callable's complete signature — data
#   container for Parameter objects and return annotation — not numeric.
# inspect.BoundArguments: result of Signature.bind() or bind_partial() —
#   maps parameter names to argument values — not numeric, no arithmetic.
# ---------------------------------------------------------------------------

table inspect_extra1756.arithmetic_operators:
  description: "inspect types arithmetic operator dict-presence checks — all False — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1756

  columns: [id, function, args, expected]
  rows:
    - ["in1756001", "inspect.Parameter.__dict__.__contains__", ["__add__"], false]
    - ["in1756002", "inspect.Parameter.__dict__.__contains__", ["__sub__"], false]
    - ["in1756003", "inspect.Parameter.__dict__.__contains__", ["__mul__"], false]
    - ["in1756004", "inspect.Parameter.__dict__.__contains__", ["__truediv__"], false]
    - ["in1756005", "inspect.Parameter.__dict__.__contains__", ["__floordiv__"], false]
    - ["in1756006", "inspect.Parameter.__dict__.__contains__", ["__pow__"], false]
    - ["in1756007", "inspect.Parameter.__dict__.__contains__", ["__neg__"], false]
    - ["in1756008", "inspect.Parameter.__dict__.__contains__", ["__pos__"], false]
    - ["in1756009", "inspect.Signature.__dict__.__contains__", ["__add__"], false]
    - ["in1756010", "inspect.Signature.__dict__.__contains__", ["__sub__"], false]
    - ["in1756011", "inspect.Signature.__dict__.__contains__", ["__mul__"], false]
    - ["in1756012", "inspect.Signature.__dict__.__contains__", ["__neg__"], false]
    - ["in1756013", "inspect.BoundArguments.__dict__.__contains__", ["__add__"], false]
    - ["in1756014", "inspect.BoundArguments.__dict__.__contains__", ["__mul__"], false]
    - ["in1756015", "inspect.BoundArguments.__dict__.__contains__", ["__truediv__"], false]

# ---------------------------------------------------------------------------
# Table 2: ParameterKind enum checks and arithmetic absence confirmation
#
# Unique checks not covered in earlier waves:
# inspect.Parameter.POSITIONAL_ONLY is a member of ParameterKind (an IntEnum),
# so its __class__.__name__ is "ParameterKind". This contrasts with the
# Parameter class itself which is not numeric.
# Further confirms BoundArguments and Signature also lack floordiv/pow/pos.
# Reaffirms that the arithmetic-free nature of these types is consistent across
# all eight arithmetic dunders.
# ---------------------------------------------------------------------------

table inspect_extra1756.parameter_kind_and_arithmetic_contrast:
  description: "inspect.Parameter.POSITIONAL_ONLY is ParameterKind; Signature/BoundArguments lack all arithmetic dunders — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1756

  columns: [id, function, args, expected]
  rows:
    - ["in1756016", "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__", ["ParameterKind"], true]
    - ["in1756017", "inspect.Signature.__dict__.__contains__", ["__floordiv__"], false]
    - ["in1756018", "inspect.Signature.__dict__.__contains__", ["__pow__"], false]
    - ["in1756019", "inspect.Signature.__dict__.__contains__", ["__pos__"], false]
    - ["in1756020", "inspect.BoundArguments.__dict__.__contains__", ["__sub__"], false]
    - ["in1756021", "inspect.BoundArguments.__dict__.__contains__", ["__floordiv__"], false]
    - ["in1756022", "inspect.BoundArguments.__dict__.__contains__", ["__pow__"], false]
    - ["in1756023", "inspect.BoundArguments.__dict__.__contains__", ["__neg__"], false]
    - ["in1756024", "inspect.BoundArguments.__dict__.__contains__", ["__pos__"], false]
    - ["in1756025", "inspect.Parameter.__dict__.__contains__", ["__add__"], false]
