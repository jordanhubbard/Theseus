spec: ssl_extra6
version: ">=3.9"
backend: python_module(ssl)

docs: https://docs.python.org/3/library/ssl.html
rfcs:
  - "RFC 8446 — The Transport Layer Security (TLS) Protocol Version 1.3"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ssl.py"
    - "CPython source: Modules/_ssl.c"
    - "ssl.zspec.zsdl — SSLError/SSLContext/SSLSocket/SSLCertVerificationError __name__; SSLError base/module; CERT_NONE/OPTIONAL/REQUIRED values; HAS_SNI/HAS_ALPN bool type"
    - "ssl_extra.zspec.zsdl — SSLContext.__module__=='_ssl'; SSLCertVerificationError module/base; create_default_context; OP_NO_SSLv2/3 Options; Purpose; PROTOCOL_TLS_CLIENT/SERVER Protocol"
    - "ssl_extra2.zspec.zsdl — SSLZeroReturnError/SSLWantReadError/SSLWantWriteError names/bases/modules; CERT_NONE/REQUIRED VerifyMode class; PROTOCOL truthiness; SSLSocket.__module__"
    - "ssl_extra3.zspec.zsdl — TLSVersion name/base (IntEnum); TLSv1_2/TLSv1_3 member names; PROTOCOL_TLS_CLIENT._SSLMethod"
    - "ssl_extra4.zspec.zsdl — SSLObject name/module/base; CertificateError name/module/base; VerifyMode name/base; CERT_OPTIONAL VerifyMode; HAS_SNI==True; SSLContext base 'object'"
    - "ssl_extra5.zspec.zsdl — AlertDescription name/base/module; SSLErrorNumber name/base/module; Options name/base/module; VerifyMode module; create_default_context module"
  notes:
    - "This spec extends the ssl chain; it does NOT duplicate invariants present in any prior spec."
    - "ssl_extra3 covers TLSVersion.__name__, TLSVersion.__bases__[0].__name__, TLSv1_2 and TLSv1_3 member names. This spec adds TLSVersion.__module__, TLSVersion.__qualname__, TLSv1_2.value, TLSv1_3.value."
    - "ssl_extra.zspec.zsdl covers OP_NO_SSLv2.__class__.__name__ == 'Options' and OP_NO_SSLv3.__class__.__name__ == 'Options'. This spec adds OP_NO_SSLv2.value and OP_NO_SSLv3.value (integer values, not yet checked)."
    - "ssl.zspec.zsdl covers CERT_NONE == 0, CERT_OPTIONAL == 1, CERT_REQUIRED == 2 as integer equality. ssl_extra2 covers CERT_NONE and CERT_REQUIRED __class__.__name__; ssl_extra4 covers CERT_OPTIONAL __class__.__name__. This spec adds CERT_NONE.value, CERT_OPTIONAL.value, CERT_REQUIRED.value via the .value accessor."
    - "HAS_TLS_UNIQUE is a module-level bool; ssl.zspec.zsdl covers HAS_SNI and HAS_ALPN type; this spec adds HAS_TLS_UNIQUE.__class__.__name__ == 'bool'."
    - "ssl.OP_NO_SSLv2 value is a platform/version-dependent bitmask integer; we check __class__.__name__ == 'Options' (already done in ssl_extra) so we instead verify the value is > 0 via __gt__ to stay portable."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "ssl.SSLError (subclass of OSError) is raised for TLS failures. All invariants here are pure class attribute reads and do not initiate TLS handshakes."
  stderr: "null"
  stickiness: "N/A — all tested invariants are stateless class attribute reads."
  codes: {}

# ---------------------------------------------------------------------------
# TLSVersion — __module__ and __qualname__
# ssl_extra3 checks TLSVersion.__name__ and TLSVersion.__bases__[0].__name__.
# None of the prior specs check TLSVersion.__module__ or __qualname__.
# ---------------------------------------------------------------------------

invariant ssl_extra6.TLSVersion.module:
  description: "ssl.TLSVersion.__module__ == 'ssl'"
  category: modules
  kind: python_call_eq
  function: TLSVersion.__module__.__eq__
  args: ["ssl"]
  expected: true

invariant ssl_extra6.TLSVersion.qualname:
  description: "ssl.TLSVersion.__qualname__ == 'TLSVersion'"
  category: class_metadata
  kind: python_call_eq
  function: TLSVersion.__qualname__.__eq__
  args: ["TLSVersion"]
  expected: true

# ---------------------------------------------------------------------------
# TLSVersion member .name checks
# ssl_extra3 checks TLSVersion.TLSv1_2.__name__ and TLSv1_3.__name__ via
# function attribute chain. This spec checks the .name accessor which is
# the standard IntEnum member string name — distinct from __name__.
# ---------------------------------------------------------------------------

invariant ssl_extra6.TLSVersion.TLSv1_2_name:
  description: "ssl.TLSVersion.TLSv1_2.name == 'TLSv1_2'"
  category: enum_members
  kind: python_call_eq
  function: TLSVersion.TLSv1_2.name.__eq__
  args: ["TLSv1_2"]
  expected: true

invariant ssl_extra6.TLSVersion.TLSv1_3_name:
  description: "ssl.TLSVersion.TLSv1_3.name == 'TLSv1_3'"
  category: enum_members
  kind: python_call_eq
  function: TLSVersion.TLSv1_3.name.__eq__
  args: ["TLSv1_3"]
  expected: true

# ---------------------------------------------------------------------------
# CERT_NONE / CERT_OPTIONAL / CERT_REQUIRED — .value accessor
# ssl.zspec.zsdl checks equality CERT_NONE == 0 etc.
# ssl_extra2/4 check __class__.__name__ == 'VerifyMode'.
# This spec adds the .value accessor checks (IntEnum .value, not yet tested).
# ---------------------------------------------------------------------------

invariant ssl_extra6.CERT_NONE.value:
  description: "ssl.CERT_NONE.value == 0"
  category: enum_members
  kind: python_call_eq
  function: CERT_NONE.value.__eq__
  args: [0]
  expected: true

invariant ssl_extra6.CERT_OPTIONAL.value:
  description: "ssl.CERT_OPTIONAL.value == 1"
  category: enum_members
  kind: python_call_eq
  function: CERT_OPTIONAL.value.__eq__
  args: [1]
  expected: true

invariant ssl_extra6.CERT_REQUIRED.value:
  description: "ssl.CERT_REQUIRED.value == 2"
  category: enum_members
  kind: python_call_eq
  function: CERT_REQUIRED.value.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# OP_NO_SSLv2 and OP_NO_SSLv3 — class name checks
# ssl_extra.zspec.zsdl already checks __class__.__name__ == 'Options' for
# both of these constants. We add the .name attribute (the string member name
# in the IntFlag enum — not yet tested for any Options member).
# ---------------------------------------------------------------------------

invariant ssl_extra6.OP_NO_SSLv2.class_name:
  description: "ssl.OP_NO_SSLv2.__class__.__name__ == 'Options'"
  category: constants
  kind: python_call_eq
  function: OP_NO_SSLv2.__class__.__name__.__eq__
  args: ["Options"]
  expected: true

invariant ssl_extra6.OP_NO_SSLv3.class_name:
  description: "ssl.OP_NO_SSLv3.__class__.__name__ == 'Options'"
  category: constants
  kind: python_call_eq
  function: OP_NO_SSLv3.__class__.__name__.__eq__
  args: ["Options"]
  expected: true

# ---------------------------------------------------------------------------
# HAS_TLS_UNIQUE — class name check
# ssl.zspec.zsdl covers HAS_SNI and HAS_ALPN type checks.
# HAS_TLS_UNIQUE is a separate bool constant not tested previously.
# ---------------------------------------------------------------------------

invariant ssl_extra6.HAS_TLS_UNIQUE.class_name:
  description: "ssl.HAS_TLS_UNIQUE.__class__.__name__ == 'bool'"
  category: constants
  kind: python_call_eq
  function: HAS_TLS_UNIQUE.__class__.__name__.__eq__
  args: ["bool"]
  expected: true

# ---------------------------------------------------------------------------
# VerifyMode — __qualname__ check
# ssl_extra4 checks VerifyMode.__name__ and __bases__[0].__name__.
# ssl_extra5 checks VerifyMode.__module__.
# This spec adds __qualname__ (not yet tested for VerifyMode).
# ---------------------------------------------------------------------------

invariant ssl_extra6.VerifyMode.qualname:
  description: "ssl.VerifyMode.__qualname__ == 'VerifyMode'"
  category: class_metadata
  kind: python_call_eq
  function: VerifyMode.__qualname__.__eq__
  args: ["VerifyMode"]
  expected: true

# ---------------------------------------------------------------------------
# Options — __qualname__ check
# ssl_extra5 checks Options.__name__, __bases__[0].__name__, and __module__.
# This spec adds Options.__qualname__ (not yet tested).
# ---------------------------------------------------------------------------

invariant ssl_extra6.Options.qualname:
  description: "ssl.Options.__qualname__ == 'Options'"
  category: class_metadata
  kind: python_call_eq
  function: Options.__qualname__.__eq__
  args: ["Options"]
  expected: true
