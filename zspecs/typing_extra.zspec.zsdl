spec: typing_extra
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "Python typing documentation — https://docs.python.org/3/library/typing.html"
    - "PEP 484 — Type Hints"
    - "PEP 526 — Syntax for Variable Annotations"
    - "PEP 544 — Protocols: Structural subtyping (static duck typing)"
    - "PEP 589 — TypedDict"
    - "PEP 591 — final qualifier"
    - "Test vectors verified by running Python 3.14.3 typing module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "Complements typing.zspec.zsdl, typing_extensions.zspec.zsdl, and typing_protocol.zspec.zsdl."
    - "TypeVar is an ordinary class (not a special form); its __name__ is 'TypeVar' and __module__ is 'typing'."
    - "Generic is a class; Generic.__name__ == 'Generic' and Generic.__module__ == 'typing'."
    - "NamedTuple and TypedDict are special forms whose class names differ across Python versions."
    - "get_type_hints, get_args, get_origin, cast, overload, final, runtime_checkable are plain functions."
    - "TypeVar('T').__name__ == 'T' — the bound name of a TypeVar instance equals its first argument."
    - "TypeVar('T').__constraints__ is a tuple; empty tuple when no constraints are supplied."
    - "TypeVar.__module__ is 'typing' (the class itself, not an instance)."
    - "get_origin returns None for unparameterized concrete types such as int and str."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TypeVar — class identity and module
#
# TypeVar is a plain class (not a _SpecialForm). Its __name__ is 'TypeVar'
# and its __module__ is 'typing'.
# ---------------------------------------------------------------------------

invariant typing_extra.typevar.class_name:
  description: "typing.TypeVar.__name__ == 'TypeVar'"
  category: typevar
  kind: python_call_eq
  function: TypeVar.__name__.__eq__
  args: ["TypeVar"]
  expected: true

invariant typing_extra.typevar.module:
  description: "typing.TypeVar.__module__ == 'typing'"
  category: typevar
  kind: python_call_eq
  function: TypeVar.__module__.__eq__
  args: ["typing"]
  expected: true

invariant typing_extra.typevar.instance_name:
  description: "typing.TypeVar('T').__name__ == 'T' — bound name equals first argument"
  category: typevar
  kind: python_call_eq
  function: TypeVar
  args: ["T"]
  method: __name__
  method_args: []
  expected: "T"

invariant typing_extra.typevar.instance_constraints_empty:
  description: "typing.TypeVar('T').__constraints__ is () when no constraints given"
  category: typevar
  kind: python_call_eq
  function: TypeVar
  args: ["T"]
  method: __constraints__
  method_chain: __len__
  expected: 0

# ---------------------------------------------------------------------------
# Generic — class identity and module
#
# typing.Generic is the base class for generic types. It is a plain class
# (not a special form) and lives in the 'typing' module.
# ---------------------------------------------------------------------------

invariant typing_extra.generic.class_name:
  description: "typing.Generic.__name__ == 'Generic'"
  category: generic
  kind: python_call_eq
  function: Generic.__name__.__eq__
  args: ["Generic"]
  expected: true

invariant typing_extra.generic.module:
  description: "typing.Generic.__module__ == 'typing'"
  category: generic
  kind: python_call_eq
  function: Generic.__module__.__eq__
  args: ["typing"]
  expected: true

# ---------------------------------------------------------------------------
# get_origin — returns None for unparameterized concrete types
#
# get_origin(T) is defined to return None when T has no origin (i.e., is
# not a parameterized generic). This is safe to test with int and str.
# ---------------------------------------------------------------------------

invariant typing_extra.get_origin.int_is_none:
  description: "typing.get_origin(int) is None — int has no generic origin"
  category: introspection
  kind: python_call_eq
  function: get_origin
  args: [42]
  expected: null

invariant typing_extra.get_origin.str_is_none:
  description: "typing.get_origin(str) is None — str has no generic origin"
  category: introspection
  kind: python_call_eq
  function: get_origin
  args: ["hello"]
  expected: null

# ---------------------------------------------------------------------------
# Function module checks
#
# All public typing helper functions are defined in the 'typing' module.
# We verify __module__ for the key ones that are plain functions.
# ---------------------------------------------------------------------------

table typing_extra.function_modules:
  description: "Key typing helper functions have __module__ == 'typing'"
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [get_type_hints, get_type_hints.__module__.__eq__, ["typing"], true]
    - [get_args,       get_args.__module__.__eq__,       ["typing"], true]
    - [get_origin,     get_origin.__module__.__eq__,     ["typing"], true]
    - [cast,           cast.__module__.__eq__,           ["typing"], true]
    - [overload,       overload.__module__.__eq__,       ["typing"], true]
    - [final,          final.__module__.__eq__,          ["typing"], true]

# ---------------------------------------------------------------------------
# Function names — additional callables not covered by typing.zspec.zsdl
#
# typing.zspec.zsdl covers: cast, get_args, get_origin, get_type_hints,
# overload, final, runtime_checkable, no_type_check.
# Here we add: is_typeddict, assert_never, reveal_type (3.11+), get_overloads.
# ---------------------------------------------------------------------------

invariant typing_extra.names.is_typeddict:
  description: "typing.is_typeddict.__name__ == 'is_typeddict' (Python 3.10+)"
  category: names
  kind: python_call_eq
  function: is_typeddict.__name__.__eq__
  args: ["is_typeddict"]
  expected: true

invariant typing_extra.names.get_overloads:
  description: "typing.get_overloads.__name__ == 'get_overloads' (Python 3.11+)"
  category: names
  kind: python_call_eq
  function: get_overloads.__name__.__eq__
  args: ["get_overloads"]
  expected: true

# ---------------------------------------------------------------------------
# TypeVar constraints — TypeVar with constraints stores them as a tuple
# ---------------------------------------------------------------------------

invariant typing_extra.typevar.constrained_count:
  description: "typing.TypeVar('AnyStr', str, bytes).__constraints__ has length 2"
  category: typevar
  kind: python_call_eq
  function: TypeVar
  args: ["AnyStr", "str", "bytes"]
  method: __constraints__
  method_chain: __len__
  expected: 2
