spec: pathlib_extra242
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.PurePath relative_to and is_relative_to contracts."
    - "pathlib.PurePosixPath('/a/b/c').relative_to('/a').__str__() == 'b/c' — removes the '/a' prefix leaving 'b/c'; verified Python 3.14.3 macOS."
    - "pathlib.PurePosixPath('/a/b/c').relative_to('/a/b').__str__() == 'c' — removes '/a/b' prefix leaving single component 'c'; verified Python 3.14.3 macOS."
    - "pathlib.PurePosixPath('/a/b/c').relative_to('/a/b/c').__str__() == '.' — path relative to itself is '.'; verified Python 3.14.3 macOS."
    - "pathlib.PurePosixPath('/a/b/c').is_relative_to('/a') == True — '/a/b/c' starts with '/a'; verified Python 3.14.3 macOS."
    - "pathlib.PurePosixPath('/a/b/c').is_relative_to('/b') == False — '/a/b/c' does not start with '/b'; verified Python 3.14.3 macOS."
    - "pathlib.PurePosixPath('/a/b/c').is_relative_to('/a/b/c') == True — path is relative to itself; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath.relative_to() contracts
# relative_to(other) returns a new PurePosixPath representing this path
# relative to the other path. Raises ValueError if this path is not
# a sub-path of the other path.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant pathlib_extra242.PurePosixPath.relative_to.abc_from_a:
  description: "pathlib.PurePosixPath('/a/b/c').relative_to('/a').__str__() == 'b/c' — removes '/a' prefix leaving 'b/c'; verified Python 3.14.3 macOS"
  category: relative_to
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: relative_to
  method_args: ["/a"]
  method_chain: __str__
  expected: "b/c"

invariant pathlib_extra242.PurePosixPath.relative_to.abc_from_ab:
  description: "pathlib.PurePosixPath('/a/b/c').relative_to('/a/b').__str__() == 'c' — removes '/a/b' prefix leaving single component 'c'; verified Python 3.14.3 macOS"
  category: relative_to
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: relative_to
  method_args: ["/a/b"]
  method_chain: __str__
  expected: "c"

invariant pathlib_extra242.PurePosixPath.relative_to.abc_from_abc:
  description: "pathlib.PurePosixPath('/a/b/c').relative_to('/a/b/c').__str__() == '.' — path relative to itself is the current-directory dot; verified Python 3.14.3 macOS"
  category: relative_to
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: relative_to
  method_args: ["/a/b/c"]
  method_chain: __str__
  expected: "."

invariant pathlib_extra242.PurePosixPath.relative_to.result_class:
  description: "pathlib.PurePosixPath('/a/b/c').relative_to('/a').__class__.__name__ == 'PurePosixPath' — result of relative_to is a PurePosixPath; verified Python 3.14.3 macOS"
  category: relative_to
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: relative_to
  method_args: ["/a"]
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["PurePosixPath"]
  expected: true

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath.is_relative_to() contracts
# is_relative_to(other) returns True if this path is relative to the other path,
# False otherwise. Added in Python 3.9.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant pathlib_extra242.PurePosixPath.is_relative_to.abc_under_a:
  description: "pathlib.PurePosixPath('/a/b/c').is_relative_to('/a') == True — '/a/b/c' starts with '/a'; verified Python 3.14.3 macOS"
  category: is_relative_to
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: is_relative_to
  method_args: ["/a"]
  expected: true

invariant pathlib_extra242.PurePosixPath.is_relative_to.abc_not_under_b:
  description: "pathlib.PurePosixPath('/a/b/c').is_relative_to('/b') == False — '/a/b/c' does not start with '/b'; verified Python 3.14.3 macOS"
  category: is_relative_to
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: is_relative_to
  method_args: ["/b"]
  expected: false

invariant pathlib_extra242.PurePosixPath.is_relative_to.abc_under_abc:
  description: "pathlib.PurePosixPath('/a/b/c').is_relative_to('/a/b/c') == True — every path is relative to itself; verified Python 3.14.3 macOS"
  category: is_relative_to
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: is_relative_to
  method_args: ["/a/b/c"]
  expected: true

invariant pathlib_extra242.PurePosixPath.is_relative_to.abc_under_ab:
  description: "pathlib.PurePosixPath('/a/b/c').is_relative_to('/a/b') == True — '/a/b/c' starts with '/a/b'; verified Python 3.14.3 macOS"
  category: is_relative_to
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: is_relative_to
  method_args: ["/a/b"]
  expected: true

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath.relative_to() result length and component checks
# Spot-check string lengths of relative_to results.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table pathlib_extra242.relative_to_str_lengths:
  description: "PurePosixPath.relative_to().__str__().__len__() for various path/base combinations; verified Python 3.14.3"
  kind: python_call_eq
  category: relative_to
  id_prefix: pathlibrelto242

  columns: [id, function, args, method, method_args, method_chain, expected]
  rows:
    - [abc_from_a_len,   PurePosixPath, ["/a/b/c"],   relative_to, ["/a"],     __str__,              "b/c"]
    - [abc_from_ab_len,  PurePosixPath, ["/a/b/c"],   relative_to, ["/a/b"],   __str__,              "c"]
    - [abc_from_abc_dot, PurePosixPath, ["/a/b/c"],   relative_to, ["/a/b/c"], __str__,              "."]
