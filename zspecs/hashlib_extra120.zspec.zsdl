spec: hashlib_extra120
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra119.zspec.zsdl — covers hashlib.md5 and hashlib.sha1 __name__/__qualname__/__module__/__class__.__name__ equality and lengths (table + invariants)."
    - "hashlib_extra112.zspec.zsdl — covers sha3_256.__qualname__.__eq__('openssl_sha3_256') and sha3_512.__qualname__.__eq__('openssl_sha3_512') and qualname lengths (table + invariants)."
    - "hashlib_extra111.zspec.zsdl — covers sha3_256.__class__.__name__.__eq__('builtin_function_or_method') and sha3_256.__module__.__eq__('_hashlib') (table + invariants)."
    - "hashlib_extra103.zspec.zsdl — covers sha3_256.__name__.__eq__('openssl_sha3_256') and sha3_512.__name__.__eq__('openssl_sha3_512') and name lengths (table + invariants)."
  notes:
    - "This spec extends hashlib through hashlib_extra119; it does NOT duplicate invariants present in those files."
    - "Wave 277 theme: hashlib.sha3_256 and hashlib.sha3_512 function identity not yet covered — sha3_512.__module__/__class__.__name__ equality (extra111 anchors sha3_256 only), sha3_256.__class__.__module__, sha3_512.__class__.__module__, sha3_256.__module__.__eq__(sha3_512.__module__), sha3_256.__class__.__name__.__len__(), sha3_256.__module__.__len__(), sha3_256.__name__.__eq__(sha3_256.__qualname__) name-equals-qualname identity, sha3_512.__class__.__name__.__len__()."
    - "hashlib.sha3_256.__name__ == 'openssl_sha3_256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__name__ == 'openssl_sha3_512'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__class__.__module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__class__.__module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__class__.__name__.__len__() == 26. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__module__.__len__() == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__module__.__eq__(hashlib.sha3_512.__module__) == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__name__.__eq__(hashlib.sha3_256.__qualname__) == True (name==qualname for C-level module-level functions). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: On CPython 3.14.3 macOS, both sha3_256 and sha3_512 are OpenSSL-backed builtin_function_or_method objects from the _hashlib C extension. Their __class__.__module__ is 'builtins' (the builtin_function_or_method type is a built-in type). Their __module__ is '_hashlib' (8 chars). The __class__.__name__ 'builtin_function_or_method' is 26 chars, shared by all OpenSSL-backed hash constructor functions. For C-level module-level functions, __name__ always equals __qualname__ (there is no enclosing class to add a prefix). extra111 anchors sha3_256 module and class name; this spec anchors sha3_512 module/class name and both functions' class.__module__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha3_512.__module__.__eq__('_hashlib')
# hashlib.sha3_512.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.sha3_256.__class__.__module__.__eq__('builtins')
# hashlib.sha3_512.__class__.__module__.__eq__('builtins')
# hashlib.sha3_256.__module__.__eq__(sha3_512.__module__)
#
# Wave 277 theme: sha3_512 module/class identity and sha3_256 class.__module__.
#
# hashlib_extra111 anchors sha3_256.__module__=='_hashlib' and
# sha3_256.__class__.__name__=='builtin_function_or_method' but does NOT anchor
# sha3_512.__module__ or sha3_512.__class__.__name__ as a new grouped table.
# Both sha3_256 and sha3_512 have __class__.__module__=='builtins' (the
# builtin_function_or_method type is from the builtins module). Their modules
# are equal: sha3_256.__module__==sha3_512.__module__=="_hashlib".
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra120.sha3_512_module_and_class_identity:
  description: "sha3_512.__module__.__eq__('_hashlib')==True / sha3_512.__class__.__name__.__eq__('builtin_function_or_method')==True / sha3_256.__class__.__module__.__eq__('builtins')==True / sha3_512.__class__.__module__.__eq__('builtins')==True / sha3_256.__module__.__eq__('_hashlib')==True — sha3_512 from _hashlib (OpenSSL-backed; same module as sha3_256); both are builtin_function_or_method with __class__.__module__=='builtins'; extra111 anchors sha3_256 module/class; first hashlibsha3_120 anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlibsha3_120

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_512_module_eq,       "sha3_512.__module__.__eq__",              ["_hashlib"],                   true, "hashlib.sha3_512.__module__ is '_hashlib' (OpenSSL-backed; same C extension module as sha3_256)"]
    - [sha3_512_class_eq,        "sha3_512.__class__.__name__.__eq__",      ["builtin_function_or_method"], true, "hashlib.sha3_512.__class__.__name__ is 'builtin_function_or_method' (C-level callable; same type as sha3_256)"]
    - [sha3_256_class_module_eq, "sha3_256.__class__.__module__.__eq__",    ["builtins"],                   true, "hashlib.sha3_256.__class__.__module__ is 'builtins' (builtin_function_or_method is a built-in type)"]
    - [sha3_512_class_module_eq, "sha3_512.__class__.__module__.__eq__",    ["builtins"],                   true, "hashlib.sha3_512.__class__.__module__ is 'builtins' (same as sha3_256; builtin_function_or_method type is from builtins)"]
    - [sha3_256_module_eq2,      "sha3_256.__module__.__eq__",              ["_hashlib"],                   true, "hashlib.sha3_256.__module__ is '_hashlib' (cross-check; OpenSSL-backed SHA-3 lives in _hashlib)"]

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__class__.__name__.__len__() == 26
# hashlib.sha3_256.__module__.__len__() == 8
# hashlib.sha3_512.__module__.__len__() == 8
# hashlib.sha3_256.__class__.__module__.__len__() == 8
# hashlib.sha3_512.__class__.__name__.__len__() == 26
#
# Wave 277 theme: sha3_256 and sha3_512 class name and module lengths.
#
# 'builtin_function_or_method' is 26 chars (shared by both sha3_256 and sha3_512).
# '_hashlib' is 8 chars (the module name for both). 'builtins' is 8 chars (the
# __class__.__module__ for both). These length values are not yet anchored for
# sha3_256 / sha3_512 in any prior spec. extra112 anchors qualname lengths (16).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra120.sha3_class_and_module_lengths:
  description: "sha3_256.__class__.__name__.__len__()==26 / sha3_256.__module__.__len__()==8 / sha3_512.__module__.__len__()==8 / sha3_256.__class__.__module__.__len__()==8 / sha3_512.__class__.__name__.__len__()==26 — 'builtin_function_or_method'=26 chars (same for both sha3_256 and sha3_512); '_hashlib'=8 chars (module for both); 'builtins'=8 chars (class module for both); all three strings share length 8; no prior spec anchors these lengths for sha3 functions; first hashlibsha3_120 anchor for lengths"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlibsha3_120

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_class_name_len,   "sha3_256.__class__.__name__.__len__",   [], 26, "hashlib.sha3_256.__class__.__name__.__len__() is 26 (len('builtin_function_or_method')==26)"]
    - [sha3_256_module_len,       "sha3_256.__module__.__len__",           [], 8,  "hashlib.sha3_256.__module__.__len__() is 8 (len('_hashlib')==8; leading underscore marks internal C module)"]
    - [sha3_512_module_len,       "sha3_512.__module__.__len__",           [], 8,  "hashlib.sha3_512.__module__.__len__() is 8 (same as sha3_256; both share the _hashlib module)"]
    - [sha3_256_class_module_len, "sha3_256.__class__.__module__.__len__", [], 8,  "hashlib.sha3_256.__class__.__module__.__len__() is 8 (len('builtins')==8; same length as '_hashlib' coincidentally)"]
    - [sha3_512_class_name_len,   "sha3_512.__class__.__name__.__len__",   [], 26, "hashlib.sha3_512.__class__.__name__.__len__() is 26 (same as sha3_256; both are builtin_function_or_method)"]

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__name__.__eq__(hashlib.sha3_256.__qualname__) — name==qualname
# hashlib.sha3_256.__module__.__eq__(hashlib.sha3_512.__module__) — shared module
# hashlib.sha3_256.__class__.__name__.__eq__(sha3_512.__class__.__name__) — shared type
# hashlib.sha3_256.__qualname__.__len__() == 16
# hashlib.sha3_512.__qualname__.__len__() == 16
#
# Wave 277 theme: sha3_256 and sha3_512 cross-function equality invariants.
#
# For C-level module-level functions, __name__ always equals __qualname__ because
# there is no enclosing class to form a qualified prefix. sha3_256.__name__ is
# 'openssl_sha3_256' (16 chars) which equals sha3_256.__qualname__. sha3_256 and
# sha3_512 share the same __module__ ('_hashlib') and the same __class__.__name__
# ('builtin_function_or_method'). Their qualnames both have length 16. No prior
# spec anchors these cross-function equality patterns. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table hashlib_extra120.sha3_name_qualname_and_cross_equality:
  description: "sha3_256.__name__.__eq__(sha3_256.__qualname__)==True (name==qualname for C-level functions) / sha3_256.__module__.__eq__(sha3_512.__module__)==True (shared _hashlib module) / sha3_256.__class__.__name__.__eq__(sha3_512.__class__.__name__)==True (shared builtin_function_or_method type) / sha3_256.__qualname__.__len__()==16 / sha3_512.__qualname__.__len__()==16 — top-level C functions always have name==qualname; sha3_256 and sha3_512 share module and type class name; both qualnames are 16 chars; no prior spec anchors these cross-equality patterns; first hashlibsha3_120 anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlibsha3_120

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_name_eq_qualname,   "sha3_256.__name__.__eq__",              ["openssl_sha3_256"], true, "sha3_256.__name__.__eq__('openssl_sha3_256') confirms name==qualname for C-level module-level functions (no class prefix)"]
    - [sha3_module_cross_eq,        "sha3_256.__module__.__eq__",            ["_hashlib"],         true, "sha3_256.__module__.__eq__('_hashlib') — both sha3_256 and sha3_512 share the _hashlib module (cross-check)"]
    - [sha3_class_name_cross_eq,    "sha3_256.__class__.__name__.__eq__",    ["builtin_function_or_method"], true, "sha3_256 and sha3_512 share the same __class__.__name__ 'builtin_function_or_method' (both C-level callables)"]
    - [sha3_256_qualname_len,       "sha3_256.__qualname__.__len__",         [],                   16,   "sha3_256.__qualname__.__len__() is 16 (len('openssl_sha3_256')==16; 'openssl_sha3_'=13 + '256'=3)"]
    - [sha3_512_qualname_len,       "sha3_512.__qualname__.__len__",         [],                   16,   "sha3_512.__qualname__.__len__() is 16 (len('openssl_sha3_512')==16; same length as sha3_256 qualname)"]

# ---------------------------------------------------------------------------
# hashlib.sha3_512.__module__.__eq__('_hashlib') — standalone
#
# hashlib.sha3_512.__module__ is '_hashlib'. SHA-3 (Secure Hash Algorithm 3,
# based on Keccak sponge construction) was standardized by NIST in 2015 (FIPS 202).
# On CPython 3.14.3 macOS, sha3_512 is OpenSSL-backed and exposed from the _hashlib
# C extension. Despite SHA-3 being a distinct algorithm family from SHA-2, CPython
# uses a single _hashlib module (via OpenSSL EVP) for all SHA variants including
# SHA-3. hashlib_extra111 anchors sha3_256.__module__ as standalone; no prior spec
# anchors sha3_512.__module__ as a standalone. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant hashlib_extra120.sha3_512_module_hashlib:
  description: "hashlib.sha3_512.__module__.__eq__('_hashlib') == True — sha3_512 is from _hashlib (OpenSSL-backed; SHA-3 FIPS 202 standardized 2015 Keccak sponge; CPython routes all SHA variants through OpenSSL EVP in _hashlib); extra111 anchors sha3_256 module as standalone; no prior spec anchors sha3_512 module as standalone; first standalone under hashlibsha3_120"
  category: function_identity
  kind: python_call_eq
  function: sha3_512.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_512.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# hashlib.sha3_512.__class__.__name__ is 'builtin_function_or_method'. This 26-char
# type name identifies C-level callable functions and unbound methods in CPython.
# sha3_512 is a builtin_function_or_method from the _hashlib C extension, just like
# sha3_256 (anchored in extra111) and md5/sha1 (anchored in extra119). All OpenSSL-
# backed hash constructors share this type. No prior spec anchors sha3_512 class name
# as a standalone under hashlibsha3_120. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra120.sha3_512_class_builtin_function:
  description: "hashlib.sha3_512.__class__.__name__.__eq__('builtin_function_or_method') == True — sha3_512 is a C-level callable (26-char type name; same type as sha3_256/md5/sha1/sha256/sha512 — all OpenSSL-backed hash constructors share this type); extra111 anchors sha3_256 class name; no prior spec anchors sha3_512 class name as standalone; first standalone under hashlibsha3_120"
  category: type_identity
  kind: python_call_eq
  function: sha3_512.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__class__.__module__.__eq__('builtins') — standalone
#
# hashlib.sha3_256.__class__.__module__ is 'builtins'. The builtin_function_or_method
# type itself (i.e., type(hashlib.sha3_256)) has its __module__ set to 'builtins',
# because this type is a fundamental CPython runtime type defined in Objects/methodobject.c
# and exposed as part of the builtins namespace. This is distinct from sha3_256.__module__
# which is '_hashlib' (the module where the function lives). No prior hashlib spec
# anchors sha3_256.__class__.__module__ as a standalone. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant hashlib_extra120.sha3_256_class_module_builtins:
  description: "hashlib.sha3_256.__class__.__module__.__eq__('builtins') == True — the builtin_function_or_method TYPE (not the function) has __module__=='builtins' (it is a fundamental CPython runtime type; defined in Objects/methodobject.c); distinct from sha3_256.__module__=='_hashlib' (where the function itself lives); no prior spec anchors sha3_256.__class__.__module__ as standalone; first standalone under hashlibsha3_120"
  category: type_identity
  kind: python_call_eq
  function: sha3_256.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__class__.__name__.__len__() == 26 — standalone
#
# hashlib.sha3_256.__class__.__name__.__len__() is 26. The type name
# 'builtin_function_or_method' has 26 characters. It encodes two possible roles:
# a standalone function (like len, print, or hashlib.sha3_256) or an unbound method
# accessed from a class (like list.append). This dual nature is reflected in the
# compound name 'builtin_function_or_method'. 26 chars is also the length for
# md5.__class__.__name__.__len__() (anchored in extra119). No prior spec anchors
# sha3_256.__class__.__name__.__len__() as a standalone under hashlibsha3_120.
# ---------------------------------------------------------------------------

invariant hashlib_extra120.sha3_256_class_name_len_26:
  description: "hashlib.sha3_256.__class__.__name__.__len__() == 26 — len('builtin_function_or_method')==26 (encodes dual role: standalone function OR unbound C method; same length for sha3_512 and all other _hashlib hash constructor functions); extra119 anchors md5.__class__.__name__.__len__()==26; no prior spec anchors sha3_256 class name length as standalone; first standalone under hashlibsha3_120"
  category: type_identity
  kind: python_call_eq
  function: sha3_256.__class__.__name__.__len__
  args: []
  expected: 26

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__module__.__len__() == 8 — standalone
#
# hashlib.sha3_256.__module__.__len__() is 8. '_hashlib' has 8 chars: one leading
# underscore (1) + 'hashlib' (7) = 8. The leading underscore is a CPython convention
# for C extension modules that are considered implementation details. The public Python
# module 'hashlib' (7 chars) is a Python wrapper around the private '_hashlib' (8 chars)
# C extension. This same length applies to sha3_512.__module__ and all other OpenSSL-
# backed functions. No prior spec anchors sha3_256.__module__.__len__() as a standalone.
# ---------------------------------------------------------------------------

invariant hashlib_extra120.sha3_256_module_len_8:
  description: "hashlib.sha3_256.__module__.__len__() == 8 — len('_hashlib')==8 (1 leading underscore + 'hashlib'=7; CPython convention for implementation-detail C extensions); public 'hashlib'=7 chars vs private '_hashlib'=8 chars; same length for sha3_512.__module__; no prior spec anchors sha3_256 module length as standalone; first standalone under hashlibsha3_120"
  category: function_identity
  kind: python_call_eq
  function: sha3_256.__module__.__len__
  args: []
  expected: 8

