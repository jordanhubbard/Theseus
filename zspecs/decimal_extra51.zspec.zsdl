spec: decimal_extra51
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal_extra50.zspec.zsdl — covers Decimal/Context/DecimalException/InvalidOperation/DivisionByZero __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy'); decimal module __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy')."
    - "decimal_extra49.zspec.zsdl — covers all 8 decimal exception __module__=='decimal' equality and __module__.__class__.__name__=='str'."
    - "decimal_extra45.zspec.zsdl — covers ROUND_HALF_DOWN/ROUND_HALF_EVEN/ROUND_UP/ROUND_DOWN/ROUND_05UP __class__.__module__=='builtins'."
    - "decimal_extra24.zspec.zsdl — covers ROUND_HALF_UP/ROUND_DOWN/ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_EVEN __class__.__module__.__eq__('builtins')."
    - "decimal_extra29.zspec.zsdl — covers Decimal/Context/DecimalException __dict__.__class__.__name__.__len__()==12."
    - "decimal_extra43.zspec.zsdl — covers Decimal/__class__.__name__.__eq__('type'); Context/__class__.__name__.__eq__('type')."
  notes:
    - "This spec extends decimal_extra50.zspec.zsdl."
    - "Prior specs collectively covered: all 8 ROUND_* constants __class__.__module__=='builtins' (decimal_extra24 covers ROUND_HALF_UP/DOWN/CEILING/FLOOR/HALF_EVEN; decimal_extra45 covers ROUND_HALF_DOWN/HALF_EVEN/UP/DOWN/05UP — together all 8 are covered); decimal_extra43 covers Decimal/__class__.__name__.__eq__('type') and Context/__class__.__name__.__eq__('type'). NOT YET COVERED: Decimal.__class__.__module__.__eq__('builtins') — Decimal is a C-extension type with metaclass 'type' from builtins; no prior decimal spec checks Decimal.__class__.__module__; novel; Context.__class__.__module__.__eq__('builtins') (novel); DecimalException.__class__.__module__.__eq__('builtins') (novel — exception class with metaclass 'type' from builtins); InvalidOperation.__class__.__module__.__eq__('builtins') (novel); DivisionByZero.__class__.__module__.__eq__('builtins') (novel); Overflow.__class__.__module__.__eq__('builtins') (novel); Underflow.__class__.__module__.__eq__('builtins') (novel); Clamped.__class__.__module__.__eq__('builtins') (novel)."
    - "This spec covers: decimal.Decimal.__class__.__module__.__eq__('builtins') (NOVEL — Decimal is a C-extension type; its metaclass is 'type' from builtins; no prior decimal spec checks Decimal.__class__.__module__; novel in decmod51 namespace); decimal.Context.__class__.__module__.__eq__('builtins') (NOVEL); decimal.DecimalException.__class__.__module__.__eq__('builtins') (NOVEL — DecimalException is an exception base class; metaclass is 'type' from builtins; novel); decimal.InvalidOperation.__class__.__module__.__eq__('builtins') (NOVEL); decimal.DivisionByZero.__class__.__module__.__eq__('builtins') (NOVEL); decimal.Overflow.__class__.__module__.__eq__('builtins') (NOVEL); decimal.Underflow.__class__.__module__.__eq__('builtins') (NOVEL); decimal.Clamped.__class__.__module__.__eq__('builtins') (NOVEL)."
    - "decimal.Decimal.__class__.__module__ == 'builtins'. Decimal is implemented in the _decimal C extension. Its metaclass is the standard 'type' builtin. The 'type' metaclass has __module__=='builtins'. No prior decimal spec checks Decimal.__class__.__module__. decimal_extra43 covers Decimal.__class__.__name__.__eq__('type') but not __module__. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.Context.__class__.__module__ == 'builtins'. Context is also from the _decimal C extension. Same metaclass reasoning as Decimal. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.DecimalException.__class__.__module__ == 'builtins'. DecimalException is the base class for all decimal exceptions. It is an Exception subclass with metaclass 'type' from builtins. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.InvalidOperation.__class__.__module__ == 'builtins'. InvalidOperation is a DecimalException subclass. Exception subclasses use the 'type' metaclass from builtins. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.DivisionByZero.__class__.__module__ == 'builtins'. DivisionByZero is a DecimalException subclass. Same reasoning. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.Overflow.__class__.__module__ == 'builtins'. Overflow is a DecimalException subclass raised when a result is too large. Same reasoning. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.Underflow.__class__.__module__ == 'builtins'. Underflow is a DecimalException subclass raised for small non-zero results. Same reasoning. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.Clamped.__class__.__module__ == 'builtins'. Clamped is a DecimalException subclass raised when an exponent is adjusted. Same reasoning. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal C-extension class __class__.__module__ == 'builtins'
#
# Decimal and Context are C-extension types from the _decimal module. Their
# metaclass is the standard 'type' builtin, which has __module__ == 'builtins'.
# decimal_extra43 anchors Decimal.__class__.__name__=='type' and
# Context.__class__.__name__=='type' (via __name__ path), but no prior decimal
# spec checks __class__.__module__ for Decimal or Context.
#
#   Decimal.__class__.__module__ == 'builtins'
#   Context.__class__.__module__ == 'builtins'
#
# Both anchors are novel in the decmod51 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra51.cext_class_module_eq:
  description: "decimal C-extension class __class__.__module__.__eq__('builtins') for Decimal/Context — C-extension types have metaclass 'type' from builtins; decimal_extra43 covers __class__.__name__=='type' but not __module__; no prior decimal spec checks Decimal/Context __class__.__module__; both novel anchors in decmod51 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: decmod51cext

  columns: [id, function, args, expected]
  rows:
    - [Decimal_class_module, "Decimal.__class__.__module__.__eq__", ["builtins"], true]
    - [Context_class_module, "Context.__class__.__module__.__eq__", ["builtins"], true]

# ---------------------------------------------------------------------------
# decimal exception class __class__.__module__ == 'builtins'
#
# DecimalException, InvalidOperation, DivisionByZero, Overflow, Underflow, and
# Clamped are all Exception subclasses. Exception subclasses use the standard
# 'type' metaclass from builtins. No prior decimal spec checks __class__.__module__
# for any decimal exception class.
#
#   DecimalException.__class__.__module__ == 'builtins'
#   InvalidOperation.__class__.__module__ == 'builtins'
#   DivisionByZero.__class__.__module__   == 'builtins'
#   Overflow.__class__.__module__         == 'builtins'
#   Underflow.__class__.__module__        == 'builtins'
#   Clamped.__class__.__module__          == 'builtins'
#
# All six anchors are novel in the decmod51 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra51.exception_class_module_eq:
  description: "decimal exception class __class__.__module__.__eq__('builtins') for DecimalException/InvalidOperation/DivisionByZero/Overflow/Underflow/Clamped — Exception subclasses use metaclass 'type' from builtins; no prior decimal spec checks __class__.__module__ for any decimal exception class; all six novel anchors in decmod51 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: decmod51exc

  columns: [id, function, args, expected]
  rows:
    - [DecimalException_class_module, "DecimalException.__class__.__module__.__eq__", ["builtins"], true]
    - [InvalidOperation_class_module, "InvalidOperation.__class__.__module__.__eq__", ["builtins"], true]
    - [DivisionByZero_class_module,   "DivisionByZero.__class__.__module__.__eq__",   ["builtins"], true]
    - [Overflow_class_module,         "Overflow.__class__.__module__.__eq__",         ["builtins"], true]
    - [Underflow_class_module,        "Underflow.__class__.__module__.__eq__",        ["builtins"], true]
    - [Clamped_class_module,          "Clamped.__class__.__module__.__eq__",          ["builtins"], true]

invariant decimal_extra51.Decimal_class_module_builtins:
  description: "decimal.Decimal.__class__.__module__ == 'builtins' — Decimal is a C-extension type from _decimal; its metaclass is the standard 'type' builtin with __module__=='builtins'; decimal_extra43 anchors Decimal.__class__.__name__=='type' via __name__ path but not __module__; novel anchor in decmod51 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant decimal_extra51.DecimalException_class_module_builtins:
  description: "decimal.DecimalException.__class__.__module__ == 'builtins' — DecimalException is the base class for all decimal exceptions; as an Exception subclass it uses the 'type' metaclass from builtins; no prior decimal spec checks DecimalException.__class__.__module__; novel anchor in decmod51 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: DecimalException.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true
