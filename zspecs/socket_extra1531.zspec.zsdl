spec: socket_extra1531
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra1516.zspec.zsdl — covers arithmetic operator absence (__add__ through __pow__) on socket.socket and socket.error; I/O method presence."
    - "socket_extra1501.zspec.zsdl — covers bitwise operator absence on socket.socket, socket.error, and socket.timeout."
    - "socket_extra991.zspec.zsdl — covers lifecycle, addressing, and configuration method __qualname__ attributes."
    - "socket_extra15.zspec.zsdl — covers IPPROTO_ICMP/IPV6/RAW values; SO_RCVBUF/SO_SNDBUF; AddressFamily/SocketKind __mro__ entries."
  notes:
    - "This spec is wave 549 / suffix _extra1531. Theme: comparison operator dict-presence checks on socket.socket, socket.error, and socket.timeout."
    - "socket.socket is a Python-level class (Lib/socket.py) wrapping OS-level file descriptors. Sockets represent I/O endpoints, not orderable values — no comparison dunders are defined in socket.__dict__."
    - "socket.error is identical to OSError (socket.error is OSError == True). OSError defines errno/strerror/filename descriptors and lifecycle dunders, but no comparison operators in its own __dict__."
    - "socket.timeout is identical to TimeoutError, a subclass of OSError. Its __dict__ contains only __doc__."
    - "Verified: socket.socket.__dict__.__contains__('__lt__') == False (through __ne__) == False."
    - "Verified True for socket.socket: __init__, __enter__, __exit__, __repr__, close, accept, makefile, sendfile, dup, detach, family, type."
    - "Verified: socket.error.__dict__.__contains__('__lt__') == False (through __ne__) == False."
    - "Verified True for socket.error: errno, strerror, filename, __new__, __str__, __init__, __reduce__."
    - "Verified: socket.timeout.__dict__.__contains__('__lt__') == False (through __ne__) == False."
    - "Verified True for socket.timeout: __doc__ only."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket — comparison operator absence checks
#
# socket.socket is a Python class (Lib/socket.py) providing an interface to
# OS-level sockets. Socket objects represent open communication endpoints;
# there is no natural ordering between sockets, so none of the comparison
# dunders (__lt__, __le__, __gt__, __ge__, __eq__, __hash__, __ne__) are
# defined in socket.__dict__. The True entries (__init__, __enter__,
# __exit__, close, accept) confirm the dict-presence mechanism is working.
# Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-12.
# ---------------------------------------------------------------------------

table socket_extra1531.socket_cmp_absent:
  description: "Comparison operator dunders absent from socket.socket.__dict__ — sockets are endpoints, not values"
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk1531ca

  columns: [id, function, args, expected]
  rows:
    - ["sk1531ca001", "socket.__dict__.__contains__", ["__lt__"],    false]
    - ["sk1531ca002", "socket.__dict__.__contains__", ["__le__"],    false]
    - ["sk1531ca003", "socket.__dict__.__contains__", ["__gt__"],    false]
    - ["sk1531ca004", "socket.__dict__.__contains__", ["__ge__"],    false]
    - ["sk1531ca005", "socket.__dict__.__contains__", ["__eq__"],    false]
    - ["sk1531ca006", "socket.__dict__.__contains__", ["__hash__"],  false]
    - ["sk1531ca007", "socket.__dict__.__contains__", ["__ne__"],    false]
    - ["sk1531ca008", "socket.__dict__.__contains__", ["__init__"],  true]
    - ["sk1531ca009", "socket.__dict__.__contains__", ["__enter__"], true]
    - ["sk1531ca010", "socket.__dict__.__contains__", ["close"],     true]

# ---------------------------------------------------------------------------
# socket.socket — I/O and descriptor presence checks
#
# socket.socket defines a rich I/O and context-manager interface in its
# __dict__: context manager protocol (__enter__, __exit__), core I/O
# (accept, makefile, sendfile, dup, detach), and attribute descriptors
# (family, type) for socket metadata. These True entries validate the
# dict-presence mechanism and highlight what the socket class does own.
# ---------------------------------------------------------------------------

table socket_extra1531.socket_methods_present:
  description: "I/O methods and attribute descriptors present in socket.socket.__dict__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk1531mp

  columns: [id, function, args, expected]
  rows:
    - ["sk1531mp001", "socket.__dict__.__contains__", ["__repr__"],  true]
    - ["sk1531mp002", "socket.__dict__.__contains__", ["__exit__"],  true]
    - ["sk1531mp003", "socket.__dict__.__contains__", ["accept"],    true]
    - ["sk1531mp004", "socket.__dict__.__contains__", ["makefile"],  true]
    - ["sk1531mp005", "socket.__dict__.__contains__", ["sendfile"],  true]
    - ["sk1531mp006", "socket.__dict__.__contains__", ["dup"],       true]
    - ["sk1531mp007", "socket.__dict__.__contains__", ["detach"],    true]
    - ["sk1531mp008", "socket.__dict__.__contains__", ["family"],    true]
    - ["sk1531mp009", "socket.__dict__.__contains__", ["type"],      true]
    - ["sk1531mp010", "socket.__dict__.__contains__", ["__lt__"],    false]

# ---------------------------------------------------------------------------
# socket.error — comparison operator absence checks
#
# socket.error is OSError (they are the same object). OSError stores
# errno/strerror/filename and overrides lifecycle dunders (__new__, __init__,
# __str__, __reduce__), but defines no comparison operators in its own
# __dict__. socket.timeout is TimeoutError; its __dict__ contains only
# __doc__. Both confirm that OS-level exception types do not define ordering.
# Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-12.
# ---------------------------------------------------------------------------

table socket_extra1531.error_cmp_absent:
  description: "Comparison operator dunders absent from socket.error (OSError).__dict__ and socket.timeout.__dict__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk1531ec

  columns: [id, function, args, expected]
  rows:
    - ["sk1531ec001", "error.__dict__.__contains__",   ["__lt__"],    false]
    - ["sk1531ec002", "error.__dict__.__contains__",   ["__le__"],    false]
    - ["sk1531ec003", "error.__dict__.__contains__",   ["__gt__"],    false]
    - ["sk1531ec004", "error.__dict__.__contains__",   ["__ge__"],    false]
    - ["sk1531ec005", "error.__dict__.__contains__",   ["__eq__"],    false]
    - ["sk1531ec006", "error.__dict__.__contains__",   ["__hash__"],  false]
    - ["sk1531ec007", "error.__dict__.__contains__",   ["__ne__"],    false]
    - ["sk1531ec008", "error.__dict__.__contains__",   ["errno"],     true]
    - ["sk1531ec009", "error.__dict__.__contains__",   ["strerror"],  true]
    - ["sk1531ec010", "error.__dict__.__contains__",   ["filename"],  true]
    - ["sk1531ec011", "error.__dict__.__contains__",   ["__new__"],   true]
    - ["sk1531ec012", "error.__dict__.__contains__",   ["__str__"],   true]
    - ["sk1531ec013", "timeout.__dict__.__contains__", ["__lt__"],    false]
    - ["sk1531ec014", "timeout.__dict__.__contains__", ["__hash__"],  false]
    - ["sk1531ec015", "timeout.__dict__.__contains__", ["__doc__"],   true]
