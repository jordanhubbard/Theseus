spec: in2986
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 646 (in2986): __len__, __length_hint__, __contains__ dict-presence checks for inspect types."
    - "inspect types are introspection helpers — none define len, length_hint, or contains (container/sequence protocol) operators."
    - "Verified types: inspect.Parameter, inspect.BoundArguments, inspect.Signature, inspect.FullArgSpec, inspect.FrameInfo, inspect.ArgInfo, inspect.Traceback, inspect.ClosureVars."
    - "inspect.FullArgSpec, inspect.FrameInfo, inspect.ArgInfo, inspect.Traceback, and inspect.ClosureVars are namedtuple subclasses; they inherit __len__ and __contains__ from tuple but do not define them in their own __dict__."
    - "inspect.Parameter, inspect.BoundArguments, and inspect.Signature are pure Python classes with no container protocol."
    - "inspect.BoundArguments does not define __contains__ for checking argument names; membership testing is not part of its interface."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in2986.len:
  description: "inspect types __len__ dict-presence checks; wave 646"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2986
  columns: [id, function, args, expected]
  rows:
    - ["in2986001", operator.contains, [inspect.Parameter.__dict__,       "__len__"], false]
    - ["in2986002", operator.contains, [inspect.BoundArguments.__dict__,  "__len__"], false]
    - ["in2986003", operator.contains, [inspect.Signature.__dict__,       "__len__"], false]
    - ["in2986004", operator.contains, [inspect.FullArgSpec.__dict__,     "__len__"], false]
    - ["in2986005", operator.contains, [inspect.FrameInfo.__dict__,       "__len__"], false]
    - ["in2986006", operator.contains, [inspect.ArgInfo.__dict__,         "__len__"], false]

