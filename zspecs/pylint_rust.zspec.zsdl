spec: pylint_rust
version: ">=3.9"
backend: rust_module(pylint_rust)

docs: https://pylint.readthedocs.io/en/stable/

provenance:
  derived_from:
    - "https://pylint.readthedocs.io/en/stable/ — Pylint documentation"
  not_derived_from:
    - "pylint source: pylint/__init__.py"
  notes:
    - "Pylint is a Python static code analysis tool."
    - "pylint.__version__ is a non-empty string."
    - "int(pylint.__version__.split('.')[0]) >= 3."
    - "pylint.lint is available."
    - "Expose pylint_version_nonempty() -> bool: len(pylint.__version__) > 0."
    - "Expose pylint_version_major() -> int: int(pylint.__version__.split('.')[0])."
    - "Expose pylint_has_lint() -> bool: hasattr(pylint, 'lint')."
    - "All test vectors verified against pylint 3.3.6."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# pylint_version_nonempty — version non-empty
invariant pylint_rust.version.nonempty:
  description: "pylint.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: pylint_version_nonempty
  args: []
  expected: true

# pylint_version_major — major version >= 3
invariant pylint_rust.version.major_ge3:
  description: "pylint major version >= 3"
  category: version
  kind: python_call_eq
  function: pylint_version_major
  args: []
  expected: 3

# pylint_has_lint — lint module present
invariant pylint_rust.module.has_lint:
  description: "pylint.lint is available"
  category: module
  kind: python_call_eq
  function: pylint_has_lint
  args: []
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T02:08:14Z
  iterations: 2
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 2 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
