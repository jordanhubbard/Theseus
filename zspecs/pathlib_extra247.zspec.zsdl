spec: pathlib_extra247
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
    - "pathlib_extra246.zspec.zsdl — covers PurePosixPath and PureWindowsPath class identity"
  notes:
    - "This spec covers: pathlib.Path IO method identity contracts — read_text, write_text, read_bytes, write_bytes."
    - "pathlib.Path.read_text.__name__ == 'read_text' — length 9; verified Python 3.14.3 macOS."
    - "pathlib.Path.read_text.__qualname__ == 'Path.read_text' — length 14; verified Python 3.14.3 macOS."
    - "pathlib.Path.read_text.__module__ == 'pathlib' — length 7; verified Python 3.14.3 macOS."
    - "pathlib.Path.write_text.__name__ == 'write_text' — length 10; verified Python 3.14.3 macOS."
    - "pathlib.Path.write_text.__qualname__ == 'Path.write_text' — length 15; verified Python 3.14.3 macOS."
    - "pathlib.Path.write_text.__module__ == 'pathlib' — length 7; verified Python 3.14.3 macOS."
    - "pathlib.Path.read_bytes.__name__ == 'read_bytes' — length 10; verified Python 3.14.3 macOS."
    - "pathlib.Path.read_bytes.__qualname__ == 'Path.read_bytes' — length 15; verified Python 3.14.3 macOS."
    - "pathlib.Path.read_bytes.__module__ == 'pathlib' — length 7; verified Python 3.14.3 macOS."
    - "pathlib.Path.write_bytes.__name__ == 'write_bytes' — length 11; verified Python 3.14.3 macOS."
    - "pathlib.Path.write_bytes.__qualname__ == 'Path.write_bytes' — length 16; verified Python 3.14.3 macOS."
    - "pathlib.Path.write_bytes.__module__ == 'pathlib' — length 7; verified Python 3.14.3 macOS."
    - "All these methods are regular Python instance methods defined in pathlib, so __module__ == 'pathlib'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path.read_text method identity contracts
# read_text.__name__ == 'read_text', __qualname__ == 'Path.read_text',
# __module__ == 'pathlib'. All verified with Python 3.14.3 macOS.
# ---------------------------------------------------------------------------

table pathlib_extra247.read_text_identity:
  description: "pathlib.Path.read_text method identity: __name__, __qualname__, __module__ equality; verified Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathlibio247

  columns: [id, function, args, expected]
  rows:
    - [rt_name_eq,      Path.read_text.__name__.__eq__,      ["read_text"],      true]
    - [rt_name_not,     Path.read_text.__name__.__eq__,      ["write_text"],     false]
    - [rt_qualname_eq,  Path.read_text.__qualname__.__eq__,  ["Path.read_text"], true]
    - [rt_module_eq,    Path.read_text.__module__.__eq__,    ["pathlib"],        true]
    - [rt_name_len,     Path.read_text.__name__.__len__,     [],                 9]

