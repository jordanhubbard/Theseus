# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra247.read_text.name_eq:
  description: "pathlib.Path.read_text.__name__ == 'read_text' — the unbound method's __name__ attribute; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Path.read_text.__name__.__eq__
  args: ["read_text"]
  expected: true

invariant pathlib_extra247.read_text.qualname_eq:
  description: "pathlib.Path.read_text.__qualname__ == 'Path.read_text' — the class-qualified name for the method; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Path.read_text.__qualname__.__eq__
  args: ["Path.read_text"]
  expected: true

invariant pathlib_extra247.read_text.qualname_len:
  description: "len(pathlib.Path.read_text.__qualname__) == 14 — 'Path.read_text' has 14 characters; verified Python 3.14.3 macOS"
