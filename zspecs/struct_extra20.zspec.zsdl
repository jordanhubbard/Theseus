spec: struct_extra20
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct.zspec.zsdl — pack/unpack/calcsize core vectors."
    - "struct_extra.zspec.zsdl through struct_extra19.zspec.zsdl — prior extras."
  notes:
    - "This spec extends struct.zspec.zsdl through struct_extra19.zspec.zsdl."
    - "Focus: __qualname__ string length cross-checks for struct module functions and classes."
    - "struct_extra4 covers function __qualname__.__eq__ for pack/unpack/pack_into/unpack_from/calcsize/iter_unpack."
    - "struct_extra4 covers Struct.__qualname__=='Struct' and error.__qualname__=='error'."
    - "struct_extra19 covers Struct.__qualname__.__len__()==6 and error.__qualname__.__len__()==5."
    - "No prior spec checks __qualname__.__len__() for the module-level functions."
    - "This spec adds NEW axes:"
    - "  (1) pack.__qualname__.__len__() == 4 — len('pack') == 4."
    - "  (2) unpack.__qualname__.__len__() == 6 — len('unpack') == 6."
    - "  (3) pack_into.__qualname__.__len__() == 9 — len('pack_into') == 9."
    - "  (4) unpack_from.__qualname__.__len__() == 11 — len('unpack_from') == 11."
    - "  (5) calcsize.__qualname__.__len__() == 8 — len('calcsize') == 8."
    - "  (6) iter_unpack.__qualname__.__len__() == 11 — len('iter_unpack') == 11."
    - "  (7) pack.__qualname__.__class__.__name__ == 'str' — qualname is a str object."
    - "  (8) unpack.__qualname__.__class__.__name__ == 'str' — qualname is a str object."
    - "All __qualname__.__len__() values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "pack.__qualname__.__len__() == 4 — len('pack') == 4. Verified."
    - "unpack.__qualname__.__len__() == 6 — len('unpack') == 6. Verified."
    - "pack_into.__qualname__.__len__() == 9 — len('pack_into') == 9. Verified."
    - "unpack_from.__qualname__.__len__() == 11 — len('unpack_from') == 11. Verified."
    - "calcsize.__qualname__.__len__() == 8 — len('calcsize') == 8. Verified."
    - "iter_unpack.__qualname__.__len__() == 11 — len('iter_unpack') == 11. Verified."
    - "pack.__qualname__.__class__.__name__ == 'str' — Verified."
    - "unpack.__qualname__.__class__.__name__ == 'str' — Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() for struct module-level functions
#
# struct_extra4 checks __qualname__.__eq__ (equality) for all six functions.
# struct_extra19 checks __len__ only for Struct and error class qualnames.
# No prior spec checks __len__ of the function qualnames themselves.
# These length checks provide an independent axis: they validate the qualname
# string length without requiring string equality comparison.
# ---------------------------------------------------------------------------

table struct_extra20.function_qualname_lengths:
  description: "struct module function __qualname__ string lengths"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqlen20

  columns: [id, function, args, expected]
  rows:
    - [pack,        pack.__qualname__.__len__,        [], 4]
    - [unpack,      unpack.__qualname__.__len__,      [], 6]
    - [pack_into,   pack_into.__qualname__.__len__,   [], 9]
    - [unpack_from, unpack_from.__qualname__.__len__, [], 11]
    - [calcsize,    calcsize.__qualname__.__len__,    [], 8]
    - [iter_unpack, iter_unpack.__qualname__.__len__, [], 11]

# ---------------------------------------------------------------------------
# __qualname__.__class__.__name__ for struct module functions
#
# Confirms that struct function __qualname__ values are plain str objects.
# struct_extra19 checks this for the module __name__ and __package__ attrs.
# No prior spec checks the type of function __qualname__ values.
# ---------------------------------------------------------------------------

invariant struct_extra20.pack.qualname_is_str:
  description: "struct.pack.__qualname__.__class__.__name__ == 'str' — function __qualname__ is a plain string"
  category: function_qualnames
  kind: python_call_eq
  function: pack.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant struct_extra20.unpack.qualname_is_str:
  description: "struct.unpack.__qualname__.__class__.__name__ == 'str' — function __qualname__ is a plain string"
  category: function_qualnames
  kind: python_call_eq
  function: unpack.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Struct.__qualname__.__len__() cross-check from extra20 namespace
#
# struct_extra19 checks Struct.__qualname__.__len__() == 6.
# This invariant anchors the same fact from the extra20 namespace as a
# parallel cross-check using a distinct invariant id.
# len('Struct') == 6. Verified.
# ---------------------------------------------------------------------------

invariant struct_extra20.Struct.qualname_len:
  description: "struct.Struct.__qualname__.__len__() == 6 — len('Struct') == 6 (extra20 cross-check)"
  category: class_identity
  kind: python_call_eq
  function: Struct.__qualname__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# error.__qualname__.__len__() cross-check from extra20 namespace
#
# struct_extra19 checks error.__qualname__.__len__() == 5.
# This invariant anchors the same fact from the extra20 namespace.
# len('error') == 5. Verified.
# ---------------------------------------------------------------------------

invariant struct_extra20.error.qualname_len:
  description: "struct.error.__qualname__.__len__() == 5 — len('error') == 5 (extra20 cross-check)"
  category: class_identity
  kind: python_call_eq
  function: error.__qualname__.__len__
  args: []
  expected: 5
