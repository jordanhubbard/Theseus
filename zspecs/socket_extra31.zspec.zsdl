spec: socket_extra31
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra30.zspec.zsdl — covers socket.__all__.__len__()==238; AF_INET/AF_INET6 __class__.__name__=='AddressFamily'; SOCK_STREAM/SOCK_DGRAM __class__.__name__=='SocketKind'; SOL_SOCKET/IPPROTO_TCP values; socket.socket/__dict__.__class__.__name__=='mappingproxy'/__len__()==12; socket.error/__dict__.__class__.__name__==mappingproxy/__len__()==12."
    - "socket_extra29.zspec.zsdl — covers socket.socket/__mro__.__len__()==3; socket.error/__mro__.__len__()==4; timeout/herror/gaierror __mro__.__len__()==5; setsockopt/getsockopt/settimeout/getpeername __qualname__/__qualname__.__len__()/__name__.__len__()."
    - "socket_extra28.zspec.zsdl — covers socket.socket method __qualname__ and __name__ for bind/connect/listen/accept/send/recv; getaddrinfo/__qualname__.__len__(); setdefaulttimeout/__qualname__.__len__() and __module__.__len__()."
    - "socket_extra27.zspec.zsdl — covers __module__.__len__() for socket.socket/error/timeout/herror/gaierror; __name__.__len__() for socket.socket/error; __qualname__ for gethostname/getfqdn/inet_aton/inet_ntoa."
    - "socket_extra26.zspec.zsdl — covers socket.timeout/__bases__[0].__name__, socket.herror/__bases__[0].__name__, socket.gaierror/__bases__[0].__name__, socket.socket.__init__.__name__, inet_aton/__name__/__module__, inet_ntoa/__name__."
  notes:
    - "This spec extends socket_extra30.zspec.zsdl."
    - "Prior specs covered: all __module__.__len__()/__name__.__len__()/__mro__.__len__()/__bases__[0].__name__ for socket/error/timeout/herror/gaierror; method __qualname__/__name__/__len__() for bind/connect/listen/accept/send/recv/setsockopt/getsockopt/settimeout/getpeername; socket.socket and socket.error __dict__.__class__.__name__=='mappingproxy'/__len__()==12; socket.__all__.__len__()==238; AF_INET/AF_INET6/SOCK_STREAM/SOCK_DGRAM/SOL_SOCKET/IPPROTO_TCP values and class names."
    - "This spec covers: socket.timeout/__dict__.__class__.__name__=='mappingproxy' and __len__()==12; socket.herror/__dict__.__class__.__name__=='mappingproxy' and __len__()==12; socket.gaierror/__dict__.__class__.__name__=='mappingproxy' and __len__()==12; socket.socket.close.__qualname__=='socket.close' and __len__()==12; socket.socket.setblocking.__qualname__=='socket.setblocking' and __len__()==18; socket.socket.getsockname.__qualname__=='socket.getsockname' and __len__()==18; socket.socket.fileno/__qualname__.__len__()==13; socket.socket.detach/__qualname__.__len__()==13; socket.socket.shutdown/__qualname__.__len__()==15; socket.socket.sendall/__qualname__.__len__()==14."
    - "socket.timeout.__dict__.__class__.__name__ == 'mappingproxy' — len 12. Applies equally to herror and gaierror. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.close.__qualname__ == 'socket.close' — len 12. setblocking.__qualname__ == 'socket.setblocking' — len 18. getsockname.__qualname__ == 'socket.getsockname' — len 18. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.fileno.__qualname__ == 'socket.fileno' — len 13. detach == 'socket.detach' — len 13. shutdown == 'socket.shutdown' — len 15. sendall == 'socket.sendall' — len 14. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.timeout, herror, gaierror __dict__.__class__.__name__ and __len__()
#
# No prior spec checks __dict__.__class__.__name__ for timeout, herror, or gaierror.
# Class __dict__ is always a mappingproxy; __class__.__name__ == 'mappingproxy' (len 12).
# socket.socket and socket.error were covered in socket_extra30.
# ---------------------------------------------------------------------------

invariant socket_extra31.timeout_dict_class_name:
  description: "socket.timeout.__dict__.__class__.__name__ == 'mappingproxy' — exception class namespace is a mappingproxy"
  category: class_structure
  kind: python_call_eq
  function: "timeout.__dict__.__class__.__name__.__eq__"
  args: ["mappingproxy"]
  expected: true

invariant socket_extra31.timeout_dict_class_name_len:
  description: "len(socket.timeout.__dict__.__class__.__name__) == 12 — len('mappingproxy') == 12"
  category: class_structure
  kind: python_call_eq
  function: "timeout.__dict__.__class__.__name__.__len__"
  args: []
  expected: 12

table socket_extra31.exception_dict_proxy_names:
  description: "socket.herror/gaierror __dict__.__class__.__name__=='mappingproxy' and __len__()==12"
  kind: python_call_eq
  category: class_structure
  id_prefix: sedpn31

  columns: [id, function, args, expected, description]
  rows:
    - [herror_dict_class,
       "herror.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "socket.herror.__dict__.__class__.__name__ == 'mappingproxy'"]
    - [herror_dict_class_len,
       "herror.__dict__.__class__.__name__.__len__",
       [],
       12,
       "len('mappingproxy') == 12"]
    - [gaierror_dict_class,
       "gaierror.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "socket.gaierror.__dict__.__class__.__name__ == 'mappingproxy'"]
    - [gaierror_dict_class_len,
       "gaierror.__dict__.__class__.__name__.__len__",
       [],
       12,
       "len('mappingproxy') == 12"]

# ---------------------------------------------------------------------------
# socket.socket.close, setblocking, getsockname __qualname__ and __len__()
#
# No prior spec checks __qualname__ or __len__() for close, setblocking, or getsockname.
# Extra28 covered bind/connect/listen/accept/send/recv.
# Extra29 covered setsockopt/getsockopt/settimeout/getpeername.
# close.__qualname__ == 'socket.close' (len 12)
# setblocking.__qualname__ == 'socket.setblocking' (len 18)
# getsockname.__qualname__ == 'socket.getsockname' (len 18)
# ---------------------------------------------------------------------------

invariant socket_extra31.socket_close_qualname:
  description: "socket.socket.close.__qualname__ == 'socket.close'"
  category: function_qualnames
  kind: python_call_eq
  function: "socket.close.__qualname__.__eq__"
  args: ["socket.close"]
  expected: true

invariant socket_extra31.socket_close_qualname_len:
  description: "len(socket.socket.close.__qualname__) == 12 — len('socket.close') == 12"
  category: function_qualnames
  kind: python_call_eq
  function: "socket.close.__qualname__.__len__"
  args: []
  expected: 12

table socket_extra31.socket_method_qualnames_new:
  description: "socket.socket setblocking/getsockname __qualname__.__eq__ and __len__()"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: smqn31

  columns: [id, function, args, expected, description]
  rows:
    - [setblocking_qualname,
       "socket.setblocking.__qualname__.__eq__",
       ["socket.setblocking"],
       true,
       "socket.socket.setblocking.__qualname__ == 'socket.setblocking'"]
    - [setblocking_qualname_len,
       "socket.setblocking.__qualname__.__len__",
       [],
       18,
       "len('socket.setblocking') == 18"]
    - [getsockname_qualname,
       "socket.getsockname.__qualname__.__eq__",
       ["socket.getsockname"],
       true,
       "socket.socket.getsockname.__qualname__ == 'socket.getsockname'"]
    - [getsockname_qualname_len,
       "socket.getsockname.__qualname__.__len__",
       [],
       18,
       "len('socket.getsockname') == 18"]

# ---------------------------------------------------------------------------
# socket.socket.fileno, detach, shutdown, sendall __qualname__.__len__()
#
# No prior spec checks __qualname__ length for fileno, detach, shutdown, or sendall.
# fileno.__qualname__ == 'socket.fileno' (len 13)
# detach.__qualname__ == 'socket.detach' (len 13)
# shutdown.__qualname__ == 'socket.shutdown' (len 15)
# sendall.__qualname__ == 'socket.sendall' (len 14)
# ---------------------------------------------------------------------------

table socket_extra31.socket_method_qualname_lengths:
  description: "socket.socket fileno/detach/shutdown/sendall __qualname__.__len__()"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: smql31

  columns: [id, function, args, expected, description]
  rows:
    - [fileno_qualname_len,
       "socket.fileno.__qualname__.__len__",
       [],
       13,
       "len('socket.fileno') == 13"]
    - [detach_qualname_len,
       "socket.detach.__qualname__.__len__",
       [],
       13,
       "len('socket.detach') == 13"]
    - [shutdown_qualname_len,
       "socket.shutdown.__qualname__.__len__",
       [],
       15,
       "len('socket.shutdown') == 15"]
    - [sendall_qualname_len,
       "socket.sendall.__qualname__.__len__",
       [],
       14,
       "len('socket.sendall') == 14"]
