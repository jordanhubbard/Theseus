spec: hashlib_extra209
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Modules/md5module.c"
  notes:
    - "This spec covers __code__ attributes of Python-level hashlib functions: hashlib.new and hashlib.file_digest."
    - "hashlib.md5 and hashlib.sha256 are C builtins and do NOT have a __code__ attribute; only Python-level functions (hashlib.new, hashlib.file_digest, hashlib.__get_builtin_constructor) have __code__."
    - "hashlib.pbkdf2_hmac is a C-level builtin_function_or_method and does NOT have __code__; verified with Python 3.14.3."
    - "hashlib.new.__code__.co_flags.__class__.__name__ == 'int' — co_flags is a plain Python int; verified with Python 3.14.3."
    - "hashlib.new.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is a plain Python int; verified with Python 3.14.3."
    - "hashlib.new.__code__.co_filename.__class__.__name__ == 'str' — co_filename is the path to hashlib.py as a str; verified with Python 3.14.3."
    - "hashlib.file_digest.__code__.co_flags.__class__.__name__ == 'int' — co_flags is a plain Python int; verified with Python 3.14.3."
    - "hashlib.file_digest.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is a plain Python int; verified with Python 3.14.3."
    - "hashlib.new.__code__.__class__.__name__ == 'code' — the __code__ object is of type 'code'; verified with Python 3.14.3."
    - "hashlib.new.__code__.co_argcount == 1 — hashlib.new takes exactly 1 positional argument (the algorithm name); verified with Python 3.14.3."
    - "hashlib.file_digest.__code__.co_argcount == 2 — file_digest takes 2 positional arguments; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: hashlib.new.__code__ attribute class names
#
# hashlib.new is a Python-level function whose __code__ object exposes
# co_flags (int), co_stacksize (int), and co_filename (str).
# ---------------------------------------------------------------------------

table hashlib_extra209.new_code_attr_types:
  description: "hashlib.new.__code__.co_flags/co_stacksize/co_filename/__class__.__name__ return their class name as str; new to extra209"
  kind: python_call_eq
  category: code_attrs
  id_prefix: hashlibcoflags209

  columns: [id, function, args, expected, description]
  rows:
    - [new_co_flags_class_eq,
       new.__code__.co_flags.__class__.__name__.__eq__,
       ["int"],
       true,
       "hashlib.new.__code__.co_flags.__class__.__name__.__eq__('int') == True — co_flags is a plain Python int on code objects; verified with Python 3.14.3; new to extra209"]
    - [new_co_stacksize_class_eq,
       new.__code__.co_stacksize.__class__.__name__.__eq__,
       ["int"],
       true,
       "hashlib.new.__code__.co_stacksize.__class__.__name__.__eq__('int') == True — co_stacksize is a plain Python int on code objects; verified with Python 3.14.3; new to extra209"]
    - [new_co_filename_class_eq,
       new.__code__.co_filename.__class__.__name__.__eq__,
       ["str"],
       true,
       "hashlib.new.__code__.co_filename.__class__.__name__.__eq__('str') == True — co_filename is the path to hashlib.py as a str; verified with Python 3.14.3; new to extra209"]
    - [new_code_class_eq,
       new.__code__.__class__.__name__.__eq__,
       ["code"],
       true,
       "hashlib.new.__code__.__class__.__name__.__eq__('code') == True — the __code__ object itself is of type 'code'; verified with Python 3.14.3; new to extra209"]

# ---------------------------------------------------------------------------
# Table 2: hashlib.file_digest.__code__ attribute class names
#
# hashlib.file_digest is a Python-level function; its __code__ exposes
# co_flags (int), co_stacksize (int), co_filename (str), co_argcount (int).
# ---------------------------------------------------------------------------

table hashlib_extra209.file_digest_code_attr_types:
  description: "hashlib.file_digest.__code__.co_flags/co_stacksize/co_filename/co_argcount class names; new to extra209"
  kind: python_call_eq
  category: code_attrs
  id_prefix: hashlibcoflags209

  columns: [id, function, args, expected, description]
  rows:
    - [fd_co_flags_class_eq,
       file_digest.__code__.co_flags.__class__.__name__.__eq__,
       ["int"],
       true,
       "hashlib.file_digest.__code__.co_flags.__class__.__name__.__eq__('int') == True — co_flags is int on file_digest's code object; verified with Python 3.14.3; new to extra209"]
    - [fd_co_stacksize_class_eq,
       file_digest.__code__.co_stacksize.__class__.__name__.__eq__,
       ["int"],
       true,
       "hashlib.file_digest.__code__.co_stacksize.__class__.__name__.__eq__('int') == True — co_stacksize is int on file_digest's code object; verified with Python 3.14.3; new to extra209"]
    - [fd_co_filename_class_eq,
       file_digest.__code__.co_filename.__class__.__name__.__eq__,
       ["str"],
       true,
       "hashlib.file_digest.__code__.co_filename.__class__.__name__.__eq__('str') == True — co_filename is str on file_digest's code object; verified with Python 3.14.3; new to extra209"]
    - [fd_co_argcount_class_eq,
       file_digest.__code__.co_argcount.__class__.__name__.__eq__,
       ["int"],
       true,
       "hashlib.file_digest.__code__.co_argcount.__class__.__name__.__eq__('int') == True — co_argcount is int on file_digest's code object; verified with Python 3.14.3; new to extra209"]

# ---------------------------------------------------------------------------
# Table 3: hashlib.new.__code__ co_argcount and co_name class names
#
# hashlib.new.__code__.co_argcount == 1
# hashlib.new.__code__.co_name.__class__.__name__ == 'str'
# hashlib.file_digest.__code__.co_argcount == 2
# ---------------------------------------------------------------------------

table hashlib_extra209.code_argcount_and_name:
  description: "hashlib.new and file_digest __code__.co_argcount and co_name class name checks; new to extra209"
  kind: python_call_eq
  category: code_attrs
  id_prefix: hashlibcoflags209

  columns: [id, function, args, expected, description]
  rows:
    - [new_co_argcount_eq_1,
       new.__code__.co_argcount.__eq__,
       [1],
       true,
       "hashlib.new.__code__.co_argcount.__eq__(1) == True — hashlib.new takes exactly 1 positional parameter (name); verified with Python 3.14.3; new to extra209"]
    - [new_co_name_class_eq,
       new.__code__.co_name.__class__.__name__.__eq__,
       ["str"],
       true,
       "hashlib.new.__code__.co_name.__class__.__name__.__eq__('str') == True — co_name is a str on code objects; verified with Python 3.14.3; new to extra209"]
    - [fd_co_argcount_eq_2,
       file_digest.__code__.co_argcount.__eq__,
       [2],
       true,
       "hashlib.file_digest.__code__.co_argcount.__eq__(2) == True — file_digest takes exactly 2 positional parameters; verified with Python 3.14.3; new to extra209"]
    - [fd_code_class_eq,
       file_digest.__code__.__class__.__name__.__eq__,
       ["code"],
       true,
       "hashlib.file_digest.__code__.__class__.__name__.__eq__('code') == True — the __code__ object of file_digest is of type 'code'; verified with Python 3.14.3; new to extra209"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra209
# ---------------------------------------------------------------------------

invariant hashlib_extra209.new_co_flags_is_int:
  description: "hashlib.new.__code__.co_flags.__class__.__name__ == 'int' — co_flags on the code object of hashlib.new is a plain Python int; verified with Python 3.14.3; new to extra209"
  category: code_attrs
  kind: python_call_eq
  function: new.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant hashlib_extra209.new_co_stacksize_is_int:
  description: "hashlib.new.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize on the code object of hashlib.new is a plain Python int; verified with Python 3.14.3; new to extra209"
  category: code_attrs
  kind: python_call_eq
  function: new.__code__.co_stacksize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant hashlib_extra209.new_co_filename_is_str:
  description: "hashlib.new.__code__.co_filename.__class__.__name__ == 'str' — co_filename on the code object of hashlib.new is a str; it holds the path to hashlib.py; verified with Python 3.14.3; new to extra209"
  category: code_attrs
  kind: python_call_eq
  function: new.__code__.co_filename.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant hashlib_extra209.new_code_is_code_type:
  description: "hashlib.new.__code__.__class__.__name__ == 'code' — the __code__ attribute of hashlib.new is a code object whose type is 'code'; verified with Python 3.14.3; new to extra209"
  category: code_attrs
  kind: python_call_eq
  function: new.__code__.__class__.__name__.__eq__
  args: ["code"]
  expected: true

invariant hashlib_extra209.file_digest_co_flags_is_int:
  description: "hashlib.file_digest.__code__.co_flags.__class__.__name__ == 'int' — co_flags on the code object of file_digest is a plain Python int; verified with Python 3.14.3; new to extra209"
  category: code_attrs
  kind: python_call_eq
  function: file_digest.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant hashlib_extra209.file_digest_co_stacksize_is_int:
  description: "hashlib.file_digest.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize on the code object of file_digest is a plain Python int; verified with Python 3.14.3; new to extra209"
  category: code_attrs
  kind: python_call_eq
  function: file_digest.__code__.co_stacksize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant hashlib_extra209.new_co_argcount_is_1:
  description: "hashlib.new.__code__.co_argcount == 1 — hashlib.new accepts exactly 1 positional argument (the algorithm name string); co_argcount is an int equal to 1; verified with Python 3.14.3; new to extra209"
  category: code_attrs
  kind: python_call_eq
  function: new.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant hashlib_extra209.file_digest_co_argcount_is_2:
  description: "hashlib.file_digest.__code__.co_argcount == 2 — file_digest accepts exactly 2 positional arguments; co_argcount is an int equal to 2; verified with Python 3.14.3; new to extra209"
  category: code_attrs
  kind: python_call_eq
  function: file_digest.__code__.co_argcount.__eq__
  args: [2]
  expected: true

