spec: ft3016
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 648 (ft3016): __iter__, __next__, __reversed__ dict-presence checks for functools types."
    - "functools classes are utility wrappers and decorators — none define iterator protocol methods in their own __dict__."
    - "Verified types: functools.partial, functools.partialmethod, functools.cached_property, functools._lru_cache_wrapper, functools._CacheInfo, functools.singledispatchmethod."
    - "functools._lru_cache_wrapper is the C-level wrapper type produced by functools.lru_cache()."
    - "functools._CacheInfo is the namedtuple class for lru_cache statistics."
    - "functools.singledispatchmethod is the descriptor-based dispatch decorator class."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ft3016.iter:
  description: "functools types __iter__ dict-presence checks; wave 648"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft3016
  columns: [id, function, args, expected]
  rows:
    - ["ft3016001", operator.contains, [functools.partial.__dict__,              "__iter__"], false]
    - ["ft3016002", operator.contains, [functools.partialmethod.__dict__,        "__iter__"], false]
    - ["ft3016003", operator.contains, [functools.cached_property.__dict__,      "__iter__"], false]
    - ["ft3016004", operator.contains, [functools._lru_cache_wrapper.__dict__,   "__iter__"], false]
    - ["ft3016005", operator.contains, [functools._CacheInfo.__dict__,           "__iter__"], false]
    - ["ft3016006", operator.contains, [functools.singledispatchmethod.__dict__,  "__iter__"], false]

