spec: struct_extra248
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra91.zspec.zsdl — covers struct.calcsize('b')==1 / calcsize('c')==1 / calcsize('H')==2 / calcsize('h')==2 / calcsize('i')==4 / calcsize('I')==4 / calcsize('q')==8 / calcsize('Q')==8 / calcsize('f')==4 / calcsize('d')==8 / calcsize('?')==1 / calcsize('x')==1 / calcsize('e')==2 (table + invariants)."
  notes:
    - "Wave 248 theme: struct.calcsize for platform-dependent pointer-width formats (l, L, n, N, P) and byte-order prefixed formats (!H, !I, !Q, =I)."
    - "struct.calcsize('l') == 8 on macOS/Darwin 64-bit (signed long, LP64 ABI). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('L') == 8 on macOS/Darwin 64-bit (unsigned long, LP64 ABI). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('n') == 8 on macOS/Darwin 64-bit (ssize_t, pointer-width). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('N') == 8 on macOS/Darwin 64-bit (size_t, pointer-width). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('P') == 8 on macOS/Darwin 64-bit (void* pointer). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('!H') == 2 (network big-endian unsigned short). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('!I') == 4 (network big-endian unsigned int). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('!Q') == 8 (network big-endian unsigned long long). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('=I') == 4 (native byte order, standard size unsigned int). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: 'l', 'L', 'n', 'N', 'P' formats are platform-dependent. Values here reflect macOS/Darwin 64-bit LP64 ABI (long==ssize_t==size_t==pointer==8 bytes)."
    - "Note: The '!' prefix (network/big-endian byte order) does not affect size, only byte order. '!H', '!I', '!Q' have the same sizes as 'H', 'I', 'Q' respectively."
    - "Note: The '=' prefix uses native byte order but standard sizes (no alignment padding). '=I' == 4 bytes (same as 'I' on this platform)."
    - "Note: 'n' and 'N' (ssize_t/size_t) are only valid with native byte order ('@' or no prefix); they raise struct.error with '<', '>', '=', '!' prefixes."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.calcsize('l') == 8 (macOS/Darwin 64-bit)
# struct.calcsize('L') == 8
# struct.calcsize('n') == 8
# struct.calcsize('N') == 8
# struct.calcsize('P') == 8
#
# Wave 248 theme: calcsize for platform-dependent pointer-width format codes.
#
# On macOS/Darwin 64-bit (LP64 ABI), signed long ('l'), unsigned long ('L'),
# ssize_t ('n'), size_t ('N'), and void* pointer ('P') are all 8 bytes.
# These five formats are platform-dependent — on 32-bit platforms or Windows
# (LLP64), 'l' and 'L' would be 4 bytes. The 'n' format (added Python 3.3)
# maps to C ssize_t; 'N' maps to C size_t; 'P' maps to void*. struct_extra91
# covers fixed-size formats (b, c, h, H, i, I, q, Q, f, d, ?, x, e) but not
# these five platform-dependent formats. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra248.calcsize_platform_pointer_width_formats:
  description: "struct.calcsize for platform-dependent pointer-width formats on macOS/Darwin 64-bit LP64 — calcsize('l')==8 / calcsize('L')==8 / calcsize('n')==8 / calcsize('N')==8 / calcsize('P')==8 — on LP64 macOS 64-bit: signed long/unsigned long/ssize_t/size_t/void* are all 8 bytes; platform-dependent (4 bytes on 32-bit); struct_extra91 covers fixed-size formats but not these five; first structcalc248 anchor for pointer-width format calcsize values; wave 248 theme"
  kind: python_call_eq
  category: calcsize_values
  id_prefix: structcalc248

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_l, calcsize, ["l"], 8, "struct.calcsize('l')==8 on macOS/Darwin 64-bit LP64; signed long is 8 bytes (4 on 32-bit)"]
    - [calcsize_L, calcsize, ["L"], 8, "struct.calcsize('L')==8 on macOS/Darwin 64-bit LP64; unsigned long is 8 bytes (4 on 32-bit)"]
    - [calcsize_n, calcsize, ["n"], 8, "struct.calcsize('n')==8 on macOS/Darwin 64-bit; ssize_t (Python 3.3+) is 8 bytes"]
    - [calcsize_N, calcsize, ["N"], 8, "struct.calcsize('N')==8 on macOS/Darwin 64-bit; size_t is 8 bytes"]
    - [calcsize_P, calcsize, ["P"], 8, "struct.calcsize('P')==8 on macOS/Darwin 64-bit; void* pointer is 8 bytes"]

# ---------------------------------------------------------------------------
# struct.calcsize('!H') == 2
# struct.calcsize('!I') == 4
# struct.calcsize('!Q') == 8
#
# Wave 248 theme: calcsize with '!' (network big-endian) byte-order prefix.
#
# The '!' prefix specifies network byte order (big-endian, equivalent to '>').
# It does not change the packed size — '!H' (unsigned short) is 2 bytes,
# '!I' (unsigned int) is 4 bytes, '!Q' (unsigned long long) is 8 bytes.
# These match the sizes of 'H', 'I', 'Q' respectively. Network byte order is
# commonly used for binary protocol headers (IP, TCP, UDP). struct_extra91
# covers 'H', 'I', 'Q' without byte-order prefix; no prior struct spec anchors
# calcsize with '!' prefix under structcalc248. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra248.calcsize_network_byteorder_formats:
  description: "struct.calcsize for network byte-order ('!') prefixed formats — calcsize('!H')==2 / calcsize('!I')==4 / calcsize('!Q')==8 — '!' specifies big-endian network byte order (equivalent to '>'); does not change size vs unprefixed H/I/Q; network byte order is used for IP/TCP/UDP binary protocol headers; struct_extra91 covers H/I/Q without prefix; first structcalc248 anchor for '!' prefix calcsize values; wave 248 theme"
  kind: python_call_eq
  category: calcsize_values
  id_prefix: structcalc248

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_net_H, calcsize, ["!H"], 2, "struct.calcsize('!H')==2; network big-endian unsigned short, same size as 'H'"]
    - [calcsize_net_I, calcsize, ["!I"], 4, "struct.calcsize('!I')==4; network big-endian unsigned int, same size as 'I'"]
    - [calcsize_net_Q, calcsize, ["!Q"], 8, "struct.calcsize('!Q')==8; network big-endian unsigned long long, same size as 'Q'"]

# ---------------------------------------------------------------------------
# struct.calcsize('=I') == 4
# struct.calcsize('=H') == 2
# struct.calcsize('=Q') == 8
#
# Wave 248 theme: calcsize with '=' (native byte order, standard sizes) prefix.
#
# The '=' prefix uses native byte order but standard sizes without alignment
# padding (unlike '@' which uses native alignment). '=I' (unsigned int) is
# 4 bytes, '=H' (unsigned short) is 2 bytes, '=Q' (unsigned long long) is
# 8 bytes. These sizes are the same as '!' (network byte order) and '>' (big-endian)
# and '<' (little-endian) since all non-'@' prefixes use standard sizes.
# struct_extra91 covers 'H', 'I', 'Q' without byte-order prefix; no prior
# struct spec anchors calcsize with '=' prefix under structcalc248.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra248.calcsize_native_std_byteorder_formats:
  description: "struct.calcsize for '=' (native byte order, standard sizes) prefixed formats — calcsize('=H')==2 / calcsize('=I')==4 / calcsize('=Q')==8 — '=' uses native byte order but standard sizes without alignment padding; sizes match '!', '>', '<' prefixes (all non-'@' use standard sizes); struct_extra91 covers H/I/Q without prefix; first structcalc248 anchor for '=' prefix calcsize values; wave 248 theme"
  kind: python_call_eq
  category: calcsize_values
  id_prefix: structcalc248

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_std_H, calcsize, ["=H"], 2, "struct.calcsize('=H')==2; native byte order, standard size unsigned short, no alignment padding"]
    - [calcsize_std_I, calcsize, ["=I"], 4, "struct.calcsize('=I')==4; native byte order, standard size unsigned int, no alignment padding"]
    - [calcsize_std_Q, calcsize, ["=Q"], 8, "struct.calcsize('=Q')==8; native byte order, standard size unsigned long long, no alignment padding"]

# ---------------------------------------------------------------------------
# struct.calcsize('l') == 8 — standalone (macOS/Darwin 64-bit)
#
# struct.calcsize('l') is 8 on macOS/Darwin 64-bit. The 'l' format character
# represents a signed C long. On 64-bit macOS (LP64 ABI), long is 8 bytes.
# This differs from Windows (LLP64 ABI), where long remains 4 bytes even on
# 64-bit systems. The contrast with 'i' (always 4 bytes, int) and 'q' (always
# 8 bytes, long long) is important: 'l' is the portable integer whose size
# tracks the platform's pointer width on POSIX but not on Windows. struct_extra91
# covers 'i' (4) and 'q' (8) but not 'l'; this is the first standalone anchor
# for calcsize('l') under structcalc248. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra248.calcsize_l_is_8:
  description: "struct.calcsize('l') == 8 on macOS/Darwin 64-bit — 'l' is signed C long; on LP64 macOS 64-bit, long==8 bytes (unlike Windows LLP64 where long==4 bytes on 64-bit); differs from 'i' (always 4) and 'q' (always 8); struct_extra91 covers 'i' and 'q' but not 'l'; first standalone for calcsize('l') under structcalc248; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: calcsize_values
  kind: python_call_eq
  function: calcsize
  args: ["l"]
  expected: 8

# ---------------------------------------------------------------------------
# struct.calcsize('P') == 8 — standalone (macOS/Darwin 64-bit)
#
# struct.calcsize('P') is 8 on macOS/Darwin 64-bit. The 'P' format character
# represents a void* pointer, and its size is the native pointer width of the
# platform — 8 bytes on any 64-bit OS. Unlike 'n' (ssize_t) and 'N' (size_t),
# 'P' has no signed/unsigned distinction — it simply represents a pointer-sized
# integer. When packing/unpacking, Python integers are used. 'P' is commonly
# used when interoperating with C extensions that expose raw pointer values.
# struct_extra91 covers 'q'/'Q' (always-8-byte long long) but not 'P'; this is
# the first standalone anchor for calcsize('P') under structcalc248.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra248.calcsize_P_is_8:
  description: "struct.calcsize('P') == 8 on macOS/Darwin 64-bit — 'P' is void* pointer; size is native pointer width: 8 bytes on any 64-bit OS, 4 on 32-bit; no signed/unsigned distinction unlike n/N; used for C extension interop exposing raw pointer values; struct_extra91 covers q/Q but not P; first standalone for calcsize('P') under structcalc248; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: calcsize_values
  kind: python_call_eq
  function: calcsize
  args: ["P"]
  expected: 8

# ---------------------------------------------------------------------------
# struct.calcsize('!I') == 4 — standalone
#
# struct.calcsize('!I') is 4. The '!' prefix specifies network byte order
# (big-endian). '!I' packs an unsigned int as 4 big-endian bytes. Network byte
# order is defined in RFC 1700 and is used in virtually all network protocol
# headers (IP, TCP, UDP, DNS). The size of '!I' is the same as 'I' (4 bytes);
# the prefix only changes the byte order. struct_extra91 covers 'I' (4 bytes)
# without a prefix; this is the first standalone anchor for calcsize('!I') under
# structcalc248. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra248.calcsize_net_I_is_4:
  description: "struct.calcsize('!I') == 4 — '!' specifies big-endian network byte order (RFC 1700); '!I' packs unsigned int as 4 big-endian bytes; size same as 'I' (4); byte order only changes encoding not size; used in IP/TCP/UDP protocol header parsing; struct_extra91 covers 'I' without prefix; first standalone for calcsize('!I') under structcalc248; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: calcsize_values
  kind: python_call_eq
  function: calcsize
  args: ["!I"]
  expected: 4
