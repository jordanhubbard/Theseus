spec: io_extra252
version: ">=3.2"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra.zspec.zsdl — covers DEFAULT_BUFFER_SIZE type/positive and SEEK_* type checks"
    - "io_extra248.zspec.zsdl — covers BufferedReader and BufferedWriter class identity"
  notes:
    - "This spec covers: SEEK_SET/SEEK_CUR/SEEK_END integer value identity and type checks; DEFAULT_BUFFER_SIZE value and type."
    - "io.SEEK_SET == 0, io.SEEK_CUR == 1, io.SEEK_END == 2 — constant values per POSIX lseek(2); verified Python 3.14.3 macOS."
    - "SEEK_SET.__class__.__name__ == 'int' — SEEK constants are plain int objects; verified Python 3.14.3 macOS."
    - "io.DEFAULT_BUFFER_SIZE == 131072 on Python 3.14.3 macOS/Darwin 25.4.0 (not 8192 as on some older platforms)."
    - "DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' — the buffer size is a plain int object; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SEEK_* constants — integer value identity
# SEEK_SET==0, SEEK_CUR==1, SEEK_END==2 per POSIX lseek(2).
# Tested via __eq__ on each constant to confirm the precise integer value.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra252.seek_values:
  description: "SEEK_SET==0, SEEK_CUR==1, SEEK_END==2; verified Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: ioseek252

  columns: [id, function, args, expected]
  rows:
    - [seek_set_eq_0,   SEEK_SET.__eq__, [0], true ]
    - [seek_cur_eq_1,   SEEK_CUR.__eq__, [1], true ]
    - [seek_end_eq_2,   SEEK_END.__eq__, [2], true ]
    - [seek_set_not_1,  SEEK_SET.__eq__, [1], false]
    - [seek_cur_not_0,  SEEK_CUR.__eq__, [0], false]

# ---------------------------------------------------------------------------
# SEEK_* constants — type checks
# Each constant must be a plain int (__class__.__name__ == 'int').
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra252.seek_types:
  description: "SEEK_SET, SEEK_CUR, SEEK_END __class__.__name__ == 'int'; verified Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: ioseek252

  columns: [id, function, args, expected]
  rows:
    - [seek_set_is_int, SEEK_SET.__class__.__name__.__eq__, ["int"], true]
    - [seek_cur_is_int, SEEK_CUR.__class__.__name__.__eq__, ["int"], true]
    - [seek_end_is_int, SEEK_END.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# DEFAULT_BUFFER_SIZE — exact value and type
# On Python 3.14.3 macOS/Darwin 25.4.0 the value is 131072 (128 KiB).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra252.default_buffer_size:
  description: "io.DEFAULT_BUFFER_SIZE == 131072 and is int; verified Python 3.14.3 macOS"
  kind: python_call_eq
  category: constants
  id_prefix: iobufsize252

  columns: [id, function, args, expected]
  rows:
    - [bufsize_eq,    DEFAULT_BUFFER_SIZE.__eq__,                  [131072], true]
    - [bufsize_is_int, DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# Standalone invariants — SEEK_SET
# ---------------------------------------------------------------------------

invariant io_extra252.SEEK_SET.value_eq_0:
  description: "io.SEEK_SET == 0 — SEEK_SET is the integer 0 (seek from start of file); verified Python 3.14.3 macOS"
  category: constants
  kind: python_call_eq
  function: SEEK_SET.__eq__
  args: [0]
  expected: true

invariant io_extra252.SEEK_SET.class_is_int:
  description: "io.SEEK_SET.__class__.__name__ == 'int' — SEEK_SET is a plain int object; verified Python 3.14.3 macOS"
  category: constants
  kind: python_call_eq
  function: SEEK_SET.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant io_extra252.SEEK_SET.not_eq_1:
  description: "io.SEEK_SET != 1 — SEEK_SET (0) does not equal SEEK_CUR (1); verified Python 3.14.3 macOS"
  category: constants
  kind: python_call_eq
  function: SEEK_SET.__eq__
  args: [1]
  expected: false

# ---------------------------------------------------------------------------
# Standalone invariants — SEEK_CUR
# ---------------------------------------------------------------------------

invariant io_extra252.SEEK_CUR.value_eq_1:
  description: "io.SEEK_CUR == 1 — SEEK_CUR is the integer 1 (seek from current position); verified Python 3.14.3 macOS"
  category: constants
  kind: python_call_eq
  function: SEEK_CUR.__eq__
  args: [1]
  expected: true

invariant io_extra252.SEEK_CUR.class_is_int:
  description: "io.SEEK_CUR.__class__.__name__ == 'int' — SEEK_CUR is a plain int object; verified Python 3.14.3 macOS"
  category: constants
  kind: python_call_eq
  function: SEEK_CUR.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — SEEK_END
# ---------------------------------------------------------------------------

invariant io_extra252.SEEK_END.value_eq_2:
  description: "io.SEEK_END == 2 — SEEK_END is the integer 2 (seek from end of file); verified Python 3.14.3 macOS"
  category: constants
  kind: python_call_eq
  function: SEEK_END.__eq__
  args: [2]
  expected: true

invariant io_extra252.SEEK_END.class_is_int:
  description: "io.SEEK_END.__class__.__name__ == 'int' — SEEK_END is a plain int object; verified Python 3.14.3 macOS"
  category: constants
  kind: python_call_eq
  function: SEEK_END.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant io_extra252.SEEK_END.not_eq_0:
  description: "io.SEEK_END != 0 — SEEK_END (2) does not equal SEEK_SET (0); verified Python 3.14.3 macOS"
  category: constants
  kind: python_call_eq
  function: SEEK_END.__eq__
  args: [0]
  expected: false

# ---------------------------------------------------------------------------
# Standalone invariants — DEFAULT_BUFFER_SIZE
# ---------------------------------------------------------------------------

invariant io_extra252.DEFAULT_BUFFER_SIZE.value_eq_131072:
  description: "io.DEFAULT_BUFFER_SIZE == 131072 — the default I/O buffer size on Python 3.14.3 macOS is 131072 bytes (128 KiB); verified Python 3.14.3 macOS"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__eq__
  args: [131072]
  expected: true

invariant io_extra252.DEFAULT_BUFFER_SIZE.class_is_int:
  description: "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' — DEFAULT_BUFFER_SIZE is a plain int; verified Python 3.14.3 macOS"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__
  args: ["int"]
  expected: true
