spec: decimal_extra1111
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module Context class identity, rounding constant class names, and DecimalException hierarchy documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks Context class __name__/__module__/__qualname__, Context.__init__/__repr__ qualnames, rounding constant string values and __class__.__name__, and DecimalException/InvalidOperation/DivisionByZero/Overflow/Underflow/Inexact/Rounded class identity; not covered in _extra1081 or _extra1096"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra1111.context_class_identity:
  description: "decimal.Context class __name__, __module__, __qualname__, and __init__/__repr__ qualname checks"
  kind: python_call_eq
  category: context_class_identity
  id_prefix: dc1111cx
  columns: [id, function, args, expected]
  rows:
    - [dc1111cx001, decimal.Context.__name__.__eq__,              ["Context"],           true]
    - [dc1111cx002, decimal.Context.__module__.__eq__,            ["decimal"],           true]
    - [dc1111cx003, decimal.Context.__qualname__.__eq__,          ["Context"],           true]
    - [dc1111cx004, decimal.Context.__init__.__qualname__.__eq__, ["Context.__init__"],  true]
    - [dc1111cx005, decimal.Context.__repr__.__qualname__.__eq__, ["Context.__repr__"],  true]
    - [dc1111cx006, decimal.Context.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [dc1111cx007, decimal.Context.__repr__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [dc1111cx008, decimal.Context.__str__.__qualname__.__eq__,  ["object.__str__"],    true]
    - [dc1111cx009, decimal.Context.__module__.__eq__,            ["_decimal"],          false]

table decimal_extra1111.rounding_constant_identity:
  description: "decimal rounding constant __class__.__name__ and string value checks"
  kind: python_call_eq
  category: rounding_constant_identity
  id_prefix: dc1111rc
  columns: [id, function, args, expected]
  rows:
    - [dc1111rc001, decimal.ROUND_HALF_UP.__class__.__name__.__eq__,   ["str"],          true]
    - [dc1111rc002, decimal.ROUND_DOWN.__class__.__name__.__eq__,      ["str"],          true]
    - [dc1111rc003, decimal.ROUND_CEILING.__class__.__name__.__eq__,   ["str"],          true]
    - [dc1111rc004, decimal.ROUND_FLOOR.__class__.__name__.__eq__,     ["str"],          true]
    - [dc1111rc005, decimal.ROUND_HALF_EVEN.__class__.__name__.__eq__, ["str"],          true]
    - [dc1111rc006, decimal.ROUND_UP.__class__.__name__.__eq__,        ["str"],          true]
    - [dc1111rc007, decimal.ROUND_05UP.__class__.__name__.__eq__,      ["str"],          true]
    - [dc1111rc008, decimal.ROUND_HALF_UP.__eq__,   ["ROUND_HALF_UP"], true]
    - [dc1111rc009, decimal.ROUND_DOWN.__eq__,      ["ROUND_DOWN"],    true]
    - [dc1111rc010, decimal.ROUND_HALF_UP.__eq__,   ["ROUND_DOWN"],    false]

table decimal_extra1111.exception_class_identity:
  description: "decimal exception class __name__, __module__, and __qualname__ checks"
  kind: python_call_eq
  category: exception_class_identity
  id_prefix: dc1111ex
  columns: [id, function, args, expected]
  rows:
    - [dc1111ex001, decimal.DecimalException.__name__.__eq__,     ["DecimalException"],  true]
    - [dc1111ex002, decimal.DecimalException.__module__.__eq__,   ["decimal"],           true]
    - [dc1111ex003, decimal.DecimalException.__qualname__.__eq__, ["DecimalException"],  true]
    - [dc1111ex004, decimal.InvalidOperation.__name__.__eq__,     ["InvalidOperation"],  true]
    - [dc1111ex005, decimal.DivisionByZero.__name__.__eq__,       ["DivisionByZero"],    true]
    - [dc1111ex006, decimal.Overflow.__name__.__eq__,             ["Overflow"],          true]
    - [dc1111ex007, decimal.Underflow.__name__.__eq__,            ["Underflow"],         true]
    - [dc1111ex008, decimal.Inexact.__name__.__eq__,              ["Inexact"],           true]
    - [dc1111ex009, decimal.Rounded.__name__.__eq__,              ["Rounded"],           true]
    - [dc1111ex010, decimal.InvalidOperation.__module__.__eq__,   ["decimal"],           true]
