# abc.get_cache_token and abc.update_abstractmethods function identity
#
# get_cache_token.__name__ == 'get_cache_token' (len=15)
# get_cache_token.__module__ == '_abc' (len=4)
# get_cache_token.__class__.__name__ == 'builtin_function_or_method'
# update_abstractmethods.__name__ == 'update_abstractmethods' (len=22)
# update_abstractmethods.__module__ == 'abc' (len=3)
# update_abstractmethods.__class__.__name__ == 'function' (len=8)
# ---------------------------------------------------------------------------

table abc_extra245.cache_token_and_update_abstractmethods_identity:
  description: "abc.get_cache_token and abc.update_abstractmethods function identity — get_cache_token.__name__.__eq__('get_cache_token')==True (len=15); get_cache_token.__module__.__eq__('_abc')==True (len=4; implemented in C extension _abc, re-exported by abc); get_cache_token.__class__.__name__.__eq__('builtin_function_or_method')==True (C builtin); update_abstractmethods.__name__.__eq__('update_abstractmethods')==True (len=22, longest name in this spec); update_abstractmethods.__module__.__eq__('abc')==True (len=3; pure Python, unlike get_cache_token); update_abstractmethods.__class__.__name__.__eq__('function')==True (len=8); all verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc245gct

  columns: [id, function, args, expected, description]
  rows:
    - [gct_name_eq,   get_cache_token.__name__.__eq__,                ["get_cache_token"],             true, "abc.get_cache_token.__name__ == 'get_cache_token'; verified with Python 3.14.3"]
    - [gct_name_len,  get_cache_token.__name__.__len__,               [],                              15,   "abc.get_cache_token.__name__.__len__() == 15; verified with Python 3.14.3"]
    - [gct_mod_eq,    get_cache_token.__module__.__eq__,              ["_abc"],                        true, "abc.get_cache_token.__module__ == '_abc' (C extension module); verified with Python 3.14.3"]
    - [gct_mod_len,   get_cache_token.__module__.__len__,             [],                              4,    "abc.get_cache_token.__module__.__len__() == 4; verified with Python 3.14.3"]
    - [gct_cls_eq,    get_cache_token.__class__.__name__.__eq__,      ["builtin_function_or_method"],  true, "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method' (C builtin); verified with Python 3.14.3"]
    - [uam_name_eq,   update_abstractmethods.__name__.__eq__,         ["update_abstractmethods"],      true, "abc.update_abstractmethods.__name__ == 'update_abstractmethods'; verified with Python 3.14.3"]
    - [uam_name_len,  update_abstractmethods.__name__.__len__,        [],                              22,   "abc.update_abstractmethods.__name__.__len__() == 22; verified with Python 3.14.3"]
    - [uam_mod_eq,    update_abstractmethods.__module__.__eq__,       ["abc"],                         true, "abc.update_abstractmethods.__module__ == 'abc'; verified with Python 3.14.3"]
    - [uam_mod_len,   update_abstractmethods.__module__.__len__,      [],                              3,    "abc.update_abstractmethods.__module__.__len__() == 3; verified with Python 3.14.3"]
    - [uam_cls_eq,    update_abstractmethods.__class__.__name__.__eq__, ["function"],                  true, "abc.update_abstractmethods.__class__.__name__ == 'function' (pure Python); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra245
# ---------------------------------------------------------------------------

invariant abc_extra245.abcmeta_base_is_type:
  description: "abc.ABCMeta.__bases__[0].__name__.__eq__('type') returns True — ABCMeta is a metaclass; metaclasses are themselves classes that subclass type; ABCMeta.__name__ == 'ABCMeta' (len=7); ABCMeta.__module__ == 'abc' (len=3); contrast with ABC.__bases__[0].__name__ == 'object' (ABC is a regular class, not a metaclass); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABCMeta.__bases__[0].__name__.__eq__"
  args: ["type"]
  expected: true

invariant abc_extra245.get_cache_token_module_is_c_extension:
  description: "abc.get_cache_token.__module__.__eq__('_abc') returns True — get_cache_token is implemented in the C extension module _abc (len=4), not in the pure-Python abc module (len=3); the abc module re-exports it; get_cache_token.__class__.__name__ == 'builtin_function_or_method' (C builtin); contrast with abstractmethod.__module__ == 'abc' and update_abstractmethods.__module__ == 'abc' (both pure Python); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: get_cache_token.__module__.__eq__
  args: ["_abc"]
  expected: true

invariant abc_extra245.abc_doc_contains_inheritance:
  description: "abc.ABC.__doc__.__contains__('inheritance') returns True — ABC.__doc__ reads 'Helper class that provides a standard way to create an ABC using inheritance.' (len=78); it contains both 'ABC' and 'inheritance'; ABC.__module__ == 'abc' (len=3); ABC.__bases__[0].__name__ == 'object' (len=6); ABCMeta.__doc__.__len__() == 576 (much longer than ABC.__doc__.__len__() == 78); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABC.__doc__.__contains__
  args: ["inheritance"]
  expected: true

invariant abc_extra245.abcmeta_bases_index_1_raises:
  description: "abc.ABCMeta.__bases__[1].__name__.__eq__ raises IndexError — ABCMeta has exactly one direct base class (type); __bases__ is a 1-element tuple; accessing __bases__[1] raises IndexError; this confirms single-inheritance: ABCMeta -> type; ABCMeta.__name__ == 'ABCMeta' (len=7); ABCMeta.__module__ == 'abc' (len=3); verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: "ABCMeta.__bases__[1].__name__.__eq__"
  args: ["ShouldNotReach"]
  raises: IndexError
