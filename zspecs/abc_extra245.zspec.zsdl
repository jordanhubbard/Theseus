table abc_extra245.abc_identity:
  description: "abc.ABC class identity — ABC.__module__.__eq__('abc')==True (len=3); ABC.__bases__[0].__name__.__eq__('object')==True (len=6; ABC provides standard ABC creation via inheritance from object, using ABCMeta as its metaclass); ABC.__doc__.__contains__('ABC')==True; ABC.__doc__.__contains__('inheritance')==True (doc reads 'Helper class that provides a standard way to create an ABC using inheritance.'); ABC.__doc__.__len__()==78; all verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc245ab

  columns: [id, function, args, expected, description]
  rows:
    - [ab_mod_eq,    ABC.__module__.__eq__,                ["abc"],          true, "abc.ABC.__module__ == 'abc'; verified with Python 3.14.3"]
    - [ab_mod_len,   ABC.__module__.__len__,               [],               3,    "abc.ABC.__module__.__len__() == 3; verified with Python 3.14.3"]
    - [ab_base_eq,   "ABC.__bases__[0].__name__.__eq__",   ["object"],       true, "abc.ABC.__bases__[0].__name__ == 'object'; verified with Python 3.14.3"]
    - [ab_base_len,  "ABC.__bases__[0].__name__.__len__",  [],               6,    "abc.ABC.__bases__[0].__name__.__len__() == 6; verified with Python 3.14.3"]
    - [ab_doc_abc,   ABC.__doc__.__contains__,             ["ABC"],          true, "abc.ABC.__doc__.__contains__('ABC') == True; verified with Python 3.14.3"]
    - [ab_doc_inh,   ABC.__doc__.__contains__,             ["inheritance"],  true, "abc.ABC.__doc__.__contains__('inheritance') == True; verified with Python 3.14.3"]
    - [ab_doc_len,   ABC.__doc__.__len__,                  [],               78,   "abc.ABC.__doc__.__len__() == 78; verified with Python 3.14.3"]

