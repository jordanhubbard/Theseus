spec: abc_extra245
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "https://docs.python.org/3/library/abc.html#abc.ABCMeta — ABCMeta metaclass"
    - "https://docs.python.org/3/library/abc.html#abc.ABC — ABC helper class"
    - "https://docs.python.org/3/library/abc.html#abc.abstractmethod — abstractmethod decorator"
    - "https://docs.python.org/3/library/abc.html#abc.update_abstractmethods — update_abstractmethods"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py (internal implementation)"
    - "CPython source: Modules/_abc.c (C-level accelerators)"
  notes:
    - "abc.ABCMeta.__name__ == 'ABCMeta' (len=7); __module__ == 'abc' (len=3); __bases__[0].__name__ == 'type' (len=4; ABCMeta is a metaclass, i.e., a subclass of type)."
    - "abc.ABC.__module__ == 'abc' (len=3); __bases__[0].__name__ == 'object' (len=6); ABC.__doc__ (len=78) contains 'ABC' and 'inheritance'."
    - "abc.abstractmethod.__name__ == 'abstractmethod' (len=14); __module__ == 'abc' (len=3); __doc__.__contains__('abstract')==True (doc len=537)."
    - "abc.ABCMeta.__doc__.__contains__('Abstract')==True (doc len=576; full doc mentions Abstract Base Classes)."
    - "abc.get_cache_token.__name__ == 'get_cache_token' (len=15); __module__ == '_abc' (len=4; C extension); __class__.__name__ == 'builtin_function_or_method'."
    - "abc.update_abstractmethods.__name__ == 'update_abstractmethods' (len=22); __module__ == 'abc' (len=3); __class__.__name__ == 'function' (len=8)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta class identity
#
# ABCMeta.__name__ == 'ABCMeta' (len=7)
# ABCMeta.__module__ == 'abc' (len=3)
# ABCMeta.__bases__[0].__name__ == 'type' (len=4)
# ABCMeta.__doc__.__contains__('Abstract') == True
# ---------------------------------------------------------------------------

table abc_extra245.abcmeta_identity:
  description: "abc.ABCMeta class identity — ABCMeta.__name__.__eq__('ABCMeta')==True (len=7); ABCMeta.__module__.__eq__('abc')==True (len=3); ABCMeta.__bases__[0].__name__.__eq__('type')==True (len=4; ABCMeta is a metaclass that subclasses type directly); ABCMeta.__doc__.__contains__('Abstract')==True (docstring opens 'Metaclass for defining Abstract Base Classes (ABCs)'); ABCMeta.__name__.__len__()==7; ABCMeta.__module__.__len__()==3; all verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc245am

  columns: [id, function, args, expected, description]
  rows:
    - [am_name_eq,   ABCMeta.__name__.__eq__,                  ["ABCMeta"],    true, "abc.ABCMeta.__name__ == 'ABCMeta'; verified with Python 3.14.3"]
    - [am_name_len,  ABCMeta.__name__.__len__,                 [],             7,    "abc.ABCMeta.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [am_mod_eq,    ABCMeta.__module__.__eq__,                ["abc"],        true, "abc.ABCMeta.__module__ == 'abc'; verified with Python 3.14.3"]
    - [am_mod_len,   ABCMeta.__module__.__len__,               [],             3,    "abc.ABCMeta.__module__.__len__() == 3; verified with Python 3.14.3"]
    - [am_base_eq,   "ABCMeta.__bases__[0].__name__.__eq__",   ["type"],       true, "abc.ABCMeta.__bases__[0].__name__ == 'type'; verified with Python 3.14.3"]
    - [am_base_len,  "ABCMeta.__bases__[0].__name__.__len__",  [],             4,    "abc.ABCMeta.__bases__[0].__name__.__len__() == 4; verified with Python 3.14.3"]
    - [am_doc_abs,   ABCMeta.__doc__.__contains__,             ["Abstract"],   true, "abc.ABCMeta.__doc__.__contains__('Abstract') == True; verified with Python 3.14.3"]
    - [am_doc_len,   ABCMeta.__doc__.__len__,                  [],             576,  "abc.ABCMeta.__doc__.__len__() == 576; verified with Python 3.14.3"]

