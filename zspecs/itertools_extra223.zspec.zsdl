spec: itertools_extra223
version: ">=3.10"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers itertools class __class__.__name__ type identity contracts."
    - "itertools.chain.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "itertools.cycle.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "itertools.count.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "itertools.repeat.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "itertools.product.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "itertools.combinations.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "itertools.permutations.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "itertools.accumulate.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "itertools.compress.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "itertools.dropwhile.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "itertools.takewhile.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "itertools.islice.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "itertools.starmap.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "itertools.groupby.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "itertools.pairwise.__class__.__name__ == 'type' — pairwise added in Python 3.10. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools C-type __class__.__name__ checks (chain through permutations)
#
# All itertools iterator classes are C extension types whose metaclass is 'type'.
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table itertools_extra223.class_type_names_a:
  description: "itertools C-type __class__.__name__ == 'type' for chain, cycle, count, repeat, product, combinations, permutations; new to extra223"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra223classtypea

  columns: [id, function, args, expected, description]
  rows:
    - [chain_class_name_eq,
       chain.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.chain.__class__.__name__.__eq__('type') == True — chain is a C extension type in Modules/itertoolsmodule.c; its metaclass is 'type'; str.__eq__('type') returns True; new to extra223"]
    - [cycle_class_name_eq,
       cycle.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.cycle.__class__.__name__.__eq__('type') == True — cycle is a C extension type in Modules/itertoolsmodule.c; its metaclass is 'type'; str.__eq__('type') returns True; new to extra223"]
    - [count_class_name_eq,
       count.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.count.__class__.__name__.__eq__('type') == True — count is a C extension type in Modules/itertoolsmodule.c; its metaclass is 'type'; str.__eq__('type') returns True; new to extra223"]
    - [repeat_class_name_eq,
       repeat.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.repeat.__class__.__name__.__eq__('type') == True — repeat is a C extension type in Modules/itertoolsmodule.c; its metaclass is 'type'; str.__eq__('type') returns True; new to extra223"]
    - [product_class_name_eq,
       product.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.product.__class__.__name__.__eq__('type') == True — product is a C extension type in Modules/itertoolsmodule.c; its metaclass is 'type'; str.__eq__('type') returns True; new to extra223"]
    - [combinations_class_name_eq,
       combinations.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.combinations.__class__.__name__.__eq__('type') == True — combinations is a C extension type in Modules/itertoolsmodule.c; its metaclass is 'type'; str.__eq__('type') returns True; new to extra223"]
    - [permutations_class_name_eq,
       permutations.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.permutations.__class__.__name__.__eq__('type') == True — permutations is a C extension type in Modules/itertoolsmodule.c; its metaclass is 'type'; str.__eq__('type') returns True; new to extra223"]

# ---------------------------------------------------------------------------
