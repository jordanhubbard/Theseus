spec: theseus_struct_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_struct_cr2)
blocks: struct

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html"
  notes:
    - "Clean-room extended struct utilities. Do NOT import struct."
    - "Struct(fmt): compiled format object with pack/unpack/size."
    - "pack_into(fmt, buffer, offset, *v): pack into a bytearray at offset."
    - "unpack_from(fmt, buffer, offset=0): unpack from buffer at offset."
    - "iter_unpack(fmt, buffer): iterate over successive packed items."
    - "struct2_struct_size(): Struct('>I').size == 4."
    - "struct2_pack_into(): pack_into('>H', buf, 0, 0x1234); buf[0]==0x12."
    - "struct2_unpack_from(): unpack_from('>H', b'\\x00\\x42', 0) == (0x42,)."
    - "Export: Struct class, pack_into, unpack_from, iter_unpack."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_struct_cr2.struct_size:
  description: "Struct('>I').size == 4"
  category: struct
  kind: python_call_eq
  function: struct2_struct_size
  args: []
  expected: 4

invariant theseus_struct_cr2.pack_into:
  description: "pack_into('>H', buf, 0, 0x1234); buf[0] == 0x12"
  category: pack
  kind: python_call_eq
  function: struct2_pack_into
  args: []
  expected: 18

invariant theseus_struct_cr2.unpack_from:
  description: "unpack_from('>H', b'\\x00\\x42', 0)[0] == 0x42"
  category: unpack
  kind: python_call_eq
  function: struct2_unpack_from
  args: []
  expected: 66
