spec: typing_extra3
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html — Python typing module documentation"
    - "PEP 612 — Parameter Specification Variables (Python 3.10)"
    - "PEP 646 — Variadic Generics / TypeVarTuple (Python 3.11)"
    - "PEP 647 — User-Defined Type Guards / TypeGuard (Python 3.10)"
    - "PEP 655 — Marking individual TypedDict items as required or not (Python 3.11)"
    - "PEP 673 — Self Type (Python 3.11)"
    - "PEP 675 — Arbitrary Literal String Type / LiteralString (Python 3.11)"
    - "PEP 681 — Data Class Transforms (Python 3.12)"
    - "PEP 695 — Type Parameter Syntax / TypeAlias (Python 3.10, TypeAliasType Python 3.12)"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "Extends typing.zspec.zsdl, typing_extra.zspec.zsdl, typing_extra2.zspec.zsdl, typing_protocol.zspec.zsdl."
    - "typing_extra.zspec.zsdl covers: TypeVar, Generic __name__/__module__; get_origin(int/str) returns None; function __module__ table; is_typeddict/get_overloads names; TypeVar constraints."
    - "typing_extra2.zspec.zsdl covers: TypeVar/Generic class names; ClassVar/Final/Literal/Union/Optional __class__.__name__; get_type_hints/cast/overload names."
    - "This spec covers: get_origin/__name__, get_args/__name__; ParamSpec (3.10+) name/module/qualname; TypeVarTuple (3.11+) name/module; TypeGuard (3.10+) as _SpecialForm; TypeAlias (3.10+) as _SpecialForm; Never (3.11+) as _SpecialForm; LiteralString (3.11+) as _SpecialForm; Self (3.11+) as _SpecialForm; Unpack (3.11+) as _SpecialForm."
    - "typing.get_origin.__name__ == 'get_origin' — plain function."
    - "typing.get_args.__name__ == 'get_args' — plain function."
    - "typing.ParamSpec is a class (not a special form) available in Python 3.10+; __name__ == 'ParamSpec', __module__ == 'typing'."
    - "typing.TypeVarTuple is a class available in Python 3.11+; __name__ == 'TypeVarTuple', __module__ == 'typing'."
    - "typing.TypeGuard is a _SpecialForm (Python 3.10+); __class__.__name__ == '_SpecialForm'."
    - "typing.TypeAlias is a _SpecialForm (Python 3.10+); __class__.__name__ == '_SpecialForm'."
    - "typing.Never is a _SpecialForm (Python 3.11+); __class__.__name__ == '_SpecialForm'."
    - "typing.LiteralString is a _SpecialForm (Python 3.11+); __class__.__name__ == '_SpecialForm'."
    - "typing.Self is a _SpecialForm (Python 3.11+); __class__.__name__ == '_SpecialForm'."
    - "typing.Unpack is a _SpecialForm (Python 3.11+); __class__.__name__ == '_SpecialForm'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# get_origin and get_args — __name__ checks
#
# Both are plain functions. typing_extra verifies __module__; this spec
# verifies __name__ explicitly (typing_extra2 mentions overload/cast/get_type_hints
# but not get_origin or get_args __name__ as standalone invariants).
# ---------------------------------------------------------------------------

invariant typing_extra3.get_origin.name:
  description: "typing.get_origin.__name__ == 'get_origin'"
  category: function_names
  kind: python_call_eq
  function: get_origin.__name__.__eq__
  args: ["get_origin"]
  expected: true

invariant typing_extra3.get_args.name:
  description: "typing.get_args.__name__ == 'get_args'"
  category: function_names
  kind: python_call_eq
  function: get_args.__name__.__eq__
  args: ["get_args"]
  expected: true

# ---------------------------------------------------------------------------
# get_origin and get_args — __qualname__ checks
#
# Plain functions defined at module scope have __qualname__ == __name__.
# ---------------------------------------------------------------------------

invariant typing_extra3.get_origin.qualname:
  description: "typing.get_origin.__qualname__ == 'get_origin'"
  category: function_qualnames
  kind: python_call_eq
  function: get_origin.__qualname__.__eq__
  args: ["get_origin"]
  expected: true

invariant typing_extra3.get_args.qualname:
  description: "typing.get_args.__qualname__ == 'get_args'"
  category: function_qualnames
  kind: python_call_eq
  function: get_args.__qualname__.__eq__
  args: ["get_args"]
  expected: true

# ---------------------------------------------------------------------------
# ParamSpec — class identity (Python 3.10+)
#
# typing.ParamSpec is a class (like TypeVar, not a _SpecialForm) introduced
# in PEP 612. It allows type-safe parameterization of callable signatures.
# Available since Python 3.10.
# ---------------------------------------------------------------------------

invariant typing_extra3.ParamSpec.name:
  description: "typing.ParamSpec.__name__ == 'ParamSpec' (Python 3.10+)"
  category: paramspec
  kind: python_call_eq
  function: ParamSpec.__name__.__eq__
  args: ["ParamSpec"]
  expected: true
  version: ">=3.10"

invariant typing_extra3.ParamSpec.module:
  description: "typing.ParamSpec.__module__ == 'typing' (Python 3.10+)"
  category: paramspec
  kind: python_call_eq
  function: ParamSpec.__module__.__eq__
  args: ["typing"]
  expected: true
  version: ">=3.10"

invariant typing_extra3.ParamSpec.qualname:
  description: "typing.ParamSpec.__qualname__ == 'ParamSpec' (Python 3.10+)"
  category: paramspec
  kind: python_call_eq
  function: ParamSpec.__qualname__.__eq__
  args: ["ParamSpec"]
  expected: true
  version: ">=3.10"

# ---------------------------------------------------------------------------
# TypeVarTuple — class identity (Python 3.11+)
#
# typing.TypeVarTuple is a class introduced in PEP 646 for variadic generics.
# Like TypeVar and ParamSpec it is a proper class, not a _SpecialForm.
# Available since Python 3.11.
# ---------------------------------------------------------------------------

invariant typing_extra3.TypeVarTuple.name:
  description: "typing.TypeVarTuple.__name__ == 'TypeVarTuple' (Python 3.11+)"
  category: typevartuple
  kind: python_call_eq
  function: TypeVarTuple.__name__.__eq__
  args: ["TypeVarTuple"]
  expected: true
  version: ">=3.11"

invariant typing_extra3.TypeVarTuple.module:
  description: "typing.TypeVarTuple.__module__ == 'typing' (Python 3.11+)"
  category: typevartuple
  kind: python_call_eq
  function: TypeVarTuple.__module__.__eq__
  args: ["typing"]
  expected: true
  version: ">=3.11"

# ---------------------------------------------------------------------------
# TypeGuard — special form class-of-class check (Python 3.10+)
#
# typing.TypeGuard is a _SpecialForm (PEP 647), not an ordinary class.
# We verify via __class__.__name__ as done for ClassVar/Final/Optional
# in typing_extra2.
# ---------------------------------------------------------------------------

invariant typing_extra3.TypeGuard.class_of_class:
  description: "typing.TypeGuard.__class__.__name__ == '_SpecialForm' (Python 3.10+)"
  category: special_forms
  kind: python_call_eq
  function: TypeGuard.__class__.__name__.__eq__
  args: ["_SpecialForm"]
  expected: true
  version: ">=3.10"

# ---------------------------------------------------------------------------
# TypeAlias — special form class-of-class check (Python 3.10+)
#
# typing.TypeAlias is a _SpecialForm marker for explicit type alias
# declarations (PEP 613 / PEP 695). Available since Python 3.10.
# ---------------------------------------------------------------------------

invariant typing_extra3.TypeAlias.class_of_class:
  description: "typing.TypeAlias.__class__.__name__ == '_SpecialForm' (Python 3.10+)"
  category: special_forms
  kind: python_call_eq
  function: TypeAlias.__class__.__name__.__eq__
  args: ["_SpecialForm"]
  expected: true
  version: ">=3.10"

# ---------------------------------------------------------------------------
# Never — special form class-of-class check (Python 3.11+)
#
# typing.Never is a _SpecialForm representing the bottom type (PEP 673-adjacent,
# added as an alias for NoReturn in type-theoretic contexts). Python 3.11+.
# ---------------------------------------------------------------------------

invariant typing_extra3.Never.class_of_class:
  description: "typing.Never.__class__.__name__ == '_SpecialForm' (Python 3.11+)"
  category: special_forms
  kind: python_call_eq
  function: Never.__class__.__name__.__eq__
  args: ["_SpecialForm"]
  expected: true
  version: ">=3.11"

# ---------------------------------------------------------------------------
# LiteralString — special form class-of-class check (Python 3.11+)
#
# typing.LiteralString is a _SpecialForm (PEP 675) representing strings
# known to be literal string values at type-check time. Python 3.11+.
# ---------------------------------------------------------------------------

invariant typing_extra3.LiteralString.class_of_class:
  description: "typing.LiteralString.__class__.__name__ == '_SpecialForm' (Python 3.11+)"
  category: special_forms
  kind: python_call_eq
  function: LiteralString.__class__.__name__.__eq__
  args: ["_SpecialForm"]
  expected: true
  version: ">=3.11"

# ---------------------------------------------------------------------------
# Self — special form class-of-class check (Python 3.11+)
#
# typing.Self is a _SpecialForm (PEP 673) used to annotate methods that
# return an instance of their own class. Python 3.11+.
# ---------------------------------------------------------------------------

invariant typing_extra3.Self.class_of_class:
  description: "typing.Self.__class__.__name__ == '_SpecialForm' (Python 3.11+)"
  category: special_forms
  kind: python_call_eq
  function: Self.__class__.__name__.__eq__
  args: ["_SpecialForm"]
  expected: true
  version: ">=3.11"

# ---------------------------------------------------------------------------
# Unpack — special form class-of-class check (Python 3.11+)
#
# typing.Unpack is a _SpecialForm (PEP 646) used with TypeVarTuple to
# unpack a tuple of types. Python 3.11+.
# ---------------------------------------------------------------------------

invariant typing_extra3.Unpack.class_of_class:
  description: "typing.Unpack.__class__.__name__ == '_SpecialForm' (Python 3.11+)"
  category: special_forms
  kind: python_call_eq
  function: Unpack.__class__.__name__.__eq__
  args: ["_SpecialForm"]
  expected: true
  version: ">=3.11"

# ---------------------------------------------------------------------------
# NoReturn — special form class-of-class check (Python 3.9+)
#
# typing.NoReturn is the original bottom-type special form, available since
# Python 3.6. On Python 3.9+ it remains a _SpecialForm. This provides a
# baseline complement to the Never check above (Python 3.11+).
# ---------------------------------------------------------------------------

invariant typing_extra3.NoReturn.class_of_class:
  description: "typing.NoReturn.__class__.__name__ == '_SpecialForm'"
  category: special_forms
  kind: python_call_eq
  function: NoReturn.__class__.__name__.__eq__
  args: ["_SpecialForm"]
  expected: true
