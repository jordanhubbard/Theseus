invariant uuidmethods201.UUID_dict.contains_clock_seq_low_standalone:
  description: "uuid.UUID.__dict__.__contains__('clock_seq_low') == True — UUID exposes 'clock_seq_low' for RFC 9562 variant sub-field access"
