spec: uuid_extra201
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 9562 — Universally Unique IDentifiers (UUID)"

provenance:
  derived_from:
    - "Python uuid documentation — https://docs.python.org/3/library/uuid.html"
    - "RFC 9562 — Universally Unique IDentifiers (UUID) — https://www.rfc-editor.org/rfc/rfc9562"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "CPython source: internal PRNG or MAC address resolution"
  notes:
    - "This spec extends uuid.zspec.zsdl, uuid_extra.zspec.zsdl, and uuid_extra200.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "uuid_extra200.zspec.zsdl covers: UUID.__dict__ contains 'urn', 'fields', 'time_low', 'time_mid', 'time_hi_version', 'clock_seq', 'version', 'node'; NAMESPACE_* __class__.__name__ == 'UUID'."
    - "uuid.UUID.__dict__ contains 'time_hi_version', 'clock_seq_hi_variant', 'clock_seq_low', 'node', 'time', 'clock_seq' — all verified True on Python 3.14.3 macOS/Darwin 25.4.0."
    - "These are property descriptors defined on the UUID class; type(UUID.__dict__['node']).__name__ == 'property' (verified on Python 3.14.3)."
    - "UUID.__dict__['time'].__class__.__name__ == 'property' — 'time' is a computed property from the UUID integer fields (RFC 9562 Section 5.1)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UUID.__dict__ — RFC 9562 time-based field property descriptors
# These property descriptors are part of the UUID class interface defined
# in RFC 9562 for UUID version 1 (time-based) attributes.
# ---------------------------------------------------------------------------

table uuidmethods201.UUID_dict.time_fields:
  description: "uuid.UUID.__dict__ contains property descriptors for RFC 9562 time-based UUID fields"
  kind: python_call_eq
  category: class_metadata
  id_prefix: uuidmethods201_dict_time

  columns: [id, function, args, expected, description]
  rows:
    - [time_hi_version,    "UUID.__dict__.__contains__", ["time_hi_version"],    true, "UUID.__dict__ contains 'time_hi_version' property descriptor"]
    - [time,               "UUID.__dict__.__contains__", ["time"],               true, "UUID.__dict__ contains 'time' property descriptor"]
    - [clock_seq,          "UUID.__dict__.__contains__", ["clock_seq"],          true, "UUID.__dict__ contains 'clock_seq' property descriptor"]
    - [clock_seq_hi_variant, "UUID.__dict__.__contains__", ["clock_seq_hi_variant"], true, "UUID.__dict__ contains 'clock_seq_hi_variant' property descriptor"]

# ---------------------------------------------------------------------------
# UUID.__dict__ — node and clock_seq_low property descriptors
# ---------------------------------------------------------------------------

table uuidmethods201.UUID_dict.node_fields:
  description: "uuid.UUID.__dict__ contains property descriptors for node and clock_seq_low"
  kind: python_call_eq
  category: class_metadata
  id_prefix: uuidmethods201_dict_node

  columns: [id, function, args, expected, description]
  rows:
    - [node,          "UUID.__dict__.__contains__", ["node"],          true, "UUID.__dict__ contains 'node' property descriptor"]
    - [clock_seq_low, "UUID.__dict__.__contains__", ["clock_seq_low"], true, "UUID.__dict__ contains 'clock_seq_low' property descriptor"]
    - [no_bytes_le,   "UUID.__dict__.__contains__", ["bytes_le"],      true, "UUID.__dict__ contains 'bytes_le' property descriptor"]
    - [no_fake_attr,  "UUID.__dict__.__contains__", ["not_a_field"],   false, "'not_a_field' is NOT in UUID.__dict__"]

# ---------------------------------------------------------------------------
# UUID.__dict__ — class-level type and length checks
# UUID.__dict__ is a mappingproxy; its __class__.__name__ == 'mappingproxy'.
# UUID.__dict__.__len__() == 37 on Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuidmethods201.UUID_dict.meta:
  description: "uuid.UUID.__dict__ type and size metadata checks"
  kind: python_call_eq
  category: class_metadata
  id_prefix: uuidmethods201_dict_meta

  columns: [id, function, args, expected, description]
  rows:
    - [class_name, "UUID.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true, "UUID.__dict__.__class__.__name__ == 'mappingproxy'"]
    - [len_37,     "UUID.__dict__.__len__",                   [],               37,   "UUID.__dict__.__len__() == 37 on Python 3.14.3"]
    - [no_missing, "UUID.__dict__.__contains__",              ["__missing__"],  false, "'__missing__' is NOT in UUID.__dict__"]
    - [has_init,   "UUID.__dict__.__contains__",              ["__init__"],     true,  "UUID.__dict__ contains '__init__'"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant uuidmethods201.UUID_dict.contains_time_hi_version:
  description: "uuid.UUID.__dict__.__contains__('time_hi_version') == True — UUID exposes 'time_hi_version' as a property descriptor"
  category: class_metadata
  kind: python_call_eq
  function: "UUID.__dict__.__contains__"
  args: ["time_hi_version"]
  expected: true

invariant uuidmethods201.UUID_dict.contains_clock_seq_hi_variant:
