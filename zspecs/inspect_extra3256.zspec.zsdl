spec: in3256
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 664 (in3256): __rpow__, __rlshift__, __rrshift__ dict-presence checks for inspect types."
    - "Theme: __rpow__/__rlshift__/__rrshift__ reflected power/shift dict-presence."
    - "Reflected operators are called when the left operand doesn't support the operation."
    - "All values False — callable/iterator/inspection/synchronization types have no reflected arithmetic."
    - "No inspect type defines __rpow__, __rlshift__, or __rrshift__ in its own __dict__."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception types."
    - "None of these types implement reflected power/shift protocols directly."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3256.rpow:
  description: "inspect types __rpow__ dict-presence checks; wave 664"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: in3256
  columns: [id, function, args, expected]
  rows:
    - ["in3256001", operator.contains, [inspect.Parameter.__dict__,           "__rpow__"], false]
    - ["in3256002", operator.contains, [inspect.Signature.__dict__,           "__rpow__"], false]
    - ["in3256003", operator.contains, [inspect.BoundArguments.__dict__,      "__rpow__"], false]
    - ["in3256004", operator.contains, [inspect.FrameInfo.__dict__,           "__rpow__"], false]
    - ["in3256005", operator.contains, [inspect.ArgInfo.__dict__,             "__rpow__"], false]
    - ["in3256006", operator.contains, [inspect.FullArgSpec.__dict__,         "__rpow__"], false]
    - ["in3256007", operator.contains, [inspect.Attribute.__dict__,           "__rpow__"], false]
    - ["in3256008", operator.contains, [inspect.ClassFoundException.__dict__, "__rpow__"], false]
    - ["in3256009", operator.contains, [inspect.EndOfBlock.__dict__,          "__rpow__"], false]

