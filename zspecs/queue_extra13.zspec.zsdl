spec: queue_extra13
version: ">=3.9"
backend: python_module(queue)

docs: https://docs.python.org/3/library/queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/queue.html — Python queue module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/queue.py"
    - "CPython source: Modules/_queuemodule.c"
    - "queue_extra12.zspec.zsdl — covers Queue instance method __qualname__ (put/get/put_nowait/get_nowait/empty/full/qsize/task_done/join); LifoQueue/PriorityQueue __qualname__ standalone."
    - "queue_extra8/extra4 — cover __qualname__.__eq__ for all 6 classes."
    - "queue_extra11 — covers __qualname__.__len__ for all 6 classes."
    - "queue_extra9 — covers Empty/__qualname__.__eq__ and Full/__qualname__.__eq__ standalone."
  notes:
    - "This spec extends queue.zspec.zsdl through queue_extra12.zspec.zsdl."
    - "queue_extra12 covers Queue instance methods (put, get, etc.) __qualname__; no prior spec covers __init__/__repr__ qualnames."
    - "NOT yet covered: Queue.__init__.__qualname__; Queue.__repr__.__qualname__; LifoQueue.__init__.__qualname__; PriorityQueue.__init__.__qualname__; SimpleQueue.put.__qualname__; SimpleQueue.get.__qualname__."
    - "Focus: __qualname__.__eq__ for __init__/__repr__ methods and SimpleQueue method qualnames."
    - "queue.Queue.__init__.__qualname__ == 'Queue.__init__' — Verified Python 3.12 macOS."
    - "queue.Queue.__repr__.__qualname__ == 'object.__repr__' — Queue does not define __repr__; inherits from object. Verified."
    - "queue.LifoQueue.__init__.__qualname__ == 'Queue.__init__' — LifoQueue inherits __init__ from Queue. Verified."
    - "queue.PriorityQueue.__init__.__qualname__ == 'Queue.__init__' — PriorityQueue inherits __init__ from Queue. Verified."
    - "queue.SimpleQueue.put.__qualname__ == 'SimpleQueue.put' — C-level method on SimpleQueue. Verified."
    - "queue.SimpleQueue.get.__qualname__ == 'SimpleQueue.get' — C-level method on SimpleQueue. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Queue.__init__.__qualname__ — extra13 standalone
#
# queue_extra12 covers Queue instance methods (put, get, etc.) __qualname__.
# No prior queue spec checks Queue.__init__.__qualname__. Queue defines its
# own __init__, so its __qualname__ is 'Queue.__init__'. Under
# python_module(queue), 'Queue.__init__.__qualname__.__eq__' resolves as
# queue_module.Queue.__init__.__qualname__.__eq__.
# ---------------------------------------------------------------------------

invariant queue_extra13.Queue.init_qualname:
  description: "queue.Queue.__init__.__qualname__ == 'Queue.__init__' — Queue defines its own __init__"
  category: method_qualnames
  kind: python_call_eq
  function: "Queue.__init__.__qualname__.__eq__"
  args: ["Queue.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# Queue.__repr__.__qualname__ — extra13 standalone
#
# Queue does not define __repr__; it inherits the default from object.
# Therefore Queue.__repr__.__qualname__ == 'object.__repr__', not 'Queue.__repr__'.
# This is a notable invariant: it reveals that Queue has no custom __repr__.
# No prior queue spec checks this attribute.
# ---------------------------------------------------------------------------

invariant queue_extra13.Queue.repr_qualname:
  description: "queue.Queue.__repr__.__qualname__ == 'object.__repr__' — Queue inherits __repr__ from object"
  category: method_qualnames
  kind: python_call_eq
  function: "Queue.__repr__.__qualname__.__eq__"
  args: ["object.__repr__"]
  expected: true

# ---------------------------------------------------------------------------
# LifoQueue.__init__.__qualname__ and PriorityQueue.__init__.__qualname__
#
# LifoQueue and PriorityQueue both inherit __init__ from Queue. Their
# __init__.__qualname__ is therefore 'Queue.__init__', not 'LifoQueue.__init__'
# or 'PriorityQueue.__init__'. No prior queue spec covers this attribute.
# ---------------------------------------------------------------------------

invariant queue_extra13.LifoQueue.init_qualname:
  description: "queue.LifoQueue.__init__.__qualname__ == 'Queue.__init__' — LifoQueue inherits __init__ from Queue"
  category: method_qualnames
  kind: python_call_eq
  function: "LifoQueue.__init__.__qualname__.__eq__"
  args: ["Queue.__init__"]
  expected: true

invariant queue_extra13.PriorityQueue.init_qualname:
  description: "queue.PriorityQueue.__init__.__qualname__ == 'Queue.__init__' — PriorityQueue inherits __init__ from Queue"
  category: method_qualnames
  kind: python_call_eq
  function: "PriorityQueue.__init__.__qualname__.__eq__"
  args: ["Queue.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# SimpleQueue.put.__qualname__ and SimpleQueue.get.__qualname__
#
# SimpleQueue is implemented in the C extension _queue. Its methods put and get
# are C-level methods. Their __qualname__ follows the 'ClassName.method' pattern.
# queue_extra6/extra7 cover __name__ for SimpleQueue.put and SimpleQueue.get.
# No prior queue spec checks __qualname__ for SimpleQueue methods.
# ---------------------------------------------------------------------------

invariant queue_extra13.SimpleQueue.put_qualname:
  description: "queue.SimpleQueue.put.__qualname__ == 'SimpleQueue.put' — C-level method on SimpleQueue"
  category: method_qualnames
  kind: python_call_eq
  function: "SimpleQueue.put.__qualname__.__eq__"
  args: ["SimpleQueue.put"]
  expected: true

invariant queue_extra13.SimpleQueue.get_qualname:
  description: "queue.SimpleQueue.get.__qualname__ == 'SimpleQueue.get' — C-level method on SimpleQueue"
  category: method_qualnames
  kind: python_call_eq
  function: "SimpleQueue.get.__qualname__.__eq__"
  args: ["SimpleQueue.get"]
  expected: true

# ---------------------------------------------------------------------------
# Unified table — __init__ qualnames for Queue, LifoQueue, PriorityQueue
# plus SimpleQueue method qualnames
#
# Consolidates the above invariants in a single table for extra13. The inherited
# __init__ qualnames for LifoQueue and PriorityQueue demonstrate that Python
# preserves the defining class's name in __qualname__, not the inheriting class.
# id_prefix qminit13 does not conflict with any prior queue spec.
# ---------------------------------------------------------------------------

table queue_extra13.init_and_method_qualnames:
  description: "__init__.__qualname__ for Queue/LifoQueue/PriorityQueue and method __qualname__ for SimpleQueue"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qminit13

  columns: [id, function, args, expected]
  rows:
    - [Queue_init,         "Queue.__init__.__qualname__.__eq__",         ["Queue.__init__"],  true]
    - [Queue_repr,         "Queue.__repr__.__qualname__.__eq__",         ["object.__repr__"], true]
    - [LifoQueue_init,     "LifoQueue.__init__.__qualname__.__eq__",     ["Queue.__init__"],  true]
    - [PriorityQueue_init, "PriorityQueue.__init__.__qualname__.__eq__", ["Queue.__init__"],  true]
    - [SimpleQueue_put,    "SimpleQueue.put.__qualname__.__eq__",        ["SimpleQueue.put"], true]
    - [SimpleQueue_get,    "SimpleQueue.get.__qualname__.__eq__",        ["SimpleQueue.get"], true]
