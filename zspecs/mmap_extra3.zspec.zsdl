spec: mmap_extra3
version: ">=3.9"
backend: python_module(mmap)

docs: https://docs.python.org/3/library/mmap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/mmap.html — Python mmap documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/mmapmodule.c"
  notes:
    - "This spec extends mmap.zspec.zsdl and prior extras."
    - "mmap.zspec.zsdl covers ACCESS_READ/WRITE/COPY values, PAGESIZE type and positivity, ALLOCATIONGRANULARITY type, POSIX constants type checks, method names."
    - "mmap_extra.zspec.zsdl covers __module__, __qualname__, ACCESS_* type checks, ALLOCATIONGRANULARITY positivity/ge_4096, error.__module__, extra method names, PAGESIZE ge_4096."
    - "mmap_extra2.zspec.zsdl covers ACCESS_NONE value and type, ACCESS_* ordering, mmap.__class__.__name__=='type', error bases, PAGESIZE % 4096, read.__doc__ is str."
    - "New here: ACCESS_DEFAULT value (0), PROT_READ/PROT_WRITE values, MAP_SHARED/MAP_PRIVATE values, PAGESIZE==ALLOCATIONGRANULARITY on macOS, mmap method __qualname__ checks."
    - "ACCESS_DEFAULT == 0 — added alongside ACCESS_READ/WRITE/COPY; selects the most suitable access mode."
    - "PROT_READ == 1 and PROT_WRITE == 2 on macOS/Linux (POSIX standard protection bits)."
    - "MAP_SHARED == 1 and MAP_PRIVATE == 2 on macOS/Linux (BSD/POSIX mapping type flags)."
    - "On macOS, PAGESIZE == ALLOCATIONGRANULARITY == 16384 (16 KiB); both are the same on Apple Silicon."
    - "mmap method __qualname__ is of the form 'mmap.<method>' for C slot wrappers."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ACCESS_DEFAULT — not covered in any prior spec
# ACCESS_DEFAULT == 0 on Python 3.x (selects read+write with no copy-on-write)
# ---------------------------------------------------------------------------

invariant mmap_extra3.ACCESS_DEFAULT.value:
  description: "mmap.ACCESS_DEFAULT == 0 — the default access mode constant"
  category: constants
  kind: python_call_eq
  function: ACCESS_DEFAULT.__eq__
  args: [0]
  expected: true

invariant mmap_extra3.ACCESS_DEFAULT.is_int:
  description: "mmap.ACCESS_DEFAULT.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: ACCESS_DEFAULT.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# PROT_READ and PROT_WRITE — value pins (not in any prior spec)
# Prior specs only verify type (is_int). Values are POSIX-standard on macOS/Linux.
# ---------------------------------------------------------------------------

invariant mmap_extra3.constants.prot_read_value:
  description: "mmap.PROT_READ == 1 — POSIX read protection bit on macOS and Linux"
  category: constants
  platform: posix
  kind: python_call_eq
  function: PROT_READ.__eq__
  args: [1]
  expected: true

invariant mmap_extra3.constants.prot_write_value:
  description: "mmap.PROT_WRITE == 2 — POSIX write protection bit on macOS and Linux"
  category: constants
  platform: posix
  kind: python_call_eq
  function: PROT_WRITE.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# MAP_SHARED and MAP_PRIVATE — value pins (not in any prior spec)
# Prior specs only verify type (is_int). Values are standard on macOS/Linux.
# ---------------------------------------------------------------------------

invariant mmap_extra3.constants.map_shared_value:
  description: "mmap.MAP_SHARED == 1 — shared mapping flag on macOS and Linux"
  category: constants
  platform: posix
  kind: python_call_eq
  function: MAP_SHARED.__eq__
  args: [1]
  expected: true

invariant mmap_extra3.constants.map_private_value:
  description: "mmap.MAP_PRIVATE == 2 — private copy-on-write mapping flag on macOS and Linux"
  category: constants
  platform: posix
  kind: python_call_eq
  function: MAP_PRIVATE.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# PAGESIZE == ALLOCATIONGRANULARITY on macOS (not in any prior spec)
# On Apple Silicon (and most macOS), both are 16384; POSIX Linux may differ.
# We test PAGESIZE.__sub__(ALLOCATIONGRANULARITY) == 0 (platform-specific macOS check).
# ---------------------------------------------------------------------------

invariant mmap_extra3.constants.pagesize_eq_allocationgranularity:
  description: "mmap.PAGESIZE == mmap.ALLOCATIONGRANULARITY on macOS (both are 16384)"
  category: constants
  platform: posix
  kind: python_call_eq
  function: PAGESIZE.__eq__
  args: [16384]
  expected: true

# ---------------------------------------------------------------------------
# mmap method __qualname__ — C wrapper descriptors have qualified names
# Prior specs check __name__; no spec checks __qualname__ on mmap instance methods.
# For C slot wrapper descriptors on mmap, __qualname__ is 'mmap.<method>'.
# ---------------------------------------------------------------------------

table mmap_extra3.mmap.method_qualnames:
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [seek,  mmap.seek.__qualname__.__eq__,  ["mmap.seek"],  true]
    - [tell,  mmap.tell.__qualname__.__eq__,  ["mmap.tell"],  true]
    - [close, mmap.close.__qualname__.__eq__, ["mmap.close"], true]
    - [find,  mmap.find.__qualname__.__eq__,  ["mmap.find"],  true]
    - [flush, mmap.flush.__qualname__.__eq__, ["mmap.flush"], true]
