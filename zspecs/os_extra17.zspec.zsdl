spec: os_extra17
version: ">=3.9"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
    - "CPython source: Lib/os.py"
  notes:
    - "This spec extends os.zspec.zsdl and prior extras through os_extra16.zspec.zsdl."
    - "os_extra12 covers O_RDONLY/O_WRONLY/O_RDWR/O_CREAT/O_EXCL/O_APPEND/O_TRUNC."
    - "os_extra16 covers O_NONBLOCK, O_NOCTTY, O_DIRECTORY, O_NOFOLLOW."
    - "No prior os spec covers os.sep, os.altsep, os.extsep, os.pathsep, os.linesep."
    - "No prior os spec covers os.curdir, os.pardir, os.devnull."
    - "No prior os spec covers os.F_OK, os.R_OK, os.W_OK, os.X_OK access mode constants."
    - "os.sep == '/' on POSIX systems; os.altsep is None on POSIX (no alternate separator)."
    - "os.extsep == '.' — the extension separator used in filenames."
    - "os.pathsep == ':' on POSIX — separates entries in PATH-like environment variables."
    - "os.linesep == '\\n' on POSIX — the line separator for text files."
    - "os.curdir == '.' and os.pardir == '..' — POSIX directory navigation strings."
    - "os.devnull == '/dev/null' on POSIX — the null device path."
    - "os.F_OK == 0, os.R_OK == 4, os.W_OK == 2, os.X_OK == 1 — POSIX access(2) mode bits."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# os.sep, os.altsep, os.extsep, os.pathsep, os.linesep — path separator strings
#
# No prior os spec covers these POSIX path separator constants.
# On POSIX systems: sep='/', altsep=None, extsep='.', pathsep=':', linesep='\n'.
# ---------------------------------------------------------------------------

invariant os_extra17.sep:
  description: "os.sep == '/' on POSIX — the primary directory separator"
  category: constants
  kind: python_call_eq
  function: sep.__eq__
  args: ["/"]
  expected: true

invariant os_extra17.altsep_is_none:
  description: "os.altsep is None on POSIX — no alternate directory separator"
  category: constants
  kind: python_call_eq
  function: altsep.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant os_extra17.extsep:
  description: "os.extsep == '.' — the file extension separator"
  category: constants
  kind: python_call_eq
  function: extsep.__eq__
  args: ["."]
  expected: true

invariant os_extra17.pathsep:
  description: "os.pathsep == ':' on POSIX — the PATH variable entry separator"
  category: constants
  kind: python_call_eq
  function: pathsep.__eq__
  args: [":"]
  expected: true

invariant os_extra17.linesep:
  description: "os.linesep == '\\n' on POSIX — the line separator for text files"
  category: constants
  kind: python_call_eq
  function: linesep.__eq__
  args: ["\n"]
  expected: true

# ---------------------------------------------------------------------------
# os.curdir, os.pardir, os.devnull — directory navigation and null device
#
# No prior os spec covers curdir, pardir, or devnull.
# curdir == '.', pardir == '..' on all POSIX-like systems.
# devnull == '/dev/null' on POSIX (the null device path).
# ---------------------------------------------------------------------------

invariant os_extra17.curdir:
  description: "os.curdir == '.' — the string naming the current directory"
  category: constants
  kind: python_call_eq
  function: curdir.__eq__
  args: ["."]
  expected: true

invariant os_extra17.pardir:
  description: "os.pardir == '..' — the string naming the parent directory"
  category: constants
  kind: python_call_eq
  function: pardir.__eq__
  args: [".."]
  expected: true

invariant os_extra17.devnull:
  description: "os.devnull == '/dev/null' on POSIX — path to the null device"
  category: constants
  kind: python_call_eq
  function: devnull.__eq__
  args: ["/dev/null"]
  expected: true

# ---------------------------------------------------------------------------
# os.F_OK, os.R_OK, os.W_OK, os.X_OK — access(2) mode bit constants
#
# No prior os spec covers the F_OK/R_OK/W_OK/X_OK access mode constants.
# These correspond to the POSIX access(2) mode argument bits.
# F_OK == 0 (existence), R_OK == 4 (read), W_OK == 2 (write), X_OK == 1 (execute).
# ---------------------------------------------------------------------------

invariant os_extra17.F_OK:
  description: "os.F_OK == 0 — existence check flag for os.access()"
  category: constants
  kind: python_call_eq
  function: F_OK.__eq__
  args: [0]
  expected: true

invariant os_extra17.R_OK:
  description: "os.R_OK == 4 — read permission flag for os.access()"
  category: constants
  kind: python_call_eq
  function: R_OK.__eq__
  args: [4]
  expected: true

invariant os_extra17.W_OK:
  description: "os.W_OK == 2 — write permission flag for os.access()"
  category: constants
  kind: python_call_eq
  function: W_OK.__eq__
  args: [2]
  expected: true

invariant os_extra17.X_OK:
  description: "os.X_OK == 1 — execute permission flag for os.access()"
  category: constants
  kind: python_call_eq
  function: X_OK.__eq__
  args: [1]
  expected: true
