spec: itertools_extra215
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers exception-raising behavior for itertools functions on bad inputs."
    - "itertools.islice([1,2,3], -1) raises ValueError at construction — Stop argument must be None or non-negative integer. Verified with Python 3.14.3."
    - "itertools.repeat(1, 'bad') raises TypeError — times argument must be an integer. Verified with Python 3.14.3."
    - "itertools.combinations([1,2], -1) raises ValueError at construction — r must be non-negative. Verified with Python 3.14.3."
    - "itertools.permutations([1,2], -1) raises ValueError at construction — r must be non-negative. Verified with Python 3.14.3."
    - "itertools.product(42) raises TypeError — all arguments must be iterables; 42 is not iterable. Verified with Python 3.14.3."
    - "itertools.chain.from_iterable(42) raises TypeError — argument must be iterable; 42 is not iterable. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools.islice — exception on negative stop
#
# itertools.islice(iterable, stop) requires stop to be None or a non-negative
# integer. Passing -1 raises ValueError at object construction time, before
# any iteration occurs.
# Verified: islice([1,2,3], -1) -> ValueError: Stop argument for islice()
# must be None or an integer: 0 <= x <= sys.maxsize.
# ---------------------------------------------------------------------------

table itertools_extra215.islice_bad_stop:
  description: "islice(iterable, -1) raises ValueError — stop must be None or non-negative int; new to extra215"
  kind: python_call_raises
  category: errors
  id_prefix: itertoolsextra215

  columns: [id, function, args, expected, description]
  rows:
    - [islice_negative_stop_raises_ValueError,
       islice,
       "[[1, 2, 3], -1]",
       ValueError,
       "itertools.islice([1,2,3], -1) raises ValueError — islice requires stop to be None or a non-negative integer between 0 and sys.maxsize inclusive; -1 is negative so Python raises ValueError: Stop argument for islice() must be None or an integer: 0 <= x <= sys.maxsize; exception fires at construction time; new to extra215"]

# ---------------------------------------------------------------------------
# itertools.repeat — exception on non-integer times
#
# itertools.repeat(object, times) requires times to be an integer when
# provided. Passing a string raises TypeError immediately at construction.
# Verified: repeat(1, 'bad') -> TypeError: 'str' object cannot be interpreted
# as an integer.
# ---------------------------------------------------------------------------

table itertools_extra215.repeat_bad_times:
  description: "repeat(obj, non-integer) raises TypeError — times arg must be an integer; new to extra215"
  kind: python_call_raises
  category: errors
  id_prefix: itertoolsextra215

  columns: [id, function, args, expected, description]
  rows:
    - [repeat_string_times_raises_TypeError,
       repeat,
       [1, "bad"],
       TypeError,
       "itertools.repeat(1, 'bad') raises TypeError — the optional times argument to repeat() must be an integer specifying how many times the value is repeated; passing the string 'bad' raises TypeError: 'str' object cannot be interpreted as an integer; new to extra215"]

# ---------------------------------------------------------------------------
# itertools.combinations and itertools.permutations — exception on negative r
#
# Both combinations(iterable, r) and permutations(iterable, r) require r to
# be a non-negative integer. Passing r=-1 raises ValueError at construction.
# Verified: combinations([1,2], -1) -> ValueError: r must be non-negative.
# Verified: permutations([1,2], -1) -> ValueError: r must be non-negative.
# ---------------------------------------------------------------------------

table itertools_extra215.combinations_permutations_negative_r:
  description: "combinations/permutations with r=-1 raise ValueError — r must be non-negative; new to extra215"
  kind: python_call_raises
  category: errors
  id_prefix: itertoolsextra215

  columns: [id, function, args, expected, description]
  rows:
    - [combinations_negative_r_raises_ValueError,
       combinations,
       "[[1, 2], -1]",
       ValueError,
       "itertools.combinations([1,2], -1) raises ValueError — the r argument specifies the length of each combination tuple and must be a non-negative integer; -1 is negative so Python raises ValueError: r must be non-negative; exception fires at construction time; new to extra215"]
    - [permutations_negative_r_raises_ValueError,
       permutations,
       "[[1, 2], -1]",
       ValueError,
       "itertools.permutations([1,2], -1) raises ValueError — the r argument specifies the length of each permutation tuple and must be a non-negative integer; -1 is negative so Python raises ValueError: r must be non-negative; exception fires at construction time; new to extra215"]

# ---------------------------------------------------------------------------
# itertools.product — exception on non-iterable argument
#
# itertools.product(*iterables) requires all arguments to be iterable. Passing
# a bare integer raises TypeError at construction because int is not iterable.
# Verified: product(42) -> TypeError: 'int' object is not iterable.
# ---------------------------------------------------------------------------

table itertools_extra215.product_non_iterable:
  description: "product(non-iterable) raises TypeError — all args must be iterable; new to extra215"
  kind: python_call_raises
  category: errors
  id_prefix: itertoolsextra215

  columns: [id, function, args, expected, description]
  rows:
    - [product_int_raises_TypeError,
       product,
       [42],
       TypeError,
       "itertools.product(42) raises TypeError — product() computes the Cartesian product of its arguments; each argument must be iterable; 42 is an int and not iterable so Python raises TypeError: 'int' object is not iterable; exception fires at construction time; new to extra215"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra215
# ---------------------------------------------------------------------------

invariant itertools_extra215.islice_negative_ValueError:
  description: "itertools.islice([1,2,3], -1) raises ValueError — stop must be non-negative; new to extra215"
  kind: python_call_raises
  category: errors
  function: islice
  args: "[[1, 2, 3], -1]"
  expected: ValueError

invariant itertools_extra215.repeat_bad_times_TypeError:
  description: "itertools.repeat(1, 'bad') raises TypeError — times must be an integer; new to extra215"
  kind: python_call_raises
  category: errors
  function: repeat
  args: [1, "bad"]
  expected: TypeError

invariant itertools_extra215.combinations_negative_r_ValueError:
  description: "itertools.combinations([1,2], -1) raises ValueError — r must be non-negative; new to extra215"
  kind: python_call_raises
  category: errors
  function: combinations
  args: "[[1, 2], -1]"
  expected: ValueError

invariant itertools_extra215.permutations_negative_r_ValueError:
  description: "itertools.permutations([1,2], -1) raises ValueError — r must be non-negative; new to extra215"
  kind: python_call_raises
  category: errors
  function: permutations
  args: "[[1, 2], -1]"
  expected: ValueError

invariant itertools_extra215.product_non_iterable_TypeError:
  description: "itertools.product(42) raises TypeError — all arguments must be iterable; new to extra215"
  kind: python_call_raises
  category: errors
  function: product
  args: [42]
  expected: TypeError
