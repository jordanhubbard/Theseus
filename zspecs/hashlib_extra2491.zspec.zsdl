spec: hashlib_extra2491
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Modules/md5module.c"
  notes:
    - "Wave extra2491, theme: __setitem__, __delitem__, and __missing__ dict-presence."
    - "Checks whether the HASH class (type(hashlib.md5())) defines mutable item access or missing-key protocol in its class __dict__."
    - "HASH is the internal C type (module _hashlib, class name HASH) returned by hashlib.md5(), hashlib.sha256(), etc."
    - "HASH is not a mapping type; it has no __setitem__, __delitem__, or __missing__ in its class __dict__."
    - "HASH.__dict__ contains: __doc__, __module__, __repr__, block_size, copy, digest, digest_size, hexdigest, name, update."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HASH class — __setitem__ absent from class __dict__
# hashlib HASH objects are not mutable mappings; they define no item-setting
# protocol at the class level.
# ---------------------------------------------------------------------------

table hashlib_extra2491.HASH_setitem_absent:
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl2491

  columns: [id, function, args, expected]
  rows:
    - ["hl2491001", md5.__class__.__dict__.__contains__, ["__setitem__"], false]
    - ["hl2491002", sha256.__class__.__dict__.__contains__, ["__setitem__"], false]
    - ["hl2491003", sha1.__class__.__dict__.__contains__, ["__setitem__"], false]
    - ["hl2491004", sha512.__class__.__dict__.__contains__, ["__setitem__"], false]

# ---------------------------------------------------------------------------
# HASH class — __delitem__ absent from class __dict__
# Item deletion protocol is also not defined on the HASH class.
# ---------------------------------------------------------------------------

table hashlib_extra2491.HASH_delitem_absent:
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl2491

  columns: [id, function, args, expected]
  rows:
    - ["hl2491005", md5.__class__.__dict__.__contains__, ["__delitem__"], false]
    - ["hl2491006", sha256.__class__.__dict__.__contains__, ["__delitem__"], false]
    - ["hl2491007", sha1.__class__.__dict__.__contains__, ["__delitem__"], false]
    - ["hl2491008", sha512.__class__.__dict__.__contains__, ["__delitem__"], false]

# ---------------------------------------------------------------------------
# HASH class — __missing__ absent from class __dict__
# Missing-key fallback protocol is not defined on the HASH class.
# ---------------------------------------------------------------------------

table hashlib_extra2491.HASH_missing_absent:
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl2491

  columns: [id, function, args, expected]
  rows:
    - ["hl2491009", md5.__class__.__dict__.__contains__, ["__missing__"], false]
    - ["hl2491010", sha256.__class__.__dict__.__contains__, ["__missing__"], false]
    - ["hl2491011", sha1.__class__.__dict__.__contains__, ["__missing__"], false]
    - ["hl2491012", sha512.__class__.__dict__.__contains__, ["__missing__"], false]

# ---------------------------------------------------------------------------
# HASH class — real methods ARE present in __dict__ (positive anchors)
# Verifies that __dict__.__contains__ works correctly for the class:
# the hash API methods copy, digest, hexdigest, and update must be present.
# ---------------------------------------------------------------------------

table hashlib_extra2491.HASH_real_methods_present:
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl2491

  columns: [id, function, args, expected]
  rows:
    - ["hl2491013", md5.__class__.__dict__.__contains__, ["copy"],      true]
    - ["hl2491014", md5.__class__.__dict__.__contains__, ["digest"],    true]
    - ["hl2491015", md5.__class__.__dict__.__contains__, ["hexdigest"], true]
    - ["hl2491016", md5.__class__.__dict__.__contains__, ["update"],    true]
    - ["hl2491017", md5.__class__.__dict__.__contains__, ["block_size"], true]
    - ["hl2491018", md5.__class__.__dict__.__contains__, ["digest_size"], true]
    - ["hl2491019", md5.__class__.__dict__.__contains__, ["name"],      true]
