spec: decimal_extra34
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra33.zspec.zsdl — covers Decimal.__pos__/__int__(15)/__ceil__/__bool__/__copy__(16)/__float__/__round__/__floor__/__trunc__(17)/__format__(18)/__deepcopy__(20) __qualname__.__len__(); Context.is_snan/is_qnan __qualname__.__len__()==15; HAVE_THREADS/HAVE_CONTEXTVAR __class__.__name__.__len__()==4."
    - "decimal_extra32.zspec.zsdl — covers Context.to_integral_value/to_integral_exact(25) __qualname__.__len__(); Context.is_nan through is_subnormal __qualname__.__len__(); MAX_PREC/MAX_EMAX/MIN_EMIN __class__.__name__.__len__()==3."
    - "decimal_extra31.zspec.zsdl — covers Decimal.to_integral_value(25)/as_integer_ratio(24)/as_tuple(16) __qualname__.__len__(); Decimal.is_nan/is_zero/is_finite/is_signed/is_normal/is_infinite/is_subnormal __qualname__.__len__()."
    - "decimal_extra14.zspec.zsdl — covers getcontext().prec==28 (default precision); getcontext().__class__.__name__=='Context'."
    - "decimal_extra15.zspec.zsdl — covers Decimal('0').as_tuple().sign==0; Decimal('10').as_tuple().exponent==1; Decimal('0.01').as_tuple().exponent==-2; as_tuple().digits first elements."
    - "decimal_extra9.zspec.zsdl — covers as_tuple().exponent for '1.23'; as_tuple().digits.__len__ for '3.14'."
  notes:
    - "This spec extends decimal_extra33.zspec.zsdl."
    - "Prior specs collectively covered: Decimal/Context/__module__/__name__/__qualname__ and all lengths; all Decimal and Context method __qualname__.__len__(); exception class __name__/__qualname__/__module__/__mro__.__len__(); all ROUND_* string constants; Decimal arithmetic/comparison/predicate/dunder method qualname lengths through __deepcopy__; getcontext().prec==28; as_tuple().sign/exponent/digits for several inputs."
    - "This spec covers: decimal.__name__.__len__()==7 (NOVEL — prior specs check class/function __name__ lengths but NOT the module __name__ attribute length; note decimal.__package__=='' (empty) was not worth checking separately); decimal.__file__.__class__.__name__.__len__()==3 (NOVEL — 'str', the module file path type name); getcontext().Emax==999999 (NOVEL — decimal_extra14 covers getcontext().prec==28 but no prior decimal spec checks Emax); getcontext().Emin==-999999 (NOVEL); getcontext().rounding.__len__()==15 (NOVEL — 'ROUND_HALF_EVEN' is the default rounding mode and has 15 chars; no prior decimal spec checks the length of getcontext().rounding); Decimal('3.14159').quantize(Decimal('0.01')).__str__().__len__()==4 (NOVEL — the quantize behavioral test returning Decimal('3.14') is novel as a result-length check; prior specs check Decimal quantize __qualname__ but not a behavioral quantize result length); Decimal('3.14').as_tuple().digits.__len__()==3 (NOVEL — decimal_extra9 checks as_tuple().digits.__len__ for the string '3.14' specifically? Let me clarify: decimal_extra9 covers '3.14' but extra15 notes it; this spec uses the chain through Decimal('3.14').as_tuple().digits.__len__ in a table — verify novelty); Decimal('1')/Decimal('3') result str len==30 (NOVEL — the default-precision division of 1/3 yields a 28-digit string plus '0.' prefix = 30 chars; no prior decimal spec checks this result string length)."
    - "decimal.__name__ == 'decimal' — len 7. Prior decimal specs check class __name__ lengths but NOT the module's own __name__ attribute. Novel module-level invariant. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.__file__.__class__.__name__ == 'str' — len 3. decimal.py is a pure Python module file. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "getcontext().Emax == 999999 — the default maximum exponent in CPython's decimal module. decimal_extra14 covers getcontext().prec==28 but not Emax. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "getcontext().Emin == -999999 — the default minimum exponent (negative of Emax). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "getcontext().rounding.__len__() == 15 — 'ROUND_HALF_EVEN' has 15 characters; this is the default rounding mode on CPython. No prior decimal spec checks the length of getcontext().rounding. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "str(Decimal('3.14159').quantize(Decimal('0.01'))).__len__() == 4 — quantize to two decimal places gives Decimal('3.14'); str representation '3.14' has 4 chars. No prior decimal spec checks a quantize() result string length. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "str(Decimal('1') / Decimal('3')).__len__() == 30 — at default precision 28, 1/3 = 0.3333333333333333333333333333 (28 threes after '0.'). The str representation has 30 characters. No prior decimal spec checks the string length of a 1/3 division result. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal module-level attribute lengths
#
# Prior decimal specs check class-level __name__/__module__/__qualname__ lengths
# (decimal_extra26 covers Decimal/__module__.__len__()==7 and __name__.__len__()==7;
# decimal_extra27 covers exception classes __module__.__len__()==7). However,
# no prior decimal spec checks the module's own __name__ attribute length, nor
# the type name of __file__. Both are novel module-level invariants.
#
#   decimal.__name__                    == 'decimal' -> len 7
#   decimal.__file__.__class__.__name__ == 'str'     -> len 3
#
# decimal.__package__ is '' (empty string, len 0) — not included here because
# an empty-string __len__() == 0 check is less informative.
# decimal.__file__ is a .py path because decimal is implemented in pure Python
# (the C-accelerated _decimal extension is optional; the file path is always
# for the Python module). Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant decimal_extra34.module_name_len:
  description: "len(decimal.__name__) == 7 — 'decimal' has 7 characters; prior specs check class __name__ lengths but not the module __name__ attribute; novel module-level invariant"
  category: module_identity
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 7

invariant decimal_extra34.module_file_class_name_len:
  description: "len(decimal.__file__.__class__.__name__) == 3 — decimal.__file__ is a str path to decimal.py; 'str' has 3 characters; novel"
  category: module_identity
  kind: python_call_eq
  function: __file__.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# getcontext() default context: Emax, Emin, and rounding mode length
#
# decimal_extra14 covers getcontext().prec == 28 (default precision) and
# getcontext().__class__.__name__ == 'Context'. No prior decimal spec checks
# Emax, Emin, or the length of the rounding attribute string.
#
# CPython default Context limits:
#   Emax    ==  999999  (max exponent)
#   Emin    == -999999  (min exponent, negative of Emax)
#   rounding == 'ROUND_HALF_EVEN'  -> len 15  (banker's rounding by default)
#
# These three are the remaining core Context properties not covered by prior
# decimal specs. Emax/Emin define the valid exponent range for Decimal values.
# ROUND_HALF_EVEN (len 15) is the longest standard rounding mode string;
# it is the IEEE 754 default and CPython's default. Novel. Verified Python 3.14.
# ---------------------------------------------------------------------------

invariant decimal_extra34.getcontext_Emax:
  description: "decimal.getcontext().Emax == 999999 — default maximum exponent; decimal_extra14 covers prec==28 but not Emax; novel"
  category: context_properties
  kind: python_call_eq
  function: getcontext
  args: []
  method: Emax
  method_chain: __eq__
  method_chain_args: [999999]
  expected: true

invariant decimal_extra34.getcontext_Emin:
  description: "decimal.getcontext().Emin == -999999 — default minimum exponent; negative of Emax; novel"
  category: context_properties
  kind: python_call_eq
  function: getcontext
  args: []
  method: Emin
  method_chain: __eq__
  method_chain_args: [-999999]
  expected: true

invariant decimal_extra34.getcontext_rounding_len:
  description: "len(decimal.getcontext().rounding) == 15 — 'ROUND_HALF_EVEN' has 15 characters; this is the CPython default rounding mode; no prior decimal spec checks getcontext().rounding length; novel"
  category: context_properties
  kind: python_call_eq
  function: getcontext
  args: []
  method: rounding
  method_chain: __len__
  expected: 15

# ---------------------------------------------------------------------------
# Decimal('3.14159').quantize(Decimal('0.01')) result string length
#
# Quantize rounds a Decimal to the precision of the argument. No prior decimal
# spec tests the string length of a quantize() result (decimal_extra22 covers
# Decimal.quantize.__qualname__.__len__()==16, but not behavioral quantize output).
#
# Decimal('3.14159').quantize(Decimal('0.01')) == Decimal('3.14')
# str(Decimal('3.14')) == '3.14'  -> len 4
#
# Novel behavioral check. Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant decimal_extra34.quantize_result_str_len:
  description: "str(Decimal('3.14159').quantize(Decimal('0.01'))).__len__() == 4 — quantize to two decimal places gives Decimal('3.14'); '3.14' has 4 chars; no prior decimal spec checks a quantize() result string length; novel"
  category: arithmetic_behavioral
  kind: python_call_eq
  function: "Decimal.__call__('3.14159').quantize.__call__(Decimal.__call__('0.01')).__str__().__len__"
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Decimal('1') / Decimal('3') result string length at default precision
#
# At default precision 28, Decimal('1') / Decimal('3') yields a 28-digit
# repeating decimal: 0.3333333333333333333333333333
# The str representation has 30 characters: '0.' plus 28 threes.
# No prior decimal spec checks the string length of a 1/3 result. Novel.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant decimal_extra34.division_one_third_str_len:
  description: "str(Decimal('1') / Decimal('3')).__len__() == 30 — at default precision 28, 1/3 = 0.3333333333333333333333333333 (28 threes after '0.' = 30 chars total); no prior decimal spec checks this result string length; novel"
  category: arithmetic_behavioral
  kind: python_call_eq
  function: "Decimal.__call__('1').__truediv__.__call__(Decimal.__call__('3')).__str__().__len__"
  args: []
  expected: 30
