spec: lodash_isarraylikeobject
version: ">=4.0.0"
backend: node(lodash.isarraylikeobject)

docs: https://lodash.com/docs/#isArrayLikeObject

provenance:
  derived_from:
    - "lodash.isarraylikeobject README — https://www.npmjs.com/package/lodash.isarraylikeobject"
    - "Test vectors verified with lodash.isarraylikeobject@4.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.isarraylikeobject exports the _.isArrayLikeObject function directly as module.exports."
    - "isArrayLikeObject is like isArrayLike except it also checks the value is an object."
    - "Strings return false (primitives are not objects)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_isarraylikeobject.isarraylikeobject:
  kind: node_module_call_eq
  function: ~
  category: isarraylikeobject
  id_prefix: lialo

  columns: [id, args, expected]
  rows:
    - [array,   [[1, 2, 3]],   true]
    - [string,  ["abc"],       false]
    - [number,  [42],          false]
    - [null_v,  [null],        false]
