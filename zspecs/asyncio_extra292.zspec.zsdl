spec: asyncio_extra292
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives and queue exception documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "asyncio.Queue.__bases__[0].__name__ == '_LoopBoundMixin' (not object) — Queue mixes in loop binding behavior"
    - "asyncio.QueueEmpty and asyncio.QueueFull both inherit directly from Exception"
    - "asyncio.Semaphore, BoundedSemaphore, Event, Condition are all in asyncio.locks submodule"
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table asyncio_extra292.queue_class_identity:
  description: "asyncio.Queue, QueueEmpty, QueueFull class name, module, and base class identity"
  kind: python_call_eq
  category: identity
  id_prefix: asyncio292a

  columns: [id, function, args, expected, description]
  rows:
    - [asyncio292a001, asyncio.Queue.__name__.__eq__, ["Queue"], true, "Queue.__name__ is 'Queue'"]
    - [asyncio292a002, asyncio.Queue.__module__.__eq__, ["asyncio.queues"], true, "Queue.__module__ is 'asyncio.queues'"]
    - [asyncio292a003, "asyncio.Queue.__bases__[0].__name__.__eq__", ["_LoopBoundMixin"], true, "Queue base class is _LoopBoundMixin"]
    - [asyncio292a004, asyncio.QueueEmpty.__name__.__eq__, ["QueueEmpty"], true, "QueueEmpty.__name__ is 'QueueEmpty'"]
    - [asyncio292a005, asyncio.QueueEmpty.__module__.__eq__, ["asyncio.queues"], true, "QueueEmpty.__module__ is 'asyncio.queues'"]
    - [asyncio292a006, "asyncio.QueueEmpty.__bases__[0].__name__.__eq__", ["Exception"], true, "QueueEmpty base class is Exception"]
    - [asyncio292a007, asyncio.QueueFull.__name__.__eq__, ["QueueFull"], true, "QueueFull.__name__ is 'QueueFull'"]
    - [asyncio292a008, asyncio.QueueFull.__module__.__eq__, ["asyncio.queues"], true, "QueueFull.__module__ is 'asyncio.queues'"]
    - [asyncio292a009, "asyncio.QueueFull.__bases__[0].__name__.__eq__", ["Exception"], true, "QueueFull base class is Exception"]

table asyncio_extra292.sync_primitives_identity:
  description: "asyncio Semaphore, BoundedSemaphore, Event, Condition class name and module identity"
  kind: python_call_eq
  category: identity
  id_prefix: asyncio292b

  columns: [id, function, args, expected, description]
  rows:
    - [asyncio292b001, asyncio.Semaphore.__name__.__eq__, ["Semaphore"], true, "Semaphore.__name__ is 'Semaphore'"]
    - [asyncio292b002, asyncio.Semaphore.__module__.__eq__, ["asyncio.locks"], true, "Semaphore.__module__ is 'asyncio.locks'"]
    - [asyncio292b003, asyncio.BoundedSemaphore.__name__.__eq__, ["BoundedSemaphore"], true, "BoundedSemaphore.__name__ is 'BoundedSemaphore'"]
    - [asyncio292b004, asyncio.BoundedSemaphore.__module__.__eq__, ["asyncio.locks"], true, "BoundedSemaphore.__module__ is 'asyncio.locks'"]
    - [asyncio292b005, asyncio.Event.__name__.__eq__, ["Event"], true, "Event.__name__ is 'Event'"]
    - [asyncio292b006, asyncio.Event.__module__.__eq__, ["asyncio.locks"], true, "Event.__module__ is 'asyncio.locks'"]
    - [asyncio292b007, asyncio.Condition.__name__.__eq__, ["Condition"], true, "Condition.__name__ is 'Condition'"]
    - [asyncio292b008, asyncio.Condition.__module__.__eq__, ["asyncio.locks"], true, "Condition.__module__ is 'asyncio.locks'"]

invariant asyncio_extra292.queue_module:
  description: "asyncio.Queue.__module__ is 'asyncio.queues'"
  category: identity
  kind: python_call_eq
  function: asyncio.Queue.__module__.__eq__
  args: ["asyncio.queues"]
  expected: true

invariant asyncio_extra292.queue_base_is_loop_bound_mixin:
  description: "asyncio.Queue.__bases__[0].__name__ is '_LoopBoundMixin', not 'object'"
  category: identity
  kind: python_call_eq
  function: "asyncio.Queue.__bases__[0].__name__.__eq__"
  args: ["_LoopBoundMixin"]
  expected: true

invariant asyncio_extra292.queue_empty_base_is_exception:
  description: "asyncio.QueueEmpty inherits directly from Exception"
  category: identity
  kind: python_call_eq
  function: "asyncio.QueueEmpty.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant asyncio_extra292.queue_full_base_is_exception:
  description: "asyncio.QueueFull inherits directly from Exception"
  category: identity
  kind: python_call_eq
  function: "asyncio.QueueFull.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true
