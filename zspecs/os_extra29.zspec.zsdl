spec: os_extra29
version: ">=3.9"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
    - "os_extra8.zspec.zsdl — covers __qualname__ equality for getpid/getuid/urandom/cpu_count"
    - "os_extra18.zspec.zsdl — covers getuid.__qualname__ equality standalone"
    - "os_extra20.zspec.zsdl — covers putenv.__qualname__ equality in table"
    - "os_extra27.zspec.zsdl — covers qualname lengths for getcwd/listdir/makedirs/remove/walk/rename"
    - "os_extra28.zspec.zsdl — covers qualname lengths for getenv/mkdir/rmdir/stat"
  notes:
    - "This spec extends os.zspec.zsdl and all prior os_extra specs through os_extra28.zspec.zsdl."
    - "Focus: __qualname__ string lengths for getpid/getppid/getuid/cpu_count/putenv/urandom — not covered as standalone length invariants in any prior os spec."
    - "os.getppid.__qualname__ == 'getppid' — not covered as qualname equality in any prior os spec (extra15 covers return type/module only)."
    - "os.getpid.__qualname__.__len__() == 6 — 'getpid' has 6 characters; qualname equality covered in extra8 but length not yet covered."
    - "os.getppid.__qualname__.__len__() == 7 — 'getppid' has 7 characters; no prior os spec covers getppid qualname at all."
    - "os.getuid.__qualname__.__len__() == 6 — 'getuid' has 6 characters; qualname equality covered in extra8/18 but length not yet covered."
    - "os.cpu_count.__qualname__.__len__() == 9 — 'cpu_count' has 9 characters; qualname equality covered in extra8 but length not yet covered."
    - "os.putenv.__qualname__.__len__() == 6 — 'putenv' has 6 characters; qualname equality covered in extra20 but length not yet covered."
    - "os.urandom.__qualname__.__len__() == 7 — 'urandom' has 7 characters; qualname equality covered in extra8 but length not yet covered."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# getppid __qualname__ equality — new coverage in extra29 namespace
#
# os.getppid.__qualname__ == 'getppid'. os_extra15 covers getppid return type
# and __module__ but not __qualname__. No prior os spec covers getppid in any
# __qualname__ context. This is the first coverage of getppid.__qualname__.
# ---------------------------------------------------------------------------

invariant os_extra29.getppid.qualname:
  description: "os.getppid.__qualname__ == 'getppid' — qualname equals bare function name"
  category: function_identity
  kind: python_call_eq
  function: getppid.__qualname__.__eq__
  args: ["getppid"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ length table — getpid, getppid, getuid, cpu_count, putenv, urandom
#
# os_extra8 covers qualname equality for getpid/getuid/urandom/cpu_count.
# os_extra20 covers putenv qualname equality in a table.
# No prior os spec covers the __len__() of any of these qualname strings.
# This table anchors qualname-length facts for six POSIX-level os functions.
# ---------------------------------------------------------------------------

table os_extra29.qualname_lengths:
  description: "__qualname__ string length for POSIX os functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: qlen29

  columns: [id, function, args, expected]
  rows:
    - [getpid,     getpid.__qualname__.__len__,     [], 6]
    - [getppid,    getppid.__qualname__.__len__,    [], 7]
    - [getuid,     getuid.__qualname__.__len__,     [], 6]
    - [cpu_count,  cpu_count.__qualname__.__len__,  [], 9]
    - [putenv,     putenv.__qualname__.__len__,     [], 6]
    - [urandom,    urandom.__qualname__.__len__,    [], 7]

# ---------------------------------------------------------------------------
# Standalone qualname length invariants
# ---------------------------------------------------------------------------

invariant os_extra29.getpid.qualname_length:
  description: "os.getpid.__qualname__.__len__() == 6 — 'getpid' has 6 characters"
  category: function_identity
  kind: python_call_eq
  function: getpid.__qualname__.__len__
  args: []
  expected: 6

invariant os_extra29.getppid.qualname_length:
  description: "os.getppid.__qualname__.__len__() == 7 — 'getppid' has 7 characters"
  category: function_identity
  kind: python_call_eq
  function: getppid.__qualname__.__len__
  args: []
  expected: 7

invariant os_extra29.getuid.qualname_length:
  description: "os.getuid.__qualname__.__len__() == 6 — 'getuid' has 6 characters"
  category: function_identity
  kind: python_call_eq
  function: getuid.__qualname__.__len__
  args: []
  expected: 6

invariant os_extra29.cpu_count.qualname_length:
  description: "os.cpu_count.__qualname__.__len__() == 9 — 'cpu_count' has 9 characters"
  category: function_identity
  kind: python_call_eq
  function: cpu_count.__qualname__.__len__
  args: []
  expected: 9

invariant os_extra29.putenv.qualname_length:
  description: "os.putenv.__qualname__.__len__() == 6 — 'putenv' has 6 characters"
  category: function_identity
  kind: python_call_eq
  function: putenv.__qualname__.__len__
  args: []
  expected: 6

invariant os_extra29.urandom.qualname_length:
  description: "os.urandom.__qualname__.__len__() == 7 — 'urandom' has 7 characters"
  category: function_identity
  kind: python_call_eq
  function: urandom.__qualname__.__len__
  args: []
  expected: 7
