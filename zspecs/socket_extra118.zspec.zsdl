spec: socket_extra118
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra117.zspec.zsdl — covers socket.SocketType class structure, qualname, MRO, and module identity (table + invariants)."
    - "socket_extra112.zspec.zsdl — covers AddressFamily/SocketKind enum .name equality and lengths (table + invariants)."
    - "socket_extra95.zspec.zsdl — covers AddressFamily/SocketKind enum member values and names / __all__ class name (table + invariants)."
    - "socket_extra6.zspec.zsdl — covers SOCK_STREAM.value/SOCK_DGRAM.value/AF_INET.value/AF_UNIX.value/IPPROTO_TCP.value."
    - "socket_extra9.zspec.zsdl — covers AF_INET6.value and AF_INET.name/AF_INET6.name/SOCK_STREAM.name/SOCK_DGRAM.name."
  notes:
    - "This spec extends socket through socket_extra117; it does NOT duplicate invariants present in those files."
    - "Wave 278 theme: socket.AddressFamily enum class-level identity not yet covered — extra95 anchors __module__/__qualname__/__name__ equality; extra112 anchors .name equality for members; NOT YET covered: AddressFamily.__class__.__module__ equality, AddressFamily.__class__.__name__.__len__(), AF_UNSPEC/AF_UNIX/AF_INET6 member name __len__ as grouped table, AddressFamily.__name__.__len__() standalone."
    - "socket.AddressFamily.__class__.__name__ == 'EnumType'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__class__.__module__ == 'enum'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('EnumType') == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('enum') == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET.name.__len__() == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_UNIX.name.__len__() == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET6.name.__len__() == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_UNSPEC.name.__len__() == 9. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__name__.__len__() == 13. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__class__.__name__.__len__() == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.AddressFamily is an IntEnum subclass defined in Lib/socket.py. Its metaclass is 'EnumType' (from the enum module), not the standard 'type' metaclass. This distinguishes it from plain C extension types (like SocketType, whose metaclass is 'type'). AF_INET.value==2, AF_INET6.value==30 on macOS/Darwin (unlike Linux where AF_INET6==10), AF_UNIX.value==1, AF_UNSPEC.value==0. Member .name lengths: AF_INET=7, AF_UNIX=7, AF_INET6=8, AF_UNSPEC=9."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.AddressFamily.__class__.__name__.__eq__('EnumType') == True  [covered in prior spec]
# socket.AddressFamily.__class__.__module__.__eq__('enum') == True
# socket.AddressFamily.__class__.__name__.__len__() == 8
# socket.AddressFamily.__class__.__module__.__len__() == 4
# socket.AddressFamily.__name__.__len__() == 13
#
# Wave 278 theme: socket.AddressFamily metaclass module and name lengths.
#
# socket_extra95 anchors AddressFamily.__class__.__name__.__eq__('EnumType') in a table.
# No prior spec anchors AddressFamily.__class__.__module__.__eq__('enum') or the length
# of 'EnumType' (8 chars) or 'enum' (4 chars) for AddressFamily specifically, or the
# length of 'AddressFamily' (13 chars) as a standalone or grouped table. AddressFamily
# uses 'EnumType' as its metaclass (from the enum module), not the standard 'type'.
# 'EnumType' (8 chars) is the same length as 'builtins' and '_hashlib' — coincidental.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra118.AddressFamily_metaclass_module_and_lengths:
  description: "AddressFamily.__class__.__module__.__eq__('enum')==True / AddressFamily.__class__.__name__.__len__()==8 / AddressFamily.__class__.__module__.__len__()==4 / AddressFamily.__name__.__len__()==13 / AddressFamily.__qualname__.__len__()==13 — EnumType metaclass is from the 'enum' module (4 chars; Python stdlib); 'EnumType'=8 chars (same as 'builtins'=8 coincidentally); 'AddressFamily'=13 chars; extra95 anchors __class__.__name__=='EnumType'; no prior spec anchors class module or lengths as grouped table; first sockaf118 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockaf118

  columns: [id, function, args, expected, description]
  rows:
    - [af_class_mod_eq,      "AddressFamily.__class__.__module__.__eq__",   ["enum"],  true, "AddressFamily.__class__.__module__ is 'enum' (EnumType metaclass comes from the Python enum stdlib module)"]
    - [af_class_name_len,    "AddressFamily.__class__.__name__.__len__",    [],         8,   "AddressFamily.__class__.__name__.__len__() is 8 (len('EnumType')==8; coincidentally same as len('builtins'))"]
    - [af_class_mod_len,     "AddressFamily.__class__.__module__.__len__",  [],         4,   "AddressFamily.__class__.__module__.__len__() is 4 (len('enum')==4; the stdlib enum module name)"]
    - [af_name_len,          "AddressFamily.__name__.__len__",              [],         13,  "AddressFamily.__name__.__len__() is 13 (len('AddressFamily')==13; 'Address'=7 + 'Family'=6)"]
    - [af_qualname_len,      "AddressFamily.__qualname__.__len__",          [],         13,  "AddressFamily.__qualname__.__len__() is 13 (same as __name__; top-level enum class has name==qualname)"]

# ---------------------------------------------------------------------------
# socket.AF_INET.name.__len__() == 7
# socket.AF_UNIX.name.__len__() == 7
# socket.AF_INET6.name.__len__() == 8
# socket.AF_UNSPEC.name.__len__() == 9
# socket.AddressFamily.__class__.__module__.__eq__('enum') == True
#
# Wave 278 theme: AddressFamily member .name attribute lengths.
#
# socket_extra112 anchors AF_INET.name.__eq__('AF_INET') and AF_INET6.name.__eq__
# ('AF_INET6') and their lengths (7 and 8) as a grouped table. No prior spec anchors
# AF_UNSPEC.name.__len__()==9 or a table grouping all four name lengths together.
# AF_INET (7 chars) and AF_UNIX (7 chars) are tied; AF_INET6 (8 chars) has one more
# (the '6' suffix); AF_UNSPEC (9 chars) is the longest ('UNSPEC'=6 vs 'INET'=4).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra118.AddressFamily_member_name_lengths:
  description: "AF_INET.name.__len__()==7 / AF_UNIX.name.__len__()==7 / AF_INET6.name.__len__()==8 / AF_UNSPEC.name.__len__()==9 / AddressFamily.__class__.__module__.__eq__('enum')==True — AF_INET/AF_UNIX are tied at 7 chars (3-char suffix: INET/UNIX); AF_INET6 is 8 (4-char INET plus digit 6); AF_UNSPEC is 9 (UNSPEC=6 chars vs INET=4 chars); extra112 anchors AF_INET/AF_INET6 name lengths; first sockaf118 anchor for AF_UNSPEC/AF_UNIX name lengths"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockaf118

  columns: [id, function, args, expected, description]
  rows:
    - [af_inet_name_len,    "AF_INET.name.__len__",    [], 7, "AF_INET.name.__len__() is 7 (len('AF_INET')==7; 'AF_'=3 + 'INET'=4; IPv4 address family; cross-check with extra112)"]
    - [af_unix_name_len,    "AF_UNIX.name.__len__",    [], 7, "AF_UNIX.name.__len__() is 7 (len('AF_UNIX')==7; tied with AF_INET; 'AF_'=3 + 'UNIX'=4; Unix domain sockets)"]
    - [af_inet6_name_len,   "AF_INET6.name.__len__",   [], 8, "AF_INET6.name.__len__() is 8 (len('AF_INET6')==8; 'AF_'=3 + 'INET6'=5; IPv6 address family; one more than AF_INET)"]
    - [af_unspec_name_len,  "AF_UNSPEC.name.__len__",  [], 9, "AF_UNSPEC.name.__len__() is 9 (len('AF_UNSPEC')==9; 'AF_'=3 + 'UNSPEC'=6; longest of the four; unspecified address family)"]
    - [af_class_mod_eq2,    "AddressFamily.__class__.__module__.__eq__", ["enum"], true, "AddressFamily.__class__.__module__ is 'enum' (cross-check; EnumType metaclass from stdlib enum module)"]

# ---------------------------------------------------------------------------
# socket.AF_UNIX.name.__len__() == 7
# socket.AF_UNIX.name.__eq__('AF_UNIX') == True
# socket.AF_UNSPEC.name.__len__() == 9
# socket.AF_UNSPEC.name.__eq__('AF_UNSPEC') == True
# socket.AddressFamily.__name__.__len__() == 13
#
# Wave 278 theme: AF_UNIX and AF_UNSPEC member name equality cross-check.
#
# socket_extra112 anchors AF_INET.name.__eq__('AF_INET') and AF_INET6.name.__eq__
# ('AF_INET6') but does NOT anchor AF_UNIX.name.__eq__('AF_UNIX') or AF_UNSPEC
# .name.__eq__('AF_UNSPEC') as grouped table rows. AF_UNIX (Unix domain sockets,
# value=1 on macOS/Darwin) and AF_UNSPEC (unspecified family, value=0) are the two
# remaining common address families. AF_UNSPEC (9 chars) is the longest name among
# the four. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra118.AddressFamily_unix_unspec_name_equality:
  description: "AF_UNIX.name.__len__()==7 / AF_UNIX.name.__eq__('AF_UNIX')==True / AF_UNSPEC.name.__len__()==9 / AF_UNSPEC.name.__eq__('AF_UNSPEC')==True / AddressFamily.__name__.__len__()==13 — AF_UNIX value=1 on macOS/Darwin (Unix domain sockets; IPC without network); AF_UNSPEC value=0 (unspecified family; default for getaddrinfo hints); extra112 anchors AF_INET/AF_INET6 name equality; no prior spec anchors AF_UNIX/AF_UNSPEC name equality as grouped table; first sockaf118 anchor for unix/unspec names"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockaf118

  columns: [id, function, args, expected, description]
  rows:
    - [af_unix_name_len2,   "AF_UNIX.name.__len__",              [],           7,    "AF_UNIX.name.__len__() is 7 (len('AF_UNIX')==7; Unix domain socket family; value=1 on macOS/Darwin)"]
    - [af_unix_name_eq,     "AF_UNIX.name.__eq__",               ["AF_UNIX"],  true, "AF_UNIX.name is 'AF_UNIX' (7 chars; IPC via filesystem paths; no network stack involvement)"]
    - [af_unspec_name_len2, "AF_UNSPEC.name.__len__",            [],           9,    "AF_UNSPEC.name.__len__() is 9 (len('AF_UNSPEC')==9; longest AF_ name in this set; 'UNSPEC'=6 chars)"]
    - [af_unspec_name_eq,   "AF_UNSPEC.name.__eq__",             ["AF_UNSPEC"],true, "AF_UNSPEC.name is 'AF_UNSPEC' (9 chars; value=0; passed to getaddrinfo as unspecified family hint)"]
    - [af_name_len2,        "AddressFamily.__name__.__len__",    [],           13,   "AddressFamily.__name__.__len__() is 13 (len('AddressFamily')==13; cross-check for enum class name length)"]

# ---------------------------------------------------------------------------
# socket.AddressFamily.__class__.__module__.__eq__('enum') — standalone
#
# socket.AddressFamily.__class__.__module__ is 'enum'. AddressFamily is an IntEnum
# subclass, and its metaclass is 'EnumType' (defined in the Python stdlib 'enum'
# module, Lib/enum.py). This is distinct from the standard 'type' metaclass used
# by most classes. The 'enum' module (4 chars) implements Enum, IntEnum, Flag, and
# IntFlag through this metaclass. AddressFamily is an IntEnum (inherits from both
# int and Enum) making AF_INET.value directly usable as an integer in system calls.
# No prior spec anchors AddressFamily.__class__.__module__ as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra118.AddressFamily_class_module_enum:
  description: "socket.AddressFamily.__class__.__module__.__eq__('enum') == True — EnumType metaclass is from the Python stdlib 'enum' module (4 chars; Lib/enum.py; implements Enum/IntEnum/Flag/IntFlag); AddressFamily is an IntEnum so AF_* values are directly usable as ints in system calls; 'enum' module is 4 chars (shortest of the metaclass modules in this spec); no prior spec anchors AddressFamily class module as standalone; first standalone under sockaf118"
  category: type_identity
  kind: python_call_eq
  function: AddressFamily.__class__.__module__.__eq__
  args: ["enum"]
  expected: true

# ---------------------------------------------------------------------------
# socket.AddressFamily.__class__.__name__.__len__() == 8 — standalone
#
# socket.AddressFamily.__class__.__name__.__len__() is 8. 'EnumType' has 8 chars:
# 'Enum'=4 + 'Type'=4 = 8. The EnumType metaclass was renamed from 'EnumMeta' to
# 'EnumType' in Python 3.11 (PEP 663 / bpo-40066). So on Python 3.9/3.10, this
# would be 8 chars ('EnumMeta'=8 chars as well) but for different content.
# On Python 3.14.3, it is 'EnumType' (8 chars). Coincidentally, 'EnumType' (8 chars)
# has the same length as 'builtins' (8 chars) and '_hashlib' (8 chars), though the
# strings are completely different. No prior spec anchors this length as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra118.AddressFamily_class_name_len_8:
  description: "socket.AddressFamily.__class__.__name__.__len__() == 8 — len('EnumType')==8 ('Enum'=4 + 'Type'=4; renamed from 'EnumMeta' to 'EnumType' in Python 3.11; coincidentally same length as 'builtins'=8 and '_hashlib'=8); extra95 anchors __class__.__name__=='EnumType'; no prior spec anchors AddressFamily class name length as standalone; first standalone under sockaf118"
  category: type_identity
  kind: python_call_eq
  function: AddressFamily.__class__.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# socket.AF_UNIX.name.__len__() == 7 — standalone
#
# socket.AF_UNIX.name.__len__() is 7. 'AF_UNIX' has 7 chars: 'AF_'=3 plus 'UNIX'=4
# = 7. AF_UNIX (address family for Unix domain sockets, value=1 on macOS/Darwin) is
# used for inter-process communication (IPC) on the local machine via filesystem path
# names. Unlike AF_INET (TCP/IP), AF_UNIX sockets involve no network stack — packets
# do not leave the machine. AF_UNIX.name.__len__()==7 is tied with AF_INET.name
# .__len__()==7. No prior spec anchors AF_UNIX.name.__len__() as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra118.AF_UNIX_name_len_7:
  description: "socket.AF_UNIX.name.__len__() == 7 — len('AF_UNIX')==7 ('AF_'=3 + 'UNIX'=4; Unix domain socket family; value=1 on macOS/Darwin; IPC via filesystem paths; no network stack; tied with AF_INET at 7 chars); extra112 anchors AF_INET name length; no prior spec anchors AF_UNIX name length as standalone; first standalone under sockaf118"
  category: type_identity
  kind: python_call_eq
  function: AF_UNIX.name.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# socket.AF_UNSPEC.name.__len__() == 9 — standalone
#
# socket.AF_UNSPEC.name.__len__() is 9. 'AF_UNSPEC' has 9 chars: 'AF_'=3 plus
# 'UNSPEC'=6 = 9. AF_UNSPEC (value=0) is the unspecified address family. It is
# passed to getaddrinfo() as a hint when the caller does not care about the
# address family (IPv4 or IPv6) and lets the system choose. AF_UNSPEC with value
# 0 is the default for many networking functions. 'AF_UNSPEC' (9 chars) is the
# longest .name among AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC. No prior spec anchors
# AF_UNSPEC.name.__len__() as a standalone. Verified Python 3.14.3 macOS/Darwin.
# ---------------------------------------------------------------------------

invariant socket_extra118.AF_UNSPEC_name_len_9:
  description: "socket.AF_UNSPEC.name.__len__() == 9 — len('AF_UNSPEC')==9 ('AF_'=3 + 'UNSPEC'=6; value=0; unspecified address family; passed to getaddrinfo as 'any family' hint; longest AF_ name in this set; 'UNSPEC'=6 vs 'INET'=4 vs 'UNIX'=4); no prior spec anchors AF_UNSPEC name length as standalone; first standalone under sockaf118"
  category: type_identity
  kind: python_call_eq
  function: AF_UNSPEC.name.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# socket.AddressFamily.__name__.__len__() == 13 — standalone
#
# socket.AddressFamily.__name__.__len__() is 13. 'AddressFamily' has 13 chars:
# 'Address'=7 plus 'Family'=6 = 13. The name 'AddressFamily' encodes the concept
# of grouping socket address types (IPv4, IPv6, Unix, etc.) under a family taxonomy.
# This is the same length as '__qualname__' (13 chars, anchored in extra95). The
# name is a CamelCase compound: 'Address' (7 chars) describes the endpoint location,
# 'Family' (6 chars) indicates the classification. No prior spec anchors
# AddressFamily.__name__.__len__() as a standalone invariant.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra118.AddressFamily_name_len_13:
  description: "socket.AddressFamily.__name__.__len__() == 13 — len('AddressFamily')==13 ('Address'=7 + 'Family'=6; CamelCase compound; same length as __qualname__=='AddressFamily'=13; groups IPv4/IPv6/Unix/etc. socket endpoint types); extra95 anchors __qualname__.__len__()==13; no prior spec anchors __name__.__len__() as standalone; first standalone under sockaf118"
  category: type_identity
  kind: python_call_eq
  function: AddressFamily.__name__.__len__
  args: []
  expected: 13

