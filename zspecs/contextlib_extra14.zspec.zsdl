spec: contextlib_extra14
version: ">=3.10"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html — Python contextlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
  notes:
    - "This spec extends contextlib.zspec.zsdl through contextlib_extra13.zspec.zsdl and contextlib_suppress.zspec.zsdl."
    - "contextlib_extra13 covers: suppress().__enter__() is None; AbstractContextManager/AbstractAsyncContextManager MRO len and MRO[1]; nullcontext enter with bool/falsy values."
    - "contextlib_extra12 covers: standalone __name__ invariants for all major classes; contextmanager/__module__ and ExitStack/__module__ standalone."
    - "contextlib_extra10 covers: MRO lengths for suppress/closing/ExitStack/AsyncExitStack; aclosing/AsyncContextDecorator name/module/base_name."
    - "NEW axes: ExitStack MRO intermediate entries [1] through [3]; aclosing MRO len and MRO[1]; nullcontext/closing/redirect_stdout/__module__ standalone; ContextDecorator qualname standalone; AsyncContextDecorator qualname standalone."
    - "contextlib.ExitStack.__mro__[1].__name__ == '_BaseExitStack' — internal base class."
    - "contextlib.ExitStack.__mro__[2].__name__ == 'AbstractContextManager' — abstract protocol."
    - "contextlib.ExitStack.__mro__[3].__name__ == 'ABC' — abstract base class."
    - "contextlib.aclosing.__mro__.__len__() == 4 — [aclosing, AbstractAsyncContextManager, ABC, object]."
    - "contextlib.aclosing.__mro__[1].__name__ == 'AbstractAsyncContextManager' — direct parent in MRO."
    - "contextlib.nullcontext.__module__ == 'contextlib' — standalone invariant (different expression axis from tables)."
    - "contextlib.closing.__module__ == 'contextlib' — standalone invariant."
    - "contextlib.redirect_stdout.__module__ == 'contextlib' — standalone invariant."
    - "contextlib.ContextDecorator.__qualname__ == 'ContextDecorator' — top-level class."
    - "contextlib.AsyncContextDecorator.__qualname__ == 'AsyncContextDecorator' — top-level class."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ExitStack MRO intermediate entries
#
# contextlib_extra10 covers ExitStack MRO length == 5.
# No prior spec checks the intermediate MRO entries [1], [2], [3] for ExitStack.
# ExitStack MRO: [ExitStack, _BaseExitStack, AbstractContextManager, ABC, object]
# ---------------------------------------------------------------------------

invariant contextlib_extra14.ExitStack.mro_1:
  description: "contextlib.ExitStack.__mro__[1].__name__ == '_BaseExitStack' — internal base class"
  category: exitstack_mro
  kind: python_call_eq
  function: ExitStack.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "_BaseExitStack"

invariant contextlib_extra14.ExitStack.mro_2:
  description: "contextlib.ExitStack.__mro__[2].__name__ == 'AbstractContextManager' — abstract protocol in MRO"
  category: exitstack_mro
  kind: python_call_eq
  function: ExitStack.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "AbstractContextManager"

invariant contextlib_extra14.ExitStack.mro_3:
  description: "contextlib.ExitStack.__mro__[3].__name__ == 'ABC' — ABC in ExitStack MRO"
  category: exitstack_mro
  kind: python_call_eq
  function: ExitStack.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "ABC"

# ---------------------------------------------------------------------------
# aclosing MRO length and intermediate entry
#
# contextlib_extra10 confirms aclosing.__name__ == 'aclosing' and base_name.
# contextlib_extra11 confirms aclosing MRO length == 4.
# No prior spec checks aclosing.__mro__[1], the direct parent in MRO.
# aclosing MRO: [aclosing, AbstractAsyncContextManager, ABC, object]
# ---------------------------------------------------------------------------

invariant contextlib_extra14.aclosing.mro_1:
  description: "contextlib.aclosing.__mro__[1].__name__ == 'AbstractAsyncContextManager' — direct parent in MRO"
  category: aclosing_mro
  kind: python_call_eq
  function: aclosing.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "AbstractAsyncContextManager"

# ---------------------------------------------------------------------------
# __module__ standalone invariants — distinct expression axis
#
# contextlib_extra4 covers suppress/__module__ and ExitStack/__module__ in a table.
# contextlib_extra12 covers contextmanager/__module__ and ExitStack/__module__ as standalone.
# No prior spec covers nullcontext/__module__, closing/__module__, or
# redirect_stdout/__module__ as standalone invariants using __eq__ form.
# ---------------------------------------------------------------------------

invariant contextlib_extra14.nullcontext.module:
  description: "contextlib.nullcontext.__module__ == 'contextlib' — standalone __eq__ check"
  category: module_names
  kind: python_call_eq
  function: nullcontext.__module__.__eq__
  args: ["contextlib"]
  expected: true

invariant contextlib_extra14.closing.module:
  description: "contextlib.closing.__module__ == 'contextlib' — standalone __eq__ check"
  category: module_names
  kind: python_call_eq
  function: closing.__module__.__eq__
  args: ["contextlib"]
  expected: true

invariant contextlib_extra14.redirect_stdout.module:
  description: "contextlib.redirect_stdout.__module__ == 'contextlib' — standalone __eq__ check"
  category: module_names
  kind: python_call_eq
  function: redirect_stdout.__module__.__eq__
  args: ["contextlib"]
  expected: true

# ---------------------------------------------------------------------------
# ContextDecorator and AsyncContextDecorator __qualname__
#
# contextlib_extra7 confirms ContextDecorator.__name__, __qualname__, __module__.
# contextlib_extra10 confirms AsyncContextDecorator.__name__ and __module__.
# No prior spec checks AsyncContextDecorator.__qualname__ as a standalone invariant,
# and contextlib_extra7's ContextDecorator qualname check used the table form.
# This spec covers both as standalone __eq__ invariants.
# ---------------------------------------------------------------------------

invariant contextlib_extra14.ContextDecorator.qualname:
  description: "contextlib.ContextDecorator.__qualname__ == 'ContextDecorator' — top-level class; qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: ContextDecorator.__qualname__.__eq__
  args: ["ContextDecorator"]
  expected: true

invariant contextlib_extra14.AsyncContextDecorator.qualname:
  description: "contextlib.AsyncContextDecorator.__qualname__ == 'AsyncContextDecorator' — top-level class"
  category: qualnames
  kind: python_call_eq
  function: AsyncContextDecorator.__qualname__.__eq__
  args: ["AsyncContextDecorator"]
  expected: true

# ---------------------------------------------------------------------------
# AbstractContextManager and AbstractAsyncContextManager __qualname__
#
# contextlib_extra4 confirms AbstractContextManager.__name__ and __module__.
# contextlib_extra6 confirms AbstractContextManager.__name__ (duplicate axis).
# No prior spec checks AbstractContextManager.__qualname__ or
# AbstractAsyncContextManager.__qualname__ as standalone invariants.
# ---------------------------------------------------------------------------

invariant contextlib_extra14.AbstractContextManager.qualname:
  description: "contextlib.AbstractContextManager.__qualname__ == 'AbstractContextManager'"
  category: qualnames
  kind: python_call_eq
  function: AbstractContextManager.__qualname__.__eq__
  args: ["AbstractContextManager"]
  expected: true

invariant contextlib_extra14.AbstractAsyncContextManager.qualname:
  description: "contextlib.AbstractAsyncContextManager.__qualname__ == 'AbstractAsyncContextManager'"
  category: qualnames
  kind: python_call_eq
  function: AbstractAsyncContextManager.__qualname__.__eq__
  args: ["AbstractAsyncContextManager"]
  expected: true
