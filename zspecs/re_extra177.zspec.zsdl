spec: re_extra177
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re function identity — __name__ and __module__ for compile, search, match, fullmatch, findall, finditer, sub, subn, split."
    - "re.compile.__name__ == 'compile' (len=7)."
    - "re.compile.__module__ == 're' (len=2)."
    - "re.search.__name__ == 'search' (len=6)."
    - "re.match.__name__ == 'match' (len=5)."
    - "re.fullmatch.__name__ == 'fullmatch' (len=9)."
    - "re.findall.__name__ == 'findall' (len=7; same as compile: 'findall' (7) == 'compile' (7))."
    - "re.finditer.__name__ == 'finditer' (len=8)."
    - "re.sub.__name__ == 'sub' (len=3)."
    - "re.subn.__name__ == 'subn' (len=4)."
    - "re.split.__name__ == 'split' (len=5; same as match: 'split' (5) == 'match' (5))."
    - "Name length ordering: sub (3) < subn (4) < match=split (5) < search (6) < compile=findall (7) < finditer (8) < fullmatch (9)."
    - "sub (3) is the minimum; fullmatch (9) is the maximum among the re functions checked."
    - "compile (7) == findall (7): two-way tie at 7."
    - "match (5) == split (5): two-way tie at 5."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re function names — compile (7), search (6), match (5)
# compile.__name__ == 'compile' (len=7)
# search.__name__ == 'search' (len=6)
# match.__name__ == 'match' (len=5)
# ---------------------------------------------------------------------------

table re_extra177.compile_search_match_names:
  description: "re.compile.__name__=='compile' (len=7); re.compile.__module__=='re' (len=2); re.search.__name__=='search' (len=6); re.match.__name__=='match' (len=5); match (5) < search (6) < compile (7) in name-length ordering"
  kind: python_call_eq
  category: identity
  id_prefix: refunctions177

  columns: [id, function, args, expected, description]
  rows:
    - [compile_name,     compile.__name__.__eq__,   ["compile"], true, "re.compile.__name__ == 'compile' — 'compile' has 7 characters; compile (7) == findall (7): a two-way tie at 7 in the re function name lengths; compile (7) > search (6) by 1; compile (7) < finditer (8) by 1; re.compile() compiles a regex pattern string into a re.Pattern object; re.compile.__module__ == 're'; confirmed Python 3.14.3 macOS"]
    - [compile_name_len, compile.__name__.__len__,  [],          7,    "re.compile.__name__.__len__() == 7 — 'compile' has 7 characters; compile (7) == findall (7): the two 7-character functions; compile (7) > search (6) > match=split (5) > subn (4) > sub (3) in the descending name-length ordering; compile (7) < finditer (8) < fullmatch (9); confirmed Python 3.14.3 macOS"]
    - [compile_module,   compile.__module__.__eq__, ["re"],      true, "re.compile.__module__ == 're' — 're' has 2 characters; compile.__module__ (2) == all other re functions' __module__ (2): the 2-character module name 're' is shared by all public re module functions; compile (7 chars) > 're' (2 chars) by 5; confirmed Python 3.14.3 macOS"]
    - [search_name,      search.__name__.__eq__,    ["search"],  true, "re.search.__name__ == 'search' — 'search' has 6 characters; search (6) > match=split (5) by 1; search (6) < compile=findall (7) by 1; re.search() scans through the string looking for any location where the regex pattern produces a match; confirmed Python 3.14.3 macOS"]
    - [search_name_len,  search.__name__.__len__,   [],          6,    "re.search.__name__.__len__() == 6 — 'search' has 6 characters; search (6) is between match=split (5) and compile=findall (7) in the name-length ordering; search (6) > match (5) by 1; search (6) < compile (7) by 1; confirmed Python 3.14.3 macOS"]
    - [match_name,       match.__name__.__eq__,     ["match"],   true, "re.match.__name__ == 'match' — 'match' has 5 characters; match (5) == split (5): a two-way tie at 5; match (5) > subn (4) by 1; match (5) < search (6) by 1; re.match() tries to apply the pattern at the start of the string; confirmed Python 3.14.3 macOS"]
    - [match_name_len,   match.__name__.__len__,    [],          5,    "re.match.__name__.__len__() == 5 — 'match' has 5 characters; match (5) == split (5): the two 5-character re functions; match (5) > subn (4) by 1; match (5) < search (6) by 1; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# re function names — fullmatch (9), findall (7), finditer (8)
# fullmatch.__name__ == 'fullmatch' (len=9; maximum)
# findall.__name__ == 'findall' (len=7; same as compile)
# finditer.__name__ == 'finditer' (len=8)
# ---------------------------------------------------------------------------

table re_extra177.fullmatch_findall_finditer_names:
  description: "re.fullmatch.__name__=='fullmatch' (len=9; maximum in spec); re.findall.__name__=='findall' (len=7; ties compile); re.finditer.__name__=='finditer' (len=8); findall (7) < finditer (8) < fullmatch (9): a three-way ascending sequence"
  kind: python_call_eq
  category: identity
  id_prefix: refunctions177

  columns: [id, function, args, expected, description]
  rows:
    - [fullmatch_name,     fullmatch.__name__.__eq__,   ["fullmatch"], true, "re.fullmatch.__name__ == 'fullmatch' — 'fullmatch' has 9 characters: 'full' (4) + 'match' (5) = 9; fullmatch (9) is the maximum function name length in this spec; fullmatch (9) > finditer (8) by 1; fullmatch (9) > findall=compile (7) by 2; re.fullmatch() tries to apply the pattern to the entire string, returning None if there is no match at the full string extent; confirmed Python 3.14.3 macOS"]
    - [fullmatch_name_len, fullmatch.__name__.__len__,  [],            9,    "re.fullmatch.__name__.__len__() == 9 — 'fullmatch' has 9 characters; fullmatch (9) is the global maximum in the name-length ordering: sub (3) < subn (4) < match=split (5) < search (6) < compile=findall (7) < finditer (8) < fullmatch (9); fullmatch (9) > finditer (8) by 1; confirmed Python 3.14.3 macOS"]
    - [findall_name,       findall.__name__.__eq__,     ["findall"],   true, "re.findall.__name__ == 'findall' — 'findall' has 7 characters: 'find' (4) + 'all' (3) = 7; findall (7) == compile (7): a two-way tie at 7 between findall and compile; findall (7) > search (6) by 1; findall (7) < finditer (8) by 1; re.findall() returns all non-overlapping matches of the pattern in the string as a list; confirmed Python 3.14.3 macOS"]
    - [findall_name_len,   findall.__name__.__len__,    [],            7,    "re.findall.__name__.__len__() == 7 — 'findall' has 7 characters; findall (7) == compile (7): the two 7-character re functions; findall (7) < finditer (8) by 1; findall (7) < fullmatch (9) by 2; findall (7) > search (6) by 1; confirmed Python 3.14.3 macOS"]
    - [finditer_name,      finditer.__name__.__eq__,    ["finditer"],  true, "re.finditer.__name__ == 'finditer' — 'finditer' has 8 characters: 'find' (4) + 'iter' (4) = 8; finditer (8) > findall (7) by 1: 'iter' (4) == 'all' (3) + 1 character difference; finditer (8) < fullmatch (9) by 1; finditer (8) > search (6) by 2; re.finditer() returns an iterator yielding match objects for all non-overlapping matches; confirmed Python 3.14.3 macOS"]
    - [finditer_name_len,  finditer.__name__.__len__,   [],            8,    "re.finditer.__name__.__len__() == 8 — 'finditer' has 8 characters; finditer (8) is between findall=compile (7) and fullmatch (9) in the name-length ordering; finditer (8) > findall (7) by 1; finditer (8) < fullmatch (9) by 1; finditer and fullmatch form a two-step ascending sequence 8, 9 at the top of the name-length ordering; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# re function names — sub (3), subn (4), split (5)
# sub.__name__ == 'sub' (len=3; minimum)
# subn.__name__ == 'subn' (len=4)
# split.__name__ == 'split' (len=5; same as match)
# ---------------------------------------------------------------------------

table re_extra177.sub_subn_split_names:
  description: "re.sub.__name__=='sub' (len=3; minimum in spec); re.subn.__name__=='subn' (len=4); re.split.__name__=='split' (len=5; ties match); sub (3) < subn (4) < split=match (5): a three-step ascending sequence from minimum"
  kind: python_call_eq
  category: identity
  id_prefix: refunctions177

  columns: [id, function, args, expected, description]
  rows:
    - [sub_name,     sub.__name__.__eq__,   ["sub"],   true, "re.sub.__name__ == 'sub' — 'sub' has 3 characters; sub (3) is the minimum function name length in this spec; sub (3) < subn (4) by 1; sub (3) < match=split (5) by 2; sub (3) < fullmatch (9) by 6; re.sub() replaces occurrences of the pattern in the string with a replacement; confirmed Python 3.14.3 macOS"]
    - [sub_name_len, sub.__name__.__len__,  [],        3,    "re.sub.__name__.__len__() == 3 — 'sub' has 3 characters; sub (3) is the global minimum in the name-length ordering: sub (3) < subn (4) < match=split (5) < search (6) < compile=findall (7) < finditer (8) < fullmatch (9); sub (3) is 6 characters shorter than fullmatch (9); confirmed Python 3.14.3 macOS"]
    - [subn_name,    subn.__name__.__eq__,  ["subn"],  true, "re.subn.__name__ == 'subn' — 'subn' has 4 characters: 'sub' (3) + 'n' (1) = 4; subn (4) > sub (3) by 1: subn is sub with an appended 'n' that signals it returns a tuple (replacement_string, count); subn (4) < match=split (5) by 1; re.subn() behaves like re.sub() but also returns the number of substitutions made; confirmed Python 3.14.3 macOS"]
    - [subn_name_len,subn.__name__.__len__, [],        4,    "re.subn.__name__.__len__() == 4 — 'subn' has 4 characters; subn (4) > sub (3) by 1; subn (4) < match=split (5) by 1; subn sits between sub (3) and match=split (5) in the name-length ordering; subn (4) is exactly sub (3) + 1; confirmed Python 3.14.3 macOS"]
    - [split_name,   split.__name__.__eq__, ["split"],  true, "re.split.__name__ == 'split' — 'split' has 5 characters; split (5) == match (5): a two-way tie at 5; split (5) > subn (4) by 1; split (5) < search (6) by 1; re.split() splits the string by occurrences of the pattern; confirmed Python 3.14.3 macOS"]
    - [split_name_len,split.__name__.__len__,[],        5,    "re.split.__name__.__len__() == 5 — 'split' has 5 characters; split (5) == match (5): the two 5-character re functions; split (5) > subn (4) by 1; split (5) < search (6) by 1; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra177.compile_name_is_compile:
  description: "re.compile.__name__ == 'compile' — 'compile' has 7 characters; compile (7) == findall (7): two-way tie at 7; compile (7) > search (6) by 1; compile (7) < finditer (8) by 1; re.compile() is the primary function for creating compiled regex Pattern objects; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: compile.__name__.__eq__
  args: ["compile"]
  expected: true

invariant re_extra177.compile_module_is_re:
  description: "re.compile.__module__ == 're' — 're' has 2 characters; compile.__module__ (2) is shared by all re module functions checked in this spec; compile (7 chars name) >> 're' (2 chars module) by 5; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: compile.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra177.sub_name_len_3:
  description: "re.sub.__name__.__len__() == 3 — 'sub' has 3 characters; sub (3) is the minimum function name length in this spec; sub (3) < subn (4) < match=split (5) < search (6) < compile=findall (7) < finditer (8) < fullmatch (9); sub (3) is the global minimum; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: sub.__name__.__len__
  args: []
  expected: 3

invariant re_extra177.fullmatch_name_len_9:
  description: "re.fullmatch.__name__.__len__() == 9 — 'fullmatch' has 9 characters: 'full' (4) + 'match' (5) = 9; fullmatch (9) is the maximum function name length in this spec; fullmatch (9) > finditer (8) by 1; fullmatch (9) > sub (3) by 6; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: fullmatch.__name__.__len__
  args: []
  expected: 9

invariant re_extra177.findall_name_len_7:
  description: "re.findall.__name__.__len__() == 7 — 'findall' has 7 characters; findall (7) == compile (7): a two-way tie at 7; findall (7) < finditer (8) by 1; findall (7) > search (6) by 1; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: findall.__name__.__len__
  args: []
  expected: 7

invariant re_extra177.finditer_name_len_8:
  description: "re.finditer.__name__.__len__() == 8 — 'finditer' has 8 characters: 'find' (4) + 'iter' (4) = 8; finditer (8) > findall=compile (7) by 1; finditer (8) < fullmatch (9) by 1; finditer occupies the second-to-maximum position in the name-length ordering; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: finditer.__name__.__len__
  args: []
  expected: 8

invariant re_extra177.split_name_len_5:
  description: "re.split.__name__.__len__() == 5 — 'split' has 5 characters; split (5) == match (5): a two-way tie at 5; split (5) > subn (4) by 1; split (5) < search (6) by 1; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: split.__name__.__len__
  args: []
  expected: 5
