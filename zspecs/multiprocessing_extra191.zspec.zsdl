# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra191
# ---------------------------------------------------------------------------

invariant multiprocessing_extra191.mp_ProcessError_name_eq:
  description: "multiprocessing.ProcessError.__name__.__eq__('ProcessError') returns True — multiprocessing.ProcessError.__name__=='ProcessError' (len=12: 'Process'=7+'Error'=5=12); ProcessError is the root exception class for all multiprocessing-specific exceptions; AuthenticationError, BufferTooShort, ProcessLookupError, and TimeoutError all derive (directly or indirectly) from ProcessError; ProcessError.__name__ (12) == TimeoutError.__name__ (12) — same length; ProcessError.__name__ (12) < BufferTooShort.__name__ (14) by 2; NEW in mpexceptions191: first standalone ProcessError.__name__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.ProcessError.__name__.__eq__
  args: ["ProcessError"]
  expected: true

invariant multiprocessing_extra191.mp_ProcessError_module_eq:
  description: "multiprocessing.ProcessError.__module__.__eq__('multiprocessing.context') returns True — ProcessError.__module__=='multiprocessing.context' (len=23: 'multiprocessing'=15+'.'=1+'context'=7=23); multiprocessing exception classes are defined in Lib/multiprocessing/context.py, the module that implements spawn/fork/forkserver start-method contexts; ProcessError.__module__ (23) == BufferTooShort.__module__ (23) == TimeoutError.__module__ (23) — all three share the same context submodule; compare multiprocessing.Process.__module__=='multiprocessing.process' (25 — 'process' vs 'context'); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.ProcessError.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra191.mp_ProcessError_base_is_Exception:
  description: "multiprocessing.ProcessError.__bases__[0].__name__.__eq__('Exception') returns True — ProcessError inherits directly from the built-in Exception (len=9: E(1)x(2)c(3)e(4)p(5)t(6)i(7)o(8)n(9)); ProcessError is the top of the multiprocessing exception hierarchy — all other mp exceptions inherit from it; ProcessError.__bases__[0].__name__=='Exception' distinguishes it from built-in TimeoutError (which inherits OSError) and concurrent.futures.BrokenExecutor (which inherits RuntimeError); NEW in mpexceptions191: standalone ProcessError base invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.ProcessError.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant multiprocessing_extra191.mp_BufferTooShort_name_eq:
  description: "multiprocessing.BufferTooShort.__name__.__eq__('BufferTooShort') returns True — BufferTooShort.__name__=='BufferTooShort' (len=14: 'Buffer'=6+'Too'=3+'Short'=5=14); BufferTooShort is raised by Connection.recv_bytes_into(buffer) when the supplied buffer object is too small to hold the incoming message; the exception's args[0] is the message data that could not fit; BufferTooShort.__name__ (14) > ProcessError.__name__ (12) by 2 and > TimeoutError.__name__ (12) by 2; BufferTooShort.__name__ (14) is the longest name among these three exceptions; NEW in mpexceptions191: first standalone BufferTooShort.__name__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.BufferTooShort.__name__.__eq__
  args: ["BufferTooShort"]
  expected: true

invariant multiprocessing_extra191.mp_BufferTooShort_module_eq:
  description: "multiprocessing.BufferTooShort.__module__.__eq__('multiprocessing.context') returns True — BufferTooShort.__module__=='multiprocessing.context' (len=23); BufferTooShort is defined in the same context module as ProcessError and TimeoutError; BufferTooShort.__module__ (23) == ProcessError.__module__ (23) == TimeoutError.__module__ (23) — all three exceptions are co-located in multiprocessing.context; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.BufferTooShort.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra191.mp_BufferTooShort_base_is_ProcessError:
  description: "multiprocessing.BufferTooShort.__bases__[0].__name__.__eq__('ProcessError') returns True — BufferTooShort inherits from ProcessError (len=12); BufferTooShort is a specialization of the mp exception hierarchy root, indicating a communication failure due to an undersized buffer; BufferTooShort.__bases__[0].__name__=='ProcessError' (12) == TimeoutError.__bases__[0].__name__ (12) — both direct subclasses of ProcessError with same base name length; NEW in mpexceptions191: standalone BufferTooShort base class invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.BufferTooShort.__bases__[0].__name__.__eq__"
  args: ["ProcessError"]
  expected: true

invariant multiprocessing_extra191.mp_TimeoutError_name_eq:
  description: "multiprocessing.TimeoutError.__name__.__eq__('TimeoutError') returns True — multiprocessing.TimeoutError.__name__=='TimeoutError' (len=12: T(1)i(2)m(3)e(4)o(5)u(6)t(7)E(8)r(9)r(10)o(11)r(12)); this is the multiprocessing-specific TimeoutError, distinct from both the built-in TimeoutError (OSError subclass) and concurrent.futures.TimeoutError (built-in alias); multiprocessing.TimeoutError inherits from ProcessError, placing it within the mp exception hierarchy; TimeoutError.__name__ (12) == ProcessError.__name__ (12) — an interesting length tie; NEW in mpexceptions191: first standalone mp TimeoutError.__name__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.TimeoutError.__name__.__eq__
  args: ["TimeoutError"]
  expected: true

invariant multiprocessing_extra191.mp_TimeoutError_module_eq:
  description: "multiprocessing.TimeoutError.__module__.__eq__('multiprocessing.context') returns True — multiprocessing.TimeoutError.__module__=='multiprocessing.context' (len=23); multiprocessing.TimeoutError shares the context module with ProcessError and BufferTooShort — all three exceptions are defined in Lib/multiprocessing/context.py; TimeoutError.__module__ (23) == ProcessError.__module__ (23) == BufferTooShort.__module__ (23); contrast with concurrent.futures.TimeoutError.__module__=='builtins' (8) — the two TimeoutError classes have the same __name__ but completely different modules and inheritance hierarchies; NEW in mpexceptions191: standalone mp TimeoutError.__module__ invariant completing 8-invariant coverage for multiprocessing exception identity; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.TimeoutError.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

