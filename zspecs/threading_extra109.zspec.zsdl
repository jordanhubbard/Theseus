spec: threading_extra109
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra108.zspec.zsdl."
    - "This spec covers: threading.Thread method type names (run/start/join/is_alive are all 'function'); threading.Thread method qualnames (all follow 'Thread.method_name' pattern); threading.Thread base class identity (__bases__[0].__name__ == 'object', MRO depth 2); threading.Thread class module and identity (__module__ == 'threading', __name__ == 'Thread'); threading.Thread.run/join/is_alive/__init__ co_argcount values; wave 261."
    - "type(threading.Thread.run).__name__ == 'function'. Verified with Python 3.14.3."
    - "type(threading.Thread.start).__name__ == 'function'. Verified with Python 3.14.3."
    - "type(threading.Thread.join).__name__ == 'function'. Verified with Python 3.14.3."
    - "type(threading.Thread.is_alive).__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Thread.run.__qualname__ == 'Thread.run'. Verified with Python 3.14.3."
    - "threading.Thread.start.__qualname__ == 'Thread.start'. Verified with Python 3.14.3."
    - "threading.Thread.join.__qualname__ == 'Thread.join'. Verified with Python 3.14.3."
    - "threading.Thread.is_alive.__qualname__ == 'Thread.is_alive'. Verified with Python 3.14.3."
    - "threading.Thread.__init__.__qualname__ == 'Thread.__init__'. Verified with Python 3.14.3."
    - "threading.Thread.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "threading.Thread.__mro__.__len__() == 2. Verified with Python 3.14.3."
    - "threading.Thread.__module__ == 'threading'. Verified with Python 3.14.3."
    - "threading.Thread.__name__ == 'Thread'. Verified with Python 3.14.3."
    - "threading.Thread.run.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "threading.Thread.join.__code__.co_argcount == 2. Verified with Python 3.14.3."
    - "threading.Thread.is_alive.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "threading.Thread.__init__.__code__.co_argcount == 6. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread method type names
#
# Wave 261 theme: threading.Thread is a pure-Python class defined in
# Lib/threading.py. All its methods (run, start, join, is_alive) are plain
# Python 'function' objects when accessed unbound from the class. This
# contrasts with C-extension methods (like threading.Lock methods) which
# would have type 'method_descriptor'. The type __init__ method is also
# a 'function'.
#
# type(threading.Thread.run).__name__ == 'function'
# type(threading.Thread.start).__name__ == 'function'
# type(threading.Thread.join).__name__ == 'function'
# type(threading.Thread.is_alive).__name__ == 'function'
#
# New to extra109.
# ---------------------------------------------------------------------------

table threading_extra109.thread_method_type_names:
  description: "threading.Thread methods run/start/join/is_alive are all type 'function' (pure-Python, not C method_descriptor); wave 261; new to extra109"
  kind: python_call_eq
  category: class_names
  id_prefix: threadingthread109

  columns: [id, function, args, expected, description]
  rows:
    - [thread_run_type_function,
       "Thread.run.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Thread.run.__class__.__name__.__eq__('function') == True — threading.Thread is a pure-Python class defined in Lib/threading.py; Thread.run is the method users override to define thread behavior; accessed unbound from the class it is a plain function object; __class__.__name__ is 'function' (not 'method_descriptor'); str.__eq__('function') returns True; new to extra109"]
    - [thread_start_type_function,
       "Thread.start.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Thread.start.__class__.__name__.__eq__('function') == True — threading.Thread.start arranges for the thread's run() to be invoked in a separate thread of control; it is a Python def method; accessed unbound it is a function object; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra109"]
    - [thread_join_type_function,
       "Thread.join.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Thread.join.__class__.__name__.__eq__('function') == True — threading.Thread.join blocks until the thread terminates; it accepts an optional timeout argument; it is a Python def method; accessed unbound it is a function object; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra109"]
    - [thread_is_alive_type_function,
       "Thread.is_alive.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Thread.is_alive.__class__.__name__.__eq__('function') == True — threading.Thread.is_alive returns True if the thread is alive (started and not yet terminated); it is a Python def method; accessed unbound it is a function object; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra109"]
    - [thread_init_type_function,
       "Thread.__init__.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Thread.__init__.__class__.__name__.__eq__('function') == True — threading.Thread.__init__ initializes the Thread instance with group/target/name/args/kwargs/daemon arguments; it is a Python def method; accessed unbound it is a function object; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra109"]

# ---------------------------------------------------------------------------
# Table 2: threading.Thread method qualnames
#
# Wave 261 theme: all threading.Thread methods follow the 'Thread.method_name'
# qualname pattern because they are defined directly inside the Thread class
# body. The __qualname__ includes the class name as a prefix, separated by
# a dot. For __init__ the qualname is 'Thread.__init__'.
#
# threading.Thread.run.__qualname__ == 'Thread.run'
# threading.Thread.start.__qualname__ == 'Thread.start'
# threading.Thread.join.__qualname__ == 'Thread.join'
# threading.Thread.is_alive.__qualname__ == 'Thread.is_alive'
# threading.Thread.__init__.__qualname__ == 'Thread.__init__'
#
# New to extra109.
# ---------------------------------------------------------------------------

table threading_extra109.thread_method_qualnames:
  description: "threading.Thread method qualnames: run/start/join/is_alive/__init__ all follow 'Thread.method_name' pattern; wave 261; new to extra109"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingqn109

  columns: [id, function, args, expected, description]
  rows:
    - [thread_run_qualname_eq,
       "Thread.run.__qualname__.__eq__",
       ["Thread.run"],
       true,
       "threading.Thread.run.__qualname__.__eq__('Thread.run') == True — Thread.run is defined inside the Thread class body; its __qualname__ is 'Thread.run' (class name dot method name); str.__eq__('Thread.run') returns True; new to extra109"]
    - [thread_start_qualname_eq,
       "Thread.start.__qualname__.__eq__",
       ["Thread.start"],
       true,
       "threading.Thread.start.__qualname__.__eq__('Thread.start') == True — Thread.start is defined inside the Thread class body; its __qualname__ is 'Thread.start'; str.__eq__('Thread.start') returns True; new to extra109"]
    - [thread_join_qualname_eq,
       "Thread.join.__qualname__.__eq__",
       ["Thread.join"],
       true,
       "threading.Thread.join.__qualname__.__eq__('Thread.join') == True — Thread.join is defined inside the Thread class body; its __qualname__ is 'Thread.join'; str.__eq__('Thread.join') returns True; new to extra109"]
    - [thread_is_alive_qualname_eq,
       "Thread.is_alive.__qualname__.__eq__",
       ["Thread.is_alive"],
       true,
       "threading.Thread.is_alive.__qualname__.__eq__('Thread.is_alive') == True — Thread.is_alive is defined inside the Thread class body; its __qualname__ is 'Thread.is_alive'; str.__eq__('Thread.is_alive') returns True; new to extra109"]
    - [thread_init_qualname_eq,
       "Thread.__init__.__qualname__.__eq__",
       ["Thread.__init__"],
       true,
       "threading.Thread.__init__.__qualname__.__eq__('Thread.__init__') == True — Thread.__init__ is defined inside the Thread class body; its __qualname__ is 'Thread.__init__'; the dunder name is preserved as-is in the qualname; str.__eq__('Thread.__init__') returns True; new to extra109"]

# ---------------------------------------------------------------------------
# Table 3: threading.Thread class identity and method co_argcount
#
# Wave 261 theme: threading.Thread is a pure-Python class that inherits
# directly from object. Its MRO is [Thread, object] with depth 2. It is
# defined in 'threading' module. The co_argcount of its methods reveals
# their signatures: run takes 1 (self), join takes 2 (self, timeout),
# is_alive takes 1 (self), __init__ takes 6 (self, group, target, name,
# args, kwargs — daemon is keyword-only so not counted in co_argcount).
#
# threading.Thread.__bases__[0].__name__ == 'object'
# threading.Thread.__mro__.__len__() == 2
# threading.Thread.__module__ == 'threading'
# threading.Thread.run.__code__.co_argcount == 1
# threading.Thread.join.__code__.co_argcount == 2
# threading.Thread.is_alive.__code__.co_argcount == 1
# threading.Thread.__init__.__code__.co_argcount == 6
#
# New to extra109.
# ---------------------------------------------------------------------------

table threading_extra109.thread_class_identity_and_argcounts:
  description: "threading.Thread class identity: __bases__[0] == object, MRO depth 2, __module__ == 'threading'; method co_argcount: run==1, join==2, is_alive==1, __init__==6; wave 261; new to extra109"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingcls109

  columns: [id, function, args, expected, description]
  rows:
    - ["thread_bases_0_object",
       "Thread.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Thread.__bases__[0].__name__.__eq__('object') == True — threading.Thread inherits directly from object with no intermediate base classes; __bases__[0] is object; object.__name__ is 'object'; str.__eq__('object') returns True; new to extra109"]
    - [thread_mro_len_2,
       "Thread.__mro__.__len__",
       [],
       2,
       "threading.Thread.__mro__.__len__() == 2 — threading.Thread inherits directly from object; its MRO is [Thread, object] with length 2; contrasts with BoundedSemaphore (MRO depth 3); new to extra109"]
    - [thread_module_threading,
       "Thread.__module__.__eq__",
       ["threading"],
       true,
       "threading.Thread.__module__.__eq__('threading') == True — threading.Thread is defined in Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra109"]
    - [thread_name_eq,
       "Thread.__name__.__eq__",
       ["Thread"],
       true,
       "threading.Thread.__name__.__eq__('Thread') == True — threading.Thread is the main thread class; its __name__ is 'Thread'; str.__eq__('Thread') returns True; new to extra109"]
    - [thread_run_co_argcount_1,
       "Thread.run.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading.Thread.run.__code__.co_argcount.__eq__(1) == True — Thread.run takes 1 positional argument (self); it is meant to be overridden in subclasses to define thread activity; co_argcount is 1; int.__eq__(1) returns True; new to extra109"]
    - [thread_join_co_argcount_2,
       "Thread.join.__code__.co_argcount.__eq__",
       [2],
       true,
       "threading.Thread.join.__code__.co_argcount.__eq__(2) == True — Thread.join takes 2 positional arguments (self, timeout); timeout is a positional argument with default None and counts toward co_argcount; int.__eq__(2) returns True; new to extra109"]
    - [thread_is_alive_co_argcount_1,
       "Thread.is_alive.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading.Thread.is_alive.__code__.co_argcount.__eq__(1) == True — Thread.is_alive takes 1 positional argument (self); it returns a boolean indicating whether the thread is still running; co_argcount is 1; int.__eq__(1) returns True; new to extra109"]
    - [thread_init_co_argcount_6,
       "Thread.__init__.__code__.co_argcount.__eq__",
       [6],
       true,
       "threading.Thread.__init__.__code__.co_argcount.__eq__(6) == True — Thread.__init__ takes 6 positional arguments (self, group, target, name, args, kwargs); 'daemon' is keyword-only and does not count toward co_argcount; int.__eq__(6) returns True; new to extra109"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra109
# ---------------------------------------------------------------------------

invariant threading_extra109.thread_run_function:
  description: "threading.Thread.run.__class__.__name__ == 'function' — Thread is pure-Python; run is a function object; wave 261; new to extra109"
  kind: python_call_eq
  function: Thread.run.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra109.thread_run_qualname:
  description: "threading.Thread.run.__qualname__ == 'Thread.run' — qualname includes class prefix; wave 261; new to extra109"
  kind: python_call_eq
  function: Thread.run.__qualname__.__eq__
  args: ["Thread.run"]
  expected: true

invariant threading_extra109.thread_mro_len:
  description: "threading.Thread.__mro__.__len__() == 2 — Thread inherits directly from object; MRO is [Thread, object]; wave 261; new to extra109"
  kind: python_call_eq
  function: Thread.__mro__.__len__
  args: []
  expected: 2

invariant threading_extra109.thread_init_co_argcount:
  description: "threading.Thread.__init__.__code__.co_argcount == 6 — self/group/target/name/args/kwargs; daemon is keyword-only; wave 261; new to extra109"
  kind: python_call_eq
  function: Thread.__init__.__code__.co_argcount.__eq__
  args: [6]
  expected: true

invariant threading_extra109.thread_join_co_argcount:
  description: "threading.Thread.join.__code__.co_argcount == 2 — join takes self and timeout; wave 261; new to extra109"
  kind: python_call_eq
  function: Thread.join.__code__.co_argcount.__eq__
  args: [2]
  expected: true
