spec: uuid_extra2446
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "uuid_extra161.zspec.zsdl and uuid_extra180.zspec.zsdl and other pre-existing uuid_extra files"
  notes:
    - "Theme: __enter__/__exit__ context manager protocol dict-presence for uuid types."
    - "uuid.UUID does NOT define __enter__ or __exit__ in its own __dict__; UUID objects cannot be used as context managers."
    - "uuid.SafeUUID is an IntEnum subclass; it also does NOT define __enter__ or __exit__ in its own __dict__."
    - "uuid.UUID defines a rich comparison and representation API: __hash__, __eq__, __lt__, __gt__, __str__, __repr__, __int__, plus computed property descriptors like bytes, hex, version."
    - "uuid.SafeUUID.__dict__ contains its enum members (safe, unsafe, unknown) and the enum infrastructure (__new__, _member_names_) but no context manager hooks."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: uuid.UUID — context manager protocol absent
#
# uuid.UUID is a plain Python class. It defines rich comparison, hashing, and
# a comprehensive set of computed property attributes. It does NOT define
# __enter__ or __exit__ in its class __dict__ — UUID instances cannot be used
# as context managers.
# ---------------------------------------------------------------------------

table uuid_extra2446.uuid_ctx_protocol_absent:
  description: "uuid.UUID.__dict__: __enter__ and __exit__ absent — UUID is not a context manager; new to extra2446"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2446

  columns: [id, function, args, expected]
  rows:
    - ["uu2446-001", "uuid.UUID.__dict__.__contains__", ["__enter__"], false]
    - ["uu2446-002", "uuid.UUID.__dict__.__contains__", ["__exit__"], false]
    - ["uu2446-003", "uuid.UUID.__dict__.__contains__", ["__iter__"], false]
    - ["uu2446-004", "uuid.UUID.__dict__.__contains__", ["__next__"], false]

# ---------------------------------------------------------------------------
# Table 2: uuid.UUID — comparison and identity API present in __dict__
#
# uuid.UUID defines __hash__, __eq__, __lt__, __gt__, __str__, __repr__, and
# __int__ directly in its class body. These are all own attributes in __dict__.
# Contrasting with Table 1: the full object identity API is present, but the
# context manager protocol is absent.
# ---------------------------------------------------------------------------

table uuid_extra2446.uuid_comparison_api_present:
  description: "uuid.UUID.__dict__: __hash__, __eq__, __lt__, __gt__, __str__, __repr__, __int__ present; new to extra2446"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2446

  columns: [id, function, args, expected]
  rows:
    - ["uu2446-005", "uuid.UUID.__dict__.__contains__", ["__hash__"], true]
    - ["uu2446-006", "uuid.UUID.__dict__.__contains__", ["__eq__"], true]
    - ["uu2446-007", "uuid.UUID.__dict__.__contains__", ["__lt__"], true]
    - ["uu2446-008", "uuid.UUID.__dict__.__contains__", ["__gt__"], true]
    - ["uu2446-009", "uuid.UUID.__dict__.__contains__", ["__str__"], true]
    - ["uu2446-010", "uuid.UUID.__dict__.__contains__", ["__repr__"], true]
    - ["uu2446-011", "uuid.UUID.__dict__.__contains__", ["__int__"], true]

# ---------------------------------------------------------------------------
# Table 3: uuid.UUID — computed property descriptors present
#
# uuid.UUID exposes computed attributes via property descriptors: bytes, hex,
# and version are defined directly in the class body and therefore appear in
# __dict__. These are read-only computed properties, not instance variables.
# ---------------------------------------------------------------------------

table uuid_extra2446.uuid_property_descriptors_present:
  description: "uuid.UUID.__dict__: bytes, hex, version property descriptors present; new to extra2446"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2446

  columns: [id, function, args, expected]
  rows:
    - ["uu2446-012", "uuid.UUID.__dict__.__contains__", ["bytes"], true]
    - ["uu2446-013", "uuid.UUID.__dict__.__contains__", ["hex"], true]
    - ["uu2446-014", "uuid.UUID.__dict__.__contains__", ["version"], true]

# ---------------------------------------------------------------------------
# Table 4: uuid.SafeUUID — context manager protocol absent; enum members present
#
# uuid.SafeUUID is an IntEnum subclass with three members: safe (1), unsafe (-1),
# unknown (None). As an IntEnum it inherits extensive enum infrastructure but
# does NOT define __enter__ or __exit__ in its own __dict__. The class-level
# enum members (safe, unsafe, unknown) and enum plumbing (_member_names_,
# __new__) are present in __dict__.
# ---------------------------------------------------------------------------

table uuid_extra2446.safeuuid_ctx_and_members:
  description: "uuid.SafeUUID.__dict__: __enter__/__exit__ absent; safe/unsafe/unknown enum members present; new to extra2446"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2446

  columns: [id, function, args, expected]
  rows:
    - ["uu2446-015", "uuid.SafeUUID.__dict__.__contains__", ["__enter__"], false]
    - ["uu2446-016", "uuid.SafeUUID.__dict__.__contains__", ["__exit__"], false]
    - ["uu2446-017", "uuid.SafeUUID.__dict__.__contains__", ["safe"], true]
    - ["uu2446-018", "uuid.SafeUUID.__dict__.__contains__", ["unsafe"], true]
    - ["uu2446-019", "uuid.SafeUUID.__dict__.__contains__", ["unknown"], true]
    - ["uu2446-020", "uuid.SafeUUID.__dict__.__contains__", ["__new__"], true]
    - ["uu2446-021", "uuid.SafeUUID.__dict__.__contains__", ["_member_names_"], true]
