spec: _csv
version: ">=3.0"
backend: python_module(_csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/csv.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "_csv source: Modules/_csv.c (PSF; C extension)"
  not_derived_from:
    - "_csv source: internal parser state machine details"
  notes:
    - "_csv is the C-extension backend for the csv stdlib module."
    - "QUOTE_MINIMAL=0, QUOTE_ALL=1, QUOTE_NONNUMERIC=2, QUOTE_NONE=3 are integer quoting mode constants."
    - "Dialect is an abstract base class; concrete dialects subclass it."
    - "Error is the base exception class for all csv errors; it subclasses Exception."
    - "reader and writer are callable C types (not Python classes); their __name__ is 'reader' and 'writer'."
    - "_csv.reader is accessed as a type/callable from the C extension; the csv module re-exports it."
    - "All expected values verified by running Python 3.12 _csv module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Quoting mode constants — pin exact integer values
# ---------------------------------------------------------------------------

table _csv.quote_constants:
  kind: python_call_eq
  category: constants
  id_prefix: quote

  columns: [id, function, args, expected]
  rows:
    - [minimal,     QUOTE_MINIMAL.__eq__,     [0], true]
    - [all,         QUOTE_ALL.__eq__,         [1], true]
    - [nonnumeric,  QUOTE_NONNUMERIC.__eq__,  [2], true]
    - [none,        QUOTE_NONE.__eq__,        [3], true]

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

invariant _csv.Dialect_name:
  description: "_csv.Dialect.__name__ == 'Dialect'"
  category: classes
  kind: python_call_eq
  function: Dialect.__name__.__eq__
  args: ["Dialect"]
  expected: true

invariant _csv.Error_name:
  description: "_csv.Error.__name__ == 'Error'"
  category: classes
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

invariant _csv.reader_name:
  description: "_csv.reader.__name__ == 'reader'"
  category: classes
  kind: python_call_eq
  function: reader.__name__.__eq__
  args: ["reader"]
  expected: true

invariant _csv.writer_name:
  description: "_csv.writer.__name__ == 'writer'"
  category: classes
  kind: python_call_eq
  function: writer.__name__.__eq__
  args: ["writer"]
  expected: true

# ---------------------------------------------------------------------------
# Class hierarchy — Error subclasses Exception
# ---------------------------------------------------------------------------

invariant _csv.Error_base:
  description: "_csv.Error.__bases__[0].__name__ == 'Exception'"
  category: classes
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

# ---------------------------------------------------------------------------
# Module membership — classes report __module__ == '_csv'
# ---------------------------------------------------------------------------

table _csv.class_modules:
  kind: python_call_eq
  category: classes
  id_prefix: cmod

  columns: [id, function, args, expected]
  rows:
    - [dialect, Dialect.__module__.__eq__, ["_csv"], true]
    - [error,   Error.__module__.__eq__,   ["_csv"], true]
    - [reader,  reader.__module__.__eq__,  ["_csv"], true]
    - [writer,  writer.__module__.__eq__,  ["_csv"], true]

# ---------------------------------------------------------------------------
# Quoting constant ordering — MINIMAL < ALL < NONNUMERIC < NONE
# ---------------------------------------------------------------------------

invariant _csv.quote_minimal_lt_all:
  description: "QUOTE_MINIMAL < QUOTE_ALL — quoting constants are ordered 0 < 1"
  category: constants
  kind: python_call_eq
  function: QUOTE_MINIMAL.__lt__
  args: [1]
  expected: true

invariant _csv.quote_all_lt_nonnumeric:
  description: "QUOTE_ALL < QUOTE_NONNUMERIC — quoting constants are ordered 1 < 2"
  category: constants
  kind: python_call_eq
  function: QUOTE_ALL.__lt__
  args: [2]
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: infeasible
  model: claude-cli
  attempted_at: 2026-04-15T00:43:03Z
  iterations: 1
  pass_count: 0
  fail_count: 0
  total_invariants: 15
  notes: "LLM unavailable: claude CLI timed out after 600s"
  infeasible_reason: llm_unavailable
  invariant_annotations: {}
