spec: pprint_extra
version: ">=3.9"
backend: python_module(pprint)

docs: https://docs.python.org/3/library/pprint.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pprint.html — Python pprint documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pprint.py"
  notes:
    - "pformat() returns the formatted representation as a string; pprint() prints it and returns None."
    - "isreadable(obj) returns True if the formatted output is readable (i.e., could be eval'd back to an equal object)."
    - "isrecursive(obj) returns True if the object contains a recursive (self-referencing) data structure."
    - "saferepr(obj) returns a string representation of the object, truncating recursive references."
    - "pformat(42) == '42' — integers format the same as repr()."
    - "pformat('hello') == \"'hello'\" — strings are single-quoted, same as repr()."
    - "pformat([1,2,3]) == '[1, 2, 3]' — short lists fit on one line with default width=80."
    - "isreadable(42) == True — plain integers are always readable."
    - "isrecursive({}) == False — a plain empty dict contains no recursive references."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class identity — PrettyPrinter
# ---------------------------------------------------------------------------

invariant pprint_extra.class_names.PrettyPrinter_name:
  description: "PrettyPrinter.__name__ == 'PrettyPrinter'"
  category: class_names
  kind: python_call_eq
  function: PrettyPrinter.__name__.__eq__
  args: ["PrettyPrinter"]
  expected: true

invariant pprint_extra.class_names.PrettyPrinter_module:
  description: "PrettyPrinter.__module__ == 'pprint'"
  category: class_names
  kind: python_call_eq
  function: PrettyPrinter.__module__.__eq__
  args: ["pprint"]
  expected: true

# ---------------------------------------------------------------------------
# Function identity — pformat, pprint, isreadable, isrecursive, saferepr
# ---------------------------------------------------------------------------

invariant pprint_extra.function_names.pformat:
  description: "pformat.__name__ == 'pformat'"
  category: function_names
  kind: python_call_eq
  function: pformat.__name__.__eq__
  args: ["pformat"]
  expected: true

invariant pprint_extra.function_names.pprint:
  description: "pprint.__name__ == 'pprint'"
  category: function_names
  kind: python_call_eq
  function: pprint.__name__.__eq__
  args: ["pprint"]
  expected: true

invariant pprint_extra.function_names.isreadable:
  description: "isreadable.__name__ == 'isreadable'"
  category: function_names
  kind: python_call_eq
  function: isreadable.__name__.__eq__
  args: ["isreadable"]
  expected: true

invariant pprint_extra.function_names.isrecursive:
  description: "isrecursive.__name__ == 'isrecursive'"
  category: function_names
  kind: python_call_eq
  function: isrecursive.__name__.__eq__
  args: ["isrecursive"]
  expected: true

invariant pprint_extra.function_names.saferepr:
  description: "saferepr.__name__ == 'saferepr'"
  category: function_names
  kind: python_call_eq
  function: saferepr.__name__.__eq__
  args: ["saferepr"]
  expected: true

# ---------------------------------------------------------------------------
# pformat() — formatted string output
# ---------------------------------------------------------------------------

invariant pprint_extra.pformat.integer:
  description: "pformat(42) == '42'"
  category: pformat
  kind: python_call_eq
  function: pformat
  args: [42]
  expected: "42"

invariant pprint_extra.pformat.string:
  description: "pformat('hello') == \"'hello'\""
  category: pformat
  kind: python_call_eq
  function: pformat
  args: ["hello"]
  expected: "'hello'"

invariant pprint_extra.pformat.short_list:
  description: "pformat([1, 2, 3]) == '[1, 2, 3]'"
  category: pformat
  kind: python_call_eq
  function: pformat
  args: [[1, 2, 3]]
  expected: "[1, 2, 3]"

# ---------------------------------------------------------------------------
# isreadable() — readability predicate
# ---------------------------------------------------------------------------

invariant pprint_extra.isreadable.integer:
  description: "isreadable(42) == True — integers are always readable"
  category: isreadable
  kind: python_call_eq
  function: isreadable
  args: [42]
  expected: true

# ---------------------------------------------------------------------------
# isrecursive() — recursion predicate
# ---------------------------------------------------------------------------

invariant pprint_extra.isrecursive.empty_dict:
  description: "isrecursive({}) == False — plain empty dict has no recursive references"
  category: isrecursive
  kind: python_call_eq
  function: isrecursive
  args: [{}]
  expected: false
