spec: socket_extra186
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra185.zspec.zsdl — prior extras."
  notes:
    - "socket.socket.__init__.__name__ == '__init__' — len=8; pure Python method in Lib/socket.py."
    - "socket.socket.__repr__.__name__ == '__repr__' — len=8; pure Python method."
    - "socket.socket.__enter__.__name__ == '__enter__' — len=9; context manager entry."
    - "socket.socket.__exit__.__name__ == '__exit__' — len=8; context manager exit."
    - "socket.socket.__del__.__name__ == '__del__' — len=7; finalizer; present on Darwin."
    - "socket.socket.fileno.__name__ == 'fileno' — len=6; returns file descriptor integer."
    - "socket.socket.makefile.__name__ == 'makefile' — len=8; wraps socket in file-like object."
    - "socket.socket.detach.__name__ == 'detach' — len=6; detaches fd from socket object."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: socket.socket lifecycle dunder method names
#
# socket.socket.__init__.__name__  == '__init__'   (len=8)
# socket.socket.__repr__.__name__  == '__repr__'   (len=8)
# socket.socket.__del__.__name__   == '__del__'    (len=7)
#
# __init__ sets up the socket; __repr__ provides a string representation;
# __del__ is the finalizer that closes the file descriptor on GC.
# ---------------------------------------------------------------------------

