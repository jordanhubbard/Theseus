spec: platformdirs
version: ">=4.0"
backend: python_module(platformdirs)

docs: https://platformdirs.readthedocs.io/

provenance:
  derived_from:
    - "platformdirs documentation — https://platformdirs.readthedocs.io/"
    - "XDG Base Directory Specification — https://specifications.freedesktop.org/basedir-spec/"
    - "Test vectors verified with platformdirs 4.9.4 on Python 3.14 / macOS Darwin 25.4.0, 2026-04-05"
  not_derived_from:
    - "platformdirs source: src/platformdirs/__init__.py"
  notes:
    - "All path checks are structural (non-empty, contains app name or separator) — exact paths vary by platform."
    - "user_data_dir('appname') always contains the app name on all supported platforms."
    - "user_data_path returns a pathlib.Path object; checked via is_absolute()."
  created_at: "2026-04-05T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# version — __version__ is a non-empty string
# ---------------------------------------------------------------------------

invariant platformdirs.version.is_str:
  description: "__version__.__class__.__name__ == 'str'"
  category: version
  kind: python_call_eq
  function: __version__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant platformdirs.version.contains_dot:
  description: "__version__ contains a version separator dot"
  category: version
  kind: python_call_eq
  function: __version__.__contains__
  args: ["."]
  expected: true

# ---------------------------------------------------------------------------
# paths — module-level convenience functions return paths containing app name
# ---------------------------------------------------------------------------

invariant platformdirs.paths.user_data_dir_contains_appname:
  description: "user_data_dir('myapp') returns a path containing the app name"
  category: paths
  kind: python_call_eq
  function: user_data_dir
  args: ["myapp"]
  method: __contains__
  method_args: ["myapp"]
  expected: true

invariant platformdirs.paths.user_cache_dir_contains_appname:
  description: "user_cache_dir('myapp') returns a path containing the app name"
  category: paths
  kind: python_call_eq
  function: user_cache_dir
  args: ["myapp"]
  method: __contains__
  method_args: ["myapp"]
  expected: true

invariant platformdirs.paths.user_log_dir_contains_appname:
  description: "user_log_dir('myapp') returns a path containing the app name"
  category: paths
  kind: python_call_eq
  function: user_log_dir
  args: ["myapp"]
  method: __contains__
  method_args: ["myapp"]
  expected: true

invariant platformdirs.paths.user_config_dir_contains_appname:
  description: "user_config_dir('myapp') returns a path containing the app name"
  category: paths
  kind: python_call_eq
  function: user_config_dir
  args: ["myapp"]
  method: __contains__
  method_args: ["myapp"]
  expected: true

invariant platformdirs.paths.site_data_dir_contains_appname:
  description: "site_data_dir('myapp') returns a path containing the app name"
  category: paths
  kind: python_call_eq
  function: site_data_dir
  args: ["myapp"]
  method: __contains__
  method_args: ["myapp"]
  expected: true

invariant platformdirs.paths.user_data_dir_is_absolute:
  description: "user_data_dir('myapp') returns an absolute path (starts with /)"
  category: paths
  skip_if: "platform == 'win32'"
  kind: python_call_eq
  function: user_data_dir
  args: ["myapp"]
  method: startswith
  method_args: ["/"]
  expected: true

# ---------------------------------------------------------------------------
# path_objects — user_data_path returns a pathlib.Path (absolute)
# ---------------------------------------------------------------------------

invariant platformdirs.path_objects.user_data_path_is_absolute:
  description: "user_data_path('myapp') returns an absolute Path object"
  category: path_objects
  skip_if: "platform == 'win32'"
  kind: python_call_eq
  function: user_data_path
  args: ["myapp"]
  method: is_absolute
  expected: true

invariant platformdirs.path_objects.user_cache_path_is_absolute:
  description: "user_cache_path('myapp') returns an absolute Path object"
  category: path_objects
  skip_if: "platform == 'win32'"
  kind: python_call_eq
  function: user_cache_path
  args: ["myapp"]
  method: is_absolute
  expected: true

invariant platformdirs.path_objects.user_log_path_is_absolute:
  description: "user_log_path('myapp') returns an absolute Path object"
  category: path_objects
  skip_if: "platform == 'win32'"
  kind: python_call_eq
  function: user_log_path
  args: ["myapp"]
  method: is_absolute
  expected: true

# ---------------------------------------------------------------------------
# site_dirs — site directories (system-wide) are absolute paths
# ---------------------------------------------------------------------------

invariant platformdirs.site_dirs.site_data_dir_is_absolute:
  description: "site_data_dir('x') returns an absolute path"
  category: site_dirs
  skip_if: "platform == 'win32'"
  kind: python_call_eq
  function: site_data_dir
  args: ["x"]
  method: startswith
  method_args: ["/"]
  expected: true

invariant platformdirs.site_dirs.site_config_dir_contains_appname:
  description: "site_config_dir('myapp') returns a path containing the app name"
  category: site_dirs
  kind: python_call_eq
  function: site_config_dir
  args: ["myapp"]
  method: __contains__
  method_args: ["myapp"]
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-04-15T10:32:06Z
  iterations: 1
  pass_count: 13
  fail_count: 0
  total_invariants: 13
  notes: Synthesis succeeded in 1 iteration(s). 13 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
