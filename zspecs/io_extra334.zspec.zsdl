spec: io_extra334
version: ">=3.2"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BytesIO — read length, seek, tell, closed, close return value
#
# Verified on Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12:
#   io.BytesIO().read().__len__() == 0
#   io.BytesIO(b'hello').seek(3) == 3
#   io.BytesIO(b'hello').tell() == 0
#   io.BytesIO().closed == False
#   io.BytesIO().close().__class__.__name__ == 'NoneType'
# ---------------------------------------------------------------------------

invariant io_extra334.BytesIO.read_empty_len:
  description: "io.BytesIO().read().__len__() == 0 — reading from an empty BytesIO yields b'' of length 0"
  category: bytesio
  kind: python_call_eq
  function: BytesIO
  args: []
  method: read
  method_chain: __len__
  expected: 0

invariant io_extra334.BytesIO.seek_returns_position:
  description: "io.BytesIO(b'hello').seek(3) == 3 — seek() returns the new stream position"
  category: bytesio
  kind: python_call_eq
  function: BytesIO
  args: [!b64 aGVsbG8=]
  method: seek
  method_args: [3]
  expected: 3

invariant io_extra334.BytesIO.tell_zero_before_read:
  description: "io.BytesIO(b'hello').tell() == 0 — tell() returns 0 before any read"
  category: bytesio
  kind: python_call_eq
  function: BytesIO
  args: [!b64 aGVsbG8=]
  method: tell
  expected: 0

invariant io_extra334.BytesIO.closed_false:
  description: "io.BytesIO().closed == False — a freshly created BytesIO is not closed"
  category: bytesio
  kind: python_call_eq
  function: BytesIO
  args: []
  method: closed
  expected: false

invariant io_extra334.BytesIO.close_returns_none:
  description: "io.BytesIO().close() returns None — close() has no return value"
  category: bytesio
  kind: python_call_eq
  function: BytesIO
  args: []
  method: close
  method_chain: __class__.__name__
  expected: "NoneType"

# ---------------------------------------------------------------------------
# StringIO — read, seek, closed
#
# Verified on Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12:
#   io.StringIO('hello').read().__eq__('hello') == True
#   io.StringIO('hello').seek(0) == 0
#   io.StringIO().closed == False
# ---------------------------------------------------------------------------

invariant io_extra334.StringIO.read_hello:
  description: "io.StringIO('hello').read().__eq__('hello') == True — read() returns the full string from position 0"
  category: stringio
  kind: python_call_eq
  function: StringIO
  args: ["hello"]
  method: read
  method_chain: __eq__
  method_chain_args: ["hello"]
  expected: true

invariant io_extra334.StringIO.seek_returns_position:
  description: "io.StringIO('hello').seek(0) == 0 — seek(0) returns 0"
  category: stringio
  kind: python_call_eq
  function: StringIO
  args: ["hello"]
  method: seek
  method_args: [0]
  expected: 0

invariant io_extra334.StringIO.closed_false:
  description: "io.StringIO().closed == False — a freshly created StringIO is not closed"
  category: stringio
  kind: python_call_eq
  function: StringIO
  args: []
  method: closed
  expected: false
