spec: pretty_ms
version: ">=9.3.0"
backend: node(pretty-ms)

docs: https://www.npmjs.com/package/pretty-ms

provenance:
  derived_from:
    - "pretty-ms README — https://www.npmjs.com/package/pretty-ms"
    - "Test vectors verified with pretty-ms via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "pretty-ms source"
  notes:
    - "pretty-ms is an npm package. Install: npm install pretty-ms"
    - "Converts milliseconds to a human-readable string. ESM package; use function: default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a human-readable duration string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table pretty_ms.prettyMs:
  kind: node_module_call_eq
  function: "default"
  category: format
  id_prefix: prettyms

  columns: [id, args, expected]
  rows:
    - [seconds, [1000],    "1s"]
    - [minutes, [60000],   "1m"]
    - [hours,   [3600000], "1h"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:51:27Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
