spec: is_absolute_url
version: ">=5.0.0"
backend: node(is-absolute-url)

docs: https://www.npmjs.com/package/is-absolute-url

provenance:
  derived_from:
    - "is-absolute-url README — https://www.npmjs.com/package/is-absolute-url"
    - "Test vectors verified with is-absolute-url via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-absolute-url source"
  notes:
    - "is-absolute-url is an npm package. Install: npm install is-absolute-url"
    - "Returns true if the URL is absolute (has a scheme). ESM package; use function: default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_absolute_url.isAbsoluteUrl:
  kind: node_module_call_eq
  function: "default"
  category: validate
  id_prefix: isabsurl

  columns: [id, args, expected]
  rows:
    - [http_url,    ["http://foo.com"],   true]
    - [https_url,   ["https://bar.org"],  true]
    - [root_path,   ["/foo/bar"],         false]
    - [rel_path,    ["./foo"],            false]
