# __eq__==__ne__ (6): a 2-way tie; both have len==6
# ---------------------------------------------------------------------------

table decimal_extra174.equality_cmp_method_names:
  description: "decimal.Decimal equality/inequality comparison dunder names: __eq__.__name__=='__eq__' (len=6); __ne__.__name__=='__ne__' (len=6); __eq__==__ne__ (6): a 2-way tie, part of the 6-way tie across all comparison dunders"
  kind: python_call_eq
  category: identity
  id_prefix: decimalcmp174

  columns: [id, function, args, expected, description]
  rows:
    - [eq_name,      "Decimal.__eq__.__name__.__eq__",      ["__eq__"], true, "decimal.Decimal.__eq__.__name__ == '__eq__' — __eq__ implements the == operator for Decimal; '__eq__' has 6 characters: _(1)_(2)e(3)q(4)_(5)_(6); __eq__ (6) is part of the 6-way tie at length 6 among all comparison dunders; confirmed Python 3.14.3 macOS"]
    - [eq_name_len,  "Decimal.__eq__.__name__.__len__",     [],         6,    "decimal.Decimal.__eq__.__name__.__len__() == 6 — '__eq__' has 6 characters; __eq__ (6) == __ne__ (6) == __lt__ (6) == __le__ (6) == __gt__ (6) == __ge__ (6): a 6-way tie; __eq__ (6) < __str__ (7) < __hash__ (8): the full length ordering; confirmed Python 3.14.3 macOS"]
    - [ne_name,      "Decimal.__ne__.__name__.__eq__",      ["__ne__"], true, "decimal.Decimal.__ne__.__name__ == '__ne__' — __ne__ implements the != operator for Decimal; '__ne__' has 6 characters: _(1)_(2)n(3)e(4)_(5)_(6); __ne__ (6) == __eq__ (6): both equality-testing dunders share length 6; confirmed Python 3.14.3 macOS"]
    - [ne_name_len,  "Decimal.__ne__.__name__.__len__",     [],         6,    "decimal.Decimal.__ne__.__name__.__len__() == 6 — '__ne__' has 6 characters; __ne__ (6) == __eq__ (6): both share length 6 as part of the 6-way tie across all six comparison dunders; confirmed Python 3.14.3 macOS"]
    - [eq_class,     "Decimal.__eq__.__class__.__name__.__eq__", ["wrapper_descriptor"], true, "decimal.Decimal.__eq__.__class__.__name__ == 'wrapper_descriptor' — Decimal is a C extension type so its special methods are wrapper_descriptor objects; this holds for all comparison dunders: __eq__, __ne__, __lt__, __le__, __gt__, __ge__; confirmed Python 3.14.3 macOS"]
    - [ne_class,     "Decimal.__ne__.__class__.__name__.__eq__", ["wrapper_descriptor"], true, "decimal.Decimal.__ne__.__class__.__name__ == 'wrapper_descriptor' — __ne__ is a C wrapper_descriptor like __eq__; all six comparison dunders share the wrapper_descriptor class; confirmed Python 3.14.3 macOS"]

