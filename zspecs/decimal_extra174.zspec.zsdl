spec: decimal_extra174
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal comparison method names — __eq__, __ne__, __lt__, __le__, __gt__, __ge__, __hash__, __str__."
    - "decimal.Decimal.__eq__.__name__ == '__eq__' (len=6); __ne__ (6); __lt__ (6); __le__ (6); __gt__ (6); __ge__ (6): a 6-way tie at length 6."
    - "All six comparison dunders (__eq__, __ne__, __lt__, __le__, __gt__, __ge__) have len==6: a 6-way tie."
    - "decimal.Decimal.__hash__.__name__ == '__hash__' (len=8); __str__.__name__ == '__str__' (len=7)."
    - "Length groupings: __eq__==__ne__==__lt__==__le__==__gt__==__ge__ (6); __str__ (7); __hash__ (8)."
    - "__str__ (7) > all comparison dunders (6) by 1; __hash__ (8) > __str__ (7) by 1."
    - "Length ordering: __eq__==__ne__==__lt__==__le__==__gt__==__ge__ (6) < __str__ (7) < __hash__ (8)."
    - "decimal.Decimal is implemented in C so its special methods are wrapper_descriptor objects."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

