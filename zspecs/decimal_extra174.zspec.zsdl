table decimal_extra174.ordering_cmp_method_names:
  description: "decimal.Decimal ordering comparison dunder names: __lt__.__name__=='__lt__' (len=6); __le__.__name__=='__le__' (len=6); __gt__.__name__=='__gt__' (len=6); __ge__.__name__=='__ge__' (len=6); all four share length 6 — together with __eq__ and __ne__ form a 6-way tie"
  kind: python_call_eq
