  id_prefix: decimalcmp174

  columns: [id, function, args, expected, description]
  rows:
    - [lt_name,      "Decimal.__lt__.__name__.__eq__",      ["__lt__"], true, "decimal.Decimal.__lt__.__name__ == '__lt__' — __lt__ implements the < operator for Decimal; '__lt__' has 6 characters: _(1)_(2)l(3)t(4)_(5)_(6); __lt__ (6) == __le__ (6) == __gt__ (6) == __ge__ (6): a 4-way tie among ordering operators, completing the 6-way tie with __eq__ and __ne__; confirmed Python 3.14.3 macOS"]
    - [lt_name_len,  "Decimal.__lt__.__name__.__len__",     [],         6,    "decimal.Decimal.__lt__.__name__.__len__() == 6 — '__lt__' has 6 characters; __lt__ (6) is part of the 6-way tie: __eq__==__ne__==__lt__==__le__==__gt__==__ge__ (6); __lt__ (6) < __str__ (7): the comparison dunders are shorter than __str__; confirmed Python 3.14.3 macOS"]
    - [le_name,      "Decimal.__le__.__name__.__eq__",      ["__le__"], true, "decimal.Decimal.__le__.__name__ == '__le__' — __le__ implements the <= operator for Decimal; '__le__' has 6 characters: _(1)_(2)l(3)e(4)_(5)_(6); __le__ (6) == __lt__ (6): both lower-bound ordering operators share length 6; confirmed Python 3.14.3 macOS"]
    - [le_name_len,  "Decimal.__le__.__name__.__len__",     [],         6,    "decimal.Decimal.__le__.__name__.__len__() == 6 — '__le__' has 6 characters; __le__ (6) == __lt__ (6) == __gt__ (6) == __ge__ (6) == __eq__ (6) == __ne__ (6): the 6-way tie at length 6; confirmed Python 3.14.3 macOS"]
    - [gt_name,      "Decimal.__gt__.__name__.__eq__",      ["__gt__"], true, "decimal.Decimal.__gt__.__name__ == '__gt__' — __gt__ implements the > operator for Decimal; '__gt__' has 6 characters: _(1)_(2)g(3)t(4)_(5)_(6); __gt__ (6) == __ge__ (6): both upper-bound ordering operators share length 6; confirmed Python 3.14.3 macOS"]
    - [gt_name_len,  "Decimal.__gt__.__name__.__len__",     [],         6,    "decimal.Decimal.__gt__.__name__.__len__() == 6 — '__gt__' has 6 characters; __gt__ (6) is part of the 6-way tie; __gt__ (6) < __str__ (7) < __hash__ (8); confirmed Python 3.14.3 macOS"]
    - [ge_name,      "Decimal.__ge__.__name__.__eq__",      ["__ge__"], true, "decimal.Decimal.__ge__.__name__ == '__ge__' — __ge__ implements the >= operator for Decimal; '__ge__' has 6 characters: _(1)_(2)g(3)e(4)_(5)_(6); __ge__ (6) == __gt__ (6): both share length 6, completing the 6-way tie with __eq__, __ne__, __lt__, __le__; confirmed Python 3.14.3 macOS"]
    - [ge_name_len,  "Decimal.__ge__.__name__.__len__",     [],         6,    "decimal.Decimal.__ge__.__name__.__len__() == 6 — '__ge__' has 6 characters; __ge__ (6) completes the 6-way tie: __eq__==__ne__==__lt__==__le__==__gt__==__ge__ all have length 6; __ge__ (6) < __str__ (7) < __hash__ (8); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
