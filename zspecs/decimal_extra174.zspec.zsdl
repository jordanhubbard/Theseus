table decimal_extra174.hash_and_str_method_names:
  description: "decimal.Decimal __hash__ and __str__ method names: __hash__.__name__=='__hash__' (len=8); __str__.__name__=='__str__' (len=7); comparison dunders (6) < __str__ (7) < __hash__ (8): a strict ascending order"
  kind: python_call_eq
  category: identity
  id_prefix: decimalcmp174

  columns: [id, function, args, expected, description]
  rows:
    - [str_name,      "Decimal.__str__.__name__.__eq__",           ["__str__"],  true, "decimal.Decimal.__str__.__name__ == '__str__' — __str__ implements str() conversion for Decimal; '__str__' has 7 characters: _(1)_(2)s(3)t(4)r(5)_(6)_(7); __str__ (7) > all comparison dunders (6) by 1: __str__ is longer than all six comparison dunders; __str__ (7) < __hash__ (8) by 1; confirmed Python 3.14.3 macOS"]
    - [str_name_len,  "Decimal.__str__.__name__.__len__",          [],           7,    "decimal.Decimal.__str__.__name__.__len__() == 7 — '__str__' has 7 characters; __eq__==__ne__==__lt__==__le__==__gt__==__ge__ (6) < __str__ (7) < __hash__ (8): __str__ is strictly between the comparison dunders and __hash__ in the length ordering; confirmed Python 3.14.3 macOS"]
    - [hash_name,     "Decimal.__hash__.__name__.__eq__",          ["__hash__"], true, "decimal.Decimal.__hash__.__name__ == '__hash__' — __hash__ implements the hash() built-in for Decimal; '__hash__' has 8 characters: _(1)_(2)h(3)a(4)s(5)h(6)_(7)_(8); __hash__ (8) is the longest dunder name covered; __hash__ (8) > __str__ (7) > comparison dunders (6): a strict ordering; confirmed Python 3.14.3 macOS"]
    - [hash_name_len, "Decimal.__hash__.__name__.__len__",         [],           8,    "decimal.Decimal.__hash__.__name__.__len__() == 8 — '__hash__' has 8 characters; __hash__ (8) is the maximum in the ordering: comparison dunders (6) < __str__ (7) < __hash__ (8); __hash__ (8) > __str__ (7) by 1; confirmed Python 3.14.3 macOS"]
    - [str_class,     "Decimal.__str__.__class__.__name__.__eq__",  ["wrapper_descriptor"], true, "decimal.Decimal.__str__.__class__.__name__ == 'wrapper_descriptor' — __str__ is a C wrapper_descriptor; Decimal is a C extension type so all its special methods, including comparison dunders, __hash__, and __str__, are wrapper_descriptor objects; confirmed Python 3.14.3 macOS"]
    - [hash_class,    "Decimal.__hash__.__class__.__name__.__eq__", ["wrapper_descriptor"], true, "decimal.Decimal.__hash__.__class__.__name__ == 'wrapper_descriptor' — __hash__ is a C wrapper_descriptor; __hash__ (len=8) and __str__ (len=7) both share the wrapper_descriptor class with the six comparison dunders (len=6); confirmed Python 3.14.3 macOS"]

