    - ["re2101014", "re.Match.__dict__.__contains__", ["__mro_entries__"], false]
    - ["re2101015", "re.RegexFlag.__dict__.__contains__", ["__mro_entries__"], false]
    - ["re2101016", "re.error.__dict__.__contains__", ["__mro_entries__"], false]

