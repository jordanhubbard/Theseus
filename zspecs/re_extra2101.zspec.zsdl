  category: dict_contains
  id_prefix: re2101

  columns: [id, function, args, expected]
  rows:
    - ["re2101005", "re.Pattern.__dict__.__contains__", ["__init_subclass__"], false]
    - ["re2101006", "re.Match.__dict__.__contains__", ["__init_subclass__"], false]
    - ["re2101007", "re.RegexFlag.__dict__.__contains__", ["__init_subclass__"], false]
    - ["re2101008", "re.error.__dict__.__contains__", ["__init_subclass__"], false]

