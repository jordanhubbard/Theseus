spec: re_extra2101
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/re.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2101 (re_extra2101): __class_getitem__, __init_subclass__, __subclasshook__, __mro_entries__ dict-presence checks."
    - "re.Pattern and re.Match support generic alias subscript syntax (e.g. Pattern[str], Match[str]) via __class_getitem__ in Python 3.9+."
    - "re.RegexFlag is an IntFlag enum and does NOT define __class_getitem__ in its own __dict__."
    - "re.error (PatternError in Python 3.13+) is a plain Exception subclass and does not define any of the four protocol dunders."
    - "Neither re.Pattern nor re.Match define __init_subclass__, __subclasshook__, or __mro_entries__ in their own __dict__."
    - "re.RegexFlag does not define __init_subclass__, __subclasshook__, or __mro_entries__ in its own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table re_extra2101.class_getitem_protocol:
  description: "re module classes __class_getitem__ dict-presence checks — generic alias protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2101

  columns: [id, function, args, expected]
  rows:
    - ["re2101001", "re.Pattern.__dict__.__contains__", ["__class_getitem__"], true]
    - ["re2101002", "re.Match.__dict__.__contains__", ["__class_getitem__"], true]
    - ["re2101003", "re.RegexFlag.__dict__.__contains__", ["__class_getitem__"], false]
    - ["re2101004", "re.error.__dict__.__contains__", ["__class_getitem__"], false]

table re_extra2101.init_subclass_protocol:
  description: "re module classes __init_subclass__ dict-presence checks — subclass hook protocol"
