    - ["re2101010", "re.Match.__dict__.__contains__", ["__subclasshook__"], false]
    - ["re2101011", "re.RegexFlag.__dict__.__contains__", ["__subclasshook__"], false]
    - ["re2101012", "re.error.__dict__.__contains__", ["__subclasshook__"], false]

