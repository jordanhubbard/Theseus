  id_prefix: hl661baq
  columns: [id, function, args, expected]
  rows:
    - [hl661baq001, hashlib.blake2b.block_size.__qualname__.__eq__, ["blake2b.block_size"], true]
    - [hl661baq002, hashlib.blake2b.digest_size.__qualname__.__eq__, ["blake2b.digest_size"], true]
    - [hl661baq003, hashlib.blake2b.name.__qualname__.__eq__, ["blake2b.name"], true]

