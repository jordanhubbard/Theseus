spec: hashlib_extra661
backend: python_module(hashlib)
description: "HASH object (blake2b/blake2s) additional method qualnames and descriptor class names"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib HASH object attributes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Covers getset_descriptor class names and __qualname__ strings for blake2b and blake2s attributes"]
  created_at: "2026-04-12T00:00:00Z"

table hashlib_extra661.blake2b_attr_class_names:
  description: "Class names of blake2b attribute descriptors"
  kind: python_call_eq
  category: descriptor_identity
  id_prefix: hl661bac
  columns: [id, function, args, expected]
  rows:
    - [hl661bac001, hashlib.blake2b.block_size.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [hl661bac002, hashlib.blake2b.digest_size.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [hl661bac003, hashlib.blake2b.name.__class__.__name__.__eq__, ["getset_descriptor"], true]

table hashlib_extra661.blake2s_attr_class_names:
  description: "Class names of blake2s attribute descriptors"
  kind: python_call_eq
  category: descriptor_identity
  id_prefix: hl661sac
  columns: [id, function, args, expected]
  rows:
    - [hl661sac001, hashlib.blake2s.block_size.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [hl661sac002, hashlib.blake2s.digest_size.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [hl661sac003, hashlib.blake2s.name.__class__.__name__.__eq__, ["getset_descriptor"], true]

table hashlib_extra661.blake2b_attr_qualnames:
  description: "Qualified names of blake2b attribute descriptors"
  kind: python_call_eq
