spec: io_extra280
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/io.py"
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "io.FileIO.__name__ == 'FileIO' and __module__ == '_io' — FileIO is defined in the C extension _io."
    - "io.FileIO.__bases__[0].__name__ == '_RawIOBase' — FileIO inherits from C-level _RawIOBase."
    - "io.FileIO.__class__.__name__ == 'type' — FileIO is a plain C type, not wrapped in ABCMeta."
    - "io.BufferedReader.__name__ == 'BufferedReader' and __module__ == '_io' — defined in the C extension."
    - "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' — BufferedReader inherits from C-level _BufferedIOBase."
    - "io.BufferedWriter.__name__ == 'BufferedWriter' and __module__ == '_io' — defined in the C extension."
    - "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' — BufferedWriter inherits from C-level _BufferedIOBase."
    - "io.TextIOWrapper.__name__ == 'TextIOWrapper' and __module__ == '_io' — defined in the C extension."
    - "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' — TextIOWrapper inherits from C-level _TextIOBase."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: io.FileIO class identity
# ---------------------------------------------------------------------------

table io_extra280.fileio_class_identity:
  description: "io.FileIO __name__, __module__, __bases__[0].__name__, and __class__.__name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: fio

  columns: [id, function, args, expected, description]
  rows:
    - [name,       FileIO.__name__.__eq__,                   ["FileIO"],       true, "io.FileIO.__name__ == 'FileIO'"]
    - [module,     FileIO.__module__.__eq__,                 ["_io"],          true, "io.FileIO.__module__ == '_io' — defined in C extension"]
    - [base_name,  "FileIO.__bases__[0].__name__.__eq__",    ["_RawIOBase"],   true, "io.FileIO.__bases__[0].__name__ == '_RawIOBase'"]
    - [metaclass,  FileIO.__class__.__name__.__eq__,         ["type"],         true, "io.FileIO.__class__.__name__ == 'type' — plain C type"]

# ---------------------------------------------------------------------------
# Table: io.BufferedReader and io.BufferedWriter class identity
# ---------------------------------------------------------------------------

table io_extra280.buffered_rw_class_identity:
  description: "io.BufferedReader and io.BufferedWriter __name__, __module__, __bases__[0].__name__, and __class__.__name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: brw

  columns: [id, function, args, expected, description]
  rows:
    - [br_name,      BufferedReader.__name__.__eq__,                   ["BufferedReader"],   true, "io.BufferedReader.__name__ == 'BufferedReader'"]
    - [br_module,    BufferedReader.__module__.__eq__,                 ["_io"],              true, "io.BufferedReader.__module__ == '_io' — defined in C extension"]
    - [br_base,      "BufferedReader.__bases__[0].__name__.__eq__",    ["_BufferedIOBase"],  true, "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase'"]
    - [br_meta,      BufferedReader.__class__.__name__.__eq__,         ["type"],             true, "io.BufferedReader.__class__.__name__ == 'type' — plain C type"]
    - [bw_name,      BufferedWriter.__name__.__eq__,                   ["BufferedWriter"],   true, "io.BufferedWriter.__name__ == 'BufferedWriter'"]
    - [bw_module,    BufferedWriter.__module__.__eq__,                 ["_io"],              true, "io.BufferedWriter.__module__ == '_io' — defined in C extension"]
    - [bw_base,      "BufferedWriter.__bases__[0].__name__.__eq__",    ["_BufferedIOBase"],  true, "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase'"]
    - [bw_meta,      BufferedWriter.__class__.__name__.__eq__,         ["type"],             true, "io.BufferedWriter.__class__.__name__ == 'type' — plain C type"]

# ---------------------------------------------------------------------------
# Standalone invariants: io.TextIOWrapper and io.FileIO additional checks
# ---------------------------------------------------------------------------

invariant io_extra280.TextIOWrapper.name:
  description: "io.TextIOWrapper.__name__ == 'TextIOWrapper'"
  category: identity
  kind: python_call_eq
  function: TextIOWrapper.__name__.__eq__
  args: ["TextIOWrapper"]
  expected: true

invariant io_extra280.TextIOWrapper.module:
  description: "io.TextIOWrapper.__module__ == '_io' — TextIOWrapper is defined in the C extension _io"
  category: identity
  kind: python_call_eq
  function: TextIOWrapper.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra280.TextIOWrapper.base_name:
  description: "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' — inherits from C-level _TextIOBase"
  category: identity
  kind: python_call_eq
  function: "TextIOWrapper.__bases__[0].__name__.__eq__"
  args: ["_TextIOBase"]
  expected: true

invariant io_extra280.TextIOWrapper.metaclass:
  description: "io.TextIOWrapper.__class__.__name__ == 'type' — TextIOWrapper is a plain C type"
  category: identity
  kind: python_call_eq
  function: TextIOWrapper.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant io_extra280.FileIO.name:
  description: "io.FileIO.__name__ == 'FileIO'"
  category: identity
  kind: python_call_eq
  function: FileIO.__name__.__eq__
  args: ["FileIO"]
  expected: true

invariant io_extra280.FileIO.module:
  description: "io.FileIO.__module__ == '_io' — FileIO is defined in the C extension, not the io wrapper"
  category: identity
  kind: python_call_eq
  function: FileIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra280.BufferedReader.name:
  description: "io.BufferedReader.__name__ == 'BufferedReader'"
  category: identity
  kind: python_call_eq
  function: BufferedReader.__name__.__eq__
  args: ["BufferedReader"]
  expected: true

invariant io_extra280.BufferedWriter.name:
  description: "io.BufferedWriter.__name__ == 'BufferedWriter'"
  category: identity
  kind: python_call_eq
  function: BufferedWriter.__name__.__eq__
  args: ["BufferedWriter"]
  expected: true
