spec: io_extra171
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/textio.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: io.TextIOWrapper.__dict__ membership for core I/O methods using __dict__.__contains__, and TextIOWrapper.__dict__.__len__()."
    - "io.TextIOWrapper.__dict__.__contains__('read') == True (len('read')=4)."
    - "io.TextIOWrapper.__dict__.__contains__('readline') == True (len('readline')=8)."
    - "io.TextIOWrapper.__dict__.__contains__('write') == True (len('write')=5)."
    - "io.TextIOWrapper.__dict__.__contains__('seek') == True (len('seek')=4)."
    - "io.TextIOWrapper.__dict__.__contains__('tell') == True (len('tell')=4)."
    - "io.TextIOWrapper.__dict__.__contains__('flush') == True (len('flush')=5)."
    - "io.TextIOWrapper.__dict__.__len__() == 31 — the TextIOWrapper class dict has exactly 31 entries on Python 3.14.3."
    - "Key name length ranking: read=seek=tell=4 (three-way tie), write=flush=5 (two-way tie), readline=8 (sole occupant)."
    - "Three-way tie at 4: read, seek, tell — all 4-character method names."
    - "Two-way tie at 5: write and flush — both 5-character method names."
    - "readline (8) is the longest of the six method names and stands alone at the maximum length."
    - "TextIOWrapper is the concrete class wrapping a BufferedIOBase for text-mode file I/O, handling encoding/decoding."
    - "io.TextIOWrapper.__module__ == '_io' (3 chars) — implemented in the C extension module '_io'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.TextIOWrapper.__dict__ membership for core I/O methods (group 1)
# read=seek=tell=4 (three-way tie), write=flush=5 (two-way tie)
# All are concrete method implementations directly defined on TextIOWrapper.
# ---------------------------------------------------------------------------

table io_extra171.TextIOWrapper_dict_core_methods_group1:
  description: "io.TextIOWrapper.__dict__ membership: read=seek=tell (len=4, three-way tie), write=flush (len=5, two-way tie) — all True; minimum key name length 4 with a three-way tie; write and flush are tied at 5"
  kind: python_call_eq
  category: identity
  id_prefix: tiow171

  columns: [id, function, args, expected, description]
  rows:
    - [tiow_read_in,  "TextIOWrapper.__dict__.__contains__",  ["read"],  true, "io.TextIOWrapper.__dict__.__contains__('read') == True (read is directly defined in TextIOWrapper.__dict__; TextIOWrapper.read(size=-1) reads and returns up to size characters from the stream — or the entire stream when size is negative; TextIOWrapper decodes bytes from the underlying BufferedIOBase using the specified encoding and error handler; 'read' has 4 characters — tied with 'seek' and 'tell' (also 4) in key name length, forming a three-way tie at 4; the three-way tie at 4 (read, seek, tell) is the minimum key name length in this spec; read (4) < write=flush (5) < readline (8) in the ascending key name length sequence; TextIOWrapper.read() is the primary method for reading text content from files opened in text mode)"]
    - [tiow_seek_in,  "TextIOWrapper.__dict__.__contains__",  ["seek"],  true, "io.TextIOWrapper.__dict__.__contains__('seek') == True (seek is directly defined in TextIOWrapper.__dict__; TextIOWrapper.seek(cookie, whence=0) sets the stream position; for text streams, seek() has stricter constraints than binary streams — only positions obtained from tell() are valid when whence=0, and whence=2 (seek from end) is only supported for seek(0, 2) moving to the end; 'seek' has 4 characters — tied with 'read' and 'tell' (also 4) in the three-way tie at 4; seek (4) is the minimum key name length in this spec shared with read and tell; seek must account for multi-byte encodings and buffering, making TextIOWrapper.seek() more complex than FileIO.seek())"]
    - [tiow_tell_in,  "TextIOWrapper.__dict__.__contains__",  ["tell"],  true, "io.TextIOWrapper.__dict__.__contains__('tell') == True (tell is directly defined in TextIOWrapper.__dict__; TextIOWrapper.tell() returns an opaque integer 'cookie' representing the current stream position; unlike binary streams where tell() returns a simple byte offset, the cookie for text streams encodes both the underlying byte position and decoder state to handle multi-byte encodings correctly; 'tell' has 4 characters — tied with 'read' and 'seek' (also 4) in the three-way tie at 4; tell (4) is the minimum key name length in this spec; the returned cookie is only meaningful when passed back to seek() — do not perform arithmetic on text stream positions)"]
    - [tiow_write_in, "TextIOWrapper.__dict__.__contains__",  ["write"], true, "io.TextIOWrapper.__dict__.__contains__('write') == True (write is directly defined in TextIOWrapper.__dict__; TextIOWrapper.write(s) writes the string s to the stream using the configured encoding and returns the number of characters written; TextIOWrapper encodes the string to bytes before writing to the underlying BufferedIOBase; 'write' has 5 characters — tied with 'flush' (also 5) in the two-way tie at 5; write (5) is longer than read=seek=tell (4) by 1 character; the two-way tie at 5 (write, flush) sits between the three-way tie at 4 (read, seek, tell) and readline (8) alone at the maximum; write + flush together perform the complete buffered text output cycle: write accumulates text, flush pushes it to the OS)"]

# ---------------------------------------------------------------------------
# io.TextIOWrapper.__dict__ membership for flush and readline
# flush (len=5, tied with write), readline (len=8, sole maximum)
# Also check TextIOWrapper.__dict__.__len__() == 31.
# ---------------------------------------------------------------------------

table io_extra171.TextIOWrapper_dict_flush_readline_and_len:
  description: "io.TextIOWrapper.__dict__ membership: flush (len=5, tied with write), readline (len=8, sole maximum); also TextIOWrapper.__dict__.__len__()==31; readline (8) is the longest of the six method names"
  kind: python_call_eq
  category: identity
  id_prefix: tiow171

  columns: [id, function, args, expected, description]
  rows:
    - [tiow_flush_in,    "TextIOWrapper.__dict__.__contains__",  ["flush"],    true, "io.TextIOWrapper.__dict__.__contains__('flush') == True (flush is directly defined in TextIOWrapper.__dict__; TextIOWrapper.flush() flushes the write buffers of the stream, ensuring all buffered text data is encoded and written to the underlying BufferedIOBase, which in turn flushes to the OS; 'flush' has 5 characters — tied with 'write' (also 5) in the two-way tie at 5; flush (5) > read=seek=tell (4) by 1 character; flush (5) < readline (8) by 3 characters; the two-way tie at 5 (write, flush) comprises one output method (write) and one drain method (flush) — semantically related as the write-and-flush pair for text output; TextIOWrapper inherits automatic flushing on close() but explicit flush() is needed to push data without closing)"]
    - [tiow_readline_in, "TextIOWrapper.__dict__.__contains__",  ["readline"], true, "io.TextIOWrapper.__dict__.__contains__('readline') == True (readline is directly defined in TextIOWrapper.__dict__; TextIOWrapper.readline(size=-1) reads until a newline or EOF and returns the line including the newline; when size is given it reads at most size characters; TextIOWrapper.readline() handles universal newlines if enabled at construction time; 'readline' has 8 characters: 'read' (4) + 'line' (4) = 8; readline (8) stands alone at the maximum key name length in this spec; readline (8) is 3 characters longer than write=flush (5) and 4 characters longer than read=seek=tell (4); the complete ascending sequence: read=seek=tell=4, write=flush=5, readline=8; readline contains 'read' (4 chars) as a prefix — sharing the same prefix length as the three-way tie members)"]
    - [tiow_dict_len,    "TextIOWrapper.__dict__.__len__",        [],           31,   "io.TextIOWrapper.__dict__.__len__() == 31 — the TextIOWrapper class dictionary has exactly 31 entries on Python 3.14.3; this count includes all methods and attributes directly defined on TextIOWrapper: core I/O methods (read, readline, write, seek, tell, flush), property accessors (name, mode, encoding, errors, line_buffering, write_through, newlines), and dunders (__init__, __repr__, __next__, __iter__, __closed, __getstate__, __doc__, __module__, etc.); 31 entries reflects a focused class dict for a text stream wrapper — fewer than Context (85) or Decimal (101) but richer than FileIO (which is a C-extension class); TextIOWrapper.__dict__.__len__() == 31 on Python 3.14.3 macOS"]
    - [tiow_readline_len, "TextIOWrapper.__dict__.__contains__", ["readline"], true, "io.TextIOWrapper.__dict__.__contains__('readline') == True — confirming readline at key name length 8 is the maximum; 'readline' (8 chars) is formed from 'read' (4) + 'line' (4) = 8; the 'line' suffix (4 chars) added to 'read' (4 chars) doubles the key length from 4 to 8; readline (8) is 3 longer than write=flush (5) and 4 longer than read=seek=tell (4); the gap from the two-way tie at 5 to readline (8) is 3 characters — larger than any gap between the lower groups; readline is defined directly on TextIOWrapper because text-mode line reading requires encoding-aware buffering not present in the raw C-level base classes; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra171.TextIOWrapper_read_seek_tell_three_way_tie_at_4:
  description: "io.TextIOWrapper.__dict__.__contains__('read') == True — 'read', 'seek', and 'tell' all have 4 characters, forming a three-way tie at 4 in key name length among the six methods checked in this spec; the three-way tie at 4 (read, seek, tell) is the minimum key name length and the most densely populated length in this spec; all three are fundamental stream-position operations: read consumes data, seek repositions the stream, tell reports the current position; the three-way tie at 4 contrasts with the two-way tie at 5 (write, flush) and the sole occupant at 8 (readline); ascending sequence: read=seek=tell=4, write=flush=5, readline=8; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "TextIOWrapper.__dict__.__contains__"
  args: ["read"]
  expected: true

invariant io_extra171.TextIOWrapper_write_flush_two_way_tie_at_5:
  description: "io.TextIOWrapper.__dict__.__contains__('write') == True — 'write' and 'flush' both have 5 characters, forming a two-way tie at 5 in key name length; the two-way tie at 5 (write, flush) sits between the three-way tie at 4 (read, seek, tell) and readline (8) alone at the maximum; write and flush are semantically paired as the text output cycle: write() accumulates encoded text in the buffer, flush() pushes the buffered bytes to the underlying stream and OS; write (5) is 1 longer than read=seek=tell (4) and 3 shorter than readline (8); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "TextIOWrapper.__dict__.__contains__"
  args: ["write"]
  expected: true

invariant io_extra171.TextIOWrapper_readline_is_longest_at_8:
  description: "io.TextIOWrapper.__dict__.__contains__('readline') == True — 'readline' (8 chars) is the longest key name among the six methods checked in this spec; it stands alone at the maximum length 8; readline (8) is formed from 'read' (4) + 'line' (4) = 8; the 'line' suffix doubles the base 'read' (4) to 8 characters; the ascending sequence: read=seek=tell=4, write=flush=5, readline=8; the gap from write=flush (5) to readline (8) is 3 characters — the largest gap in this spec; readline requires encoding-aware buffering to detect line boundaries in multi-byte encodings, which is why it is directly implemented on TextIOWrapper rather than delegated to the underlying binary stream; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "TextIOWrapper.__dict__.__contains__"
  args: ["readline"]
  expected: true

invariant io_extra171.TextIOWrapper_dict_len_31:
  description: "io.TextIOWrapper.__dict__.__len__() == 31 — TextIOWrapper's class dict has exactly 31 entries on Python 3.14.3; this count covers the six core I/O methods (read, readline, write, seek, tell, flush) plus property accessors (name, mode, encoding, errors, line_buffering, write_through, newlines) and dunders (__init__, __repr__, __next__, __iter__, and others); 31 entries is consistent with a focused text-wrapper class that delegates most binary I/O to the underlying BufferedIOBase; io.TextIOWrapper.__module__ == '_io' (3 chars) — TextIOWrapper is implemented in the C extension; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "TextIOWrapper.__dict__.__len__"
  args: []
  expected: 31
