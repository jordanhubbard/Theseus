spec: decimal_extra2641
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra.zspec.zsdl — covers existing decimal invariants"
    - "decimal_extra2626.zspec.zsdl — covers __length_hint__/__missing__/__reversed__ dict-presence"
  notes:
    - "Wave 623 (decimal_extra2641) theme: __copy__, __deepcopy__, and __sizeof__ dict-presence checks."
    - "decimal.Decimal defines __copy__, __deepcopy__, AND __sizeof__ in its own __dict__."
    - "decimal.Context defines __copy__ in its own __dict__ but NOT __deepcopy__ or __sizeof__."
    - "decimal.DecimalException defines none of __copy__, __deepcopy__, or __sizeof__ in its own __dict__."
    - "decimal.Decimal.__copy__ and __deepcopy__ ensure proper copy semantics for immutable arbitrary-precision numbers."
    - "decimal.Decimal.__sizeof__ provides accurate memory sizing for the variable-length C structure."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __copy__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2641.copy_in_decimal_classes:
  description: "__copy__ IS defined in decimal.Decimal and decimal.Context __dict__s but absent from decimal.DecimalException"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2641

  columns: [id, function, args, expected]
  rows:
    - ["dc2641001", "decimal.Decimal.__dict__.__contains__",          ["__copy__"], true]
    - ["dc2641002", "decimal.Context.__dict__.__contains__",          ["__copy__"], true]
    - ["dc2641003", "decimal.DecimalException.__dict__.__contains__", ["__copy__"], false]

# ---------------------------------------------------------------------------
# __deepcopy__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2641.deepcopy_in_decimal_classes:
  description: "__deepcopy__ IS defined in decimal.Decimal __dict__ but absent from decimal.Context and decimal.DecimalException"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2641

  columns: [id, function, args, expected]
  rows:
    - ["dc2641004", "decimal.Decimal.__dict__.__contains__",          ["__deepcopy__"], true]
    - ["dc2641005", "decimal.Context.__dict__.__contains__",          ["__deepcopy__"], false]
    - ["dc2641006", "decimal.DecimalException.__dict__.__contains__", ["__deepcopy__"], false]

# ---------------------------------------------------------------------------
# __sizeof__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2641.sizeof_in_decimal_classes:
  description: "__sizeof__ IS defined in decimal.Decimal __dict__ but absent from decimal.Context and decimal.DecimalException"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2641

  columns: [id, function, args, expected]
  rows:
    - ["dc2641007", "decimal.Decimal.__dict__.__contains__",          ["__sizeof__"], true]
    - ["dc2641008", "decimal.Context.__dict__.__contains__",          ["__sizeof__"], false]
    - ["dc2641009", "decimal.DecimalException.__dict__.__contains__", ["__sizeof__"], false]

# ---------------------------------------------------------------------------
# Complementary: decimal.Decimal has arithmetic methods AND copy/sizeof hooks
# Confirms that Decimal is a richly-implemented numeric type with full protocol support
# ---------------------------------------------------------------------------

table decimal_extra2641.decimal_arithmetic_and_copy_hooks:
  description: "decimal.Decimal defines __new__/__add__/real/sqrt AND __copy__/__deepcopy__/__sizeof__; decimal.Context defines prec/rounding/create_decimal AND __copy__ but NOT __deepcopy__ or __sizeof__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2641

  columns: [id, function, args, expected]
  rows:
    - ["dc2641010", "decimal.Decimal.__dict__.__contains__", ["__new__"],      true]
    - ["dc2641011", "decimal.Decimal.__dict__.__contains__", ["__add__"],      true]
    - ["dc2641012", "decimal.Decimal.__dict__.__contains__", ["real"],         true]
    - ["dc2641013", "decimal.Decimal.__dict__.__contains__", ["sqrt"],         true]
    - ["dc2641014", "decimal.Decimal.__dict__.__contains__", ["__copy__"],     true]
    - ["dc2641015", "decimal.Decimal.__dict__.__contains__", ["__deepcopy__"], true]
    - ["dc2641016", "decimal.Decimal.__dict__.__contains__", ["__sizeof__"],   true]
    - ["dc2641017", "decimal.Context.__dict__.__contains__", ["prec"],         true]
    - ["dc2641018", "decimal.Context.__dict__.__contains__", ["rounding"],     true]
    - ["dc2641019", "decimal.Context.__dict__.__contains__", ["create_decimal"], true]
    - ["dc2641020", "decimal.Context.__dict__.__contains__", ["__copy__"],     true]
    - ["dc2641021", "decimal.Context.__dict__.__contains__", ["__deepcopy__"], false]
    - ["dc2641022", "decimal.Context.__dict__.__contains__", ["__sizeof__"],   false]
