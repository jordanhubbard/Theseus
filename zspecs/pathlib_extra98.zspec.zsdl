spec: pathlib_extra98
version: ">=3.9"
backend: python_module(pathlib)
extends: pathlib_extra97

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends pathlib_extra97.zspec.zsdl."
    - "This spec covers: pathlib.Path method __qualname__ lengths for key methods grouped by length."
    - "Path.absolute.__qualname__ = 'Path.absolute' (len=13)."
    - "Path.resolve.__qualname__ = 'Path.resolve' (len=12)."
    - "Path.symlink_to.__qualname__ = 'Path.symlink_to' (len=15)."
    - "Path.hardlink_to.__qualname__ = 'Path.hardlink_to' (len=16)."
    - "Path.touch.__qualname__ = 'Path.touch' (len=10)."
    - "Path.iterdir.__qualname__ = 'Path.iterdir' (len=12)."
    - "Path.is_file.__qualname__ = 'Path.is_file' (len=12)."
    - "Path.is_dir.__qualname__ = 'Path.is_dir' (len=11)."
    - "Path.is_symlink.__qualname__ = 'Path.is_symlink' (len=15)."
    - "Path.is_absolute.__qualname__ = 'PurePath.is_absolute' (len=20) — is_absolute is defined on PurePath."
    - "Path.mkdir.__qualname__ = 'Path.mkdir' (len=10)."
    - "Path.rmdir.__qualname__ = 'Path.rmdir' (len=10)."
    - "Path.unlink.__qualname__ = 'Path.unlink' (len=11)."
    - "Path.rename.__qualname__ = 'Path.rename' (len=11)."
    - "Path.replace.__qualname__ = 'Path.replace' (len=12)."
    - "Path.open.__qualname__ = 'Path.open' (len=9)."
    - "Path.read_text.__qualname__ = 'Path.read_text' (len=14)."
    - "Path.write_text.__qualname__ = 'Path.write_text' (len=15)."
    - "Path.read_bytes.__qualname__ = 'Path.read_bytes' (len=15)."
    - "Path.write_bytes.__qualname__ = 'Path.write_bytes' (len=16)."
    - "Path.stat.__qualname__ = 'Path.stat' (len=9)."
    - "Path.exists.__qualname__ = 'Path.exists' (len=11)."
    - "Path.glob.__qualname__ = 'Path.glob' (len=9)."
    - "Path.rglob.__qualname__ = 'Path.rglob' (len=10)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path method __qualname__ lengths: length-9 and length-10 group
# open/stat/glob have len=9; touch/mkdir/rmdir/rglob have len=10.
# ---------------------------------------------------------------------------

table pathlib_extra98.Path_qualname_len_9_10:
  description: "pathlib.Path method __qualname__ lengths for len-9 (open/stat/glob) and len-10 (touch/mkdir/rmdir/rglob) groups"
  kind: python_call_eq
  category: qualname
  id_prefix: pathlibpathqlen98

  columns: [id, function, args, expected]
  rows:
    - [path_open_qlen,   Path.open.__qualname__.__len__,   [], 9]
    - [path_stat_qlen,   Path.stat.__qualname__.__len__,   [], 9]
    - [path_glob_qlen,   Path.glob.__qualname__.__len__,   [], 9]
    - [path_touch_qlen,  Path.touch.__qualname__.__len__,  [], 10]
    - [path_mkdir_qlen,  Path.mkdir.__qualname__.__len__,  [], 10]
    - [path_rmdir_qlen,  Path.rmdir.__qualname__.__len__,  [], 10]
    - [path_rglob_qlen,  Path.rglob.__qualname__.__len__,  [], 10]

# ---------------------------------------------------------------------------
# pathlib.Path method __qualname__ lengths: length-11 and length-12 group
# is_dir/unlink/rename/exists have len=11; resolve/iterdir/is_file/replace have len=12.
# ---------------------------------------------------------------------------

table pathlib_extra98.Path_qualname_len_11_12:
  description: "pathlib.Path method __qualname__ lengths for len-11 (is_dir/unlink/rename/exists) and len-12 (resolve/iterdir/is_file/replace) groups"
  kind: python_call_eq
  category: qualname
  id_prefix: pathlibpathqlen98

  columns: [id, function, args, expected]
  rows:
    - [path_is_dir_qlen,  Path.is_dir.__qualname__.__len__,  [], 11]
    - [path_unlink_qlen,  Path.unlink.__qualname__.__len__,  [], 11]
    - [path_rename_qlen,  Path.rename.__qualname__.__len__,  [], 11]
    - [path_exists_qlen,  Path.exists.__qualname__.__len__,  [], 11]
    - [path_resolve_qlen, Path.resolve.__qualname__.__len__, [], 12]
    - [path_iterdir_qlen, Path.iterdir.__qualname__.__len__, [], 12]
    - [path_is_file_qlen, Path.is_file.__qualname__.__len__, [], 12]
    - [path_replace_qlen, Path.replace.__qualname__.__len__, [], 12]

# ---------------------------------------------------------------------------
# pathlib.Path method __qualname__ lengths: length-13 through length-16 group
# absolute=13, read_text=14, symlink_to/is_symlink/write_text/read_bytes=15,
# hardlink_to/write_bytes=16.
# ---------------------------------------------------------------------------

table pathlib_extra98.Path_qualname_len_13_to_16:
  description: "pathlib.Path method __qualname__ lengths for len 13-16 group"
  kind: python_call_eq
  category: qualname
  id_prefix: pathlibpathqlen98

  columns: [id, function, args, expected]
  rows:
    - [path_absolute_qlen,    Path.absolute.__qualname__.__len__,    [], 13]
    - [path_read_text_qlen,   Path.read_text.__qualname__.__len__,   [], 14]
    - [path_symlink_to_qlen,  Path.symlink_to.__qualname__.__len__,  [], 15]
    - [path_is_symlink_qlen,  Path.is_symlink.__qualname__.__len__,  [], 15]
    - [path_write_text_qlen,  Path.write_text.__qualname__.__len__,  [], 15]
    - [path_read_bytes_qlen,  Path.read_bytes.__qualname__.__len__,  [], 15]
    - [path_hardlink_to_qlen, Path.hardlink_to.__qualname__.__len__, [], 16]
    - [path_write_bytes_qlen, Path.write_bytes.__qualname__.__len__, [], 16]

# ---------------------------------------------------------------------------
# pathlib.Path.is_absolute via PurePath: __qualname__ length is 20
# is_absolute is defined on PurePath, so its qualname is 'PurePath.is_absolute' (len=20).
# Cross-checks: hardlink_to and write_bytes share len=16; symlink_to < hardlink_to.
# ---------------------------------------------------------------------------

table pathlib_extra98.Path_is_absolute_purepath_cross_checks:
  description: "PurePath.is_absolute __qualname__ length (20) and cross-checks"
  kind: python_call_eq
  category: qualname
  id_prefix: pathlibpathqlen98

  columns: [id, function, args, expected]
  rows:
    - [is_absolute_qlen,     Path.is_absolute.__qualname__.__len__,  [], 20]
    - [hardlink_write_match, Path.hardlink_to.__qualname__.__len__,  [], 16]
    - [write_bytes_xchk,     Path.write_bytes.__qualname__.__len__,  [], 16]
    - [open_stat_glob_match, Path.open.__qualname__.__len__,         [], 9]

# ---------------------------------------------------------------------------
# Standalone invariants (using __qualname__.__eq__ for full string value)
# ---------------------------------------------------------------------------

invariant pathlib_extra98.Path.absolute_qualname_eq:
  description: "pathlib.Path.absolute.__qualname__ == 'Path.absolute' (len=13, defined on Path)"
  category: qualname
  kind: python_call_eq
  function: Path.absolute.__qualname__.__eq__
  args: ["Path.absolute"]
  expected: true

invariant pathlib_extra98.Path.is_absolute_qualname_eq:
  description: "pathlib.Path.is_absolute.__qualname__ == 'PurePath.is_absolute' (len=20, defined on PurePath not Path)"
  category: qualname
  kind: python_call_eq
  function: Path.is_absolute.__qualname__.__eq__
  args: ["PurePath.is_absolute"]
  expected: true

invariant pathlib_extra98.Path.hardlink_to_qualname_eq:
  description: "pathlib.Path.hardlink_to.__qualname__ == 'Path.hardlink_to' (len=16, added in Python 3.10)"
  category: qualname
  kind: python_call_eq
  function: Path.hardlink_to.__qualname__.__eq__
  args: ["Path.hardlink_to"]
  expected: true

invariant pathlib_extra98.Path.write_bytes_qualname_eq:
  description: "pathlib.Path.write_bytes.__qualname__ == 'Path.write_bytes' (len=16)"
  category: qualname
  kind: python_call_eq
  function: Path.write_bytes.__qualname__.__eq__
  args: ["Path.write_bytes"]
  expected: true

invariant pathlib_extra98.Path.open_qualname_eq:
  description: "pathlib.Path.open.__qualname__ == 'Path.open' (len=9, shortest Path method qualname)"
  category: qualname
  kind: python_call_eq
  function: Path.open.__qualname__.__eq__
  args: ["Path.open"]
  expected: true
