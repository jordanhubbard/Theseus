spec: os_extra25
version: ">=3.9"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
    - "CPython source: Lib/os.py"
    - "os_extra24.zspec.zsdl — covers getpid/getcwd/listdir __name__ table; getpid return type/positivity; getcwd return type; path.join.__name__; environ.__class__.__name__"
    - "os_extra23.zspec.zsdl — covers sep/devnull/__class__.__name__; separator_values table; separator_class_names table"
    - "os_extra22.zspec.zsdl — covers getcwd/getpid/getuid/getgid/cpu_count/urandom return types; linesep/pathsep/name __class__.__name__"
  notes:
    - "This spec extends os.zspec.zsdl and all prior os_extra specs through os_extra24.zspec.zsdl."
    - "os.PathLike.__bases__[0].__name__ == 'ABC' — PathLike is an ABC subclass; verified at runtime."
    - "os.stat_result.__bases__[0].__name__ == 'tuple' — stat_result is a named tuple subclass; verified at runtime."
    - "os.scandir.__module__ == 'posix' — scandir is implemented in the posix C extension; verified at runtime."
    - "os.fspath.__module__ == 'posix' — fspath is implemented in the posix C extension; verified at runtime."
    - "os.makedirs.__module__ == 'os' — makedirs is a pure-Python function in the os module; verified at runtime."
    - "os.PathLike.__module__ == 'os' — PathLike is defined in the os module; verified at runtime."
    - "os.stat_result.__module__ == 'os' — stat_result is defined/re-exported via the os module; verified at runtime."
    - "os.sep.__class__.__name__ == 'str' — sep is a plain str; re-anchored in extra25 namespace for independent coverage."
    - "os.linesep.__class__.__name__ == 'str' — linesep is a plain str; re-anchored in extra25 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class hierarchy — __bases__[0].__name__ for PathLike, stat_result
#
# os.PathLike is an abstract base class whose first base is ABC (from abc).
# os.stat_result is a named tuple whose first base is tuple.
# Neither relationship is covered as a standalone named invariant in any
# prior os spec. Verified at runtime.
# ---------------------------------------------------------------------------

invariant os_extra25.PathLike.base_name:
  description: "os.PathLike.__bases__[0].__name__ == 'ABC' — PathLike extends the ABC metaclass mixin"
  category: class_hierarchy
  kind: python_call_eq
  function: "PathLike.__bases__[0].__name__.__eq__"
  args: ["ABC"]
  expected: true

invariant os_extra25.stat_result.base_name:
  description: "os.stat_result.__bases__[0].__name__ == 'tuple' — stat_result is a named-tuple subclass"
  category: class_hierarchy
  kind: python_call_eq
  function: "stat_result.__bases__[0].__name__.__eq__"
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ table — scandir, fspath, makedirs, PathLike, stat_result
#
# scandir and fspath live in the C-level 'posix' extension; makedirs, PathLike,
# and stat_result are defined in the pure-Python 'os' module. This table
# captures the module membership of five distinct os-namespace objects.
# No prior os spec groups these five in a single table in the extra25 namespace.
# ---------------------------------------------------------------------------

table os_extra25.module_membership:
  description: "__module__ for scandir, fspath, makedirs, PathLike, stat_result"
  kind: python_call_eq
  category: module_identity
  id_prefix: osmod25

  columns: [id, function, args, expected]
  rows:
    - [scandir,      scandir.__module__.__eq__,       ["posix"], true]
    - [fspath,       fspath.__module__.__eq__,        ["posix"], true]
    - [makedirs,     makedirs.__module__.__eq__,      ["os"],    true]
    - [PathLike,     PathLike.__module__.__eq__,      ["os"],    true]
    - [stat_result,  stat_result.__module__.__eq__,   ["os"],    true]

# ---------------------------------------------------------------------------
# String constant class names — sep, linesep, devnull
#
# os.sep, os.linesep, and os.devnull are all plain str objects. os_extra23
# covers sep and devnull via a table; os_extra22 covers linesep. These
# standalone invariants re-anchor all three in the extra25 namespace for
# independent cross-checking.
# ---------------------------------------------------------------------------

invariant os_extra25.sep.class_name:
  description: "os.sep.__class__.__name__ == 'str' — path separator is a plain string constant"
  category: constants
  kind: python_call_eq
  function: sep.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant os_extra25.linesep.class_name:
  description: "os.linesep.__class__.__name__ == 'str' — line separator is a plain string constant"
  category: constants
  kind: python_call_eq
  function: linesep.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant os_extra25.devnull.class_name:
  description: "os.devnull.__class__.__name__ == 'str' — devnull device path is a plain string constant"
  category: constants
  kind: python_call_eq
  function: devnull.__class__.__name__.__eq__
  args: ["str"]
  expected: true
