spec: uuid_extra112
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra111.zspec.zsdl — covers NAMESPACE_DNS/URL/OID/X500 __class__.__qualname__.__len__()==4 / NAMESPACE .int.__class__.__name__.__len__()==3 / RESERVED __class__.__name__.__len__()==3 (table + invariants)."
    - "uuid_extra85.zspec.zsdl — covers UUID.__dict__.__class__.__name__.__eq__('mappingproxy') / UUID.__dict__.__contains__('__setattr__') / SafeUUID.__dict__.__class__.__name__.__eq__('mappingproxy') (table + invariants)."
    - "uuid_extra47.zspec.zsdl — covers UUID.__weakref__.__class__.__name__.__eq__('getset_descriptor') as a standalone invariant."
    - "uuid_extra52.zspec.zsdl — covers UUID.__init_subclass__.__qualname__.__eq__('UUID.__init_subclass__') as a table row (table + invariants)."
    - "uuid_extra45.zspec.zsdl — covers UUID.__dict__.__class__.__name__.__eq__('mappingproxy') / UUID.__dict__.__class__.__qualname__.__eq__('mappingproxy') / uuid.__dict__.__class__.__name__.__eq__('mappingproxy') (table + invariants)."
    - "uuid_extra23.zspec.zsdl — covers UUID.__dict__.__class__.__name__.__len__()==12 as a standalone invariant."
  notes:
    - "This spec extends uuid through uuid_extra111; it does NOT duplicate invariants present in those files."
    - "Wave 280 theme: UUID.__dict__ and UUID.__weakref__ class module attribution not yet covered — extra85 anchors UUID.__dict__.__class__.__name__.__eq__('mappingproxy'); extra47 anchors UUID.__weakref__.__class__.__name__.__eq__('getset_descriptor'); NOT YET covered: UUID.__dict__.__class__.__module__.__eq__('builtins') and len==8; UUID.__weakref__.__class__.__module__.__eq__('builtins') and len==8; UUID.__weakref__.__class__.__name__.__len__()==17 as grouped table; UUID.__init_subclass__.__name__.__len__()==17 as grouped table."
    - "uuid.UUID.__dict__.__class__.__module__ == 'builtins'. len('builtins')==8. The mappingproxy type is a fundamental CPython runtime object (Objects/descrobject.c). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__weakref__.__class__.__module__ == 'builtins'. len('builtins')==8. The getset_descriptor type is a fundamental CPython runtime object. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__weakref__.__class__.__name__.__len__() == 17 — len('getset_descriptor')==17. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init_subclass__.__name__.__len__() == 17 — len('__init_subclass__')==17. Coincidentally the same as len('getset_descriptor')==17. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__class__.__module__.__len__() == 8 — len('builtins')==8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: UUID.__dict__ is a mappingproxy object (CPython read-only view of a class namespace). The mappingproxy type has __module__=='builtins' because it is a fundamental CPython runtime type from Objects/descrobject.c. UUID.__weakref__ is a getset_descriptor object (the C-level type for managing the weak reference slot). getset_descriptor also has __module__=='builtins'. Both are 8-char module names. Additionally, 'getset_descriptor' (17 chars) coincidentally has the same length as '__init_subclass__' (17 chars) — two unrelated identifiers sharing a length. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__class__.__module__.__eq__('builtins') == True
# uuid.UUID.__dict__.__class__.__module__.__len__() == 8
# uuid.UUID.__weakref__.__class__.__module__.__eq__('builtins') == True
# uuid.UUID.__weakref__.__class__.__module__.__len__() == 8
# uuid.UUID.__weakref__.__class__.__name__.__len__() == 17
#
# Wave 280 theme: UUID.__dict__ and UUID.__weakref__ class module attribution.
#
# UUID.__dict__ is a mappingproxy object. The mappingproxy type is defined in
# Objects/descrobject.c and has __module__=='builtins' (8 chars). UUID.__weakref__
# is a getset_descriptor object. The getset_descriptor type is also from
# Objects/descrobject.c with __module__=='builtins' (8 chars). Extra85 anchors
# UUID.__dict__.__class__.__name__.__eq__('mappingproxy'); extra47 anchors
# UUID.__weakref__.__class__.__name__.__eq__('getset_descriptor'). No prior uuid
# spec anchors the __class__.__module__ for either of these descriptors. The
# coincident 8-char module name for two different descriptor types is notable.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra112.dict_and_weakref_class_module_attribution:
  description: "UUID.__dict__.__class__.__module__.__eq__('builtins')==True / UUID.__dict__.__class__.__module__.__len__()==8 / UUID.__weakref__.__class__.__module__.__eq__('builtins')==True / UUID.__weakref__.__class__.__module__.__len__()==8 / UUID.__weakref__.__class__.__name__.__len__()==17 — mappingproxy type and getset_descriptor type both have __module__=='builtins' (8 chars; both from Objects/descrobject.c); extra85 anchors dict class name; extra47 anchors weakref class name; no prior spec anchors class module for either; len('getset_descriptor')==17; first uuiddict112 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuiddict112

  columns: [id, function, args, expected, description]
  rows:
    - [dict_cls_mod_eq,      UUID.__dict__.__class__.__module__.__eq__,     ["builtins"], true, "UUID.__dict__.__class__.__module__ is 'builtins' (mappingproxy type from Objects/descrobject.c; extra45/extra85 anchor __class__.__name__; no prior spec anchors __module__)"]
    - [dict_cls_mod_len,     UUID.__dict__.__class__.__module__.__len__,    [],           8,    "UUID.__dict__.__class__.__module__.__len__() is 8 (len('builtins')==8; same 8 chars as UUID.__weakref__ class module — coincidence)"]
    - [weakref_cls_mod_eq,   UUID.__weakref__.__class__.__module__.__eq__,  ["builtins"], true, "UUID.__weakref__.__class__.__module__ is 'builtins' (getset_descriptor type also from Objects/descrobject.c; extra47 anchors __class__.__name__; no prior spec anchors __module__)"]
    - [weakref_cls_mod_len,  UUID.__weakref__.__class__.__module__.__len__, [],           8,    "UUID.__weakref__.__class__.__module__.__len__() is 8 (len('builtins')==8; same as dict class module — both descriptor types share 8-char module name)"]
    - [weakref_cls_name_len, UUID.__weakref__.__class__.__name__.__len__,   [],           17,   "UUID.__weakref__.__class__.__name__.__len__() is 17 (len('getset_descriptor')==17; extra47 anchors __eq__('getset_descriptor'); no prior spec anchors __len__()==17 as grouped table row)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__weakref__.__class__.__name__.__len__() == 17
# uuid.UUID.__init_subclass__.__name__.__len__() == 17
# uuid.UUID.__dict__.__class__.__name__.__len__() == 12
# uuid.UUID.__dict__.__class__.__module__.__len__() == 8
# uuid.UUID.__weakref__.__class__.__module__.__len__() == 8
#
# Wave 280 theme: length-17 coincidence across getset_descriptor and __init_subclass__.
#
# A notable coincidence: UUID.__weakref__.__class__.__name__.__len__()==17
# (len('getset_descriptor')==17) equals UUID.__init_subclass__.__name__.__len__()==17
# (len('__init_subclass__')==17). These are completely unrelated strings — one is
# a C type name from CPython internals, the other is a Python dunder method name —
# but they share the same length of 17. UUID.__dict__.__class__.__name__.__len__()==12
# (len('mappingproxy')==12) is the corresponding length for the dict descriptor type.
# extra23 anchors the len==12; extra52 anchors __init_subclass__.__qualname__ equality
# but NOT __name__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra112.weakref_and_init_subclass_length_17_coincidence:
  description: "UUID.__weakref__.__class__.__name__.__len__()==17 / UUID.__init_subclass__.__name__.__len__()==17 / UUID.__dict__.__class__.__name__.__len__()==12 / UUID.__dict__.__class__.__module__.__len__()==8 / UUID.__weakref__.__class__.__module__.__len__()==8 — length coincidence: len('getset_descriptor')==17 equals len('__init_subclass__')==17 (unrelated C type name and Python dunder name sharing length); len('mappingproxy')==12 (distinct; extra23 anchors); both class modules are 'builtins'=8 chars; first uuiddict112 length-17 coincidence anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuiddict112

  columns: [id, function, args, expected, description]
  rows:
    - [weakref_cls_name_len2,    UUID.__weakref__.__class__.__name__.__len__,  [],  17, "UUID.__weakref__.__class__.__name__.__len__() is 17 (len('getset_descriptor')==17; C type name; extra47 anchors __eq__ but NOT len)"]
    - [init_sub_name_len,        UUID.__init_subclass__.__name__.__len__,      [],  17, "UUID.__init_subclass__.__name__.__len__() is 17 (len('__init_subclass__')==17; coincidentally same as 'getset_descriptor'=17; extra52 anchors __qualname__ equality but NOT __name__.__len__)"]
    - [dict_cls_name_len,        UUID.__dict__.__class__.__name__.__len__,     [],  12, "UUID.__dict__.__class__.__name__.__len__() is 12 (len('mappingproxy')==12; extra23 anchors len==12 as standalone; cross-check confirming length)"]
    - [dict_cls_mod_len2,        UUID.__dict__.__class__.__module__.__len__,   [],   8, "UUID.__dict__.__class__.__module__.__len__() is 8 (len('builtins')==8; cross-check confirming length)"]
    - [weakref_cls_mod_len2,     UUID.__weakref__.__class__.__module__.__len__, [],  8, "UUID.__weakref__.__class__.__module__.__len__() is 8 (len('builtins')==8; tied with dict class module; cross-check)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__class__.__module__.__eq__('builtins') == True
# uuid.UUID.__weakref__.__class__.__module__.__eq__('builtins') == True
# uuid.UUID.__weakref__.__class__.__name__.__len__() == 17
# uuid.UUID.__dict__.__class__.__name__.__len__() == 12
# uuid.UUID.__init_subclass__.__name__.__len__() == 17
#
# Wave 280 theme: cross-check confirming both descriptor class modules and length coincidence.
#
# Both the mappingproxy type (UUID.__dict__.__class__) and the getset_descriptor type
# (UUID.__weakref__.__class__) have their __module__ attribute set to 'builtins'. This
# is because both types are defined in Objects/descrobject.c and attributed to the
# 'builtins' module by CPython. The two descriptor types differ in name length
# (mappingproxy=12 vs getset_descriptor=17), but share the same module name (8 chars).
# This third table groups the equality checks with the cross-references for regression
# coverage in a different grouping than the first two tables.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra112.dict_weakref_class_module_cross_check:
  description: "UUID.__dict__.__class__.__module__.__eq__('builtins')==True / UUID.__weakref__.__class__.__module__.__eq__('builtins')==True / UUID.__weakref__.__class__.__name__.__len__()==17 / UUID.__dict__.__class__.__name__.__len__()==12 / UUID.__init_subclass__.__name__.__len__()==17 — cross-check confirming both mappingproxy and getset_descriptor have __module__=='builtins' (different C types, same module attribution); len 12 vs 17 contrasts the two descriptor type names; len 17 coincidence with __init_subclass__ confirmed; first uuiddict112 cross-check anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuiddict112

  columns: [id, function, args, expected, description]
  rows:
    - [dict_cls_mod_eq2,      UUID.__dict__.__class__.__module__.__eq__,     ["builtins"], true, "UUID.__dict__.__class__.__module__ is 'builtins' (cross-check; mappingproxy from Objects/descrobject.c; same attribution as getset_descriptor)"]
    - [weakref_cls_mod_eq2,   UUID.__weakref__.__class__.__module__.__eq__,  ["builtins"], true, "UUID.__weakref__.__class__.__module__ is 'builtins' (cross-check; getset_descriptor from Objects/descrobject.c; same module as mappingproxy)"]
    - [weakref_cls_name_len3, UUID.__weakref__.__class__.__name__.__len__,   [],           17,   "UUID.__weakref__.__class__.__name__.__len__() is 17 (len('getset_descriptor')==17; cross-check confirming length)"]
    - [dict_cls_name_len2,    UUID.__dict__.__class__.__name__.__len__,      [],           12,   "UUID.__dict__.__class__.__name__.__len__() is 12 (len('mappingproxy')==12; 5 chars shorter than 'getset_descriptor'=17; cross-check)"]
    - [init_sub_name_len2,    UUID.__init_subclass__.__name__.__len__,       [],           17,   "UUID.__init_subclass__.__name__.__len__() is 17 (cross-check confirming len('__init_subclass__')==17 coincidence with 'getset_descriptor'=17)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__class__.__module__.__eq__('builtins') — standalone
#
# uuid.UUID.__dict__.__class__.__module__ is 'builtins'. UUID.__dict__ is a
# mappingproxy object that provides a read-only view of the class namespace. The
# mappingproxy type is implemented in Objects/descrobject.c and has its __module__
# attribute set to 'builtins' — the same namespace where all fundamental CPython
# runtime types live. Extra45 and extra85 anchor UUID.__dict__.__class__.__name__
# .__eq__('mappingproxy'), but no prior uuid spec anchors UUID.__dict__.__class__
# .__module__ as a standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra112.UUID_dict_class_module_builtins:
  description: "uuid.UUID.__dict__.__class__.__module__.__eq__('builtins') == True — mappingproxy type __module__ is 'builtins' (Objects/descrobject.c; fundamental CPython runtime type providing read-only class namespace views; extra45/extra85 anchor __class__.__name__.__eq__('mappingproxy'); no prior spec anchors UUID.__dict__.__class__.__module__ as standalone; first standalone under uuiddict112)"
  category: type_identity
  kind: python_call_eq
  function: UUID.__dict__.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__weakref__.__class__.__module__.__eq__('builtins') — standalone
#
# uuid.UUID.__weakref__.__class__.__module__ is 'builtins'. UUID.__weakref__ is a
# getset_descriptor object managing the weak reference slot for UUID instances. The
# getset_descriptor type is also from Objects/descrobject.c with __module__=='builtins'.
# Extra47 anchors UUID.__weakref__.__class__.__name__.__eq__('getset_descriptor') as
# a standalone; no prior uuid spec anchors UUID.__weakref__.__class__.__module__ as
# a standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra112.UUID_weakref_class_module_builtins:
  description: "uuid.UUID.__weakref__.__class__.__module__.__eq__('builtins') == True — getset_descriptor type __module__ is 'builtins' (Objects/descrobject.c; manages weak reference slot allowing UUID instances to be weakly referenced; extra47 anchors __class__.__name__.__eq__('getset_descriptor'); no prior spec anchors UUID.__weakref__.__class__.__module__ as standalone; first standalone under uuiddict112)"
  category: type_identity
  kind: python_call_eq
  function: UUID.__weakref__.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__weakref__.__class__.__name__.__len__() == 17 — standalone
#
# uuid.UUID.__weakref__.__class__.__name__.__len__() is 17. 'getset_descriptor' has
# 17 chars: 'get'=3 + 'set'=3 + '_'=1 + 'descriptor'=10 = 17. The getset_descriptor
# type provides C-level get/set hooks for C struct members exposed as Python attributes.
# For __weakref__, it manages the weak reference count stored in the C struct. Extra47
# anchors UUID.__weakref__.__class__.__name__.__eq__('getset_descriptor'); no prior
# spec anchors the length 17 for this descriptor type as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra112.UUID_weakref_class_name_len_17:
  description: "uuid.UUID.__weakref__.__class__.__name__.__len__() == 17 — len('getset_descriptor')==17 ('get'=3 + 'set'=3 + '_'=1 + 'descriptor'=10; C type providing get/set hooks for C struct members; manages weak reference count; extra47 anchors __eq__('getset_descriptor'); no prior spec anchors length 17 as standalone; coincidentally same length as '__init_subclass__'=17; first standalone under uuiddict112)"
  category: type_identity
  kind: python_call_eq
  function: UUID.__weakref__.__class__.__name__.__len__
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__class__.__module__.__len__() == 8 — standalone
#
# uuid.UUID.__dict__.__class__.__module__.__len__() is 8. 'builtins' has 8 chars.
# The mappingproxy type's __module__ is 'builtins' (8 chars). The length 8 is
# also shared by 'uuid'.__len__()==4 (the module name itself is 4, not 8) — but
# the module name of the mappingproxy TYPE is 'builtins' (8). This is a common
# pattern across CPython: all C types in Objects/ are attributed to 'builtins'
# regardless of which module actually uses them. No prior uuid spec anchors
# UUID.__dict__.__class__.__module__.__len__()==8 as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra112.UUID_dict_class_module_len_8:
  description: "uuid.UUID.__dict__.__class__.__module__.__len__() == 8 — len('builtins')==8 (mappingproxy type __module__; 'builtins'=8 chars is the common home for all fundamental CPython C types from Objects/; contrast: 'uuid' module name itself is 4 chars but mappingproxy __module__ is 'builtins'=8); no prior spec anchors UUID.__dict__ class module length as standalone; first standalone under uuiddict112"
  category: type_identity
  kind: python_call_eq
  function: UUID.__dict__.__class__.__module__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# uuid.UUID.__init_subclass__.__name__.__len__() == 17 — standalone
#
# uuid.UUID.__init_subclass__.__name__.__len__() is 17. '__init_subclass__' has
# 17 chars: '__'=2 + 'init_subclass'=13 + '__'=2 = 17. __init_subclass__ is a
# Python special method (PEP 487, Python 3.6+) that is called whenever a class
# subclasses UUID. It allows UUID to customize subclassing behavior. Extra52 anchors
# UUID.__init_subclass__.__qualname__.__eq__('UUID.__init_subclass__') as a table row
# and extra25 anchors UUID.__init_subclass__.__qualname__.__len__()==22; no prior uuid
# spec anchors UUID.__init_subclass__.__name__.__len__()==17 as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra112.UUID_init_subclass_name_len_17:
  description: "uuid.UUID.__init_subclass__.__name__.__len__() == 17 — len('__init_subclass__')==17 ('__'=2 + 'init_subclass'=13 + '__'=2; PEP 487 special method called when UUID is subclassed; extra52 anchors __qualname__.__eq__('UUID.__init_subclass__'); extra25 anchors __qualname__.__len__()==22; no prior spec anchors __name__.__len__()==17 as standalone; coincidentally same length as len('getset_descriptor')==17; first standalone under uuiddict112)"
  category: type_identity
  kind: python_call_eq
  function: UUID.__init_subclass__.__name__.__len__
  args: []
  expected: 17

