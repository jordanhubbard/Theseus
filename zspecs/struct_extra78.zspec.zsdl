invariant struct_extra78.struct_size_class_getset_descriptor:
  description: "struct.Struct.size.__class__.__name__.__eq__('getset_descriptor') == True — Struct.size is a C-level getset_descriptor (not a Python property); no prior struct spec checks Struct.size.__class__.__name__; first __class__.__name__ standalone for struct.Struct.size"
  category: class_attrs
