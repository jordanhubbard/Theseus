spec: struct_extra78
version: ">=3.9"
extends: struct_extra77
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra77.zspec.zsdl — covers Struct/__dict__/__len__()==16 / error/__dict__/__len__()==3 / error/__dict__/__class__/__name__=='mappingproxy' / Struct/__doc__/__len__()==40 / module-level and Struct __doc__.__class__.__name__ cross-checks (table + invariants)."
    - "struct_extra76.zspec.zsdl — covers Struct.__dict__ membership (pack/unpack/pack_into/unpack_from/iter_unpack/format/size/__init__/__new__/__repr__) and Struct.__dict__.__class__.__name__=='mappingproxy' and Struct.__name__/__qualname__/__module__ (table + invariants)."
    - "struct_extra75.zspec.zsdl — covers struct.error.__name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__()/__bases__.__len__()/__qualname__.__len__()/__name__.__len__()/__module__.__len__() and pack/unpack __qualname__.__eq__ (table + invariants)."
    - "struct_extra74.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __qualname__.__len__() / module-level pack/unpack/pack_into/unpack_from/iter_unpack/calcsize __qualname__.__len__() (table + invariants)."
    - "struct_extra71.zspec.zsdl — covers Struct.__dict__.__contains__('__doc__') / pack/unpack/calcsize/pack_into/unpack_from/iter_unpack/__module__=='_struct' (table + invariants)."
    - "struct_extra68.zspec.zsdl — covers Struct.__doc__.__class__.__name__=='str' / Struct.__name__/__module__/__qualname__ / pack/unpack/calcsize/__qualname__ (table + invariants)."
    - "struct_extra67.zspec.zsdl — covers pack/unpack/calcsize/pack_into/unpack_from/iter_unpack/__class__/__name__=='builtin_function_or_method' (table + invariants)."
    - "struct_extra65.zspec.zsdl — covers Struct.__dict__.__contains__ pack/unpack/pack_into/unpack_from/iter_unpack/size/format (table + invariants)."
    - "struct_extra59.zspec.zsdl — covers pack.__doc__.__len__()==176 (table + invariants)."
    - "struct_extra53.zspec.zsdl — covers error.__doc__.__class__.__name__.__eq__('NoneType') (invariant)."
    - "struct_extra44.zspec.zsdl — covers pack/unpack/calcsize/pack_into/unpack_from/iter_unpack/Struct __doc__.__class__.__name__.__eq__('str') (table + invariants)."
    - "struct_extra43.zspec.zsdl — covers Struct/error __class__.__qualname__.__eq__('type') / pack/unpack/etc. __class__.__module__.__eq__('builtins') (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra77; it does NOT duplicate invariants present in those files."
    - "Wave 249 theme: struct.Struct method __doc__.__class__.__name__ / Struct method __class__.__name__ / Struct.format/size __class__.__name__ / Struct.__module__/__len__() / Struct.__name__/__len__()."
    - "struct.Struct.pack.__doc__.__class__.__name__ == 'str' — Struct.pack has a str docstring. struct_extra44 covers pack.__doc__.__class__.__name__ for the module-level pack; this spec covers Struct.pack (the method descriptor). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__doc__.__class__.__name__ == 'str' — Struct.unpack method has a str docstring. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__doc__.__class__.__name__ == 'str' — Struct.pack_into method has a str docstring. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__doc__.__class__.__name__ == 'str' — Struct.unpack_from method has a str docstring. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__doc__.__class__.__name__ == 'str' — Struct.iter_unpack method has a str docstring. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__class__.__name__ == 'getset_descriptor' — format is a C-level attribute descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__class__.__name__ == 'getset_descriptor' — size is a C-level attribute descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__class__.__name__ == 'method_descriptor' — Struct.pack is a method_descriptor (C-level method). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__class__.__name__ == 'method_descriptor' — Struct.unpack is a method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__class__.__name__ == 'method_descriptor' — Struct.pack_into is a method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__class__.__name__ == 'method_descriptor' — Struct.unpack_from is a method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__class__.__name__ == 'method_descriptor' — Struct.iter_unpack is a method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__module__.__len__() == 7 — '_struct' is 7 characters. No prior struct spec checks Struct.__module__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__name__.__len__() == 6 — 'Struct' is 6 characters. No prior struct spec checks Struct.__name__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.pack/__doc__/__class__/__name__ / Struct.unpack/__doc__/__class__/__name__
# struct.Struct.pack_into/__doc__/__class__/__name__ / Struct.unpack_from/__doc__/__class__/__name__
#
# Wave 249 theme: Struct method descriptor __doc__.__class__.__name__ (group 1).
#
# Struct.pack/unpack/pack_into/unpack_from all have str docstrings.
# struct_extra44 covers module-level pack/unpack/etc.; this covers Struct.pack/etc.
# (the method descriptors on the Struct class).
# No prior struct spec checks __doc__.__class__.__name__ for Struct.pack etc. (as method descriptors).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra78.struct_method_doc_class_names_group1:
  description: "struct.Struct.pack/__doc__/__class__/__name__.__eq__('str')==True / Struct.unpack/__doc__/__class__/__name__.__eq__('str')==True / Struct.pack_into/__doc__/__class__.__name__.__eq__('str')==True / Struct.unpack_from/__doc__/__class__/__name__.__eq__('str')==True — all four Struct method descriptors have str docstrings; struct_extra44 covers module-level functions; this table anchors the Struct method descriptor docstrings; first __doc__.__class__.__name__ anchor for Struct.pack/unpack/pack_into/unpack_from as method descriptors"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra78

  columns: [id, function, args, expected]
  rows:
    - [struct_pack_doc_class_str,      "Struct.pack.__doc__.__class__.__name__.__eq__",      ["str"], true]
    - [struct_unpack_doc_class_str,    "Struct.unpack.__doc__.__class__.__name__.__eq__",    ["str"], true]
    - [struct_pack_into_doc_class_str, "Struct.pack_into.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [struct_unpack_from_doc_class_str, "Struct.unpack_from.__doc__.__class__.__name__.__eq__", ["str"], true]

# ---------------------------------------------------------------------------
# struct.Struct.iter_unpack/__doc__/__class__/__name__
# struct.Struct.format/__class__/__name__ / Struct.size/__class__/__name__
#
# Wave 249 theme: iter_unpack doc class name and format/size descriptor class names.
#
# Struct.iter_unpack has a str docstring.
# Struct.format and Struct.size are getset_descriptors (C-level attribute descriptors).
# No prior struct spec checks __class__.__name__ for Struct.format or Struct.size.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra78.iter_unpack_doc_and_format_size_class:
  description: "struct.Struct.iter_unpack/__doc__/__class__/__name__.__eq__('str')==True / Struct.format/__class__/__name__.__eq__('getset_descriptor')==True / Struct.size/__class__/__name__.__eq__('getset_descriptor')==True — iter_unpack has a str docstring; format and size are C-level getset_descriptor objects (not methods or properties); no prior struct spec checks Struct.format/__class__/__name__ or Struct.size/__class__/__name__; first class name anchor for Struct.format and Struct.size"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra78

  columns: [id, function, args, expected]
  rows:
    - [struct_iter_unpack_doc_class_str,    "Struct.iter_unpack.__doc__.__class__.__name__.__eq__", ["str"],              true]
    - [struct_format_class_getset,          Struct.format.__class__.__name__.__eq__,                ["getset_descriptor"], true]
    - [struct_size_class_getset,            Struct.size.__class__.__name__.__eq__,                  ["getset_descriptor"], true]

# ---------------------------------------------------------------------------
# struct.Struct.pack/__class__/__name__ / Struct.unpack/__class__/__name__
# struct.Struct.pack_into/__class__/__name__ / Struct.unpack_from/__class__/__name__
#
# Wave 249 theme: Struct method descriptor __class__.__name__ identity.
#
# Struct.pack/unpack/pack_into/unpack_from are all method_descriptors (C-level methods).
# No prior struct spec checks __class__.__name__ for Struct.pack etc. as method descriptors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra78.struct_method_class_names:
  description: "struct.Struct.pack/__class__/__name__.__eq__('method_descriptor')==True / Struct.unpack/__class__/__name__.__eq__('method_descriptor')==True / Struct.pack_into/__class__.__name__.__eq__('method_descriptor')==True / Struct.unpack_from/__class__/__name__.__eq__('method_descriptor')==True — Struct.pack/unpack/pack_into/unpack_from are C-level method_descriptor objects; no prior struct spec checks __class__.__name__ for these as Struct methods; first method_descriptor class name anchor for Struct pack/unpack/pack_into/unpack_from"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra78

  columns: [id, function, args, expected]
  rows:
    - [struct_pack_class_method_desc,      Struct.pack.__class__.__name__.__eq__,      ["method_descriptor"], true]
    - [struct_unpack_class_method_desc,    Struct.unpack.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [struct_pack_into_class_method_desc, Struct.pack_into.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [struct_unpack_from_class_method_desc, Struct.unpack_from.__class__.__name__.__eq__, ["method_descriptor"], true]

# ---------------------------------------------------------------------------
# struct.Struct.iter_unpack/__class__/__name__
# struct.Struct.__module__/__len__() / struct.Struct.__name__/__len__()
#
# Wave 249 theme: iter_unpack method class name and Struct name/module lengths.
#
# Struct.iter_unpack is also a method_descriptor.
# Struct.__module__ is '_struct' (7 chars), Struct.__name__ is 'Struct' (6 chars).
# No prior struct spec checks Struct.__module__.__len__() or Struct.__name__.__len__().
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra78.iter_unpack_class_and_name_lengths:
  description: "struct.Struct.iter_unpack/__class__/__name__.__eq__('method_descriptor')==True / Struct/__module__/__len__()==7 / Struct/__name__/__len__()==6 — iter_unpack is a method_descriptor; Struct.__module__ is '_struct' (7 chars); Struct.__name__ is 'Struct' (6 chars); no prior struct spec checks Struct/__module__/__len__() or Struct/__name__/__len__(); first module name length and class name length anchor for struct.Struct"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra78

  columns: [id, function, args, expected]
  rows:
    - [struct_iter_unpack_class_method_desc, Struct.iter_unpack.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [struct_module_len_7,                  Struct.__module__.__len__,                    [],                    7]
    - [struct_name_len_6,                    Struct.__name__.__len__,                      [],                    6]

# ---------------------------------------------------------------------------
# struct.Struct.pack.__doc__.__class__.__name__.__eq__('str') — standalone
#
# Struct.pack has a str docstring. No prior struct spec checks
# Struct.pack.__doc__.__class__.__name__ (as a method descriptor).
# First __doc__.__class__.__name__ standalone for struct.Struct.pack.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra78.struct_pack_doc_class_str:
  description: "struct.Struct.pack.__doc__.__class__.__name__.__eq__('str') == True — Struct.pack has a str docstring; struct_extra44 covers module-level pack.__doc__.__class__.__name__; this standalone anchors Struct.pack (the method descriptor); first __doc__.__class__.__name__ standalone for struct.Struct.pack"
  category: class_attrs
  kind: python_call_eq
  function: "Struct.pack.__doc__.__class__.__name__.__eq__"
  args: ["str"]
  expected: true

