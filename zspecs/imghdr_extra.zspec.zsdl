spec: imghdr_extra
version: ">=3.9,<3.13"
backend: python_module(imghdr)

docs: https://docs.python.org/3/library/imghdr.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/imghdr.html — Python imghdr module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/imghdr.py"
  notes:
    - "This spec extends imghdr.zspec.zsdl with additional identity and registry invariants not covered there."
    - "imghdr was deprecated in Python 3.11 (PEP 594) and removed in Python 3.13; this spec applies to >=3.9,<3.13."
    - "imghdr.what.__name__ == 'what' and imghdr.what.__module__ == 'imghdr'."
    - "imghdr.tests is a module-level list of callable image-format tester functions."
    - "len(imghdr.tests) >= 10 — Python 3.12 ships with 13 registered format testers."
    - "Each element of imghdr.tests is a function (callable); imghdr.tests[0].__class__.__name__ == 'function'."
    - "imghdr.test and imghdr.testall are internal helper functions present in the module namespace."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name and module affiliation — what()
# ---------------------------------------------------------------------------

invariant imghdr_extra.names.what:
  description: "imghdr.what.__name__ == 'what'"
  category: names
  kind: python_call_eq
  function: what.__name__.__eq__
  args: ["what"]
  expected: true

invariant imghdr_extra.modules.what:
  description: "imghdr.what.__module__ == 'imghdr'"
  category: modules
  kind: python_call_eq
  function: what.__module__.__eq__
  args: ["imghdr"]
  expected: true

# ---------------------------------------------------------------------------
# imghdr.tests registry — type checks
# ---------------------------------------------------------------------------

invariant imghdr_extra.tests_registry.is_list:
  description: "imghdr.tests.__class__.__name__ == 'list' — tests registry is a list"
  category: tests_registry
  kind: python_call_eq
  function: tests.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant imghdr_extra.tests_registry.len_gte_10:
  description: "len(imghdr.tests) >= 10 — at least 10 image-format tester functions are registered"
  category: tests_registry
  kind: python_call_eq
  function: tests.__len__
  args: []
  method: __ge__
  method_args: [10]
  expected: true

invariant imghdr_extra.tests_registry.first_item_is_function:
  description: "imghdr.tests[0].__class__.__name__ == 'function' — first tester in registry is a callable function"
  category: tests_registry
  kind: python_call_eq
  function: tests.__getitem__
  args: [0]
  method: __class__.__name__.__eq__
  method_args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# imghdr.tests callable elements — spot-check several entries
# ---------------------------------------------------------------------------

table imghdr_extra.tests_registry.items_are_callable:
  kind: python_call_eq
  category: tests_registry
  id_prefix: tester
  columns: [id, function, args, expected]
  rows:
    - [item0_callable, tests.__getitem__, [0], {type: truthy}]
    - [item1_callable, tests.__getitem__, [1], {type: truthy}]
    - [item2_callable, tests.__getitem__, [2], {type: truthy}]

# ---------------------------------------------------------------------------
# Module-level helper function names
# ---------------------------------------------------------------------------

invariant imghdr_extra.names.test:
  description: "imghdr.test.__name__ == 'test' — internal helper function name"
  category: names
  kind: python_call_eq
  function: test.__name__.__eq__
  args: ["test"]
  expected: true

invariant imghdr_extra.names.testall:
  description: "imghdr.testall.__name__ == 'testall' — internal helper function name"
  category: names
  kind: python_call_eq
  function: testall.__name__.__eq__
  args: ["testall"]
  expected: true

# ---------------------------------------------------------------------------
# what() module affiliation for internal helpers
# ---------------------------------------------------------------------------

invariant imghdr_extra.modules.test:
  description: "imghdr.test.__module__ == 'imghdr'"
  category: modules
  kind: python_call_eq
  function: test.__module__.__eq__
  args: ["imghdr"]
  expected: true

invariant imghdr_extra.modules.testall:
  description: "imghdr.testall.__module__ == 'imghdr'"
  category: modules
  kind: python_call_eq
  function: testall.__module__.__eq__
  args: ["imghdr"]
  expected: true

# ---------------------------------------------------------------------------
# what() is a callable (function object)
# ---------------------------------------------------------------------------

invariant imghdr_extra.names.what_is_function:
  description: "imghdr.what.__class__.__name__ == 'function' — what is a plain function"
  category: names
  kind: python_call_eq
  function: what.__class__.__name__.__eq__
  args: ["function"]
  expected: true
