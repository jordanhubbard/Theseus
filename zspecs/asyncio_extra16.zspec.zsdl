spec: asyncio_extra16
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-exceptions.html — asyncio exception classes"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/asyncio/exceptions.py"
    - "CPython source: Lib/asyncio/streams.py"
    - "CPython source: Lib/asyncio/tasks.py"
  notes:
    - "This spec extends asyncio.zspec.zsdl through asyncio_extra15.zspec.zsdl."
    - "asyncio_extra covers: CancelledError/__name__, TimeoutError/__name__, IncompleteReadError/__name__; Task/Future/Queue/Lock/Event/Semaphore __name__."
    - "asyncio_extra5 covers: BoundedSemaphore/__name__, InvalidStateError/__name__."
    - "asyncio_extra9 covers: CancelledError/__bases__[0].__name__=='BaseException'; TimeoutError/__bases__[0].__name__=='OSError'; InvalidStateError/__bases__[0].__name__=='Exception'; IncompleteReadError/__bases__[0].__name__=='EOFError'."
    - "asyncio_extra12 covers: Task/Future/Lock/Queue __class__.__name__ == 'type'."
    - "asyncio_extra13 covers: BoundedSemaphore/Event/LifoQueue/PriorityQueue __class__.__name__ == 'type'; LimitOverrunError/__bases__[0].__name__; LimitOverrunError/__class__.__name__; IncompleteReadError/__class__.__name__."
    - "asyncio_extra15 covers: Lock/Event/Semaphore/Barrier __qualname__ and __module__; Task/Future/Queue __qualname__; CancelledError/__qualname__ and __module__; InvalidStateError/__module__."
    - "NOT yet covered in any prior spec: SendfileNotAvailableError.__name__ == 'SendfileNotAvailableError'."
    - "NOT yet covered: SendfileNotAvailableError.__class__.__name__ == 'type'."
    - "NOT yet covered: SendfileNotAvailableError.__bases__[0].__name__ == 'OSError'."
    - "NOT yet covered: CancelledError.__class__.__name__ == 'type' — metaclass check for CancelledError."
    - "NOT yet covered: TimeoutError.__class__.__name__ == 'type' — metaclass check for TimeoutError."
    - "NOT yet covered: InvalidStateError.__class__.__name__ == 'type' — metaclass check for InvalidStateError."
    - "NOT yet covered: LimitOverrunError.__name__.__eq__ as an invariant function call — asyncio_extra13 notes it indirectly but has no actual __name__.__eq__ invariant for it."
    - "asyncio.SendfileNotAvailableError is a subclass of OSError defined in asyncio/exceptions.py."
    - "asyncio.CancelledError.__class__.__name__ == 'type' — CancelledError is a plain Python class."
    - "asyncio.TimeoutError.__class__.__name__ == 'type' — TimeoutError is a plain Python class (aliased from builtins)."
    - "asyncio.SendfileNotAvailableError.__bases__[0].__name__ == 'OSError' — inherits directly from OSError."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SendfileNotAvailableError — name, base class, and metaclass
#
# No prior asyncio spec covers SendfileNotAvailableError in any form.
# asyncio.SendfileNotAvailableError is defined in asyncio/exceptions.py and
# inherits from OSError. It is raised when sendfile() is not supported.
# ---------------------------------------------------------------------------

invariant asyncio_extra16.SendfileNotAvailableError.name:
  description: "asyncio.SendfileNotAvailableError.__name__ == 'SendfileNotAvailableError'"
  category: exception_names
  kind: python_call_eq
  function: SendfileNotAvailableError.__name__.__eq__
  args: ["SendfileNotAvailableError"]
  expected: true

invariant asyncio_extra16.SendfileNotAvailableError.class_name:
  description: "asyncio.SendfileNotAvailableError.__class__.__name__ == 'type' — plain Python exception class"
  category: exception_types
  kind: python_call_eq
  function: SendfileNotAvailableError.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant asyncio_extra16.SendfileNotAvailableError.base:
  description: "asyncio.SendfileNotAvailableError.__bases__[0].__name__ == 'OSError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: SendfileNotAvailableError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "OSError"

# ---------------------------------------------------------------------------
# asyncio exception class metaclass checks — __class__.__name__ == 'type'
#
# asyncio_extra12 covers Task/Future/Lock/Queue __class__.__name__ == 'type'.
# asyncio_extra13 covers BoundedSemaphore/Event/LifoQueue/PriorityQueue and
# LimitOverrunError/IncompleteReadError __class__.__name__.
# No prior spec checks __class__.__name__ for CancelledError, TimeoutError,
# or InvalidStateError.
# ---------------------------------------------------------------------------

table asyncio_extra16.exception_class_metaclass:
  description: "asyncio exception classes have __class__.__name__ == 'type'"
  kind: python_call_eq
  category: exception_types
  id_prefix: excmeta16

  columns: [id, function, args, expected]
  rows:
    - [CancelledError,    CancelledError.__class__.__name__.__eq__,    ["type"], true]
    - [TimeoutError,      TimeoutError.__class__.__name__.__eq__,      ["type"], true]
    - [InvalidStateError, InvalidStateError.__class__.__name__.__eq__, ["type"], true]

# ---------------------------------------------------------------------------
# LimitOverrunError __name__ — standalone invariant
#
# asyncio_extra7 covers LimitOverrunError/__qualname__.
# asyncio_extra13 covers LimitOverrunError/__bases__[0].__name__ and
# __class__.__name__. The asyncio_extra13 comment claims the __name__ was
# covered in asyncio_extra via IncompleteReadError module commentary, but no
# actual LimitOverrunError.__name__.__eq__ invariant exists in any prior spec.
# ---------------------------------------------------------------------------

invariant asyncio_extra16.LimitOverrunError.name:
  description: "asyncio.LimitOverrunError.__name__ == 'LimitOverrunError'"
  category: exception_names
  kind: python_call_eq
  function: LimitOverrunError.__name__.__eq__
  args: ["LimitOverrunError"]
  expected: true

# ---------------------------------------------------------------------------
# SendfileNotAvailableError __module__ and __qualname__
#
# No prior spec checks SendfileNotAvailableError.__module__ or
# SendfileNotAvailableError.__qualname__. The class is defined in
# asyncio/exceptions.py, so its __module__ is 'asyncio.exceptions' and
# its __qualname__ matches its __name__ as it is a top-level class.
# ---------------------------------------------------------------------------

invariant asyncio_extra16.SendfileNotAvailableError.module:
  description: "asyncio.SendfileNotAvailableError.__module__ == 'asyncio.exceptions'"
  category: exception_modules
  kind: python_call_eq
  function: SendfileNotAvailableError.__module__.__eq__
  args: ["asyncio.exceptions"]
  expected: true

invariant asyncio_extra16.SendfileNotAvailableError.qualname:
  description: "asyncio.SendfileNotAvailableError.__qualname__ == 'SendfileNotAvailableError'"
  category: exception_names
  kind: python_call_eq
  function: SendfileNotAvailableError.__qualname__.__eq__
  args: ["SendfileNotAvailableError"]
  expected: true
