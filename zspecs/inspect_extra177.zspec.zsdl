spec: inspect_extra177
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect predicate functions — inspect.isbuiltin.__name__=='isbuiltin' (len=9); inspect.isbuiltin.__module__=='inspect'; inspect.isgenerator.__name__=='isgenerator' (len=11); inspect.iscoroutine.__name__=='iscoroutine' (len=11; same as isgenerator); inspect.isawaitable.__name__=='isawaitable' (len=11; same — 3-way tie); inspect.isasyncgen.__name__=='isasyncgen' (len=10); inspect.isframe.__name__=='isframe' (len=7); inspect.iscode.__name__=='iscode' (len=6)."
    - "inspect.isbuiltin.__name__ == 'isbuiltin' — isbuiltin is a Python function in Lib/inspect.py returning True if the object is a built-in function or bound built-in method; its __name__ is 'isbuiltin', 9 characters. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__module__ == 'inspect' — isbuiltin is defined in Lib/inspect.py; its __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.isgenerator.__name__ == 'isgenerator' — isgenerator is a Python function in Lib/inspect.py returning True if the object is a generator; its __name__ is 'isgenerator', 11 characters. Verified with Python 3.14.3."
    - "inspect.iscoroutine.__name__ == 'iscoroutine' — iscoroutine is a Python function in Lib/inspect.py returning True if the object is a coroutine object; its __name__ is 'iscoroutine', 11 characters, same length as 'isgenerator'. Verified with Python 3.14.3."
    - "inspect.isawaitable.__name__ == 'isawaitable' — isawaitable is a Python function in Lib/inspect.py returning True if the object can be used in an await expression; its __name__ is 'isawaitable', 11 characters (3-way tie with isgenerator and iscoroutine). Verified with Python 3.14.3."
    - "inspect.isasyncgen.__name__ == 'isasyncgen' — isasyncgen is a Python function in Lib/inspect.py returning True if the object is an async generator; its __name__ is 'isasyncgen', 10 characters. Verified with Python 3.14.3."
    - "inspect.isframe.__name__ == 'isframe' — isframe is a Python function in Lib/inspect.py returning True if the object is a frame; its __name__ is 'isframe', 7 characters. Verified with Python 3.14.3."
    - "inspect.iscode.__name__ == 'iscode' — iscode is a Python function in Lib/inspect.py returning True if the object is a code object; its __name__ is 'iscode', 6 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.isbuiltin __name__ and __module__
#
# inspect.isbuiltin.__name__ == 'isbuiltin'
# inspect.isbuiltin.__name__.__len__() == 9
# inspect.isbuiltin.__module__ == 'inspect'
# inspect.isgenerator.__name__ == 'isgenerator'
#
# inspect.isbuiltin is a Python function in Lib/inspect.py that returns True if
# the object is a built-in function or bound built-in method. Its __name__ is
# 'isbuiltin' (9 chars) and its __module__ is 'inspect'. New to extra177.
# ---------------------------------------------------------------------------

table inspect_extra177.isbuiltin_name_module_and_isgenerator_name:
  description: "inspect.isbuiltin.__name__ 'isbuiltin' len 9; __module__ 'inspect'; isgenerator.__name__ 'isgenerator' len 11; new to extra177"
  kind: python_call_eq
  category: identity
  id_prefix: inspectpreds177

  columns: [id, function, args, expected, description]
  rows:
    - [isbuiltin_name_eq,
       "isbuiltin.__name__.__eq__",
       ["isbuiltin"],
       true,
       "inspect.isbuiltin.__name__.__eq__('isbuiltin') == True — inspect.isbuiltin is a Python function in Lib/inspect.py returning True if the object is a built-in function or a bound built-in method; its __name__ is 'isbuiltin'; str.__eq__('isbuiltin') returns True; new to extra177"]
    - [isbuiltin_name_len_9,
       "isbuiltin.__name__.__len__",
       [],
       9,
       "inspect.isbuiltin.__name__.__len__() == 9 — the name 'isbuiltin' has exactly 9 characters: i-s-b-u-i-l-t-i-n; str.__len__() returns 9; new to extra177"]
    - [isbuiltin_module_inspect,
       "isbuiltin.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.isbuiltin.__module__.__eq__('inspect') == True — inspect.isbuiltin is a Python function defined in Lib/inspect.py; its __module__ is the string 'inspect'; str.__eq__('inspect') returns True; new to extra177"]
    - [isgenerator_name_eq,
       "isgenerator.__name__.__eq__",
       ["isgenerator"],
       true,
       "inspect.isgenerator.__name__.__eq__('isgenerator') == True — inspect.isgenerator is a Python function in Lib/inspect.py returning True if the object is a generator object (i.e., created by calling a generator function); its __name__ is 'isgenerator'; str.__eq__('isgenerator') returns True; new to extra177"]

# ---------------------------------------------------------------------------
# Table 2: inspect.isgenerator name length and inspect.iscoroutine, isawaitable
#
# inspect.isgenerator.__name__.__len__() == 11
# inspect.iscoroutine.__name__ == 'iscoroutine'
# inspect.iscoroutine.__name__.__len__() == 11
# inspect.isawaitable.__name__ == 'isawaitable'
#
# isgenerator has __name__ 'isgenerator' (11 chars). iscoroutine and isawaitable
# each also have 11-character names — a 3-way tie at length 11. New to extra177.
# ---------------------------------------------------------------------------

table inspect_extra177.isgenerator_len_iscoroutine_isawaitable_name:
  description: "inspect.isgenerator.__name__ len 11; iscoroutine.__name__ 'iscoroutine' len 11; isawaitable.__name__ 'isawaitable' len 11 (3-way tie); new to extra177"
  kind: python_call_eq
  category: identity
  id_prefix: inspectpreds177

  columns: [id, function, args, expected, description]
  rows:
    - [isgenerator_name_len_11,
       "isgenerator.__name__.__len__",
       [],
       11,
       "inspect.isgenerator.__name__.__len__() == 11 — the name 'isgenerator' has exactly 11 characters: i-s-g-e-n-e-r-a-t-o-r; str.__len__() returns 11; new to extra177"]
    - [iscoroutine_name_eq,
       "iscoroutine.__name__.__eq__",
       ["iscoroutine"],
       true,
       "inspect.iscoroutine.__name__.__eq__('iscoroutine') == True — inspect.iscoroutine is a Python function in Lib/inspect.py returning True if the object is a coroutine object (created by calling an async def function); its __name__ is 'iscoroutine'; str.__eq__('iscoroutine') returns True; new to extra177"]
    - [iscoroutine_name_len_11,
       "iscoroutine.__name__.__len__",
       [],
       11,
       "inspect.iscoroutine.__name__.__len__() == 11 — the name 'iscoroutine' has exactly 11 characters: i-s-c-o-r-o-u-t-i-n-e; same length as 'isgenerator' (11); str.__len__() returns 11; new to extra177"]
    - [isawaitable_name_eq,
       "isawaitable.__name__.__eq__",
       ["isawaitable"],
       true,
       "inspect.isawaitable.__name__.__eq__('isawaitable') == True — inspect.isawaitable is a Python function in Lib/inspect.py returning True if the object can be used in an await expression; its __name__ is 'isawaitable'; along with 'isgenerator' and 'iscoroutine', this forms a 3-way tie at 11 characters; str.__eq__('isawaitable') returns True; new to extra177"]

# ---------------------------------------------------------------------------
# Table 3: inspect.isawaitable name length and inspect.isasyncgen __name__
#
# inspect.isawaitable.__name__.__len__() == 11
# inspect.isasyncgen.__name__ == 'isasyncgen'
# inspect.isasyncgen.__name__.__len__() == 10
# inspect.isasyncgen.__module__ == 'inspect'
#
# isawaitable has 11 chars (completing the 3-way tie). isasyncgen has __name__
# 'isasyncgen' (10 chars) and __module__ 'inspect'. New to extra177.
# ---------------------------------------------------------------------------

table inspect_extra177.isawaitable_len_and_isasyncgen_name:
  description: "inspect.isawaitable.__name__ len 11 (3-way tie); isasyncgen.__name__ 'isasyncgen' len 10; __module__ 'inspect'; new to extra177"
  kind: python_call_eq
  category: identity
  id_prefix: inspectpreds177

  columns: [id, function, args, expected, description]
  rows:
    - [isawaitable_name_len_11,
       "isawaitable.__name__.__len__",
       [],
       11,
       "inspect.isawaitable.__name__.__len__() == 11 — the name 'isawaitable' has exactly 11 characters: i-s-a-w-a-i-t-a-b-l-e; same length as 'isgenerator' and 'iscoroutine' — a 3-way tie at 11 characters; str.__len__() returns 11; new to extra177"]
    - [isasyncgen_name_eq,
       "isasyncgen.__name__.__eq__",
       ["isasyncgen"],
       true,
       "inspect.isasyncgen.__name__.__eq__('isasyncgen') == True — inspect.isasyncgen is a Python function in Lib/inspect.py returning True if the object is an asynchronous generator iterator (created by calling an async def function containing yield); its __name__ is 'isasyncgen'; str.__eq__('isasyncgen') returns True; new to extra177"]
    - [isasyncgen_name_len_10,
       "isasyncgen.__name__.__len__",
       [],
       10,
       "inspect.isasyncgen.__name__.__len__() == 10 — the name 'isasyncgen' has exactly 10 characters: i-s-a-s-y-n-c-g-e-n; str.__len__() returns 10; new to extra177"]
    - [isasyncgen_module_inspect,
       "isasyncgen.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.isasyncgen.__module__.__eq__('inspect') == True — inspect.isasyncgen is a Python function defined in Lib/inspect.py; its __module__ is the string 'inspect'; str.__eq__('inspect') returns True; new to extra177"]

# ---------------------------------------------------------------------------
# Table 4: inspect.isframe and inspect.iscode __name__
#
# inspect.isframe.__name__ == 'isframe'
# inspect.isframe.__name__.__len__() == 7
# inspect.iscode.__name__ == 'iscode'
# inspect.iscode.__name__.__len__() == 6
#
# isframe has __name__ 'isframe' (7 chars). iscode has __name__ 'iscode' (6
# chars — shortest among the inspect predicate functions). New to extra177.
# ---------------------------------------------------------------------------

table inspect_extra177.isframe_and_iscode_name:
  description: "inspect.isframe.__name__ 'isframe' len 7; iscode.__name__ 'iscode' len 6 (shortest predicate); new to extra177"
  kind: python_call_eq
  category: identity
  id_prefix: inspectpreds177

  columns: [id, function, args, expected, description]
  rows:
    - [isframe_name_eq,
       "isframe.__name__.__eq__",
       ["isframe"],
       true,
       "inspect.isframe.__name__.__eq__('isframe') == True — inspect.isframe is a Python function in Lib/inspect.py returning True if the object is a frame object (a stack frame as returned by sys._getframe()); its __name__ is 'isframe'; str.__eq__('isframe') returns True; new to extra177"]
    - [isframe_name_len_7,
       "isframe.__name__.__len__",
       [],
       7,
       "inspect.isframe.__name__.__len__() == 7 — the name 'isframe' has exactly 7 characters: i-s-f-r-a-m-e; str.__len__() returns 7; new to extra177"]
    - [iscode_name_eq,
       "iscode.__name__.__eq__",
       ["iscode"],
       true,
       "inspect.iscode.__name__.__eq__('iscode') == True — inspect.iscode is a Python function in Lib/inspect.py returning True if the object is a code object (as compiled from a function body); its __name__ is 'iscode'; str.__eq__('iscode') returns True; new to extra177"]
    - [iscode_name_len_6,
       "iscode.__name__.__len__",
       [],
       6,
       "inspect.iscode.__name__.__len__() == 6 — the name 'iscode' has exactly 6 characters: i-s-c-o-d-e; this is the shortest name among the inspect predicate functions covered in this spec; str.__len__() returns 6; new to extra177"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra177
# ---------------------------------------------------------------------------

invariant inspect_extra177.isbuiltin_name_isbuiltin:
  description: "inspect.isbuiltin.__name__ == 'isbuiltin' — Python function in Lib/inspect.py with __name__ 'isbuiltin' (9 chars); new to extra177"
  kind: python_call_eq
  function: isbuiltin.__name__.__eq__
  args: ["isbuiltin"]
  expected: true

invariant inspect_extra177.isbuiltin_name_len_9:
  description: "inspect.isbuiltin.__name__.__len__() == 9 — 'isbuiltin' is 9 characters long; new to extra177"
  kind: python_call_eq
  function: isbuiltin.__name__.__len__
  args: []
  expected: 9

invariant inspect_extra177.isbuiltin_module_inspect:
  description: "inspect.isbuiltin.__module__ == 'inspect' — isbuiltin is defined in Lib/inspect.py; new to extra177"
  kind: python_call_eq
  function: isbuiltin.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra177.isgenerator_name_isgenerator:
  description: "inspect.isgenerator.__name__ == 'isgenerator' — Python function in Lib/inspect.py with __name__ 'isgenerator' (11 chars); new to extra177"
  kind: python_call_eq
  function: isgenerator.__name__.__eq__
  args: ["isgenerator"]
  expected: true

invariant inspect_extra177.iscoroutine_name_iscoroutine:
  description: "inspect.iscoroutine.__name__ == 'iscoroutine' — Python function in Lib/inspect.py with __name__ 'iscoroutine' (11 chars, same as isgenerator); new to extra177"
  kind: python_call_eq
  function: iscoroutine.__name__.__eq__
  args: ["iscoroutine"]
  expected: true

invariant inspect_extra177.isawaitable_name_isawaitable:
  description: "inspect.isawaitable.__name__ == 'isawaitable' — Python function in Lib/inspect.py with __name__ 'isawaitable' (11 chars — 3-way tie with isgenerator and iscoroutine); new to extra177"
  kind: python_call_eq
  function: isawaitable.__name__.__eq__
  args: ["isawaitable"]
  expected: true

invariant inspect_extra177.isawaitable_name_len_11:
  description: "inspect.isawaitable.__name__.__len__() == 11 — 'isawaitable' is 11 characters long; same length as 'isgenerator' and 'iscoroutine'; new to extra177"
  kind: python_call_eq
  function: isawaitable.__name__.__len__
  args: []
  expected: 11

invariant inspect_extra177.isasyncgen_name_isasyncgen:
  description: "inspect.isasyncgen.__name__ == 'isasyncgen' — Python function in Lib/inspect.py with __name__ 'isasyncgen' (10 chars); new to extra177"
  kind: python_call_eq
  function: isasyncgen.__name__.__eq__
  args: ["isasyncgen"]
  expected: true

invariant inspect_extra177.isframe_name_isframe:
  description: "inspect.isframe.__name__ == 'isframe' — Python function in Lib/inspect.py with __name__ 'isframe' (7 chars); new to extra177"
  kind: python_call_eq
  function: isframe.__name__.__eq__
  args: ["isframe"]
  expected: true

invariant inspect_extra177.iscode_name_iscode:
  description: "inspect.iscode.__name__ == 'iscode' — Python function in Lib/inspect.py with __name__ 'iscode' (6 chars); new to extra177"
  kind: python_call_eq
  function: iscode.__name__.__eq__
  args: ["iscode"]
  expected: true

invariant inspect_extra177.iscode_name_len_6:
  description: "inspect.iscode.__name__.__len__() == 6 — 'iscode' is 6 characters long, shortest predicate name in this spec; new to extra177"
  kind: python_call_eq
  function: iscode.__name__.__len__
  args: []
  expected: 6
