    - "compute-sum README — https://www.npmjs.com/package/compute-sum"
    - "Test vectors verified with compute-sum via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "compute-sum source"
  notes:
    - "compute-sum is an npm package. Install: npm install compute-sum"
    - "Returns the sum of an array of numbers."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table compute_sum.sum:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: csum

  columns: [id, args, expected]
  rows:
    - [four,   [[1, 2, 3, 4]],  10]
    - [two,    [[10, 20]],      30]
    - [one,    [[7]],           7]

