spec: dataclasses_extra27
version: ">=3.9"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "This spec extends dataclasses_extra26.zspec.zsdl."
    - "Focus: __qualname__ and __module__ values for Field/FrozenInstanceError/InitVar classes, and KW_ONLY sentinel type metadata in the extra27 namespace."
    - "dataclasses_extra26 covers module-level function qualnames (dataclass/field/asdict/astuple/make_dataclass/replace/is_dataclass/fields) in a combined table."
    - "dataclasses_extra25 covers Field instance method qualnames (Field.__set_name__, Field.__repr__, Field.__init__) and sentinel type metadata."
    - "No prior dataclasses spec records a combined __qualname__.__eq__ table for Field/FrozenInstanceError/InitVar in the extra27 namespace."
    - "No prior dataclasses spec records a combined __module__.__eq__ table for Field/FrozenInstanceError/InitVar in the extra27 namespace."
    - "No prior dataclasses spec records KW_ONLY.__class__.__name__ == '_KW_ONLY_TYPE' in any invariant or table."
    - "No prior dataclasses spec records FrozenInstanceError.__bases__[0].__name__ == 'AttributeError' in any invariant or table."
    - "FrozenInstanceError inherits from AttributeError (its sole base class in Python 3.11+)."
    - "KW_ONLY is a singleton sentinel; its class _KW_ONLY_TYPE has len 13."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# dataclasses class __qualname__ values — combined table
#
# Field, FrozenInstanceError, and InitVar are all defined at module level in
# dataclasses; each has __qualname__ equal to its own class name.
# No prior dataclasses spec has all three together in a combined __qualname__
# table in the extra27 namespace.
# ---------------------------------------------------------------------------

table dataclasses_extra27.class_qualnames:
  description: "__qualname__.__eq__ for dataclasses.Field, FrozenInstanceError, InitVar"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Field,               Field.__qualname__.__eq__,               ["Field"],               true]
    - [FrozenInstanceError, FrozenInstanceError.__qualname__.__eq__,  ["FrozenInstanceError"], true]
    - [InitVar,             InitVar.__qualname__.__eq__,             ["InitVar"],             true]

# ---------------------------------------------------------------------------
# dataclasses class __qualname__.__len__() — combined table
#
# Verifies the string length of each class __qualname__:
#   Field -> 5, FrozenInstanceError -> 19, InitVar -> 7
# No prior dataclasses spec collects these three qualname lengths together
# in a single table in the extra27 namespace.
# ---------------------------------------------------------------------------

table dataclasses_extra27.class_qualname_lens:
  description: "__qualname__.__len__() for dataclasses.Field, FrozenInstanceError, InitVar"
  kind: python_call_eq
  category: class_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [Field,               Field.__qualname__.__len__,               [],  5]
    - [FrozenInstanceError, FrozenInstanceError.__qualname__.__len__,  [], 19]
    - [InitVar,             InitVar.__qualname__.__len__,             [],  7]

# ---------------------------------------------------------------------------
# dataclasses class __module__ values — combined table
#
# Field, FrozenInstanceError, and InitVar all have __module__ == 'dataclasses'.
# No prior dataclasses spec has all three together in a combined __module__
# table in the extra27 namespace.
# ---------------------------------------------------------------------------

table dataclasses_extra27.class_modules:
  description: "__module__.__eq__ for dataclasses.Field, FrozenInstanceError, InitVar"
  kind: python_call_eq
  category: module_attrs
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [Field,               Field.__module__.__eq__,               ["dataclasses"], true]
    - [FrozenInstanceError, FrozenInstanceError.__module__.__eq__,  ["dataclasses"], true]
    - [InitVar,             InitVar.__module__.__eq__,             ["dataclasses"], true]

# ---------------------------------------------------------------------------
# dataclasses class __module__.__len__() — combined table
#
# All three __module__ strings equal 'dataclasses' which has length 11.
# No prior dataclasses spec collects these three module name lengths together
# in a single table in the extra27 namespace.
# ---------------------------------------------------------------------------

table dataclasses_extra27.class_module_lens:
  description: "__module__.__len__() for dataclasses.Field, FrozenInstanceError, InitVar"
  kind: python_call_eq
  category: module_attr_lengths
  id_prefix: module_len

  columns: [id, function, args, expected]
  rows:
    - [Field,               Field.__module__.__len__,               [], 11]
    - [FrozenInstanceError, FrozenInstanceError.__module__.__len__,  [], 11]
    - [InitVar,             InitVar.__module__.__len__,             [], 11]

# ---------------------------------------------------------------------------
# dataclasses.KW_ONLY.__class__.__name__ == '_KW_ONLY_TYPE' — standalone invariant
#
# KW_ONLY is a singleton sentinel value; its internal class is _KW_ONLY_TYPE.
# No prior dataclasses spec records KW_ONLY.__class__.__name__ in any invariant.
# ---------------------------------------------------------------------------

invariant dataclasses_extra27.KW_ONLY.class_name:
  description: "dataclasses.KW_ONLY.__class__.__name__ == '_KW_ONLY_TYPE' — KW_ONLY sentinel internal type name"
  category: sentinel_attrs
  kind: python_call_eq
  function: KW_ONLY.__class__.__name__.__eq__
  args: ["_KW_ONLY_TYPE"]
  expected: true

# ---------------------------------------------------------------------------
# dataclasses.KW_ONLY.__class__.__name__.__len__() == 13 — standalone invariant
#
# len('_KW_ONLY_TYPE') == 13.
# No prior dataclasses spec records this length in the extra27 namespace.
# ---------------------------------------------------------------------------

invariant dataclasses_extra27.KW_ONLY.class_name_len:
  description: "len(dataclasses.KW_ONLY.__class__.__name__) == 13 — len('_KW_ONLY_TYPE') == 13"
  category: sentinel_attr_lengths
  kind: python_call_eq
  function: KW_ONLY.__class__.__name__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# dataclasses.FrozenInstanceError.__bases__[0].__name__ == 'AttributeError'
#
# FrozenInstanceError inherits from AttributeError (its sole base class).
# No prior dataclasses spec records FrozenInstanceError.__bases__[0].__name__
# in any invariant or table.
# ---------------------------------------------------------------------------

invariant dataclasses_extra27.FrozenInstanceError.base_name:
  description: "dataclasses.FrozenInstanceError.__bases__[0].__name__ == 'AttributeError' — inherits from AttributeError"
  category: class_attrs
  kind: python_call_eq
  function: "FrozenInstanceError.__bases__[0].__name__.__eq__"
  args: ["AttributeError"]
  expected: true

# ---------------------------------------------------------------------------
# len(dataclasses.FrozenInstanceError.__bases__[0].__name__) == 14
#
# len('AttributeError') == 14.
# No prior dataclasses spec records this length in the extra27 namespace.
# ---------------------------------------------------------------------------

invariant dataclasses_extra27.FrozenInstanceError.base_name_len:
  description: "len(dataclasses.FrozenInstanceError.__bases__[0].__name__) == 14 — len('AttributeError') == 14"
  category: class_attr_lengths
  kind: python_call_eq
  function: "FrozenInstanceError.__bases__[0].__name__.__len__"
  args: []
  expected: 14
