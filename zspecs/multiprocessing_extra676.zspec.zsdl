spec: multiprocessing_extra676
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.connection.html"
  not_derived_from: ["CPython source code"]
  notes: ["Covers multiprocessing.connection module class identity for Connection and Listener"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra676.connection_identity:
  description: "Identity checks for multiprocessing.connection.Connection attributes"
  kind: python_call_eq
  category: class_identity
  id_prefix: mp676ci
  columns: [id, function, args, expected]
  rows:
    - [mp676ci001, multiprocessing.connection.Connection.__qualname__.__eq__, ["Connection"], true]
    - [mp676ci002, multiprocessing.connection.Connection.__module__.__eq__, ["multiprocessing.connection"], true]
    - [mp676ci003, multiprocessing.connection.Connection.__class__.__name__.__eq__, ["type"], true]
    - [mp676ci004, multiprocessing.connection.Connection.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [mp676ci005, multiprocessing.connection.Connection.__init__.__qualname__.__eq__, ["Connection.__init__"], true]
    - [mp676ci006, multiprocessing.connection.Connection.send.__qualname__.__eq__, ["Connection.send"], true]
    - [mp676ci007, multiprocessing.connection.Connection.recv.__qualname__.__eq__, ["Connection.recv"], true]
    - [mp676ci008, multiprocessing.connection.Connection.close.__qualname__.__eq__, ["Connection.close"], true]

table multiprocessing_extra676.client_listener_identity:
  description: "Identity checks for multiprocessing.connection.Client and Listener"
  kind: python_call_eq
  category: class_identity
  id_prefix: mp676cl
  columns: [id, function, args, expected]
  rows:
    - [mp676cl001, multiprocessing.connection.Client.__qualname__.__eq__, ["Client"], true]
    - [mp676cl002, multiprocessing.connection.Listener.__qualname__.__eq__, ["Listener"], true]
    - [mp676cl003, multiprocessing.connection.Listener.__module__.__eq__, ["multiprocessing.connection"], true]
    - [mp676cl004, multiprocessing.connection.Listener.__init__.__qualname__.__eq__, ["Listener.__init__"], true]
