spec: safe_buffer
version: ">=5.0.0"
backend: node(safe-buffer)

docs: https://github.com/feross/safe-buffer#readme

provenance:
  derived_from:
    - "safe-buffer README — https://github.com/feross/safe-buffer#readme"
    - "Node.js Buffer documentation — https://nodejs.org/api/buffer.html"
    - "Test vectors verified with safe-buffer via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "safe-buffer source"
  notes:
    - "Safer Buffer API for Node — re-exports the built-in Buffer with the deprecated unsafe constructor disabled."
    - "Install: npm install safe-buffer"
    - "v5 CJS; named export Buffer (identical to Node's global Buffer on modern Node)."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws TypeError on invalid alloc/from arguments."
  stderr: "null"
  stickiness: "N/A — each Buffer independent."
  codes: {}

invariant safe_buffer.alloc_zeros:
  description: "Buffer.alloc(5) creates a 5-byte zero-filled buffer"
  category: alloc
  kind: node_chain_eq
  entry: named
  function: "Buffer.alloc"
  entry_args: [5]
  chain:
    - {get: length}
  expected: 5

invariant safe_buffer.alloc_byte_value_zero:
  description: "Each byte of alloc(N) is 0 (.at(0))"
  category: alloc
  kind: node_chain_eq
  entry: named
  function: "Buffer.alloc"
  entry_args: [5]
  chain:
    - {method: at, args: [0]}
  expected: 0

invariant safe_buffer.alloc_with_fill:
  description: "alloc(5, 0xff).at(0) is 255"
  category: alloc
  kind: node_chain_eq
  entry: named
  function: "Buffer.alloc"
  entry_args: [5, 255]
  chain:
    - {method: at, args: [0]}
  expected: 255

invariant safe_buffer.from_string_length:
  description: "Buffer.from('hello').length is 5"
  category: from
  kind: node_chain_eq
  entry: named
  function: "Buffer.from"
  entry_args: ["hello"]
  chain:
    - {get: length}
  expected: 5

invariant safe_buffer.from_string_round_trip:
  description: "Buffer.from('hello').toString() returns 'hello'"
  category: from
  kind: node_chain_eq
  entry: named
  function: "Buffer.from"
  entry_args: ["hello"]
  chain:
    - {method: toString, args: []}
  expected: "hello"

invariant safe_buffer.from_array:
  description: "Buffer.from([0x68, 0x69]).toString() is 'hi'"
  category: from
  kind: node_chain_eq
  entry: named
  function: "Buffer.from"
  entry_args: [[104, 105]]
  chain:
    - {method: toString, args: []}
  expected: "hi"

invariant safe_buffer.from_string_hex_encoding:
  description: "Buffer.from('hello').toString('hex') is '68656c6c6f'"
  category: encoding
  kind: node_chain_eq
  entry: named
  function: "Buffer.from"
  entry_args: ["hello"]
  chain:
    - {method: toString, args: ["hex"]}
  expected: "68656c6c6f"

invariant safe_buffer.from_hex_decode:
  description: "Buffer.from('68656c6c6f', 'hex').toString() is 'hello'"
  category: encoding
  kind: node_chain_eq
  entry: named
  function: "Buffer.from"
  entry_args: ["68656c6c6f", "hex"]
  chain:
    - {method: toString, args: []}
  expected: "hello"

invariant safe_buffer.from_string_base64_encoding:
  description: "Buffer.from('hello').toString('base64') is 'aGVsbG8='"
  category: encoding
  kind: node_chain_eq
  entry: named
  function: "Buffer.from"
  entry_args: ["hello"]
  chain:
    - {method: toString, args: ["base64"]}
  expected: "aGVsbG8="
