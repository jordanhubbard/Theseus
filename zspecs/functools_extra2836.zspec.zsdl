spec: functools_extra2836
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "any proprietary source"
    - "zspecs/functools_extra2821.zspec.zsdl — wave 635 predecessor (__radd__, __rsub__, __rmul__)"
  notes:
    - "Wave 636 (_extra2836): __rtruediv__, __rfloordiv__, and __rmod__ dict-presence checks (reflected true division, floor division, modulo)."
    - "functools.partial is a C-level type — no reflected arithmetic operators defined."
    - "functools.partialmethod is a pure-Python class — no reflected arithmetic operators defined."
    - "functools.cached_property is a pure-Python descriptor class — no reflected arithmetic operators defined."
    - "functools.singledispatchmethod is a pure-Python class — no reflected arithmetic operators defined."
    - "None of the functools utility types implement numeric arithmetic protocols; __rtruediv__, __rfloordiv__, __rmod__ are all absent."
    - "Reflected operators (__rtruediv__, __rfloordiv__, __rmod__) are invoked when the left operand does not support the operation; these higher-order function wrappers have no numeric semantics."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __rtruediv__ dict-presence (reflected true division)
#
# functools.partial, partialmethod, cached_property, singledispatchmethod
# are utility wrappers — none define __rtruediv__ in their own __dict__.
# ---------------------------------------------------------------------------

table functools_extra2836.rtruediv_protocol:
  description: "functools types __rtruediv__ dict-presence checks — all False (no reflected true division protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2836
  columns: [id, function, args, expected]
  rows:
    - ["ft2836001", "functools.partial.__dict__.__contains__",              ["__rtruediv__"], false]
    - ["ft2836002", "functools.partialmethod.__dict__.__contains__",        ["__rtruediv__"], false]
    - ["ft2836003", "functools.cached_property.__dict__.__contains__",      ["__rtruediv__"], false]
    - ["ft2836004", "functools.singledispatchmethod.__dict__.__contains__",  ["__rtruediv__"], false]

# ---------------------------------------------------------------------------
# Table 2: __rfloordiv__ dict-presence (reflected floor division)
#
# None of the functools types define __rfloordiv__ — these classes wrap
# callables and have no numeric floor division semantics.
# ---------------------------------------------------------------------------

table functools_extra2836.rfloordiv_protocol:
  description: "functools types __rfloordiv__ dict-presence checks — all False (no reflected floor division protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2836
  columns: [id, function, args, expected]
  rows:
    - ["ft2836005", "functools.partial.__dict__.__contains__",              ["__rfloordiv__"], false]
    - ["ft2836006", "functools.partialmethod.__dict__.__contains__",        ["__rfloordiv__"], false]
    - ["ft2836007", "functools.cached_property.__dict__.__contains__",      ["__rfloordiv__"], false]
    - ["ft2836008", "functools.singledispatchmethod.__dict__.__contains__",  ["__rfloordiv__"], false]

# ---------------------------------------------------------------------------
# Table 3: __rmod__ dict-presence (reflected modulo)
#
# None of the functools types define __rmod__ — higher-order function
# utilities have no modulo or remainder semantics.
# ---------------------------------------------------------------------------

table functools_extra2836.rmod_protocol:
  description: "functools types __rmod__ dict-presence checks — all False (no reflected modulo protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2836
  columns: [id, function, args, expected]
  rows:
    - ["ft2836009", "functools.partial.__dict__.__contains__",              ["__rmod__"], false]
    - ["ft2836010", "functools.partialmethod.__dict__.__contains__",        ["__rmod__"], false]
    - ["ft2836011", "functools.cached_property.__dict__.__contains__",      ["__rmod__"], false]
    - ["ft2836012", "functools.singledispatchmethod.__dict__.__contains__",  ["__rmod__"], false]

# ---------------------------------------------------------------------------
# Table 4: combined reflected division/modulo operator absence — all three ops
#
# Cross-check: each type lacks all three reflected division/modulo operators.
# Confirms that the functools API surface is strictly about higher-order
# function utilities, not numeric true division, floor division, or modulo.
# ---------------------------------------------------------------------------

table functools_extra2836.reflected_divmod_absent:
  description: "functools types full __rtruediv__/__rfloordiv__/__rmod__ absence cross-check — all False"
