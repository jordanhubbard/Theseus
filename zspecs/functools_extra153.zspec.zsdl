spec: functools_extra153
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools._lru_cache_wrapper C extension type (the return type of lru_cache) — __name__ '_lru_cache_wrapper' len 18, __module__ 'functools', __bases__[0].__name__ 'object', MRO len 2; functools.__loader__ — __class__.__name__ 'SourceFileLoader'; functools.__package__ — empty string, len 0; functools.cache — Python function, __qualname__ 'cache' len 5, __module__ 'functools', __doc__ len 64, co_argcount 1; functools.reduce — C builtin, __qualname__ 'reduce', __module__ '_functools', __doc__ len 389; functools.WRAPPER_ASSIGNMENTS — tuple len 6; functools.WRAPPER_UPDATES — tuple len 1 (Wave 276)."
    - "The return type of functools.lru_cache()(f) is functools._lru_cache_wrapper, a C extension type defined in Modules/_functoolsmodule.c; its __name__ is '_lru_cache_wrapper' (len 18); __module__ is 'functools'; __bases__[0].__name__ is 'object'; MRO len is 2. Verified with Python 3.14.3."
    - "functools.__loader__.__class__.__name__ == 'SourceFileLoader' — functools is a source module; its loader is importlib.machinery.SourceFileLoader. Verified with Python 3.14.3."
    - "functools.__package__ == '' (empty string, len 0) — top-level source modules have empty __package__. Verified with Python 3.14.3."
    - "functools.cache is a Python function defined in Lib/functools.py (added in 3.9); __qualname__ == 'cache' (len 5); __module__ == 'functools'; len(__doc__) == 64; co_argcount == 1. Verified with Python 3.14.3."
    - "functools.reduce is a C builtin from _functoolsmodule.c; __qualname__ == 'reduce' (len 6); __module__ == '_functools'; len(__doc__) == 389. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS is a tuple of 6 attribute names; functools.WRAPPER_UPDATES is a tuple of 1 attribute name ('__dict__'). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools._lru_cache_wrapper — C extension type identity
#
# Wave 276 theme: the _lru_cache_wrapper C extension type is what
# lru_cache()(f) returns; it wraps a callable with a bounded LRU cache.
#
# The wrapper's __class__.__name__ == '_lru_cache_wrapper'
# The wrapper class's __name__ == '_lru_cache_wrapper' (len 18)
# The wrapper class's __module__ == 'functools'
# The wrapper class's __bases__[0].__name__ == 'object'
# len(wrapper class's __mro__) == 2
#
# _lru_cache_wrapper is defined in Modules/_functoolsmodule.c and exposed
# in the functools module. New to extra153.
# ---------------------------------------------------------------------------

table functools_extra153.lru_cache_wrapper_type_identity:
  description: "functools._lru_cache_wrapper: C extension type returned by lru_cache()(f); __name__ '_lru_cache_wrapper' len 18, __module__ 'functools', __bases__[0]=='object', MRO len 2; wave 276; new to extra153"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolslruwrap153

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_wrapper_name_eq,
       "_lru_cache_wrapper.__name__.__eq__",
       ["_lru_cache_wrapper"],
       true,
       "functools._lru_cache_wrapper.__name__.__eq__('_lru_cache_wrapper') == True — the C extension type returned by applying lru_cache has __name__ '_lru_cache_wrapper', matching the PyTypeObject tp_name; str.__eq__('_lru_cache_wrapper') returns True; new to extra153"]
    - [lru_cache_wrapper_name_len_eq_18,
       "_lru_cache_wrapper.__name__.__len__",
       [],
       18,
       "functools._lru_cache_wrapper.__name__.__len__() == 18 — '__name__' is '_lru_cache_wrapper' which has 18 characters; len('_lru_cache_wrapper') == 18; new to extra153"]
    - [lru_cache_wrapper_module_eq_functools,
       "_lru_cache_wrapper.__module__.__eq__",
       ["functools"],
       true,
       "functools._lru_cache_wrapper.__module__.__eq__('functools') == True — _lru_cache_wrapper is defined in _functoolsmodule.c but exposed with __module__ set to 'functools'; str.__eq__('functools') returns True; new to extra153"]
    - [lru_cache_wrapper_class_eq_type,
       "_lru_cache_wrapper.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools._lru_cache_wrapper.__class__.__name__.__eq__('type') == True — _lru_cache_wrapper is a C extension type whose metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra153"]
    - [lru_cache_wrapper_bases_first_eq_object,
       "_lru_cache_wrapper.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools._lru_cache_wrapper.__bases__[0].__name__.__eq__('object') == True — _lru_cache_wrapper inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra153"]
    - [lru_cache_wrapper_mro_len_eq_2,
       "_lru_cache_wrapper.__mro__.__len__",
       [],
       2,
       "functools._lru_cache_wrapper.__mro__.__len__() == 2 — _lru_cache_wrapper inherits directly from object; MRO is [_lru_cache_wrapper, object]; len(__mro__) == 2; new to extra153"]

# ---------------------------------------------------------------------------
# Table 2: functools.__loader__ and functools.__package__
#
# Wave 276 theme: functools module loader and package identity.
#
# functools.__loader__.__class__.__name__ == 'SourceFileLoader'
# functools.__package__ == '' (empty string, len 0)
#
# functools is a pure-Python source module; its loader is
# importlib.machinery.SourceFileLoader. The __package__ attribute for a
# top-level module is an empty string (not the module name itself).
# New to extra153.
# ---------------------------------------------------------------------------

table functools_extra153.loader_package_identity:
  description: "functools.__loader__.__class__.__name__ 'SourceFileLoader'; functools.__package__ is empty string len 0; wave 276; new to extra153"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsloader153

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_eq_sourcefileloader,
       "__loader__.__class__.__name__.__eq__",
       ["SourceFileLoader"],
       true,
       "functools.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — functools is loaded from a .py source file; its loader is an instance of importlib.machinery.SourceFileLoader; __class__.__name__ is 'SourceFileLoader'; str.__eq__('SourceFileLoader') returns True; new to extra153"]
    - [loader_class_name_len_eq_16,
       "__loader__.__class__.__name__.__len__",
       [],
       16,
       "functools.__loader__.__class__.__name__.__len__() == 16 — 'SourceFileLoader' has 16 characters; len('SourceFileLoader') == 16; new to extra153"]
    - [package_eq_empty,
       "__package__.__eq__",
       [""],
       true,
       "functools.__package__.__eq__('') == True — the __package__ attribute for a top-level module (not a sub-package) is an empty string; str.__eq__('') returns True; new to extra153"]
    - [package_len_eq_0,
       "__package__.__len__",
       [],
       0,
       "functools.__package__.__len__() == 0 — __package__ is an empty string for the top-level functools module; len('') == 0; new to extra153"]
    - [file_class_eq_str,
       "__file__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.__file__.__class__.__name__.__eq__('str') == True — __file__ is a string giving the path to functools.py; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra153"]

# ---------------------------------------------------------------------------
# Table 3: functools.cache — Python function identity
#
# Wave 276 theme: functools.cache (added in Python 3.9) — unbounded LRU cache.
#
# functools.cache.__class__.__name__ == 'function'
# functools.cache.__qualname__ == 'cache' (len 5)
# functools.cache.__module__ == 'functools'
# len(functools.cache.__doc__) == 64
# functools.cache.__code__.co_argcount == 1
#
# cache(user_function) is a simple unbounded cache defined in Lib/functools.py.
# New to extra153.
# ---------------------------------------------------------------------------

table functools_extra153.cache_func_identity:
  description: "functools.cache: Python function (3.9+), __qualname__ 'cache' len 5, __module__ 'functools', __doc__ len 64, co_argcount 1; wave 276; new to extra153"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolscache153

  columns: [id, function, args, expected, description]
  rows:
    - [cache_class_eq_function,
       "cache.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.cache.__class__.__name__.__eq__('function') == True — cache is a Python function defined in Lib/functools.py (added in 3.9); __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra153"]
    - [cache_qualname_eq,
       "cache.__qualname__.__eq__",
       ["cache"],
       true,
       "functools.cache.__qualname__.__eq__('cache') == True — cache's __qualname__ is 'cache'; str.__eq__('cache') returns True; new to extra153"]
    - [cache_qualname_len_eq_5,
       "cache.__qualname__.__len__",
       [],
       5,
       "functools.cache.__qualname__.__len__() == 5 — __qualname__ is 'cache' which has 5 characters; len('cache') == 5; new to extra153"]
    - [cache_module_eq_functools,
       "cache.__module__.__eq__",
       ["functools"],
       true,
       "functools.cache.__module__.__eq__('functools') == True — cache is defined in Lib/functools.py; __module__ is 'functools'; str.__eq__('functools') returns True; new to extra153"]
    - [cache_doc_len_eq_64,
       "cache.__doc__.__len__",
       [],
       64,
       "functools.cache.__doc__.__len__() == 64 — the cache docstring has 64 characters in Python 3.14.3; len(__doc__) == 64; verified with Python 3.14.3; new to extra153"]
    - [cache_co_argcount_eq_1,
       "cache.__code__.co_argcount.__eq__",
       [1],
       true,
       "functools.cache.__code__.co_argcount.__eq__(1) == True — cache takes exactly 1 positional argument: the user function to wrap; co_argcount is 1; int.__eq__(1) returns True; new to extra153"]

# ---------------------------------------------------------------------------
# Table 4: functools.WRAPPER_ASSIGNMENTS and functools.WRAPPER_UPDATES
#
# Wave 276 theme: functools wrapper attribute constants.
#
# functools.WRAPPER_ASSIGNMENTS is a tuple of 6 attribute names
# functools.WRAPPER_UPDATES is a tuple of 1 attribute name ('__dict__')
#
# These constants control which attributes update_wrapper/wraps copies from
# the wrapped function. Defined in Lib/functools.py. New to extra153.
# ---------------------------------------------------------------------------

table functools_extra153.wrapper_constants_identity:
  description: "functools.WRAPPER_ASSIGNMENTS: tuple len 6; functools.WRAPPER_UPDATES: tuple len 1; control attributes copied by update_wrapper; wave 276; new to extra153"
  kind: python_call_eq
  category: identity
  id_prefix: functoolswrapper153

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_assignments_class_eq_tuple,
       "WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('tuple') == True — WRAPPER_ASSIGNMENTS is a tuple of attribute names that update_wrapper copies from the wrapped function to the wrapper; __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra153"]
    - [wrapper_assignments_len_eq_6,
       "WRAPPER_ASSIGNMENTS.__len__",
       [],
       6,
       "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — WRAPPER_ASSIGNMENTS contains 6 attribute names: '__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__' in Python 3.14.3; len == 6; new to extra153"]
    - [wrapper_updates_class_eq_tuple,
       "WRAPPER_UPDATES.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.WRAPPER_UPDATES.__class__.__name__.__eq__('tuple') == True — WRAPPER_UPDATES is a tuple of attribute names that update_wrapper updates (merges) on the wrapper from the wrapped function; __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra153"]
    - [wrapper_updates_len_eq_1,
       "WRAPPER_UPDATES.__len__",
       [],
       1,
       "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES contains 1 attribute name: '__dict__'; len == 1; verified with Python 3.14.3; new to extra153"]

