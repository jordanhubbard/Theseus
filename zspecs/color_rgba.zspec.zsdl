spec: color_rgba
version: ">=3.0.0"
backend: node(color-rgba)

docs: https://www.npmjs.com/package/color-rgba

provenance:
  derived_from:
    - "color-rgba README — https://www.npmjs.com/package/color-rgba"
    - "Test vectors verified with color-rgba via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "color-rgba source"
  notes:
    - "color-rgba is an npm package. Install: npm install color-rgba"
    - "Parses a CSS color string and returns [r, g, b, a] array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array [r, g, b, a] or undefined for invalid input."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table color_rgba.parse:
  kind: node_module_call_eq
  function: "default"
  category: color
  id_prefix: crgba

  columns: [id, args, expected]
  rows:
    - [named,   ["red"],           [255, 0, 0, 1]]
    - [hex,     ["#ff0000"],       [255, 0, 0, 1]]
    - [rgb,     ["rgb(0,128,0)"],  [0, 128, 0, 1]]
