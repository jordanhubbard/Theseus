spec: asyncio_extra1516
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-future.html — Python asyncio Future and Task documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — Python asyncio synchronization primitives"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_asynciomodule.c"
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "Wave 548 theme: arithmetic/numeric operator protocol dict-presence checks — __add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__, __pow__ in class __dict__."
    - "asyncio classes are async concurrency primitives — not numeric types. None of Queue, Task, Future, Lock, Event, Semaphore, Barrier, or TaskGroup define any arithmetic operator protocol methods (__add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__, __pow__) in their own __dict__."
    - "asyncio.Queue does not define any arithmetic operators because Queue is a FIFO async queue — qsize(), put(), get() are its interface, not numeric operations."
    - "asyncio.Future does not define any arithmetic operators — Future.result() and Future.set_result() handle futures; numeric operators would be nonsensical on an async future object."
    - "asyncio.Task does not define any arithmetic operators — Task is a Future subclass wrapping a coroutine; arithmetic on tasks is undefined."
    - "asyncio.Lock, Event, Semaphore: synchronization primitives with acquire()/release() interfaces — no arithmetic operators."
    - "asyncio.Barrier: a synchronization barrier (wait() interface) — no arithmetic operators."
    - "asyncio.TaskGroup: async context manager grouping tasks — no arithmetic operators."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.Queue arithmetic operator __dict__ absence
#
# asyncio.Queue.__dict__.__contains__('__add__')      == False
# asyncio.Queue.__dict__.__contains__('__mul__')      == False
# asyncio.Queue.__dict__.__contains__('__sub__')      == False
# asyncio.Queue.__dict__.__contains__('__truediv__')  == False
# asyncio.Queue.__dict__.__contains__('__floordiv__') == False
# asyncio.Queue.__dict__.__contains__('__mod__')      == False
# asyncio.Queue.__dict__.__contains__('qsize')        == True  (sync queue method)
# ---------------------------------------------------------------------------

table asyncio_extra1516.queue_no_arithmetic_ops:
  description: "asyncio.Queue has no arithmetic operator methods in its own __dict__ — as1516qu namespace. asyncio.Queue.__dict__.__contains__('__add__')==False (Queue is an async FIFO queue — it provides put(), get(), qsize() but no arithmetic operators; adding arithmetic to a queue is semantically meaningless; Queue.__dict__ contains queue interface methods and async coroutines, not numeric operators); asyncio.Queue.__dict__.__contains__('__mul__')==False (no multiplication operator — Queue does not support repeating or scaling like a numeric type); asyncio.Queue.__dict__.__contains__('__sub__')==False (no subtraction operator on Queue); asyncio.Queue.__dict__.__contains__('__truediv__')==False (no division operator on Queue); asyncio.Queue.__dict__.__contains__('__floordiv__')==False (no floor division on Queue); asyncio.Queue.__dict__.__contains__('__mod__')==False (no modulo operator on Queue); asyncio.Queue.__dict__.__contains__('qsize')==True (Queue.qsize() IS defined directly in Queue.__dict__ — it returns the number of items in the queue; this is the canonical size-inspection method for asyncio.Queue); verified with Python 3.14.4"
  kind: python_call_eq
  category: arithmetic_protocol
  id_prefix: as1516qu

  columns: [id, function, args, expected, description]
  rows:
    - [as1516qu001, asyncio.Queue.__dict__.__contains__, ["__add__"],      false, "asyncio.Queue.__dict__.__contains__('__add__')==False — Queue is an async FIFO queue, not a numeric type; no __add__ in __dict__; verified with Python 3.14.4"]
    - [as1516qu002, asyncio.Queue.__dict__.__contains__, ["__mul__"],      false, "asyncio.Queue.__dict__.__contains__('__mul__')==False — no multiplication operator on Queue; verified with Python 3.14.4"]
    - [as1516qu003, asyncio.Queue.__dict__.__contains__, ["__sub__"],      false, "asyncio.Queue.__dict__.__contains__('__sub__')==False — no subtraction operator on Queue; verified with Python 3.14.4"]
    - [as1516qu004, asyncio.Queue.__dict__.__contains__, ["__truediv__"],  false, "asyncio.Queue.__dict__.__contains__('__truediv__')==False — no true division on Queue; verified with Python 3.14.4"]
    - [as1516qu005, asyncio.Queue.__dict__.__contains__, ["__floordiv__"], false, "asyncio.Queue.__dict__.__contains__('__floordiv__')==False — no floor division on Queue; verified with Python 3.14.4"]
    - [as1516qu006, asyncio.Queue.__dict__.__contains__, ["__mod__"],      false, "asyncio.Queue.__dict__.__contains__('__mod__')==False — no modulo operator on Queue; verified with Python 3.14.4"]
    - [as1516qu007, asyncio.Queue.__dict__.__contains__, ["qsize"],        true,  "asyncio.Queue.__dict__.__contains__('qsize')==True — qsize() is defined directly in Queue.__dict__; returns current queue depth; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Table 2: asyncio.Future and asyncio.Task arithmetic operator __dict__ absence
#
# asyncio.Future.__dict__.__contains__('__add__')      == False
# asyncio.Future.__dict__.__contains__('__mul__')      == False
# asyncio.Future.__dict__.__contains__('__sub__')      == False
# asyncio.Future.__dict__.__contains__('__truediv__')  == False
# asyncio.Future.__dict__.__contains__('__floordiv__') == False
# asyncio.Future.__dict__.__contains__('__mod__')      == False
# asyncio.Future.__dict__.__contains__('result')       == True  (sync result method)
# asyncio.Task.__dict__.__contains__('__add__')        == False
# asyncio.Task.__dict__.__contains__('__pow__')        == False
# ---------------------------------------------------------------------------

table asyncio_extra1516.future_task_no_arithmetic_ops:
  description: "asyncio.Future and asyncio.Task have no arithmetic operator methods in their own __dict__ — as1516ft namespace. asyncio.Future.__dict__.__contains__('__add__')==False (asyncio.Future is an awaitable async result container — it defines __await__, result(), set_result(), cancel(), done() in its C-level __dict__, but no arithmetic operators; Future represents a pending computation, not a numeric value); asyncio.Future.__dict__.__contains__('__mul__')==False (no multiplication on Future); asyncio.Future.__dict__.__contains__('__sub__')==False (no subtraction on Future); asyncio.Future.__dict__.__contains__('__truediv__')==False (no division on Future); asyncio.Future.__dict__.__contains__('__floordiv__')==False (no floor division on Future); asyncio.Future.__dict__.__contains__('__mod__')==False (no modulo on Future); asyncio.Future.__dict__.__contains__('result')==True (Future.result() IS defined directly in Future.__dict__ — it returns the result of the future or raises the exception; this is the core retrieval interface); asyncio.Task.__dict__.__contains__('__add__')==False (Task is a Future subclass wrapping a coroutine; no arithmetic operators); asyncio.Task.__dict__.__contains__('__pow__')==False (no exponentiation on Task); verified with Python 3.14.4"
  kind: python_call_eq
  category: arithmetic_protocol
  id_prefix: as1516ft

  columns: [id, function, args, expected, description]
  rows:
    - [as1516ft001, asyncio.Future.__dict__.__contains__, ["__add__"],      false, "asyncio.Future.__dict__.__contains__('__add__')==False — Future is an async result container, not a numeric type; no __add__ in __dict__; verified with Python 3.14.4"]
    - [as1516ft002, asyncio.Future.__dict__.__contains__, ["__mul__"],      false, "asyncio.Future.__dict__.__contains__('__mul__')==False — no multiplication operator on Future; verified with Python 3.14.4"]
    - [as1516ft003, asyncio.Future.__dict__.__contains__, ["__sub__"],      false, "asyncio.Future.__dict__.__contains__('__sub__')==False — no subtraction operator on Future; verified with Python 3.14.4"]
    - [as1516ft004, asyncio.Future.__dict__.__contains__, ["__truediv__"],  false, "asyncio.Future.__dict__.__contains__('__truediv__')==False — no true division on Future; verified with Python 3.14.4"]
    - [as1516ft005, asyncio.Future.__dict__.__contains__, ["__floordiv__"], false, "asyncio.Future.__dict__.__contains__('__floordiv__')==False — no floor division on Future; verified with Python 3.14.4"]
    - [as1516ft006, asyncio.Future.__dict__.__contains__, ["__mod__"],      false, "asyncio.Future.__dict__.__contains__('__mod__')==False — no modulo on Future; verified with Python 3.14.4"]
    - [as1516ft007, asyncio.Future.__dict__.__contains__, ["result"],       true,  "asyncio.Future.__dict__.__contains__('result')==True — Future.result() is defined directly in Future.__dict__; the core retrieval interface; verified with Python 3.14.4"]
    - [as1516ft008, asyncio.Task.__dict__.__contains__,   ["__add__"],      false, "asyncio.Task.__dict__.__contains__('__add__')==False — Task is a coroutine wrapper, not a numeric type; no __add__; verified with Python 3.14.4"]
    - [as1516ft009, asyncio.Task.__dict__.__contains__,   ["__pow__"],      false, "asyncio.Task.__dict__.__contains__('__pow__')==False — no exponentiation on Task; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Table 3: asyncio synchronization primitives arithmetic operator __dict__ absence
#
# asyncio.Lock.__dict__.__contains__('__add__')          == False
# asyncio.Event.__dict__.__contains__('__mul__')         == False
# asyncio.Semaphore.__dict__.__contains__('__sub__')     == False
# asyncio.Barrier.__dict__.__contains__('__truediv__')   == False
# asyncio.TaskGroup.__dict__.__contains__('__floordiv__') == False
# asyncio.Lock.__dict__.__contains__('locked')           == True
# asyncio.Event.__dict__.__contains__('is_set')          == True
# asyncio.Barrier.__dict__.__contains__('wait')          == True
# ---------------------------------------------------------------------------

table asyncio_extra1516.sync_primitives_no_arithmetic_ops:
  description: "asyncio synchronization primitives have no arithmetic operators in their own __dict__ — as1516sp namespace. asyncio.Lock.__dict__.__contains__('__add__')==False (Lock is an async mutual exclusion primitive with locked(), acquire(), release() — no arithmetic; Lock semantics are boolean-like, not numeric); asyncio.Event.__dict__.__contains__('__mul__')==False (Event is an async signaling primitive with is_set(), set(), clear(), wait() — no multiplication operator); asyncio.Semaphore.__dict__.__contains__('__sub__')==False (Semaphore has an integer counter internally but does NOT expose arithmetic operators in its __dict__ — the counter is managed through acquire()/release(); no __sub__ defined); asyncio.Barrier.__dict__.__contains__('__truediv__')==False (Barrier is a synchronization point for a fixed number of coroutines; no division operator in its __dict__); asyncio.TaskGroup.__dict__.__contains__('__floordiv__')==False (TaskGroup is an async context manager for task grouping; no floor division operator); asyncio.Lock.__dict__.__contains__('locked')==True (Lock.locked() IS defined directly in Lock.__dict__ — returns True if the lock is held); asyncio.Event.__dict__.__contains__('is_set')==True (Event.is_set() IS defined in Event.__dict__ — returns True if the event is set); asyncio.Barrier.__dict__.__contains__('wait')==True (Barrier.wait() IS defined in Barrier.__dict__ — coroutine that waits until all parties reach the barrier); verified with Python 3.14.4"
  kind: python_call_eq
  category: arithmetic_protocol
  id_prefix: as1516sp

  columns: [id, function, args, expected, description]
  rows:
    - [as1516sp001, asyncio.Lock.__dict__.__contains__,      ["__add__"],       false, "asyncio.Lock.__dict__.__contains__('__add__')==False — Lock is a mutual exclusion primitive, not numeric; no __add__; verified with Python 3.14.4"]
    - [as1516sp002, asyncio.Event.__dict__.__contains__,     ["__mul__"],       false, "asyncio.Event.__dict__.__contains__('__mul__')==False — Event is a signaling primitive, not numeric; no __mul__; verified with Python 3.14.4"]
    - [as1516sp003, asyncio.Semaphore.__dict__.__contains__, ["__sub__"],       false, "asyncio.Semaphore.__dict__.__contains__('__sub__')==False — Semaphore counter is managed via acquire/release, not __sub__; verified with Python 3.14.4"]
    - [as1516sp004, asyncio.Barrier.__dict__.__contains__,   ["__truediv__"],   false, "asyncio.Barrier.__dict__.__contains__('__truediv__')==False — Barrier is a sync point, not numeric; no __truediv__; verified with Python 3.14.4"]
    - [as1516sp005, asyncio.TaskGroup.__dict__.__contains__, ["__floordiv__"],  false, "asyncio.TaskGroup.__dict__.__contains__('__floordiv__')==False — TaskGroup groups tasks, not numeric; no __floordiv__; verified with Python 3.14.4"]
    - [as1516sp006, asyncio.Semaphore.__dict__.__contains__, ["__mod__"],       false, "asyncio.Semaphore.__dict__.__contains__('__mod__')==False — no modulo operator on Semaphore; verified with Python 3.14.4"]
    - [as1516sp007, asyncio.Lock.__dict__.__contains__,      ["locked"],        true,  "asyncio.Lock.__dict__.__contains__('locked')==True — Lock.locked() is defined directly in Lock.__dict__; returns True if lock is held; verified with Python 3.14.4"]
    - [as1516sp008, asyncio.Event.__dict__.__contains__,     ["is_set"],        true,  "asyncio.Event.__dict__.__contains__('is_set')==True — Event.is_set() is defined directly in Event.__dict__; returns True if the event is set; verified with Python 3.14.4"]
    - [as1516sp009, asyncio.Barrier.__dict__.__contains__,   ["wait"],          true,  "asyncio.Barrier.__dict__.__contains__('wait')==True — Barrier.wait() is defined directly in Barrier.__dict__; coroutine that waits until all parties arrive; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1516
# ---------------------------------------------------------------------------

invariant asyncio_extra1516.queue_no_add:
  description: "asyncio.Queue.__dict__.__contains__('__add__') returns False — asyncio.Queue does not define __add__ in its own __dict__; Queue is an async FIFO queue used for coroutine communication, not a numeric type; its __dict__ contains qsize(), put(), get(), task_done(), join(), shutdown() and async coroutines — all queue-management methods; no arithmetic operator protocol methods (__add__, __mul__, __sub__, etc.) exist in Queue.__dict__; wave 548 theme: arithmetic/numeric operator protocol __dict__ presence checks; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: arithmetic_protocol
  kind: python_call_eq
  function: asyncio.Queue.__dict__.__contains__
  args: ["__add__"]
  expected: false

invariant asyncio_extra1516.future_no_mul:
  description: "asyncio.Future.__dict__.__contains__('__mul__') returns False — asyncio.Future does not define __mul__ in its own __dict__; Future is an awaitable result container used to represent the outcome of a coroutine or async operation; its __dict__ contains __await__, result(), set_result(), cancel(), done(), cancelled(), get_loop() and callback management — all async result-handling methods; multiplication is semantically undefined for a future object; wave 548 theme: arithmetic operator __dict__ presence; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: arithmetic_protocol
  kind: python_call_eq
  function: asyncio.Future.__dict__.__contains__
  args: ["__mul__"]
  expected: false

invariant asyncio_extra1516.task_no_sub:
  description: "asyncio.Task.__dict__.__contains__('__sub__') returns False — asyncio.Task does not define __sub__ in its own __dict__; Task is a Future subclass that schedules and drives a coroutine to completion in the event loop; its __dict__ contains coroutine management methods (get_coro(), get_context()), cancellation methods (cancel(), cancelling(), uncancel()), and stack inspection (get_stack(), print_stack()) — no arithmetic operators; wave 548 theme; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: arithmetic_protocol
  kind: python_call_eq
  function: asyncio.Task.__dict__.__contains__
  args: ["__sub__"]
  expected: false

invariant asyncio_extra1516.semaphore_no_truediv:
  description: "asyncio.Semaphore.__dict__.__contains__('__truediv__') returns False — asyncio.Semaphore does not define __truediv__ in its own __dict__; Semaphore maintains an internal counter that is decremented on acquire() and incremented on release() — but this counter management is done through acquire/release coroutines, not through Python's arithmetic operator protocol; __truediv__ (the / operator) is absent from Semaphore.__dict__; wave 548 theme: arithmetic operator __dict__ presence; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: arithmetic_protocol
  kind: python_call_eq
  function: asyncio.Semaphore.__dict__.__contains__
  args: ["__truediv__"]
  expected: false
