spec: number_to_words
version: ">=1.0.0"
backend: node(number-to-words)

docs: https://www.npmjs.com/package/number-to-words

provenance:
  derived_from:
    - "number-to-words README — https://www.npmjs.com/package/number-to-words"
    - "Test vectors verified with number-to-words@1.2.4 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "number-to-words source"
  notes:
    - "number-to-words exports {toWords, toOrdinal, toWordsOrdinal}."
    - "toWords(n) converts an integer to its English words representation."
    - "toOrdinal(n) converts an integer to its ordinal English form."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns English words string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table number_to_words.toWords:
  kind: node_module_call_eq
  function: toWords
  category: toWords
  id_prefix: ntow

  columns: [id, args, expected]
  rows:
    - [one,      [1],    "one"]
    - [twelve,   [12],   "twelve"]
    - [hundred,  [100],  "one hundred"]
    - [thousand, [1000], "one thousand"]
    - [complex,  [42],   "forty-two"]

table number_to_words.toOrdinal:
  kind: node_module_call_eq
  function: toOrdinal
  category: toOrdinal
  id_prefix: ntoord

  columns: [id, args, expected]
  rows:
    - [first,   [1],  "1st"]
    - [second,  [2],  "2nd"]
    - [third,   [3],  "3rd"]
    - [fourth,  [4],  "4th"]
    - [twenty,  [21], "21st"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:05:39Z
  iterations: 1
  pass_count: 10
  fail_count: 0
  total_invariants: 10
  notes: Synthesis succeeded in 1 iteration(s). 10 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
