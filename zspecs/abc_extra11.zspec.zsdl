spec: abc_extra11
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc.zspec.zsdl through abc_extra10.zspec.zsdl."
    - "abc_extra10 covers: update_abstractmethods __module__/__qualname__/__class__.__name__; ABCMeta.__mro__[2].__name__ == 'object'; ABC.__mro__[1].__name__ == 'object'; ABCMeta.__subclasscheck__.__qualname__; ABC.__subclasshook__.__qualname__; ABC.__doc__.__len__ > 0; ABCMeta.__doc__.__len__ > 0; abstractmethod.__qualname__.__eq__ standalone; ABCMeta.__name__.__len__ == 7."
    - "abc_extra8 covers ABCMeta.__subclasscheck__.__name__ and class; ABCMeta.__instancecheck__ (via abc_extra)."
    - "NEW axes: ABCMeta.__instancecheck__.__qualname__ — not yet checked; ABCMeta.__bases__[0].__name__ == 'type' as standalone invariant; ABC.__abstractmethods__.__class__.__name__ == 'frozenset'; abstractmethod.__class__.__name__ == 'function' as standalone invariant; get_cache_token.__doc__ nonempty; update_abstractmethods.__doc__ nonempty."
    - "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' — qualified name includes enclosing class."
    - "abc.ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta inherits directly from type (it is a metaclass)."
    - "abc.ABC.__abstractmethods__.__class__.__name__ == 'frozenset' — __abstractmethods__ is always a frozenset."
    - "abc.abstractmethod.__class__.__name__ == 'function' — abstractmethod is a plain Python function (not a C builtin)."
    - "len(abc.get_cache_token.__doc__) > 0 — get_cache_token has a non-empty docstring."
    - "len(abc.update_abstractmethods.__doc__) > 0 — update_abstractmethods has a non-empty docstring."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ABCMeta.__instancecheck__.__qualname__
#
# abc_extra covers ABCMeta.__instancecheck__.__name__ == '__instancecheck__'
# and ABCMeta.__instancecheck__.__class__.__name__.
# abc_extra10 covers ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__'.
# No prior spec checks ABCMeta.__instancecheck__.__qualname__.
# ---------------------------------------------------------------------------

invariant abc_extra11.ABCMeta.instancecheck_qualname:
  description: "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' — qualified name includes enclosing class"
  category: abcmeta_class
  kind: python_call_eq
  function: ABCMeta.__instancecheck__.__qualname__.__eq__
  args: ["ABCMeta.__instancecheck__"]
  expected: true

# ---------------------------------------------------------------------------
# ABCMeta.__bases__[0].__name__ == 'type'
#
# abc.zspec confirms ABCMeta.__class__.__name__ == 'type' (ABCMeta is an instance of type).
# abc_extra9 confirms ABCMeta.__bases__.__len__() == 1.
# abc_extra9 confirms ABCMeta.__mro__[1].__name__ == 'type' (middle MRO entry).
# No prior spec checks ABCMeta.__bases__[0].__name__ directly as a standalone
# boolean __eq__ invariant. This confirms ABCMeta's declared superclass is type.
# ---------------------------------------------------------------------------

invariant abc_extra11.ABCMeta.base_is_type:
  description: "abc.ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta directly subclasses type (it is a metaclass)"
  category: abcmeta_class
  kind: python_call_eq
  function: ABCMeta.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "type"

# ---------------------------------------------------------------------------
# ABC.__abstractmethods__ — type is frozenset, length is 0
#
# abc_extra9 confirms ABC.__abstractmethods__ is a frozenset via
# ABC.__abstractmethods__.__class__.__name__.__eq__('frozenset') — wait,
# that was not confirmed in any prior spec. abc_extra9 only covers ABCMeta.__dict__
# class name. No prior spec checks ABC.__abstractmethods__.__class__.__name__.
# ABC itself has no abstract methods, so the frozenset is empty (length 0).
# ---------------------------------------------------------------------------

invariant abc_extra11.ABC.abstractmethods_is_frozenset:
  description: "abc.ABC.__abstractmethods__.__class__.__name__ == 'frozenset' — __abstractmethods__ is always a frozenset"
  category: abc_class
  kind: python_call_eq
  function: ABC.__abstractmethods__.__class__.__name__.__eq__
  args: ["frozenset"]
  expected: true

invariant abc_extra11.ABC.abstractmethods_empty:
  description: "len(abc.ABC.__abstractmethods__) == 0 — ABC itself has no abstract methods"
  category: abc_class
  kind: python_call_eq
  function: ABC.__abstractmethods__.__len__
  args: []
  expected: 0

# ---------------------------------------------------------------------------
# abstractmethod.__class__.__name__ == 'function'
#
# abc_extra9 confirms abstractmethod.__isabstractmethod__.__class__.__name__ == 'bool'.
# abc_extra10 confirms update_abstractmethods.__class__.__name__ == 'function'.
# No prior spec checks abstractmethod.__class__.__name__ as a standalone boolean
# invariant via __eq__ chain. abstractmethod is a pure-Python decorator function.
# ---------------------------------------------------------------------------

invariant abc_extra11.abstractmethod.class_is_function:
  description: "abc.abstractmethod.__class__.__name__ == 'function' — abstractmethod is a pure-Python function"
  category: abstractmethod
  kind: python_call_eq
  function: abstractmethod.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# get_cache_token.__doc__ — non-empty docstring
#
# abc_extra9 confirms get_cache_token.__class__.__name__ == 'builtin_function_or_method'.
# abc_extra8 confirms get_cache_token.__qualname__ == 'get_cache_token'.
# No prior spec checks that get_cache_token has a non-empty docstring.
# ---------------------------------------------------------------------------

invariant abc_extra11.get_cache_token.doc_nonempty:
  description: "len(abc.get_cache_token.__doc__) > 0 — get_cache_token has a non-empty docstring"
  category: get_cache_token
  kind: python_call_eq
  function: get_cache_token.__doc__.__len__
  args: []
  method: __gt__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# update_abstractmethods.__doc__ — non-empty docstring
#
# abc_extra10 confirms update_abstractmethods.__module__, __qualname__, and
# __class__.__name__. No prior spec checks that update_abstractmethods has a
# non-empty docstring. As a pure-Python function it has a detailed docstring.
# ---------------------------------------------------------------------------

invariant abc_extra11.update_abstractmethods.doc_nonempty:
  description: "len(abc.update_abstractmethods.__doc__) > 0 — update_abstractmethods has a non-empty docstring"
  category: update_abstractmethods
  kind: python_call_eq
  function: update_abstractmethods.__doc__.__len__
  args: []
  method: __gt__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# ABCMeta.__mro__[0].__name__ == 'ABCMeta'
#
# abc_extra9 confirms ABCMeta.__mro__[1].__name__ == 'type' (middle MRO entry).
# abc_extra10 confirms ABCMeta.__mro__[2].__name__ == 'object' (last MRO entry).
# No prior spec checks ABCMeta.__mro__[0].__name__ — the first entry which
# must be ABCMeta itself (C3 linearization always starts with the class itself).
# ---------------------------------------------------------------------------

invariant abc_extra11.ABCMeta.mro_first_is_self:
  description: "abc.ABCMeta.__mro__[0].__name__ == 'ABCMeta' — first MRO entry is always the class itself"
  category: abcmeta_mro
  kind: python_call_eq
  function: ABCMeta.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "ABCMeta"
