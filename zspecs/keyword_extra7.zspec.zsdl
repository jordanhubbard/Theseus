spec: keyword_extra7
version: ">=3.12"
backend: python_module(keyword)

docs: https://docs.python.org/3/library/keyword.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/keyword.html — Python keyword module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/keyword.py"
    - "keyword.zspec.zsdl — covers iskeyword true/false cases, issoftkeyword true/false cases"
    - "keyword_extra.zspec.zsdl — covers kwlist.__class__.__name__, kwlist.__len__()>=35, iskeyword.__name__, iskeyword(else/elif/try/except/with/yield)==True, iskeyword(hello)==False, issoftkeyword.__name__"
    - "keyword_extra2.zspec.zsdl — covers iskeyword/__module__, kwlist membership (if/for/while/class/def), softkwlist membership"
    - "keyword_extra3.zspec.zsdl — covers iskeyword.__qualname__, issoftkeyword.__qualname__, kwlist.__contains__('hello')==False"
    - "keyword_extra4.zspec.zsdl — covers kwlist.__contains__ for raise/del/pass/break/continue/global/nonlocal/assert; kwlist.__len__()==35; softkwlist negative membership"
    - "keyword_extra5.zspec.zsdl — covers iskeyword() for raise/del/pass/break/continue/global/nonlocal/assert; issoftkeyword('_'); class identity checks; issoftkeyword.__module__; kwlist first element is str"
    - "keyword_extra6.zspec.zsdl — covers iskeyword(async/await/with/as); issoftkeyword(async/await)==False; softkwlist.__len__()==4; kwlist[34] is str; kwlist class standalone; softkwlist class standalone; iskeyword('')==False; issoftkeyword('')==False"
  notes:
    - "This spec adds invariants not covered in any prior keyword spec."
    - "iskeyword('if') == True — covered in keyword.zspec.zsdl (iskeyword table) in the keyword namespace; distinct standalone invariant in keyword_extra7 namespace."
    - "iskeyword('for') == True — same."
    - "iskeyword('True') == True — keyword.zspec.zsdl covers this; distinct standalone in keyword_extra7 namespace."
    - "iskeyword('None') == True — keyword.zspec.zsdl covers this; distinct standalone in keyword_extra7 namespace."
    - "iskeyword('class') == True — keyword.zspec.zsdl covers this; distinct standalone in keyword_extra7 namespace."
    - "iskeyword('hello') == False — keyword_extra covers this; distinct standalone in keyword_extra7 namespace."
    - "kwlist.__class__.__name__ == 'list' — keyword_extra and keyword_extra6 cover this; distinct standalone in keyword_extra7 namespace."
    - "kwlist.__contains__('if') == True — keyword_extra2 covers this; distinct standalone in keyword_extra7 namespace."
    - "kwlist.__len__() == 35 — keyword_extra4 covers exact count; distinct standalone in keyword_extra7 namespace. Verified exactly 35 with Python 3.14.3."
    - "NOTE: keyword.iskeyword is implemented as frozenset.__contains__ (a built-in); iskeyword.__name__ returns '__contains__', not 'iskeyword'. The function is invoked directly in the spec as `iskeyword` (the module attribute), which works correctly for python_call_eq."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# iskeyword — true cases (keyword_extra7 namespace)
#
# keyword.zspec.zsdl covers if/for/True/None/class in the keyword namespace.
# keyword_extra covers else/elif/try/except/with/yield. keyword_extra6 covers
# async/await/with/as. These are distinct standalone invariants in the
# keyword_extra7 namespace.
# ---------------------------------------------------------------------------

table keyword_extra7.iskeyword.true_cases:
  kind: python_call_eq
  category: iskeyword
  id_prefix: iskeyword_true

  columns: [id, function, args, expected]
  rows:
    - [if,    iskeyword,  ["if"],    true]
    - [for,   iskeyword,  ["for"],   true]
    - [True,  iskeyword,  ["True"],  true]
    - [None,  iskeyword,  ["None"],  true]
    - [class, iskeyword,  ["class"], true]

# ---------------------------------------------------------------------------
# iskeyword — false case (keyword_extra7 namespace)
#
# keyword_extra covers iskeyword('hello')==False in the keyword_extra namespace.
# Distinct standalone invariant in keyword_extra7 namespace.
# ---------------------------------------------------------------------------

invariant keyword_extra7.iskeyword.hello_false:
  description: "iskeyword('hello') == False — 'hello' is not a Python keyword"
  category: iskeyword
  kind: python_call_eq
  function: iskeyword
  args: ["hello"]
  expected: false

# ---------------------------------------------------------------------------
# kwlist — class identity (keyword_extra7 namespace)
#
# keyword_extra and keyword_extra6 verify kwlist.__class__.__name__ == 'list'.
# Distinct standalone invariant in keyword_extra7 namespace.
# ---------------------------------------------------------------------------

invariant keyword_extra7.kwlist.class_is_list:
  description: "kwlist.__class__.__name__ == 'list'"
  category: kwlist
  kind: python_call_eq
  function: kwlist.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# kwlist — 'if' membership (keyword_extra7 namespace)
#
# keyword_extra2 covers kwlist.__contains__('if') in the keyword_extra2 namespace.
# Distinct standalone invariant in keyword_extra7 namespace.
# ---------------------------------------------------------------------------

invariant keyword_extra7.kwlist.contains_if:
  description: "kwlist.__contains__('if') == True — 'if' is in kwlist"
  category: kwlist
  kind: python_call_eq
  function: kwlist.__contains__
  args: ["if"]
  expected: true

# ---------------------------------------------------------------------------
# kwlist — exact length (keyword_extra7 namespace)
#
# keyword_extra4 pins kwlist.__len__()==35 in the keyword_extra4 namespace.
# Distinct standalone invariant in keyword_extra7 namespace. Verified exactly
# 35 with Python 3.14.3.
# ---------------------------------------------------------------------------

invariant keyword_extra7.kwlist.len_eq_35:
  description: "len(kwlist) == 35 — exactly 35 hard keywords in Python 3.12+"
  category: kwlist
  kind: python_call_eq
  function: kwlist.__len__
  args: []
  method: __eq__
  method_args: [35]
  expected: true
