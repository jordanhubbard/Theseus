spec: http_cookiejar_extra2
version: ">=3.0"
backend: python_module(http.cookiejar)

docs: https://docs.python.org/3/library/http.cookiejar.html

provenance:
  derived_from:
    - "Python http.cookiejar documentation — https://docs.python.org/3/library/http.cookiejar.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/cookiejar.py"
  notes:
    - "This spec extends http_cookiejar.zspec.zsdl and http_cookiejar_extra.zspec.zsdl."
    - "http_cookiejar.zspec.zsdl covers: __name__ table for CookieJar/CookiePolicy/DefaultCookiePolicy/FileCookieJar/LWPCookieJar/MozillaCookieJar/Cookie/LoadError; CookieJar.__module__; DefaultCookiePolicy/__bases__[0].__name__=='CookiePolicy'; FileCookieJar/__bases__[0].__name__=='CookieJar'; LoadError/__bases__[0].__name__=='OSError'; CookieJar().__len__()==0."
    - "http_cookiejar_extra.zspec.zsdl covers: __qualname__ for all seven public classes."
    - "This spec adds: __module__ for FileCookieJar, LWPCookieJar, MozillaCookieJar, Cookie, CookiePolicy, DefaultCookiePolicy, and LoadError (base spec covers only CookieJar.__module__); hierarchy for LWPCookieJar and MozillaCookieJar (both inherit FileCookieJar); CookieJar base class hierarchy; __name__ length checks for CookieJar and FileCookieJar."
    - "LWPCookieJar.__bases__[0].__name__ == 'FileCookieJar' — LWPCookieJar stores cookies in LWP format."
    - "MozillaCookieJar.__bases__[0].__name__ == 'FileCookieJar' — MozillaCookieJar stores cookies in Mozilla/Netscape format."
    - "CookieJar.__bases__[0].__name__ == 'object' — CookieJar is the root cookie container with no framework base."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ checks — all classes except CookieJar
# (http_cookiejar.zspec.zsdl covers CookieJar.__module__ only;
#  the remaining seven classes are new in this spec)
# ---------------------------------------------------------------------------

table http_cookiejar_extra2.class_modules:
  kind: python_call_eq
  category: modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [FileCookieJar,       FileCookieJar.__module__.__eq__,       ["http.cookiejar"], true]
    - [LWPCookieJar,        LWPCookieJar.__module__.__eq__,        ["http.cookiejar"], true]
    - [MozillaCookieJar,    MozillaCookieJar.__module__.__eq__,    ["http.cookiejar"], true]
    - [Cookie,              Cookie.__module__.__eq__,              ["http.cookiejar"], true]
    - [CookiePolicy,        CookiePolicy.__module__.__eq__,        ["http.cookiejar"], true]
    - [DefaultCookiePolicy, DefaultCookiePolicy.__module__.__eq__, ["http.cookiejar"], true]
    - [LoadError,           LoadError.__module__.__eq__,           ["http.cookiejar"], true]

# ---------------------------------------------------------------------------
# Hierarchy — LWPCookieJar and MozillaCookieJar both inherit FileCookieJar
# (base spec covers FileCookieJar and DefaultCookiePolicy bases only;
#  LWPCookieJar and MozillaCookieJar bases are not yet tested)
# ---------------------------------------------------------------------------

invariant http_cookiejar_extra2.hierarchy.lwpcookiejar_base:
  description: "LWPCookieJar.__bases__[0].__name__ == 'FileCookieJar' — LWPCookieJar inherits from FileCookieJar"
  category: hierarchy
  kind: python_call_eq
  function: LWPCookieJar.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "FileCookieJar"

invariant http_cookiejar_extra2.hierarchy.mozillacookiejar_base:
  description: "MozillaCookieJar.__bases__[0].__name__ == 'FileCookieJar' — MozillaCookieJar inherits from FileCookieJar"
  category: hierarchy
  kind: python_call_eq
  function: MozillaCookieJar.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "FileCookieJar"

# ---------------------------------------------------------------------------
# CookieJar base class — root of the jar hierarchy
# (base spec verifies FileCookieJar.__bases__[0].__name__=='CookieJar' but
#  does not verify CookieJar's own base; CookieJar inherits from object)
# ---------------------------------------------------------------------------

invariant http_cookiejar_extra2.hierarchy.cookiejar_base:
  description: "CookieJar.__bases__[0].__name__ == 'object' — CookieJar has no cookiejar-specific parent"
  category: hierarchy
  kind: python_call_eq
  function: CookieJar.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# CookiePolicy base class hierarchy
# (base spec verifies DefaultCookiePolicy.__bases__[0].__name__=='CookiePolicy'
#  but does not verify CookiePolicy's own base class)
# ---------------------------------------------------------------------------

invariant http_cookiejar_extra2.hierarchy.cookiepolicy_base:
  description: "CookiePolicy.__bases__[0].__name__ == 'object' — CookiePolicy has no non-trivial base"
  category: hierarchy
  kind: python_call_eq
  function: CookiePolicy.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# __name__ length checks — spot-check that class names have no extra whitespace
# (no prior http.cookiejar spec checks __name__ lengths)
# ---------------------------------------------------------------------------

invariant http_cookiejar_extra2.CookieJar.name_len:
  description: "CookieJar.__name__.__len__() == 9 — 'CookieJar' has 9 characters"
  category: class_identity
  kind: python_call_eq
  function: CookieJar.__name__.__len__
  args: []
  expected: 9

invariant http_cookiejar_extra2.FileCookieJar.name_len:
  description: "FileCookieJar.__name__.__len__() == 13 — 'FileCookieJar' has 13 characters"
  category: class_identity
  kind: python_call_eq
  function: FileCookieJar.__name__.__len__
  args: []
  expected: 13

invariant http_cookiejar_extra2.DefaultCookiePolicy.name_len:
  description: "DefaultCookiePolicy.__name__.__len__() == 19 — 'DefaultCookiePolicy' has 19 characters"
  category: class_identity
  kind: python_call_eq
  function: DefaultCookiePolicy.__name__.__len__
  args: []
  expected: 19
