table abc_extra157.abc_abcmeta_cache_methods_and_abc_identity:
  description: "abc.ABCMeta private cache methods and abc.ABC identity checks in abcmetacache157 namespace — ABCMeta.__dict__.__contains__('_abc_caches_clear')==True (_abc_caches_clear is a private method defined directly on ABCMeta; _abc_caches_clear.__qualname__=='ABCMeta._abc_caches_clear' (len=25: 'ABCMeta'=7+'.'=1+'_abc_caches_clear'=17=25; '_abc_caches_clear'='_abc_'=5+'caches'=6+'_clear'=6=17); _abc_caches_clear() clears the ABCMeta caches used for isinstance/issubclass lookups); ABCMeta.__dict__.__contains__('_abc_registry_clear')==True (_abc_registry_clear.__qualname__=='ABCMeta._abc_registry_clear' (len=27: 'ABCMeta'=7+'.'=1+'_abc_registry_clear'=19=27; '_abc_registry_clear'='_abc_'=5+'registry'=8+'_clear'=6=19); _abc_registry_clear is the longest ABCMeta qualname in this spec at len=27); abc.ABC.__bases__[0].__name__=='object' (len=6; ABC is an ordinary class inheriting from object — it uses ABCMeta as its metaclass but does NOT inherit from ABCMeta or type); abc.ABC.__module__=='abc' (same top-level module as ABCMeta); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetacache157

  columns: [id, function, args, expected, description]
  rows:
    - [meta_has_caches_clear,   abc.ABCMeta.__dict__.__contains__,           ["_abc_caches_clear"],    true,  "ABCMeta.__dict__.__contains__('_abc_caches_clear') == True (private cache-clearing method); verified with Python 3.14.3"]
    - [meta_has_registry_clear, abc.ABCMeta.__dict__.__contains__,           ["_abc_registry_clear"],  true,  "ABCMeta.__dict__.__contains__('_abc_registry_clear') == True (private registry-clearing method); verified with Python 3.14.3"]
    - [abc_base_eq,             "abc.ABC.__bases__[0].__name__.__eq__",       ["object"],               true,  "abc.ABC.__bases__[0].__name__ == 'object' (ABC is an ordinary class inheriting from object); verified with Python 3.14.3"]
    - [abc_mod_eq,              abc.ABC.__module__.__eq__,                    ["abc"],                  true,  "abc.ABC.__module__ == 'abc' (len=3; same top-level abc module as ABCMeta); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra157
# ---------------------------------------------------------------------------

invariant abc_extra157.abc_ABCMeta_name_eq:
  description: "abc.ABCMeta.__name__.__eq__('ABCMeta') returns True — abc.ABCMeta is the metaclass that implements Python's Abstract Base Class protocol; ABCMeta.__name__=='ABCMeta' (len=7: 'ABC'=3+'Meta'=4=7; 'ABCMeta' = 'Abstract Base Class' + 'Metaclass' abbreviated); ABCMeta.__module__=='abc' (len=3; the top-level abc module — the shortest module path in the abc spec series; compare: asyncio.__module__ names have len>=13, concurrent.futures._base has len=24); ABCMeta.__bases__[0].__name__=='type' (ABCMeta inherits from type; ABCMeta IS a metaclass — its instances are classes; using class MyABC(metaclass=abc.ABCMeta) or class MyABC(abc.ABC) installs ABCMeta as the metaclass); compare: abc.ABC.__name__=='ABC' (len=3; 4 chars shorter than ABCMeta=7); compare: abc.ABC.__bases__[0].__name__=='object' (ABC inherits from object, not from type — ABC is an ordinary class); NEW in extra157: first standalone abc.ABCMeta.__name__ identity invariant in abcmetaid157 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra157.abc_ABCMeta_base_is_type:
  description: "abc.ABCMeta.__bases__[0].__name__.__eq__('type') returns True — abc.ABCMeta inherits from the built-in type metaclass; __bases__[0].__name__=='type' (len=4: 't'+'y'+'p'+'e'=4); ABCMeta IS a metaclass because it inherits from type; the metaclass protocol in Python: type is the default metaclass for all classes; ABCMeta extends type to add ABC tracking (register(), __instancecheck__(), __subclasscheck__()); compare: abc.ABC.__bases__[0].__name__=='object' (ABC is an ordinary class inheriting from object, NOT from type; ABC uses ABCMeta as its metaclass but does NOT inherit from it); the distinction: ABCMeta.__bases__[0].__name__=='type' (ABCMeta IS a metaclass) while ABC.__bases__[0].__name__=='object' (ABC IS a regular class); prior specs (extra155, extra156) verified ABCMeta methods; this spec establishes the ABCMeta base class identity for the first time; NEW in extra157: first standalone abc.ABCMeta.__bases__[0].__name__ identity invariant in abcmetaid157 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "abc.ABCMeta.__bases__[0].__name__.__eq__"
  args: ["type"]
  expected: true

invariant abc_extra157.abc_ABCMeta_dict_has_register:
  description: "abc.ABCMeta.__dict__.__contains__('register') returns True — 'register' is defined directly in ABCMeta.__dict__; register(cls, subclass) registers subclass as a virtual subclass of the ABC cls; ABCMeta.__dict__.__contains__('register')==True confirms register is on ABCMeta itself (not inherited from type); register.__qualname__=='ABCMeta.register' (len=16; established in prior specs); after registration, isinstance(subclass(), cls) and issubclass(subclass, cls) return True even if subclass does not inherit from cls; this 'virtual subclass' mechanism allows retroactive extension of existing classes to satisfy ABC interfaces; ABCMeta.__dict__ also contains __instancecheck__ (len=25 qualname), __subclasscheck__ (len=25), __new__ (len=15), _dump_registry (len=22), _abc_caches_clear (len=25), _abc_registry_clear (len=27) — all directly on ABCMeta; NEW in extra157: first standalone ABCMeta.__dict__.__contains__('register') invariant in abcmetadict157 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__contains__
  args: ["register"]
  expected: true

invariant abc_extra157.abc_ABCMeta_dict_has_instancecheck:
  description: "abc.ABCMeta.__dict__.__contains__('__instancecheck__') returns True — '__instancecheck__' is defined directly in ABCMeta.__dict__; ABCMeta.__instancecheck__ overrides isinstance() behavior for ABC-typed checks; __instancecheck__.__qualname__=='ABCMeta.__instancecheck__' (len=25; established in extra155); ABCMeta.__dict__.__contains__('__instancecheck__')==True confirms __instancecheck__ is defined on ABCMeta itself (not inherited from type, though type also has __instancecheck__); ABCMeta.__instancecheck__ checks both real instances (via type hierarchy) and virtual subclasses (registered via register()); compare: ABCMeta.__dict__.__contains__('__subclasscheck__')==True (__subclasscheck__ is also directly on ABCMeta — they are companions implementing isinstance and issubclass overrides); both __instancecheck__ and __subclasscheck__ have qualname length 25 (established in extra155) because 'instancecheck'=13 == 'subclasscheck'=13; NEW in extra157: first standalone ABCMeta.__dict__.__contains__('__instancecheck__') invariant in abcmetadict157 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__contains__
  args: ["__instancecheck__"]
  expected: true

invariant abc_extra157.abc_ABCMeta_module_eq:
  description: "abc.ABCMeta.__module__.__eq__('abc') returns True — abc.ABCMeta is defined in Lib/abc.py (with C acceleration in Modules/_abc.c); ABCMeta.__module__=='abc' (len=3: 'a'+'b'+'c'=3; the shortest module path encountered in the abc spec series); compare: the abc module has no submodules for its core classes — both ABCMeta and ABC are at the top-level 'abc' module (len=3); contrast with asyncio (events submodule: len=14), concurrent.futures (_base submodule: len=24), and multiprocessing (pool/context/process submodules: len=20-24); ABCMeta.__module__ (len=3) is the shortest module string in these spec series; ABCMeta.__name__=='ABCMeta' (len=7); ABCMeta.__bases__[0].__name__=='type' (len=4; metaclass base); NEW in extra157: first standalone abc.ABCMeta.__module__ identity invariant in abcmetaid157 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__module__.__eq__
  args: ["abc"]
  expected: true

