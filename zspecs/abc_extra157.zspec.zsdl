spec: abc_extra157
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: abc.ABCMeta class identity (name, module, base), abc.ABCMeta.__dict__ membership checks for key methods (_abc_caches_clear, _abc_registry_clear, register, __instancecheck__, __subclasscheck__, __new__), and abc.ABC class identity. abc.ABCMeta.__name__=='ABCMeta' (len=7: 'ABC'=3+'Meta'=4=7); abc.ABCMeta.__module__=='abc' (len=3: the top-level abc module — not a submodule); abc.ABCMeta.__bases__[0].__name__=='type' (len=4; ABCMeta inherits from type — it IS a metaclass; compare: abc.ABC.__bases__[0].__name__=='object' — ABC inherits from object, not from type). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__dict__ contains: 'register', '__instancecheck__', '__subclasscheck__', '__new__', '_dump_registry', '_abc_caches_clear', '_abc_registry_clear' — seven directly-defined methods/attributes; NOTE: '__prepare__' is NOT in ABCMeta.__dict__ (it is inherited from type, not defined on ABCMeta itself); _abc_caches_clear.__qualname__=='ABCMeta._abc_caches_clear' (len=25: 'ABCMeta'=7+'.'=1+'_abc_caches_clear'=17=25; '_abc_caches_clear'='_abc_'=5+'caches'=6+'_clear'=6=17); _abc_registry_clear.__qualname__=='ABCMeta._abc_registry_clear' (len=27: 'ABCMeta'=7+'.'=1+'_abc_registry_clear'=19=27; '_abc_registry_clear'='_abc_'=5+'registry'=8+'_clear'=6=19). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "ABCMeta.__bases__[0].__name__=='type' is the key distinction: ABCMeta is a metaclass (a class whose instances are classes); type is Python's built-in metaclass; ABCMeta inherits from type and adds ABC tracking (the _abc_data attribute and associated C machinery); compare: abc.ABC.__bases__[0].__name__=='object' (ABC is a regular class, not a metaclass); abc.ABCMeta.__module__=='abc' (len=3; the shortest module path in the abc spec series — just the module name 'abc' with no submodule, because ABC-related code is all in the top-level abc module); compare: 'abc' (len=3) vs 'asyncio.locks' (len=13) vs 'concurrent.futures._base' (len=24). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "Qualname lengths for ABCMeta methods in this spec: register(16) < __new__(15)... wait: 'ABCMeta.__new__'=7+1+7=15; register='ABCMeta.register'=7+1+8=16; _abc_caches_clear='ABCMeta._abc_caches_clear'=7+1+17=25; _abc_registry_clear='ABCMeta._abc_registry_clear'=7+1+19=27; length ordering: __new__(15) < register(16) < _abc_caches_clear(25) < _abc_registry_clear(27). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta class identity — extra157
#
# abc.ABCMeta.__name__.__eq__('ABCMeta')         == True
# abc.ABCMeta.__module__.__eq__('abc')            == True
# abc.ABCMeta.__bases__[0].__name__.__eq__('type') == True
# ---------------------------------------------------------------------------

table abc_extra157.abc_abcmeta_class_identity:
  description: "abc.ABCMeta class identity checks in abcmetaid157 namespace — abc.ABCMeta.__name__=='ABCMeta' (len=7: 'ABC'=3+'Meta'=4=7; ABCMeta is the metaclass that powers the Abstract Base Class machinery in Python; classes created with ABCMeta as their metaclass can use @abstractmethod decorators to mark methods that subclasses must implement); abc.ABCMeta.__module__=='abc' (len=3: 'a'+'b'+'c'=3; the shortest possible module name — ABCMeta lives at the top level of the abc module, not in any submodule; compare: 'abc' (len=3) << 'asyncio.locks' (len=13) << 'concurrent.futures._base' (len=24)); abc.ABCMeta.__bases__[0].__name__=='type' (len=4: 't'+'y'+'p'+'e'=4; ABCMeta inherits from the built-in type metaclass — ABCMeta IS a metaclass, a class whose instances are classes; contrast: abc.ABC.__bases__[0].__name__=='object' (ABC is an ordinary class, not a metaclass)); ABCMeta.__name__.__len__()==7; compare: ABC.__name__.__len__()==3 (ABC name is 4 chars shorter than ABCMeta=7); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetaid157

  columns: [id, function, args, expected, description]
  rows:
    - [meta_name_eq,   abc.ABCMeta.__name__.__eq__,                ["ABCMeta"],  true,  "abc.ABCMeta.__name__ == 'ABCMeta' (len=7: 'ABC'=3+'Meta'=4=7; the ABC metaclass); verified with Python 3.14.3"]
    - [meta_mod_eq,    abc.ABCMeta.__module__.__eq__,               ["abc"],      true,  "abc.ABCMeta.__module__ == 'abc' (len=3; top-level abc module, no submodule); verified with Python 3.14.3"]
    - [meta_base_eq,   "abc.ABCMeta.__bases__[0].__name__.__eq__",  ["type"],     true,  "abc.ABCMeta.__bases__[0].__name__ == 'type' (ABCMeta inherits from type; it IS a metaclass); verified with Python 3.14.3"]
    - [meta_name_len,  abc.ABCMeta.__name__.__len__,                [],           7,     "abc.ABCMeta.__name__.__len__() == 7 ('ABCMeta'; 4 longer than ABC=3); verified with Python 3.14.3"]

