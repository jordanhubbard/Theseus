#
# ABCMeta.__dict__.__contains__('register')            == True
# ABCMeta.__dict__.__contains__('__instancecheck__')   == True
# ABCMeta.__dict__.__contains__('__subclasscheck__')   == True
# ABCMeta.__dict__.__contains__('__new__')             == True
# ---------------------------------------------------------------------------

table abc_extra157.abc_abcmeta_dict_contains:
  description: "abc.ABCMeta.__dict__ membership checks in abcmetadict157 namespace — ABCMeta.__dict__.__contains__('register')==True (register(cls, subclass) is defined on ABCMeta; register.__qualname__=='ABCMeta.register' (len=16; established in prior specs); register() adds a class as a virtual subclass of an ABC so isinstance() and issubclass() return True even without real inheritance); ABCMeta.__dict__.__contains__('__instancecheck__')==True (__instancecheck__ is defined directly on ABCMeta, not inherited from type; qualname=='ABCMeta.__instancecheck__' (len=25; established in extra155)); ABCMeta.__dict__.__contains__('__subclasscheck__')==True (__subclasscheck__ is also defined on ABCMeta; qualname=='ABCMeta.__subclasscheck__' (len=25; established in extra155)); ABCMeta.__dict__.__contains__('__new__')==True (__new__ is defined on ABCMeta; qualname=='ABCMeta.__new__' (len=15)); NOTE: '__prepare__' is NOT in ABCMeta.__dict__ (it is inherited from type); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetadict157

  columns: [id, function, args, expected, description]
  rows:
    - [meta_has_register,  abc.ABCMeta.__dict__.__contains__,  ["register"],          true,  "ABCMeta.__dict__.__contains__('register') == True (direct method: register virtual subclasses); verified with Python 3.14.3"]
    - [meta_has_instchk,   abc.ABCMeta.__dict__.__contains__,  ["__instancecheck__"], true,  "ABCMeta.__dict__.__contains__('__instancecheck__') == True (direct method: isinstance() override); verified with Python 3.14.3"]
    - [meta_has_subclschk, abc.ABCMeta.__dict__.__contains__,  ["__subclasscheck__"], true,  "ABCMeta.__dict__.__contains__('__subclasscheck__') == True (direct method: issubclass() override); verified with Python 3.14.3"]
    - [meta_has_new,       abc.ABCMeta.__dict__.__contains__,  ["__new__"],           true,  "ABCMeta.__dict__.__contains__('__new__') == True (direct method: metaclass constructor); verified with Python 3.14.3"]

