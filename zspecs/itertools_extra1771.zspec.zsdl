spec: itertools_extra1771
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/itertools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 565 (_extra1771): async protocol dict-presence checks."
    - "Theme: which itertools stdlib types define __aenter__, __aexit__, __aiter__, __anext__, __await__ in their own __dict__."
    - "itertools.chain: C-level type producing a flat sequence from multiple iterables — implements sync __iter__/__next__, NOT async protocol -> all False."
    - "itertools.product: C-level type producing cartesian product tuples — implements sync __iter__/__next__, NOT async protocol -> all False."
    - "itertools.combinations: C-level type producing r-length combinations — implements sync __iter__/__next__, NOT async protocol -> all False."
    - "Rationale: all itertools types are C-level synchronous iterators; they implement the synchronous iterator protocol (__iter__, __next__) not the asynchronous iterator protocol (__aiter__, __anext__)."
    - "Complementary checks: itertools.chain.__dict__.__contains__('from_iterable') -> True (classmethod defined on chain). itertools.product.__dict__.__contains__('__new__') -> True (C type defines __new__). itertools.combinations.__dict__.__contains__('__new__') -> True."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: async protocol dict-presence checks for itertools types
#
# Wave 565 theme: which itertools types define __aenter__, __aexit__,
# __aiter__, __anext__, __await__ in their own __dict__.
#
# itertools.chain: flattens multiple iterables into a single sequential
#   iterator. C-level type; sync __iter__/__next__ only; no async protocol.
# itertools.product: cartesian product iterator. C-level type; sync only.
# itertools.combinations: r-length combination iterator. C-level type; sync only.
# ---------------------------------------------------------------------------

table itertools_extra1771.async_protocol:
  description: "itertools types async protocol dict-presence checks — all False — wave 565 _extra1771"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1771

  columns: [id, function, args, expected]
  rows:
    - ["it1771001", "itertools.chain.__dict__.__contains__",        ["__aenter__"], false]
    - ["it1771002", "itertools.chain.__dict__.__contains__",        ["__aexit__"],  false]
    - ["it1771003", "itertools.chain.__dict__.__contains__",        ["__aiter__"],  false]
    - ["it1771004", "itertools.chain.__dict__.__contains__",        ["__anext__"],  false]
    - ["it1771005", "itertools.chain.__dict__.__contains__",        ["__await__"],  false]
    - ["it1771006", "itertools.product.__dict__.__contains__",      ["__aenter__"], false]
    - ["it1771007", "itertools.product.__dict__.__contains__",      ["__aexit__"],  false]
    - ["it1771008", "itertools.product.__dict__.__contains__",      ["__aiter__"],  false]
    - ["it1771009", "itertools.product.__dict__.__contains__",      ["__anext__"],  false]
    - ["it1771010", "itertools.product.__dict__.__contains__",      ["__await__"],  false]
    - ["it1771011", "itertools.combinations.__dict__.__contains__", ["__aenter__"], false]
    - ["it1771012", "itertools.combinations.__dict__.__contains__", ["__aexit__"],  false]
    - ["it1771013", "itertools.combinations.__dict__.__contains__", ["__aiter__"],  false]
    - ["it1771014", "itertools.combinations.__dict__.__contains__", ["__anext__"],  false]
    - ["it1771015", "itertools.combinations.__dict__.__contains__", ["__await__"],  false]

# ---------------------------------------------------------------------------
# Table 2: complementary checks for itertools types
#
# The async theme is all-False for all itertools types (all are sync C-level
# iterators). Complementary checks confirm genuine itertools-specific structural
# properties:
# - itertools.chain.__dict__.__contains__('from_iterable') -> True: chain
#   exposes the from_iterable() classmethod in its own __dict__.
# - itertools.product.__dict__.__contains__('__new__') -> True: C-level types
#   define __new__ in their own __dict__.
# - itertools.combinations.__dict__.__contains__('__new__') -> True: same.
# - itertools.chain.__dict__.__contains__('__iter__') -> True: chain
#   implements the sync iterator protocol.
# - itertools.product.__dict__.__contains__('__iter__') -> True.
# - itertools.combinations.__dict__.__contains__('__iter__') -> True.
# - itertools.chain.__dict__.__contains__('__next__') -> True.
# - itertools.product.__dict__.__contains__('__next__') -> True.
# ---------------------------------------------------------------------------

table itertools_extra1771.complementary_checks:
  description: "itertools types sync-iterator protocol and classmethod dict-presence complementary checks — wave 565 _extra1771"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1771

  columns: [id, function, args, expected]
  rows:
    - ["it1771016", "itertools.chain.__dict__.__contains__",        ["from_iterable"], true]
    - ["it1771017", "itertools.product.__dict__.__contains__",      ["__new__"],       true]
    - ["it1771018", "itertools.combinations.__dict__.__contains__", ["__new__"],       true]
    - ["it1771019", "itertools.chain.__dict__.__contains__",        ["__iter__"],      true]
    - ["it1771020", "itertools.product.__dict__.__contains__",      ["__iter__"],      true]
    - ["it1771021", "itertools.combinations.__dict__.__contains__", ["__iter__"],      true]
    - ["it1771022", "itertools.chain.__dict__.__contains__",        ["__next__"],      true]
    - ["it1771023", "itertools.product.__dict__.__contains__",      ["__next__"],      true]
