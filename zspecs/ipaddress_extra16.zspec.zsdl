spec: ipaddress_extra16
version: ">=3.9"
backend: python_module(ipaddress)

docs: https://docs.python.org/3/library/ipaddress.html
rfcs:
  - "RFC 791 — Internet Protocol (IPv4)"
  - "RFC 2460 — Internet Protocol, Version 6 (IPv6)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ipaddress.html — Python ipaddress module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ipaddress.py"
    - "ipaddress_extra5.zspec.zsdl — covers __qualname__.__eq__ for all 6 classes, 3 factories, 2 exception classes."
    - "ipaddress_extra11.zspec.zsdl — covers IPv4Address/IPv6Address/IPv4Network/IPv6Network __name__.__len__()==11; ip_address/__qualname__.__len__(); IPv4/IPv6Interface __qualname__.__len__()==13."
    - "ipaddress_extra12.zspec.zsdl — covers ip_address/ip_network/ip_interface __qualname__.__len__(); IPv4/IPv6Interface __qualname__.__len__()==13."
    - "ipaddress_extra15.zspec.zsdl — covers ip_address/ip_network/ip_interface __module__.__len__()==9; summarize_address_range/collapse_addresses/get_mixed_type_key __module__."
  notes:
    - "This spec extends the ipaddress chain through extra15; it does NOT duplicate invariants in any prior spec."
    - "Focus: __qualname__.__len__() for the four base address/network classes (IPv4Address, IPv6Address, IPv4Network, IPv6Network) — not yet length-checked via __qualname__.__len__(). ipaddress_extra11 checked __name__.__len__()==11 for these same classes, but __qualname__.__len__ is a distinct attribute chain."
    - "ipaddress.IPv4Address.__qualname__.__len__() == 11 — len('IPv4Address') == 11. extra11 checks __name__.__len__()==11 (same value, different attribute). extra5 checks __qualname__.__eq__. No prior spec checks __qualname__.__len__() for IPv4Address. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ipaddress.IPv6Address.__qualname__.__len__() == 11 — len('IPv6Address') == 11. Same rationale as IPv4Address. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ipaddress.IPv4Network.__qualname__.__len__() == 11 — len('IPv4Network') == 11. Same rationale. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ipaddress.IPv6Network.__qualname__.__len__() == 11 — len('IPv6Network') == 11. Same rationale. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ipaddress.ip_address.__qualname__.__len__() == 10 and ip_network == 10 already covered by extra12. Not repeated here."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# IPv4Address / IPv6Address / IPv4Network / IPv6Network __qualname__.__len__()
#
# ipaddress_extra5 covers __qualname__.__eq__ for all six classes via table.
# ipaddress_extra11 covers __name__.__len__()==11 for these four classes.
# ipaddress_extra12 covers __qualname__.__len__() for IPv4Interface/IPv6Interface
# and the three factory functions; it does NOT cover the four base classes.
# len('IPv4Address') == len('IPv6Address') == len('IPv4Network') == len('IPv6Network') == 11.
# ---------------------------------------------------------------------------

table ipaddress_extra16.base_class_qualname_lengths:
  description: "Length of __qualname__ strings for the four primary ipaddress classes — all 11"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: clsqlen16

  columns: [id, function, args, expected]
  rows:
    - [IPv4Address, IPv4Address.__qualname__.__len__, [], 11]
    - [IPv6Address, IPv6Address.__qualname__.__len__, [], 11]
    - [IPv4Network, IPv4Network.__qualname__.__len__, [], 11]
    - [IPv6Network, IPv6Network.__qualname__.__len__, [], 11]

# ---------------------------------------------------------------------------
# IPv4Address.__qualname__.__eq__('IPv4Address') — standalone invariant
#
# ipaddress_extra5 covers IPv4Address.__qualname__.__eq__ in a table.
# This standalone invariant anchors the same property from the extra16 namespace
# as a companion to the length check above.
# ---------------------------------------------------------------------------

invariant ipaddress_extra16.IPv4Address.qualname_eq:
  description: "ipaddress.IPv4Address.__qualname__ == 'IPv4Address'"
  category: class_qualnames
  kind: python_call_eq
  function: IPv4Address.__qualname__.__eq__
  args: ["IPv4Address"]
  expected: true

# ---------------------------------------------------------------------------
# IPv6Network.__qualname__.__eq__('IPv6Network') — standalone invariant
#
# ipaddress_extra5 covers IPv6Network.__qualname__.__eq__ in a table.
# This standalone invariant anchors the same property from the extra16 namespace.
# ---------------------------------------------------------------------------

invariant ipaddress_extra16.IPv6Network.qualname_eq:
  description: "ipaddress.IPv6Network.__qualname__ == 'IPv6Network'"
  category: class_qualnames
  kind: python_call_eq
  function: IPv6Network.__qualname__.__eq__
  args: ["IPv6Network"]
  expected: true
