spec: theseus_xmlrpc_cr
version: ">=3.0"
backend: python_cleanroom(theseus_xmlrpc_cr)
blocks: xmlrpc

docs: https://docs.python.org/3/library/xmlrpc.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/xmlrpc.html"
  not_derived_from:
    - "CPython source: Lib/xmlrpc/__init__.py"
  notes:
    - "Clean-room xmlrpc namespace package. Do NOT import xmlrpc."

error_model: python_exceptions

invariant theseus_xmlrpc_cr.xmlrpc2_package:
  description: "xmlrpc package is importable as a namespace"
  category: behavior
  kind: python_call_eq
  function: xmlrpc2_package
  args: []
  expected: true

invariant theseus_xmlrpc_cr.xmlrpc2_name:
  description: "xmlrpc package has correct __name__"
  category: behavior
  kind: python_call_eq
  function: xmlrpc2_name
  args: []
  expected: true

invariant theseus_xmlrpc_cr.xmlrpc2_path:
  description: "xmlrpc package has __path__ (is a package)"
  category: behavior
  kind: python_call_eq
  function: xmlrpc2_path
  args: []
  expected: true
