spec: io_extra1831
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/io.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 569 (_extra1831): descriptor protocol (__get__/__set__/__delete__/__set_name__); __call__ callable protocol; io module attribute presence."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table io_extra1831.descriptor_protocol:
  description: "io types descriptor protocol dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1831

  columns: [id, function, args, expected]
  rows:
    - ["io1831001", "io.BytesIO.__dict__.__contains__", ["__get__"], false]
    - ["io1831002", "io.StringIO.__dict__.__contains__", ["__get__"], false]
    - ["io1831003", "io.FileIO.__dict__.__contains__", ["__get__"], false]
    - ["io1831004", "io.BufferedReader.__dict__.__contains__", ["__get__"], false]
    - ["io1831005", "io.TextIOWrapper.__dict__.__contains__", ["__get__"], false]
    - ["io1831006", "io.IOBase.__dict__.__contains__", ["__get__"], false]
    - ["io1831007", "io.RawIOBase.__dict__.__contains__", ["__get__"], false]
    - ["io1831008", "io.BufferedIOBase.__dict__.__contains__", ["__get__"], false]

table io_extra1831.callable_protocol:
  description: "io types __call__ and __init__ callable protocol dict-presence checks"
