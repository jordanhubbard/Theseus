    - ["io1831102", "io.StringIO.__dict__.__contains__", ["__call__"], false]
    - ["io1831103", "io.FileIO.__dict__.__contains__", ["__call__"], false]
    - ["io1831104", "io.IOBase.__dict__.__contains__", ["__call__"], false]
    - ["io1831105", "io.TextIOWrapper.__dict__.__contains__", ["__call__"], false]
    - ["io1831106", "io.BytesIO.__dict__.__contains__", ["__init__"], true]
    - ["io1831107", "io.StringIO.__dict__.__contains__", ["__init__"], true]
    - ["io1831108", "io.TextIOWrapper.__dict__.__contains__", ["__init__"], true]

table io_extra1831.io_module_attrs:
  description: "io module-level attribute dict-presence checks"
