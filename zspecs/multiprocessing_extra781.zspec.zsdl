spec: multiprocessing_extra781
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - multiprocessing standard library documentation
    - CPython source for multiprocessing.Process
  not_derived_from:
    - any third-party multiprocessing wrappers
    - pathos or billiard process pool implementations
  notes:
    - Covers property and method __qualname__ identity checks for Process class
    - Property qualnames follow the descriptor protocol naming convention
  created_at: "2026-04-12"

table multiprocessing_extra781.name:
  description: multiprocessing.Process property and method qualname identity checks
  kind: python_call_eq
  category: stdlib_identity
  id_prefix: mp781
  columns: [id, function, args, expected]
  rows:
    - [mp781xx001, multiprocessing.Process.name.__qualname__.__eq__, ["Process.name"], true]
    - [mp781xx002, multiprocessing.Process.daemon.__qualname__.__eq__, ["Process.daemon"], true]
    - [mp781xx003, multiprocessing.Process.pid.__qualname__.__eq__, ["Process.pid"], true]
    - [mp781xx004, multiprocessing.Process.exitcode.__qualname__.__eq__, ["Process.exitcode"], true]
    - [mp781xx005, multiprocessing.Process.authkey.__qualname__.__eq__, ["Process.authkey"], true]
    - [mp781xx006, multiprocessing.Process.sentinel.__qualname__.__eq__, ["Process.sentinel"], true]
    - [mp781xx007, multiprocessing.Process.__init__.__qualname__.__eq__, ["Process.__init__"], true]
    - [mp781xx008, multiprocessing.Process.__repr__.__qualname__.__eq__, ["Process.__repr__"], true]
    - [mp781xx009, multiprocessing.Process.start.__qualname__.__eq__, ["Process.start"], true]
    - [mp781xx010, multiprocessing.Process.run.__qualname__.__eq__, ["Process.run"], true]
    - [mp781xx011, multiprocessing.Process.join.__qualname__.__eq__, ["Process.join"], true]
    - [mp781xx012, multiprocessing.Process.terminate.__qualname__.__eq__, ["Process.terminate"], true]
