spec: gc_extra29
version: ">=3.9"
backend: python_module(gc)

docs: https://docs.python.org/3/library/gc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gc.html — Python gc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/gcmodule.c"
  notes:
    - "This spec extends gc_extra28.zspec.zsdl."
    - "Prior specs covered: gc.__name__/__package__, gc.collect/__name__/__module__, gc.disable/__name__, gc.enable/__name__, gc.isenabled/__name__, gc.get_count/__name__, gc.get_threshold/__name__, gc.set_threshold/__name__, gc.get_objects/__name__, gc.get_referrers/__name__, gc.get_referents/__name__, gc.is_tracked/__name__, gc.is_finalized/__name__, gc.freeze/__name__, gc.unfreeze/__name__, gc.get_freeze_count/__name__, gc.callbacks/__class__.__name__, gc.garbage/__class__.__name__, various __qualname__ and __module__ checks for collect/enable/disable/isenabled/get_count/get_threshold/set_threshold/get_objects in earlier namespaces."
    - "This spec covers: collect.__qualname__ (extra29 anchor), disable.__qualname__ (extra29 anchor), enable.__qualname__ (extra29 anchor), isenabled.__qualname__ (extra29 anchor), get_count.__qualname__ (extra29 anchor), get_threshold.__qualname__ (extra29 anchor), set_threshold.__qualname__ (extra29 anchor), get_objects.__qualname__ (extra29 anchor), collect.__module__ (extra29 anchor), disable.__module__ (extra29 anchor), enable.__module__ (extra29 anchor), isenabled.__module__ (extra29 anchor)."
    - "gc.collect.__qualname__ == 'collect' — C builtin; qualname equals simple name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.disable.__qualname__ == 'disable' — C builtin; qualname equals simple name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.enable.__qualname__ == 'enable' — C builtin; qualname equals simple name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.isenabled.__qualname__ == 'isenabled' — C builtin; qualname equals simple name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.get_count.__qualname__ == 'get_count' — C builtin; qualname equals simple name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.get_threshold.__qualname__ == 'get_threshold' — C builtin; qualname equals simple name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.set_threshold.__qualname__ == 'set_threshold' — C builtin; qualname equals simple name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.get_objects.__qualname__ == 'get_objects' — C builtin; qualname equals simple name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.collect.__module__ == 'gc' — C builtin defined in the gc module. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.disable.__module__ == 'gc' — C builtin defined in the gc module. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.enable.__module__ == 'gc' — C builtin defined in the gc module. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "gc.isenabled.__module__ == 'gc' — C builtin defined in the gc module. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# gc.collect.__qualname__ (extra29-namespace anchor)
#
# gc_extra24 records collect.__qualname__ == 'collect' in the extra24 namespace.
# This spec provides a fresh extra29-namespace standalone anchor.
# gc.collect is a C builtin; its __qualname__ equals its simple __name__.
# ---------------------------------------------------------------------------

invariant gc_extra29.collect.qualname:
  description: "gc.collect.__qualname__ == 'collect' — C builtin; qualname equals simple name"
  category: function_qualname
  kind: python_call_eq
  function: collect.__qualname__.__eq__
  args: ["collect"]
  expected: true

# ---------------------------------------------------------------------------
