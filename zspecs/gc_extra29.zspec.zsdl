# ---------------------------------------------------------------------------
# Consolidated table — all twelve invariants
#
# Covers __qualname__ anchors for collect/disable/enable/isenabled/
# get_count/get_threshold/set_threshold/get_objects (8) and __module__
# anchors for collect/disable/enable/isenabled (4).
# ---------------------------------------------------------------------------

table gc_extra29.qualnames_and_modules:
  description: "gc function __qualname__ anchors (8 functions) and __module__ anchors (4 functions) in extra29 namespace"
  kind: python_call_eq
  category: function_qualname

  columns: [id, function, args, expected]
  rows:
    - [collect_qualname,       collect.__qualname__.__eq__,       ["collect"],       true]
    - [disable_qualname,       disable.__qualname__.__eq__,       ["disable"],       true]
    - [enable_qualname,        enable.__qualname__.__eq__,        ["enable"],        true]
    - [isenabled_qualname,     isenabled.__qualname__.__eq__,     ["isenabled"],     true]
    - [get_count_qualname,     get_count.__qualname__.__eq__,     ["get_count"],     true]
    - [get_threshold_qualname, get_threshold.__qualname__.__eq__, ["get_threshold"], true]
    - [set_threshold_qualname, set_threshold.__qualname__.__eq__, ["set_threshold"], true]
    - [get_objects_qualname,   get_objects.__qualname__.__eq__,   ["get_objects"],   true]
    - [collect_module,         collect.__module__.__eq__,         ["gc"],            true]
    - [disable_module,         disable.__module__.__eq__,         ["gc"],            true]
    - [enable_module,          enable.__module__.__eq__,          ["gc"],            true]
    - [isenabled_module,       isenabled.__module__.__eq__,       ["gc"],            true]
