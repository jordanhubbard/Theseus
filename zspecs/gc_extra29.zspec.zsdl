# ---------------------------------------------------------------------------
# gc.collect.__module__ (extra29-namespace anchor)
#
# gc_extra10 and gc_extra20 record collect.__module__ == 'gc' in earlier
# namespaces. This spec provides a fresh extra29-namespace standalone anchor.
# gc is a C extension module; all its builtins report __module__ == 'gc'.
# ---------------------------------------------------------------------------

invariant gc_extra29.collect.module:
  description: "gc.collect.__module__ == 'gc' — C builtin defined in the gc module"
  category: function_module
  kind: python_call_eq
  function: collect.__module__.__eq__
  args: ["gc"]
  expected: true

