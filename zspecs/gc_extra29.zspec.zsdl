# ---------------------------------------------------------------------------

invariant gc_extra29.disable.qualname:
  description: "gc.disable.__qualname__ == 'disable' — C builtin; qualname equals simple name"
  category: function_qualname
  kind: python_call_eq
  function: disable.__qualname__.__eq__
  args: ["disable"]
  expected: true

