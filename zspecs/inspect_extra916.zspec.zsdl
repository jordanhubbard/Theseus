spec: inspect_extra916
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks inspect classes for __module__ and __qualname__ identity; FrameInfo is a NamedTuple"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra916.signature_boundargs_attrs:
  description: "inspect.Signature and inspect.BoundArguments __module__ and __qualname__ identity"
  kind: python_call_eq
  category: signature_boundargs_attrs
  id_prefix: ip916sb
  columns: [id, function, args, expected]
  rows:
    - [ip916sb001, inspect.Signature.__module__.__eq__,         ["inspect"], true]
    - [ip916sb002, inspect.Signature.__qualname__.__eq__,        ["Signature"], true]
    - [ip916sb003, inspect.Signature.__name__.__eq__,            ["Signature"], true]
    - [ip916sb004, inspect.BoundArguments.__module__.__eq__,     ["inspect"], true]
    - [ip916sb005, inspect.BoundArguments.__qualname__.__eq__,   ["BoundArguments"], true]
    - [ip916sb006, inspect.BoundArguments.__name__.__eq__,       ["BoundArguments"], true]

table inspect_extra916.fullargspec_frameinfo_attrs:
  description: "inspect.FullArgSpec and inspect.FrameInfo __module__ and __qualname__ identity"
  kind: python_call_eq
  category: fullargspec_frameinfo_attrs
  id_prefix: ip916ff
  columns: [id, function, args, expected]
  rows:
    - [ip916ff001, inspect.FullArgSpec.__module__.__eq__,        ["inspect"], true]
    - [ip916ff002, inspect.FullArgSpec.__qualname__.__eq__,       ["FullArgSpec"], true]
    - [ip916ff003, inspect.FullArgSpec.__name__.__eq__,           ["FullArgSpec"], true]
    - [ip916ff004, inspect.FrameInfo.__module__.__eq__,           ["inspect"], true]
    - [ip916ff005, inspect.FrameInfo.__qualname__.__eq__,         ["FrameInfo"], true]
    - [ip916ff006, inspect.FrameInfo.__name__.__eq__,             ["FrameInfo"], true]

table inspect_extra916.parameter_attrs:
  description: "inspect.Parameter __module__, __qualname__, and POSITIONAL_ONLY class name identity"
  kind: python_call_eq
  category: parameter_attrs
  id_prefix: ip916pa
  columns: [id, function, args, expected]
  rows:
    - [ip916pa001, inspect.Parameter.__module__.__eq__,                    ["inspect"],   true]
    - [ip916pa002, inspect.Parameter.__qualname__.__eq__,                   ["Parameter"], true]
    - [ip916pa003, inspect.Parameter.__name__.__eq__,                       ["Parameter"], true]
    - [ip916pa004, inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__, ["ParameterKind"], true]
    - [ip916pa005, inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__,   ["ParameterKind"], true]
    - [ip916pa006, inspect.Parameter.VAR_POSITIONAL.__class__.__name__.__eq__,  ["ParameterKind"], true]
    - [ip916pa007, inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__,     ["ParameterKind"], true]
