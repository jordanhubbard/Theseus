spec: struct_extra721
version: ">=3.9"
backend: python_module(struct)
docs: "Behavioral spec covering struct.Struct property qualnames and struct module function qualnames"
error_model: python_exceptions

provenance:
  derived_from: "struct stdlib documentation and CPython source"
  not_derived_from: "any third-party struct extension"
  notes: "struct module functions are implemented in _struct C extension; Struct class and error live in struct namespace"
  created_at: "2026-04-12"

table struct_extra721.struct_qualnames:
  description: "struct.Struct property qualnames and struct module function and exception qualnames"
  kind: python_call_eq
  category: qualname
  id_prefix: st721qn
  columns: [id, function, args, expected]
  rows:
    - [st721qn001, struct.Struct.size.__qualname__.__eq__, ["Struct.size"], true]
    - [st721qn002, struct.Struct.format.__qualname__.__eq__, ["Struct.format"], true]
    - [st721qn003, struct.Struct.__qualname__.__eq__, ["Struct"], true]
    - [st721qn004, struct.Struct.__module__.__eq__, ["struct"], true]
    - [st721qn005, struct.pack.__qualname__.__eq__, ["pack"], true]
    - [st721qn006, struct.unpack.__qualname__.__eq__, ["unpack"], true]
    - [st721qn007, struct.pack_into.__qualname__.__eq__, ["pack_into"], true]
    - [st721qn008, struct.unpack_from.__qualname__.__eq__, ["unpack_from"], true]
    - [st721qn009, struct.iter_unpack.__qualname__.__eq__, ["iter_unpack"], true]
    - [st721qn010, struct.calcsize.__qualname__.__eq__, ["calcsize"], true]
    - [st721qn011, struct.error.__qualname__.__eq__, ["error"], true]
    - [st721qn012, struct.error.__module__.__eq__, ["struct"], true]
