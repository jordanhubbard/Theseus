spec: concurrent_futures_extra213
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "concurrent.futures.FIRST_COMPLETED == 'FIRST_COMPLETED' (str, len=15)."
    - "concurrent.futures.FIRST_EXCEPTION == 'FIRST_EXCEPTION' (str, len=15)."
    - "concurrent.futures.ALL_COMPLETED == 'ALL_COMPLETED' (str, len=13)."
    - "All three wait constants are plain str, __class__.__name__ == 'str'."
    - "concurrent.futures.BrokenExecutor.__doc__ starts with newline then 'Raised when'."
    - "concurrent.futures.InvalidStateError.__doc__ == 'The operation is not allowed in this state.'."
    - "concurrent.futures.CancelledError.__doc__ == 'The Future was cancelled.'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures wait constants — extra213 namespace
#
# FIRST_COMPLETED, FIRST_EXCEPTION, and ALL_COMPLETED are plain str values
# used as the return_when parameter to concurrent.futures.wait().
# ---------------------------------------------------------------------------

table concurrent_futures_extra213.wait_constants_eq:
  description: "concurrent.futures wait-constant string equality checks in extra213 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cfe213waitconst

  columns: [id, function, args, expected, description]
  rows:
    - [first_completed_eq,  FIRST_COMPLETED.__eq__,  ["FIRST_COMPLETED"],  true,  "concurrent.futures.FIRST_COMPLETED == 'FIRST_COMPLETED'"]
    - [first_exception_eq,  FIRST_EXCEPTION.__eq__,  ["FIRST_EXCEPTION"],  true,  "concurrent.futures.FIRST_EXCEPTION == 'FIRST_EXCEPTION'"]
    - [all_completed_eq,    ALL_COMPLETED.__eq__,    ["ALL_COMPLETED"],    true,  "concurrent.futures.ALL_COMPLETED == 'ALL_COMPLETED'"]

# ---------------------------------------------------------------------------
# concurrent.futures wait-constant type — extra213 namespace
#
# All three constants are plain str; __class__.__name__ == 'str'.
# ---------------------------------------------------------------------------

table concurrent_futures_extra213.wait_constants_type:
  description: "concurrent.futures wait-constant __class__.__name__ checks in extra213 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cfe213waittype

  columns: [id, function, args, expected, description]
  rows:
    - [first_completed_type,  FIRST_COMPLETED.__class__.__name__.__eq__,  ["str"],  true,  "concurrent.futures.FIRST_COMPLETED is a plain str"]
    - [first_exception_type,  FIRST_EXCEPTION.__class__.__name__.__eq__,  ["str"],  true,  "concurrent.futures.FIRST_EXCEPTION is a plain str"]
    - [all_completed_type,    ALL_COMPLETED.__class__.__name__.__eq__,    ["str"],  true,  "concurrent.futures.ALL_COMPLETED is a plain str"]

# ---------------------------------------------------------------------------
# concurrent.futures wait-constant length — extra213 namespace
#
# FIRST_COMPLETED and FIRST_EXCEPTION each have 15 characters; ALL_COMPLETED
# has 13 characters.
# ---------------------------------------------------------------------------

table concurrent_futures_extra213.wait_constants_len:
  description: "concurrent.futures wait-constant len() checks in extra213 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cfe213waitlen

  columns: [id, function, args, expected, description]
  rows:
    - [first_completed_len,  FIRST_COMPLETED.__len__,  [],  15,  "len(concurrent.futures.FIRST_COMPLETED) == 15"]
    - [first_exception_len,  FIRST_EXCEPTION.__len__,  [],  15,  "len(concurrent.futures.FIRST_EXCEPTION) == 15"]
    - [all_completed_len,    ALL_COMPLETED.__len__,    [],  13,  "len(concurrent.futures.ALL_COMPLETED) == 13"]

# ---------------------------------------------------------------------------
# concurrent.futures exception __doc__ contains — extra213 namespace
#
# BrokenExecutor.__doc__ contains 'executor' and 'failure'.
# InvalidStateError.__doc__ contains 'state' and 'operation'.
# CancelledError.__doc__ contains 'cancelled' (case-insensitive 'Future').
# ---------------------------------------------------------------------------

table concurrent_futures_extra213.exception_doc_contains:
  description: "concurrent.futures exception __doc__ contains checks in extra213 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cfe213excdoc

  columns: [id, function, args, expected, description]
  rows:
    - [broken_executor_doc_executor,    BrokenExecutor.__doc__.__contains__,    ["executor"],  true,  "concurrent.futures.BrokenExecutor.__doc__ contains 'executor'"]
    - [broken_executor_doc_failure,     BrokenExecutor.__doc__.__contains__,    ["failure"],   true,  "concurrent.futures.BrokenExecutor.__doc__ contains 'failure'"]
    - [invalid_state_doc_state,         InvalidStateError.__doc__.__contains__,  ["state"],    true,  "concurrent.futures.InvalidStateError.__doc__ contains 'state'"]
    - [invalid_state_doc_operation,     InvalidStateError.__doc__.__contains__,  ["operation"], true, "concurrent.futures.InvalidStateError.__doc__ contains 'operation'"]
    - [cancelled_error_doc_future,      CancelledError.__doc__.__contains__,    ["Future"],    true,  "concurrent.futures.CancelledError.__doc__ contains 'Future'"]
    - [cancelled_error_doc_cancelled,   CancelledError.__doc__.__contains__,    ["cancelled"], true,  "concurrent.futures.CancelledError.__doc__ contains 'cancelled'"]

# ---------------------------------------------------------------------------
# concurrent.futures exception __doc__ exact equality — extra213 namespace
#
# InvalidStateError.__doc__ == 'The operation is not allowed in this state.'
# CancelledError.__doc__    == 'The Future was cancelled.'
# ---------------------------------------------------------------------------

table concurrent_futures_extra213.exception_doc_eq:
  description: "concurrent.futures exception __doc__ exact string equality in extra213 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cfe213excdoceq

  columns: [id, function, args, expected, description]
  rows:
    - [invalid_state_doc_eq,   InvalidStateError.__doc__.__eq__,  ["The operation is not allowed in this state."],  true,  "concurrent.futures.InvalidStateError.__doc__ exact value"]
    - [cancelled_error_doc_eq, CancelledError.__doc__.__eq__,    ["The Future was cancelled."],                    true,  "concurrent.futures.CancelledError.__doc__ exact value"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra213 namespace
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra213.FIRST_COMPLETED_eq:
  description: "concurrent.futures.FIRST_COMPLETED.__eq__('FIRST_COMPLETED') returns True"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.FIRST_COMPLETED.__eq__
  args: ["FIRST_COMPLETED"]
  expected: true

invariant concurrent_futures_extra213.ALL_COMPLETED_len:
  description: "concurrent.futures.ALL_COMPLETED.__len__() == 13 — 'ALL_COMPLETED' has 13 characters"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ALL_COMPLETED.__len__
  args: []
  expected: 13

invariant concurrent_futures_extra213.InvalidStateError_doc_contains_state:
  description: "concurrent.futures.InvalidStateError.__doc__.__contains__('state') returns True"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.InvalidStateError.__doc__.__contains__
  args: ["state"]
  expected: true

