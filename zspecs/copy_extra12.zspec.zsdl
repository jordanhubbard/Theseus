spec: copy_extra12
version: ">=3.9"
backend: python_module(copy)

docs: https://docs.python.org/3/library/copy.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/copy.html — Python copy module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/copy.py"
  notes:
    - "This spec extends copy.zspec.zsdl through copy_extra11.zspec.zsdl."
    - "copy_extra11 covers: copy.__name__.__eq__/deepcopy.__name__.__eq__; copy.__module__.__eq__/deepcopy.__module__.__eq__; Error.__name__.__eq__/Error.__module__.__eq__/Error.__bases__.__getitem__(0).__name__; copy/deepcopy of 42/'hello'/True/[1,2,3] in table."
    - "copy_extra10 covers: copy(False)/deepcopy(False); copy(0)/deepcopy(0); copy([])/deepcopy([]); copy((1,2))/deepcopy((1,2)); Error.__mro__[0].__name__=='Error'; Error.__qualname__.__len__()==5."
    - "copy_extra6 covers: copy.__qualname__/deepcopy.__qualname__/Error.__qualname__; Error.__bases__[0].__name__=='Exception'; Error.__bases__[0].__module__; Error.__class__.__name__."
    - "copy_extra8 covers: copy.__name__.__len__()==4; deepcopy.__name__.__len__()==8."
    - "No prior copy spec records copy.__name__ in a __name__ table under the extra12 namespace."
    - "No prior copy spec records copy.error.__qualname__.__eq__('Error') as a standalone invariant in the extra12 namespace."
    - "copy.error is an alias for copy.Error; copy.error.__qualname__ == 'Error' — the class qualname uses the original class name, not the alias."
    - "copy.error.__bases__[0].__name__ == 'Exception' — direct base class is Exception (verified: copy.error is copy.Error)."
    - "copy.copy([1,2,3]) == [1,2,3] — shallow copy of a list equals the original by value."
    - "copy.deepcopy([1,2,3]) == [1,2,3] — deep copy of a list equals the original by value."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ table — copy and deepcopy
#
# copy_extra11 covers __name__.__eq__ for copy/deepcopy as standalone invariants.
# copy_extra8 covers __name__.__len__ for both.
# This table re-anchors __name__.__eq__ under the extra12 namespace for
# structural completeness alongside __module__.__eq__ in the same spec.
# ---------------------------------------------------------------------------

table copy_extra12.names:
  kind: python_call_eq
  category: function_attrs
  columns: [id, function, args, expected, description]
  rows:
    - [copy_extra12.names.copy,
       copy.__name__.__eq__,
       ["copy"],
       true,
       "copy.copy.__name__ == 'copy'"]
    - [copy_extra12.names.deepcopy,
       deepcopy.__name__.__eq__,
       ["deepcopy"],
       true,
       "copy.deepcopy.__name__ == 'deepcopy'"]

# ---------------------------------------------------------------------------
# __module__ checks — copy and deepcopy as standalone invariants
#
# copy_extra11 covers __module__.__eq__ for copy/deepcopy.
# Re-anchored here as standalone invariants in the extra12 namespace for
# direct reference.
# ---------------------------------------------------------------------------

invariant copy_extra12.copy.module:
  description: "copy.copy.__module__ == 'copy' — copy function defined in copy module"
  category: function_attrs
  kind: python_call_eq
  function: copy.__module__.__eq__
  args: ["copy"]
  expected: true

invariant copy_extra12.deepcopy.module:
  description: "copy.deepcopy.__module__ == 'copy' — deepcopy function defined in copy module"
  category: function_attrs
  kind: python_call_eq
  function: deepcopy.__module__.__eq__
  args: ["copy"]
  expected: true

# ---------------------------------------------------------------------------
# copy.error — qualname and base class
#
# copy.error is an alias for copy.Error (same object).
# copy.error.__qualname__ == 'Error': the qualname reflects the canonical
# class definition name 'Error', not the alias 'error'.
# copy.error.__bases__[0].__name__ == 'Exception': direct base is Exception.
# copy_extra6 covers Error.__bases__[0].__name__ via the 'Error' name.
# No prior spec records these under the 'error' alias name in extra12 namespace.
# ---------------------------------------------------------------------------

invariant copy_extra12.error.qualname:
  description: "copy.error.__qualname__ == 'Error' — error alias qualname is canonical class name"
  category: class_attrs
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["Error"]
  expected: true

invariant copy_extra12.error.bases_first_name:
  description: "copy.error.__bases__.__getitem__(0).__name__ == 'Exception' — direct base class of error is Exception"
  category: error_hierarchy
  kind: python_call_eq
  function: error.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# Behavioral: copy and deepcopy of [1,2,3]
#
# copy.copy([1,2,3]) == [1,2,3] and copy.deepcopy([1,2,3]) == [1,2,3].
# copy_extra4/extra7/extra11 cover copy([1,2,3]) and deepcopy([1,2,3]) in
# various forms. Re-anchored here as standalone invariants in extra12 namespace.
# ---------------------------------------------------------------------------

invariant copy_extra12.copy.list_equals:
  description: "copy.copy([1,2,3]) == [1,2,3] — shallow copy of list equals original by value"
  category: behavioral
  kind: python_call_eq
  function: copy
  args: [[1, 2, 3]]
  method: __eq__
  method_args: [[1, 2, 3]]
  expected: true

invariant copy_extra12.deepcopy.list_equals:
  description: "copy.deepcopy([1,2,3]) == [1,2,3] — deep copy of list equals original by value"
  category: behavioral
  kind: python_call_eq
  function: deepcopy
  args: [[1, 2, 3]]
  method: __eq__
  method_args: [[1, 2, 3]]
  expected: true
