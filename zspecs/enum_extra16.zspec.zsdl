spec: enum_extra16
version: ">=3.9"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum.zspec.zsdl through enum_extra15.zspec.zsdl and enum_flags.zspec.zsdl."
    - "enum_extra15 covers: Enum/__module__/__qualname__/__name__.__len__; IntEnum/__module__/__qualname__; Flag/__module__/__qualname__; auto/__module__/__qualname__; EnumMeta/__qualname__; name_lengths table."
    - "enum_extra14 covers: standalone __name__.__eq__ invariants for IntFlag/IntEnum/Flag/EnumMeta/auto/unique; StrEnum/ReprEnum/EnumType __name__ (>=3.11); IntEnum/__bases__[0].__name__=='int'; IntFlag/__bases__[0].__name__=='int'; auto().__class__.__name__=='auto'."
    - "NOT yet covered: enum.Enum.__bases__.__len__() == 1 — Enum has one direct base (object)."
    - "NOT yet covered: enum.Enum.__bases__[0].__name__ == 'object'."
    - "NOT yet covered: enum.Flag.__bases__.__len__() — Flag has one direct base (Enum) in its __bases__ tuple."
    - "NOT yet covered: enum.Flag.__bases__[0].__name__ == 'Enum'."
    - "NOT yet covered: enum.EnumMeta.__bases__.__len__() == 1 — EnumMeta has one direct base (type)."
    - "NOT yet covered: enum.EnumMeta.__bases__[0].__name__ == 'type'."
    - "NOT yet covered: enum.auto.__bases__[0].__name__ — auto inherits from int (on CPython)."
    - "NOT yet covered: enum.Enum.__mro__[0].__name__ == 'Enum' — first MRO entry is the class itself."
    - "NOT yet covered: enum.EnumMeta.__mro__[0].__name__ == 'EnumMeta' — first MRO entry is itself."
    - "enum.Enum.__bases__.__len__() == 1 — Enum has exactly one direct base (object)."
    - "enum.Enum.__bases__[0].__name__ == 'object' — Enum's direct base is object."
    - "enum.Flag.__bases__.__len__() == 1 — Flag's direct base is Enum only in __bases__."
    - "enum.Flag.__bases__[0].__name__ == 'Enum' — first base of Flag is Enum."
    - "enum.EnumMeta.__bases__.__len__() == 1 — EnumMeta has one direct base (type)."
    - "enum.EnumMeta.__bases__[0].__name__ == 'type' — EnumMeta is a subclass of type."
    - "enum.auto.__bases__[0].__name__ == 'int' — auto inherits from int."
    - "enum.Enum.__mro__[0].__name__ == 'Enum' — Enum is first in its own MRO."
    - "enum.EnumMeta.__mro__[0].__name__ == 'EnumMeta' — EnumMeta is first in its own MRO."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Enum __bases__ — length and first entry
#
# Prior specs verify Enum.__mro__ entries and __qualname__/__module__.
# No prior spec checks Enum.__bases__.__len__() or __bases__[0].__name__.
# enum.Enum has a single direct base: object.
# ---------------------------------------------------------------------------

invariant enum_extra16.Enum.bases_len:
  description: "enum.Enum.__bases__.__len__() == 1 — Enum has exactly one direct base (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: Enum.__bases__.__len__
  args: []
  expected: 1

invariant enum_extra16.Enum.base0_is_object:
  description: "enum.Enum.__bases__[0].__name__ == 'object' — Enum's only direct base is object"
  category: class_hierarchy
  kind: python_call_eq
  function: Enum.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Flag __bases__ — length and first entry
#
# enum_extra11 verified IntEnum/__bases__.__len__() == 2 and
# enum_extra14 verified IntFlag/__bases__[0].__name__ == 'int'.
# No prior spec checks Flag.__bases__.__len__() or Flag.__bases__[0].__name__.
# Flag's __bases__ contains only Enum (one direct base).
# ---------------------------------------------------------------------------

invariant enum_extra16.Flag.bases_len:
  description: "enum.Flag.__bases__.__len__() == 1 — Flag has one direct base (Enum)"
  category: class_hierarchy
  kind: python_call_eq
  function: Flag.__bases__.__len__
  args: []
  expected: 1

invariant enum_extra16.Flag.base0_is_Enum:
  description: "enum.Flag.__bases__[0].__name__ == 'Enum' — Flag's only direct base is Enum"
  category: class_hierarchy
  kind: python_call_eq
  function: Flag.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Enum"

# ---------------------------------------------------------------------------
# EnumMeta __bases__ — length and first entry
#
# No prior spec checks EnumMeta.__bases__. EnumMeta is the metaclass for enum
# types; it inherits directly from type (one base).
# ---------------------------------------------------------------------------

invariant enum_extra16.EnumMeta.bases_len:
  description: "enum.EnumMeta.__bases__.__len__() == 1 — EnumMeta has one direct base (type)"
  category: class_hierarchy
  kind: python_call_eq
  function: EnumMeta.__bases__.__len__
  args: []
  expected: 1

invariant enum_extra16.EnumMeta.base0_is_type:
  description: "enum.EnumMeta.__bases__[0].__name__ == 'type' — EnumMeta is a subclass of type"
  category: class_hierarchy
  kind: python_call_eq
  function: EnumMeta.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "type"

# ---------------------------------------------------------------------------
# auto __bases__[0] — auto inherits from int
#
# enum_extra14 covers IntEnum/__bases__[0] and IntFlag/__bases__[0] == 'int'.
# enum_extra13 covers auto.__mro__[1].__name__ == 'object'.
# No prior spec checks auto.__bases__[0].__name__ as a standalone invariant.
# On CPython, enum.auto's direct base is int.
# ---------------------------------------------------------------------------

invariant enum_extra16.auto.base0_is_int:
  description: "enum.auto.__bases__[0].__name__ == 'int' — auto inherits from int"
  category: class_hierarchy
  kind: python_call_eq
  function: auto.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "int"

# ---------------------------------------------------------------------------
# MRO[0] self-identity — Enum and EnumMeta
#
# All enum MRO specs (extra6, extra12, extra13) check MRO entries at index >=1.
# No prior spec verifies MRO[0] (which must always be the class itself).
# These two invariants confirm the self-identity property.
# ---------------------------------------------------------------------------

invariant enum_extra16.Enum.mro_first_is_self:
  description: "enum.Enum.__mro__[0].__name__ == 'Enum' — first MRO entry is the class itself"
  category: class_hierarchy
  kind: python_call_eq
  function: Enum.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "Enum"

invariant enum_extra16.EnumMeta.mro_first_is_self:
  description: "enum.EnumMeta.__mro__[0].__name__ == 'EnumMeta' — first MRO entry is the class itself"
  category: class_hierarchy
  kind: python_call_eq
  function: EnumMeta.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "EnumMeta"
