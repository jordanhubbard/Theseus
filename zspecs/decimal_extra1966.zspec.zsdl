spec: decimal_extra1966
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/decimal.html"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "_decimal_extra.zspec.zsdl — covers _decimal C-module class metadata"
    - "any proprietary source"
  notes:
    - "Wave 578 (_extra1966): __enter__/__exit__, __aenter__/__aexit__, __del__ dict-presence checks."
    - "decimal.Context is NOT a context manager at the Python level — __enter__/__exit__ are absent."
    - "decimal.localcontext() returns a _ContextManager object that IS a CM, but decimal.Context itself is not."
    - "decimal.Decimal defines no context manager or finalizer protocol methods in its own __dict__."
    - "decimal.DecimalException and all its subclasses define no CM or finalizer protocol."
    - "None of the decimal types define __aenter__ or __aexit__ — decimal is sync-only."
    - "None of the decimal types define __del__ — no Python-level finalizer protocol."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __enter__ dict-presence — decimal core types
# decimal.Context does NOT define __enter__; the context manager for
# decimal.localcontext() is a separate _ContextManager wrapper object.
# ---------------------------------------------------------------------------

table decimal_extra1966.enter_protocol_core:
  description: "decimal core type __dict__.__contains__('__enter__') — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1966

  columns: [id, function, args, expected]
  rows:
    - ["dc1966001", "decimal.Decimal.__dict__.__contains__",          ["__enter__"], false]
    - ["dc1966002", "decimal.Context.__dict__.__contains__",          ["__enter__"], false]
    - ["dc1966003", "decimal.DecimalException.__dict__.__contains__", ["__enter__"], false]

# ---------------------------------------------------------------------------
# __enter__ dict-presence — decimal exception subclasses
# ---------------------------------------------------------------------------

table decimal_extra1966.enter_protocol_exceptions:
  description: "decimal exception subclass __dict__.__contains__('__enter__') — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1966

  columns: [id, function, args, expected]
  rows:
    - ["dc1966004", "decimal.InvalidOperation.__dict__.__contains__",  ["__enter__"], false]
    - ["dc1966005", "decimal.DivisionByZero.__dict__.__contains__",    ["__enter__"], false]
    - ["dc1966006", "decimal.Overflow.__dict__.__contains__",          ["__enter__"], false]
    - ["dc1966007", "decimal.Underflow.__dict__.__contains__",         ["__enter__"], false]
    - ["dc1966008", "decimal.Inexact.__dict__.__contains__",           ["__enter__"], false]
    - ["dc1966009", "decimal.Rounded.__dict__.__contains__",           ["__enter__"], false]
    - ["dc1966010", "decimal.Subnormal.__dict__.__contains__",         ["__enter__"], false]

