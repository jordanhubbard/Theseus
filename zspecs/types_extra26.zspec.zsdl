spec: types_extra26
version: ">=3.9"
backend: python_module(types)

docs: https://docs.python.org/3/library/types.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/types.html — Python types module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/types.py"
  notes:
    - "This spec extends types_extra25.zspec.zsdl."
    - "Prior specs covered: FunctionType/LambdaType/MethodType/GeneratorType/CodeType/ModuleType/__name__/__module__/__qualname__, SimpleNamespace/__name__/__module__/__qualname__, MappingProxyType/__name__, DynamicClassAttribute/__name__, GenericAlias/__name__, UnionType/__name__, various __bases__[0].__name__ checks, NoneType/EllipsisType/NotImplementedType, FunctionType/MethodType/GeneratorType/CodeType/ModuleType/SimpleNamespace __module__.__len__() and __name__.__len__()."
    - "This spec covers: __module__.__len__() for CoroutineType/AsyncGeneratorType/BuiltinFunctionType/TracebackType/FrameType/CellType/MappingProxyType; __name__.__len__() for CoroutineType/AsyncGeneratorType/BuiltinFunctionType/TracebackType/FrameType/CellType/MappingProxyType; __module__.__len__() and __name__.__len__() for resolve_bases/prepare_class/new_class."
    - "CoroutineType.__module__ == 'builtins' (8); AsyncGeneratorType.__module__ == 'builtins' (8)."
    - "BuiltinFunctionType.__name__ == 'builtin_function_or_method' (length 26) — longest __name__ among all types module objects measured."
    - "BuiltinMethodType.__name__ == 'builtin_function_or_method' (length 26) — same as BuiltinFunctionType; they are aliases for the same C type."
    - "resolve_bases/prepare_class/new_class have __module__ == 'types' (length 5); they are Python-level functions in Lib/types.py."
    - "resolve_bases.__name__ == 'resolve_bases' (13); prepare_class.__name__ == 'prepare_class' (13); new_class.__name__ == 'new_class' (9)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__len__() for CoroutineType/AsyncGeneratorType/BuiltinFunctionType/
# TracebackType/FrameType/CellType/MappingProxyType
#
# These are all C-level types; their __module__ is 'builtins' (length 8).
# extra25 recorded this for FunctionType/MethodType/GeneratorType/CodeType/
# ModuleType. This table extends coverage to seven additional C-level types.
# ---------------------------------------------------------------------------

table types_extra26.ctype_module_lens:
  description: "__module__.__len__() for additional C-level types in the types module — all 'builtins' (8)"
  kind: python_call_eq
  category: module_attr_lengths
  id_prefix: module_len

  columns: [id, function, args, expected]
  rows:
    - [CoroutineType,        CoroutineType.__module__.__len__,        [], 8]
    - [AsyncGeneratorType,   AsyncGeneratorType.__module__.__len__,   [], 8]
    - [BuiltinFunctionType,  BuiltinFunctionType.__module__.__len__,  [], 8]
    - [TracebackType,        TracebackType.__module__.__len__,        [], 8]
    - [FrameType,            FrameType.__module__.__len__,            [], 8]
    - [CellType,             CellType.__module__.__len__,             [], 8]
    - [MappingProxyType,     MappingProxyType.__module__.__len__,     [], 8]

# ---------------------------------------------------------------------------
# __name__.__len__() for CoroutineType/AsyncGeneratorType/BuiltinFunctionType/
# TracebackType/FrameType/CellType/MappingProxyType
#
# C-level type __name__ values use lowercase internal names distinct from the
# types module attribute names:
#   CoroutineType -> 'coroutine' (9), AsyncGeneratorType -> 'async_generator' (15),
#   BuiltinFunctionType -> 'builtin_function_or_method' (26),
#   TracebackType -> 'traceback' (9), FrameType -> 'frame' (5),
#   CellType -> 'cell' (4), MappingProxyType -> 'mappingproxy' (12).
# ---------------------------------------------------------------------------

table types_extra26.ctype_name_lens:
  description: "__name__.__len__() for additional C-level types — internal C names differ from Python attribute names"
  kind: python_call_eq
  category: name_attr_lengths
  id_prefix: name_len

  columns: [id, function, args, expected]
  rows:
    - [CoroutineType,       CoroutineType.__name__.__len__,       [], 9]
    - [AsyncGeneratorType,  AsyncGeneratorType.__name__.__len__,  [], 15]
    - [BuiltinFunctionType, BuiltinFunctionType.__name__.__len__, [], 26]
    - [TracebackType,       TracebackType.__name__.__len__,       [], 9]
    - [FrameType,           FrameType.__name__.__len__,           [], 5]
    - [CellType,            CellType.__name__.__len__,            [], 4]
    - [MappingProxyType,    MappingProxyType.__name__.__len__,    [], 12]

# ---------------------------------------------------------------------------
# __module__.__len__() and __name__.__len__() for resolve_bases/prepare_class/
# new_class — Python-level functions in Lib/types.py
#
# These three functions are defined in Lib/types.py and have __module__ == 'types'
# (length 5), like SimpleNamespace but unlike the C-level types (length 8).
# resolve_bases and prepare_class share __name__ length 13; new_class has 9.
# ---------------------------------------------------------------------------

table types_extra26.pyfunc_module_lens:
  description: "__module__.__len__() for Python-level types module functions — 'types' (5)"
  kind: python_call_eq
  category: module_attr_lengths
  id_prefix: module_len

  columns: [id, function, args, expected]
  rows:
    - [resolve_bases,  resolve_bases.__module__.__len__,  [], 5]
    - [prepare_class,  prepare_class.__module__.__len__,  [], 5]
    - [new_class,      new_class.__module__.__len__,      [], 5]

# ---------------------------------------------------------------------------
# types.BuiltinFunctionType.__name__.__len__() == 26 — standalone
#
# BuiltinFunctionType.__name__ is 'builtin_function_or_method', 26 characters —
# the longest __name__ of any type measured across all types extra specs.
# BuiltinMethodType is an alias for the same C type and has an identical __name__.
# ---------------------------------------------------------------------------

invariant types_extra26.BuiltinFunctionType.name_len:
  description: "types.BuiltinFunctionType.__name__.__len__() == 26 — 'builtin_function_or_method' is the longest __name__ among types module types"
  category: name_attr_lengths
  kind: python_call_eq
  function: BuiltinFunctionType.__name__.__len__
  args: []
  expected: 26

# ---------------------------------------------------------------------------
# types.BuiltinMethodType.__name__.__len__() == 26 — standalone
#
# BuiltinMethodType is an alias for BuiltinFunctionType in the types module;
# both point to the same C-level type builtin_function_or_method.
# Their __name__.__len__() values are therefore identical (26).
# ---------------------------------------------------------------------------

invariant types_extra26.BuiltinMethodType.name_len:
  description: "types.BuiltinMethodType.__name__.__len__() == 26 — alias for BuiltinFunctionType; same C type, same __name__ length"
  category: name_attr_lengths
  kind: python_call_eq
  function: BuiltinMethodType.__name__.__len__
  args: []
  expected: 26

# ---------------------------------------------------------------------------
# types.resolve_bases.__name__.__len__() == 13 — standalone
#
# resolve_bases and prepare_class both have __name__ length 13 — they are the
# longest __name__ values among the Python-level functions in types.py.
# Re-anchored as a standalone to highlight this symmetry.
# ---------------------------------------------------------------------------

invariant types_extra26.resolve_bases.name_len:
  description: "types.resolve_bases.__name__.__len__() == 13 — 'resolve_bases' has length 13; tied with prepare_class for longest __name__ among Python-level types functions"
  category: name_attr_lengths
  kind: python_call_eq
  function: resolve_bases.__name__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# types.CellType.__name__.__len__() == 4 — standalone
#
# CellType.__name__ is 'cell' (4), tied with CodeType.__name__ ('code', 4) as
# the shortest __name__ among all C-level types in the types module. Re-anchored
# to confirm the minimal-name pattern in both CellType and CodeType.
# ---------------------------------------------------------------------------

invariant types_extra26.CellType.name_len:
  description: "types.CellType.__name__.__len__() == 4 — 'cell' has length 4; tied with CodeType ('code') for shortest C-level type __name__"
  category: name_attr_lengths
  kind: python_call_eq
  function: CellType.__name__.__len__
  args: []
  expected: 4
