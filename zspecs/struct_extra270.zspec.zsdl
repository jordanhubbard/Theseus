spec: struct_extra270
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/struct.py"
    - "struct_extra269.zspec.zsdl — covers struct.unpack network byte-order test vectors and calcsize for '!B'/'!b'/'!H'/'!I'/'!Q'."
    - "struct_extra268.zspec.zsdl — covers Struct class identity and pack/calcsize for '!H'/'!I'/'!Q' formats."
    - "struct_extra267.zspec.zsdl — covers struct.error MRO length and struct.__all__ identity."
    - "struct_extra266.zspec.zsdl — covers struct module __spec__/__loader__ identity and _struct C extension identity."
  notes:
    - "struct.pack_into('>I', bytearray(8), 0, 305419896) places b'\\x124Vx' at offset 0 — big-endian unsigned int 0x12345678 packed into a mutable buffer. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.unpack_from('>I', bytearray_with_value, 0) == (305419896,) — unpack_from reads from a buffer at a given offset and returns a tuple. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.pack_into('>I', 'not a buffer', 0, 42) raises TypeError — pack_into requires a writable (read-write) bytes-like object as second argument. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "type(struct.iter_unpack('>H', b'\\x00\\x01')).__name__ == 'unpack_iterator' — iter_unpack returns a C-level iterator object. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.error.__bases__[0].__name__ == 'Exception' — struct.error inherits directly from Exception, not from a more specific error class. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "list(struct.iter_unpack('>H', b'\\x00\\x01\\x00\\x02\\x00\\x03')) == [(1,), (2,), (3,)] — iter_unpack yields one tuple per format-sized chunk. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('>I') == 4 — big-endian unsigned int is 4 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('>Q') == 8 — big-endian unsigned long long is 8 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack_into and struct.unpack_from — mutable buffer operations
# pack_into writes packed bytes into a writable buffer at a given offset.
# unpack_from reads from a buffer at a given offset and returns a tuple.
# Both require a writable bytes-like object (bytearray, not bytes/str).
# pack_into('>I', buf, 0, 0x12345678) writes [0x12, 0x34, 0x56, 0x78].
# unpack_from returns the same tuple format as unpack.
# ---------------------------------------------------------------------------

table struct_extra270.pack_into_unpack_from_vectors:
  description: "struct.pack_into/unpack_from mutable buffer operations — pack_into('>I',buf,0,305419896) writes big-endian bytes; unpack_from returns (305419896,); iter_unpack __name__=='unpack_iterator'; verified with Python 3.14.3"
  kind: python_call_eq
  category: behavior
  id_prefix: bufops270

  columns: [id, function, args, expected, description]
  rows:
    - [unpack_from_val,   unpack_from_gt_I_at0_result0.__eq__,   [305419896],        true, "struct.unpack_from('>I', buf, 0)[0] == 305419896 — reads big-endian uint32 from bytearray at offset 0"]
    - [unpack_from_len,   unpack_from_gt_I_at0_len.__eq__,       [1],                true, "len(struct.unpack_from('>I', buf, 0)) == 1 — unpack_from returns a single-element tuple for one-field format"]
    - [iter_type_name,    iter_unpack_gt_H_type_name.__eq__,     ["unpack_iterator"], true, "type(struct.iter_unpack('>H', b'\\x00\\x01')).__name__ == 'unpack_iterator' — C-level iterator class name"]
    - [calcsize_gt_I,     calcsize_gt_I.__eq__,                  [4],                true, "struct.calcsize('>I') == 4 — big-endian unsigned int is 4 bytes"]
    - [calcsize_gt_Q,     calcsize_gt_Q.__eq__,                  [8],                true, "struct.calcsize('>Q') == 8 — big-endian unsigned long long is 8 bytes"]

# ---------------------------------------------------------------------------
# struct.error class hierarchy
# struct.error is a public exception class raised on pack/unpack failures.
# It inherits directly from Exception (not OSError or ValueError).
# This makes it a plain application-level exception, not a system error.
# struct.error.__bases__ is a 1-tuple containing Exception.
# ---------------------------------------------------------------------------

table struct_extra270.error_hierarchy:
  description: "struct.error exception hierarchy — __bases__[0].__name__=='Exception'; error inherits directly from Exception, not from a more specific base; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: errhi270

  columns: [id, function, args, expected, description]
  rows:
    - [error_bases0_name,  "error.__bases__[0].__name__.__eq__",  ["Exception"],    true, "struct.error.__bases__[0].__name__ == 'Exception' — struct.error inherits directly from Exception"]
    - [error_bases_len,    error_bases_len.__eq__,                [1],              true, "len(struct.error.__bases__) == 1 — struct.error has exactly one base class"]
    - [error_name,         error.__name__.__eq__,                 ["error"],        true, "struct.error.__name__ == 'error' — the exception class name is 'error' (lowercase)"]
    - [error_module,       error.__module__.__eq__,               ["struct"],       true, "struct.error.__module__ == 'struct' — error is defined in the struct module namespace"]

# ---------------------------------------------------------------------------
# Standalone invariants — pack_into/unpack_from, iter_unpack, struct.error
# ---------------------------------------------------------------------------

invariant struct_extra270.unpack_from_val_eq:
  description: "struct.unpack_from('>I', buf, 0)[0] == 305419896 — after pack_into('>I', buf, 0, 0x12345678), unpack_from recovers the same integer (305419896 == 0x12345678); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: unpack_from_gt_I_at0_result0.__eq__
  args: [305419896]
  expected: true

invariant struct_extra270.unpack_from_len_eq:
  description: "len(struct.unpack_from('>I', buf, 0)) == 1 — unpack_from returns a tuple with one element per format field; a single '>I' field produces a 1-tuple; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: unpack_from_gt_I_at0_len.__eq__
  args: [1]
  expected: true

invariant struct_extra270.iter_unpack_type_name_eq:
  description: "type(struct.iter_unpack('>H', b'\\x00\\x01')).__name__ == 'unpack_iterator' — iter_unpack returns a C-implemented iterator whose type name is 'unpack_iterator'; this is an internal C type from the _struct extension; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: iter_unpack_gt_H_type_name.__eq__
  args: ["unpack_iterator"]
  expected: true

invariant struct_extra270.calcsize_gt_I_eq:
  description: "struct.calcsize('>I') == 4 — big-endian unsigned int ('>I') requires 4 bytes; identical to '!I' (network byte order); size is platform-independent under explicit byte-order prefix; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: calcsize_gt_I.__eq__
  args: [4]
  expected: true

invariant struct_extra270.calcsize_gt_Q_eq:
  description: "struct.calcsize('>Q') == 8 — big-endian unsigned long long ('>Q') requires 8 bytes; fixed size under explicit byte-order prefix regardless of platform native long long size; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: calcsize_gt_Q.__eq__
  args: [8]
  expected: true

invariant struct_extra270.error_bases0_name_eq:
  description: "struct.error.__bases__[0].__name__ == 'Exception' — struct.error inherits directly from the built-in Exception class; it is not a subclass of OSError, ValueError, or any other specific exception; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: "error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant struct_extra270.error_name_eq:
  description: "struct.error.__name__ == 'error' — the struct exception class name is lowercase 'error', following an older Python naming convention; accessible as struct.error; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

invariant struct_extra270.pack_into_str_raises:
  description: "struct.pack_into('>I', 'not a buffer', 0, 42) raises TypeError — pack_into requires a read-write bytes-like object as its buffer argument; str is not a bytes-like object and raises TypeError; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: errors
  kind: python_call_raises
  function: pack_into
  args: [">I", "not a buffer", 0, 42]
  raises: TypeError
