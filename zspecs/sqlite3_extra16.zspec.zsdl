spec: sqlite3_extra16
version: ">=3.9"
backend: python_module(sqlite3)

docs: https://docs.python.org/3/library/sqlite3.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sqlite3.html — Python sqlite3 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sqlite3/__init__.py"
    - "CPython source: Modules/_sqlite/module.c"
    - "CPython source: Modules/_sqlite/connection.c"
    - "CPython source: Modules/_sqlite/cursor.c"
  notes:
    - "This spec extends sqlite3.zspec.zsdl and prior extras through sqlite3_extra15.zspec.zsdl."
    - "sqlite3_extra15 covers: sqlite_version __class__.__name__; Error/__name__; DatabaseError/__name__; OperationalError/__name__; DatabaseError/__bases__[0].__name__; OperationalError/__bases__[0].__name__; PARSE_DECLTYPES == 1."
    - "sqlite3_extra14 covers: Cursor/Connection/Row __name__/__module__/__qualname__ table; connect/__qualname__; complete_statement boolean results."
    - "sqlite3_extra12 covers: Warning/InterfaceError/ProgrammingError __name__; Error/DatabaseError __module__."
    - "sqlite3_extra11 covers: exception __name__ table for several exceptions."
    - "sqlite3_extra9 covers: DatabaseError/Error MRO[1]; PARSE_DECLTYPES/PARSE_COLNAMES type."
    - "Focus: new axes — exception class __bases__[0].__name__ for the full hierarchy; Warning.__name__ standalone; InterfaceError/__bases__[0].__name__; InternalError/__bases__[0].__name__; DataError/__bases__[0].__name__; ProgrammingError/__bases__[0].__name__; IntegrityError/__bases__[0].__name__; NotSupportedError/__bases__[0].__name__."
    - "sqlite3.Warning.__bases__[0].__name__ == 'Exception' — Warning is a direct Exception subclass; no prior spec checks Warning.__bases__[0].__name__."
    - "sqlite3.InterfaceError.__bases__[0].__name__ == 'Error' — no prior spec checks InterfaceError.__bases__[0].__name__."
    - "sqlite3.InternalError.__bases__[0].__name__ == 'DatabaseError' — no prior spec checks InternalError.__bases__[0].__name__."
    - "sqlite3.DataError.__bases__[0].__name__ == 'DatabaseError' — no prior spec checks DataError.__bases__[0].__name__."
    - "sqlite3.ProgrammingError.__bases__[0].__name__ == 'DatabaseError' — no prior spec checks ProgrammingError.__bases__[0].__name__."
    - "sqlite3.IntegrityError.__bases__[0].__name__ == 'DatabaseError' — no prior spec checks IntegrityError.__bases__[0].__name__."
    - "sqlite3.NotSupportedError.__bases__[0].__name__ == 'DatabaseError' — no prior spec checks NotSupportedError.__bases__[0].__name__."
    - "sqlite3.Warning.__name__ == 'Warning' — sqlite3_extra12 checks Warning.__name__ in a table; standalone invariant in sqlite3_extra16 is new."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sqlite3.Warning — __name__ standalone invariant
#
# sqlite3_extra12 checks Warning.__name__ in a table. This standalone invariant
# provides independent coverage under the sqlite3_extra16 namespace.
# ---------------------------------------------------------------------------

invariant sqlite3_extra16.Warning.name:
  description: "sqlite3.Warning.__name__ == 'Warning'"
  category: class_attrs
  kind: python_call_eq
  function: Warning.__name__.__eq__
  args: ["Warning"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.Warning.__bases__[0].__name__
#
# Warning is a direct subclass of Exception (the top-level exception type
# for sqlite3 warnings). No prior spec checks Warning.__bases__[0].__name__.
# ---------------------------------------------------------------------------

invariant sqlite3_extra16.Warning.bases_0_name:
  description: "sqlite3.Warning.__bases__[0].__name__ == 'Exception' — Warning is a direct Exception subclass"
  category: class_attrs
  kind: python_call_eq
  function: "Warning.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.InterfaceError.__bases__[0].__name__
#
# InterfaceError inherits directly from sqlite3.Error (not DatabaseError).
# sqlite3_extra9 checks InterfaceError via MRO only; no prior spec checks
# InterfaceError.__bases__[0].__name__.
# ---------------------------------------------------------------------------

invariant sqlite3_extra16.InterfaceError.bases_0_name:
  description: "sqlite3.InterfaceError.__bases__[0].__name__ == 'Error' — InterfaceError inherits directly from sqlite3.Error"
  category: class_attrs
  kind: python_call_eq
  function: "InterfaceError.__bases__[0].__name__.__eq__"
  args: ["Error"]
  expected: true

# ---------------------------------------------------------------------------
# DatabaseError subclass hierarchy — __bases__[0].__name__ table
#
# sqlite3 has five exception classes that all inherit directly from
# DatabaseError: InternalError, DataError, ProgrammingError, IntegrityError,
# NotSupportedError. No prior spec checks these via __bases__[0].__name__.
# ---------------------------------------------------------------------------

table sqlite3_extra16.databaseerror_subclass_bases:
  description: "sqlite3 DatabaseError subclasses — __bases__[0].__name__ == 'DatabaseError'"
  kind: python_call_eq
  category: class_attrs
  id_prefix: dbe16

  columns: [id, function, args, expected]
  rows:
    - [InternalError_bases,     "InternalError.__bases__[0].__name__.__eq__",     ["DatabaseError"], true]
    - [DataError_bases,         "DataError.__bases__[0].__name__.__eq__",         ["DatabaseError"], true]
    - [ProgrammingError_bases,  "ProgrammingError.__bases__[0].__name__.__eq__",  ["DatabaseError"], true]
    - [IntegrityError_bases,    "IntegrityError.__bases__[0].__name__.__eq__",    ["DatabaseError"], true]
    - [NotSupportedError_bases, "NotSupportedError.__bases__[0].__name__.__eq__", ["DatabaseError"], true]
