spec: hashlib_extra2251
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_blake2/blake2module.c"
    - "hashlib_extra.zspec.zsdl"
    - "_hashlib.zspec.zsdl"
  notes:
    - "Wave 597 (_extra2251): callable protocol and function-attribute dict-presence checks for hashlib types."
    - "hashlib.blake2b and hashlib.blake2s are C extension types implemented in Modules/_blake2/."
    - "__call__ is absent from both blake2b and blake2s __dict__ — they are types/classes, not callable-with-__call__-in-dict objects; their metaclass (type) provides __call__ for construction."
    - "__init__ is absent from blake2b and blake2s __dict__; they use __new__ for construction."
    - "Function-object attributes (__code__, __globals__, __defaults__, __kwdefaults__, __annotations__, __builtins__) are absent from C extension type dicts."
    - "Positive anchors: update, digest, hexdigest, copy, __new__, __doc__, __module__, block_size, digest_size, name, MAX_DIGEST_SIZE, MAX_KEY_SIZE, PERSON_SIZE, SALT_SIZE are present."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table hashlib_extra2251.blake2b_call_protocol:
  description: "hashlib.blake2b callable protocol and function-attribute dict-presence (all false)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2251
  columns: [id, function, args, expected]
  rows:
    - ["hl2251001", "hashlib.blake2b.__dict__.__contains__", ["__call__"],       false]
    - ["hl2251002", "hashlib.blake2b.__dict__.__contains__", ["__init__"],       false]
    - ["hl2251003", "hashlib.blake2b.__dict__.__contains__", ["__code__"],       false]
    - ["hl2251004", "hashlib.blake2b.__dict__.__contains__", ["__globals__"],    false]
    - ["hl2251005", "hashlib.blake2b.__dict__.__contains__", ["__defaults__"],   false]
    - ["hl2251006", "hashlib.blake2b.__dict__.__contains__", ["__kwdefaults__"], false]
    - ["hl2251007", "hashlib.blake2b.__dict__.__contains__", ["__annotations__"],false]
    - ["hl2251008", "hashlib.blake2b.__dict__.__contains__", ["__builtins__"],   false]

table hashlib_extra2251.blake2s_call_protocol:
  description: "hashlib.blake2s callable protocol and function-attribute dict-presence (all false)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2251
  columns: [id, function, args, expected]
  rows:
    - ["hl2251009", "hashlib.blake2s.__dict__.__contains__", ["__call__"],       false]
    - ["hl2251010", "hashlib.blake2s.__dict__.__contains__", ["__init__"],       false]
    - ["hl2251011", "hashlib.blake2s.__dict__.__contains__", ["__code__"],       false]
    - ["hl2251012", "hashlib.blake2s.__dict__.__contains__", ["__globals__"],    false]
    - ["hl2251013", "hashlib.blake2s.__dict__.__contains__", ["__defaults__"],   false]
    - ["hl2251014", "hashlib.blake2s.__dict__.__contains__", ["__kwdefaults__"], false]
    - ["hl2251015", "hashlib.blake2s.__dict__.__contains__", ["__annotations__"],false]
    - ["hl2251016", "hashlib.blake2s.__dict__.__contains__", ["__builtins__"],   false]

table hashlib_extra2251.blake2b_positive_anchors:
