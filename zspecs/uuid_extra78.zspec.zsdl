spec: uuid_extra78
version: ">=3.9"
extends: uuid_extra77
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra77.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __qualname__/__eq__ / uuid1/uuid3/uuid4/uuid5 __name__/__eq__ / UUID.__init__/__str__/__eq__/__hash__ __qualname__.__len__() / UUID.__repr__/__setattr__ __qualname__.__len__() (table + invariants)."
    - "uuid_extra76.zspec.zsdl — covers UUID/__init__/__str__/__repr__/__eq__/__hash__/__lt__/__setattr__/__class__/__name__=='function' / UUID.int/__class__.__name__=='member_descriptor' / UUID.hex/__class__.__name__=='property' / UUID/__init__/__str__/__eq__/__hash__/__qualname__/__eq__ (table + invariants)."
    - "uuid_extra73.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 qualname lengths / UUID.__dict__ special method membership / UUID.__dict__ property membership (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra77; it does NOT duplicate invariants present in those files."
    - "Wave 252 theme: uuid.UUID.__dict__ membership — checking that key attributes, methods, and properties are present in the class dict."
    - "uuid.UUID.__dict__.__contains__('__init__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__str__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__repr__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__eq__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__hash__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('int') == True — stored as member_descriptor named 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('hex') == True — stored as property. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('bytes') == True — stored as property. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('variant') == True — stored as property. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('version') == True — stored as property. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__class__.__name__ == 'mappingproxy'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__bases__[0].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__mro__.__len__() == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('__init__') / UUID.__dict__.__contains__('__str__')
# uuid.UUID.__dict__.__contains__('__repr__') / UUID.__dict__.__contains__('__eq__')
#
# Wave 252 theme: uuid.UUID.__dict__ membership for dunder methods (group 1).
#
# uuid_extra73 checks membership using a different mechanism (table-row function call);
# this spec uses __dict__.__contains__ as the function being called.
# __init__, __str__, __repr__, __eq__ are all defined in uuid.py.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra78.uuid_dict_dunder_group1:
  description: "uuid.UUID/__dict__/__contains__('__init__')==True / UUID/__dict__/__contains__('__str__')==True / UUID/__dict__/__contains__('__repr__')==True / UUID/__dict__/__contains__('__eq__')==True — __init__/__str__/__repr__/__eq__ are all defined in uuid.py and present in UUID.__dict__; uuid_extra73 anchors __dict__ membership via a different approach; this table anchors the __dict__.__contains__ call form for dunder methods; first __dict__.__contains__ call anchor for uuid.UUID.__init__/__str__/__repr__/__eq__"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuiddictmem78

  columns: [id, function, args, expected]
  rows:
    - [uuid_dict_has_init,   "UUID.__dict__.__contains__", ["__init__"], true]
    - [uuid_dict_has_str,    "UUID.__dict__.__contains__", ["__str__"],  true]
    - [uuid_dict_has_repr,   "UUID.__dict__.__contains__", ["__repr__"], true]
    - [uuid_dict_has_eq,     "UUID.__dict__.__contains__", ["__eq__"],   true]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('__hash__') / UUID.__dict__.__contains__('int')
# uuid.UUID.__dict__.__contains__('hex') / UUID.__dict__.__contains__('bytes')
#
# Wave 252 theme: uuid.UUID.__dict__ membership for __hash__ and properties (group 2).
#
# __hash__ is defined in uuid.py. 'int' is a member_descriptor (slot), 'hex'
# and 'bytes' are property objects, all present in UUID.__dict__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra78.uuid_dict_hash_and_properties:
  description: "uuid.UUID/__dict__/__contains__('__hash__')==True / UUID/__dict__/__contains__('int')==True / UUID/__dict__/__contains__('hex')==True / UUID/__dict__/__contains__('bytes')==True — __hash__ is defined in uuid.py; 'int' is a member_descriptor slot; 'hex' and 'bytes' are property descriptors; all appear in UUID.__dict__; first __dict__.__contains__ anchor for uuid.UUID.__hash__/int/hex/bytes"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuiddictmem78

  columns: [id, function, args, expected]
  rows:
    - [uuid_dict_has_hash,   "UUID.__dict__.__contains__", ["__hash__"], true]
    - [uuid_dict_has_int,    "UUID.__dict__.__contains__", ["int"],      true]
    - [uuid_dict_has_hex,    "UUID.__dict__.__contains__", ["hex"],      true]
    - [uuid_dict_has_bytes,  "UUID.__dict__.__contains__", ["bytes"],    true]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('variant') / UUID.__dict__.__contains__('version')
# uuid.UUID.__dict__.__class__.__name__.__eq__('mappingproxy')
# uuid.UUID.__bases__[0].__name__.__eq__('object')
#
# Wave 252 theme: uuid.UUID dict membership for variant/version and class identity.
#
# 'variant' and 'version' are property descriptors in UUID.__dict__.
# __dict__.__class__.__name__ is 'mappingproxy'.
# __bases__[0].__name__ is 'object' (UUID inherits only from object).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra78.uuid_dict_properties_and_class_identity:
  description: "uuid.UUID/__dict__/__contains__('variant')==True / UUID/__dict__/__contains__('version')==True / UUID/__dict__/__class__/__name__.__eq__('mappingproxy')==True / UUID/__bases__[0]/__name__.__eq__('object')==True — variant and version are property descriptors in UUID.__dict__; the __dict__ is a mappingproxy (standard CPython class dict type); UUID directly inherits from object with no other bases; first __dict__.__contains__ anchor for uuid.UUID.variant/version and first __dict__.__class__.__name__ anchor for uuid.UUID"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuiddictmem78

  columns: [id, function, args, expected]
  rows:
    - [uuid_dict_has_variant,       "UUID.__dict__.__contains__",          ["variant"],      true]
    - [uuid_dict_has_version,       "UUID.__dict__.__contains__",          ["version"],      true]
    - [uuid_dict_class_proxy,       UUID.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [uuid_bases_object,           "UUID.__bases__[0].__name__.__eq__",   ["object"],       true]

# ---------------------------------------------------------------------------
# uuid.UUID.__mro__.__len__() == 2 / uuid.UUID.__dict__.__contains__('__init__')
# uuid.UUID.__dict__.__contains__('hex') / uuid.UUID.__dict__.__contains__('variant')
#
# Wave 252 theme: uuid.UUID MRO length and __dict__ cross-checks.
#
# UUID.__mro__.__len__() == 2 (UUID, object only).
# Cross-check dict membership for __init__, hex, variant.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra78.uuid_mro_len_and_dict_cross:
  description: "uuid.UUID/__mro__/__len__()==2 / UUID/__dict__/__contains__('__init__')==True / UUID/__dict__/__contains__('hex')==True / UUID/__dict__/__contains__('variant')==True — UUID inherits only from object so MRO has exactly 2 entries; cross-checks confirm dict membership for key attributes; first __mro__.__len__ anchor for uuid.UUID; first standalone cross-check group for uuid.UUID MRO and __dict__ identity"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuiddictmem78

  columns: [id, function, args, expected]
  rows:
    - [uuid_mro_len_2,          UUID.__mro__.__len__,                [], 2]
    - [uuid_dict_has_init2,     "UUID.__dict__.__contains__",        ["__init__"], true]
    - [uuid_dict_has_hex2,      "UUID.__dict__.__contains__",        ["hex"],      true]
    - [uuid_dict_has_variant2,  "UUID.__dict__.__contains__",        ["variant"],  true]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('__init__') == True — standalone
#
# UUID.__dict__.__contains__('__init__') is True. No prior uuid spec checks
# UUID.__dict__.__contains__ using the __contains__ call form.
# First __dict__.__contains__ standalone for uuid.UUID.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra78.uuid_dict_has_init:
  description: "uuid.UUID.__dict__.__contains__('__init__') == True — UUID.__init__ is defined in uuid.py to initialize a UUID from various forms; this is the first __dict__.__contains__ standalone using the __contains__ call form for uuid.UUID; no prior uuid spec checks __dict__.__contains__('__init__') as a call"
  category: class_attrs
  kind: python_call_eq
  function: "UUID.__dict__.__contains__"
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('hex') == True — standalone
#
# UUID.__dict__.__contains__('hex') is True. 'hex' is a property descriptor
# in UUID that returns the UUID as a 32-character hex string.
# First __dict__.__contains__('hex') standalone for uuid.UUID.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra78.uuid_dict_has_hex:
  description: "uuid.UUID.__dict__.__contains__('hex') == True — UUID.hex is a property returning the UUID as a 32-character hex string without hyphens; it lives in UUID.__dict__ as a property descriptor; first __dict__.__contains__('hex') standalone for uuid.UUID"
  category: class_attrs
  kind: python_call_eq
  function: "UUID.__dict__.__contains__"
  args: ["hex"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__class__.__name__.__eq__('mappingproxy') — standalone
#
# UUID.__dict__.__class__.__name__ is 'mappingproxy'. No prior uuid spec checks
# UUID.__dict__.__class__.__name__. First dict-type standalone for uuid.UUID.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra78.uuid_dict_class_mappingproxy:
  description: "uuid.UUID.__dict__.__class__.__name__.__eq__('mappingproxy') == True — UUID.__dict__ is a mappingproxy (the standard CPython type for class dicts); no prior uuid spec checks UUID.__dict__.__class__.__name__; first __dict__.__class__.__name__ standalone for uuid.UUID"
  category: class_attrs
  kind: python_call_eq
  function: UUID.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__mro__.__len__() == 2 — standalone
#
# UUID.__mro__.__len__() is 2 (UUID, object). No prior uuid spec checks
# UUID.__mro__.__len__(). First __mro__.__len__ standalone for uuid.UUID.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra78.uuid_mro_len_2:
  description: "uuid.UUID.__mro__.__len__() == 2 — UUID inherits only from object, giving a two-entry MRO of [UUID, object]; no prior uuid spec checks UUID.__mro__.__len__(); first __mro__.__len__ standalone for uuid.UUID"
  category: class_attrs
  kind: python_call_eq
  function: UUID.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('variant') == True — standalone
#
# UUID.__dict__.__contains__('variant') is True. 'variant' is a property
# describing the UUID variant (RFC 4122, etc.).
# First __dict__.__contains__('variant') standalone for uuid.UUID.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra78.uuid_dict_has_variant:
  description: "uuid.UUID.__dict__.__contains__('variant') == True — UUID.variant is a property that returns the variant of the UUID (e.g., RFC_4122); it lives in UUID.__dict__ as a property descriptor; first __dict__.__contains__('variant') standalone for uuid.UUID"
  category: class_attrs
  kind: python_call_eq
  function: "UUID.__dict__.__contains__"
  args: ["variant"]
  expected: true
