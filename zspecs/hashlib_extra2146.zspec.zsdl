spec: hashlib_extra2146
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_blake2/blake2module.c"
    - "hashlib.zspec.zsdl — covers sha256/sha1/md5/sha512/sha3 vectors, algorithms_guaranteed"
    - "hashlib_extra.zspec.zsdl — covers blake2b/blake2s attrs, algorithms_available, pbkdf2_hmac"
    - "hashlib_extra2131.zspec.zsdl — covers exception protocol dict-presence wave"
  notes:
    - "Wave (_extra2146): numeric conversion protocol dict-presence — checking __trunc__, __floor__, __ceil__, __index__, __complex__, __bool__, __int__ in class __dict__."
    - "hashlib.blake2b and hashlib.blake2s are non-numeric C extension types; none of the numeric conversion protocol attributes appear in their __dict__."
    - "blake2b.__dict__ contains: copy, digest, hexdigest, update, name, block_size, digest_size, SALT_SIZE, PERSON_SIZE, MAX_KEY_SIZE, MAX_DIGEST_SIZE — all hash-specific, none numeric."
    - "blake2s.__dict__ contains the same set of keys as blake2b; confirmed non-numeric."
    - "All expected values (false) verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table hashlib_extra2146.blake2b_trunc_floor_ceil:
  description: "hashlib.blake2b __dict__ numeric conversion dict-presence — __trunc__, __floor__, __ceil__ absent"
  kind: python_call_eq
  category: dict_contains

  columns: [id, function, args, expected]
  rows:
    - ["hl2146001", "hashlib.blake2b.__dict__.__contains__", ["__trunc__"], false]
    - ["hl2146002", "hashlib.blake2b.__dict__.__contains__", ["__floor__"], false]
    - ["hl2146003", "hashlib.blake2b.__dict__.__contains__", ["__ceil__"], false]

