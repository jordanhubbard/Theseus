table hashlib_extra2146.blake2b_real_attrs:
  description: "hashlib.blake2b __dict__ positive presence — known real attributes are present; confirms __dict__.__contains__ works for this type"
  kind: python_call_eq
  category: dict_contains

  columns: [id, function, args, expected]
  rows:
    - ["hl2146015", "hashlib.blake2b.__dict__.__contains__", ["copy"],          true]
    - ["hl2146016", "hashlib.blake2b.__dict__.__contains__", ["digest"],        true]
    - ["hl2146017", "hashlib.blake2b.__dict__.__contains__", ["hexdigest"],     true]
    - ["hl2146018", "hashlib.blake2b.__dict__.__contains__", ["update"],        true]
    - ["hl2146019", "hashlib.blake2b.__dict__.__contains__", ["SALT_SIZE"],     true]
