spec: itertools_extra56
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra55.zspec.zsdl."
    - "No prior itertools spec records __repr__.__class__.__name__ or __hash__.__class__.__name__ for any itertools type."
    - "No prior itertools spec records __spec__.name.__eq__('itertools') or __spec__.name.__len__()==9."
    - "This spec covers: itertools.groupby/__repr__.__class__.__name__.__eq__('wrapper_descriptor')==true; itertools.chain/__repr__.__class__.__name__.__eq__('wrapper_descriptor')==true; itertools.count/__repr__.__class__.__name__.__eq__('wrapper_descriptor')==true; itertools.product/__repr__.__class__.__name__.__eq__('wrapper_descriptor')==true; itertools.accumulate/__repr__.__class__.__name__.__eq__('wrapper_descriptor')==true; itertools.groupby/__hash__.__class__.__name__.__eq__('wrapper_descriptor')==true; itertools.chain/__hash__.__class__.__name__.__eq__('wrapper_descriptor')==true; itertools.count/__hash__.__class__.__name__.__eq__('wrapper_descriptor')==true; itertools.__spec__.name.__eq__('itertools')==true; itertools.__spec__.name.__len__()==9."
    - "Key findings: All itertools types (groupby, chain, count, product, accumulate) are C-extension types defined in Modules/itertoolsmodule.c. Their class-level __repr__ and __hash__ are C-slot method descriptors exposed as 'wrapper_descriptor' objects — the same pattern as other C-extension types. itertools.__spec__ is a ModuleSpec object; its .name attribute (not .__name__, which does not exist on ModuleSpec) is the string 'itertools' (9 characters). The ModuleSpec.name attribute holds the fully-qualified module name used by the import system. All ten invariants are new to extra56."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools C-type class-level __repr__ are wrapper_descriptor — extra56
#
# All itertools types (groupby, chain, count, product, accumulate) are C-level
# types defined in Modules/itertoolsmodule.c. When __repr__ is accessed on the
# class object (not on an instance), Python returns the tp_repr slot method
# descriptor stored in the type object. This descriptor is a 'wrapper_descriptor'
# object — the class-level form of a C slot method. At the instance level this
# becomes a 'method-wrapper' bound to the instance.
#
# No prior itertools spec records __repr__.__class__.__name__ for any itertools
# type. All five checks below are new to extra56.
# ---------------------------------------------------------------------------

table itertools_extra56.c_type_repr_descriptor:
  description: "itertools C-type class-level __repr__.__class__.__name__ == 'wrapper_descriptor' — C-extension types have tp_repr slot exposed as wrapper_descriptor at the class level; not recorded in any prior itertools spec; new to extra56"
  kind: python_call_eq
  category: class_identity
  id_prefix: itertrepr56

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_repr_class_name,
       groupby.__repr__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true,
       "itertools.groupby.__repr__.__class__.__name__ == 'wrapper_descriptor' — groupby is a C-extension type in Modules/itertoolsmodule.c that groups consecutive elements sharing the same key; accessed at the class level, __repr__ is the tp_repr slot method stored in the type object; Python exposes this as a 'wrapper_descriptor'; at the instance level it becomes 'method-wrapper'; no prior itertools spec records __repr__.__class__.__name__ for groupby; new to extra56"]
    - [chain_repr_class_name,
       chain.__repr__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true,
       "itertools.chain.__repr__.__class__.__name__ == 'wrapper_descriptor' — chain is a C-extension type in Modules/itertoolsmodule.c that chains multiple iterables together; its class-level __repr__ is the tp_repr slot descriptor exposed as a 'wrapper_descriptor'; this is the class-level form of the C slot method; no prior itertools spec records __repr__.__class__.__name__ for chain; new to extra56"]
    - [count_repr_class_name,
       count.__repr__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true,
       "itertools.count.__repr__.__class__.__name__ == 'wrapper_descriptor' — count is a C-extension type in Modules/itertoolsmodule.c that generates an infinite arithmetic sequence; its class-level __repr__ is the tp_repr C-slot descriptor, type 'wrapper_descriptor'; no prior itertools spec records __repr__.__class__.__name__ for count; new to extra56"]
    - [product_repr_class_name,
       product.__repr__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true,
       "itertools.product.__repr__.__class__.__name__ == 'wrapper_descriptor' — product is a C-extension type in Modules/itertoolsmodule.c that yields the Cartesian product of input iterables; its class-level __repr__ is the tp_repr C-slot descriptor exposed as a 'wrapper_descriptor'; no prior itertools spec records __repr__.__class__.__name__ for product; new to extra56"]
    - [accumulate_repr_class_name,
       accumulate.__repr__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true,
       "itertools.accumulate.__repr__.__class__.__name__ == 'wrapper_descriptor' — accumulate is a C-extension type in Modules/itertoolsmodule.c that yields running totals (or other binary function results); its class-level __repr__ is the tp_repr C-slot descriptor, type 'wrapper_descriptor'; no prior itertools spec records __repr__.__class__.__name__ for accumulate; new to extra56"]

# ---------------------------------------------------------------------------
# itertools C-type class-level __hash__ are wrapper_descriptor — extra56
#
# itertools C-extension types inherit __hash__ from the object base type (since
# they do not define __eq__ and thus keep the default identity-based hash).
# The class-level __hash__ descriptor is therefore the tp_hash slot from object,
# which Python exposes as a 'wrapper_descriptor'. No prior itertools spec records
# __hash__.__class__.__name__ for any itertools type. The three checks below
# (groupby, chain, count) are new to extra56.
# ---------------------------------------------------------------------------

table itertools_extra56.c_type_hash_descriptor:
  description: "itertools C-type class-level __hash__.__class__.__name__ == 'wrapper_descriptor' — C-extension types inherit tp_hash from object, exposed as wrapper_descriptor at the class level; not recorded in any prior itertools spec; new to extra56"
  kind: python_call_eq
  category: class_identity
  id_prefix: itertrepr56

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_hash_class_name,
       groupby.__hash__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true,
       "itertools.groupby.__hash__.__class__.__name__ == 'wrapper_descriptor' — groupby is a C-extension type; it does not define __eq__, so it inherits the default identity-based __hash__ from object via the tp_hash slot; accessed at the class level, this descriptor is a 'wrapper_descriptor'; no prior itertools spec records __hash__.__class__.__name__ for groupby; new to extra56"]
    - [chain_hash_class_name,
       chain.__hash__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true,
       "itertools.chain.__hash__.__class__.__name__ == 'wrapper_descriptor' — chain is a C-extension type that inherits the default identity hash from object; the class-level tp_hash descriptor is a 'wrapper_descriptor'; no prior itertools spec records __hash__.__class__.__name__ for chain; new to extra56"]
    - [count_hash_class_name,
       count.__hash__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true,
       "itertools.count.__hash__.__class__.__name__ == 'wrapper_descriptor' — count is a C-extension type that inherits the default identity hash from object; the class-level tp_hash descriptor is a 'wrapper_descriptor'; no prior itertools spec records __hash__.__class__.__name__ for count; new to extra56"]

# ---------------------------------------------------------------------------
# itertools.__spec__.name — extra56
#
# itertools.__spec__ is a ModuleSpec instance created by the import system when
# the module is loaded. ModuleSpec is defined in _frozen_importlib and has a
# .name attribute (not .__name__, which does not exist on ModuleSpec instances)
# holding the fully-qualified module name as a string.
#
# For itertools, __spec__.name == 'itertools' (9 characters). Prior extra55
# established itertools.__loader__.__name__ == 'BuiltinImporter', which accesses
# the loader's class name. The __spec__.name check is a different attribute on a
# different object (the ModuleSpec itself, not the loader). No prior itertools
# spec records __spec__.name.__eq__ or __spec__.name.__len__. New to extra56.
# ---------------------------------------------------------------------------

table itertools_extra56.spec_name:
  description: "itertools.__spec__.name == 'itertools' (9 chars) — ModuleSpec.name is the fully-qualified module name; distinct from __loader__.__name__ (the loader class name 'BuiltinImporter'); not recorded in any prior itertools spec; new to extra56"
  kind: python_call_eq
  category: string_value
  id_prefix: itertrepr56

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,
       __spec__.name.__eq__,
       ["itertools"],
       true,
       "itertools.__spec__.name == 'itertools' — __spec__ is the ModuleSpec created by the import system when the itertools C-extension module is loaded; ModuleSpec.name holds the fully-qualified module name as a string; for itertools the fully-qualified name is 'itertools' (9 chars; no package prefix since it is a top-level module); distinct from __loader__.__name__=='BuiltinImporter' covered in extra55; no prior itertools spec records __spec__.name.__eq__; new to extra56"]
    - [spec_name_len,
       __spec__.name.__len__,
       [],
       9,
       "itertools.__spec__.name.__len__() == 9 — __spec__.name is the string 'itertools'; it has 9 characters (i-t-e-r-t-o-o-l-s); no prior itertools spec records __spec__.name.__len__; complements the __eq__ check above; new to extra56"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra56
# ---------------------------------------------------------------------------

invariant itertools_extra56.groupby_repr_is_wrapper_descriptor:
  description: "groupby.__repr__.__class__.__name__ == 'wrapper_descriptor' — C-extension type class-level tp_repr slot is wrapper_descriptor; contrasts with pure-Python class __repr__ which is 'function'; new to extra56"
  kind: python_call_eq
  function: groupby.__repr__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant itertools_extra56.chain_hash_is_wrapper_descriptor:
  description: "chain.__hash__.__class__.__name__ == 'wrapper_descriptor' — C-extension types inherit identity hash from object as a tp_hash slot descriptor exposed as wrapper_descriptor; new to extra56"
  kind: python_call_eq
  function: chain.__hash__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant itertools_extra56.spec_name_is_itertools:
  description: "__spec__.name == 'itertools' — ModuleSpec.name gives the fully-qualified import name; 9 characters; different from __loader__.__name__ checked in extra55"
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra56.spec_name_len_nine:
  description: "__spec__.name.__len__() == 9 — 'itertools' is a 9-character top-level module name; complements the __eq__ check for the same attribute"
  kind: python_call_eq
  function: __spec__.name.__len__
  args: []
  expected: 9
