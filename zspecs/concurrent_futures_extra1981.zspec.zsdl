spec: concurrent_futures_extra1981
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 579 (_extra1981): __sizeof__, __length_hint__, __floor__, __ceil__, __trunc__ dict-presence checks."
    - "concurrent.futures.Future is a pure Python class (concurrent/futures/_base.py); it does NOT define __sizeof__ in its own __dict__ -> False."
    - "concurrent.futures.ThreadPoolExecutor is a pure Python class (concurrent/futures/thread.py); it does NOT define __sizeof__ -> False."
    - "concurrent.futures.ProcessPoolExecutor is a pure Python class (concurrent/futures/process.py); it does NOT define __sizeof__ -> False."
    - "concurrent.futures.Executor is an abstract base class (concurrent/futures/_base.py); it does NOT define __sizeof__ -> False."
    - "__length_hint__ is an iterator length-estimation protocol; none of the concurrent.futures executor/future types implement iterators -> False for all."
    - "__floor__, __ceil__, __trunc__ are math rounding protocol methods; concurrent.futures types are not numeric -> False for all."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __sizeof__ dict-presence checks
#
# Wave 579 theme: all four public concurrent.futures types are pure Python
# classes. None define __sizeof__ in their own __dict__; the method is
# inherited from object without override.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1981.sizeof_protocol:
  description: "concurrent.futures types __sizeof__ dict-presence checks — none define __sizeof__ in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1981

  columns: [id, function, args, expected]
  rows:
    - ["cf1981001", "concurrent.futures.Future.__dict__.__contains__",              ["__sizeof__"], false]
    - ["cf1981002", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__sizeof__"], false]
    - ["cf1981003", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__sizeof__"], false]
    - ["cf1981004", "concurrent.futures.Executor.__dict__.__contains__",            ["__sizeof__"], false]

# ---------------------------------------------------------------------------
# Table 2: __length_hint__ dict-presence checks
#
# __length_hint__ supports operator.length_hint() and is part of the iterator
# protocol (PEP 424). concurrent.futures types (executors and futures) are not
# iterators or sequences; none define __length_hint__ in their own __dict__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1981.length_hint_protocol:
  description: "concurrent.futures types __length_hint__ dict-presence checks — none define __length_hint__ in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1981

  columns: [id, function, args, expected]
  rows:
    - ["cf1981005", "concurrent.futures.Future.__dict__.__contains__",              ["__length_hint__"], false]
    - ["cf1981006", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__length_hint__"], false]
    - ["cf1981007", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__length_hint__"], false]
    - ["cf1981008", "concurrent.futures.Executor.__dict__.__contains__",            ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# Table 3: __floor__ dict-presence checks
#
# math.floor() dispatches to type.__floor__ when the type defines it in its
# __dict__. concurrent.futures types are not numeric; none define __floor__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1981.floor_protocol:
  description: "concurrent.futures types __floor__ dict-presence checks — none define __floor__ in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1981

  columns: [id, function, args, expected]
  rows:
    - ["cf1981009",  "concurrent.futures.Future.__dict__.__contains__",              ["__floor__"], false]
    - ["cf1981010",  "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__floor__"], false]
    - ["cf1981011",  "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__floor__"], false]
    - ["cf1981012",  "concurrent.futures.Executor.__dict__.__contains__",            ["__floor__"], false]

# ---------------------------------------------------------------------------
