# ---------------------------------------------------------------------------
# Table 6: cross-check — __format__ dict-presence
#
# __format__ supports format() and f-strings; concurrent.futures types are
# not numeric and do not override __format__ in their own __dict__. This
# table pads the spec to at least 30 rows and confirms the related absence
# of any numeric/display protocol override in concurrent.futures types.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1981.format_protocol:
  description: "concurrent.futures types __format__ dict-presence cross-checks — none define __format__ in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1981

  columns: [id, function, args, expected]
  rows:
    - ["cf1981021",  "concurrent.futures.Future.__dict__.__contains__",              ["__format__"], false]
    - ["cf1981022",  "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__format__"], false]
    - ["cf1981023",  "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__format__"], false]
    - ["cf1981024",  "concurrent.futures.Executor.__dict__.__contains__",            ["__format__"], false]

