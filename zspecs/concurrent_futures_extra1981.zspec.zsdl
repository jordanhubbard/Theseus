    - ["cf1981015",  "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__ceil__"], false]
    - ["cf1981016",  "concurrent.futures.Executor.__dict__.__contains__",            ["__ceil__"], false]

# ---------------------------------------------------------------------------
