spec: abc_extra3
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Extends abc.zspec.zsdl, abc_extra.zspec.zsdl, and abc_extra2.zspec.zsdl."
    - "abc.zspec.zsdl covers: ABCMeta/__name__, ABC/__name__, abstractmethod/__name__/__qualname__/__module__, ABC/__module__, ABCMeta/__module__, get_cache_token/__name__, base class checks, abstractmethod.__isabstractmethod__."
    - "abc_extra.zspec.zsdl covers: ABCMeta.__instancecheck__ and __subclasscheck__, ABC/__module__, ABCMeta/__module__, abstractmethod/__module__."
    - "abc_extra2.zspec.zsdl covers: ABC/__qualname__, ABCMeta/__qualname__, ABC/__module__, ABCMeta/__module__, abstractmethod/__module__/__name__, get_cache_token/__name__, update_abstractmethods/__name__, abstractclassmethod/__name__."
    - "This spec focuses on __qualname__ for abstractclassmethod/abstractstaticmethod/abstractproperty/get_cache_token, and ABCMeta.__bases__[0].__name__."
    - "abc.abstractclassmethod.__qualname__ == 'abstractclassmethod' (deprecated, present <3.13)."
    - "abc.abstractstaticmethod.__qualname__ == 'abstractstaticmethod' (deprecated, present <3.13)."
    - "abc.abstractproperty.__qualname__ == 'abstractproperty' (deprecated, present <3.13)."
    - "abc.get_cache_token.__qualname__ == 'get_cache_token' — C builtin qualname equals name."
    - "abc.ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta's first base is the built-in type metaclass."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ table — ABC, ABCMeta, abstractmethod
#
# For module-level classes and functions, __qualname__ equals __name__.
# abc_extra2 already covers these via standalone invariants but the task asks
# for them here as a compact table with the _extra3 spec prefix.
# ---------------------------------------------------------------------------

table abc_extra3.qualnames.core:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [ABC,              ABC.__qualname__.__eq__,              ["ABC"],              true]
    - [ABCMeta,          ABCMeta.__qualname__.__eq__,          ["ABCMeta"],          true]
    - [abstractmethod,   abstractmethod.__qualname__.__eq__,   ["abstractmethod"],   true]
    - [get_cache_token,  get_cache_token.__qualname__.__eq__,  ["get_cache_token"],  true]

# ---------------------------------------------------------------------------
# __qualname__ — deprecated symbols (Python 3.9–3.12)
#
# abstractclassmethod, abstractstaticmethod, and abstractproperty are
# top-level class objects; their __qualname__ equals their __name__.
# ---------------------------------------------------------------------------

invariant abc_extra3.abstractclassmethod.qualname:
  description: "abc.abstractclassmethod.__qualname__ == 'abstractclassmethod' (deprecated, present <3.13)"
  category: deprecated
  version: ">=3.9,<3.13"
  kind: python_call_eq
  function: abstractclassmethod.__qualname__.__eq__
  args: ["abstractclassmethod"]
  expected: true

invariant abc_extra3.abstractstaticmethod.qualname:
  description: "abc.abstractstaticmethod.__qualname__ == 'abstractstaticmethod' (deprecated, present <3.13)"
  category: deprecated
  version: ">=3.9,<3.13"
  kind: python_call_eq
  function: abstractstaticmethod.__qualname__.__eq__
  args: ["abstractstaticmethod"]
  expected: true

invariant abc_extra3.abstractproperty.qualname:
  description: "abc.abstractproperty.__qualname__ == 'abstractproperty' (deprecated, present <3.13)"
  category: deprecated
  version: ">=3.9,<3.13"
  kind: python_call_eq
  function: abstractproperty.__qualname__.__eq__
  args: ["abstractproperty"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ table — ABC, ABCMeta, abstractmethod
#
# All three core names are defined directly in the abc module.
# ---------------------------------------------------------------------------

table abc_extra3.modules.core:
  kind: python_call_eq
  category: modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [ABC,            ABC.__module__.__eq__,            ["abc"], true]
    - [ABCMeta,        ABCMeta.__module__.__eq__,        ["abc"], true]
    - [abstractmethod, abstractmethod.__module__.__eq__, ["abc"], true]

# ---------------------------------------------------------------------------
# ABCMeta.__bases__[0].__name__ == 'type'
#
# ABCMeta is a metaclass and inherits directly from the built-in 'type'.
# We access the first element of __bases__ and read its __name__ attribute.
# ---------------------------------------------------------------------------

invariant abc_extra3.ABCMeta.bases_first_is_type:
  description: "abc.ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta's first base is the built-in type metaclass"
  category: abcmeta_class
  kind: python_call_eq
  function: ABCMeta.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "type"
