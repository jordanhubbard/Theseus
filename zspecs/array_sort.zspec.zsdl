spec: array_sort
version: ">=1.0.0"
backend: node(array-sort)

docs: https://www.npmjs.com/package/array-sort

provenance:
  derived_from:
    - "array-sort README — https://www.npmjs.com/package/array-sort"
    - "Test vectors verified with array-sort via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "array-sort source"
  notes:
    - "array-sort is an npm package. Install: npm install array-sort"
    - "Sorts an array of numbers or strings in ascending order."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a sorted array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table array_sort.sort:
  kind: node_module_call_eq
  function: ~
  category: array
  id_prefix: asort

  columns: [id, args, expected]
  rows:
    - [nums,     [[3, 1, 2]],          [1, 2, 3]]
    - [strings,  [["c", "a", "b"]],    ["a", "b", "c"]]
    - [mixed,    [[3, 1, 4, 1, 5, 9]], [1, 1, 3, 4, 5, 9]]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T05:37:28Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
