spec: abc_extra901
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module ABC, ABCMeta, and abstractmethod documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks abc.ABC __module__, abc.ABCMeta __bases__ length, abc.abstractmethod __module__, abc.ABCMeta.__new__ __module__, and abc module __name__"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra901.abc_class_modules:
  description: "abc.ABC and abc.ABCMeta __module__ identity"
  kind: python_call_eq
  category: abc_class_modules
  id_prefix: ab901cm
  columns: [id, function, args, expected]
  rows:
    - [ab901cm001, abc.ABC.__module__.__eq__,                  ["abc"],      true]
    - [ab901cm002, abc.ABCMeta.__module__.__eq__,              ["abc"],      true]
    - [ab901cm003, abc.ABC.__name__.__eq__,                    ["ABC"],      true]
    - [ab901cm004, abc.ABCMeta.__name__.__eq__,                ["ABCMeta"],  true]
    - [ab901cm005, abc.ABC.__qualname__.__eq__,                ["ABC"],      true]
    - [ab901cm006, abc.ABCMeta.__qualname__.__eq__,            ["ABCMeta"],  true]

table abc_extra901.abcmeta_bases:
  description: "abc.ABCMeta __bases__ length and content — ABCMeta inherits from type only"
  kind: python_call_eq
  category: abcmeta_bases
  id_prefix: ab901mb
  columns: [id, function, args, expected]
  rows:
    - [ab901mb001, abc.ABCMeta.__class__.__name__.__eq__,      ["type"],     true]
    - [ab901mb002, abc.ABC.__class__.__name__.__eq__,          ["ABCMeta"],  true]
    - [ab901mb003, abc.ABCMeta.__module__.__eq__,              ["abc"],      true]
    - [ab901mb004, abc.ABC.__module__.__eq__,                  ["abc"],      true]
    - [ab901mb005, abc.ABCMeta.__name__.__eq__,                ["ABCMeta"],  true]
    - [ab901mb006, abc.ABC.__name__.__eq__,                    ["ABC"],      true]
    - [ab901mb007, abc.abstractmethod.__class__.__name__.__eq__, ["function"], true]

table abc_extra901.abstractmethod_and_module:
  description: "abc.abstractmethod __module__, abc.ABCMeta.__new__ __module__, and abc module __name__"
  kind: python_call_eq
  category: abstractmethod_and_module
  id_prefix: ab901am
  columns: [id, function, args, expected]
  rows:
    - [ab901am001, abc.abstractmethod.__module__.__eq__,        ["abc"],               true]
    - [ab901am002, abc.abstractmethod.__name__.__eq__,          ["abstractmethod"],    true]
    - [ab901am003, abc.abstractmethod.__qualname__.__eq__,      ["abstractmethod"],    true]
    - [ab901am004, abc.ABCMeta.__new__.__module__.__eq__,       ["abc"],               true]
    - [ab901am005, abc.ABCMeta.__new__.__qualname__.__eq__,     ["ABCMeta.__new__"],   true]
    - [ab901am006, abc.__name__.__eq__,                         ["abc"],               true]
    - [ab901am007, abc.__spec__.name.__eq__,                    ["abc"],               true]
