spec: dis_extra4
version: ">=3.9"
backend: python_module(dis)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dis.html — Python dis module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dis.py"
    - "CPython source: Python/compile.c"
  notes:
    - "This spec extends dis.zspec.zsdl, dis_extra.zspec.zsdl, dis_extra2.zspec.zsdl, dis_extra3.zspec.zsdl."
    - "Focus: __qualname__ checks for Instruction and key dis functions; _fields checks on Instruction."
    - "dis.Instruction.__qualname__ == 'Instruction' — qualname matches name for top-level classes."
    - "dis.Instruction.__module__ == 'dis' — already confirmed; __qualname__ variant is new."
    - "dis.Instruction._fields is a tuple containing field names like 'opname' and 'opcode'."
    - "dis.opname.__len__() >= 100 — Python 3.9+ has well over 100 defined opcodes."
    - "dis.dis.__qualname__ == 'dis' — module-level function qualname equals its simple name."
    - "dis.disassemble.__qualname__ == 'disassemble' — module-level function."
    - "dis.get_instructions.__qualname__ == 'get_instructions' — module-level function."
    - "dis.findlinestarts.__qualname__ == 'findlinestarts' — module-level function."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Instruction.__qualname__ and __module__ (qualname variant not in prior specs)
# ---------------------------------------------------------------------------

invariant dis_extra4.Instruction.qualname:
  description: "dis.Instruction.__qualname__ == 'Instruction'"
  category: instruction
  kind: python_call_eq
  function: Instruction.__qualname__.__eq__
  args: ["Instruction"]
  expected: true

# ---------------------------------------------------------------------------
# Instruction._fields — tuple of field names
# ---------------------------------------------------------------------------

invariant dis_extra4.Instruction.fields_class:
  description: "dis.Instruction._fields.__class__.__name__ == 'tuple'"
  category: instruction_fields
  kind: python_call_eq
  function: Instruction._fields.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant dis_extra4.Instruction.fields_contains_opname:
  description: "'opname' in dis.Instruction._fields == True"
  category: instruction_fields
  kind: python_call_eq
  function: Instruction._fields.__contains__
  args: ["opname"]
  expected: true

invariant dis_extra4.Instruction.fields_contains_opcode:
  description: "'opcode' in dis.Instruction._fields == True"
  category: instruction_fields
  kind: python_call_eq
  function: Instruction._fields.__contains__
  args: ["opcode"]
  expected: true

# ---------------------------------------------------------------------------
# opname — class name and minimum length (new: __ge__ check not in prior specs)
# ---------------------------------------------------------------------------

invariant dis_extra4.opname.len_ge_100:
  description: "len(dis.opname) >= 100 — Python 3.9+ has at least 100 opcode entries"
  category: opname
  kind: python_call_eq
  function: opname.__len__
  args: []
  method: __ge__
  method_args: [100]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ checks for key dis functions
# ---------------------------------------------------------------------------

table dis_extra4.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [dis_fn,          dis.__qualname__.__eq__,            ["dis"],              true]
    - [disassemble,     disassemble.__qualname__.__eq__,    ["disassemble"],      true]
    - [get_instructions, get_instructions.__qualname__.__eq__, ["get_instructions"], true]
    - [findlinestarts,  findlinestarts.__qualname__.__eq__, ["findlinestarts"],   true]
