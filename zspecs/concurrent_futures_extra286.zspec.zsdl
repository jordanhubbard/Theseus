spec: concurrent_futures_extra286
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures submodule identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py, Lib/concurrent/futures/_base.py"
  notes:
    - "concurrent is a namespace package; concurrent.__path__ class varies by implementation"
    - "concurrent.futures._base, thread, process are implementation submodules"
    - "concurrent.futures.__package__ == 'concurrent.futures'"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table concurrent_futures_extra286.submodule_name:
  description: "concurrent.futures submodule __name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: cf286n

  columns: [id, function, args, expected, description]
  rows:
    - [cf286n001, concurrent.futures._base.__name__, [], "concurrent.futures._base", "_base.__name__"]
    - [cf286n002, concurrent.futures.thread.__name__, [], "concurrent.futures.thread", "thread.__name__"]
    - [cf286n003, concurrent.futures.process.__name__, [], "concurrent.futures.process", "process.__name__"]

table concurrent_futures_extra286.submodule_package:
  description: "concurrent.futures submodule __package__ identity and concurrent.__name__"
  kind: python_call_eq
  category: identity
  id_prefix: cf286p

  columns: [id, function, args, expected, description]
  rows:
    - [cf286p001, concurrent.futures._base.__package__, [], "concurrent.futures", "_base.__package__"]
    - [cf286p002, concurrent.futures.thread.__package__, [], "concurrent.futures", "thread.__package__"]
    - [cf286p003, concurrent.futures.process.__package__, [], "concurrent.futures", "process.__package__"]
    - [cf286p004, concurrent.__name__, [], concurrent, "concurrent.__name__ is 'concurrent'"]

invariant concurrent_futures_extra286.base_name:
  description: "concurrent.futures._base.__name__ == 'concurrent.futures._base'"
  category: identity
  kind: python_call_eq
  function: concurrent.futures._base.__name__
  args: []
  expected: "concurrent.futures._base"

invariant concurrent_futures_extra286.thread_package:
  description: "concurrent.futures.thread.__package__ == 'concurrent.futures'"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.thread.__package__
  args: []
  expected: "concurrent.futures"

invariant concurrent_futures_extra286.process_name:
  description: "concurrent.futures.process.__name__ == 'concurrent.futures.process'"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.process.__name__
  args: []
  expected: "concurrent.futures.process"
