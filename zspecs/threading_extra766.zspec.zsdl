spec: threading_extra766
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "cpython/Lib/threading.py"
    - "cpython/Modules/_threadmodule.c"
  not_derived_from:
    - "any third-party threading extension"
  notes:
    - "Covers threading exception and ExceptHookArgs identity attributes"
    - "Lock and RLock are implemented in _thread (C extension), so __module__ == '_thread'"
    - "Semaphore and BoundedSemaphore are pure Python, so __doc__ is a str"
  created_at: "2026-04-12"

table threading_extra766.name:
  description: "threading exception and ExceptHookArgs identity"
  kind: python_call_eq
  category: type_identity
  id_prefix: th766xx
  columns: [id, function, args, expected]
  rows:
    - [th766xx001, threading.ThreadError.__qualname__.__eq__, ["ThreadError"], true]
    - [th766xx002, threading.ThreadError.__module__.__eq__, ["threading"], true]
    - [th766xx003, threading.ThreadError.__class__.__name__.__eq__, ["type"], true]
    - [th766xx004, threading.ExceptHookArgs.__qualname__.__eq__, ["ExceptHookArgs"], true]
    - [th766xx005, threading.ExceptHookArgs.__module__.__eq__, ["threading"], true]
    - [th766xx006, threading.ExceptHookArgs.__class__.__name__.__eq__, ["type"], true]
    - [th766xx007, threading.BrokenBarrierError.__qualname__.__eq__, ["BrokenBarrierError"], true]
    - [th766xx008, threading.BrokenBarrierError.__module__.__eq__, ["threading"], true]
    - [th766xx009, threading.Lock.__module__.__eq__, ["_thread"], true]
    - [th766xx010, threading.RLock.__module__.__eq__, ["_thread"], true]
    - [th766xx011, threading.Semaphore.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [th766xx012, threading.BoundedSemaphore.__doc__.__class__.__name__.__eq__, ["str"], true]
