spec: theseus_importlib_machinery_cr
version: ">=3.0"
backend: python_cleanroom(theseus_importlib_machinery_cr)
blocks: importlib.machinery

docs: https://docs.python.org/3/library/importlib.html#importlib.machinery

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/importlib.html"
  not_derived_from:
    - "CPython source: Lib/importlib/machinery.py"
  notes:
    - "Clean-room importlib.machinery module. Do NOT import importlib.machinery."

error_model: python_exceptions

invariant theseus_importlib_machinery_cr.impmach2_source_loader:
  description: "SourceFileLoader can load Python source files"
  category: behavior
  kind: python_call_eq
  function: impmach2_source_loader
  args: []
  expected: true

invariant theseus_importlib_machinery_cr.impmach2_module_spec:
  description: "ModuleSpec stores spec information for a module"
  category: behavior
  kind: python_call_eq
  function: impmach2_module_spec
  args: []
  expected: true

invariant theseus_importlib_machinery_cr.impmach2_finders:
  description: "FileFinder and PathFinder classes exist"
