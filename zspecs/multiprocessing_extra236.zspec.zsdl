spec: multiprocessing_extra236
version: ">=3.4"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.get_all_start_methods — get_all_start_methods"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.get_start_method — get_start_method"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.set_start_method — set_start_method"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py (internal implementation)"
  notes:
    - "This spec covers multiprocessing.get_all_start_methods, get_start_method, set_start_method function identity."
    - "All three are bound methods of DefaultContext: __class__.__name__ == 'method'."
    - "get_all_start_methods.__module__ == 'multiprocessing.context' (len=23) — same for all three."
    - "get_all_start_methods.__name__ == 'get_all_start_methods' (len=21)."
    - "get_start_method.__name__ == 'get_start_method' (len=16); set_start_method.__name__ == 'set_start_method' (len=16)."
    - "get_all_start_methods.__qualname__ == 'DefaultContext.get_all_start_methods' (len=36)."
    - "get_start_method.__qualname__ == 'DefaultContext.get_start_method' (len=31)."
    - "set_start_method.__qualname__ == 'DefaultContext.set_start_method' (len=31)."
    - "On macOS, get_all_start_methods() returns ['spawn', 'fork', 'forkserver'] (len=3)."
    - "get_start_method() returns 'spawn' on macOS by default."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.get_all_start_methods function identity
#
# get_all_start_methods.__name__ == 'get_all_start_methods' (len=21)
# get_all_start_methods.__module__ == 'multiprocessing.context' (len=23)
# get_all_start_methods.__qualname__ == 'DefaultContext.get_all_start_methods' (len=36)
# get_all_start_methods.__class__.__name__ == 'method'
# ---------------------------------------------------------------------------

table multiprocessing_extra236.get_all_start_methods_identity:
  description: "multiprocessing.get_all_start_methods function identity — get_all_start_methods is a bound method of DefaultContext; __name__.__eq__('get_all_start_methods')==True (len=21); __module__.__eq__('multiprocessing.context')==True (len=23); __qualname__.__eq__('DefaultContext.get_all_start_methods')==True (len=36); __class__.__name__.__eq__('method')==True (bound method, not a plain function); __name__.__len__()==21; __module__.__len__()==23; verified with Python 3.14.3"
  kind: python_call_eq
  category: get_all_start_methods_identity
  id_prefix: mpstart236

  columns: [id, function, args, expected, description]
  rows:
    - [gasm_name_eq,   get_all_start_methods.__name__.__eq__,           ["get_all_start_methods"],              true, "multiprocessing.get_all_start_methods.__name__ == 'get_all_start_methods'; verified with Python 3.14.3"]
    - [gasm_name_len,  get_all_start_methods.__name__.__len__,          [],                                    21,   "multiprocessing.get_all_start_methods.__name__.__len__() == 21; verified with Python 3.14.3"]
    - [gasm_mod_eq,    get_all_start_methods.__module__.__eq__,         ["multiprocessing.context"],            true, "multiprocessing.get_all_start_methods.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [gasm_mod_len,   get_all_start_methods.__module__.__len__,        [],                                    23,   "multiprocessing.get_all_start_methods.__module__.__len__() == 23; verified with Python 3.14.3"]
    - [gasm_qname_eq,  get_all_start_methods.__qualname__.__eq__,       ["DefaultContext.get_all_start_methods"], true, "multiprocessing.get_all_start_methods.__qualname__ == 'DefaultContext.get_all_start_methods'; verified with Python 3.14.3"]
    - [gasm_cls_eq,    get_all_start_methods.__class__.__name__.__eq__, ["method"],                            true, "multiprocessing.get_all_start_methods.__class__.__name__ == 'method' (bound method); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.get_start_method function identity
#
# get_start_method.__name__ == 'get_start_method' (len=16)
# get_start_method.__module__ == 'multiprocessing.context' (len=23)
# get_start_method.__qualname__ == 'DefaultContext.get_start_method' (len=31)
# get_start_method.__class__.__name__ == 'method'
# ---------------------------------------------------------------------------

table multiprocessing_extra236.get_start_method_identity:
  description: "multiprocessing.get_start_method function identity — get_start_method is a bound method of DefaultContext; __name__.__eq__('get_start_method')==True (len=16); __module__.__eq__('multiprocessing.context')==True (len=23, same as get_all_start_methods); __qualname__.__eq__('DefaultContext.get_start_method')==True (len=31); __class__.__name__.__eq__('method')==True; __name__.__len__()==16; __qualname__.__len__()==31; verified with Python 3.14.3"
  kind: python_call_eq
  category: get_start_method_identity
  id_prefix: mpstart236

  columns: [id, function, args, expected, description]
  rows:
    - [gsm_name_eq,   get_start_method.__name__.__eq__,           ["get_start_method"],             true, "multiprocessing.get_start_method.__name__ == 'get_start_method'; verified with Python 3.14.3"]
    - [gsm_name_len,  get_start_method.__name__.__len__,          [],                               16,   "multiprocessing.get_start_method.__name__.__len__() == 16; verified with Python 3.14.3"]
    - [gsm_mod_eq,    get_start_method.__module__.__eq__,         ["multiprocessing.context"],      true, "multiprocessing.get_start_method.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [gsm_qname_eq,  get_start_method.__qualname__.__eq__,       ["DefaultContext.get_start_method"], true, "multiprocessing.get_start_method.__qualname__ == 'DefaultContext.get_start_method'; verified with Python 3.14.3"]
    - [gsm_cls_eq,    get_start_method.__class__.__name__.__eq__, ["method"],                      true, "multiprocessing.get_start_method.__class__.__name__ == 'method' (bound method); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra236
# ---------------------------------------------------------------------------

invariant multiprocessing_extra236.get_all_start_methods_module_eq:
  description: "multiprocessing.get_all_start_methods.__module__.__eq__('multiprocessing.context') returns True — get_all_start_methods is a bound method of DefaultContext defined in Lib/multiprocessing/context.py; __module__ == 'multiprocessing.context' (len=23 = 'multiprocessing'=15 + '.'=1 + 'context'=7); same module as get_start_method and set_start_method; __name__ == 'get_all_start_methods' (len=21); __qualname__ == 'DefaultContext.get_all_start_methods' (len=36); NEW in extra236: first standalone get_all_start_methods module invariant in mpstart236 namespace; verified with Python 3.14.3"
  category: get_all_start_methods_identity
  kind: python_call_eq
  function: get_all_start_methods.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra236.set_start_method_name_eq:
  description: "multiprocessing.set_start_method.__name__.__eq__('set_start_method') returns True — set_start_method is a bound method of DefaultContext; __name__ == 'set_start_method' (len=16, same length as get_start_method.__name__.__len__()==16); __module__ == 'multiprocessing.context' (len=23); __qualname__ == 'DefaultContext.set_start_method' (len=31, same length as get_start_method.__qualname__.__len__()==31); __class__.__name__ == 'method'; NEW in extra236: first standalone set_start_method name invariant; verified with Python 3.14.3"
  category: set_start_method_identity
  kind: python_call_eq
  function: set_start_method.__name__.__eq__
  args: ["set_start_method"]
  expected: true

invariant multiprocessing_extra236.set_start_method_module_eq:
  description: "multiprocessing.set_start_method.__module__.__eq__('multiprocessing.context') returns True — set_start_method is defined in Lib/multiprocessing/context.py; __module__ == 'multiprocessing.context' (len=23); same module as get_start_method and get_all_start_methods; __name__ == 'set_start_method' (len=16); __qualname__ == 'DefaultContext.set_start_method' (len=31); __class__.__name__ == 'method'; NEW in extra236: first standalone set_start_method module invariant; verified with Python 3.14.3"
  category: set_start_method_identity
  kind: python_call_eq
  function: set_start_method.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra236.set_start_method_class_is_method:
  description: "multiprocessing.set_start_method.__class__.__name__.__eq__('method') returns True — set_start_method is a bound method of the DefaultContext singleton; __class__.__name__ == 'method' (len=6); same class as get_start_method and get_all_start_methods (all three are bound methods of DefaultContext); contrast with multiprocessing.active_children.__class__.__name__ == 'function' (plain function); __name__ == 'set_start_method' (len=16); __module__ == 'multiprocessing.context' (len=23); NEW in extra236: first standalone set_start_method class invariant; verified with Python 3.14.3"
  category: set_start_method_identity
  kind: python_call_eq
  function: set_start_method.__class__.__name__.__eq__
  args: ["method"]
  expected: true

invariant multiprocessing_extra236.get_all_start_methods_class_is_method:
  description: "multiprocessing.get_all_start_methods.__class__.__name__.__eq__('method') returns True — get_all_start_methods is a bound method of the DefaultContext singleton; __class__.__name__ == 'method' (len=6); all three start method functions (get_all_start_methods, get_start_method, set_start_method) are bound methods of DefaultContext; __name__ == 'get_all_start_methods' (len=21, longest of the three); __module__ == 'multiprocessing.context' (len=23); __qualname__ == 'DefaultContext.get_all_start_methods' (len=36, longest qualname of the three); NEW in extra236: first standalone get_all_start_methods class invariant; verified with Python 3.14.3"
  category: get_all_start_methods_identity
  kind: python_call_eq
  function: get_all_start_methods.__class__.__name__.__eq__
  args: ["method"]
  expected: true
