# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra133.FileIO.name_is_FileIO:
  description: "io.FileIO.__name__ == 'FileIO' (the class __name__ attribute equals the bare class name without module prefix)"
  category: class_identity
  kind: python_call_eq
  function: FileIO.__name__.__eq__
  args: ["FileIO"]
  expected: true

invariant io_extra133.FileIO.module_is_underscore_io:
  description: "io.FileIO.__module__ == '_io' (FileIO is a C extension type from the private _io extension, even though it is re-exported through the io module)"
  category: class_identity
  kind: python_call_eq
  function: FileIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra133.FileIO.base_is_RawIOBase:
  description: "io.FileIO.__bases__[0].__name__ == '_RawIOBase' (FileIO directly extends the private C-level _RawIOBase, the concrete raw I/O base type)"
  category: class_identity
  kind: python_call_eq
  function: FileIO.__bases__[0].__name__.__eq__
  args: ["_RawIOBase"]
  expected: true

invariant io_extra133.FileIO.read_qualname_len_11:
  description: "io.FileIO.read.__qualname__.__len__() == 11 ('FileIO.read' has 11 characters: F-i-l-e-I-O-.-r-e-a-d)"
  category: method_qualnames
  kind: python_call_eq
  function: FileIO.read.__qualname__.__len__
  args: []
  expected: 11

invariant io_extra133.FileIO.readall_qualname_len_14:
  description: "io.FileIO.readall.__qualname__.__len__() == 14 ('FileIO.readall' has 14 characters: F-i-l-e-I-O-.-r-e-a-d-a-l-l)"
  category: method_qualnames
  kind: python_call_eq
  function: FileIO.readall.__qualname__.__len__
  args: []
  expected: 14

