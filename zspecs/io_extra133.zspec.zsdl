spec: io_extra133
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/fileio.c"
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec covers: io.FileIO class identity and method __qualname__ values."
    - "io.FileIO.__name__ = 'FileIO' — the class name attribute."
    - "io.FileIO.__module__ = '_io' — FileIO is a C extension type from _io."
    - "io.FileIO.__bases__[0].__name__ = '_RawIOBase' — FileIO directly extends the C-level _RawIOBase."
    - "io.FileIO.__mro__.__len__() = 4 — MRO is [FileIO, _RawIOBase, _IOBase, object]."
    - "io.FileIO.__qualname__ = 'FileIO' (length 6) — for C extension types at module level, __qualname__ == __name__."
    - "io.FileIO.read.__qualname__ = 'FileIO.read' (length 11) — method qualname includes the class prefix."
    - "io.FileIO.readall.__qualname__ = 'FileIO.readall' (length 14) — method qualname includes the class prefix."
    - "io.FileIO.write.__qualname__ = 'FileIO.write' (length 12) — method qualname includes the class prefix."
    - "io.FileIO.seek.__qualname__ = 'FileIO.seek' (length 11) — method qualname includes the class prefix."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.FileIO class identity
# FileIO.__name__ == 'FileIO', __module__ == '_io', __qualname__ == 'FileIO'.
# __bases__[0].__name__ == '_RawIOBase' (direct C-level base).
# __mro__.__len__() == 4 ([FileIO, _RawIOBase, _IOBase, object]).
# ---------------------------------------------------------------------------

table io_extra133.FileIO_class_identity:
  description: "io.FileIO class identity: __name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: iofileioident133

  columns: [id, function, args, expected]
  rows:
    - [fileio_name_eq,      FileIO.__name__.__eq__,                    ["FileIO"],      true]
    - [fileio_name_len,     FileIO.__name__.__len__,                   [],              6]
    - [fileio_module_eq,    FileIO.__module__.__eq__,                  ["_io"],         true]
    - [fileio_module_not,   FileIO.__module__.__eq__,                  ["io"],          false]
    - [fileio_qualname_eq,  FileIO.__qualname__.__eq__,                ["FileIO"],      true]
    - [fileio_qualname_len, FileIO.__qualname__.__len__,               [],              6]
    - [fileio_base_eq,      "FileIO.__bases__[0].__name__.__eq__",       ["_RawIOBase"],  true]
    - [fileio_base_not_buf, "FileIO.__bases__[0].__name__.__eq__",       ["_BufferedIOBase"], false]
    - [fileio_mro_len,      FileIO.__mro__.__len__,                    [],              4]

