spec: unittest_extra2
version: ">=3.8"
backend: python_module(unittest)

docs: https://docs.python.org/3/library/unittest.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/unittest.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "unittest source: internal test runner implementation"
    - "unittest.zspec.zsdl — covers class __name__ checks and basic function names"
    - "unittest_extra.zspec.zsdl — covers class __module__ checks, decorator __module__, main identity, TestCase/FunctionTestCase bases, TestLoader/TestResult state"
  notes:
    - "Complements unittest.zspec.zsdl and unittest_extra.zspec.zsdl with runner-level module checks and class hierarchy."
    - "TextTestRunner and TextTestResult are defined in Lib/unittest/runner.py; their __module__ == 'unittest.runner'."
    - "unittest_extra.zspec.zsdl covers TestSuite.__module__ == 'unittest.suite'; this spec adds TextTestRunner/TextTestResult modules."
    - "TestSuite.__bases__[0].__name__ == 'BaseTestSuite' — TestSuite subclasses BaseTestSuite."
    - "TextTestResult.__bases__[0].__name__ == 'TestResult' — TextTestResult subclasses TestResult."
    - "TestResult.__bases__[0].__name__ == 'object' — TestResult inherits directly from object."
    - "TestLoader.__bases__[0].__name__ == 'object' — TestLoader inherits directly from object."
    - "TextTestRunner.__bases__[0].__name__ == 'object' — TextTestRunner inherits directly from object."
    - "BaseTestSuite.__name__ == 'BaseTestSuite' — the abstract suite base class."
    - "BaseTestSuite.__module__ == 'unittest.suite' — defined alongside TestSuite."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Runner module checks — TextTestRunner and TextTestResult live in runner.py
# ---------------------------------------------------------------------------

table unittest_extra2.runner_modules:
  kind: python_call_eq
  category: class_modules
  id_prefix: rmod

  columns: [id, function, args, expected]
  rows:
    - [texttestrunner, TextTestRunner.__module__.__eq__, ["unittest.runner"], true]
    - [texttestresult, TextTestResult.__module__.__eq__, ["unittest.runner"], true]

# ---------------------------------------------------------------------------
# BaseTestSuite — name and module
# ---------------------------------------------------------------------------

invariant unittest_extra2.BaseTestSuite.name:
  description: "unittest.BaseTestSuite.__name__ == 'BaseTestSuite'"
  category: class_names
  kind: python_call_eq
  function: BaseTestSuite.__name__.__eq__
  args: ["BaseTestSuite"]
  expected: true

invariant unittest_extra2.BaseTestSuite.module:
  description: "unittest.BaseTestSuite.__module__ == 'unittest.suite'"
  category: class_modules
  kind: python_call_eq
  function: BaseTestSuite.__module__.__eq__
  args: ["unittest.suite"]
  expected: true

# ---------------------------------------------------------------------------
# Class hierarchy — base class checks
# ---------------------------------------------------------------------------

invariant unittest_extra2.TestSuite.base_is_BaseTestSuite:
  description: "unittest.TestSuite.__bases__[0].__name__ == 'BaseTestSuite' — TestSuite subclasses BaseTestSuite"
  category: hierarchy
  kind: python_call_eq
  function: TestSuite.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BaseTestSuite"

invariant unittest_extra2.TextTestResult.base_is_TestResult:
  description: "unittest.TextTestResult.__bases__[0].__name__ == 'TestResult' — TextTestResult subclasses TestResult"
  category: hierarchy
  kind: python_call_eq
  function: TextTestResult.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "TestResult"

invariant unittest_extra2.TestResult.base_is_object:
  description: "unittest.TestResult.__bases__[0].__name__ == 'object' — TestResult inherits directly from object"
  category: hierarchy
  kind: python_call_eq
  function: TestResult.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant unittest_extra2.TestLoader.base_is_object:
  description: "unittest.TestLoader.__bases__[0].__name__ == 'object' — TestLoader inherits directly from object"
  category: hierarchy
  kind: python_call_eq
  function: TestLoader.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant unittest_extra2.TextTestRunner.base_is_object:
  description: "unittest.TextTestRunner.__bases__[0].__name__ == 'object' — TextTestRunner inherits directly from object"
  category: hierarchy
  kind: python_call_eq
  function: TextTestRunner.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant unittest_extra2.TestProgram.base_is_object:
  description: "unittest.TestProgram.__bases__[0].__name__ == 'object' — TestProgram inherits directly from object"
  category: hierarchy
  kind: python_call_eq
  function: TestProgram.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"
