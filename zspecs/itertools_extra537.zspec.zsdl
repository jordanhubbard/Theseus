spec: itertools_extra537
version: ">=3.9"
backend: python_module(itertools)
docs: "Cover itertools class __qualname__ and __doc__ type for remaining classes"
provenance:
  derived_from:
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"
error_model: exception_is_failure

table itertools_extra537.qualname_checks:
  description: "itertools class __qualname__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: itq

  columns: [id, function, args, expected]
  rows:
    - [itq001, itertools.combinations_with_replacement.__qualname__.__eq__, ["combinations_with_replacement"], true]
    - [itq002, itertools.filterfalse.__qualname__.__eq__, ["filterfalse"], true]
    - [itq003, itertools.zip_longest.__qualname__.__eq__, ["zip_longest"], true]
    - [itq004, itertools.tee.__qualname__.__eq__, ["tee"], true]
    - [itq005, itertools.starmap.__qualname__.__eq__, ["starmap"], true]
    - [itq006, itertools.dropwhile.__qualname__.__eq__, ["dropwhile"], true]
    - [itq007, itertools.takewhile.__qualname__.__eq__, ["takewhile"], true]

table itertools_extra537.doc_type_checks:
  description: "itertools class __doc__ type checks"
  kind: python_call_eq
  category: identity
  id_prefix: itd

  columns: [id, function, args, expected]
  rows:
    - [itd001, itertools.combinations_with_replacement.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [itd002, itertools.filterfalse.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [itd003, itertools.zip_longest.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [itd004, itertools.tee.__doc__.__class__.__name__.__eq__, ["str"], true]
