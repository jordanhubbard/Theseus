spec: pp3556
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 684 (pp3556): __reduce__, __reduce_ex__, __getstate__ dict-presence checks for pathlib types."
    - "pathlib.PurePath defines __reduce__ (true): PurePath implements custom pickle support so that unpickling recreates the correct platform-specific subclass."
    - "pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath: do NOT define __reduce__ in their own __dict__ (false) — they rely on PurePath.__reduce__."
    - "No pathlib type defines __reduce_ex__ or __getstate__ in its own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __reduce__ dict-presence — operator.contains(Cls.__dict__, '__reduce__')
#
# pathlib.PurePath defines __reduce__; subclasses inherit it.
# ---------------------------------------------------------------------------

table pp3556.reduce:
  description: "pathlib types __reduce__ dict-presence checks; wave 684"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3556
  columns: [id, function, args, expected]
  rows:
    - ["pp3556001", operator.contains, [pathlib.PurePath.__dict__,        "__reduce__"], true]
    - ["pp3556002", operator.contains, [pathlib.PurePosixPath.__dict__,   "__reduce__"], false]
    - ["pp3556003", operator.contains, [pathlib.PureWindowsPath.__dict__, "__reduce__"], false]
    - ["pp3556004", operator.contains, [pathlib.Path.__dict__,            "__reduce__"], false]
    - ["pp3556005", operator.contains, [pathlib.PosixPath.__dict__,       "__reduce__"], false]

