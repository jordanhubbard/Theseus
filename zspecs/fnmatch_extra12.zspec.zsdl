spec: fnmatch_extra12
version: ">=3.9"
backend: python_module(fnmatch)

docs: https://docs.python.org/3/library/fnmatch.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fnmatch.html — Python fnmatch module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fnmatch.py"
  notes:
    - "This spec extends fnmatch.zspec.zsdl and fnmatch_extra through fnmatch_extra11.zspec.zsdl."
    - "fnmatch_extra11 covers: star-pattern table (hello_py_match, upper_py_no_match, test_prefix_match, pyc_no_match, txt_match, hidden_dot_match, normal_dot_no_match); bracket range and ?-wildcard standalone invariants; fnmatchcase mixed-case; module/name standalone invariants."
    - "NEW in this spec: fnmatch.fnmatch('hello.py', '*.py') == True; fnmatch.fnmatch('hello.txt', '*.py') == False; fnmatch.fnmatch('test_foo.py', 'test_*.py') == True; fnmatch.fnmatch('foo.PY', '*.py') == False (POSIX is case-sensitive — verified on macOS Darwin 25.4.0); fnmatch.filter(['a.py','b.txt','c.py'], '*.py') == ['a.py','c.py']; fnmatch.translate('*.py').__class__.__name__ == 'str'."
    - "Note: on macOS the filesystem may be case-insensitive but fnmatch itself is NOT — it does pure string comparison, so 'foo.PY' does NOT match '*.py'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# fnmatch.fnmatch — basic behavioral table in extra12 namespace
#
# Prior specs (extra11 star-pattern table) cover these names:
#   hello_py_match, test_prefix_match, upper_py_no_match
# This table uses fresh IDs and tests the specific vectors requested.
# ---------------------------------------------------------------------------

table fnmatch_extra12.fnmatch_basic:
  description: "fnmatch basic match/no-match vectors with *.py and test_*.py patterns"
  kind: python_call_eq
  category: fnmatch
  id_prefix: fbasic12

  columns: [id, function, args, expected]
  rows:
    - [hello_py,       fnmatch, ["hello.py",     "*.py"],      true]
    - [hello_txt,      fnmatch, ["hello.txt",    "*.py"],      false]
    - [test_prefix,    fnmatch, ["test_foo.py",  "test_*.py"], true]
    - [foo_upper_ext,  fnmatch, ["foo.PY",       "*.py"],      false]

# ---------------------------------------------------------------------------
# fnmatch.filter — list filtering with star pattern
#
# fnmatch.filter(['a.py','b.txt','c.py'], '*.py') == ['a.py','c.py']
# Verified on Python 3.12 on macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant fnmatch_extra12.filter.star_py:
  description: "fnmatch.filter(['a.py','b.txt','c.py'], '*.py') == ['a.py','c.py']"
  category: filter
  kind: python_call_eq
  function: filter
  args: [["a.py", "b.txt", "c.py"], "*.py"]
  expected: ["a.py", "c.py"]

# ---------------------------------------------------------------------------
# fnmatch.translate — return type is str
#
# fnmatch.translate('*.py') returns a regex string.
# Verified: fnmatch.translate('*.py').__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

invariant fnmatch_extra12.translate.returns_str:
  description: "fnmatch.translate('*.py').__class__.__name__ == 'str' — translate returns a string"
  category: translate
  kind: python_call_eq
  function: translate
  args: ["*.py"]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true
