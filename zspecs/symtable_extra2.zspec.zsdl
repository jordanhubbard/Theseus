spec: symtable_extra2
version: ">=3.9"
backend: python_module(symtable)

docs: https://docs.python.org/3/library/symtable.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/symtable.html — Python symtable module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/symtable.py"
    - "symtable.zspec.zsdl — covers symtable.__name__, SymbolTable/__name__/__module__, Function/__name__, Class/__name__, Symbol/__name__, SymbolTable method names (get_type/get_id/get_name/get_children/get_symbols), Symbol method names (get_name/is_global/is_local), symtable() exec returns Module"
    - "symtable_extra.zspec.zsdl — covers symtable.__name__, class_names table (SymbolTable/Function/Class/Symbol), class_modules table (SymbolTable/Function/Class/Symbol), Function.__bases__[0].__name__=='SymbolTable', Class.__bases__[0].__name__=='SymbolTable', symtable() returns SymbolTable, symtable().get_type()=='module'"
  notes:
    - "This spec covers SymbolTableError, __qualname__ attributes, and symtable.__module__ — not in prior symtable specs."
    - "symtable.SymbolTableError is the exception class raised for symbol table construction errors."
    - "symtable.SymbolTableError.__name__ == 'SymbolTableError'."
    - "symtable.SymbolTableError.__bases__[0].__name__ == 'Exception' — inherits directly from Exception."
    - "symtable.SymbolTableError.__module__ == 'symtable' — defined in Lib/symtable.py."
    - "symtable.symtable.__module__ == 'symtable' — the top-level function's module attribute."
    - "symtable.SymbolTable.__qualname__ == 'SymbolTable' — qualname equals name for top-level classes."
    - "symtable.Function.__qualname__ == 'Function' — top-level class qualname."
    - "symtable.Class.__qualname__ == 'Class' — top-level class qualname."
    - "symtable.Symbol.__qualname__ == 'Symbol' — top-level class qualname."
    - "symtable.SymbolTable.__bases__[0].__name__ == 'object' — SymbolTable inherits directly from object."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SymbolTableError — exception class identity
# (not covered in symtable.zspec.zsdl or symtable_extra.zspec.zsdl)
# ---------------------------------------------------------------------------

invariant symtable_extra2.SymbolTableError.name:
  description: "symtable.SymbolTableError.__name__ == 'SymbolTableError'"
  category: exception_class
  kind: python_call_eq
  function: SymbolTableError.__name__.__eq__
  args: ["SymbolTableError"]
  expected: true

invariant symtable_extra2.SymbolTableError.module:
  description: "symtable.SymbolTableError.__module__ == 'symtable'"
  category: exception_class
  kind: python_call_eq
  function: SymbolTableError.__module__.__eq__
  args: ["symtable"]
  expected: true

invariant symtable_extra2.SymbolTableError.base_is_Exception:
  description: "symtable.SymbolTableError.__bases__[0].__name__ == 'Exception'"
  category: exception_class
  kind: python_call_eq
  function: SymbolTableError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# symtable() function — __module__ attribute
# (symtable_extra covers __name__; __module__ is new here)
# ---------------------------------------------------------------------------

invariant symtable_extra2.symtable.module:
  description: "symtable.symtable.__module__ == 'symtable' — the top-level function is defined in the symtable module"
  category: function_attrs
  kind: python_call_eq
  function: symtable.__module__.__eq__
  args: ["symtable"]
  expected: true

# ---------------------------------------------------------------------------
# SymbolTable base class hierarchy
# (symtable_extra covers Function.__bases__ and Class.__bases__;
#  SymbolTable.__bases__[0].__name__ == 'object' is new here)
# ---------------------------------------------------------------------------

invariant symtable_extra2.SymbolTable.base_is_object:
  description: "symtable.SymbolTable.__bases__[0].__name__ == 'object' — SymbolTable inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: SymbolTable.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# __qualname__ checks for all symtable classes
# (not covered in any prior symtable spec)
# ---------------------------------------------------------------------------

table symtable_extra2.class_qualnames:
  kind: python_call_eq
  category: qualname_attrs
  id_prefix: cqname

  columns: [id, function, args, expected]
  rows:
    - [SymbolTable, SymbolTable.__qualname__.__eq__, ["SymbolTable"], true]
    - [Function,    Function.__qualname__.__eq__,    ["Function"],    true]
    - [Class,       Class.__qualname__.__eq__,       ["Class"],       true]
    - [Symbol,      Symbol.__qualname__.__eq__,      ["Symbol"],      true]

# ---------------------------------------------------------------------------
# Symbol.__module__ — not covered in prior specs
# (symtable_extra covers Symbol.__name__ but not __module__)
# ---------------------------------------------------------------------------

invariant symtable_extra2.Symbol.module:
  description: "symtable.Symbol.__module__ == 'symtable'"
  category: class_attrs
  kind: python_call_eq
  function: Symbol.__module__.__eq__
  args: ["symtable"]
  expected: true
