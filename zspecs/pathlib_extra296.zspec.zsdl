spec: pathlib_extra296
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module identity and Path/PurePath class attributes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py, Lib/pathlib/_local.py"
  notes:
    - "pathlib.__package__ is empty string on CPython (top-level module)"
    - "pathlib.__loader__ is SourceFileLoader since pathlib is a pure-Python module"
    - "Path.__init__.__qualname__ may be 'PurePath.__init__' if inherited; verified as 'PurePath.__init__'"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table pathlib_extra296.module_identity:
  description: "pathlib module identity attributes"
  kind: python_call_eq
  category: identity
  id_prefix: plx296

  columns: [id, function, args, expected, description]
  rows:
    - [plx296_001, pathlib.__name__.__eq__, ["pathlib"], true, "pathlib module __name__"]
    - [plx296_002, pathlib.__package__.__eq__, [""], true, "pathlib module __package__ is empty string"]
    - [plx296_003, pathlib.__spec__.__class__.__name__.__eq__, ["ModuleSpec"], true, "pathlib __spec__ class name"]
    - [plx296_004, pathlib.__loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true, "pathlib __loader__ class name"]
    - [plx296_005, pathlib.__file__.__class__.__name__.__eq__, ["str"], true, "pathlib __file__ class name"]

table pathlib_extra296.path_class_attributes:
  description: "Path and PurePath class attribute identity"
  kind: python_call_eq
  category: identity
  id_prefix: plx296c

  columns: [id, function, args, expected, description]
  rows:
    - [plx296c_001, pathlib.Path.__class__.__name__.__eq__, ["type"], true, "Path __class__.__name__ is type"]
    - [plx296c_002, pathlib.PurePath.__class__.__name__.__eq__, ["type"], true, "PurePath __class__.__name__ is type"]
    - [plx296c_003, pathlib.PurePath.__init__.__qualname__.__eq__, ["PurePath.__init__"], true, "PurePath.__init__ qualname"]
    - [plx296c_004, pathlib.Path.__init__.__qualname__.__eq__, ["PurePath.__init__"], true, "Path.__init__ qualname (inherited from PurePath)"]
    - [plx296c_005, pathlib.Path.__new__.__qualname__.__eq__, ["Path.__new__"], true, "Path.__new__ qualname"]

invariant pathlib_extra296.inv_module_name:
  description: "pathlib.__name__ is 'pathlib'"
  category: identity
  kind: python_call_eq
  function: pathlib.__name__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra296.inv_spec_class:
  description: "pathlib.__spec__ class is ModuleSpec"
  category: identity
  kind: python_call_eq
  function: pathlib.__spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant pathlib_extra296.inv_path_class:
  description: "pathlib.Path is a type"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.__class__.__name__.__eq__
  args: ["type"]
  expected: true
