spec: functools_extra230
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers functools __doc__ string contains checks."
    - "functools.__doc__ == 'functools.py - Tools for working with functions and callable objects\\n'. Verified with Python 3.14.3."
    - "functools.reduce.__doc__ contains 'function'. Verified with Python 3.14.3."
    - "functools.partial.__doc__ contains 'partial'. Verified with Python 3.14.3."
    - "functools.lru_cache.__doc__ contains 'cache'. Verified with Python 3.14.3."
    - "functools.singledispatch.__doc__ contains 'dispatch'. Verified with Python 3.14.3."
    - "functools.cached_property.__doc__ is None. Verified with Python 3.14.3."
    - "functools.wraps.__doc__ contains 'wrapper'. Verified with Python 3.14.3."
    - "functools.update_wrapper.__doc__ contains 'wrapper'. Verified with Python 3.14.3."
    - "functools.total_ordering.__doc__ contains 'ordering'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools __doc__ contains checks
#
# Verified with Python 3.14.3:
#   functools.__doc__ contains 'functools'
#   functools.reduce.__doc__ contains 'function'
#   functools.partial.__doc__ contains 'partial'
#   functools.lru_cache.__doc__ contains 'cache'
#   functools.singledispatch.__doc__ contains 'dispatch'
#   functools.wraps.__doc__ contains 'wrapper'
#   functools.update_wrapper.__doc__ contains 'wrapper'
#   functools.total_ordering.__doc__ contains 'ordering'
# ---------------------------------------------------------------------------

table functools_extra230.doc_contains:
  description: "functools __doc__ string contains checks; new to extra230"
  kind: python_call_eq
  category: doc_inspection
  id_prefix: functoolsextra230doc

  columns: [id, function, args, expected, description]
  rows:
    - [module_doc_contains_functools,
       __doc__.__contains__,
       ["functools"],
       true,
       "functools.__doc__.__contains__('functools') == True — module docstring is 'functools.py - Tools for working with functions and callable objects'; contains 'functools'; new to extra230"]
    - [reduce_doc_contains_function,
       reduce.__doc__.__contains__,
       ["function"],
       true,
       "functools.reduce.__doc__.__contains__('function') == True — reduce docstring starts with 'Apply a function of two arguments'; contains 'function'; new to extra230"]
    - [partial_doc_contains_partial,
       partial.__doc__.__contains__,
       ["partial"],
       true,
       "functools.partial.__doc__.__contains__('partial') == True — partial docstring is 'Create a new function with partial application...'; contains 'partial'; new to extra230"]
    - [lru_cache_doc_contains_cache,
       lru_cache.__doc__.__contains__,
       ["cache"],
       true,
       "functools.lru_cache.__doc__.__contains__('cache') == True — lru_cache docstring starts with 'Least-recently-used cache decorator'; contains 'cache'; new to extra230"]
    - [singledispatch_doc_contains_dispatch,
       singledispatch.__doc__.__contains__,
       ["dispatch"],
       true,
       "functools.singledispatch.__doc__.__contains__('dispatch') == True — singledispatch docstring starts with 'Single-dispatch generic function decorator'; contains 'dispatch'; new to extra230"]

# ---------------------------------------------------------------------------
# Table 2: more functools __doc__ contains checks
#
# Verified with Python 3.14.3:
#   functools.wraps.__doc__ contains 'wrapper'
#   functools.update_wrapper.__doc__ contains 'wrapper'
#   functools.total_ordering.__doc__ contains 'ordering'
# ---------------------------------------------------------------------------

table functools_extra230.doc_contains_more:
  description: "functools wraps/update_wrapper/total_ordering __doc__ contains checks; new to extra230"
  kind: python_call_eq
  category: doc_inspection
  id_prefix: functoolsextra230docmore

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_doc_contains_wrapper,
       wraps.__doc__.__contains__,
       ["wrapper"],
       true,
       "functools.wraps.__doc__.__contains__('wrapper') == True — wraps docstring is 'Decorator factory to apply update_wrapper() to a wrapper function'; contains 'wrapper'; new to extra230"]
    - [update_wrapper_doc_contains_wrapper,
       update_wrapper.__doc__.__contains__,
       ["wrapper"],
       true,
       "functools.update_wrapper.__doc__.__contains__('wrapper') == True — update_wrapper docstring is 'Update a wrapper function to look like the wrapped function'; contains 'wrapper'; new to extra230"]
    - [total_ordering_doc_contains_ordering,
       total_ordering.__doc__.__contains__,
       ["ordering"],
       true,
       "functools.total_ordering.__doc__.__contains__('ordering') == True — total_ordering docstring is 'Class decorator that fills in missing ordering methods'; contains 'ordering'; new to extra230"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra230
# ---------------------------------------------------------------------------

invariant functools_extra230.module_doc_contains_functools:
  description: "functools.__doc__.__contains__('functools') == True — module docstring is 'functools.py - Tools for working with functions and callable objects'; new to extra230"
  kind: python_call_eq
  function: __doc__.__contains__
  args: ["functools"]
  expected: true

invariant functools_extra230.reduce_doc_contains_function:
  description: "functools.reduce.__doc__.__contains__('function') == True — reduce docstring contains 'function'; new to extra230"
  kind: python_call_eq
  function: reduce.__doc__.__contains__
  args: ["function"]
  expected: true

invariant functools_extra230.partial_doc_contains_partial:
  description: "functools.partial.__doc__.__contains__('partial') == True — partial docstring contains 'partial'; new to extra230"
  kind: python_call_eq
  function: partial.__doc__.__contains__
  args: ["partial"]
  expected: true

invariant functools_extra230.lru_cache_doc_contains_cache:
  description: "functools.lru_cache.__doc__.__contains__('cache') == True — lru_cache docstring contains 'cache'; new to extra230"
  kind: python_call_eq
  function: lru_cache.__doc__.__contains__
  args: ["cache"]
  expected: true

invariant functools_extra230.singledispatch_doc_contains_dispatch:
  description: "functools.singledispatch.__doc__.__contains__('dispatch') == True — singledispatch docstring contains 'dispatch'; new to extra230"
  kind: python_call_eq
  function: singledispatch.__doc__.__contains__
  args: ["dispatch"]
  expected: true

invariant functools_extra230.cached_property_doc_is_none:
  description: "functools.cached_property.__doc__ is None — cached_property has no docstring; new to extra230"
  kind: python_call_eq
  function: cached_property.__doc__.__eq__
  args: [null]
  expected: true

invariant functools_extra230.wraps_doc_contains_wrapper:
  description: "functools.wraps.__doc__.__contains__('wrapper') == True — wraps docstring contains 'wrapper'; new to extra230"
  kind: python_call_eq
  function: wraps.__doc__.__contains__
  args: ["wrapper"]
  expected: true

invariant functools_extra230.update_wrapper_doc_contains_wrapper:
  description: "functools.update_wrapper.__doc__.__contains__('wrapper') == True — update_wrapper docstring contains 'wrapper'; new to extra230"
  kind: python_call_eq
  function: update_wrapper.__doc__.__contains__
  args: ["wrapper"]
  expected: true

invariant functools_extra230.total_ordering_doc_contains_ordering:
  description: "functools.total_ordering.__doc__.__contains__('ordering') == True — total_ordering docstring contains 'ordering'; new to extra230"
  kind: python_call_eq
  function: total_ordering.__doc__.__contains__
  args: ["ordering"]
  expected: true
