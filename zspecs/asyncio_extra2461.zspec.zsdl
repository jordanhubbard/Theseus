  rows:
    - ["as2461-020", asyncio.Task.__dict__.__contains__, ["__len__"],         false]
    - ["as2461-021", asyncio.Task.__dict__.__contains__, ["__length_hint__"], false]

table asyncio_extra2461.Task.method_presence:
  description: "asyncio.Task class __dict__ contains cancel, done, and result"
  kind: python_call_eq
  category: dict_presence
  id_prefix: as2461

  columns: [id, function, args, expected]
  rows:
    - ["as2461-030", asyncio.Task.__dict__.__contains__, ["cancel"], true]
    - ["as2461-031", asyncio.Task.__dict__.__contains__, ["done"],   true]
    - ["as2461-032", asyncio.Task.__dict__.__contains__, ["result"], true]

