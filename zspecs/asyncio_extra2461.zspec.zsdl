# ---------------------------------------------------------------------------
# asyncio.Lock, Event, Semaphore, BoundedSemaphore — sync primitives; no length
# ---------------------------------------------------------------------------

table asyncio_extra2461.sync_primitives.len_protocol:
  description: "asyncio sync primitive classes do NOT contain __len__ or __length_hint__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: as2461

  columns: [id, function, args, expected]
  rows:
    - ["as2461-050", asyncio.Lock.__dict__.__contains__,            ["__len__"],         false]
    - ["as2461-051", asyncio.Lock.__dict__.__contains__,            ["__length_hint__"], false]
    - ["as2461-052", asyncio.Event.__dict__.__contains__,           ["__len__"],         false]
    - ["as2461-053", asyncio.Event.__dict__.__contains__,           ["__length_hint__"], false]
    - ["as2461-054", asyncio.Semaphore.__dict__.__contains__,       ["__len__"],         false]
    - ["as2461-055", asyncio.Semaphore.__dict__.__contains__,       ["__length_hint__"], false]
    - ["as2461-056", asyncio.BoundedSemaphore.__dict__.__contains__, ["__len__"],        false]
    - ["as2461-057", asyncio.BoundedSemaphore.__dict__.__contains__, ["__length_hint__"],false]

table asyncio_extra2461.sync_primitives.method_presence:
  description: "asyncio.Lock has acquire/release; asyncio.Event has wait/is_set/set/clear"
  kind: python_call_eq
  category: dict_presence
  id_prefix: as2461

  columns: [id, function, args, expected]
  rows:
    - ["as2461-060", asyncio.Lock.__dict__.__contains__,  ["acquire"],  true]
    - ["as2461-061", asyncio.Lock.__dict__.__contains__,  ["release"],  true]
    - ["as2461-062", asyncio.Event.__dict__.__contains__,  ["wait"],    true]
    - ["as2461-063", asyncio.Event.__dict__.__contains__,  ["is_set"],  true]
    - ["as2461-064", asyncio.Event.__dict__.__contains__,  ["set"],     true]
    - ["as2461-065", asyncio.Event.__dict__.__contains__,  ["clear"],   true]

