spec: asyncio_extra2461
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio documentation"
    - "Test vectors verified by running Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/tasks.py"
  notes:
    - "Theme: __len__ and __length_hint__ dict-presence — checking whether asyncio classes define the length protocol in their class __dict__."
    - "asyncio.Queue defines qsize() for capacity queries but does NOT define __len__ in its __dict__; it is not a sequence."
    - "asyncio.Queue.__dict__.__contains__('__len__') == False — verified Python 3.14, macOS 2026-04-13."
    - "asyncio.Task, Future, Lock, Event, Semaphore, BoundedSemaphore, Condition, StreamReader, TaskGroup all lack __len__ and __length_hint__."
    - "All expected values verified by running Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Queue — no __len__ or __length_hint__; uses qsize() instead
# ---------------------------------------------------------------------------

table asyncio_extra2461.Queue.len_protocol:
  description: "asyncio.Queue class __dict__ does NOT contain __len__ or __length_hint__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: as2461

  columns: [id, function, args, expected]
  rows:
    - ["as2461-001", asyncio.Queue.__dict__.__contains__, ["__len__"],         false]
    - ["as2461-002", asyncio.Queue.__dict__.__contains__, ["__length_hint__"], false]

table asyncio_extra2461.Queue.method_presence:
  description: "asyncio.Queue class __dict__ contains qsize, put, and get"
  kind: python_call_eq
  category: dict_presence
  id_prefix: as2461

  columns: [id, function, args, expected]
  rows:
    - ["as2461-010", asyncio.Queue.__dict__.__contains__, ["qsize"], true]
    - ["as2461-011", asyncio.Queue.__dict__.__contains__, ["put"],   true]
    - ["as2461-012", asyncio.Queue.__dict__.__contains__, ["get"],   true]

