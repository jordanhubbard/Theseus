spec: pathlib_extra29
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra28.zspec.zsdl — covers __qualname__ for read_text/write_text/resolve/iterdir and Path.is_absolute."
    - "pathlib_extra19.zspec.zsdl — covers Path.home/cwd/stat/open/mkdir/exists __qualname__."
    - "pathlib_extra27.zspec.zsdl — covers __qualname__ equality and lengths for the five main pathlib classes."
  notes:
    - "This spec extends pathlib_extra28.zspec.zsdl."
    - "Focus: __qualname__ for Path filesystem methods stat/chmod/exists/is_file/is_dir/mkdir/rename/unlink/open."
    - "pathlib_extra19 covers stat/open/mkdir/exists __qualname__; this spec extends coverage to chmod/is_file/is_dir/rename/unlink and groups all nine in one table."
    - "Path.stat.__qualname__ == 'Path.stat' — instance method qualname includes class prefix."
    - "Path.chmod.__qualname__ == 'Path.chmod' — instance method qualname includes class prefix."
    - "Path.exists.__qualname__ == 'Path.exists' — instance method qualname includes class prefix."
    - "Path.is_file.__qualname__ == 'Path.is_file' — instance method qualname includes class prefix."
    - "Path.is_dir.__qualname__ == 'Path.is_dir' — instance method qualname includes class prefix."
    - "Path.mkdir.__qualname__ == 'Path.mkdir' — instance method qualname includes class prefix."
    - "Path.rename.__qualname__ == 'Path.rename' — instance method qualname includes class prefix."
    - "Path.unlink.__qualname__ == 'Path.unlink' — instance method qualname includes class prefix."
    - "Path.open.__qualname__ == 'Path.open' — instance method qualname includes class prefix."
    - "No prior pathlib spec covers __qualname__ for chmod/is_file/is_dir/rename/unlink."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __qualname__ for Path filesystem methods
#
# pathlib_extra19 covers stat/open/mkdir/exists. No prior pathlib spec covers
# chmod, is_file, is_dir, rename, or unlink. All nine methods are grouped
# here as a comprehensive filesystem-method qualname table.
# For all, __qualname__ == 'Path.<method_name>'.
# Verified: stat='Path.stat', chmod='Path.chmod', exists='Path.exists',
#   is_file='Path.is_file', is_dir='Path.is_dir', mkdir='Path.mkdir',
#   rename='Path.rename', unlink='Path.unlink', open='Path.open'.
# ---------------------------------------------------------------------------

table pathlib_extra29.path_fs_method_qualnames:
  description: "__qualname__ for Path filesystem methods stat/chmod/exists/is_file/is_dir/mkdir/rename/unlink/open"
  kind: python_call_eq
  category: method_identity
  id_prefix: pfsmq29

  columns: [id, function, args, expected]
  rows:
    - [stat,    Path.stat.__qualname__.__eq__,    ["Path.stat"],    true]
    - [chmod,   Path.chmod.__qualname__.__eq__,   ["Path.chmod"],   true]
    - [exists,  Path.exists.__qualname__.__eq__,  ["Path.exists"],  true]
    - [is_file, "Path.is_file.__qualname__.__eq__", ["Path.is_file"], true]
    - [is_dir,  "Path.is_dir.__qualname__.__eq__",  ["Path.is_dir"],  true]
    - [mkdir,   Path.mkdir.__qualname__.__eq__,   ["Path.mkdir"],   true]
    - [rename,  Path.rename.__qualname__.__eq__,  ["Path.rename"],  true]
    - [unlink,  Path.unlink.__qualname__.__eq__,  ["Path.unlink"],  true]
    - [open,    Path.open.__qualname__.__eq__,    ["Path.open"],    true]

# ---------------------------------------------------------------------------
# Standalone: Path.chmod.__qualname__ — newly covered method
#
# chmod is a filesystem-mutating method defined directly on Path.
# No prior pathlib spec covers Path.chmod.__qualname__.
# Verified: pathlib.Path.chmod.__qualname__ == 'Path.chmod'
# ---------------------------------------------------------------------------

invariant pathlib_extra29.Path.chmod.qualname:
  description: "pathlib.Path.chmod.__qualname__ == 'Path.chmod' — instance method qualname includes the defining class name"
  category: method_identity
  kind: python_call_eq
  function: Path.chmod.__qualname__.__eq__
  args: ["Path.chmod"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: Path.unlink.__qualname__ — newly covered method
#
# unlink removes a file. Defined directly on Path.
# No prior pathlib spec covers Path.unlink.__qualname__.
# Verified: pathlib.Path.unlink.__qualname__ == 'Path.unlink'
# ---------------------------------------------------------------------------

invariant pathlib_extra29.Path.unlink.qualname:
  description: "pathlib.Path.unlink.__qualname__ == 'Path.unlink' — instance method qualname includes the defining class name"
  category: method_identity
  kind: python_call_eq
  function: Path.unlink.__qualname__.__eq__
  args: ["Path.unlink"]
  expected: true
