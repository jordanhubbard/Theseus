spec: numbers_extra9
version: ">=3.0"
backend: python_module(numbers)

docs: https://docs.python.org/3/library/numbers.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/numbers.html — Python numbers documentation"
    - "PEP 3141 — A Type Hierarchy for Numbers"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/numbers.py"
  notes:
    - "This spec extends numbers.zspec.zsdl and prior extras (numbers_extra through numbers_extra8)."
    - "numbers_extra8 covers: Integral MRO[1]-[4]; Number.__dict__ and Complex.__dict__ mappingproxy; Rational: __eq__/__mul__/__rmul__/__pow__/__rpow__ abstract; Real: __truediv__/__rtruediv__/__mul__/__rmul__/__add__/__radd__ abstract."
    - "NEW axis 1: Integral bitwise abstract methods — unique to Integral, not present in Real/Complex."
    - "NEW axis 2: Integral.__int__ abstract — required by the Integral ABC."
    - "NEW axis 3: len() of each class's __abstractmethods__ frozenset — quantifies contract size."
    - "NEW axis 4: Real, Rational, and Integral __dict__ type (mappingproxy) — numbers_extra8 covered only Number and Complex."
    - "Integral.__abstractmethods__ contains all bitwise operators: __and__, __rand__, __or__, __ror__, __xor__, __rxor__, __lshift__, __rlshift__, __rshift__, __rrshift__, __invert__."
    - "Integral.__abstractmethods__ contains __int__ — required for int() conversion."
    - "len(Integral.__abstractmethods__) == 34 — full Integral contract size."
    - "len(Rational.__abstractmethods__) == 24."
    - "len(Real.__abstractmethods__) == 23."
    - "len(Complex.__abstractmethods__) == 16."
    - "Real.__dict__.__class__.__name__ == 'mappingproxy'; same for Rational and Integral."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Integral bitwise abstract methods
#
# Bitwise operators (__and__, __or__, __xor__, __lshift__, __rshift__,
# __invert__ and their reflected forms) are abstract in Integral and absent
# from Real and Complex. They encode the requirement that integer ABCs support
# bit manipulation, which floats and complex numbers cannot.
# numbers_extra6 covers Complex: __add__, __radd__, __sub__, __rsub__.
# numbers_extra8 covers Rational: __eq__, __mul__, __rmul__, __pow__, __rpow__.
# No prior spec covers any Integral-specific bitwise abstract method.
# ---------------------------------------------------------------------------

table numbers_extra9.abstract_methods.integral_bitwise:
  kind: python_call_eq
  category: abstract_methods
  id_prefix: integral_bitwise

  columns: [id, function, args, expected]
  rows:
    - [and,     Integral.__abstractmethods__.__contains__, ["__and__"],     true]
    - [rand,    Integral.__abstractmethods__.__contains__, ["__rand__"],    true]
    - [or,      Integral.__abstractmethods__.__contains__, ["__or__"],      true]
    - [ror,     Integral.__abstractmethods__.__contains__, ["__ror__"],     true]
    - [xor,     Integral.__abstractmethods__.__contains__, ["__xor__"],     true]
    - [rxor,    Integral.__abstractmethods__.__contains__, ["__rxor__"],    true]
    - [lshift,  Integral.__abstractmethods__.__contains__, ["__lshift__"],  true]
    - [rlshift, Integral.__abstractmethods__.__contains__, ["__rlshift__"], true]
    - [rshift,  Integral.__abstractmethods__.__contains__, ["__rshift__"],  true]
    - [rrshift, Integral.__abstractmethods__.__contains__, ["__rrshift__"], true]
    - [invert,  Integral.__abstractmethods__.__contains__, ["__invert__"],  true]

# ---------------------------------------------------------------------------
# Integral.__int__ abstract method
#
# __int__ is required by the Integral ABC to guarantee int() conversion works.
# No prior spec covers this method. It is distinct from the bitwise table above
# because __int__ is also present in Real's abstract methods.
# ---------------------------------------------------------------------------

invariant numbers_extra9.Integral.abstractmethods_int:
  description: "numbers.Integral.__abstractmethods__ contains '__int__' — required for int() conversion"
  category: abstract_methods
  kind: python_call_eq
  function: Integral.__abstractmethods__.__contains__
  args: ["__int__"]
  expected: true

# ---------------------------------------------------------------------------
# __abstractmethods__ frozenset length per class
#
# No prior spec checks the cardinality of each ABC's abstract method set.
# The sizes encode the full contract: Integral inherits all of Rational, Real,
# and Complex (16 Complex + extras + bitwise = 34 total).
# len() is accessed via __len__ since the function field must be a dotted
# attribute chain without call expressions.
# ---------------------------------------------------------------------------

invariant numbers_extra9.Integral.abstractmethods_len:
  description: "len(numbers.Integral.__abstractmethods__) == 34 — full Integral contract"
  category: abstract_methods
  kind: python_call_eq
  function: Integral.__abstractmethods__.__len__
  args: []
  expected: 34

invariant numbers_extra9.Rational.abstractmethods_len:
  description: "len(numbers.Rational.__abstractmethods__) == 24 — Rational contract size"
  category: abstract_methods
  kind: python_call_eq
  function: Rational.__abstractmethods__.__len__
  args: []
  expected: 24

invariant numbers_extra9.Real.abstractmethods_len:
  description: "len(numbers.Real.__abstractmethods__) == 23 — Real contract size"
  category: abstract_methods
  kind: python_call_eq
  function: Real.__abstractmethods__.__len__
  args: []
  expected: 23

invariant numbers_extra9.Complex.abstractmethods_len:
  description: "len(numbers.Complex.__abstractmethods__) == 16 — Complex contract size"
  category: abstract_methods
  kind: python_call_eq
  function: Complex.__abstractmethods__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# Real, Rational, and Integral __dict__ type (mappingproxy)
#
# numbers_extra8 covers Number.__dict__ and Complex.__dict__ as mappingproxy.
# No prior spec covers Real, Rational, or Integral __dict__ type.
# All Python class dicts are mappingproxy instances (read-only view).
# ---------------------------------------------------------------------------

invariant numbers_extra9.Real.dict_type:
  description: "numbers.Real.__dict__.__class__.__name__ == 'mappingproxy' — Real class dict is read-only"
  category: class_dict
  kind: python_call_eq
  function: Real.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant numbers_extra9.Rational.dict_type:
  description: "numbers.Rational.__dict__.__class__.__name__ == 'mappingproxy' — Rational class dict is read-only"
  category: class_dict
  kind: python_call_eq
  function: Rational.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant numbers_extra9.Integral.dict_type:
  description: "numbers.Integral.__dict__.__class__.__name__ == 'mappingproxy' — Integral class dict is read-only"
  category: class_dict
  kind: python_call_eq
  function: Integral.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true
