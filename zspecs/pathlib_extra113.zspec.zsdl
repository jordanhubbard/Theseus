spec: pathlib_extra113
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends pathlib_extra112.zspec.zsdl."
    - "This spec covers: pathlib.Path method __qualname__ strings for file I/O methods and existence/directory-check methods."
    - "type(pathlib.Path.read_text).__name__ == 'function' (pure Python method, not a C extension method_descriptor)."
    - "type(pathlib.Path.exists).__name__ == 'function' (same: pure Python method)."
    - "pathlib.Path.read_text.__qualname__ == 'Path.read_text' (length 14)."
    - "pathlib.Path.write_text.__qualname__ == 'Path.write_text' (length 15)."
    - "pathlib.Path.read_bytes.__qualname__ == 'Path.read_bytes' (length 15)."
    - "pathlib.Path.write_bytes.__qualname__ == 'Path.write_bytes' (length 16)."
    - "pathlib.Path.exists.__qualname__ == 'Path.exists' (length 11)."
    - "pathlib.Path.is_file.__qualname__ == 'Path.is_file' (length 12)."
    - "pathlib.Path.is_dir.__qualname__ == 'Path.is_dir' (length 11)."
    - "pathlib.Path.is_symlink.__qualname__ == 'Path.is_symlink' (length 15)."
    - "pathlib.Path.mkdir.__qualname__ == 'Path.mkdir' (length 10)."
    - "pathlib.Path.rmdir.__qualname__ == 'Path.rmdir' (length 10)."
    - "pathlib.Path.unlink.__qualname__ == 'Path.unlink' (length 11)."
    - "pathlib.Path.rename.__qualname__ == 'Path.rename' (length 11)."
    - "pathlib.Path.open.__qualname__ == 'Path.open' (length 9)."
    - "All qualnames use the 'Path.' prefix (8 chars including dot); method suffix length varies by method name length."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path file I/O method __qualname__ string equality
# read_text, write_text, read_bytes, write_bytes, and open are pure Python
# methods defined in pathlib._local. Their __qualname__ uses the 'Path.' prefix.
# type() is 'function' (not method_descriptor, since they are Python-level).
# Lengths: read_text=14, write_text=15, read_bytes=15, write_bytes=16, open=9.
# ---------------------------------------------------------------------------

table pathlib_extra113.Path_fileio_method_qualnames:
  description: "pathlib.Path file I/O method __qualname__: read_text='Path.read_text'(14), write_text='Path.write_text'(15), read_bytes='Path.read_bytes'(15), write_bytes='Path.write_bytes'(16), open='Path.open'(9); type='function'"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibqn113a

  columns: [id, function, args, expected, description]
  rows:
    - [rdtxt_qn_eq,    "Path.read_text.__qualname__.__eq__",   ["Path.read_text"],   true,  "pathlib.Path.read_text.__qualname__ == 'Path.read_text'"]
    - [rdtxt_qn_len,   "Path.read_text.__qualname__.__len__",  [],                   14,    "pathlib.Path.read_text.__qualname__.__len__() == 14 ('Path.read_text' has 14 chars)"]
    - [wrtxt_qn_eq,    "Path.write_text.__qualname__.__eq__",  ["Path.write_text"],  true,  "pathlib.Path.write_text.__qualname__ == 'Path.write_text'"]
    - [wrtxt_qn_len,   "Path.write_text.__qualname__.__len__", [],                   15,    "pathlib.Path.write_text.__qualname__.__len__() == 15 ('Path.write_text' has 15 chars)"]
    - [rdbyt_qn_eq,    "Path.read_bytes.__qualname__.__eq__",  ["Path.read_bytes"],  true,  "pathlib.Path.read_bytes.__qualname__ == 'Path.read_bytes'"]
    - [rdbyt_qn_len,   "Path.read_bytes.__qualname__.__len__", [],                   15,    "pathlib.Path.read_bytes.__qualname__.__len__() == 15 ('Path.read_bytes' has 15 chars)"]
    - [wrbyt_qn_eq,    "Path.write_bytes.__qualname__.__eq__", ["Path.write_bytes"], true,  "pathlib.Path.write_bytes.__qualname__ == 'Path.write_bytes'"]
    - [wrbyt_qn_len,   "Path.write_bytes.__qualname__.__len__",[], 16, "pathlib.Path.write_bytes.__qualname__.__len__() == 16 ('Path.write_bytes' has 16 chars; longest of the file I/O group)"]
    - [open_qn_eq,     "Path.open.__qualname__.__eq__",        ["Path.open"],        true,  "pathlib.Path.open.__qualname__ == 'Path.open'"]
    - [open_qn_len,    "Path.open.__qualname__.__len__",       [],                   9,     "pathlib.Path.open.__qualname__.__len__() == 9 ('Path.open' has 9 chars; shortest of the file I/O group)"]
    - [rdtxt_type,     "Path.read_text.__class__.__name__.__eq__", ["function"],     true,  "type(pathlib.Path.read_text).__name__ == 'function' (pure Python method, not a C extension method_descriptor)"]

# ---------------------------------------------------------------------------
# pathlib.Path existence check method __qualname__ string equality
# exists, is_file, is_dir, is_symlink are pure Python methods.
# Their __qualname__ uses the 'Path.' prefix.
# Lengths: exists=11, is_file=12, is_dir=11, is_symlink=15.
# ---------------------------------------------------------------------------

table pathlib_extra113.Path_existence_method_qualnames:
  description: "pathlib.Path existence check method __qualname__: exists='Path.exists'(11), is_file='Path.is_file'(12), is_dir='Path.is_dir'(11), is_symlink='Path.is_symlink'(15); type='function'"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibqn113b

  columns: [id, function, args, expected, description]
  rows:
    - [exists_qn_eq,     "Path.exists.__qualname__.__eq__",     ["Path.exists"],     true,  "pathlib.Path.exists.__qualname__ == 'Path.exists'"]
    - [exists_qn_len,    "Path.exists.__qualname__.__len__",    [],                  11,    "pathlib.Path.exists.__qualname__.__len__() == 11 ('Path.exists' has 11 chars)"]
    - [isfile_qn_eq,     "Path.is_file.__qualname__.__eq__",    ["Path.is_file"],    true,  "pathlib.Path.is_file.__qualname__ == 'Path.is_file'"]
    - [isfile_qn_len,    "Path.is_file.__qualname__.__len__",   [],                  12,    "pathlib.Path.is_file.__qualname__.__len__() == 12 ('Path.is_file' has 12 chars)"]
    - [isdir_qn_eq,      "Path.is_dir.__qualname__.__eq__",     ["Path.is_dir"],     true,  "pathlib.Path.is_dir.__qualname__ == 'Path.is_dir'"]
    - [isdir_qn_len,     "Path.is_dir.__qualname__.__len__",    [],                  11,    "pathlib.Path.is_dir.__qualname__.__len__() == 11 ('Path.is_dir' has 11 chars)"]
    - [issymlink_qn_eq,  "Path.is_symlink.__qualname__.__eq__", ["Path.is_symlink"], true,  "pathlib.Path.is_symlink.__qualname__ == 'Path.is_symlink'"]
    - [issymlink_qn_len, "Path.is_symlink.__qualname__.__len__",[], 15, "pathlib.Path.is_symlink.__qualname__.__len__() == 15 ('Path.is_symlink' has 15 chars)"]
    - [exists_type,      "Path.exists.__class__.__name__.__eq__", ["function"],      true,  "type(pathlib.Path.exists).__name__ == 'function' (pure Python method)"]
    - [isfile_ne_isdir,  "Path.is_file.__qualname__.__eq__",    ["Path.is_dir"],     false, "pathlib.Path.is_file.__qualname__ != 'Path.is_dir' (distinct methods for file vs directory check)"]

# ---------------------------------------------------------------------------
# pathlib.Path directory mutation method __qualname__ string equality
# mkdir, rmdir, unlink, rename are pure Python methods for path mutations.
# Their __qualname__ uses the 'Path.' prefix.
# Lengths: mkdir=10, rmdir=10, unlink=11, rename=11.
# ---------------------------------------------------------------------------

table pathlib_extra113.Path_mutation_method_qualnames:
  description: "pathlib.Path directory mutation method __qualname__: mkdir='Path.mkdir'(10), rmdir='Path.rmdir'(10), unlink='Path.unlink'(11), rename='Path.rename'(11); type='function'"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibqn113c

  columns: [id, function, args, expected, description]
  rows:
    - [mkdir_qn_eq,    "Path.mkdir.__qualname__.__eq__",  ["Path.mkdir"],  true,  "pathlib.Path.mkdir.__qualname__ == 'Path.mkdir'"]
    - [mkdir_qn_len,   "Path.mkdir.__qualname__.__len__", [],              10,    "pathlib.Path.mkdir.__qualname__.__len__() == 10 ('Path.mkdir' has 10 chars)"]
    - [rmdir_qn_eq,    "Path.rmdir.__qualname__.__eq__",  ["Path.rmdir"],  true,  "pathlib.Path.rmdir.__qualname__ == 'Path.rmdir'"]
    - [rmdir_qn_len,   "Path.rmdir.__qualname__.__len__", [],              10,    "pathlib.Path.rmdir.__qualname__.__len__() == 10 ('Path.rmdir' has 10 chars; same length as mkdir)"]
    - [unlink_qn_eq,   "Path.unlink.__qualname__.__eq__", ["Path.unlink"], true,  "pathlib.Path.unlink.__qualname__ == 'Path.unlink'"]
    - [unlink_qn_len,  "Path.unlink.__qualname__.__len__",[], 11, "pathlib.Path.unlink.__qualname__.__len__() == 11 ('Path.unlink' has 11 chars)"]
    - [rename_qn_eq,   "Path.rename.__qualname__.__eq__", ["Path.rename"], true,  "pathlib.Path.rename.__qualname__ == 'Path.rename'"]
    - [rename_qn_len,  "Path.rename.__qualname__.__len__",[], 11, "pathlib.Path.rename.__qualname__.__len__() == 11 ('Path.rename' has 11 chars; same length as unlink)"]
    - [mkdir_type,     "Path.mkdir.__class__.__name__.__eq__", ["function"], true, "type(pathlib.Path.mkdir).__name__ == 'function' (pure Python method, not a C extension method_descriptor)"]
    - [mkdir_ne_rmdir, "Path.mkdir.__qualname__.__eq__",  ["Path.rmdir"],  false, "pathlib.Path.mkdir.__qualname__ != 'Path.rmdir' (distinct methods despite equal qualname length)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra113.Path.read_text_qualname:
  description: "pathlib.Path.read_text.__qualname__ == 'Path.read_text' (length 14; pathlib methods are pure Python functions whose __qualname__ uses the simple 'Path.' prefix, not a deeper nesting like 'PurePath.read_text' even though Path inherits from PurePath)"
  category: qualnames
  kind: python_call_eq
  function: "Path.read_text.__qualname__.__eq__"
  args: ["Path.read_text"]
  expected: true

invariant pathlib_extra113.Path.write_bytes_qualname_len:
  description: "pathlib.Path.write_bytes.__qualname__.__len__() == 16 ('Path.write_bytes' is 16 characters; it is the longest qualname among the file I/O methods read_text/write_text/read_bytes/write_bytes/open)"
  category: qualnames
  kind: python_call_eq
  function: "Path.write_bytes.__qualname__.__len__"
  args: []
  expected: 16

invariant pathlib_extra113.Path.read_text_type_function:
  description: "type(pathlib.Path.read_text).__name__ == 'function' (pathlib methods are pure Python functions, in contrast to C extension io types like io.FileIO whose methods are 'method_descriptor' objects)"
  category: qualnames
  kind: python_call_eq
  function: "Path.read_text.__class__.__name__.__eq__"
  args: ["function"]
  expected: true

invariant pathlib_extra113.Path.is_symlink_qualname_len:
  description: "pathlib.Path.is_symlink.__qualname__.__len__() == 15 ('Path.is_symlink' is 15 characters; the longest __qualname__ among the existence check methods exists/is_file/is_dir/is_symlink)"
  category: qualnames
  kind: python_call_eq
  function: "Path.is_symlink.__qualname__.__len__"
  args: []
  expected: 15

invariant pathlib_extra113.Path.open_qualname:
  description: "pathlib.Path.open.__qualname__ == 'Path.open' (length 9; the shortest __qualname__ among the pathlib.Path file I/O methods; type is 'function' since it is a pure Python method)"
  category: qualnames
  kind: python_call_eq
  function: "Path.open.__qualname__.__eq__"
  args: ["Path.open"]
  expected: true
