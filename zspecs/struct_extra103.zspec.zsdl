spec: struct_extra103
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra102.zspec.zsdl — covers struct.calcsize for single-char format codes ('!B','!H','!I','!Q','!b','!h','!i','!q','!f','!d') and two-element composites ('!BH','!IQ') and special codes ('!4s','c','x') (table + invariants)."
    - "struct_extra101.zspec.zsdl — covers struct.error class identity (__name__/__module__/__bases__[0].__name__/__mro__.__len__()==4/__class__.__name__=='type') / Struct class attribute equality / Struct method types (wrapper_descriptor/method_descriptor) and instance size (table + invariants)."
    - "struct_extra100.zspec.zsdl — covers Struct instance method qualname lengths / module-level function qualname lengths / Struct class-level method_descriptor type names (table + invariants)."
    - "struct_extra99.zspec.zsdl — covers module-level function __doc__ lengths / Struct.size/__format__ __doc__ equality and lengths / struct module __doc__ length (table + invariants)."
    - "struct_extra98.zspec.zsdl — covers Struct.size/__format__ getset_descriptor class names and qualnames / descriptor qualname/name lengths and __objclass__.__name__ / Struct.__doc__ length (table + invariants)."
    - "struct_extra95.zspec.zsdl — covers struct.pack_into/unpack_from/iter_unpack __qualname__.__len__() / Struct.__qualname__.__len__()==6 / error.__qualname__.__len__()==5 / module-level function __module__.__eq__('_struct') (table + invariants)."
  notes:
    - "This spec extends struct through struct_extra102; it does NOT duplicate invariants present in those files."
    - "Wave 269 theme: struct.calcsize for three-element compound format strings ('!BHI','!BHQ','!bhi') / two-element float compound ('!fd') / repeat-count formats ('!2I','!3H') / fixed-size string formats ('!16s','!32s','!64s') / struct module attribute checks (__name__,__package__,__spec__,pack.__qualname__)."
    - "struct.calcsize('!BHI') == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('!BHQ') == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('!bhi') == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('!fd') == 12. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('!2I') == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('!3H') == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('!16s') == 16. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('!32s') == 32. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('!64s') == 64. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__name__ == 'struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__package__ == ''. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__spec__.__class__.__name__ == 'ModuleSpec'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__qualname__ == 'pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: '!BHI' = B(1)+H(2)+I(4) = 7 bytes. '!BHQ' = B(1)+H(2)+Q(8) = 11 bytes. '!bhi' = b(1)+h(2)+i(4) = 7 bytes (signed variants have same sizes as unsigned in standard mode). '!fd' = f(4)+d(8) = 12 bytes."
    - "Note: '!2I' uses the repeat count prefix: 2*I(4) = 8 bytes. '!3H' = 3*H(2) = 6 bytes. The repeat count syntax is equivalent to repeating the format char N times."
    - "Note: '!16s'/'!32s'/'!64s' are fixed-size string buffers: 16/32/64 bytes. The count prefix on 's' gives the byte count of the string buffer (not the number of strings). These are commonly used for embedding fixed-size binary strings in protocol messages."
    - "Note: struct.__package__ is '' (empty string, not None) because struct is a top-level built-in module with no package hierarchy. struct.__spec__.__class__.__name__ is 'ModuleSpec' (from importlib.machinery)."
    - "Note: struct.pack.__qualname__ is 'pack' (just the function name, no class prefix) because pack is a module-level function from the _struct C extension."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.calcsize('!BHI')==7 / struct.calcsize('!BHQ')==11
# struct.calcsize('!bhi')==7 / struct.calcsize('!fd')==12
# struct.calcsize('!2I')==8
#
# Wave 269 theme: struct.calcsize for three-element and mixed compound formats.
#
# '!BHI' packs B(1)+H(2)+I(4)=7 bytes — the most common 3-element mix of
# unsigned char, short, int. '!BHQ' = B(1)+H(2)+Q(8)=11 bytes (with a 64-bit
# long long). '!bhi' = b(1)+h(2)+i(4)=7 bytes (signed equivalents, same sizes).
# '!fd' = f(4)+d(8)=12 bytes (float+double). '!2I' uses repeat count: 2*I(4)=8.
# struct_extra102 anchors '!BH'(3) and '!IQ'(12); no prior struct spec anchors
# three-element or repeat-count compound calcsize under structcomp103.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra103.calcsize_three_element_and_mixed:
  description: "calcsize('!BHI')==7 / calcsize('!BHQ')==11 / calcsize('!bhi')==7 / calcsize('!fd')==12 / calcsize('!2I')==8 — three-element '!BHI'=B(1)+H(2)+I(4)=7; '!BHQ'=B(1)+H(2)+Q(8)=11; '!bhi'=b(1)+h(2)+i(4)=7 (signed=same sizes); '!fd'=f(4)+d(8)=12; '!2I'=2*I(4)=8 (repeat count prefix); extra102 anchors '!BH'(3) and '!IQ'(12); no prior spec anchors three-element or repeat-count compound calcsize; first structcomp103 anchor"
  kind: python_call_eq
  category: calcsize
  id_prefix: structcomp103

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_BHI,  "calcsize", ["!BHI"],  7,  "calcsize('!BHI')==7 — B(1)+H(2)+I(4)=7 bytes; common 3-element protocol header format"]
    - [calcsize_BHQ,  "calcsize", ["!BHQ"], 11,  "calcsize('!BHQ')==11 — B(1)+H(2)+Q(8)=11 bytes; includes 64-bit long long field"]
    - [calcsize_bhi,  "calcsize", ["!bhi"],  7,  "calcsize('!bhi')==7 — b(1)+h(2)+i(4)=7 bytes; signed variants have same sizes as unsigned in '!' mode"]
    - [calcsize_fd,   "calcsize", ["!fd"],  12,  "calcsize('!fd')==12 — f(4)+d(8)=12 bytes; single+double float pair"]
    - [calcsize_2I,   "calcsize", ["!2I"],   8,  "calcsize('!2I')==8 — 2*I(4)=8 bytes; repeat count prefix equivalent to repeating 'I' twice"]

# ---------------------------------------------------------------------------
# struct.calcsize('!3H')==6 / struct.calcsize('!16s')==16
# struct.calcsize('!32s')==32 / struct.calcsize('!64s')==64
#
# Wave 269 theme: struct.calcsize for repeat-count and fixed-size string formats.
#
# '!3H' = 3*H(2)=6 bytes (repeat count format). '!16s', '!32s', '!64s' are
# fixed-size string buffers of 16, 32, and 64 bytes — the count prefix on 's'
# gives the byte count, not the repetition count. A fixed-size string of N bytes
# always has calcsize == N, making these trivially verifiable. They are commonly
# used in binary protocol messages for hashes (16=MD5, 32=SHA-256, 64=SHA-512).
# No prior struct spec anchors repeat-count or string-size calcsize values as
# a grouped table under structcomp103.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra103.calcsize_repeat_count_and_string_sizes:
  description: "calcsize('!3H')==6 / calcsize('!16s')==16 / calcsize('!32s')==32 / calcsize('!64s')==64 — '!3H'=3*H(2)=6 bytes (repeat count); '!Ns' is N-byte fixed string buffer (not N repetitions); 16s/32s/64s match MD5/SHA-256/SHA-512 digest sizes; commonly used in binary protocol messages; extra102 anchors '!4s'(4); no prior spec anchors '!3H' or '!16s'/'!32s'/'!64s'; first structcomp103 anchor"
  kind: python_call_eq
  category: calcsize
  id_prefix: structcomp103

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_3H,   "calcsize", ["!3H"],   6,  "calcsize('!3H')==6 — 3*H(2)=6 bytes; repeat count format is equivalent to 'HHH'"]
    - [calcsize_16s,  "calcsize", ["!16s"], 16,  "calcsize('!16s')==16 — 16-byte fixed string buffer (matches MD5 digest size)"]
    - [calcsize_32s,  "calcsize", ["!32s"], 32,  "calcsize('!32s')==32 — 32-byte fixed string buffer (matches SHA-256 digest size)"]
    - [calcsize_64s,  "calcsize", ["!64s"], 64,  "calcsize('!64s')==64 — 64-byte fixed string buffer (matches SHA-512/BLAKE2b digest size)"]

# ---------------------------------------------------------------------------
# struct.__name__.__eq__('struct')
# struct.__package__.__eq__('')
# struct.__spec__.__class__.__name__.__eq__('ModuleSpec')
# struct.pack.__qualname__.__eq__('pack')
#
# Wave 269 theme: struct module identity attributes and pack function qualname.
#
# struct.__name__ is 'struct'. struct.__package__ is '' (empty string; top-level
# C extension module with no package hierarchy). struct.__spec__.__class__.__name__
# is 'ModuleSpec' (from importlib.machinery). struct.pack.__qualname__ is 'pack'
# (module-level function; no class prefix). No prior struct spec anchors these
# module identity attributes as a grouped table under structcomp103.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra103.struct_module_identity_and_pack_qualname:
  description: "struct.__name__.__eq__('struct')==True / struct.__package__.__eq__('')==True / struct.__spec__.__class__.__name__.__eq__('ModuleSpec')==True / struct.pack.__qualname__.__eq__('pack')==True — struct is a top-level C extension module; __package__=='' (empty string, not None); __spec__ is importlib.machinery.ModuleSpec; pack.__qualname__=='pack' (no class prefix for module-level functions); no prior struct spec anchors module identity as group; first structcomp103 anchor"
  kind: python_call_eq
  category: module_attributes
  id_prefix: structcomp103

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_eq,      "__name__.__eq__",                      ["struct"],      true, "struct.__name__ is 'struct' (module name)"]
    - [module_package_eq,   "__package__.__eq__",                   [""],            true, "struct.__package__ is '' (empty string; top-level C extension module, no package hierarchy)"]
    - [module_spec_class,   "__spec__.__class__.__name__.__eq__",   ["ModuleSpec"], true, "struct.__spec__.__class__.__name__ is 'ModuleSpec' (importlib.machinery.ModuleSpec)"]
    - [pack_qualname_eq,    "pack.__qualname__.__eq__",             ["pack"],        true, "struct.pack.__qualname__ is 'pack' (module-level function; no 'ClassName.' prefix)"]

# ---------------------------------------------------------------------------
# struct.calcsize('!BHI')==7 — standalone
#
# struct.calcsize('!BHI') is 7. The format '!BHI' packs an unsigned char (B=1),
# an unsigned short (H=2), and an unsigned int (I=4) in network byte order
# with no alignment padding, giving 1+2+4=7 bytes total. This is a very common
# format for protocol message headers where a 1-byte type field, a 2-byte length
# field, and a 4-byte sequence number or identifier are combined. struct_extra102
# anchors two-element composite '!BH'(3) and '!IQ'(12); no prior struct spec
# anchors '!BHI' as a standalone under structcomp103.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra103.calcsize_BHI_eq_7:
  description: "struct.calcsize('!BHI') == 7 — B(1)+H(2)+I(4)=7 bytes; common protocol header format with type(1)+length(2)+id(4) fields; '!' removes alignment padding; extra102 anchors '!BH'(3) and '!IQ'(12) as two-element composites; first standalone for '!BHI' under structcomp103"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["!BHI"]
  expected: 7

# ---------------------------------------------------------------------------
# struct.calcsize('!BHQ')==11 — standalone
#
# struct.calcsize('!BHQ') is 11. The format '!BHQ' packs an unsigned char (B=1),
# an unsigned short (H=2), and an unsigned long long (Q=8) in network byte order,
# giving 1+2+8=11 bytes. The Q format provides a 64-bit counter or timestamp
# field in a compact protocol message. 11 is an unusual byte count (not a power
# of 2), which underscores that '!' mode gives the exact sum with no padding.
# No prior struct spec anchors '!BHQ' as a standalone under structcomp103.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra103.calcsize_BHQ_eq_11:
  description: "struct.calcsize('!BHQ') == 11 — B(1)+H(2)+Q(8)=11 bytes; 11 is an unusual count demonstrating '!' mode gives exact sum (no power-of-2 rounding); Q provides 64-bit counter or timestamp in compact protocol message; no prior struct spec anchors '!BHQ' as standalone; first standalone under structcomp103"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["!BHQ"]
  expected: 11

# ---------------------------------------------------------------------------
# struct.calcsize('!16s')==16 — standalone
#
# struct.calcsize('!16s') is 16. The '!16s' format packs a 16-byte fixed-size
# bytes buffer in network byte order. The count prefix on 's' gives the byte
# length of the string slot (not the number of 's' repetitions). A 16-byte
# string slot matches the size of an MD5 message digest (128 bits). Fixed-size
# string buffers are commonly used in binary protocols to embed hash digests or
# fixed-size identifiers. struct_extra102 anchors '!4s'(4); no prior struct spec
# anchors '!16s' as a standalone under structcomp103.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra103.calcsize_16s_eq_16:
  description: "struct.calcsize('!16s') == 16 — '!16s' is a 16-byte fixed string buffer; count prefix on 's' gives byte length (not repetitions); 16 bytes matches MD5 digest size (128 bits); commonly used to embed hash digests in binary protocols; extra102 anchors '!4s'(4); first standalone for '!16s' under structcomp103"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["!16s"]
  expected: 16

# ---------------------------------------------------------------------------
# struct.calcsize('!32s')==32 — standalone
#
# struct.calcsize('!32s') is 32. The '!32s' format packs a 32-byte fixed-size
# bytes buffer in network byte order. A 32-byte string slot matches the size of
# a SHA-256 message digest (256 bits) or a UUID (16 bytes padded, though UUIDs
# are more commonly stored as '!16s' or as a pair of Q values). Fixed-size 32-byte
# buffers are very common in cryptographic protocol messages. No prior struct spec
# anchors '!32s' as a standalone under structcomp103.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra103.calcsize_32s_eq_32:
  description: "struct.calcsize('!32s') == 32 — '!32s' is a 32-byte fixed string buffer; 32 bytes matches SHA-256 digest size (256 bits); fixed-size 32-byte buffers are common in cryptographic protocol messages; no prior struct spec anchors '!32s' as standalone; first standalone under structcomp103"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["!32s"]
  expected: 32

# ---------------------------------------------------------------------------
# struct.__package__.__eq__('') — standalone
#
# struct.__package__ is '' (empty string). Top-level C extension modules in
# Python have __package__ set to '' (empty string), not None. This distinguishes
# them from modules that belong to a package (which would have a non-empty
# __package__ like 'hashlib' belonging to no package or 'xml.etree' belonging
# to 'xml'). struct_extra97 anchors struct.__spec__/__loader__ attribute lengths;
# no prior struct spec anchors struct.__package__ equality as a standalone under
# structcomp103. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra103.struct_package_empty:
  description: "struct.__package__.__eq__('') == True — struct.__package__ is '' (empty string); top-level C extension modules have __package__=='' (not None); distinguishes from sub-package modules; extra97 anchors struct.__spec__/__loader__ lengths but not __package__; first standalone under structcomp103"
  category: module_attributes
  kind: python_call_eq
  function: "__package__.__eq__"
  args: [""]
  expected: true
