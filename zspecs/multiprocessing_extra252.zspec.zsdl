spec: multiprocessing_extra252
version: ">=3.8"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.shared_memory.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.shared_memory.html — multiprocessing.shared_memory documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/shared_memory.py"
  notes:
    - "multiprocessing.shared_memory.SharedMemory was added in Python 3.8."
    - "SharedMemory inherits directly from object (no intermediate base class)."
    - "SharedMemory.__module__ == 'multiprocessing.shared_memory'."
    - "Method qualnames follow the 'SharedMemory.<method>' pattern."
    - "SharedMemory.__init__.__qualname__ == 'SharedMemory.__init__'."
    - "ShareableList also inherits directly from object."
    - "ShareableList.__len__.__qualname__ == 'ShareableList.__len__'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SharedMemory — class identity
#
# multiprocessing.shared_memory.SharedMemory is a concrete class added in
# Python 3.8. It inherits from object with no intermediate abstract base.
# The backend receives the submodule as python_module(multiprocessing), and
# SharedMemory is accessed as multiprocessing.shared_memory.SharedMemory.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra252.shared_memory.name:
  description: "SharedMemory.__name__ == 'SharedMemory'"
  category: identity
  kind: python_call_eq
  function: shared_memory.SharedMemory.__name__.__eq__
  args: ["SharedMemory"]
  expected: true

invariant multiprocessing_extra252.shared_memory.module:
  description: "SharedMemory.__module__ == 'multiprocessing.shared_memory'"
  category: identity
  kind: python_call_eq
  function: shared_memory.SharedMemory.__module__.__eq__
  args: ["multiprocessing.shared_memory"]
  expected: true

invariant multiprocessing_extra252.shared_memory.base:
  description: "SharedMemory.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: shared_memory.SharedMemory.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# SharedMemory — method qualnames
#
# close(), unlink(), and __init__() all have qualnames prefixed 'SharedMemory.'
# ---------------------------------------------------------------------------

invariant multiprocessing_extra252.shared_memory.close_qualname:
  description: "SharedMemory.close.__qualname__ == 'SharedMemory.close'"
  category: identity
  kind: python_call_eq
  function: shared_memory.SharedMemory.close.__qualname__.__eq__
  args: ["SharedMemory.close"]
  expected: true

invariant multiprocessing_extra252.shared_memory.unlink_qualname:
  description: "SharedMemory.unlink.__qualname__ == 'SharedMemory.unlink'"
  category: identity
  kind: python_call_eq
  function: shared_memory.SharedMemory.unlink.__qualname__.__eq__
  args: ["SharedMemory.unlink"]
  expected: true

invariant multiprocessing_extra252.shared_memory.init_qualname:
  description: "SharedMemory.__init__.__qualname__ == 'SharedMemory.__init__'"
  category: identity
  kind: python_call_eq
  function: shared_memory.SharedMemory.__init__.__qualname__.__eq__
  args: ["SharedMemory.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# ShareableList — class identity
#
# multiprocessing.shared_memory.ShareableList is a companion class to
# SharedMemory, also added in Python 3.8. It inherits from object.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra252.shareable_list.name:
  description: "ShareableList.__name__ == 'ShareableList'"
  category: identity
  kind: python_call_eq
  function: shared_memory.ShareableList.__name__.__eq__
  args: ["ShareableList"]
  expected: true

invariant multiprocessing_extra252.shareable_list.module:
  description: "ShareableList.__module__ == 'multiprocessing.shared_memory'"
  category: identity
  kind: python_call_eq
  function: shared_memory.ShareableList.__module__.__eq__
  args: ["multiprocessing.shared_memory"]
  expected: true

invariant multiprocessing_extra252.shareable_list.base:
  description: "ShareableList.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: shared_memory.ShareableList.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant multiprocessing_extra252.shareable_list.len_qualname:
  description: "ShareableList.__len__.__qualname__ == 'ShareableList.__len__'"
  category: identity
  kind: python_call_eq
  function: shared_memory.ShareableList.__len__.__qualname__.__eq__
  args: ["ShareableList.__len__"]
  expected: true
