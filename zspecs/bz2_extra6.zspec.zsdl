spec: bz2_extra6
version: ">=3.9"
backend: python_module(bz2)

docs: https://docs.python.org/3/library/bz2.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bz2.html — Python bz2 documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_bz2module.c"
    - "CPython source: Lib/bz2.py"
  notes:
    - "This spec extends bz2.zspec.zsdl and prior extras."
    - "bz2 (base) covers: class_names, module_checks, function_names tables, compress magic bytes, compress nonempty output, BZ2Compressor/BZ2Decompressor is_type, BZ2Decompressor.eof initially false."
    - "bz2_extra covers: BZ2File/BZ2Compressor/BZ2Decompressor __name__/__module__, compress/decompress/open __name__, compress returns bytes (method_chain)."
    - "bz2_extra2 covers: compress/decompress/open __module__ table, BZ2Compressor/BZ2Decompressor instance method names, BZ2File method names, base class checks, class_is_type checks."
    - "bz2_extra3 covers: BZ2File/__name__, BZ2Compressor/__name__, BZ2Decompressor/__name__, compress/decompress/open __name__ table, BZ2File/__module__, BZ2Compressor/__module__, compress returns bytes (method_chain on b'hello'), compress magic B/Z, compress/__module__, decompress/__module__."
    - "bz2_extra4 covers: BZ2File/BZ2Compressor/BZ2Decompressor __qualname__ table, open/compress/decompress __qualname__ table, compress(b'') class name (method_chain), BZ2File.__qualname__ is str, compress(b'') nonempty output."
    - "bz2_extra5 covers: BZ2File/BZ2Compressor/BZ2Decompressor __name__ table (cn5), BZ2File.__module__ table, BZ2File.__qualname__ standalone, open.__name__ standalone, BZ2File.__bases__[0].__name__ == 'BaseStream' (bool form)."
    - "This spec adds: BZ2Compressor.__module__ == '_bz2' and BZ2Decompressor.__module__ == '_bz2' (C extension module — distinct from 'bz2' Python module; not in any prior spec), BZ2Compressor.__bases__[0].__name__ == 'object' and BZ2Decompressor.__bases__[0].__name__ == 'object' (C extension types are direct subclasses of object; not in any prior spec), compress/decompress/open __code__.co_name table (not in any prior bz2 spec), BZ2Decompressor().needs_input == True (not in any prior bz2 spec), BZ2Decompressor().unused_data == b'' (not in any prior bz2 spec), BZ2Compressor.__qualname__.__class__.__name__ == 'str' (qualname type sanity for Compressor — bz2_extra4 checks BZ2File; this is new for BZ2Compressor)."
    - "bz2.BZ2Compressor.__module__ == '_bz2' — the type is defined in the C extension _bz2, not in Lib/bz2.py."
    - "bz2.BZ2Decompressor.__module__ == '_bz2' — same as BZ2Compressor."
    - "bz2.BZ2Compressor.__bases__[0].__name__ == 'object' — C extension types inherit directly from object."
    - "bz2.BZ2Decompressor.__bases__[0].__name__ == 'object' — same as BZ2Compressor."
    - "bz2.BZ2Decompressor().needs_input == True — True initially because no data has been fed yet."
    - "bz2.BZ2Decompressor().unused_data == b'' — empty bytes initially."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BZ2Compressor.__module__ and BZ2Decompressor.__module__ == '_bz2'
# These types are defined in the C extension _bz2, not the pure-Python bz2 module.
# bz2_extra (and others) check BZ2File.__module__ == 'bz2' and
# bz2_extra3 checks BZ2Compressor.__module__ — but NOT the '_bz2' string value
# for BZ2Decompressor. This table captures both C-extension module names.
# ---------------------------------------------------------------------------

table bz2_extra6.c_extension_modules:
  kind: python_call_eq
  category: module_affiliation
  id_prefix: cmod6

  columns: [id, function, args, expected]
  rows:
    - [BZ2Compressor,   BZ2Compressor.__module__.__eq__,   ["_bz2"], true]
    - [BZ2Decompressor, BZ2Decompressor.__module__.__eq__, ["_bz2"], true]

# ---------------------------------------------------------------------------
# BZ2Compressor and BZ2Decompressor base class — both are direct subclasses
# of object (C extension types). Not covered in any prior bz2 spec.
# ---------------------------------------------------------------------------

invariant bz2_extra6.BZ2Compressor.base_name:
  description: "bz2.BZ2Compressor.__bases__[0].__name__ == 'object' — C extension type, direct subclass of object"
  category: hierarchy
  kind: python_call_eq
  function: BZ2Compressor.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant bz2_extra6.BZ2Decompressor.base_name:
  description: "bz2.BZ2Decompressor.__bases__[0].__name__ == 'object' — C extension type, direct subclass of object"
  category: hierarchy
  kind: python_call_eq
  function: BZ2Decompressor.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# __code__.co_name for compress, decompress, open — not in any prior bz2 spec.
# co_name is the function name stored in the bytecode code object.
# ---------------------------------------------------------------------------

table bz2_extra6.function_co_names:
  kind: python_call_eq
  category: code_objects
  id_prefix: co_name

  columns: [id, function, args, expected]
  rows:
    - [compress,   compress.__code__.co_name.__eq__,   ["compress"],   true]
    - [decompress, decompress.__code__.co_name.__eq__, ["decompress"], true]
    - [open,       open.__code__.co_name.__eq__,       ["open"],       true]

# ---------------------------------------------------------------------------
# BZ2Decompressor().needs_input — True initially; not in any prior bz2 spec.
# needs_input is True when the decompressor is ready to accept more input.
# ---------------------------------------------------------------------------

invariant bz2_extra6.BZ2Decompressor.needs_input_initially_true:
  description: "bz2.BZ2Decompressor().needs_input == True — initially True, no data fed yet"
  category: decompressor
  kind: python_call_eq
  function: BZ2Decompressor
  args: []
  method: needs_input.__eq__
  method_args: [true]
  expected: true

# ---------------------------------------------------------------------------
# BZ2Decompressor().unused_data — b'' initially; not in any prior bz2 spec.
# unused_data holds any trailing bytes after the compressed stream ends.
# ---------------------------------------------------------------------------

invariant bz2_extra6.BZ2Decompressor.unused_data_initially_empty:
  description: "bz2.BZ2Decompressor().unused_data == b'' — initially empty bytes"
  category: decompressor
  kind: python_call_eq
  function: BZ2Decompressor
  args: []
  method: unused_data.__eq__
  method_args: [!hex ""]
  expected: true

# ---------------------------------------------------------------------------
# BZ2Compressor.__qualname__.__class__.__name__ == 'str'
# bz2_extra4 checks BZ2File.__qualname__ is str; this is the first bz2 spec
# to verify the same property for BZ2Compressor (new vector).
# ---------------------------------------------------------------------------

invariant bz2_extra6.BZ2Compressor.qualname_is_str:
  description: "bz2.BZ2Compressor.__qualname__.__class__.__name__ == 'str' — __qualname__ is always a str"
  category: qualnames
  kind: python_call_eq
  function: BZ2Compressor.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
