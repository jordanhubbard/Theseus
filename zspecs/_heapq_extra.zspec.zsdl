spec: _heapq_extra
version: ">=3.9"
backend: python_module(_heapq)

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/heapq.html — Python heapq module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_heapqmodule.c"
  notes:
    - "This spec extends _heapq.zspec.zsdl, heapq_extra.zspec.zsdl, and heapq_extra2.zspec.zsdl."
    - "The _heapq module is the C accelerator for the heapq stdlib module."
    - "_heapq.heappush.__name__ == 'heappush'; all public functions report their simple unqualified name."
    - "_heapq._heapify_max is an internal C function exposed on the module; it exists in CPython >= 3.x."
    - "_heapq._heapify_max.__name__ == '_heapify_max' — the leading underscore is preserved in __name__."
    - "_heapq functions report __module__ == '_heapq' on CPython 3.12 (verified)."
    - "nlargest and nsmallest accept any iterable; they return a new list and never mutate the input."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ — public API functions of _heapq
# ---------------------------------------------------------------------------

invariant _heapq_extra.heappush.name:
  description: "_heapq.heappush.__name__ == 'heappush'"
  category: identity
  kind: python_call_eq
  function: heappush.__name__.__eq__
  args: ["heappush"]
  expected: true

invariant _heapq_extra.heappop.name:
  description: "_heapq.heappop.__name__ == 'heappop'"
  category: identity
  kind: python_call_eq
  function: heappop.__name__.__eq__
  args: ["heappop"]
  expected: true

invariant _heapq_extra.heapify.name:
  description: "_heapq.heapify.__name__ == 'heapify'"
  category: identity
  kind: python_call_eq
  function: heapify.__name__.__eq__
  args: ["heapify"]
  expected: true

invariant _heapq_extra.nlargest.name:
  description: "_heapq.nlargest.__name__ == 'nlargest'"
  category: identity
  kind: python_call_eq
  function: nlargest.__name__.__eq__
  args: ["nlargest"]
  expected: true

invariant _heapq_extra.nsmallest.name:
  description: "_heapq.nsmallest.__name__ == 'nsmallest'"
  category: identity
  kind: python_call_eq
  function: nsmallest.__name__.__eq__
  args: ["nsmallest"]
  expected: true

# ---------------------------------------------------------------------------
# _heapify_max — internal C function exposed on the module
# ---------------------------------------------------------------------------

invariant _heapq_extra._heapify_max.name:
  description: "_heapq._heapify_max.__name__ == '_heapify_max' — underscore prefix preserved"
  category: identity
  kind: python_call_eq
  function: _heapify_max.__name__.__eq__
  args: ["_heapify_max"]
  expected: true

invariant _heapq_extra._heapify_max.module:
  description: "_heapq._heapify_max.__module__ == '_heapq'"
  category: identity
  kind: python_call_eq
  function: _heapify_max.__module__.__eq__
  args: ["_heapq"]
  expected: true

invariant _heapq_extra._heapify_max.returns_none:
  description: "_heapq._heapify_max([5, 3, 1]) returns None — modifies list in-place (max-heap)"
  category: behavioral
  kind: python_call_eq
  function: _heapify_max
  args: [[5, 3, 1]]
  expected: ~

# ---------------------------------------------------------------------------
# Module affiliation — all public functions report __module__ == '_heapq'
# ---------------------------------------------------------------------------

table _heapq_extra.function_modules:
  kind: python_call_eq
  category: identity
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [heappush,    heappush.__module__.__eq__,    ["_heapq"], true]
    - [heappop,     heappop.__module__.__eq__,     ["_heapq"], true]
    - [heapify,     heapify.__module__.__eq__,     ["_heapq"], true]
    - [nlargest,    nlargest.__module__.__eq__,    ["_heapq"], true]
    - [nsmallest,   nsmallest.__module__.__eq__,   ["_heapq"], true]

# ---------------------------------------------------------------------------
# Behavioral — nlargest / nsmallest from _heapq directly
# ---------------------------------------------------------------------------

invariant _heapq_extra.nlargest.all_elements:
  description: "_heapq.nlargest(5, [3,1,4,1,5,9,2,6]) == [9,6,5,4,3] — five largest descending"
  category: behavioral
  kind: python_call_eq
  function: nlargest
  args: [5, [3, 1, 4, 1, 5, 9, 2, 6]]
  expected: [9, 6, 5, 4, 3]

invariant _heapq_extra.nsmallest.all_elements:
  description: "_heapq.nsmallest(4, [3,1,4,1,5,9,2,6]) == [1,1,2,3] — four smallest ascending"
  category: behavioral
  kind: python_call_eq
  function: nsmallest
  args: [4, [3, 1, 4, 1, 5, 9, 2, 6]]
  expected: [1, 1, 2, 3]

invariant _heapq_extra.nlargest.empty_list:
  description: "_heapq.nlargest(3, []) == [] — nlargest of empty iterable is empty list"
  category: behavioral
  kind: python_call_eq
  function: nlargest
  args: [3, []]
  expected: []

invariant _heapq_extra.nsmallest.empty_list:
  description: "_heapq.nsmallest(3, []) == [] — nsmallest of empty iterable is empty list"
  category: behavioral
  kind: python_call_eq
  function: nsmallest
  args: [3, []]
  expected: []

invariant _heapq_extra.nlargest.n_exceeds_length:
  description: "_heapq.nlargest(10, [2, 1, 3]) == [3, 2, 1] — n > len(iterable) returns all elements sorted"
  category: behavioral
  kind: python_call_eq
  function: nlargest
  args: [10, [2, 1, 3]]
  expected: [3, 2, 1]
