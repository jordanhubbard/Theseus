spec: signal_extra17
version: ">=3.9"
backend: python_module(signal)

docs: https://docs.python.org/3/library/signal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/signal.html — Python signal module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/signalmodule.c"
  notes:
    - "This spec extends signal_extra16.zspec.zsdl."
    - "signal_extra16 covers: Signals/Handlers __mro__.__len__()==6; Signals/Handlers __bases__[0].__name__=='IntEnum'; SIGTERM/SIGINT/SIG_DFL __class__.__name__; Signals._member_names_.__len__()==31; SIGINT.value==2; SIGTERM.value==15."
    - "signal_extra15 covers: alarm/__name__/__module__.__len__(); pause/__module__.__len__(); set_wakeup_fd/__module__/__name__.__len__(); function __name__.__len__() for signal/getsignal/raise_signal/strsignal/valid_signals; Signals/Handlers __module__.__len__()."
    - "signal has no __all__ attribute — hasattr(signal, '__all__') is False. No list-length invariant is possible."
    - "No prior spec covers: signal.Signals.__dict__.__class__.__name__.__len__() == 12 — __dict__ is a mappingproxy."
    - "No prior spec covers: signal.Handlers.__dict__.__class__.__name__.__len__() == 12 — same mappingproxy pattern."
    - "No prior spec covers: signal.SIG_IGN.__class__.__name__.__len__() == 8 — 'Handlers' has 8 characters."
    - "No prior spec covers: signal.NSIG.__class__.__name__.__len__() == 3 — NSIG is an int; 'int' has 3 characters."
    - "No prior spec covers: signal.NSIG == 32 — NSIG is the number of signals + 1 on macOS/Darwin."
    - "No prior spec covers: signal.Signals.__mro__[1].__name__ == 'IntEnum' — MRO index 1 is IntEnum."
    - "No prior spec covers: signal.Signals.__mro__[2].__name__ == 'int' — MRO index 2 is int."
    - "No prior spec covers: signal.Handlers.__mro__[1].__name__ == 'IntEnum' — MRO index 1 is IntEnum."
    - "No prior spec covers: signal.Handlers.__mro__[2].__name__ == 'int' — MRO index 2 is int."
    - "No prior spec covers: signal.SIGINT.name.__len__() == 6 — 'SIGINT' has 6 characters."
    - "No prior spec covers: signal.SIGTERM.name.__len__() == 7 — 'SIGTERM' has 7 characters."
    - "No prior spec covers: signal.SIGHUP.value == 1 — SIGHUP is hang-up signal, POSIX value 1."
    - "No prior spec covers: signal.SIGKILL.value == 9 — SIGKILL is kill signal, POSIX value 9."
    - "No prior spec covers: signal.alarm.__qualname__.__len__() == 5 — extra15 covers alarm/__name__ but not __qualname__.__len__()."
    - "No prior spec covers: signal.raise_signal.__qualname__.__len__() == 12 — extra13/extra14 cover raise_signal qualname string but not its length."
    - "Verified: Signals/Handlers __dict__.__class__.__name__ == 'mappingproxy'; len == 12."
    - "Verified: SIG_IGN.__class__.__name__ == 'Handlers'; len == 8."
    - "Verified: NSIG.__class__.__name__ == 'int'; len == 3; NSIG == 32."
    - "Verified: Signals.__mro__[1].__name__ == 'IntEnum'; Signals.__mro__[2].__name__ == 'int'."
    - "Verified: Handlers.__mro__[1].__name__ == 'IntEnum'; Handlers.__mro__[2].__name__ == 'int'."
    - "Verified: SIGINT.name == 'SIGINT' (len 6); SIGTERM.name == 'SIGTERM' (len 7)."
    - "Verified: SIGHUP.value == 1; SIGKILL.value == 9."
    - "Verified: alarm.__qualname__ == 'alarm' (len 5); raise_signal.__qualname__ == 'raise_signal' (len 12)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Signals and Handlers __dict__.__class__.__name__.__len__() == 12
#
# All Python classes store their namespace in a mappingproxy object.
# len('mappingproxy') == 12. No prior signal spec checks this on Signals or
# Handlers.
# ---------------------------------------------------------------------------

table signal_extra17.dict_class_name_len:
  description: "Signals/Handlers __dict__.__class__.__name__.__len__() == 12 — both are mappingproxy"
  kind: python_call_eq
  category: class_attrs
  id_prefix: dcnlen17

  columns: [id, function, args, expected]
  rows:
    - [Signals,  Signals.__dict__.__class__.__name__.__len__,  [], 12]
    - [Handlers, Handlers.__dict__.__class__.__name__.__len__, [], 12]

# ---------------------------------------------------------------------------
# SIG_IGN and NSIG class name lengths
#
# signal_extra16 covers SIG_DFL.__class__.__name__ == 'Handlers' (8 chars) and
# SIGINT/SIGTERM __class__.__name__ == 'Signals' (7 chars). No prior spec
# checks SIG_IGN.__class__.__name__.__len__() or NSIG.__class__.__name__.__len__().
# SIG_IGN.__class__.__name__ == 'Handlers' (len 8).
# NSIG.__class__.__name__ == 'int' (len 3); NSIG == 32 on macOS/Darwin.
# ---------------------------------------------------------------------------

invariant signal_extra17.SIG_IGN.class_name_len:
  description: "signal.SIG_IGN.__class__.__name__.__len__() == 8 — SIG_IGN is a Handlers member; 'Handlers' has 8 characters"
  category: enum_membership
  kind: python_call_eq
  function: SIG_IGN.__class__.__name__.__len__
  args: []
  expected: 8

invariant signal_extra17.NSIG.class_name_len:
  description: "signal.NSIG.__class__.__name__.__len__() == 3 — NSIG is an int; 'int' has 3 characters"
  category: constants
  kind: python_call_eq
  function: NSIG.__class__.__name__.__len__
  args: []
  expected: 3

invariant signal_extra17.NSIG.value:
  description: "signal.NSIG == 32 — NSIG is the number of signal slots on macOS/Darwin (POSIX value 32)"
  category: constants
  kind: python_call_eq
  function: NSIG.__eq__
  args: [32]
  expected: true

# ---------------------------------------------------------------------------
# Signals and Handlers MRO index 1 and index 2
#
# signal_extra16 covers Signals/Handlers __mro__.__len__() == 6 and
# __bases__[0].__name__ == 'IntEnum'. No prior spec checks MRO entries at
# specific indices for Signals or Handlers.
# MRO: Signals -> IntEnum -> int -> ReprEnum -> Enum -> object
# Index 1 == IntEnum, index 2 == int.
# Function paths contain '[' and MUST be quoted.
# ---------------------------------------------------------------------------

table signal_extra17.enum_mro_entries:
  description: "Signals/Handlers __mro__[1].__name__ == 'IntEnum' and __mro__[2].__name__ == 'int' — MRO indices 1 and 2"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: mroent17

  columns: [id, function, args, method, expected]
  rows:
    - [Signals_mro1,  "Signals.__mro__.__getitem__",  [1], __name__, "IntEnum"]
    - [Signals_mro2,  "Signals.__mro__.__getitem__",  [2], __name__, "int"]
    - [Handlers_mro1, "Handlers.__mro__.__getitem__", [1], __name__, "IntEnum"]
    - [Handlers_mro2, "Handlers.__mro__.__getitem__", [2], __name__, "int"]

# ---------------------------------------------------------------------------
# SIGINT and SIGTERM .name attribute lengths
#
# Enum members have a .name attribute returning their string name. No prior
# signal spec checks .name.__len__() for any signal constant. SIGINT.name ==
# 'SIGINT' (len 6); SIGTERM.name == 'SIGTERM' (len 7).
# ---------------------------------------------------------------------------

invariant signal_extra17.SIGINT.name_len:
  description: "signal.SIGINT.name.__len__() == 6 — SIGINT.name == 'SIGINT'; 'SIGINT' has 6 characters"
  category: enum_membership
  kind: python_call_eq
  function: SIGINT.name.__len__
  args: []
  expected: 6

invariant signal_extra17.SIGTERM.name_len:
  description: "signal.SIGTERM.name.__len__() == 7 — SIGTERM.name == 'SIGTERM'; 'SIGTERM' has 7 characters"
  category: enum_membership
  kind: python_call_eq
  function: SIGTERM.name.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# SIGHUP and SIGKILL values
#
# signal_extra16 covers SIGINT.value==2 and SIGTERM.value==15. No prior signal
# spec checks SIGHUP.value or SIGKILL.value via the .value attribute.
# SIGHUP == 1 (hang-up, POSIX); SIGKILL == 9 (kill, POSIX).
# ---------------------------------------------------------------------------

invariant signal_extra17.SIGHUP.value:
  description: "signal.SIGHUP.value.__eq__(1) — SIGHUP is hang-up signal, POSIX value 1"
  category: signal_values
  kind: python_call_eq
  function: SIGHUP.value.__eq__
  args: [1]
  expected: true

invariant signal_extra17.SIGKILL.value:
  description: "signal.SIGKILL.value.__eq__(9) — SIGKILL is kill signal, POSIX value 9"
  category: signal_values
  kind: python_call_eq
  function: SIGKILL.value.__eq__
  args: [9]
  expected: true

# ---------------------------------------------------------------------------
# alarm and raise_signal __qualname__.__len__()
#
# signal_extra15 covers alarm.__name__ == 'alarm' and alarm.__module__.__len__()==6.
# signal_extra13/extra14 cover raise_signal.__qualname__ == 'raise_signal' (string).
# No prior spec checks alarm.__qualname__.__len__() or raise_signal.__qualname__.__len__().
# alarm.__qualname__ == 'alarm' (len 5); raise_signal.__qualname__ == 'raise_signal' (len 12).
# ---------------------------------------------------------------------------

invariant signal_extra17.alarm.qualname_len:
  description: "signal.alarm.__qualname__.__len__() == 5 — 'alarm' has 5 characters; extra15 covers __name__ but not __qualname__.__len__()"
  category: function_attrs
  kind: python_call_eq
  function: alarm.__qualname__.__len__
  args: []
  expected: 5

invariant signal_extra17.raise_signal.qualname_len:
  description: "signal.raise_signal.__qualname__.__len__() == 12 — 'raise_signal' has 12 characters; no prior spec checks this length"
  category: function_attrs
  kind: python_call_eq
  function: raise_signal.__qualname__.__len__
  args: []
  expected: 12
