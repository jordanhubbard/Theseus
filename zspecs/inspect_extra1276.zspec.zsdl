spec: inspect_extra1276
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Wave 532 _extra1276: checks __subclasses__(), __mro__, and __bases__ type names for inspect.Parameter, inspect.Signature, inspect.BoundArguments, inspect.FrameInfo, inspect.FullArgSpec, inspect.ArgInfo, inspect.Attribute"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra1276.parameter_signature_inheritance_types:
  description: "inspect.Parameter and inspect.Signature __subclasses__, __mro__, and __bases__ type name checks"
  kind: python_call_eq
  category: parameter_signature_inheritance_types
  id_prefix: in1276ps
  columns: [id, function, args, expected]
  rows:
    - [in1276ps001, inspect.Parameter.__subclasses__().__class__.__name__.__eq__, ["list"],  true]
    - [in1276ps002, inspect.Parameter.__mro__.__class__.__name__.__eq__,          ["tuple"], true]
    - [in1276ps003, inspect.Parameter.__bases__.__class__.__name__.__eq__,        ["tuple"], true]
    - [in1276ps004, inspect.Signature.__subclasses__().__class__.__name__.__eq__, ["list"],  true]
    - [in1276ps005, inspect.Signature.__mro__.__class__.__name__.__eq__,          ["tuple"], true]
    - [in1276ps006, inspect.Signature.__bases__.__class__.__name__.__eq__,        ["tuple"], true]
    - [in1276ps007, inspect.Parameter.__class__.__name__.__eq__,                  ["type"],  true]
    - [in1276ps008, inspect.Signature.__class__.__name__.__eq__,                  ["type"],  true]

