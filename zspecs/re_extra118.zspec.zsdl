spec: re_extra118
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec extends re_extra117.zspec.zsdl."
    - "This spec covers: re.RegexFlag MRO slot names (indexed) and re.PatternError MRO slot names (indexed), not previously covered."
    - "re.RegexFlag.__mro__ has 7 entries: (RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object)."
    - "re_extra101 and re_extra109 covered RegexFlag.__mro__.__len__()==7 but NOT individual slot names by bracket notation."
    - "re.PatternError.__mro__ has 4 entries: (PatternError, Exception, BaseException, object)."
    - "re_extra108 covered PatternError.__mro__.__len__()==4 but NOT individual slot names by bracket notation."
    - "No prior re_extra spec has used double-quoted bracket-path notation to index into RegexFlag.__mro__ or PatternError.__mro__."
    - "re.RegexFlag.__mro__[1].__name__ == 'IntFlag' (len 7); RegexFlag extends IntFlag from the enum module."
    - "re.RegexFlag.__mro__[2].__name__ == 'int' (len 3); int is the numeric base for all IntFlag members."
    - "re.RegexFlag.__mro__[3].__name__ == 'ReprEnum' (len 8); provides repr customization for IntFlag."
    - "re.RegexFlag.__mro__[4].__name__ == 'Flag' (len 4); Flag is the base for all flag enums."
    - "re.RegexFlag.__mro__[5].__name__ == 'Enum' (len 4); root enum base class."
    - "re.RegexFlag.__mro__[6].__name__ == 'object' (len 6); universal Python base class."
    - "re.PatternError.__mro__[1].__name__ == 'Exception' (len 9); PatternError is a direct subclass of Exception."
    - "re.PatternError.__mro__[2].__name__ == 'BaseException' (len 13); root exception base."
    - "re.PatternError.__mro__[3].__name__ == 'object' (len 6); universal Python base class."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.RegexFlag MRO slot names (indexed bracket notation)
# RegexFlag.__mro__ == (RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object) — 7 entries.
# RegexFlag is an IntFlag subclass: each flag constant is simultaneously a
# RegexFlag enum member and a plain integer, enabling bitwise OR combination.
# re_extra101 and re_extra109 covered __mro__.__len__()==7 and __bases__[0].__name__=='IntFlag',
# but no prior spec has accessed individual MRO slots by bracket notation.
# The 7-entry MRO reflects the full IntFlag inheritance chain through the enum module.
# ---------------------------------------------------------------------------

table re_extra118.RegexFlag_mro_slot_names:
  description: "re.RegexFlag.__mro__ slot names: [0]='RegexFlag'(9),[1]='IntFlag'(7),[2]='int'(3),[3]='ReprEnum'(8),[4]='Flag'(4),[5]='Enum'(4),[6]='object'(6); 7-entry MRO; IntFlag subclass enabling bitwise flag combination"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: rerfmro118a

  columns: [id, function, args, expected, description]
  rows:
    - [rf_mro0_name,  "RegexFlag.__mro__[0].__name__.__eq__",  ["RegexFlag"],  true,  "re.RegexFlag.__mro__[0].__name__ == 'RegexFlag' (the class itself is first in its own MRO; the IntFlag enum for regex compilation flags)"]
    - [rf_mro1_name,  "RegexFlag.__mro__[1].__name__.__eq__",  ["IntFlag"],    true,  "re.RegexFlag.__mro__[1].__name__ == 'IntFlag' (direct parent; makes each flag constant simultaneously an int and an enum member)"]
    - [rf_mro2_name,  "RegexFlag.__mro__[2].__name__.__eq__",  ["int"],        true,  "re.RegexFlag.__mro__[2].__name__ == 'int' (integer base class; enables flag constants to be used directly in integer contexts)"]
    - [rf_mro3_name,  "RegexFlag.__mro__[3].__name__.__eq__",  ["ReprEnum"],   true,  "re.RegexFlag.__mro__[3].__name__ == 'ReprEnum' (mixin at slot 3; customizes repr output to show the integer value rather than enum formatting)"]
    - [rf_mro4_name,  "RegexFlag.__mro__[4].__name__.__eq__",  ["Flag"],       true,  "re.RegexFlag.__mro__[4].__name__ == 'Flag' (base class for all flag enums; supports bitwise OR composition of flag members)"]
    - [rf_mro5_name,  "RegexFlag.__mro__[5].__name__.__eq__",  ["Enum"],       true,  "re.RegexFlag.__mro__[5].__name__ == 'Enum' (root enum base class; provides the enum machinery — iteration, membership, name lookup)"]
    - [rf_mro6_name,  "RegexFlag.__mro__[6].__name__.__eq__",  ["object"],     true,  "re.RegexFlag.__mro__[6].__name__ == 'object' (universal Python base class terminates the 7-entry MRO at slot 6)"]
    - [rf_mro1_len,   "RegexFlag.__mro__[1].__name__.__len__", [],             7,     "re.RegexFlag.__mro__[1].__name__.__len__() == 7 ('IntFlag' has 7 characters: 'Int'(3)+'Flag'(4)==7)"]

# ---------------------------------------------------------------------------
# re.PatternError MRO slot names (indexed bracket notation)
# PatternError.__mro__ == (PatternError, Exception, BaseException, object) — 4 entries.
# PatternError (formerly re.error, renamed in Python 3.13) is a direct subclass
# of Exception. Its MRO includes the full exception hierarchy.
# re_extra108 covered __mro__.__len__()==4 and __bases__[0].__name__=='Exception',
# but no prior spec has indexed individual PatternError.__mro__ slots by bracket notation.
# ---------------------------------------------------------------------------

table re_extra118.PatternError_mro_slot_names:
  description: "re.PatternError.__mro__ slot names: [0]='PatternError'(12),[1]='Exception'(9),[2]='BaseException'(13),[3]='object'(6); 4-entry MRO; renamed from 're.error' in Python 3.13"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: reperrrmro118b

  columns: [id, function, args, expected, description]
  rows:
    - [pe_mro0_name,  "PatternError.__mro__[0].__name__.__eq__",  ["PatternError"],   true,  "re.PatternError.__mro__[0].__name__ == 'PatternError' (12 chars; renamed from 're.error' in Python 3.13; re.error is now an alias)"]
    - [pe_mro1_name,  "PatternError.__mro__[1].__name__.__eq__",  ["Exception"],      true,  "re.PatternError.__mro__[1].__name__ == 'Exception' (9 chars; PatternError is a direct subclass of Exception at MRO slot 1)"]
    - [pe_mro2_name,  "PatternError.__mro__[2].__name__.__eq__",  ["BaseException"],  true,  "re.PatternError.__mro__[2].__name__ == 'BaseException' (13 chars; root catchable exception base at MRO slot 2)"]
    - [pe_mro3_name,  "PatternError.__mro__[3].__name__.__eq__",  ["object"],         true,  "re.PatternError.__mro__[3].__name__ == 'object' (6 chars; universal Python base class terminates the 4-entry MRO)"]
    - [pe_mro1_len,   "PatternError.__mro__[1].__name__.__len__", [],                 9,     "re.PatternError.__mro__[1].__name__.__len__() == 9 ('Exception' has 9 characters)"]
    - [pe_mro2_len,   "PatternError.__mro__[2].__name__.__len__", [],                 13,    "re.PatternError.__mro__[2].__name__.__len__() == 13 ('BaseException' has 13 characters; the longest name in PatternError's MRO)"]
    - [pe_mro1_ne_0,  "PatternError.__mro__[1].__name__.__eq__",  ["PatternError"],   false, "re.PatternError.__mro__[1].__name__ != 'PatternError' (slot 1 is 'Exception', not the class itself)"]
    - [pe_mro2_gt_1,  "PatternError.__mro__[2].__name__.__len__.__gt__", [9],         true,  "len('BaseException') > len('Exception') (13 > 9; 'BaseException' at slot 2 is longer than 'Exception' at slot 1)"]

# ---------------------------------------------------------------------------
# RegexFlag and PatternError name lengths and cross-comparisons
# RegexFlag.__name__ has 9 chars; PatternError.__name__ has 12 chars.
# RegexFlag's deepest MRO slot (6) is 'object' (6 chars).
# PatternError's deepest MRO slot (3) is also 'object' (6 chars).
# RegexFlag's MRO has 7 entries vs PatternError's 4 entries.
# RegexFlag.__class__.__name__ == 'EnumType' (not 'type') due to enum metaclass.
# PatternError.__class__.__name__ == 'type' (plain exception class metaclass).
# ---------------------------------------------------------------------------

table re_extra118.RegexFlag_PatternError_lengths_and_metaclass:
  description: "re.RegexFlag.__name__ len=9, __class__.__name__='EnumType'; re.PatternError.__name__ len=12, __class__.__name__='type'; RegexFlag MRO len 7 vs PatternError MRO len 4"
  kind: python_call_eq
  category: class_identity
  id_prefix: rerfpemeta118c

  columns: [id, function, args, expected, description]
  rows:
    - [rf_name_len,     "RegexFlag.__name__.__len__",                  [],       9,     "re.RegexFlag.__name__.__len__() == 9 ('RegexFlag' has 9 characters: 'Regex'(5)+'Flag'(4)==9)"]
    - [pe_name_len,     "PatternError.__name__.__len__",               [],       12,    "re.PatternError.__name__.__len__() == 12 ('PatternError' has 12 characters: 'Pattern'(7)+'Error'(5)==12)"]
    - [rf_cls_enum,     "RegexFlag.__class__.__name__.__eq__",         ["EnumType"], true, "type(re.RegexFlag).__name__ == 'EnumType' (RegexFlag uses the EnumType metaclass, not plain 'type'; all enum classes use this metaclass)"]
    - [pe_cls_type,     "PatternError.__class__.__name__.__eq__",      ["type"],    true, "type(re.PatternError).__name__ == 'type' (PatternError is a plain exception class; it uses the default 'type' metaclass, not ABCMeta or EnumType)"]
    - [rf_mro_len_7,    "RegexFlag.__mro__.__len__",                   [],       7,     "re.RegexFlag.__mro__.__len__() == 7 (deep 7-entry MRO through the IntFlag/int/Enum hierarchy)"]
    - [pe_mro_len_4,    "PatternError.__mro__.__len__",                [],       4,     "re.PatternError.__mro__.__len__() == 4 (shallow 4-entry MRO: PatternError, Exception, BaseException, object)"]
    - [rf_mro_gt_pe,    "RegexFlag.__mro__.__len__.__gt__",            [4],      true,  "re.RegexFlag.__mro__.__len__() > re.PatternError.__mro__.__len__() (7 > 4; RegexFlag has a deeper MRO due to the full enum inheritance chain)"]
    - [pe_ne_rf_name,   "PatternError.__name__.__eq__",                ["RegexFlag"], false, "re.PatternError.__name__ != 'RegexFlag' (distinct names; PatternError is an exception class, RegexFlag is an IntFlag enum)"]
    - [rf_mro1_eq_base, "RegexFlag.__mro__[1].__name__.__eq__",       ["IntFlag"], true, "re.RegexFlag.__mro__[1].__name__ == 'IntFlag' == re.RegexFlag.__bases__[0].__name__ (MRO slot 1 matches the direct base class)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra118.RegexFlag.mro_slot1_is_IntFlag:
  description: "re.RegexFlag.__mro__[1].__name__ == 'IntFlag' (length 7; RegexFlag directly subclasses IntFlag from the enum module; IntFlag is the base for all integer-backed flag enums in Python; by inheriting from IntFlag, each RegexFlag constant (re.IGNORECASE, re.MULTILINE, re.DOTALL, etc.) is simultaneously a RegexFlag enum member and a plain integer, enabling bitwise OR combination with the | operator; re_extra101 covered RegexFlag.__bases__[0].__name__=='IntFlag' but not RegexFlag.__mro__[1].__name__ via bracket notation; this spec is the first to index into RegexFlag.__mro__ slots)"
  category: class_hierarchy
  kind: python_call_eq
  function: "RegexFlag.__mro__[1].__name__.__eq__"
  args: ["IntFlag"]
  expected: true

invariant re_extra118.RegexFlag.mro_slot2_is_int:
  description: "re.RegexFlag.__mro__[2].__name__ == 'int' (length 3; int appears at MRO slot 2 in the RegexFlag hierarchy because IntFlag at slot 1 itself subclasses int; this is what makes flag constants behave as integers — int(re.IGNORECASE) == 2, int(re.MULTILINE) == 8, int(re.DOTALL) == 16; the full MRO is (RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object) — 7 entries; int at slot 2 is the C-implemented integer type that provides all arithmetic and comparison operations; no prior re_extra spec has accessed RegexFlag.__mro__[2])"
  category: class_hierarchy
  kind: python_call_eq
  function: "RegexFlag.__mro__[2].__name__.__eq__"
  args: ["int"]
  expected: true

invariant re_extra118.PatternError.mro_slot1_is_Exception:
  description: "re.PatternError.__mro__[1].__name__ == 'Exception' (length 9; PatternError — formerly re.error, renamed in Python 3.13, with re.error as an alias — directly subclasses Exception with no intermediate base; its MRO is (PatternError, Exception, BaseException, object) — a simple 4-entry chain; PatternError carries two extra attributes: 'pattern' (the regex pattern string that caused the error) and 'pos' (the index in the pattern where the error was found); re_extra108 covered __mro__.__len__()==4 and __bases__[0].__name__=='Exception'; this spec is the first to index PatternError.__mro__[1] via bracket notation)"
  category: class_hierarchy
  kind: python_call_eq
  function: "PatternError.__mro__[1].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant re_extra118.PatternError.mro_slot2_is_BaseException:
  description: "re.PatternError.__mro__[2].__name__ == 'BaseException' (length 13; BaseException is the root of all catchable exception classes in Python; it appears at MRO slot 2 for PatternError because Exception at slot 1 directly subclasses BaseException; 'BaseException'(13) is the longest name in PatternError's 4-entry MRO chain (PatternError=12, Exception=9, BaseException=13, object=6); no prior re_extra spec has indexed PatternError.__mro__[2] via bracket notation)"
  category: class_hierarchy
  kind: python_call_eq
  function: "PatternError.__mro__[2].__name__.__eq__"
  args: ["BaseException"]
  expected: true

invariant re_extra118.RegexFlag.metaclass_is_EnumType:
  description: "re.RegexFlag.__class__.__name__ == 'EnumType' (the enum module's metaclass; all enum classes — whether Enum, IntEnum, Flag, or IntFlag subclasses — are instances of EnumType rather than the plain 'type' metaclass; EnumType provides the machinery for enum member creation, iteration, and __contains__ support; this distinguishes RegexFlag from re.Pattern and re.Match (which use 'type') and from re.PatternError (which also uses 'type'); re_extra101 noted RegexFlag.__class__.__name__=='EnumType' in its notes but no prior spec asserted it as a standalone invariant via the double-quoted function path)"
  category: class_identity
  kind: python_call_eq
  function: "RegexFlag.__class__.__name__.__eq__"
  args: ["EnumType"]
  expected: true

