spec: decimal_extra1036
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module Context and Decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks decimal.Context and decimal.Decimal attribute descriptor class names"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra1036.context_attr_descriptors:
  description: "decimal.Context attribute descriptor class name checks"
  kind: python_call_eq
  category: context_attr_descriptors
  id_prefix: dc1036ca
  columns: [id, function, args, expected]
  rows:
    - [dc1036ca001, decimal.Context.prec.__class__.__name__.__eq__,     ["getset_descriptor"], true]
    - [dc1036ca002, decimal.Context.rounding.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [dc1036ca003, decimal.Context.Emax.__class__.__name__.__eq__,     ["getset_descriptor"], true]
    - [dc1036ca004, decimal.Context.Emin.__class__.__name__.__eq__,     ["getset_descriptor"], true]
    - [dc1036ca005, decimal.Context.capitals.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [dc1036ca006, decimal.Context.clamp.__class__.__name__.__eq__,    ["getset_descriptor"], true]
    - [dc1036ca007, decimal.Context.__doc__.__class__.__name__.__eq__,  ["str"],               true]

table decimal_extra1036.decimal_attr_descriptors:
  description: "decimal.Decimal attribute descriptor class name checks"
  kind: python_call_eq
  category: decimal_attr_descriptors
  id_prefix: dc1036da
  columns: [id, function, args, expected]
  rows:
    - [dc1036da001, decimal.Decimal.real.__class__.__name__.__eq__,     ["property"], true]
    - [dc1036da002, decimal.Decimal.imag.__class__.__name__.__eq__,     ["property"], true]
    - [dc1036da003, decimal.Decimal.__doc__.__class__.__name__.__eq__,  ["str"],      true]
    - [dc1036da004, decimal.Decimal.__class__.__name__.__eq__,          ["type"],     true]
    - [dc1036da005, decimal.Decimal.__module__.__eq__,                  ["decimal"],  true]
    - [dc1036da006, decimal.Decimal.__name__.__eq__,                    ["Decimal"],  true]

table decimal_extra1036.module_identity:
  description: "decimal module-level class and exception identity checks"
  kind: python_call_eq
  category: module_identity
  id_prefix: dc1036mi
  columns: [id, function, args, expected]
  rows:
    - [dc1036mi001, decimal.Context.__name__.__eq__,               ["Context"],  true]
    - [dc1036mi002, decimal.Context.__module__.__eq__,             ["decimal"],  true]
    - [dc1036mi003, decimal.Context.__class__.__name__.__eq__,     ["type"],     true]
    - [dc1036mi004, decimal.DecimalException.__name__.__eq__,      ["DecimalException"], true]
    - [dc1036mi005, decimal.InvalidOperation.__name__.__eq__,      ["InvalidOperation"], true]
    - [dc1036mi006, decimal.DivisionByZero.__name__.__eq__,        ["DivisionByZero"],   true]
    - [dc1036mi007, decimal.Overflow.__name__.__eq__,              ["Overflow"],         true]
    - [dc1036mi008, decimal.Underflow.__name__.__eq__,             ["Underflow"],        true]
