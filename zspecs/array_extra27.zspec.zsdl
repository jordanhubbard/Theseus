spec: array_extra27
version: ">=3.9"
backend: python_module(array)

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/array.html — Python array module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/arraymodule.c"
    - "array_extra21.zspec.zsdl — covers __qualname__ for append/extend/pop/insert/remove/reverse/tolist/tobytes/frombytes."
    - "array_extra26.zspec.zsdl — covers __name__/__qualname__ and __name__.__len__() for append/extend/pop/reverse/tolist/frombytes; array.__init__.__qualname__."
  notes:
    - "This spec extends array_extra26.zspec.zsdl."
    - "Prior specs covered: __qualname__ for all major array.array methods (append/extend/pop/remove/reverse/tolist/frombytes/tobytes and dunders); __name__ and __name__.__len__() for append/extend/pop/reverse/tolist/frombytes; array.__init__.__qualname__."
    - "This spec covers: array.array.__module__.__len__(), array.array.__name__.__len__(), array.array.__qualname__.__len__(); __name__.__len__() for append/extend/pop/reverse/tolist/frombytes restated plus tobytes; array.array.tobytes.__name__ and __qualname__ equality; a unified class-level length table."
    - "array.array.__module__ == 'array', len=5. Verified."
    - "array.array.__name__ == 'array', len=5. Verified."
    - "array.array.__qualname__ == 'array', len=5. Verified."
    - "array.array.append.__name__.__len__() == 6. Verified."
    - "array.array.extend.__name__.__len__() == 6. Verified."
    - "array.array.pop.__name__.__len__() == 3. Verified."
    - "array.array.reverse.__name__.__len__() == 7. Verified."
    - "array.array.tolist.__name__.__len__() == 6. Verified."
    - "array.array.frombytes.__name__.__len__() == 9. Verified."
    - "array.array.tobytes.__name__ == 'tobytes', len=7. Verified."
    - "array.array.tobytes.__qualname__ == 'array.tobytes', len=13. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: class-level __module__/__name__/__qualname__ length checks for array.array
#
# No prior spec covers __len__() on array.array's class-level identity
# attributes. For array.array, all three strings are 'array' (len 5), making
# this a case where module name, class name, and qualname are all identical.
# Verified: __module__.__len__()=5, __name__.__len__()=5, __qualname__.__len__()=5.
# ---------------------------------------------------------------------------

table array_extra27.class_attr_lengths:
  description: "array.array class __module__/__name__/__qualname__ lengths — all are 'array' (len 5)"
  kind: python_call_eq
  category: class_identity
  id_prefix: cal27

  columns: [id, function, args, expected]
  rows:
    - [module_len,   "array.__module__.__len__",   [], 5]
    - [name_len,     "array.__name__.__len__",     [], 5]
    - [qualname_len, "array.__qualname__.__len__", [], 5]

# ---------------------------------------------------------------------------
# Table: __name__.__len__() for append/extend/pop/reverse/tolist/frombytes/tobytes
#
# array_extra26 covers __name__.__len__() for the six methods excluding tobytes.
# This table adds tobytes to complete the set of seven commonly-used mutation
# and conversion methods in a unified extra27 namespace.
# Verified: append=6, extend=6, pop=3, reverse=7, tolist=6, frombytes=9, tobytes=7.
# ---------------------------------------------------------------------------

table array_extra27.method_name_lengths:
  description: "array.array method __name__.__len__() for append/extend/pop/reverse/tolist/frombytes/tobytes — lengths 6/6/3/7/6/9/7"
  kind: python_call_eq
  category: method_identity
  id_prefix: amnlen27

  columns: [id, function, args, expected]
  rows:
    - [append,    "array.append.__name__.__len__",    [], 6]
    - [extend,    "array.extend.__name__.__len__",    [], 6]
    - [pop,       "array.pop.__name__.__len__",       [], 3]
    - [reverse,   "array.reverse.__name__.__len__",   [], 7]
    - [tolist,    "array.tolist.__name__.__len__",    [], 6]
    - [frombytes, "array.frombytes.__name__.__len__", [], 9]
    - [tobytes,   "array.tobytes.__name__.__len__",   [], 7]

# ---------------------------------------------------------------------------
# Standalone: array.array.tobytes.__name__ == 'tobytes'
#
# array_extra21 covers tobytes.__qualname__ == 'array.tobytes'. No prior spec
# explicitly checks tobytes.__name__ (the simple name without class prefix).
# For C extension type methods, __name__ is the method name alone.
# Verified: array.array.tobytes.__name__ == 'tobytes'.
# ---------------------------------------------------------------------------

invariant array_extra27.tobytes.name:
  description: "array.array.tobytes.__name__ == 'tobytes' — simple method name without class prefix"
  category: method_identity
  kind: python_call_eq
  function: "array.tobytes.__name__.__eq__"
  args: ["tobytes"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: array.array.tobytes.__qualname__ == 'array.tobytes'
#
# array_extra21 covers tobytes.__qualname__ in a table. This standalone
# restates it in the extra27 namespace for co-location with the tobytes.__name__
# invariant above, providing a paired name/qualname anchor for tobytes.
# Verified: array.array.tobytes.__qualname__ == 'array.tobytes'.
# ---------------------------------------------------------------------------

invariant array_extra27.tobytes.qualname:
  description: "array.array.tobytes.__qualname__ == 'array.tobytes' — qualname includes 'array.' class prefix; length 13"
  category: method_qualnames
  kind: python_call_eq
  function: "array.tobytes.__qualname__.__eq__"
  args: ["array.tobytes"]
  expected: true
