spec: base64_extra8
version: ">=3.9"
backend: python_module(base64)

docs: https://docs.python.org/3/library/base64.html
rfcs:
  - "RFC 4648 — The Base16, Base32, and Base64 Data Encodings"

provenance:
  derived_from:
    - "RFC 4648 — The Base16, Base32, and Base64 Data Encodings, October 2006"
    - "RFC 4648 Section 10 — Test vectors for Base64, Base32, Base16"
    - "https://docs.python.org/3/library/base64.html — Python base64 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/base64.py"
    - "CPython source: Modules/binascii.c"
    - "base64.zspec.zsdl — covers b64encode/b64decode RFC 4648 vectors; urlsafe; b32encode foo/foobar; b16encode; roundtrip; b64decode invalid raises"
    - "base64_extra5.zspec.zsdl — covers b64encode/__name__, __module__ table; return type checks; b64encode length 1/3/6 bytes; zero-byte encode/decode values"
    - "base64_extra6.zspec.zsdl — covers b32encode A/empty; b32decode one/two bytes; b16encode abc/ff/00; b85encode/decode hello; b64decode empty; b64encode two bytes"
    - "base64_extra7.zspec.zsdl — covers function __name__ table b16/b32/b85/urlsafe; __module__ table; b16encode null/ff bytes; b64encode Man; urlsafe return class"
  notes:
    - "This spec extends base64 through base64_extra7; it does NOT duplicate invariants present in those files."
    - "Focus: RFC 4648 §10 b32encode vectors not yet covered (f, fo, foob, fooba) and their b32decode roundtrips; urlsafe_b64encode/decode vectors for ASCII strings; b64encode two-byte length check."
    - "RFC 4648 §10 b32encode vectors: f->MY======, fo->MZXQ====, foob->MZXW6YQ=, fooba->MZXW6YTB — not in any prior base64 spec."
    - "RFC 4648 §10 b32decode roundtrips for those same vectors — not in any prior base64 spec."
    - "base64.urlsafe_b64encode(b'abc') == b'YWJj' — standard ASCII input with no +/ substitution needed; not in any prior spec."
    - "base64.urlsafe_b64encode(b'foobar') == b'Zm9vYmFy' — not in any prior spec."
    - "base64.urlsafe_b64decode(b'YWJj') == b'abc' — decode standard-alphabet b64 via urlsafe function; not in any prior spec."
    - "base64.urlsafe_b64decode(b'Zm9vYmFy') == b'foobar' — not in any prior spec."
    - "len(base64.b64encode(b'ab')) == 4 — two input bytes produce exactly 4 base64 chars; extra6 covers value but NOT length."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# b32encode — RFC 4648 §10 test vectors not yet covered
#
# base64.zspec.zsdl covers b'foo' and b'foobar'.
# base64_extra4 covers b'hello'.
# base64_extra6 covers b'A' and b''.
# NOT yet covered: b'f' (1 byte), b'fo' (2 bytes), b'foob' (4 bytes),
# b'fooba' (5 bytes). These complete the RFC 4648 §10 b32 test-vector set.
# ---------------------------------------------------------------------------

table base64_extra8.b32encode.rfc4648_missing:
  kind: python_call_eq
  category: b32
  rfc: "RFC 4648 §10"
  id_prefix: b32enc
  function: b32encode

  columns: [id, args, expected]
  rows:
    - [f,     [!ascii "f"],     !ascii "MY======"]
    - [fo,    [!ascii "fo"],    !ascii "MZXQ===="]
    - [foob,  [!ascii "foob"],  !ascii "MZXW6YQ="]
    - [fooba, [!ascii "fooba"], !ascii "MZXW6YTB"]

# ---------------------------------------------------------------------------
# b32decode — RFC 4648 §10 roundtrip vectors not yet covered
#
# base64_extra4 covers b32decode for b'hello'.
# base64_extra6 covers b32decode for ME====== (a) and MFRA==== (ab).
# NOT yet covered: MY====== (f), MZXQ==== (fo), MZXW6YQ= (foob),
# MZXW6YTB (fooba) — the inverse of the b32encode vectors above.
# ---------------------------------------------------------------------------

table base64_extra8.b32decode.rfc4648_missing:
  kind: python_call_eq
  category: b32
  rfc: "RFC 4648 §10"
  id_prefix: b32dec
  function: b32decode

  columns: [id, args, expected]
  rows:
    - [f,     [!ascii "MY======"], !ascii "f"]
    - [fo,    [!ascii "MZXQ===="], !ascii "fo"]
    - [foob,  [!ascii "MZXW6YQ="], !ascii "foob"]
    - [fooba, [!ascii "MZXW6YTB"], !ascii "fooba"]

# ---------------------------------------------------------------------------
# urlsafe_b64encode / urlsafe_b64decode — ASCII string vectors
#
# base64.zspec.zsdl covers urlsafe_b64encode(b'\xfb\xff\xfe') -> b'-__-' (uses - and _).
# base64_extra4 covers urlsafe_b64encode(b'hello').
# base64_extra7 covers return class for urlsafe functions.
# NOT yet covered: urlsafe_b64encode for inputs whose base64 encoding uses only
# the standard alphabet (no + or / substitution), confirming the urlsafe
# function also works correctly for ordinary ASCII inputs.
# ---------------------------------------------------------------------------

invariant base64_extra8.urlsafe_b64encode.abc:
  description: "base64.urlsafe_b64encode(b'abc') == b'YWJj' — standard-alphabet ASCII input"
  category: urlsafe
  rfc: "RFC 4648 §5"
  kind: python_call_eq
  function: urlsafe_b64encode
  args: [!hex 616263]
  expected: !ascii "YWJj"

invariant base64_extra8.urlsafe_b64encode.foobar:
  description: "base64.urlsafe_b64encode(b'foobar') == b'Zm9vYmFy' — standard-alphabet ASCII input"
  category: urlsafe
  rfc: "RFC 4648 §5"
  kind: python_call_eq
  function: urlsafe_b64encode
  args: [!ascii "foobar"]
  expected: !ascii "Zm9vYmFy"

invariant base64_extra8.urlsafe_b64decode.abc:
  description: "base64.urlsafe_b64decode(b'YWJj') == b'abc' — standard-alphabet token decodes correctly"
  category: urlsafe
  rfc: "RFC 4648 §5"
  kind: python_call_eq
  function: urlsafe_b64decode
  args: [!ascii "YWJj"]
  expected: !hex 616263

invariant base64_extra8.urlsafe_b64decode.foobar:
  description: "base64.urlsafe_b64decode(b'Zm9vYmFy') == b'foobar' — standard-alphabet token decodes correctly"
  category: urlsafe
  rfc: "RFC 4648 §5"
  kind: python_call_eq
  function: urlsafe_b64decode
  args: [!ascii "Zm9vYmFy"]
  expected: !ascii "foobar"

# ---------------------------------------------------------------------------
# b64encode — two-byte input length check
#
# base64_extra6 covers the value: b64encode(b'ab') == b'YWI='.
# base64_extra5 covers the output length for 1/3/6 input bytes.
# NOT yet covered: the output length for 2 input bytes (-> 4 chars).
# ---------------------------------------------------------------------------

invariant base64_extra8.b64encode.two_bytes_len:
  description: "len(base64.b64encode(b'ab')) == 4 — two bytes encode to exactly 4 base64 chars"
  category: lengths
  rfc: "RFC 4648"
  kind: python_call_eq
  function: b64encode
  args: [!hex 6162]
  method: __len__
  method_args: []
  expected: 4

# ---------------------------------------------------------------------------
# urlsafe_b64encode empty input
#
# base64.zspec.zsdl covers urlsafe_b64encode value for b'\xfb\xff\xfe'.
# base64_extra7 covers urlsafe return class. No prior spec verifies
# urlsafe_b64encode(b'') == b'' — the empty-input edge case.
# ---------------------------------------------------------------------------

invariant base64_extra8.urlsafe_b64encode.empty:
  description: "base64.urlsafe_b64encode(b'') == b'' — empty input encodes to empty bytes"
  category: urlsafe
  rfc: "RFC 4648 §5"
  kind: python_call_eq
  function: urlsafe_b64encode
  args: [!ascii ""]
  expected: !ascii ""

invariant base64_extra8.urlsafe_b64decode.empty:
  description: "base64.urlsafe_b64decode(b'') == b'' — empty string decodes to empty bytes"
  category: urlsafe
  rfc: "RFC 4648 §5"
  kind: python_call_eq
  function: urlsafe_b64decode
  args: [!ascii ""]
  expected: !ascii ""
