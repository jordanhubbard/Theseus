spec: number_precision
version: ">=1.5.0"
backend: node(number-precision)

docs: https://www.npmjs.com/package/number-precision

provenance:
  derived_from:
    - "number-precision README — https://www.npmjs.com/package/number-precision"
    - "Test vectors verified with number-precision via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "number-precision source"
  notes:
    - "number-precision is an npm package. Install: npm install number-precision"
    - "NP.plus/minus/times/divide fix IEEE-754 floating-point rounding errors."
    - "NP.round(num, decimalPlaces) rounds correctly; NP.strip removes floating-point noise."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns exact numeric result without floating-point errors."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table number_precision.plus:
  kind: node_module_call_eq
  function: plus
  category: plus
  id_prefix: npp

  columns: [id, args, expected]
  rows:
    - [float_sum,  [0.1, 0.2],   0.3]
    - [int_sum,    [1, 2],       3]
    - [mixed,      [1.5, 2.5],   4]

table number_precision.times:
  kind: node_module_call_eq
  function: times
  category: times
  id_prefix: npt

  columns: [id, args, expected]
  rows:
    - [float_mul,  [3, 0.3],   0.9]
    - [int_mul,    [4, 5],     20]
    - [frac,       [0.1, 0.1], 0.01]

table number_precision.round:
  kind: node_module_call_eq
  function: round
  category: round
  id_prefix: npr

  columns: [id, args, expected]
  rows:
    - [half,   [1.005, 2],  1.01]
    - [int,    [1.5, 0],    2]
    - [neg,    [1.555, 2],  1.56]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:05:15Z
  iterations: 1
  pass_count: 9
  fail_count: 0
  total_invariants: 9
  notes: Synthesis succeeded in 1 iteration(s). 9 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
