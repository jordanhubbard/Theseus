spec: decimal_extra1726
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/decimal.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 562 (_extra1726): comparison/ordering protocol dict-presence checks."
    - "decimal.Decimal defines all ordering operators directly in its own __dict__."
    - "decimal.Decimal.__dict__.__contains__('__lt__') is True — Decimal supports full ordered comparison."
    - "decimal.Decimal.__dict__.__contains__('__le__') is True."
    - "decimal.Decimal.__dict__.__contains__('__gt__') is True."
    - "decimal.Decimal.__dict__.__contains__('__ge__') is True."
    - "decimal.Decimal.__dict__.__contains__('__eq__') is True — Decimal defines equality."
    - "decimal.Decimal.__dict__.__contains__('__hash__') is True — Decimal is hashable (for non-NaN values)."
    - "decimal.Decimal.__dict__.__contains__('__ne__') is False — Python 3 derives __ne__ from __eq__ by default."
    - "decimal.Context.__dict__.__contains__('__lt__') is False — Context objects are not ordered."
    - "decimal.Context.__dict__.__contains__('__le__') is False."
    - "decimal.Context.__dict__.__contains__('__gt__') is False."
    - "decimal.Context.__dict__.__contains__('__ge__') is False."
    - "decimal.InvalidOperation.__dict__.__contains__('__lt__') is False — InvalidOperation is an exception with no ordering."
    - "decimal.DecimalException.__dict__.__contains__('__lt__') is False — DecimalException is an exception with no ordering."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table decimal_extra1726.decimal_comparison_protocol:
  description: "decimal.Decimal comparison protocol dict-presence checks — __lt__, __le__, __gt__, __ge__, __ne__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1726

  columns: [id, function, args, expected]
  rows:
    - ["dc1726001", "decimal.Decimal.__dict__.__contains__", ["__lt__"], true ]
    - ["dc1726002", "decimal.Decimal.__dict__.__contains__", ["__le__"], true ]
    - ["dc1726003", "decimal.Decimal.__dict__.__contains__", ["__gt__"], true ]
    - ["dc1726004", "decimal.Decimal.__dict__.__contains__", ["__ge__"], true ]
    - ["dc1726005", "decimal.Decimal.__dict__.__contains__", ["__eq__"], true ]
    - ["dc1726006", "decimal.Decimal.__dict__.__contains__", ["__hash__"], true ]
    - ["dc1726007", "decimal.Decimal.__dict__.__contains__", ["__ne__"], false]
    - ["dc1726008", "decimal.Context.__dict__.__contains__", ["__lt__"], false]
    - ["dc1726009", "decimal.Context.__dict__.__contains__", ["__le__"], false]
    - ["dc1726010", "decimal.Context.__dict__.__contains__", ["__gt__"], false]
    - ["dc1726011", "decimal.Context.__dict__.__contains__", ["__ge__"], false]
    - ["dc1726012", "decimal.Context.__dict__.__contains__", ["__ne__"], false]

table decimal_extra1726.context_eq_hash_protocol:
  description: "decimal.Context __eq__ and __hash__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1726

  columns: [id, function, args, expected]
  rows:
    - ["dc1726013", "decimal.Context.__dict__.__contains__", ["__eq__"],   true ]
    - ["dc1726014", "decimal.Context.__dict__.__contains__", ["__hash__"], false]

table decimal_extra1726.exception_comparison_protocol:
  description: "decimal exception types comparison protocol dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1726

  columns: [id, function, args, expected]
  rows:
    - ["dc1726015", "decimal.InvalidOperation.__dict__.__contains__",  ["__lt__"], false]
    - ["dc1726016", "decimal.InvalidOperation.__dict__.__contains__",  ["__le__"], false]
    - ["dc1726017", "decimal.InvalidOperation.__dict__.__contains__",  ["__gt__"], false]
    - ["dc1726018", "decimal.InvalidOperation.__dict__.__contains__",  ["__ge__"], false]
    - ["dc1726019", "decimal.InvalidOperation.__dict__.__contains__",  ["__ne__"], false]
    - ["dc1726020", "decimal.InvalidOperation.__dict__.__contains__",  ["__eq__"], false]
    - ["dc1726021", "decimal.DecimalException.__dict__.__contains__",  ["__lt__"], false]
    - ["dc1726022", "decimal.DecimalException.__dict__.__contains__",  ["__le__"], false]
