  derived_from:
    - "is-plain-obj README — https://www.npmjs.com/package/is-plain-obj"
    - "Test vectors verified with is-plain-obj via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-plain-obj source"
  notes:
    - "is-plain-obj is an npm package. Install: npm install is-plain-obj"
    - "Returns true only for plain objects (created with {} or Object.create(null))."
    - "Arrays, null, and class instances return false. ESM package; use function: default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_plain_obj.isPlainObj:
  kind: node_module_call_eq
  function: "default"
  category: predicate
  id_prefix: isplainobj

  columns: [id, args, expected]
  rows:
    - [empty_obj,    [{}],         true]
    - [with_props,   [{"a": 1}],   true]
    - [array,        [[1, 2]],     false]
    - [null,         [null],       false]

