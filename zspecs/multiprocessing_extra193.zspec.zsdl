# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra193
# ---------------------------------------------------------------------------

invariant multiprocessing_extra193.mp_BaseManager_name_eq:
  description: "multiprocessing.managers.BaseManager.__name__.__eq__('BaseManager') returns True — BaseManager.__name__=='BaseManager' (len=11: 'Base'=4+'Manager'=7=11); BaseManager is the foundation class for multiprocessing manager objects that run in a separate server process; clients connect to the server and use proxy objects to access shared state; BaseManager provides register(), start(), connect(), shutdown(), and get_server() methods; BaseManager.__name__ (11) == SyncManager.__name__ (11) — both manager classes have identical name lengths; NEW in mpmanagers193: first standalone BaseManager.__name__.__eq__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.BaseManager.__name__.__eq__
  args: ["BaseManager"]
  expected: true

invariant multiprocessing_extra193.mp_BaseManager_module_eq:
  description: "multiprocessing.managers.BaseManager.__module__.__eq__('multiprocessing.managers') returns True — BaseManager.__module__=='multiprocessing.managers' (len=24: 'multiprocessing'=15+'.'=1+'managers'=8=24); BaseManager is defined in Lib/multiprocessing/managers.py alongside SyncManager, BaseProxy, and the manager server infrastructure; BaseManager.__module__ (24) == SyncManager.__module__ (24) — all manager classes share the same source module; BaseManager.__module__ (24) == multiprocessing.sharedctypes.Value.__module__ length (28) minus 4 — comparing different multiprocessing submodules; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.BaseManager.__module__.__eq__
  args: ["multiprocessing.managers"]
  expected: true

invariant multiprocessing_extra193.mp_BaseManager_base_is_object:
  description: "multiprocessing.managers.BaseManager.__bases__[0].__name__.__eq__('object') returns True — BaseManager.__bases__[0].__name__=='object' (len=6: o(1)b(2)j(3)e(4)c(5)t(6)); BaseManager inherits directly from object with no intermediate base classes; this means BaseManager is the root of the multiprocessing manager hierarchy — SyncManager subclasses BaseManager, not object directly; BaseManager.__bases__[0].__name__ (6) << BaseManager.__name__ (11) — 'object' is shorter than 'BaseManager'; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.managers.BaseManager.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant multiprocessing_extra193.mp_SyncManager_name_eq:
  description: "multiprocessing.managers.SyncManager.__name__.__eq__('SyncManager') returns True — SyncManager.__name__=='SyncManager' (len=11: 'Sync'=4+'Manager'=7=11); SyncManager extends BaseManager to provide pre-registered proxy types for common synchronization objects: Lock, RLock, Semaphore, BoundedSemaphore, Event, Condition, Queue, Barrier, and Namespace; SyncManager is the recommended manager class for most multiprocessing use cases; SyncManager.__name__ (11) == BaseManager.__name__ (11) — same name length as its base class; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.SyncManager.__name__.__eq__
  args: ["SyncManager"]
  expected: true

invariant multiprocessing_extra193.mp_SyncManager_base_is_BaseManager:
  description: "multiprocessing.managers.SyncManager.__bases__[0].__name__.__eq__('BaseManager') returns True — SyncManager.__bases__[0].__name__=='BaseManager' (len=11); SyncManager is a direct subclass of BaseManager, inheriting all manager infrastructure while adding pre-registered synchronization proxy types; SyncManager.__bases__[0].__name__ (11) == SyncManager.__name__ (11) == BaseManager.__name__ (11) — symmetric: a class whose direct base has the same name length as itself; SyncManager.__bases__[0].__name__ (11) confirms that BaseManager.__bases__[0].__name__ (6: 'object') is not the same as SyncManager's base; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.managers.SyncManager.__bases__[0].__name__.__eq__"
  args: ["BaseManager"]
  expected: true

invariant multiprocessing_extra193.mp_BaseManager_init_qualname_eq:
  description: "multiprocessing.managers.BaseManager.__init__.__qualname__.__eq__('BaseManager.__init__') returns True — BaseManager.__init__.__qualname__=='BaseManager.__init__' (len=20: 'BaseManager'=11+'.'=1+'__init__'=8=20); BaseManager.__init__ accepts address (defaults to None for a random free port), authkey (bytes for HMAC authentication), and serializer ('pickle' or 'xmlrpclib') parameters; BaseManager.__init__.__qualname__ (20) > BaseManager.start.__qualname__ (17) by 3 — '__init__' (8) > 'start' (5); the standard qualname pattern 'ClassName.__init__' gives length = name_len + 9; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.BaseManager.__init__.__qualname__.__eq__
  args: ["BaseManager.__init__"]
  expected: true

invariant multiprocessing_extra193.mp_BaseManager_start_qualname_eq:
  description: "multiprocessing.managers.BaseManager.start.__qualname__.__eq__('BaseManager.start') returns True — BaseManager.start.__qualname__=='BaseManager.start' (len=17: 'BaseManager'=11+'.'=1+'start'=5=17); BaseManager.start() spawns a server process and allows clients to connect; it accepts an optional initializer callable and initargs for the server process; BaseManager.start.__qualname__ (17) < BaseManager.__init__.__qualname__ (20) by 3 — 'start' (5) vs '__init__' (8); BaseManager.start.__qualname__ (17) is the shortest qualname in this spec; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.BaseManager.start.__qualname__.__eq__
  args: ["BaseManager.start"]
  expected: true

invariant multiprocessing_extra193.mp_BaseManager_init_qualname_len:
  description: "multiprocessing.managers.BaseManager.__init__.__qualname__.__len__() == 20 — BaseManager.__init__.__qualname__=='BaseManager.__init__' (len=20: 'BaseManager'=11+'.'=1+'__init__'=8=20); BaseManager.__init__.__qualname__ (20) is the longest qualname in this spec; BaseManager.__module__ (24) > BaseManager.__init__.__qualname__ (20) by 4 — the module path is longer than any method qualname; the pattern qualname_len = name_len + 1 + method_name_len applies: 11 + 1 + 8 = 20 for __init__, 11 + 1 + 5 = 17 for start; NEW in mpmanagers193: completing 8-invariant coverage for multiprocessing.managers class identity; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.BaseManager.__init__.__qualname__.__len__
  args: []
  expected: 20
