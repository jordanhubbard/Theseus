    - [bm_init_qualname_len,  multiprocessing.managers.BaseManager.__init__.__qualname__.__len__, [],                        20,   "multiprocessing.managers.BaseManager.__init__.__qualname__.__len__() == 20 ('BaseManager.__init__'=20: 'BaseManager'=11+'.'=1+'__init__'=8=20); verified Python 3.14.3"]
