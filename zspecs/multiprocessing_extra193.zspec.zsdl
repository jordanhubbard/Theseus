    - ["sm_base_len",   "multiprocessing.managers.SyncManager.__bases__[0].__name__.__len__", [],                           11,   "multiprocessing.managers.SyncManager.__bases__[0].__name__.__len__() == 11 ('BaseManager'=11; SyncManager.__bases__[0].__name__ len == SyncManager.__name__ len); verified Python 3.14.3"]

