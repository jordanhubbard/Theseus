spec: multiprocessing_extra193
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/managers.py"
  notes:
    - "multiprocessing.managers.BaseManager.__name__ == 'BaseManager' (len=11: 'BaseManager'=11)."
    - "multiprocessing.managers.BaseManager.__module__ == 'multiprocessing.managers' (len=24: 'multiprocessing'=15+'.'=1+'managers'=8=24)."
    - "multiprocessing.managers.BaseManager.__bases__[0].__name__ == 'object' (len=6); BaseManager inherits directly from object."
    - "multiprocessing.managers.SyncManager.__name__ == 'SyncManager' (len=11: 'SyncManager'=11)."
    - "multiprocessing.managers.SyncManager.__module__ == 'multiprocessing.managers' (len=24)."
    - "multiprocessing.managers.SyncManager.__bases__[0].__name__ == 'BaseManager' (len=11); SyncManager inherits from BaseManager."
    - "multiprocessing.managers.BaseManager.__init__.__qualname__ == 'BaseManager.__init__' (len=20: 'BaseManager'=11+'.'=1+'__init__'=8=20)."
    - "multiprocessing.managers.BaseManager.start.__qualname__ == 'BaseManager.start' (len=17: 'BaseManager'=11+'.'=1+'start'=5=17)."
    - "Length ordering: start qualname (17) < __init__ qualname (20)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

