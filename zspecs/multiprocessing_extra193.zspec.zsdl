  description: "multiprocessing.managers.SyncManager class identity checks in mpmanagers193 namespace — SyncManager.__name__=='SyncManager' (len=11: 'Sync'=4+'Manager'=7=11; a manager providing proxy objects for common synchronization primitives); SyncManager.__module__=='multiprocessing.managers' (len=24; same source file as BaseManager); SyncManager.__bases__[0].__name__=='BaseManager' (len=11; SyncManager subclasses BaseManager, extending it with Lock, Event, Semaphore, Queue, and other shared-state proxies); SyncManager.__name__ (11) == BaseManager.__name__ (11) — both have 11-character names; SyncManager.__bases__[0].__name__ (11) == SyncManager.__name__ (11) == BaseManager.__name__ (11) — a symmetric length relationship; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmanagers193

  columns: [id, function, args, expected, description]
  rows:
    - [sm_name_eq,      multiprocessing.managers.SyncManager.__name__.__eq__,               ["SyncManager"],                 true, "multiprocessing.managers.SyncManager.__name__ == 'SyncManager' (len=11; provides proxies for Lock, Event, Semaphore, Queue); verified Python 3.14.3"]
    - [sm_name_len,     multiprocessing.managers.SyncManager.__name__.__len__,              [],                              11,   "multiprocessing.managers.SyncManager.__name__.__len__() == 11 ('SyncManager'=11: 'Sync'=4+'Manager'=7=11); verified Python 3.14.3"]
    - [sm_module_eq,    multiprocessing.managers.SyncManager.__module__.__eq__,             ["multiprocessing.managers"],    true, "multiprocessing.managers.SyncManager.__module__ == 'multiprocessing.managers' (len=24; same module as BaseManager); verified Python 3.14.3"]
