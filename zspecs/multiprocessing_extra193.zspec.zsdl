table multiprocessing_extra193.mp_BaseManager_identity:
  description: "multiprocessing.managers.BaseManager class identity checks in mpmanagers193 namespace — BaseManager.__name__=='BaseManager' (len=11: 'Base'=4+'Manager'=7=11; the base class for manager objects that run in separate processes); BaseManager.__module__=='multiprocessing.managers' (len=24: 'multiprocessing'=15+'.'=1+'managers'=8=24; pure Python in Lib/multiprocessing/managers.py); BaseManager.__bases__[0].__name__=='object' (len=6; BaseManager inherits directly from object — it is not a subclass of any other multiprocessing class); BaseManager.__name__ (11) == SyncManager.__name__ (11) — both managers have 11-character names; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmanagers193

  columns: [id, function, args, expected, description]
  rows:
    - [bm_name_eq,      multiprocessing.managers.BaseManager.__name__.__eq__,               ["BaseManager"],                 true, "multiprocessing.managers.BaseManager.__name__ == 'BaseManager' (len=11; base class for managers in separate processes); verified Python 3.14.3"]
    - [bm_name_len,     multiprocessing.managers.BaseManager.__name__.__len__,              [],                              11,   "multiprocessing.managers.BaseManager.__name__.__len__() == 11 ('BaseManager'=11: 'Base'=4+'Manager'=7=11); verified Python 3.14.3"]
    - [bm_module_eq,    multiprocessing.managers.BaseManager.__module__.__eq__,             ["multiprocessing.managers"],    true, "multiprocessing.managers.BaseManager.__module__ == 'multiprocessing.managers' (len=24; pure Python in Lib/multiprocessing/managers.py); verified Python 3.14.3"]
    - [bm_module_len,   multiprocessing.managers.BaseManager.__module__.__len__,            [],                              24,   "multiprocessing.managers.BaseManager.__module__.__len__() == 24 ('multiprocessing.managers'=24: 'multiprocessing'=15+'.'=1+'managers'=8=24); verified Python 3.14.3"]
    - ["bm_base_eq",    "multiprocessing.managers.BaseManager.__bases__[0].__name__.__eq__", ["object"],                    true, "multiprocessing.managers.BaseManager.__bases__[0].__name__ == 'object' (len=6; BaseManager inherits directly from object); verified Python 3.14.3"]

