spec: socket_extra168
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra167.zspec.zsdl — covers socket.AddressFamily/__SocketKind __name__/__module__/__bases__[0].__name__=='IntEnum' and name lengths (13/10) (table + invariants)."
    - "socket_extra166.zspec.zsdl — covers socket.AF_INET/__SOCK_STREAM/__AF_INET6/__SOCK_DGRAM/__IPPROTO_TCP/__IPPROTO_UDP enum constant class names and integer values (table + invariants)."
    - "socket_extra165.zspec.zsdl — covers socket.error/__timeout/__gaierror/__herror class identity (table + invariants)."
    - "socket_extra164.zspec.zsdl — covers socket.socket.__dict__ method membership (table + invariants)."
    - "socket_extra159.zspec.zsdl — covers socket.socket.__name__/__module__/__bases__[0].__name__ (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra93 through socket_extra167."
    - "Wave 350 theme: socket.socket class base, and socket.create_connection/__create_server/__getaddrinfo module-level function identity. socket_extra159 anchors socket.socket.__name__=='socket'/__module__=='socket'/__bases__[0].__name__ (confirmed as '_socket' or 'socket' — verified below). This spec anchors the three module-level convenience functions (create_connection/create_server/getaddrinfo) as the primary novel content."
    - "socket.socket.__name__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__bases__[0].__name__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0. NOTE: socket.socket.__bases__[0].__name__ is 'socket' (NOT '_socket'). The base class is _socket.socket whose __name__ attribute is 'socket' (same string), while __module__ is '_socket'. The class name 'socket' is shared; only the module differs."
    - "socket.socket.__bases__[0].__module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_connection.__name__ == 'create_connection'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_connection.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_connection.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_server.__name__ == 'create_server'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_server.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_server.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__name__ == 'getaddrinfo'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.socket.__bases__[0].__name__ == 'socket' (6 chars), NOT '_socket'. The base class is _socket.socket, but its __name__ attribute reports 'socket' (6 chars). Its __module__ is '_socket' (7 chars = '_'=1 + 'socket'=6). So socket.socket.__name__(6) == socket.socket.__bases__[0].__name__(6) — both say 'socket', but socket.socket.__module__=='socket'(6 chars) while socket.socket.__bases__[0].__module__=='_socket'(7 chars). The distinction is in __module__, not __name__."
    - "Note: socket.create_connection.__name__ == 'create_connection' (17 chars = 'create'=6 + '_connection'=11). create_connection is a high-level convenience function added in Python 2.6 that creates a TCP connection to a (host, port) pair. It handles address resolution, timeouts, and connection. __module__=='socket'(6 chars; pure Python in Lib/socket.py). __class__.__name__=='function'(8 chars; pure Python def-function)."
    - "Note: socket.create_server.__name__ == 'create_server' (13 chars = 'create'=6 + '_server'=7). create_server is a high-level convenience function added in Python 3.8 that creates a listening TCP socket. __module__=='socket'(6 chars). __class__.__name__=='function'(8 chars). 'create_server'(13) < 'create_connection'(17) by 4 chars."
    - "Note: socket.getaddrinfo.__name__ == 'getaddrinfo' (11 chars = 'get'=3 + 'addr'=4 + 'info'=4). getaddrinfo resolves host/port to a list of socket address structures. __module__=='socket'(6 chars). __class__.__name__=='function'(8 chars; pure Python wrapper — note: in older Python versions getaddrinfo was a C builtin; on Python 3.14.3 macOS it is a Python function). 'getaddrinfo'(11) < 'create_server'(13) < 'create_connection'(17)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.__name__.__eq__('socket')
# socket.socket.__module__.__eq__('socket')
# socket.socket.__bases__[0].__name__.__eq__('socket')
# socket.socket.__bases__[0].__module__.__eq__('_socket')
#
# Wave 350 theme: socket.socket class identity and base class detail.
#
# socket.__name__ == 'socket' (6 chars; the Python socket class name).
# socket.__module__ == 'socket' (6 chars; defined in Lib/socket.py).
# socket.__bases__[0].__name__ == 'socket' (6 chars; base class name is 'socket' NOT '_socket').
# socket.__bases__[0].__module__ == '_socket' (7 chars; base class is from private C extension).
# socket_extra159 anchors socket.socket.__name__/__module__/__bases__[0].__name__;
# this spec confirms the base class detail and adds __bases__[0].__module__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra168.socket_class_and_base_identity:
  description: "socket.socket.__name__.__eq__('socket')==True / socket.__module__.__eq__('socket')==True / socket.__bases__[0].__name__.__eq__('socket')==True / socket.__bases__[0].__module__.__eq__('_socket')==True — socket.__name__ is 'socket' (6 chars; the socket.socket class name; both the module 'socket' and the class 'socket' share the same 6-char name; socket_extra159 anchors socket.__name__=='socket' as a table row; confirmed here); socket.__module__ is 'socket' (6 chars; socket.socket is defined in Lib/socket.py; __module__=='socket' (public module); socket_extra159 anchors this); socket.__bases__[0].__name__ is 'socket' (6 chars; NOTE: the base class _socket.socket has __name__ == 'socket' (NOT '_socket'); the class name attribute of the C extension class is 'socket' (6 chars) — same as the Python subclass __name__; only the __module__ attribute differentiates them: Python socket.__module__=='socket'(6) vs C socket.__module__=='_socket'(7)); socket.__bases__[0].__module__ is '_socket' (7 chars = '_'=1 + 'socket'=6; the private C extension module from Modules/socketmodule.c; '_socket'(7) > 'socket'(6) by 1 char due to the leading underscore; first sockfn168 anchor for socket class identity combining base name and module)"
  kind: python_call_eq
  category: identity
  id_prefix: sockfn168

  columns: [id, function, args, expected, description]
  rows:
    - [sock_name,            "socket.__name__.__eq__",                  ["socket"],   true, "socket.socket.__name__ == 'socket' (6 chars; class name; socket_extra159 anchors; confirmed)"]
    - [sock_module,          "socket.__module__.__eq__",                ["socket"],   true, "socket.socket.__module__ == 'socket' (6 chars; Lib/socket.py; public module; socket_extra159 anchors)"]
    - [sock_base_name,       "socket.__bases__[0].__name__.__eq__",     ["socket"],   true, "socket.socket.__bases__[0].__name__ == 'socket' (6 chars; base class _socket.socket has __name__='socket' NOT '_socket'; name same as subclass)"]
    - [sock_base_module,     "socket.__bases__[0].__module__.__eq__",   ["_socket"],  true, "socket.socket.__bases__[0].__module__ == '_socket' (7 chars; private C extension; '_socket'(7) > 'socket'(6) by 1 char; module distinguishes base from subclass)"]

# ---------------------------------------------------------------------------
# socket.create_connection.__name__ and __module__ and __class__.__name__
#
# Wave 350 theme: socket.create_connection module-level function identity.
#
# create_connection.__name__ == 'create_connection' (17 chars; longest name in this spec).
# create_connection.__module__ == 'socket' (6 chars; pure Python in Lib/socket.py).
# create_connection.__class__.__name__ == 'function' (8 chars; pure Python function).
# create_connection.__name__.__len__() == 17 ('create_connection' = 17 chars).
# No prior socket spec anchors create_connection.__name__ as a table under sockfn168.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra168.create_connection_identity:
  description: "socket.create_connection.__name__.__eq__('create_connection')==True / create_connection.__module__.__eq__('socket')==True / create_connection.__class__.__name__.__eq__('function')==True / create_connection.__name__.__len__()==17 — create_connection.__name__ is 'create_connection' (17 chars = 'create'=6 + '_connection'=11; socket.create_connection(address, timeout=None, source_address=None) is a high-level convenience function; it creates a TCP connection to a (host, port) pair, handling address resolution, timeouts, and connection; added in Python 2.6; it calls getaddrinfo() internally and tries each result; 'create_connection'(17) is the longest function name in this spec; 17 > 13 ('create_server') > 11 ('getaddrinfo') in length); create_connection.__module__ is 'socket' (6 chars; pure Python defined in Lib/socket.py; __module__=='socket'(6 chars; public module); create_connection is a pure Python function — not a C extension function; all three module-level functions in this spec (create_connection/create_server/getaddrinfo) have __module__=='socket'(6 chars)); create_connection.__class__.__name__ is 'function' (8 chars; pure Python def-function; 'function'(8) > 'socket'(6) by 2 chars); create_connection.__name__.__len__() is 17 ('create_connection' = 'create'=6 + '_connection'=11 = 17; 'connection'(10) + underscore(1) = 11 in '_connection'; 17 = longest name in this spec; first sockfn168 anchor for create_connection identity)"
  kind: python_call_eq
  category: identity
  id_prefix: sockfn168

  columns: [id, function, args, expected, description]
  rows:
    - [cc_name,          "create_connection.__name__.__eq__",           ["create_connection"], true, "socket.create_connection.__name__ == 'create_connection' (17 chars = 'create'=6 + '_connection'=11; high-level TCP connector; Python 2.6+; longest name in spec)"]
    - [cc_module,        "create_connection.__module__.__eq__",         ["socket"],             true, "socket.create_connection.__module__ == 'socket' (6 chars; pure Python in Lib/socket.py; all three functions in spec share __module__=='socket')"]
    - [cc_class_fn,      "create_connection.__class__.__name__.__eq__", ["function"],           true, "socket.create_connection.__class__.__name__ == 'function' (8 chars; pure Python def-function; 'function'(8) > 'socket'(6) by 2)"]
    - [cc_name_len_17,   "create_connection.__name__.__len__",          [],                    17,   "socket.create_connection.__name__.__len__() is 17 ('create_connection' = 17 chars; longest name: 17 > create_server(13) > getaddrinfo(11))"]

# ---------------------------------------------------------------------------
# socket.create_server.__name__ and __module__ and __class__.__name__
#
# Wave 350 theme: socket.create_server module-level function identity.
#
# create_server.__name__ == 'create_server' (13 chars; middle-length name).
# create_server.__module__ == 'socket' (6 chars; pure Python).
# create_server.__class__.__name__ == 'function' (8 chars; pure Python function).
# create_server.__name__.__len__() == 13 ('create_server' = 13 chars).
# No prior socket spec anchors create_server.__name__ as a table under sockfn168.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra168.create_server_identity:
  description: "socket.create_server.__name__.__eq__('create_server')==True / create_server.__module__.__eq__('socket')==True / create_server.__class__.__name__.__eq__('function')==True / create_server.__name__.__len__()==13 — create_server.__name__ is 'create_server' (13 chars = 'create'=6 + '_server'=7; socket.create_server(address, *, family=AF_INET, backlog=None, reuse_port=False, dualstack_ipv6=False) creates a listening TCP socket bound to address; added in Python 3.8; it handles socket creation, binding, and listening in one call; contrasts with create_connection (client-side, 17 chars) — create_server is server-side, 13 chars; 'create_server'(13) == socket.AddressFamily.__name__.__len__()==13 == socket_extra167 anchors — coincidental same 13-char length); create_server.__module__ is 'socket' (6 chars; pure Python in Lib/socket.py; same module as create_connection; 'socket'(6) < 'create_server'(13) by 7 chars); create_server.__class__.__name__ is 'function' (8 chars; pure Python def-function; same type as create_connection and getaddrinfo; all three convenience functions are 'function' type); create_server.__name__.__len__() is 13 ('create_server' = 'create'=6 + '_server'=7 = 13; 'create_server'(13) == 'AddressFamily'(13) in length — coincidental; 13 is between 11 (getaddrinfo) and 17 (create_connection); first sockfn168 anchor for create_server identity)"
  kind: python_call_eq
  category: identity
  id_prefix: sockfn168

  columns: [id, function, args, expected, description]
  rows:
    - [cs_name,          "create_server.__name__.__eq__",           ["create_server"], true, "socket.create_server.__name__ == 'create_server' (13 chars = 'create'=6 + '_server'=7; listening socket creator; Python 3.8+; 'create_server'(13)==AddressFamily.__name__.__len__()==13)"]
    - [cs_module,        "create_server.__module__.__eq__",         ["socket"],         true, "socket.create_server.__module__ == 'socket' (6 chars; pure Python in Lib/socket.py; same as create_connection.__module__)"]
    - [cs_class_fn,      "create_server.__class__.__name__.__eq__", ["function"],       true, "socket.create_server.__class__.__name__ == 'function' (8 chars; pure Python; same type as create_connection and getaddrinfo)"]
    - [cs_name_len_13,   "create_server.__name__.__len__",          [],                13,   "socket.create_server.__name__.__len__() is 13 ('create_server' = 13 chars; getaddrinfo(11) < create_server(13) < create_connection(17))"]

# ---------------------------------------------------------------------------
# socket.getaddrinfo.__name__ and __module__ and __class__.__name__
#
# Wave 350 theme: socket.getaddrinfo function identity.
#
# getaddrinfo.__name__ == 'getaddrinfo' (11 chars; shortest of the three in this spec).
# getaddrinfo.__module__ == 'socket' (6 chars; pure Python wrapper on Python 3.14.3 macOS).
# getaddrinfo.__class__.__name__ == 'function' (8 chars; pure Python function).
# getaddrinfo.__name__.__len__() == 11 ('getaddrinfo' = 11 chars).
# No prior socket spec anchors getaddrinfo.__name__ as a table under sockfn168.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra168.getaddrinfo_identity:
  description: "socket.getaddrinfo.__name__.__eq__('getaddrinfo')==True / getaddrinfo.__module__.__eq__('socket')==True / getaddrinfo.__class__.__name__.__eq__('function')==True / getaddrinfo.__name__.__len__()==11 — getaddrinfo.__name__ is 'getaddrinfo' (11 chars = 'get'=3 + 'addr'=4 + 'info'=4; socket.getaddrinfo(host, port, family=0, type=0, proto=0, flags=0) resolves host/port to a list of 5-tuples (family, type, proto, canonname, sockaddr); it is the primary address resolution function in Python's socket module; 'getaddrinfo'(11) < 'create_server'(13) < 'create_connection'(17); 'getaddrinfo'(11) == struct.unpack_from.__name__.__len__()==11 and struct.iter_unpack.__name__.__len__()==11 — coincidental tie with struct function names); getaddrinfo.__module__ is 'socket' (6 chars; on Python 3.14.3 macOS/Darwin, getaddrinfo is a pure Python function in Lib/socket.py with __module__=='socket'; in earlier Python versions it was a C builtin; __module__=='socket'(6) confirms pure Python on this platform); getaddrinfo.__class__.__name__ is 'function' (8 chars; pure Python function; all three functions in this spec (create_connection/create_server/getaddrinfo) are 'function' type on Python 3.14.3 macOS/Darwin); getaddrinfo.__name__.__len__() is 11 ('getaddrinfo' = 11 chars; 11 is the shortest function name in this spec; length ordering: 'getaddrinfo'(11) < 'create_server'(13) < 'create_connection'(17); first sockfn168 anchor for getaddrinfo identity)"
  kind: python_call_eq
  category: identity
  id_prefix: sockfn168

  columns: [id, function, args, expected, description]
  rows:
    - [ga_name,          "getaddrinfo.__name__.__eq__",           ["getaddrinfo"], true, "socket.getaddrinfo.__name__ == 'getaddrinfo' (11 chars = 'get'=3 + 'addr'=4 + 'info'=4; address resolver; shortest of the three module-level functions)"]
    - [ga_module,        "getaddrinfo.__module__.__eq__",         ["socket"],       true, "socket.getaddrinfo.__module__ == 'socket' (6 chars; pure Python wrapper on Python 3.14.3 macOS; __module__=='socket')"]
    - [ga_class_fn,      "getaddrinfo.__class__.__name__.__eq__", ["function"],     true, "socket.getaddrinfo.__class__.__name__ == 'function' (8 chars; pure Python; all three convenience functions in spec are 'function' type)"]
    - [ga_name_len_11,   "getaddrinfo.__name__.__len__",          [],              11,   "socket.getaddrinfo.__name__.__len__() is 11 ('getaddrinfo' = 11 chars; shortest of three: getaddrinfo(11) < create_server(13) < create_connection(17))"]

# ---------------------------------------------------------------------------
# socket.socket.__name__.__eq__('socket') — standalone
#
# socket.socket.__name__ is 'socket' (6 chars). The Python socket.socket class name is
# 'socket'. Both the module name 'socket' (6 chars) and the class name 'socket' (6 chars)
# are identical strings. socket_extra159 anchors socket.socket.__name__=='socket' as a
# table row; this standalone confirms it under sockfn168.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra168.socket_class_name_socket:
  description: "socket.socket.__name__.__eq__('socket') == True — 'socket' (6 chars; the class name; socket.socket.__name__=='socket'(6)==socket.socket.__module__(6)=='socket' — class name and module name are identical strings; socket_extra159 anchors this as table row; socket.__bases__[0].__name__=='socket'(6) too — base class name also 'socket'; base is distinguished by __module__=='_socket'(7 chars); first sockfn168 standalone for socket.socket.__name__"
  category: identity
  kind: python_call_eq
  function: socket.__name__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__bases__[0].__module__.__eq__('_socket') — standalone
#
# socket.socket.__bases__[0].__module__ is '_socket' (7 chars). The base class of
# socket.socket is _socket.socket (the C-extension class from Modules/socketmodule.c).
# Its __module__ is '_socket' (7 chars) — the private C extension module.
# '_socket'(7) > 'socket'(6) by 1 char (leading underscore marks private C extension).
# socket.socket.__bases__[0].__name__ == 'socket' (6 chars — same as the Python subclass
# name), so the two classes share the same __name__ but differ in __module__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra168.socket_base_module_socket_private:
  description: "socket.socket.__bases__[0].__module__.__eq__('_socket') == True — '_socket' (7 chars = '_'=1 + 'socket'=6; private C extension from Modules/socketmodule.c; base class is _socket.socket; base.__name__=='socket'(6 chars — same as Python subclass) but base.__module__=='_socket'(7 chars — private C extension, 1 char longer due to '_' prefix); socket.socket.__module__=='socket'(6 chars; public) vs base.__module__=='_socket'(7 chars; private — the two classes are distinguished by their __module__); first sockfn168 standalone for socket.__bases__[0].__module__"
  category: identity
  kind: python_call_eq
  function: "socket.__bases__[0].__module__.__eq__"
  args: ["_socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.create_connection.__name__.__eq__('create_connection') — standalone
#
# socket.create_connection.__name__ is 'create_connection' (17 chars). create_connection
# is a high-level TCP client convenience function. 'create_connection' (17 chars) = 'create'=6 +
# '_connection'=11. It is the longest module-level socket function name in this spec.
# create_connection handles address resolution (via getaddrinfo), timeout, and connection
# setup. Added in Python 2.6. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra168.create_connection_name_eq:
  description: "socket.create_connection.__name__.__eq__('create_connection') == True — 'create_connection' (17 chars = 'create'=6 + '_connection'=11; high-level TCP client; added Python 2.6; handles getaddrinfo/timeout/connect; create_connection.__module__=='socket'(6); create_connection.__class__.__name__=='function'(8); longest name in spec: 'create_connection'(17) > 'create_server'(13) > 'getaddrinfo'(11); first sockfn168 standalone for create_connection.__name__"
  category: identity
  kind: python_call_eq
  function: create_connection.__name__.__eq__
  args: ["create_connection"]
  expected: true

# ---------------------------------------------------------------------------
# socket.create_connection.__module__.__eq__('socket') — standalone
#
# socket.create_connection.__module__ is 'socket' (6 chars). create_connection is a pure
# Python function defined in Lib/socket.py. Its __module__ is 'socket' (6 chars — the
# public module name). All three module-level convenience functions in this spec
# (create_connection, create_server, getaddrinfo) share __module__ == 'socket' (6 chars).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra168.create_connection_module_eq:
  description: "socket.create_connection.__module__.__eq__('socket') == True — 'socket' (6 chars; pure Python in Lib/socket.py; all three module-level functions in this spec share __module__=='socket'(6 chars): create_connection/create_server/getaddrinfo; 'socket'(6) < 'create_connection'(17) by 11 chars — module name much shorter than function name; create_connection.__class__.__name__=='function'(8); first sockfn168 standalone for create_connection.__module__"
  category: identity
  kind: python_call_eq
  function: create_connection.__module__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.create_server.__name__.__eq__('create_server') — standalone
#
# socket.create_server.__name__ is 'create_server' (13 chars). create_server is a high-level
# TCP server convenience function. 'create_server' (13 chars) = 'create'=6 + '_server'=7.
# It creates a listening TCP socket in one call (handles socket(), bind(), listen()).
# Added in Python 3.8. 'create_server'(13) shares the same 13-char length as
# socket.AddressFamily.__name__ ('AddressFamily' = 13 chars) — a coincidental match.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra168.create_server_name_eq:
  description: "socket.create_server.__name__.__eq__('create_server') == True — 'create_server' (13 chars = 'create'=6 + '_server'=7; high-level TCP server creator; added Python 3.8; handles socket/bind/listen; create_server.__module__=='socket'(6); create_server.__class__.__name__=='function'(8); 'create_server'(13) == AddressFamily.__name__.__len__()==13 — coincidental same 13-char length; 'create_server'(13) < 'create_connection'(17) by 4; first sockfn168 standalone for create_server.__name__"
  category: identity
  kind: python_call_eq
  function: create_server.__name__.__eq__
  args: ["create_server"]
  expected: true

# ---------------------------------------------------------------------------
# socket.create_server.__module__.__eq__('socket') — standalone
#
# socket.create_server.__module__ is 'socket' (6 chars). create_server is a pure Python
# function defined in Lib/socket.py, added in Python 3.8. Its __module__ is 'socket'
# (the public module). create_server.__module__ (6 chars) == create_connection.__module__
# (6 chars) == getaddrinfo.__module__ (6 chars) — all three convenience functions share
# the same 6-char module name. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra168.create_server_module_eq:
  description: "socket.create_server.__module__.__eq__('socket') == True — 'socket' (6 chars; pure Python in Lib/socket.py; added Python 3.8); create_server.__module__(6)==create_connection.__module__(6)==getaddrinfo.__module__(6)=='socket'(6) — all three share same module; 'socket'(6) < 'create_server'(13) by 7 chars; create_server.__class__.__name__=='function'(8); first sockfn168 standalone for create_server.__module__"
  category: identity
  kind: python_call_eq
  function: create_server.__module__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.getaddrinfo.__name__.__eq__('getaddrinfo') — standalone
#
# socket.getaddrinfo.__name__ is 'getaddrinfo' (11 chars). getaddrinfo is the primary
# address resolution function in Python's socket module. 'getaddrinfo' (11 chars) = 'get'=3 +
# 'addr'=4 + 'info'=4 = 11. It resolves host/port to a list of (family, type, proto,
# canonname, sockaddr) 5-tuples. On Python 3.14.3 macOS, getaddrinfo is a pure Python wrapper
# (not a C builtin). 'getaddrinfo'(11) is the shortest name among the three convenience
# functions in this spec. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra168.getaddrinfo_name_eq:
  description: "socket.getaddrinfo.__name__.__eq__('getaddrinfo') == True — 'getaddrinfo' (11 chars = 'get'=3 + 'addr'=4 + 'info'=4; primary address resolver; resolves host/port to list of 5-tuples (family/type/proto/canonname/sockaddr); pure Python wrapper on Python 3.14.3 macOS); getaddrinfo.__module__=='socket'(6); getaddrinfo.__class__.__name__=='function'(8); 'getaddrinfo'(11) < 'create_server'(13) < 'create_connection'(17) — ascending name length ordering; first sockfn168 standalone for getaddrinfo.__name__"
  category: identity
  kind: python_call_eq
  function: getaddrinfo.__name__.__eq__
  args: ["getaddrinfo"]
  expected: true

# ---------------------------------------------------------------------------
