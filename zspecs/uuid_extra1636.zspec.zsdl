spec: uuid_extra1636
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
    - "CPython source: Lib/uuid.py"
  notes:
    - "behavioral invariants for ABC virtual subclassing protocol"
    - "uuid.UUID is a plain Python class, not an ABC; it does not define __subclasshook__, __instancecheck__, or __subclasscheck__."
    - "uuid.SafeUUID is an Enum subclass; it also does not define __subclasshook__ in its own __dict__."
    - "isinstance(uuid.UUID(int=0), uuid.UUID) is True via normal class machinery."
    - "isinstance(uuid.SafeUUID.safe, uuid.SafeUUID) is True — enum members are instances of their enum class."
    - "isinstance(uuid.SafeUUID.safe, enum.Enum) is True — SafeUUID inherits from Enum."
    - "uuid.NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID, NAMESPACE_X500 are pre-defined UUID instances."
    - "issubclass(uuid.SafeUUID, uuid.SafeUUID) is True — every class is a subclass of itself."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: uuid.UUID and uuid.SafeUUID __dict__ does not contain ABC hooks
#
# uuid.UUID is a plain Python class defined in Lib/uuid.py; it does not
# define __subclasshook__, __instancecheck__, or __subclasscheck__.
# uuid.SafeUUID is an IntEnum; its own __dict__ also lacks these hooks
# (they are provided by EnumType/EnumMeta on the metaclass, not the class).
# ---------------------------------------------------------------------------

table uuid_extra1636.uuid_no_virtual_subclassing:
  description: "uuid.UUID and uuid.SafeUUID do not define ABC virtual-subclassing hooks in their __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1636

  columns: [id, function, args, expected]
  rows:
    - ["uu1636001", "UUID.__dict__.__contains__",     ["__subclasshook__"],  false]
    - ["uu1636002", "UUID.__dict__.__contains__",     ["__instancecheck__"], false]
    - ["uu1636003", "UUID.__dict__.__contains__",     ["__subclasscheck__"], false]
    - ["uu1636004", "SafeUUID.__dict__.__contains__", ["__subclasshook__"],  false]
    - ["uu1636005", "SafeUUID.__dict__.__contains__", ["__instancecheck__"], false]
    - ["uu1636006", "SafeUUID.__dict__.__contains__", ["__subclasscheck__"], false]
    - ["uu1636007", "UUID.__dict__.__contains__",     ["__init__"],          true]
    - ["uu1636008", "UUID.__dict__.__contains__",     ["__str__"],           true]
    - ["uu1636009", "UUID.__dict__.__contains__",     ["__eq__"],            true]
    - ["uu1636010", "UUID.__dict__.__contains__",     ["__hash__"],          true]
    - ["uu1636011", "UUID.__dict__.__contains__",     ["int"],               true]
    - ["uu1636012", "UUID.__dict__.__contains__",     ["hex"],               true]
    - ["uu1636013", "UUID.__dict__.__contains__",     ["version"],           true]
    - ["uu1636014", "UUID.__name__.__eq__",           ["UUID"],              true]
    - ["uu1636015", "UUID.__module__.__eq__",         ["uuid"],              true]
    - ["uu1636016", "SafeUUID.__name__.__eq__",       ["SafeUUID"],          true]
    - ["uu1636017", "SafeUUID.__module__.__eq__",     ["uuid"],              true]
    - ["uu1636018", "UUID.__bases__.__getitem__",     [0],                   "object"]
    - ["uu1636019", "SafeUUID.__bases__.__getitem__", [0],                   "IntEnum"]

# ---------------------------------------------------------------------------
# Table 2: isinstance / issubclass checks for uuid.UUID and uuid.SafeUUID
#
# uuid.UUID(int=0) constructs the nil UUID. isinstance checks confirm normal
# class membership; issubclass confirms class hierarchy relationships.
# Every class is trivially a subclass of itself and of object.
# ---------------------------------------------------------------------------

table uuid_extra1636.uuid_isinstance_checks:
  description: "isinstance and issubclass checks for uuid.UUID and uuid.SafeUUID via normal object machinery"
  kind: python_call_eq
  category: isinstance_issubclass
  id_prefix: uu1636

  columns: [id, function, args, expected]
  rows:
    - ["uu1636020", "UUID.__bases__.__len__",                                [],        1]
    - ["uu1636021", "UUID.__mro__.__len__",                                  [],        2]
    - ["uu1636022", "UUID.__mro__.__getitem__",                              [0],       "UUID"]
    - ["uu1636023", "UUID.__mro__.__getitem__",                              [1],       "object"]
    - ["uu1636024", "SafeUUID.__bases__.__len__",                            [],        1]
    - ["uu1636025", "SafeUUID.__mro__.__len__",                              [],        7]
    - ["uu1636026", "SafeUUID.__mro__.__contains__",                         ["Enum"],  false]
    - ["uu1636027", "SafeUUID.__subclasshook__.__class__.__name__.__eq__",   ["method"], false]
    - ["uu1636028", "UUID.__dict__.__contains__",                            ["__repr__"], true]
    - ["uu1636029", "UUID.__dict__.__contains__",                            ["bytes"],  true]
    - ["uu1636030", "UUID.__dict__.__contains__",                            ["fields"], true]
    - ["uu1636031", "UUID.__dict__.__contains__",                            ["time_low"], false]
    - ["uu1636032", "SafeUUID.__dict__.__contains__",                        ["safe"],   true]
    - ["uu1636033", "SafeUUID.__dict__.__contains__",                        ["unsafe"], true]
    - ["uu1636034", "SafeUUID.safe.__class__.__name__.__eq__",               ["SafeUUID"], true]
    - ["uu1636035", "SafeUUID.unsafe.__class__.__name__.__eq__",             ["SafeUUID"], true]
    - ["uu1636036", "SafeUUID.safe.__class__.__bases__.__getitem__",         [0],        "IntEnum"]
    - ["uu1636037", "UUID.__class__.__name__.__eq__",                        ["type"],   true]
    - ["uu1636038", "SafeUUID.__class__.__name__.__eq__",                    ["EnumType"], true]

# ---------------------------------------------------------------------------
# Table 3: uuid NAMESPACE_* constants are UUID instances
#
# NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID, NAMESPACE_X500 are module-level
# UUID objects. Their __class__.__name__ == 'UUID' and they compare unequal to
# each other (each is a distinct well-known UUID).
# ---------------------------------------------------------------------------

table uuid_extra1636.uuid_namespace_constants:
  description: "uuid.NAMESPACE_* constants are UUID instances with distinct values"
  kind: python_call_eq
  category: namespace_constants
  id_prefix: uu1636

  columns: [id, function, args, expected]
  rows:
    - ["uu1636039", "NAMESPACE_DNS.__class__.__name__.__eq__",  ["UUID"], true]
    - ["uu1636040", "NAMESPACE_URL.__class__.__name__.__eq__",  ["UUID"], true]
    - ["uu1636041", "NAMESPACE_OID.__class__.__name__.__eq__",  ["UUID"], true]
    - ["uu1636042", "NAMESPACE_X500.__class__.__name__.__eq__", ["UUID"], true]
    - ["uu1636043", "NAMESPACE_DNS.__class__.__bases__.__getitem__",  [0], "object"]
    - ["uu1636044", "NAMESPACE_URL.__class__.__bases__.__getitem__",  [0], "object"]
    - ["uu1636045", "NAMESPACE_OID.__class__.__bases__.__getitem__",  [0], "object"]
    - ["uu1636046", "NAMESPACE_X500.__class__.__bases__.__getitem__", [0], "object"]
    - ["uu1636047", "NAMESPACE_DNS.__class__.__dict__.__contains__",  ["__subclasshook__"],  false]
    - ["uu1636048", "NAMESPACE_DNS.__class__.__dict__.__contains__",  ["__instancecheck__"], false]
    - ["uu1636049", "NAMESPACE_DNS.__class__.__dict__.__contains__",  ["__subclasscheck__"], false]
    - ["uu1636050", "NAMESPACE_DNS.version.__eq__",                   [1],  true]
    - ["uu1636051", "NAMESPACE_URL.version.__eq__",                   [1],  true]
    - ["uu1636052", "NAMESPACE_OID.version.__eq__",                   [1],  true]
    - ["uu1636053", "NAMESPACE_X500.version.__eq__",                  [1],  true]
    - ["uu1636054", "NAMESPACE_DNS.__eq__",  ["6ba7b810-9dad-11d1-80b4-00c04fd430c8"], false]
    - ["uu1636055", "NAMESPACE_DNS.hex.__len__",                      [],   32]
    - ["uu1636056", "NAMESPACE_URL.hex.__len__",                      [],   32]
    - ["uu1636057", "NAMESPACE_OID.hex.__len__",                      [],   32]
    - ["uu1636058", "NAMESPACE_X500.hex.__len__",                     [],   32]
