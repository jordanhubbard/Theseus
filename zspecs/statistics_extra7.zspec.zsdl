spec: statistics_extra7
version: ">=3.8"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html — Python statistics documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
  notes:
    - "This spec extends statistics.zspec.zsdl and prior extras (statistics_extra through statistics_extra6)."
    - "statistics_extra2 covers: mean/median/stdev/variance/mode __module__."
    - "statistics_extra4 covers: fmean/geometric_mean/harmonic_mean/variance/stdev __module__ (table); pstdev/pvariance __name__ but NOT __module__."
    - "statistics_extra5 covers: NormalDist.__module__, StatisticsError.__module__."
    - "Not yet covered: pstdev/pvariance/median_low/median_high/multimode/quantiles __module__."
    - "Not yet covered: NormalDist MRO length and MRO entries beyond [0]."
    - "Not yet covered: median_grouped computation; fmean single element; harmonic_mean additional data vectors; pvariance/pstdev distinct datasets."
    - "statistics.pstdev.__module__ == 'statistics'."
    - "statistics.pvariance.__module__ == 'statistics'."
    - "statistics.median_low.__module__ == 'statistics'."
    - "statistics.median_high.__module__ == 'statistics'."
    - "statistics.multimode.__module__ == 'statistics'."
    - "statistics.quantiles.__module__ == 'statistics'."
    - "statistics.NormalDist.__mro__.__len__() == 2 — [NormalDist, object]."
    - "statistics.NormalDist.__mro__[1].__name__ == 'object' — second MRO entry is object."
    - "statistics.NormalDist.__bases__.__len__() == 1 — NormalDist has a single direct base."
    - "statistics.median_grouped([1, 2, 2, 3]) == 2.0 — grouped median of [1,2,2,3] with default interval 1."
    - "statistics.fmean([5]) == 5.0 — fmean of a single-element list."
    - "statistics.harmonic_mean([2, 8]) == 3.2 — harmonic mean of 2 and 8."
    - "statistics.pvariance([1, 2, 3]) == 0.6666... — population variance of [1,2,3]."
    - "statistics.pstdev([1, 2, 3]) == 0.8164... — population stdev of [1,2,3]."
    - "statistics.fmean([]) raises StatisticsError — empty input not allowed."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ checks for functions not yet covered
# statistics_extra2 covers mean/median/stdev/variance/mode.
# statistics_extra4 covers fmean/geometric_mean/harmonic_mean/variance/stdev.
# New here: pstdev, pvariance, median_low, median_high, multimode, quantiles.
# ---------------------------------------------------------------------------

table statistics_extra7.function_modules:
  kind: python_call_eq
  category: function_module
  id_prefix: mod

  columns: [id, function, args, expected]
  rows:
    - [pstdev,      pstdev.__module__.__eq__,      ["statistics"], true]
    - [pvariance,   pvariance.__module__.__eq__,   ["statistics"], true]
    - [median_low,  median_low.__module__.__eq__,  ["statistics"], true]
    - [median_high, median_high.__module__.__eq__, ["statistics"], true]
    - [multimode,   multimode.__module__.__eq__,   ["statistics"], true]
    - [quantiles,   quantiles.__module__.__eq__,   ["statistics"], true]

# ---------------------------------------------------------------------------
# NormalDist MRO and bases
# statistics_extra2 covers NormalDist.__bases__[0].__name__ == 'object'.
# statistics_extra6 covers NormalDist.__bases__[0].__name__ via __name__.__eq__ style.
# New here: __mro__.__len__, __mro__[1].__name__, __bases__.__len__.
# ---------------------------------------------------------------------------

invariant statistics_extra7.NormalDist.mro_len:
  description: "statistics.NormalDist.__mro__.__len__() == 2 — MRO is [NormalDist, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: NormalDist.__mro__.__len__
  args: []
  expected: 2

invariant statistics_extra7.NormalDist.mro_1_object:
  description: "statistics.NormalDist.__mro__[1].__name__ == 'object' — second MRO entry is object"
  category: class_hierarchy
  kind: python_call_eq
  function: NormalDist.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "object"

invariant statistics_extra7.NormalDist.bases_len:
  description: "statistics.NormalDist.__bases__.__len__() == 1 — NormalDist has exactly one direct base class"
  category: class_hierarchy
  kind: python_call_eq
  function: NormalDist.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# median_grouped — grouped median computation (Python 3.8+)
# No prior statistics spec covers median_grouped computation.
# median_grouped([1, 2, 2, 3]) with default interval=1 gives 2.0.
# ---------------------------------------------------------------------------

invariant statistics_extra7.median_grouped.basic:
  description: "statistics.median_grouped([1, 2, 2, 3]) == 2.0 — grouped median with default interval"
  category: median_grouped
  kind: python_call_eq
  function: median_grouped
  args: [[1, 2, 2, 3]]
  expected: 2.0

invariant statistics_extra7.median_grouped.single:
  description: "statistics.median_grouped([5]) == 5.0 — grouped median of a single value"
  category: median_grouped
  kind: python_call_eq
  function: median_grouped
  args: [[5]]
  expected: 5.0

# ---------------------------------------------------------------------------
# fmean — additional vectors
# statistics.zspec covers fmean([1,2,3])==2.0; extra3 covers [2.0,4.0]==3.0.
# New here: single-element list.
# ---------------------------------------------------------------------------

invariant statistics_extra7.fmean.single_element:
  description: "statistics.fmean([5]) == 5.0 — fmean of a single-element list returns that element as float"
  category: fmean
  kind: python_call_eq
  function: fmean
  args: [[5]]
  expected: 5.0

# ---------------------------------------------------------------------------
# harmonic_mean — additional data vectors
# statistics.zspec does not test harmonic_mean; extra2 checks return type.
# extra4 checks a value vector not specified here.
# New here: harmonic_mean([2, 8]).
# harmonic_mean([2, 8]) = 2 / (1/2 + 1/8) = 2 / (5/8) = 16/5 = 3.2
# ---------------------------------------------------------------------------

invariant statistics_extra7.harmonic_mean.two_eight:
  description: "statistics.harmonic_mean([2, 8]) == 3.2 — H([2,8]) = 2/(1/2+1/8) = 16/5 = 3.2"
  category: harmonic_mean
  kind: python_call_eq
  function: harmonic_mean
  args: [[2, 8]]
  expected: 3.2

# ---------------------------------------------------------------------------
# pvariance / pstdev — new data vectors
# statistics.zspec covers pvariance([2,4,4,4,5,5,7,9])==4 and pstdev==2.0.
# New here: simpler dataset [1, 2, 3].
# pvariance([1,2,3]) = ((0-2)^2 + (1-2)^2 + (2-2)^2)/3 ... actually:
#   mean=2, deviations: -1, 0, 1; pvariance = (1+0+1)/3 = 2/3 ≈ 0.6667
#   pstdev = sqrt(2/3) ≈ 0.816496...
# ---------------------------------------------------------------------------

invariant statistics_extra7.pvariance.simple:
  description: "statistics.pvariance([1, 2, 3]) == 2/3 — population variance of arithmetic sequence"
  category: pvariance
  kind: python_call_eq
  function: pvariance
  args: [[1, 2, 3]]
  expected: 0.6666666666666666

invariant statistics_extra7.pstdev.simple:
  description: "statistics.pstdev([1, 2, 3]) == sqrt(2/3) — population stdev of arithmetic sequence"
  category: pstdev
  kind: python_call_eq
  function: pstdev
  args: [[1, 2, 3]]
  expected: 0.816496580927726

# ---------------------------------------------------------------------------
# fmean error case — empty list raises StatisticsError
# Not covered in any prior statistics spec.
# ---------------------------------------------------------------------------

invariant statistics_extra7.fmean.empty_raises:
  description: "statistics.fmean([]) raises StatisticsError — fmean requires at least one data point"
  category: error
  kind: python_call_raises
  function: fmean
  args: [[]]
  expected_exception: StatisticsError
