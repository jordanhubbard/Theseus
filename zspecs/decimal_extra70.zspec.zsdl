spec: decimal_extra70
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal.zspec.zsdl and all prior decimal_extra specs through decimal_extra69."
    - "Prior specs covered: Decimal arithmetic; exception class __qualname__; getcontext/setcontext identity; Decimal/__dict__ membership; MAX_PREC/MAX_EMAX; exception hierarchy __bases__ and MRO; Decimal C slot wrapper identity; Context identity; Context/__dict__ membership; exception class __name__ identity."
    - "decimal_extra69 covers Context.__dict__ membership (quantize, clear_flags); DecimalException/InvalidOperation/Overflow MRO depths; Clamped/Inexact/Rounded/Subnormal class __name__ values."
    - "This spec covers: Decimal.__dict__.__contains__ for __sub__/__neg__/__abs__/__bool__/__float__/__int__; signal class hierarchy — Inexact/Rounded/Subnormal/Clamped __bases__[0].__name__ == 'DecimalException'."
    - "decimal.Decimal.__dict__.__contains__('__sub__') == True — Decimal C type defines __sub__ directly."
    - "decimal.Decimal.__dict__.__contains__('__neg__') == True — Decimal C type defines __neg__ directly."
    - "decimal.Decimal.__dict__.__contains__('__abs__') == True — Decimal C type defines __abs__ directly."
    - "decimal.Decimal.__dict__.__contains__('__bool__') == True — Decimal C type defines __bool__ directly."
    - "decimal.Decimal.__dict__.__contains__('__float__') == True — Decimal C type defines __float__ directly."
    - "decimal.Decimal.__dict__.__contains__('__int__') == True — Decimal C type defines __int__ directly."
    - "decimal.Inexact.__bases__[0].__name__ == 'DecimalException' — Inexact directly subclasses DecimalException."
    - "decimal.Rounded.__bases__[0].__name__ == 'DecimalException' — Rounded directly subclasses DecimalException."
    - "decimal.Subnormal.__bases__[0].__name__ == 'DecimalException' — Subnormal directly subclasses DecimalException."
    - "decimal.Clamped.__bases__[0].__name__ == 'DecimalException' — Clamped directly subclasses DecimalException."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal.__dict__ membership for arithmetic dunder methods
# Decimal is a C extension type in _decimal; all arithmetic dunders are
# defined directly in its __dict__.  __sub__, __neg__, __abs__ cover
# subtraction and unary operators.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra70.Decimal_dict_arithmetic:
  description: "Decimal.__dict__ contains __sub__, __neg__, __abs__"
  kind: python_call_eq
  category: class_dict
  id_prefix: decimalmore70

  columns: [id, function, args, expected]
  rows:
    - [has_sub,  "Decimal.__dict__.__contains__", ["__sub__"], true]
    - [has_neg,  "Decimal.__dict__.__contains__", ["__neg__"], true]
    - [has_abs,  "Decimal.__dict__.__contains__", ["__abs__"], true]

# ---------------------------------------------------------------------------
# Decimal.__dict__ membership for type-conversion dunder methods
# __bool__, __float__, __int__ are defined directly on the C Decimal type.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra70.Decimal_dict_conversion:
  description: "Decimal.__dict__ contains __bool__, __float__, __int__"
  kind: python_call_eq
  category: class_dict
  id_prefix: decimalmore70

  columns: [id, function, args, expected]
  rows:
    - [has_bool,  "Decimal.__dict__.__contains__", ["__bool__"],  true]
    - [has_float, "Decimal.__dict__.__contains__", ["__float__"], true]
    - [has_int,   "Decimal.__dict__.__contains__", ["__int__"],   true]

# ---------------------------------------------------------------------------
# Signal class hierarchy — Inexact and Rounded
# Both Inexact and Rounded are direct subclasses of DecimalException.
# Function values containing [ must be double-quoted.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra70.signal_bases_inexact_rounded:
  description: "Inexact and Rounded __bases__[0].__name__ == 'DecimalException'"
  kind: python_call_eq
  category: class_bases
  id_prefix: decimalmore70

  columns: [id, function, args, expected]
  rows:
    - [inexact_base,  "Inexact.__bases__[0].__name__.__eq__",  ["DecimalException"], true]
    - [rounded_base,  "Rounded.__bases__[0].__name__.__eq__",  ["DecimalException"], true]

# ---------------------------------------------------------------------------
# Signal class hierarchy — Subnormal and Clamped
# Both Subnormal and Clamped are direct subclasses of DecimalException.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra70.signal_bases_subnormal_clamped:
  description: "Subnormal and Clamped __bases__[0].__name__ == 'DecimalException'"
  kind: python_call_eq
  category: class_bases
  id_prefix: decimalmore70

  columns: [id, function, args, expected]
  rows:
    - [subnormal_base, "Subnormal.__bases__[0].__name__.__eq__", ["DecimalException"], true]
    - [clamped_base,   "Clamped.__bases__[0].__name__.__eq__",   ["DecimalException"], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra70.Decimal_dict.has_sub:
  description: "decimal.Decimal.__dict__.__contains__('__sub__') == True"
  category: class_dict
  kind: python_call_eq
  function: "Decimal.__dict__.__contains__"
  args: ["__sub__"]
  expected: true

invariant decimal_extra70.Decimal_dict.has_neg:
  description: "decimal.Decimal.__dict__.__contains__('__neg__') == True"
  category: class_dict
  kind: python_call_eq
  function: "Decimal.__dict__.__contains__"
  args: ["__neg__"]
  expected: true

invariant decimal_extra70.Decimal_dict.has_bool:
  description: "decimal.Decimal.__dict__.__contains__('__bool__') == True"
  category: class_dict
  kind: python_call_eq
  function: "Decimal.__dict__.__contains__"
  args: ["__bool__"]
  expected: true

invariant decimal_extra70.Inexact.base_is_DecimalException:
  description: "decimal.Inexact.__bases__[0].__name__ == 'DecimalException'"
  category: class_bases
  kind: python_call_eq
  function: "Inexact.__bases__[0].__name__.__eq__"
  args: ["DecimalException"]
  expected: true

invariant decimal_extra70.Clamped.base_is_DecimalException:
  description: "decimal.Clamped.__bases__[0].__name__ == 'DecimalException'"
  category: class_bases
  kind: python_call_eq
  function: "Clamped.__bases__[0].__name__.__eq__"
  args: ["DecimalException"]
  expected: true
