spec: threading_extra2386
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/threading.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 606 (_extra2386): __str__ and __repr__ implementation type classification."
    - "Python-defined __repr__ returns 'function'; C-level or inherited from object returns 'wrapper_descriptor'."
    - "threading.Thread, Event, Condition, Semaphore, Barrier all define __repr__ in Python → 'function'."
    - "threading.local is a C-level type (_thread.local); both __repr__ and __str__ are 'wrapper_descriptor'."
    - "All Python threading classes inherit __str__ from object → 'wrapper_descriptor'."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table threading_extra2386.repr_class_names:
  description: "threading class __repr__ implementation type via .__repr__.__class__.__name__"
  kind: python_call_eq
  category: type_identity
  id_prefix: th2386
  columns: [id, function, args, expected]
  rows:
    - ["th2386001", "threading.Thread.__repr__.__class__.__name__", [], "function"]
    - ["th2386002", "threading.Event.__repr__.__class__.__name__", [], "function"]
    - ["th2386003", "threading.Condition.__repr__.__class__.__name__", [], "function"]
    - ["th2386004", "threading.Semaphore.__repr__.__class__.__name__", [], "function"]
    - ["th2386005", "threading.Barrier.__repr__.__class__.__name__", [], "function"]
    - ["th2386006", "threading.local.__repr__.__class__.__name__", [], "wrapper_descriptor"]

table threading_extra2386.str_class_names:
  description: "threading class __str__ implementation type via .__str__.__class__.__name__"
  kind: python_call_eq
  category: type_identity
  id_prefix: th2386
  columns: [id, function, args, expected]
  rows:
    - ["th2386007", "threading.Thread.__str__.__class__.__name__", [], "wrapper_descriptor"]
    - ["th2386008", "threading.Event.__str__.__class__.__name__", [], "wrapper_descriptor"]
    - ["th2386009", "threading.Condition.__str__.__class__.__name__", [], "wrapper_descriptor"]
    - ["th2386010", "threading.Semaphore.__str__.__class__.__name__", [], "wrapper_descriptor"]
    - ["th2386011", "threading.Barrier.__str__.__class__.__name__", [], "wrapper_descriptor"]
    - ["th2386012", "threading.local.__str__.__class__.__name__", [], "wrapper_descriptor"]

table threading_extra2386.python_classes_repr_eq_function:
  description: "Pure-Python threading classes define __repr__ in Python → __repr__.__class__.__name__ == 'function'"
  kind: python_call_eq
  category: type_identity
  id_prefix: th2386
  columns: [id, function, args, expected]
  rows:
    - ["th2386013", "threading.Thread.__repr__.__class__.__name__.__eq__", ["function"], true]
    - ["th2386014", "threading.Event.__repr__.__class__.__name__.__eq__", ["function"], true]
    - ["th2386015", "threading.Condition.__repr__.__class__.__name__.__eq__", ["function"], true]
    - ["th2386016", "threading.Semaphore.__repr__.__class__.__name__.__eq__", ["function"], true]
    - ["th2386017", "threading.Barrier.__repr__.__class__.__name__.__eq__", ["function"], true]

table threading_extra2386.local_c_type_eq_wrapper_descriptor:
  description: "threading.local is a C-level type; both __repr__ and __str__ are 'wrapper_descriptor'"
  kind: python_call_eq
  category: type_identity
  id_prefix: th2386
  columns: [id, function, args, expected]
  rows:
    - ["th2386018", "threading.local.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["th2386019", "threading.local.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]

table threading_extra2386.all_str_eq_wrapper_descriptor:
  description: "All threading classes (Python and C) inherit __str__ from object → 'wrapper_descriptor'"
  kind: python_call_eq
  category: type_identity
  id_prefix: th2386
  columns: [id, function, args, expected]
  rows:
    - ["th2386020", "threading.Thread.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["th2386021", "threading.Event.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["th2386022", "threading.Condition.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["th2386023", "threading.Semaphore.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["th2386024", "threading.Barrier.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["th2386025", "threading.local.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
