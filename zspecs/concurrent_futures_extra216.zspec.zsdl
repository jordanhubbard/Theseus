spec: concurrent_futures_extra216
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "concurrent.futures.Future.__module__ == 'concurrent.futures._base' — defined in the private _base submodule."
    - "concurrent.futures.Future.__bases__[0].__name__ == 'object' — Future is a top-level class."
    - "concurrent.futures.CancelledError.__module__ == 'concurrent.futures._base' on CPython 3.14."
    - "concurrent.futures.TimeoutError.__module__ == 'builtins' on CPython 3.14 — aliased from builtins."
    - "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base'."
    - "concurrent.futures.InvalidStateError.__module__ == 'concurrent.futures._base'."
    - "Future.cancel and Future.result have qualnames 'Future.cancel' and 'Future.result'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

