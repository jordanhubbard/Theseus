    - [future_name,   concurrent.futures.Future.__name__.__eq__,   ["Future"],                      true, "concurrent.futures.Future.__name__ == 'Future'"]
    - [future_module, concurrent.futures.Future.__module__.__eq__, ["concurrent.futures._base"],    true, "concurrent.futures.Future.__module__ == 'concurrent.futures._base'"]

invariant concurrent_futures_extra216.future_base_name:
  description: "concurrent.futures.Future.__bases__[0].__name__ == 'object'"
