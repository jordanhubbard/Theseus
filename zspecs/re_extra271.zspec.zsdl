spec: re_extra271
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "re.Match is a C-extension class; its methods are method_descriptor objects."
    - "re.Match methods: group, groups, groupdict, start, end, span, expand all have __class__.__name__ == 'method_descriptor'."
    - "re.Match method qualnames follow 'Match.<method_name>' pattern."
    - "re.Match.__name__ == 'Match' and re.Match.__module__ == 're'."
    - "re.Match.re and re.Match.string are member_descriptor objects (C-level slot attributes)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: re.Match method __name__ identity
# ---------------------------------------------------------------------------

table re_extra271.match_method_names:
  description: "re.Match method __name__ for group, groups, groupdict, start, end, span, expand"
  kind: python_call_eq
  category: identity
  id_prefix: nm

  columns: [id, function, args, expected, description]
  rows:
    - [group_name,     Match.group.__name__.__eq__,     ["group"],     true, "re.Match.group.__name__ == 'group'"]
    - [groups_name,    Match.groups.__name__.__eq__,    ["groups"],    true, "re.Match.groups.__name__ == 'groups'"]
    - [groupdict_name, Match.groupdict.__name__.__eq__, ["groupdict"], true, "re.Match.groupdict.__name__ == 'groupdict'"]
    - [start_name,     Match.start.__name__.__eq__,     ["start"],     true, "re.Match.start.__name__ == 'start'"]
    - [end_name,       Match.end.__name__.__eq__,       ["end"],       true, "re.Match.end.__name__ == 'end'"]
    - [span_name,      Match.span.__name__.__eq__,      ["span"],      true, "re.Match.span.__name__ == 'span'"]
    - [expand_name,    Match.expand.__name__.__eq__,    ["expand"],    true, "re.Match.expand.__name__ == 'expand'"]

# ---------------------------------------------------------------------------
# Table: re.Match method __class__.__name__ (all method_descriptor)
# ---------------------------------------------------------------------------

table re_extra271.match_method_classes:
  description: "re.Match method __class__.__name__ for group, groups, groupdict, start, end, span, expand (all method_descriptor)"
  kind: python_call_eq
  category: identity
  id_prefix: cls

  columns: [id, function, args, expected, description]
  rows:
    - [group_class,     Match.group.__class__.__name__.__eq__,     ["method_descriptor"], true, "re.Match.group.__class__.__name__ == 'method_descriptor'"]
    - [groups_class,    Match.groups.__class__.__name__.__eq__,    ["method_descriptor"], true, "re.Match.groups.__class__.__name__ == 'method_descriptor'"]
    - [groupdict_class, Match.groupdict.__class__.__name__.__eq__, ["method_descriptor"], true, "re.Match.groupdict.__class__.__name__ == 'method_descriptor'"]
    - [start_class,     Match.start.__class__.__name__.__eq__,     ["method_descriptor"], true, "re.Match.start.__class__.__name__ == 'method_descriptor'"]
    - [end_class,       Match.end.__class__.__name__.__eq__,       ["method_descriptor"], true, "re.Match.end.__class__.__name__ == 'method_descriptor'"]
    - [span_class,      Match.span.__class__.__name__.__eq__,      ["method_descriptor"], true, "re.Match.span.__class__.__name__ == 'method_descriptor'"]
    - [expand_class,    Match.expand.__class__.__name__.__eq__,    ["method_descriptor"], true, "re.Match.expand.__class__.__name__ == 'method_descriptor'"]

# ---------------------------------------------------------------------------
# Standalone invariants: qualnames and Match class identity
# ---------------------------------------------------------------------------

invariant re_extra271.Match.group.qualname:
  description: "re.Match.group.__qualname__ == 'Match.group'"
  category: identity
  kind: python_call_eq
  function: Match.group.__qualname__.__eq__
  args: ["Match.group"]
  expected: true

invariant re_extra271.Match.groups.qualname:
  description: "re.Match.groups.__qualname__ == 'Match.groups'"
  category: identity
  kind: python_call_eq
  function: Match.groups.__qualname__.__eq__
  args: ["Match.groups"]
  expected: true

invariant re_extra271.Match.start.qualname:
  description: "re.Match.start.__qualname__ == 'Match.start'"
  category: identity
  kind: python_call_eq
  function: Match.start.__qualname__.__eq__
  args: ["Match.start"]
  expected: true

invariant re_extra271.Match.span.qualname:
  description: "re.Match.span.__qualname__ == 'Match.span'"
  category: identity
  kind: python_call_eq
  function: Match.span.__qualname__.__eq__
  args: ["Match.span"]
  expected: true

invariant re_extra271.Match.name:
  description: "re.Match.__name__ == 'Match'"
  category: identity
  kind: python_call_eq
  function: Match.__name__.__eq__
  args: ["Match"]
  expected: true

invariant re_extra271.Match.module:
  description: "re.Match.__module__ == 're'"
  category: identity
  kind: python_call_eq
  function: Match.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra271.Match.re.is_member_descriptor:
  description: "re.Match.re is a member_descriptor (C-level slot attribute)"
  category: identity
  kind: python_call_eq
  function: Match.re.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant re_extra271.Match.string.is_member_descriptor:
  description: "re.Match.string is a member_descriptor (C-level slot attribute)"
  category: identity
  kind: python_call_eq
  function: Match.string.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true
