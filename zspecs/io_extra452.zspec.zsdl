spec: io_extra452
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module concrete buffer class identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers BufferedReader, BufferedWriter, BufferedRandom, BufferedRWPair, TextIOWrapper, IncrementalNewlineDecoder class identity"
    - "All three buffered classes inherit from BufferedIOBase; TextIOWrapper inherits from TextIOBase"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra452.buffered_reader_identity:
  description: "io.BufferedReader class identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: BRD

  columns: [id, function, args, expected]
  rows:
    - [BRD001, io.BufferedReader.__name__.__eq__, ["BufferedReader"], true]
    - [BRD002, io.BufferedReader.__module__.__eq__, ["io"], true]

