spec: multiprocessing_extra2011
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/multiprocessing.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 581 (_extra2011): __add__/__radd__/__iadd__, __mul__/__rmul__/__imul__, __sub__/__rsub__/__isub__ dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "multiprocessing.Process and multiprocessing.synchronize types (Lock, Event, Semaphore, Barrier) do not define arithmetic operators; all checks return False."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __add__ / __radd__ / __iadd__ dict-presence for multiprocessing types
#
# None of Process, synchronize.Lock, synchronize.Event, synchronize.Semaphore,
# synchronize.Barrier define addition operators. All checks return False.
# ---------------------------------------------------------------------------

table multiprocessing_extra2011.add_protocol:
  description: "multiprocessing types __add__/__radd__/__iadd__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2011

  columns: [id, function, args, expected]
  rows:
    - ["mp2011001", "multiprocessing.Process.__dict__.__contains__",                ["__add__"],  false]
    - ["mp2011002", "multiprocessing.synchronize.Lock.__dict__.__contains__",       ["__add__"],  false]
    - ["mp2011003", "multiprocessing.synchronize.Event.__dict__.__contains__",      ["__add__"],  false]
    - ["mp2011004", "multiprocessing.synchronize.Semaphore.__dict__.__contains__",  ["__add__"],  false]
    - ["mp2011005", "multiprocessing.synchronize.Barrier.__dict__.__contains__",    ["__add__"],  false]
    - ["mp2011006", "multiprocessing.Process.__dict__.__contains__",                ["__radd__"], false]
    - ["mp2011007", "multiprocessing.synchronize.Lock.__dict__.__contains__",       ["__radd__"], false]
    - ["mp2011008", "multiprocessing.synchronize.Event.__dict__.__contains__",      ["__radd__"], false]
    - ["mp2011009", "multiprocessing.synchronize.Semaphore.__dict__.__contains__",  ["__radd__"], false]
    - ["mp2011010", "multiprocessing.synchronize.Barrier.__dict__.__contains__",    ["__radd__"], false]
    - ["mp2011011", "multiprocessing.Process.__dict__.__contains__",                ["__iadd__"], false]
    - ["mp2011012", "multiprocessing.synchronize.Lock.__dict__.__contains__",       ["__iadd__"], false]
    - ["mp2011013", "multiprocessing.synchronize.Event.__dict__.__contains__",      ["__iadd__"], false]
    - ["mp2011014", "multiprocessing.synchronize.Semaphore.__dict__.__contains__",  ["__iadd__"], false]
    - ["mp2011015", "multiprocessing.synchronize.Barrier.__dict__.__contains__",    ["__iadd__"], false]

