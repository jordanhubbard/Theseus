spec: numbers_extra7
version: ">=3.0"
backend: python_module(numbers)

docs: https://docs.python.org/3/library/numbers.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/numbers.html — Python numbers documentation"
    - "PEP 3141 — A Type Hierarchy for Numbers"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/numbers.py"
  notes:
    - "This spec extends numbers.zspec.zsdl and prior extras (numbers_extra through numbers_extra6)."
    - "numbers.zspec covers: all five __name__ and __module__ via tables."
    - "numbers_extra2 covers: Number/Complex/Real __module__ as invariants; Complex/Real __bases__[0].__name__ via __eq__ style."
    - "numbers_extra3 covers: all five __qualname__; Rational/Integral __module__ as invariants; Rational/Integral __bases__ via __eq__ style."
    - "numbers_extra6 covers: MRO self-entry [0] for all five via table; isinstance negative checks."
    - "NOT yet covered: Number.__name__ == 'Number' as a standalone invariant (numbers.zspec used a table row)."
    - "NOT yet covered: Complex.__name__ == 'Complex' as a standalone invariant."
    - "NOT yet covered: Real.__name__ == 'Real' as a standalone invariant."
    - "NOT yet covered: Rational.__name__ == 'Rational' as a standalone invariant."
    - "NOT yet covered: Integral.__name__ == 'Integral' as a standalone invariant."
    - "NOT yet covered: Number.__module__ == 'numbers' as a standalone invariant."
    - "NOT yet covered: Complex.__module__ == 'numbers' as a standalone invariant (extra2 covers this but as a different expression form check; here we use __eq__ style)."
    - "NOT yet covered: Real.__module__ == 'numbers' as a standalone __eq__ invariant."
    - "NOT yet covered: Rational.__module__ == 'numbers' as a standalone __eq__ invariant."
    - "NOT yet covered: Integral.__module__ == 'numbers' as a standalone __eq__ invariant."
    - "NOT yet covered: Complex.__bases__[0].__name__ == 'Number' as a standalone invariant."
    - "NOT yet covered: Real.__bases__[0].__name__ == 'Complex' as a standalone invariant."
    - "NOT yet covered: Rational.__bases__[0].__name__ == 'Real' as a standalone invariant."
    - "numbers.Number.__name__ == 'Number'."
    - "numbers.Complex.__name__ == 'Complex'."
    - "numbers.Real.__name__ == 'Real'."
    - "numbers.Rational.__name__ == 'Rational'."
    - "numbers.Integral.__name__ == 'Integral'."
    - "numbers.Number.__module__ == 'numbers'."
    - "numbers.Complex.__module__ == 'numbers'."
    - "numbers.Real.__module__ == 'numbers'."
    - "numbers.Rational.__module__ == 'numbers'."
    - "numbers.Integral.__module__ == 'numbers'."
    - "numbers.Complex.__bases__[0].__name__ == 'Number' — Complex directly extends Number."
    - "numbers.Real.__bases__[0].__name__ == 'Complex' — Real directly extends Complex."
    - "numbers.Rational.__bases__[0].__name__ == 'Real' — Rational directly extends Real."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ checks — invariant style
#
# numbers.zspec covers __name__ for all five classes via a table.
# This spec covers the same __name__ == '<ClassName>' assertions expressed
# as individual invariants using the function: X.__name__.__eq__ pattern,
# a distinct expression axis not previously used for this set.
# ---------------------------------------------------------------------------

invariant numbers_extra7.Number.name:
  description: "numbers.Number.__name__ == 'Number'"
  category: class_names
  kind: python_call_eq
  function: Number.__name__.__eq__
  args: ["Number"]
  expected: true

invariant numbers_extra7.Complex.name:
  description: "numbers.Complex.__name__ == 'Complex'"
  category: class_names
  kind: python_call_eq
  function: Complex.__name__.__eq__
  args: ["Complex"]
  expected: true

invariant numbers_extra7.Real.name:
  description: "numbers.Real.__name__ == 'Real'"
  category: class_names
  kind: python_call_eq
  function: Real.__name__.__eq__
  args: ["Real"]
  expected: true

invariant numbers_extra7.Rational.name:
  description: "numbers.Rational.__name__ == 'Rational'"
  category: class_names
  kind: python_call_eq
  function: Rational.__name__.__eq__
  args: ["Rational"]
  expected: true

invariant numbers_extra7.Integral.name:
  description: "numbers.Integral.__name__ == 'Integral'"
  category: class_names
  kind: python_call_eq
  function: Integral.__name__.__eq__
  args: ["Integral"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ checks — __eq__ invariant style
#
# numbers.zspec covers __module__ via table rows (method: __eq__ style).
# numbers_extra2 covers Number/Complex/Real __module__ as plain method invariants.
# numbers_extra3 covers Rational/Integral __module__ as plain method invariants.
# New here: all five expressed as function: X.__module__.__eq__ invariants,
# a distinct dotted-attribute-chain expression axis.
# ---------------------------------------------------------------------------

invariant numbers_extra7.Number.module:
  description: "numbers.Number.__module__ == 'numbers'"
  category: class_module
  kind: python_call_eq
  function: Number.__module__.__eq__
  args: ["numbers"]
  expected: true

invariant numbers_extra7.Complex.module:
  description: "numbers.Complex.__module__ == 'numbers'"
  category: class_module
  kind: python_call_eq
  function: Complex.__module__.__eq__
  args: ["numbers"]
  expected: true

invariant numbers_extra7.Real.module:
  description: "numbers.Real.__module__ == 'numbers'"
  category: class_module
  kind: python_call_eq
  function: Real.__module__.__eq__
  args: ["numbers"]
  expected: true

invariant numbers_extra7.Rational.module:
  description: "numbers.Rational.__module__ == 'numbers'"
  category: class_module
  kind: python_call_eq
  function: Rational.__module__.__eq__
  args: ["numbers"]
  expected: true

invariant numbers_extra7.Integral.module:
  description: "numbers.Integral.__module__ == 'numbers'"
  category: class_module
  kind: python_call_eq
  function: Integral.__module__.__eq__
  args: ["numbers"]
  expected: true

# ---------------------------------------------------------------------------
# __bases__[0].__name__ — tower inheritance chain
#
# numbers_extra covers all five __bases__[0].__name__ via a table.
# numbers_extra2 covers Complex/Real via __eq__ style.
# numbers_extra3 covers Rational/Integral via __eq__ style.
# New here: Complex, Real, Rational as standalone invariants using
# __bases__.__getitem__ + __name__ method chain, a distinct expression form.
# (Number inherits from object; that axis is covered in numbers_extra already.)
# ---------------------------------------------------------------------------

invariant numbers_extra7.Complex.base_is_Number:
  description: "numbers.Complex.__bases__[0].__name__ == 'Number' — Complex directly extends Number"
  category: class_hierarchy
  kind: python_call_eq
  function: Complex.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Number"

invariant numbers_extra7.Real.base_is_Complex:
  description: "numbers.Real.__bases__[0].__name__ == 'Complex' — Real directly extends Complex"
  category: class_hierarchy
  kind: python_call_eq
  function: Real.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Complex"

invariant numbers_extra7.Rational.base_is_Real:
  description: "numbers.Rational.__bases__[0].__name__ == 'Real' — Rational directly extends Real"
  category: class_hierarchy
  kind: python_call_eq
  function: Rational.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Real"
