spec: inspect_extra95
version: ">=3.9"
backend: python_module(inspect)
extends: inspect_extra94

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra94.zspec.zsdl."
    - "This spec covers: inspect Parameter.empty and Signature.empty sentinel identity + Parameter kind enum __class__.__name__; inspect.__all__ class name and length (Wave 254)."
    - "inspect.Parameter.empty.__class__.__name__ == 'type' — Parameter.empty is a sentinel class (not an instance). Verified with Python 3.14.3."
    - "inspect.Parameter.empty.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.Signature.empty.__class__.__name__ == 'type' — Signature.empty is the same object as Parameter.empty. Verified with Python 3.14.3."
    - "inspect.Parameter.empty is inspect.Signature.empty — they are the same object. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "inspect.Parameter.VAR_POSITIONAL.__class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "inspect.Parameter.KEYWORD_ONLY.__class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "inspect.Parameter.VAR_KEYWORD.__class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "All Parameter kind enums have .name equal to the constant name (e.g. 'POSITIONAL_ONLY'). Verified with Python 3.14.3."
    - "All Parameter kind enums have __class__.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.__all__.__class__.__name__ == 'list'. Verified with Python 3.14.3."
    - "inspect.__all__.__len__() == 107. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: Parameter.empty and Signature.empty sentinel identity
#
# Wave 254 theme: inspect sentinel classes — __class__.__name__ and __module__.
#
# inspect.Parameter.empty.__class__.__name__.__eq__('type') == True
# inspect.Parameter.empty.__module__.__eq__('inspect') == True
# inspect.Signature.empty.__class__.__name__.__eq__('type') == True
#
# Parameter.empty is a sentinel class object (not an instance); its
# __class__ is <class 'type'>. Signature.empty is the same object.
# New to extra95.
# ---------------------------------------------------------------------------

table inspect_extra95.empty_sentinel_identity:
  description: "inspect.Parameter.empty and Signature.empty __class__.__name__ and __module__; sentinel class objects; wave 254; new to extra95"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparamsentinel95

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_empty_class_name_eq_type,
       "Parameter.empty.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Parameter.empty.__class__.__name__.__eq__('type') == True — Parameter.empty is a sentinel defined as a class (not an instance); in Lib/inspect.py it is created with 'class _empty: ...' and assigned as Parameter.empty; its __class__ is <class 'type'>; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra95"]
    - [parameter_empty_module_eq_inspect,
       "Parameter.empty.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.empty.__module__.__eq__('inspect') == True — Parameter.empty (the _empty class) is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra95"]
    - [signature_empty_class_name_eq_type,
       "Signature.empty.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Signature.empty.__class__.__name__.__eq__('type') == True — Signature.empty is the same object as Parameter.empty (they are identical); __class__.__name__ is 'type'; str.__eq__('type') returns True; the identity (Parameter.empty is Signature.empty) was verified separately; new to extra95"]

# ---------------------------------------------------------------------------
# Table 2: Parameter kind enum __class__.__name__ (all '_ParameterKind')
#
# Wave 254 theme: Parameter kind enum values all have __class__.__name__ == '_ParameterKind'.
#
# inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__('_ParameterKind') == True
# inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True
# inspect.Parameter.VAR_POSITIONAL.__class__.__name__.__eq__('_ParameterKind') == True
# inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__('_ParameterKind') == True
# inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True
#
# _ParameterKind is an enum defined in Lib/inspect.py; all 5 parameter kinds
# are instances of it. New to extra95.
# ---------------------------------------------------------------------------

table inspect_extra95.parameter_kind_class_names:
  description: "Parameter.POSITIONAL_ONLY/POSITIONAL_OR_KEYWORD/VAR_POSITIONAL/KEYWORD_ONLY/VAR_KEYWORD __class__.__name__ == '_ParameterKind'; wave 254; new to extra95"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparamsentinel95

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_class_name,
       "Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_ONLY is an enum member of the _ParameterKind enum defined in Lib/inspect.py; __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra95"]
    - [positional_or_keyword_class_name,
       "Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_OR_KEYWORD is an enum member of _ParameterKind; __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra95"]
    - [var_positional_class_name,
       "Parameter.VAR_POSITIONAL.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_POSITIONAL.__class__.__name__.__eq__('_ParameterKind') == True — VAR_POSITIONAL is an enum member of _ParameterKind (used for *args parameters); __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra95"]
    - [keyword_only_class_name,
       "Parameter.KEYWORD_ONLY.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — KEYWORD_ONLY is an enum member of _ParameterKind (used for parameters after *args); __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra95"]
    - [var_keyword_class_name,
       "Parameter.VAR_KEYWORD.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — VAR_KEYWORD is an enum member of _ParameterKind (used for **kwargs parameters); __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra95"]

# ---------------------------------------------------------------------------
# Table 3: Parameter kind enum .name string values
#
# Wave 254 theme: Parameter kind enum .name attribute equals the constant name.
#
# inspect.Parameter.POSITIONAL_ONLY.name.__eq__('POSITIONAL_ONLY') == True
# inspect.Parameter.POSITIONAL_OR_KEYWORD.name.__eq__('POSITIONAL_OR_KEYWORD') == True
# inspect.Parameter.VAR_POSITIONAL.name.__eq__('VAR_POSITIONAL') == True
# inspect.Parameter.KEYWORD_ONLY.name.__eq__('KEYWORD_ONLY') == True
# inspect.Parameter.VAR_KEYWORD.name.__eq__('VAR_KEYWORD') == True
#
# The .name property of each _ParameterKind enum member returns the constant
# name as a string. New to extra95.
# ---------------------------------------------------------------------------

table inspect_extra95.parameter_kind_names:
  description: "Parameter kind enum .name values: POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD, VAR_POSITIONAL, KEYWORD_ONLY, VAR_KEYWORD; wave 254; new to extra95"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparamsentinel95

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_name_eq,
       "Parameter.POSITIONAL_ONLY.name.__eq__",
       ["POSITIONAL_ONLY"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.name.__eq__('POSITIONAL_ONLY') == True — the .name property of a _ParameterKind enum member returns the member's name as declared; str.__eq__('POSITIONAL_ONLY') returns True; new to extra95"]
    - [positional_or_keyword_name_eq,
       "Parameter.POSITIONAL_OR_KEYWORD.name.__eq__",
       ["POSITIONAL_OR_KEYWORD"],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.name.__eq__('POSITIONAL_OR_KEYWORD') == True — .name returns the enum member name 'POSITIONAL_OR_KEYWORD'; str.__eq__('POSITIONAL_OR_KEYWORD') returns True; new to extra95"]
    - [var_positional_name_eq,
       "Parameter.VAR_POSITIONAL.name.__eq__",
       ["VAR_POSITIONAL"],
       true,
       "inspect.Parameter.VAR_POSITIONAL.name.__eq__('VAR_POSITIONAL') == True — .name returns 'VAR_POSITIONAL'; str.__eq__('VAR_POSITIONAL') returns True; new to extra95"]
    - [keyword_only_name_eq,
       "Parameter.KEYWORD_ONLY.name.__eq__",
       ["KEYWORD_ONLY"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.name.__eq__('KEYWORD_ONLY') == True — .name returns 'KEYWORD_ONLY'; str.__eq__('KEYWORD_ONLY') returns True; new to extra95"]
    - [var_keyword_name_eq,
       "Parameter.VAR_KEYWORD.name.__eq__",
       ["VAR_KEYWORD"],
       true,
       "inspect.Parameter.VAR_KEYWORD.name.__eq__('VAR_KEYWORD') == True — .name returns 'VAR_KEYWORD'; str.__eq__('VAR_KEYWORD') returns True; new to extra95"]

# ---------------------------------------------------------------------------
# Table 4: Parameter kind enum __class__.__module__; inspect.__all__ class name and length
#
# Wave 254 theme: _ParameterKind module identity; inspect.__all__ type and length.
#
# inspect.Parameter.POSITIONAL_ONLY.__class__.__module__.__eq__('inspect') == True
# inspect.Parameter.VAR_KEYWORD.__class__.__module__.__eq__('inspect') == True
# inspect.__all__.__class__.__name__.__eq__('list') == True
# inspect.__all__.__len__().__eq__(107) == True
#
# _ParameterKind is defined in Lib/inspect.py so __module__ is 'inspect'.
# inspect.__all__ is a list with 107 entries in Python 3.14.3. New to extra95.
# ---------------------------------------------------------------------------

table inspect_extra95.parameter_kind_module_and_all:
  description: "Parameter kind __class__.__module__ == 'inspect'; inspect.__all__ class name and length; wave 254; new to extra95"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparamsentinel95

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_class_module_eq_inspect,
       "Parameter.POSITIONAL_ONLY.__class__.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__module__.__eq__('inspect') == True — _ParameterKind is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra95"]
    - [var_keyword_class_module_eq_inspect,
       "Parameter.VAR_KEYWORD.__class__.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.VAR_KEYWORD.__class__.__module__.__eq__('inspect') == True — all _ParameterKind enum members share the same __class__.__module__ 'inspect'; str.__eq__('inspect') returns True; new to extra95"]
    - [inspect_all_class_name_eq_list,
       "__all__.__class__.__name__.__eq__",
       ["list"],
       true,
       "inspect.__all__.__class__.__name__.__eq__('list') == True — inspect defines __all__ as a list in Lib/inspect.py; __class__.__name__ is 'list'; str.__eq__('list') returns True; new to extra95"]
    - [inspect_all_len_eq_107,
       "__all__.__len__",
       [],
       107,
       "inspect.__all__.__len__() == 107 — inspect.__all__ contains 107 public names in Python 3.14.3; list.__len__() returns 107; verified with Python 3.14.3 on macOS/Darwin 25.4.0; new to extra95"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra95
# ---------------------------------------------------------------------------

invariant inspect_extra95.parameter_empty_class_name:
  description: "inspect.Parameter.empty.__class__.__name__ == 'type' — sentinel is a class object not an instance; wave 254; new to extra95"
  kind: python_call_eq
  function: Parameter.empty.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra95.signature_empty_class_name:
  description: "inspect.Signature.empty.__class__.__name__ == 'type' — same object as Parameter.empty; wave 254; new to extra95"
  kind: python_call_eq
  function: Signature.empty.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra95.positional_only_class_name:
  description: "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind' — enum member of _ParameterKind; wave 254; new to extra95"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra95.var_keyword_name_eq:
  description: "inspect.Parameter.VAR_KEYWORD.name == 'VAR_KEYWORD' — enum member .name property; wave 254; new to extra95"
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.name.__eq__
  args: ["VAR_KEYWORD"]
  expected: true

invariant inspect_extra95.inspect_all_len_eq_107:
  description: "inspect.__all__.__len__() == 107 — public API list length in Python 3.14.3; wave 254; new to extra95"
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 107
