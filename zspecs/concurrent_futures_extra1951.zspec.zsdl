spec: concurrent_futures_extra1951
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Wave 577 (_extra1951): __contains__, __iter__, __next__, __aiter__, __anext__ dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "concurrent.futures has no async iterator types; none of its classes define __aiter__ or __anext__."
    - "None of the concurrent.futures classes define __contains__, __iter__, __next__, __aiter__, or __anext__ in their own __dict__."
  created_at: "2026-04-12"
error_model: python_exceptions

table concurrent_futures_extra1951.contains_protocol:
  description: "concurrent.futures types __contains__ dict-presence checks — none define __contains__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1951

  columns: [id, function, args, expected]
  rows:
    - ["cf1951001", "concurrent.futures.Future.__dict__.__contains__",              ["__contains__"], false]
    - ["cf1951002", "concurrent.futures.Executor.__dict__.__contains__",            ["__contains__"], false]
    - ["cf1951003", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__contains__"], false]
    - ["cf1951004", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__contains__"], false]
    - ["cf1951005", "concurrent.futures.BrokenExecutor.__dict__.__contains__",      ["__contains__"], false]
    - ["cf1951006", "concurrent.futures.CancelledError.__dict__.__contains__",      ["__contains__"], false]
    - ["cf1951007", "concurrent.futures.TimeoutError.__dict__.__contains__",        ["__contains__"], false]
    - ["cf1951008", "concurrent.futures.InvalidStateError.__dict__.__contains__",   ["__contains__"], false]

