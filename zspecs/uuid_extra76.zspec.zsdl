spec: uuid_extra76
version: ">=3.9"
extends: uuid_extra75
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra75.zspec.zsdl — covers SafeUUID enum members __class__.__name__/'SafeUUID' / __class__.__qualname__ / value.__class__.__name__/'int' / SafeUUID class __name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__()/__name__.__len__()/__module__.__len__() (table + invariants)."
    - "uuid_extra74.zspec.zsdl — covers UUID property descriptor __qualname__ identity (hex/urn/version/bytes/bytes_le/fields/node/time/time_hi_version/time_low/time_mid/clock_seq_hi_variant/clock_seq_low) and UUID.int member_descriptor __qualname__ (table + invariants)."
    - "uuid_extra73.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 qualname lengths / UUID.__dict__ special method membership (__repr__/__hash__/__eq__/__lt__) / UUID.__dict__ property membership (bytes_le/node/time) and mappingproxy class name (table + invariants)."
    - "uuid_extra72.zspec.zsdl — covers NAMESPACE_DNS/URL/OID/X500 __class__.__name__/__module__/__qualname__ / UUID/__name__/__module__/__qualname__/__bases__[0].__name__ / SafeUUID identity (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra75; it does NOT duplicate invariants present in those files."
    - "Wave 250 theme: uuid UUID class __dict__ method __class__.__name__ identity — __init__/__str__/__repr__/__eq__/__hash__/__lt__/__setattr__ are all 'function'; UUID.int is 'member_descriptor'; UUID.hex is 'property'; __qualname__.__eq__ for __init__/__str__/__eq__/__hash__."
    - "uuid.UUID.__init__.__class__.__name__ == 'function' — __init__ is a pure-Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__class__.__name__ == 'function' — __str__ is a pure-Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__class__.__name__ == 'function' — __repr__ is a pure-Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__class__.__name__ == 'function' — __eq__ is a pure-Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__class__.__name__ == 'function' — __hash__ is a pure-Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__lt__.__class__.__name__ == 'function' — __lt__ is a pure-Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__setattr__.__class__.__name__ == 'function' — __setattr__ is a pure-Python function that enforces immutability. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.int.__class__.__name__ == 'member_descriptor' — int is a C-level slot. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.hex.__class__.__name__ == 'property' — hex is a Python property descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__qualname__ == 'UUID.__init__' — qualname includes the class prefix. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__qualname__ == 'UUID.__str__' — qualname includes the class prefix. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__qualname__ == 'UUID.__eq__' — qualname includes the class prefix. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__qualname__ == 'UUID.__hash__' — qualname includes the class prefix. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__init__/__class__/__name__ / UUID.__str__/__class__/__name__
# uuid.UUID.__repr__/__class__/__name__ / UUID.__eq__/__class__/__name__
#
# Wave 250 theme: UUID dunder method __class__.__name__ identity (group 1).
#
# __init__, __str__, __repr__, __eq__ are all pure-Python functions (class 'function').
# No prior uuid spec checks __class__.__name__ for any UUID instance method.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra76.uuid_method_class_names_group1:
  description: "uuid.UUID/__init__/__class__/__name__.__eq__('function')==True / UUID/__str__/__class__/__name__.__eq__('function')==True / UUID/__repr__/__class__/__name__.__eq__('function')==True / UUID/__eq__/__class__/__name__.__eq__('function')==True — __init__/__str__/__repr__/__eq__ are all pure-Python functions (uuid.py is implemented in Python, not C); no prior uuid spec checks __class__.__name__ for any UUID instance method; first __class__.__name__ identity anchor for UUID dunder methods"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidextra76

  columns: [id, function, args, expected]
  rows:
    - [uuid_init_class_function,    UUID.__init__.__class__.__name__.__eq__,   ["function"], true]
    - [uuid_str_class_function,     UUID.__str__.__class__.__name__.__eq__,    ["function"], true]
    - [uuid_repr_class_function,    UUID.__repr__.__class__.__name__.__eq__,   ["function"], true]
    - [uuid_eq_class_function,      UUID.__eq__.__class__.__name__.__eq__,     ["function"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__hash__/__class__/__name__ / UUID.__lt__/__class__/__name__
# uuid.UUID.__setattr__/__class__/__name__ / UUID.int/__class__/__name__
#
# Wave 250 theme: UUID dunder method __class__.__name__ identity (group 2).
#
# __hash__, __lt__, __setattr__ are pure-Python functions; UUID.int is a member_descriptor.
# No prior uuid spec checks __class__.__name__ for __hash__/__lt__/__setattr__ or UUID.int.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra76.uuid_method_class_names_group2:
  description: "uuid.UUID/__hash__/__class__/__name__.__eq__('function')==True / UUID/__lt__/__class__/__name__.__eq__('function')==True / UUID/__setattr__/__class__/__name__.__eq__('function')==True / UUID/int/__class__/__name__.__eq__('member_descriptor')==True — __hash__/__lt__/__setattr__ are pure-Python functions; UUID.int is a C-level member_descriptor (slot); no prior uuid spec checks __class__.__name__ for these attributes; first __class__.__name__ anchor for UUID.__hash__/__lt__/__setattr__/int"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidextra76

  columns: [id, function, args, expected]
  rows:
    - [uuid_hash_class_function,       UUID.__hash__.__class__.__name__.__eq__,    ["function"],         true]
    - [uuid_lt_class_function,         UUID.__lt__.__class__.__name__.__eq__,      ["function"],         true]
    - [uuid_setattr_class_function,    UUID.__setattr__.__class__.__name__.__eq__, ["function"],         true]
    - [uuid_int_class_member_desc,     UUID.int.__class__.__name__.__eq__,         ["member_descriptor"],true]

# ---------------------------------------------------------------------------
# uuid.UUID.hex/__class__/__name__ / UUID.__init__/__qualname__/__eq__('UUID.__init__')
# uuid.UUID.__str__/__qualname__/__eq__('UUID.__str__') / UUID.__eq__/__qualname__/__eq__('UUID.__eq__')
#
# Wave 250 theme: UUID.hex property type and UUID method __qualname__.__eq__ identity.
#
# UUID.hex.__class__.__name__ == 'property'.
# UUID.__init__/__str__/__eq__ each have __qualname__ == 'UUID.<method>'.
# No prior uuid spec checks __class__.__name__ for UUID.hex or __qualname__.__eq__ for these methods.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra76.uuid_hex_class_and_qualnames_group1:
  description: "uuid.UUID/hex/__class__/__name__.__eq__('property')==True / UUID/__init__/__qualname__/__eq__('UUID.__init__')==True / UUID/__str__/__qualname__/__eq__('UUID.__str__')==True / UUID/__eq__/__qualname__/__eq__('UUID.__eq__')==True — UUID.hex is a property descriptor; __init__/__str__/__eq__ all have qualified names prefixed with 'UUID.'; no prior uuid spec checks hex.__class__.__name__ or __qualname__.__eq__ for these methods; first __qualname__.__eq__ anchor for UUID.__init__/__str__/__eq__"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidextra76

  columns: [id, function, args, expected]
  rows:
    - [uuid_hex_class_property,      UUID.hex.__class__.__name__.__eq__,               ["property"],    true]
    - [uuid_init_qualname_eq,        UUID.__init__.__qualname__.__eq__,                ["UUID.__init__"],true]
    - [uuid_str_qualname_eq,         UUID.__str__.__qualname__.__eq__,                 ["UUID.__str__"], true]
    - [uuid_eq_qualname_eq,          UUID.__eq__.__qualname__.__eq__,                  ["UUID.__eq__"],  true]

# ---------------------------------------------------------------------------
# uuid.UUID.__hash__/__qualname__/__eq__('UUID.__hash__') / UUID.__repr__/__class__/__name__
# uuid.UUID.__lt__/__class__.__name__ / UUID.__setattr__/__class__/__name__
#
# Wave 250 theme: UUID.__hash__ qualname and __repr__/__lt__/__setattr__ class cross-checks.
#
# UUID.__hash__.__qualname__.__eq__('UUID.__hash__') == True.
# UUID.__repr__/__lt__/__setattr__.__class__.__name__ all == 'function'.
# No prior uuid spec checks __hash__.__qualname__.__eq__ or __repr__/__lt__/__setattr__ class.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra76.uuid_hash_qualname_and_class_cross:
  description: "uuid.UUID/__hash__/__qualname__/__eq__('UUID.__hash__')==True / UUID/__repr__/__class__/__name__.__eq__('function')==True / UUID/__lt__/__class__.__name__.__eq__('function')==True / UUID/__setattr__/__class__.__name__.__eq__('function')==True — UUID.__hash__ has a qualified name prefixed with 'UUID.'; __repr__/__lt__/__setattr__ are all pure-Python functions; no prior uuid spec checks __hash__.__qualname__.__eq__; first __qualname__.__eq__ standalone anchor for uuid.UUID.__hash__"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidextra76

  columns: [id, function, args, expected]
  rows:
    - [uuid_hash_qualname_eq,         UUID.__hash__.__qualname__.__eq__,               ["UUID.__hash__"], true]
    - [uuid_repr_class_function2,     UUID.__repr__.__class__.__name__.__eq__,          ["function"],     true]
    - [uuid_lt_class_function2,       UUID.__lt__.__class__.__name__.__eq__,            ["function"],     true]
    - [uuid_setattr_class_function2,  UUID.__setattr__.__class__.__name__.__eq__,       ["function"],     true]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__class__.__name__.__eq__('function') — standalone
#
# UUID.__init__.__class__.__name__ is 'function'. No prior uuid spec checks
# UUID.__init__.__class__.__name__. First __class__.__name__ standalone for
# uuid.UUID.__init__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra76.uuid_init_class_function:
  description: "uuid.UUID.__init__.__class__.__name__.__eq__('function') == True — UUID.__init__ is a pure-Python function (uuid module is implemented in Python); no prior uuid spec checks UUID.__init__.__class__.__name__; first __class__.__name__ standalone for uuid.UUID.__init__"
  category: class_attrs
  kind: python_call_eq
  function: UUID.__init__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

