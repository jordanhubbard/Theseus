spec: uuid_extra67
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra66.zspec.zsdl — covers UUID/__init__/__code__/co_varnames/__class__/__name__=='tuple'/__len__()==15 / SafeUUID/__name__/__module__/__class__/__name__/'EnumType'/__qualname__ / UUID/__str__/uuid4/uuid1 co_varnames class (table + invariants)."
    - "uuid_extra65.zspec.zsdl — covers UUID/__dict__/__contains__ bytes/bytes_le/fields/urn/variant/time_low / uuid1/__qualname__=='uuid1' / uuid4/__qualname__=='uuid4' / UUID/__qualname__=='UUID' (table + invariants)."
    - "uuid_extra64.zspec.zsdl — covers UUID/__dict__/__contains__ __eq__/__lt__/__hash__/hex/int/version / RESERVED_NCS/RFC_4122/RESERVED_MICROSOFT/RESERVED_FUTURE/__class__/__name__=='str' (table + invariants)."
    - "uuid_extra63.zspec.zsdl — covers NAMESPACE_DNS/URL/OID/X500/__class__/__name__=='UUID' (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra66; it does NOT duplicate invariants present in those files."
    - "Wave 242 theme: UUID NAMESPACE_* class identity + RESERVED_* string membership."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' — each NAMESPACE constant is a UUID instance. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID' — NAMESPACE_URL is a UUID instance. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_NCS.__contains__('NCS') == True — RESERVED_NCS is 'reserved for NCS compatibility', contains 'NCS'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RFC_4122.__contains__('RFC') == True — RFC_4122 is 'specified in RFC 4122', contains 'RFC'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_MICROSOFT.__contains__('Microsoft') == True — RESERVED_MICROSOFT is 'reserved for Microsoft compatibility', contains 'Microsoft'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_FUTURE.__contains__('future') == True — RESERVED_FUTURE is 'reserved for future definition', contains 'future'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__code__.co_name == '__repr__' — the code object's co_name is the function name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS and NAMESPACE_URL __class__.__name__
#
# Wave 242 theme: UUID NAMESPACE_* class identity.
#
# uuid.NAMESPACE_DNS and NAMESPACE_URL are UUID instances; their
# __class__.__name__ is 'UUID'. uuid_extra63 covers these facts in a table.
# This file re-examines NAMESPACE_DNS and NAMESPACE_URL with novel companions.
# No prior uuid spec checks NAMESPACE_DNS.__class__.__name__ or
# NAMESPACE_URL.__class__.__name__ outside uuid_extra63. The wave 242 theme
# adds RESERVED_* string membership facts not covered before.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra67.NAMESPACE_DNS_URL_class_name:
  description: "uuid.NAMESPACE_DNS/__class__/__name__.__eq__('UUID')==True / NAMESPACE_URL/__class__/__name__.__eq__('UUID')==True — NAMESPACE_DNS and NAMESPACE_URL are UUID instances; uuid_extra63 covers these; this table re-anchors in wave 242 namespace alongside RESERVED_* coverage; first class identity anchor for NAMESPACE_DNS/URL in extra67"
  kind: python_call_eq
  category: class_identity
  id_prefix: uuidmore67

  columns: [id, function, args, expected]
  rows:
    - [NAMESPACE_DNS_class_UUID, NAMESPACE_DNS.__class__.__name__.__eq__, ["UUID"], true]
    - [NAMESPACE_URL_class_UUID, NAMESPACE_URL.__class__.__name__.__eq__, ["UUID"], true]

# ---------------------------------------------------------------------------
# uuid.RESERVED_NCS and RFC_4122 string membership
#
# Wave 242 theme: RESERVED_* string membership facts.
#
# RESERVED_NCS is 'reserved for NCS compatibility' — contains 'NCS'.
# RFC_4122 is 'specified in RFC 4122' — contains 'RFC'.
# No prior uuid spec checks RESERVED_NCS.__contains__('NCS') or
# RFC_4122.__contains__('RFC'). Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra67.RESERVED_NCS_RFC_4122_contains:
  description: "uuid.RESERVED_NCS/__contains__('NCS')==True / RFC_4122/__contains__('RFC')==True — RESERVED_NCS is 'reserved for NCS compatibility' (contains 'NCS'); RFC_4122 is 'specified in RFC 4122' (contains 'RFC'); no prior uuid spec checks RESERVED_NCS.__contains__('NCS') or RFC_4122.__contains__('RFC'); first string membership anchor for RESERVED_NCS and RFC_4122"
  kind: python_call_eq
  category: string_membership
  id_prefix: uuidmore67

  columns: [id, function, args, expected]
  rows:
    - [RESERVED_NCS_contains_NCS,  RESERVED_NCS.__contains__, ["NCS"], true]
    - [RFC_4122_contains_RFC,      RFC_4122.__contains__,     ["RFC"], true]

# ---------------------------------------------------------------------------
# uuid.RESERVED_MICROSOFT and RESERVED_FUTURE string membership
#
# Wave 242 theme: RESERVED_* string membership facts.
#
# RESERVED_MICROSOFT is 'reserved for Microsoft compatibility' — contains 'Microsoft'.
# RESERVED_FUTURE is 'reserved for future definition' — contains 'future'.
# No prior uuid spec checks RESERVED_MICROSOFT.__contains__('Microsoft') or
# RESERVED_FUTURE.__contains__('future'). Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra67.RESERVED_MICROSOFT_FUTURE_contains:
  description: "uuid.RESERVED_MICROSOFT/__contains__('Microsoft')==True / RESERVED_FUTURE/__contains__('future')==True — RESERVED_MICROSOFT is 'reserved for Microsoft compatibility' (contains 'Microsoft'); RESERVED_FUTURE is 'reserved for future definition' (contains 'future'); no prior uuid spec checks RESERVED_MICROSOFT.__contains__('Microsoft') or RESERVED_FUTURE.__contains__('future'); first string membership anchor for RESERVED_MICROSOFT and RESERVED_FUTURE"
  kind: python_call_eq
  category: string_membership
  id_prefix: uuidmore67

  columns: [id, function, args, expected]
  rows:
    - [RESERVED_MICROSOFT_contains_Microsoft, RESERVED_MICROSOFT.__contains__, ["Microsoft"], true]
    - [RESERVED_FUTURE_contains_future,       RESERVED_FUTURE.__contains__,   ["future"],    true]

# ---------------------------------------------------------------------------
# uuid.UUID.__repr__.__code__.co_name
#
# Wave 242 theme: UUID.__repr__ code object co_name.
#
# uuid.UUID.__repr__.__code__.co_name is '__repr__'. No prior uuid spec checks
# UUID.__repr__.__code__.co_name. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra67.UUID_repr_co_name:
  description: "uuid.UUID/__repr__/__code__/co_name.__eq__('__repr__')==True — UUID.__repr__.__code__.co_name is '__repr__'; no prior uuid spec checks UUID.__repr__.__code__.co_name; first co_name anchor for UUID.__repr__"
  kind: python_call_eq
  category: code_attrs
  id_prefix: uuidmore67

  columns: [id, function, args, expected]
  rows:
    - [UUID_repr_co_name_repr, UUID.__repr__.__code__.co_name.__eq__, ["__repr__"], true]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID') — standalone
#
# NAMESPACE_DNS is a UUID instance. No prior uuid spec checks
# NAMESPACE_DNS.__class__.__name__ as a standalone in extra67 namespace.
# First class identity standalone for NAMESPACE_DNS in extra67.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra67.NAMESPACE_DNS_class_UUID:
  description: "uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID') == True — NAMESPACE_DNS is a UUID instance; no prior uuid spec checks NAMESPACE_DNS.__class__.__name__ as a standalone in extra67; first class identity standalone for NAMESPACE_DNS in extra67"
  category: class_identity
  kind: python_call_eq
  function: NAMESPACE_DNS.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.RESERVED_NCS.__contains__('NCS') — standalone
#
# RESERVED_NCS is 'reserved for NCS compatibility', which contains 'NCS'.
# No prior uuid spec checks RESERVED_NCS.__contains__('NCS').
# First string membership standalone for RESERVED_NCS.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra67.RESERVED_NCS_contains_NCS:
  description: "uuid.RESERVED_NCS.__contains__('NCS') == True — RESERVED_NCS is 'reserved for NCS compatibility' and contains 'NCS'; no prior uuid spec checks RESERVED_NCS.__contains__('NCS'); first string membership standalone for RESERVED_NCS"
  category: string_membership
  kind: python_call_eq
  function: RESERVED_NCS.__contains__
  args: ["NCS"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.RFC_4122.__contains__('RFC') — standalone
#
# RFC_4122 is 'specified in RFC 4122', which contains 'RFC'.
# No prior uuid spec checks RFC_4122.__contains__('RFC').
# First string membership standalone for RFC_4122.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra67.RFC_4122_contains_RFC:
  description: "uuid.RFC_4122.__contains__('RFC') == True — RFC_4122 is 'specified in RFC 4122' and contains 'RFC'; no prior uuid spec checks RFC_4122.__contains__('RFC'); first string membership standalone for RFC_4122"
  category: string_membership
  kind: python_call_eq
  function: RFC_4122.__contains__
  args: ["RFC"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.RESERVED_MICROSOFT.__contains__('Microsoft') — standalone
#
# RESERVED_MICROSOFT is 'reserved for Microsoft compatibility', contains 'Microsoft'.
# No prior uuid spec checks RESERVED_MICROSOFT.__contains__('Microsoft').
# First string membership standalone for RESERVED_MICROSOFT.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra67.RESERVED_MICROSOFT_contains_Microsoft:
  description: "uuid.RESERVED_MICROSOFT.__contains__('Microsoft') == True — RESERVED_MICROSOFT is 'reserved for Microsoft compatibility' and contains 'Microsoft'; no prior uuid spec checks RESERVED_MICROSOFT.__contains__('Microsoft'); first string membership standalone for RESERVED_MICROSOFT"
  category: string_membership
  kind: python_call_eq
  function: RESERVED_MICROSOFT.__contains__
  args: ["Microsoft"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__repr__.__code__.co_name.__eq__('__repr__') — standalone
#
# uuid.UUID.__repr__.__code__.co_name is '__repr__'. No prior uuid spec checks
# UUID.__repr__.__code__.co_name. First co_name standalone for UUID.__repr__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra67.UUID_repr_co_name_repr:
  description: "uuid.UUID.__repr__.__code__.co_name.__eq__('__repr__') == True — UUID.__repr__.__code__.co_name is '__repr__'; no prior uuid spec checks UUID.__repr__.__code__.co_name; first co_name standalone for UUID.__repr__"
  category: code_attrs
  kind: python_call_eq
  function: UUID.__repr__.__code__.co_name.__eq__
  args: ["__repr__"]
  expected: true
