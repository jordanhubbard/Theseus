spec: copy_extra19
version: ">=3.9"
backend: python_module(copy)

docs: https://docs.python.org/3/library/copy.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/copy.html — Python copy module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/copy.py"
    - "copy_extra18.zspec.zsdl — covers __loader__.__class__.__name__; __spec__.name; __module__.__len__() for copy/deepcopy/Error; Error.__bases__[0].__name__.__len__()."
    - "copy_extra17.zspec.zsdl — covers __spec__.__class__.__name__; __qualname__.__len__() for copy/deepcopy/Error; __name__ re-anchored."
    - "copy_extra16.zspec.zsdl — covers __qualname__/__module__ standalone and table for copy/deepcopy/Error."
    - "copy_extra15.zspec.zsdl — covers module __name__/__package__ and copy.error.__qualname__ alias."
  notes:
    - "This spec extends copy.zspec.zsdl through copy_extra18.zspec.zsdl."
    - "Prior specs cover: __qualname__/__qualname__.__len__/__module__/__module__.__len__ for copy/deepcopy/Error; __spec__/__loader__ metadata; Error.__bases__; module __name__/__package__."
    - "NOT yet covered: __name__.__eq__ for copy.copy/copy.deepcopy/copy.Error in extra19 namespace; copy.replace function (copy.__all__ has 4 entries: Error/copy/deepcopy/replace); copy.__all__.__class__.__name__ and len(copy.__all__); copy.__all__[0].__class__.__name__."
    - "Focus: __name__.__eq__ table for copy/deepcopy/Error/replace; copy.__all__ list metadata."
    - "copy.copy.__name__ == 'copy'. Verified Python 3.14.3 macOS."
    - "copy.deepcopy.__name__ == 'deepcopy'. Verified."
    - "copy.Error.__name__ == 'Error'. Verified."
    - "copy.replace.__name__ == 'replace'. Verified."
    - "copy.__all__ == ['Error', 'copy', 'deepcopy', 'replace']; len == 4. Verified."
    - "copy.__all__.__class__.__name__ == 'list'. Verified."
    - "copy.__all__[0].__class__.__name__ == 'str' (first element is 'Error', a string). Verified."
    - "copy.replace.__qualname__ == 'replace'; copy.replace.__module__ == 'copy'. Verified."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__eq__ for copy.copy, copy.deepcopy, copy.Error, copy.replace
#
# Prior specs cover __name__.__len__ and __qualname__.__eq__ for copy/deepcopy/
# Error. No prior copy spec checks __name__.__eq__ in the extra19 namespace.
# copy.replace was added to __all__ and is a distinct function (calls __replace__
# on objects). Its __name__ == 'replace'. id_prefix cpname19 is novel.
# ---------------------------------------------------------------------------

table copy_extra19.function_names:
  description: "__name__.__eq__ for copy.copy, copy.deepcopy, copy.Error, and copy.replace"
  kind: python_call_eq
  category: function_name
  id_prefix: cpname19

  columns: [id, function, args, expected]
  rows:
    - [copy_name,    copy.__name__.__eq__,    ["copy"],     true]
    - [deepcopy_name, deepcopy.__name__.__eq__, ["deepcopy"], true]
    - [Error_name,   Error.__name__.__eq__,   ["Error"],    true]
    - [replace_name, replace.__name__.__eq__,  ["replace"],  true]

# ---------------------------------------------------------------------------
# copy.__all__.__class__.__name__ — the __all__ list type identity
#
# No prior copy spec checks the type of copy.__all__. The __all__ attribute is
# a plain Python list: copy.__all__.__class__.__name__ == 'list'. Under
# python_module(copy), __all__.__class__.__name__.__eq__ accesses the list's
# class name on the copy module object.
# ---------------------------------------------------------------------------

invariant copy_extra19.all.class_name:
  description: "copy.__all__.__class__.__name__ == 'list' — __all__ is a plain Python list"
  category: module_identity
  kind: python_call_eq
  function: "__all__.__class__.__name__.__eq__"
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# len(copy.__all__) — number of public names exported by copy
#
# copy.__all__ == ['Error', 'copy', 'deepcopy', 'replace']; len == 4.
# No prior copy spec checks len(copy.__all__). Under python_module(copy),
# __all__.__len__ invokes list.__len__ on the copy module's __all__ attribute.
# ---------------------------------------------------------------------------

invariant copy_extra19.all.length:
  description: "len(copy.__all__) == 4 — copy exports Error, copy, deepcopy, replace"
  category: module_identity
  kind: python_call_eq
  function: "__all__.__len__"
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# copy.__all__[0].__class__.__name__ — first element type identity
#
# copy.__all__[0] == 'Error'; it is a str. __class__.__name__ == 'str'.
# No prior copy spec accesses an element of copy.__all__. The function value
# contains '[', so it must be quoted per ZSDL rules.
# ---------------------------------------------------------------------------

invariant copy_extra19.all.first_element_class:
  description: "copy.__all__[0].__class__.__name__ == 'str' — elements of __all__ are strings"
  category: module_identity
  kind: python_call_eq
  function: "__all__[0].__class__.__name__.__eq__"
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# copy.replace — qualname and module identity (extra19 namespace)
#
# copy.replace is a pure-Python function defined in Lib/copy.py. It dispatches
# to object.__replace__ (PEP 698 / Python 3.13+). Its __qualname__ == 'replace'
# (top-level function) and __module__ == 'copy'. No prior copy spec covers any
# attribute of copy.replace.
# ---------------------------------------------------------------------------

invariant copy_extra19.replace.qualname:
  description: "copy.replace.__qualname__ == 'replace' — top-level function; qualname equals simple name"
  category: function_qualname
  kind: python_call_eq
  function: replace.__qualname__.__eq__
  args: ["replace"]
  expected: true

invariant copy_extra19.replace.module:
  description: "copy.replace.__module__ == 'copy' — defined in Lib/copy.py"
  category: function_module
  kind: python_call_eq
  function: replace.__module__.__eq__
  args: ["copy"]
  expected: true
