spec: theseus_tkinter_cr
version: ">=3.0"
backend: python_cleanroom(theseus_tkinter_cr)
blocks: tkinter

docs: https://docs.python.org/3/library/tkinter.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/tkinter.html"
  not_derived_from:
    - "CPython source: Lib/tkinter/__init__.py"
  notes:
    - "Clean-room tkinter stub. Do NOT import tkinter."

error_model: python_exceptions

invariant theseus_tkinter_cr.tkinter2_variables:
  description: "tkinter Variable subclasses work correctly"
  category: behavior
  kind: python_call_eq
  function: tkinter2_variables
  args: []
  expected: true

invariant theseus_tkinter_cr.tkinter2_constants:
  description: "tkinter layout and state constants are correct"
  category: behavior
  kind: python_call_eq
  function: tkinter2_constants
  args: []
  expected: true

invariant theseus_tkinter_cr.tkinter2_classes:
  description: "tkinter widget classes are instantiable without display"
  category: behavior
  kind: python_call_eq
  function: tkinter2_classes
  args: []
  expected: true
