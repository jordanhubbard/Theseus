spec: jose
version: ">=6.0.0"
backend: node(jose)

docs: https://github.com/panva/jose#readme

provenance:
  derived_from:
    - "jose README — https://github.com/panva/jose#readme"
    - "RFC 7515 (JWS) / RFC 7516 (JWE) / RFC 7517 (JWK) / RFC 7518 (JWA) / RFC 7519 (JWT)"
    - "Test vectors verified with jose via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "jose source"
  notes:
    - "Universal JavaScript JWS/JWE/JWK/JWT implementation — successor to jsonwebtoken for modern crypto."
    - "Install: npm install jose"
    - "v6 ESM only; named exports include base64url / errors / SignJWT / EncryptJWT / compactVerify / etc."
    - "Most of the API is async (key gen / sign / verify); spec covers the synchronous base64url helpers and class shape."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Errors thrown as instances of jose.errors.* subclasses of JOSEError."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes:
    JOSEError: "Base class for all jose errors"
    JWTExpired: "Expired token"
    JWTInvalid: "Malformed JWT"

invariant jose.base64url_encode_hello:
  description: "base64url.encode('hello') is 'aGVsbG8' (no padding)"
  category: base64url
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: base64url}
    - {method: encode, args: ["hello"]}
  expected: "aGVsbG8"

invariant jose.base64url_encode_empty:
  description: "base64url.encode('') is ''"
  category: base64url
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: base64url}
    - {method: encode, args: [""]}
  expected: ""

invariant jose.SignJWT_class_present:
  description: "SignJWT exported as a constructor"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "SignJWT.constructor.name"}
  expected: "Function"

invariant jose.EncryptJWT_class_present:
  description: "EncryptJWT exported as a constructor"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "EncryptJWT.constructor.name"}
  expected: "Function"

invariant jose.UnsecuredJWT_class_present:
  description: "UnsecuredJWT exported as a constructor"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "UnsecuredJWT.constructor.name"}
  expected: "Function"

invariant jose.compactVerify_export:
  description: "compactVerify exported as a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "compactVerify.constructor.name"}
  expected: "AsyncFunction"

invariant jose.errors_has_JOSEAlgNotAllowed:
  description: "errors namespace exposes JOSEAlgNotAllowed (one of the documented sub-classes) — its name is 'JOSEAlgNotAllowed'"
  category: errors
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "errors.JOSEAlgNotAllowed.name"}
  expected: "JOSEAlgNotAllowed"

invariant jose.errors_JOSEError_class:
  description: "errors.JOSEError is a class (Function)"
  category: errors
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "errors.JOSEError.constructor.name"}
  expected: "Function"

