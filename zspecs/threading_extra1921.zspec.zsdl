spec: threading_extra1921
version: ">=3.9"
backend: python_module(threading)

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/threading.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 575 (_extra1921): __slots__ inheritance checks, __abstractmethods__ set membership, __subclasshook__ dict presence, __init_subclass__ dict presence."
    - "threading.Thread is a Python class that does NOT define __slots__; it uses __dict__ for instance storage."
    - "threading.Event, threading.Condition, threading.Semaphore, threading.BoundedSemaphore, threading.Timer, threading.Barrier are Python classes that do NOT define __slots__."
    - "threading.Lock is a C-level type (_thread.lock); its __dict__ does not contain __slots__, __abstractmethods__, __subclasshook__, or __init_subclass__."
    - "threading.RLock is a Python function returning an RLock instance, not a class that can be introspected via __dict__ in the same way."
    - "None of the threading classes define __abstractmethods__, __subclasshook__, or __init_subclass__ in their own __dict__."
    - "threading.Thread.__dict__ contains __dict__ and __weakref__ descriptor entries confirming instance-dict storage."
    - "threading.Timer is a Thread subclass; it also does not define __slots__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

table threading_extra1921.slots_protocol:
  description: "threading classes __slots__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1921

  columns: [id, function, args, expected]
  rows:
    - ["th1921001", "threading.Thread.__dict__.__contains__", ["__slots__"], false]
    - ["th1921002", "threading.Event.__dict__.__contains__", ["__slots__"], false]
    - ["th1921003", "threading.Condition.__dict__.__contains__", ["__slots__"], false]
    - ["th1921004", "threading.Semaphore.__dict__.__contains__", ["__slots__"], false]
    - ["th1921005", "threading.BoundedSemaphore.__dict__.__contains__", ["__slots__"], false]
    - ["th1921006", "threading.Timer.__dict__.__contains__", ["__slots__"], false]
    - ["th1921007", "threading.Barrier.__dict__.__contains__", ["__slots__"], false]
    - ["th1921008", "threading.Lock.__dict__.__contains__", ["__slots__"], false]
    - ["th1921009", "threading.Thread.__dict__.__contains__", ["__dict__"], true]
    - ["th1921010", "threading.Thread.__dict__.__contains__", ["__weakref__"], true]

table threading_extra1921.abstractmethods_protocol:
  description: "threading classes __abstractmethods__ dict-presence checks"
  kind: python_call_eq
