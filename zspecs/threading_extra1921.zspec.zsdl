    - ["th1921012", "threading.Event.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["th1921013", "threading.Condition.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["th1921014", "threading.Semaphore.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["th1921015", "threading.BoundedSemaphore.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["th1921016", "threading.Timer.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["th1921017", "threading.Barrier.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["th1921018", "threading.Lock.__dict__.__contains__", ["__abstractmethods__"], false]

