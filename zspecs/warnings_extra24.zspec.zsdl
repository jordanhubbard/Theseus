spec: warnings_extra24
version: ">=3.9"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/warnings.html — Python warnings module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
  notes:
    - "This spec extends warnings_extra23.zspec.zsdl."
    - "Prior specs covered: warn/warn_explicit/simplefilter/filterwarnings/resetwarnings __module__.__len__() and __name__.__len__(), catch_warnings __module__.__len__()==12 and __name__.__len__()==14."
    - "This spec covers: catch_warnings method __qualname__.__len__() (__init__=23, __enter__=24, __exit__=23, __repr__=23), catch_warnings.__qualname__.__len__()==14, showwarning/__name__.__len__()==11 and __module__.__len__()==12, formatwarning/__name__.__len__()==13 and __module__.__len__()==12, DeprecationWarning/__name__.__len__()==18, UserWarning/__name__.__len__()==11, RuntimeWarning/__name__.__len__()==14, SyntaxWarning/__name__.__len__()==13, FutureWarning/__name__.__len__()==13."
    - "warnings.catch_warnings.__qualname__ == 'catch_warnings' (len 14). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.catch_warnings.__init__.__qualname__ == 'catch_warnings.__init__' (len 23). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.catch_warnings.__enter__.__qualname__ == 'catch_warnings.__enter__' (len 24). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.catch_warnings.__exit__.__qualname__ == 'catch_warnings.__exit__' (len 23). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.catch_warnings.__repr__.__qualname__ == 'catch_warnings.__repr__' (len 23). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.showwarning.__module__ == '_py_warnings' (len 12). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.showwarning.__name__ == 'showwarning' (len 11). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.formatwarning.__module__ == '_py_warnings' (len 12). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "warnings.formatwarning.__name__ == 'formatwarning' (len 13). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "DeprecationWarning.__name__ == 'DeprecationWarning' (len 18). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "UserWarning.__name__ == 'UserWarning' (len 11). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "RuntimeWarning.__name__ == 'RuntimeWarning' (len 14). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "SyntaxWarning.__name__ == 'SyntaxWarning' (len 13). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "FutureWarning.__name__ == 'FutureWarning' (len 13). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# warnings.catch_warnings.__qualname__.__len__()
#
# catch_warnings.__qualname__ == 'catch_warnings', which has length 14.
# extra23 covers __module__.__len__() and __name__.__len__() for catch_warnings;
# __qualname__.__len__() is a fresh extra24-namespace invariant.
# ---------------------------------------------------------------------------

invariant warnings_extra24.catch_warnings.qualname.len:
  description: "warnings.catch_warnings.__qualname__.__len__() == 14 — 'catch_warnings' has 14 characters"
  category: string_length
  kind: python_call_eq
  function: catch_warnings.__qualname__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# catch_warnings method __qualname__.__len__() checks
#
# The dunder methods carry compound qualnames of the form 'catch_warnings.MNAME'.
# No prior spec measures any catch_warnings method qualname length.
# __init__: 'catch_warnings.__init__' len 23
# __enter__: 'catch_warnings.__enter__' len 24  (one char longer — __enter__ is 9 chars)
# __exit__:  'catch_warnings.__exit__'  len 23
# __repr__:  'catch_warnings.__repr__'  len 23
# ---------------------------------------------------------------------------

invariant warnings_extra24.catch_warnings.__init__.qualname.len:
  description: "warnings.catch_warnings.__init__.__qualname__.__len__() == 23 — 'catch_warnings.__init__' has 23 characters"
  category: string_length
  kind: python_call_eq
  function: "catch_warnings.__init__.__qualname__.__len__"
  args: []
  expected: 23

invariant warnings_extra24.catch_warnings.__enter__.qualname.len:
  description: "warnings.catch_warnings.__enter__.__qualname__.__len__() == 24 — 'catch_warnings.__enter__' has 24 characters"
  category: string_length
  kind: python_call_eq
  function: "catch_warnings.__enter__.__qualname__.__len__"
  args: []
  expected: 24

invariant warnings_extra24.catch_warnings.__exit__.qualname.len:
  description: "warnings.catch_warnings.__exit__.__qualname__.__len__() == 23 — 'catch_warnings.__exit__' has 23 characters"
  category: string_length
  kind: python_call_eq
  function: "catch_warnings.__exit__.__qualname__.__len__"
  args: []
  expected: 23

invariant warnings_extra24.catch_warnings.__repr__.qualname.len:
  description: "warnings.catch_warnings.__repr__.__qualname__.__len__() == 23 — 'catch_warnings.__repr__' has 23 characters"
  category: string_length
  kind: python_call_eq
  function: "catch_warnings.__repr__.__qualname__.__len__"
  args: []
  expected: 23

# ---------------------------------------------------------------------------
# warnings.showwarning and warnings.formatwarning __name__/__module__ lengths
#
# showwarning.__module__ == '_py_warnings' (len 12), __name__ == 'showwarning' (len 11).
# formatwarning.__module__ == '_py_warnings' (len 12), __name__ == 'formatwarning' (len 13).
# No prior spec covers these two functions' __len__() checks.
# ---------------------------------------------------------------------------

invariant warnings_extra24.showwarning.module.len:
  description: "warnings.showwarning.__module__.__len__() == 12 — '_py_warnings' has 12 characters"
  category: string_length
  kind: python_call_eq
  function: showwarning.__module__.__len__
  args: []
  expected: 12

invariant warnings_extra24.showwarning.name.len:
  description: "warnings.showwarning.__name__.__len__() == 11 — 'showwarning' has 11 characters"
  category: string_length
  kind: python_call_eq
  function: showwarning.__name__.__len__
  args: []
  expected: 11

invariant warnings_extra24.formatwarning.module.len:
  description: "warnings.formatwarning.__module__.__len__() == 12 — '_py_warnings' has 12 characters"
  category: string_length
  kind: python_call_eq
  function: formatwarning.__module__.__len__
  args: []
  expected: 12

invariant warnings_extra24.formatwarning.name.len:
  description: "warnings.formatwarning.__name__.__len__() == 13 — 'formatwarning' has 13 characters"
  category: string_length
  kind: python_call_eq
  function: formatwarning.__name__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# Warning subclass __name__.__len__() checks
#
# These built-in warning classes have __module__ == 'builtins'. Their __name__
# lengths form a verifiable cross-check table. No prior spec covers these lengths.
# DeprecationWarning=18, UserWarning=11, RuntimeWarning=14, SyntaxWarning=13,
# FutureWarning=13.
# ---------------------------------------------------------------------------

invariant warnings_extra24.DeprecationWarning.name.len:
  description: "DeprecationWarning.__name__.__len__() == 18 — 'DeprecationWarning' has 18 characters"
  category: string_length
  kind: python_call_eq
  function: DeprecationWarning.__name__.__len__
  args: []
  expected: 18

invariant warnings_extra24.UserWarning.name.len:
  description: "UserWarning.__name__.__len__() == 11 — 'UserWarning' has 11 characters"
  category: string_length
  kind: python_call_eq
  function: UserWarning.__name__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# Table: catch_warnings method __qualname__.__len__() values
#
# No prior spec groups catch_warnings method qualname length checks. The
# __enter__ method is 1 character longer than the others because '__enter__'
# (9 chars) vs '__init__'/'__exit__'/'__repr__' (8 chars each).
# ---------------------------------------------------------------------------

table warnings_extra24.catch_warnings_method_qualname_lengths:
  description: "catch_warnings method __qualname__ string lengths"
  kind: python_call_eq
  category: string_length

  columns: [id, function, args, expected, description]
  rows:
    - [catch_warnings_qualname_len,
       catch_warnings.__qualname__.__len__,
       [],
       14,
       "len('catch_warnings') == 14"]
    - [init_qualname_len,
       "catch_warnings.__init__.__qualname__.__len__",
       [],
       23,
       "len('catch_warnings.__init__') == 23"]
    - [enter_qualname_len,
       "catch_warnings.__enter__.__qualname__.__len__",
       [],
       24,
       "len('catch_warnings.__enter__') == 24"]
    - [exit_qualname_len,
       "catch_warnings.__exit__.__qualname__.__len__",
       [],
       23,
       "len('catch_warnings.__exit__') == 23"]
    - [repr_qualname_len,
       "catch_warnings.__repr__.__qualname__.__len__",
       [],
       23,
       "len('catch_warnings.__repr__') == 23"]

# ---------------------------------------------------------------------------
# Table: Warning subclass __name__.__len__() values
#
# No prior spec groups warning class name length checks into a table.
# All values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10.
# ---------------------------------------------------------------------------

table warnings_extra24.warning_class_name_lengths:
  description: "Built-in warning class __name__ string lengths"
  kind: python_call_eq
  category: string_length

  columns: [id, function, args, expected, description]
  rows:
    - [DeprecationWarning_name_len,
       DeprecationWarning.__name__.__len__,
       [],
       18,
       "len('DeprecationWarning') == 18"]
    - [UserWarning_name_len,
       UserWarning.__name__.__len__,
       [],
       11,
       "len('UserWarning') == 11"]
    - [RuntimeWarning_name_len,
       RuntimeWarning.__name__.__len__,
       [],
       14,
       "len('RuntimeWarning') == 14"]
    - [SyntaxWarning_name_len,
       SyntaxWarning.__name__.__len__,
       [],
       13,
       "len('SyntaxWarning') == 13"]
    - [FutureWarning_name_len,
       FutureWarning.__name__.__len__,
       [],
       13,
       "len('FutureWarning') == 13"]
    - [showwarning_module_len,
       showwarning.__module__.__len__,
       [],
       12,
       "len('_py_warnings') == 12"]
    - [showwarning_name_len,
       showwarning.__name__.__len__,
       [],
       11,
       "len('showwarning') == 11"]
    - [formatwarning_module_len,
       formatwarning.__module__.__len__,
       [],
       12,
       "len('_py_warnings') == 12"]
    - [formatwarning_name_len,
       formatwarning.__name__.__len__,
       [],
       13,
       "len('formatwarning') == 13"]
