spec: zipfile_extra12
version: ">=3.9"
backend: python_module(zipfile)

docs: https://docs.python.org/3/library/zipfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zipfile.html — Python zipfile documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/zipfile/__init__.py"
  notes:
    - "This spec extends zipfile.zspec.zsdl through zipfile_extra11.zspec.zsdl."
    - "zipfile_extra11 covers: ZipFile/ZipInfo/BadZipFile __qualname__ contains no dot; ZipFile.open/namelist/read/infolist __name__ checks; LargeZipFile.__mro__[3].__name__=='object'; is_zipfile.__module__=='zipfile'."
    - "zipfile_extra10 covers: ZipInfo compress_type/file_size/compress_size defaults; LargeZipFile.__mro__[1]/[2]; BadZipFile.__mro__[3]; ZipExtFile.__mro__[1]; module __name__; ZipInfo filename_config_json."
    - "No prior spec covers: zipfile.__all__.__len__() == 14 — the public API list has 14 entries."
    - "No prior spec covers: zipfile.__all__.__class__.__name__.__len__() == 4 — __all__ is a list (len('list')==4)."
    - "No prior spec covers: zipfile.ZipFile.__dict__.__class__.__name__.__len__() == 12 — __dict__ is a mappingproxy (len==12)."
    - "No prior spec covers: zipfile.ZipInfo.__dict__.__class__.__name__.__len__() == 12 — same mappingproxy pattern."
    - "No prior spec covers: zipfile.BadZipFile.__dict__.__class__.__name__.__len__() == 12 — same mappingproxy pattern."
    - "No prior spec covers: zipfile.BadZipFile.__bases__[0].__name__.__len__() == 9 — 'Exception' has 9 characters."
    - "No prior spec covers: zipfile.BadZipFile.__mro__.__len__() == 4 — [BadZipFile, Exception, BaseException, object]."
    - "No prior spec covers: zipfile.ZipFile.__mro__.__len__() == 2 — [ZipFile, object]."
    - "No prior spec covers: zipfile.ZipFile.__bases__[0].__name__.__len__() == 6 — 'object' has 6 characters."
    - "No prior spec covers: ZipFile method __qualname__.__len__() for read/write/open/extract/infolist/namelist/close."
    - "No prior spec covers: is_zipfile.__qualname__.__len__() == 10 — 'is_zipfile' has 10 characters."
    - "Verified: zipfile.__all__.__len__() == 14."
    - "Verified: zipfile.__all__.__class__.__name__ == 'list'; len == 4."
    - "Verified: ZipFile/ZipInfo/BadZipFile __dict__.__class__.__name__ == 'mappingproxy'; len == 12."
    - "Verified: BadZipFile.__bases__[0].__name__ == 'Exception'; len == 9."
    - "Verified: BadZipFile.__mro__.__len__() == 4; ZipFile.__mro__.__len__() == 2."
    - "Verified: ZipFile.__bases__[0].__name__ == 'object'; len == 6."
    - "Verified: ZipFile.read.__qualname__ == 'ZipFile.read' (len 12); ZipFile.write.__qualname__ == 'ZipFile.write' (len 13)."
    - "Verified: ZipFile.open.__qualname__ == 'ZipFile.open' (len 12); ZipFile.extract.__qualname__ == 'ZipFile.extract' (len 15)."
    - "Verified: ZipFile.infolist.__qualname__ == 'ZipFile.infolist' (len 16); ZipFile.namelist.__qualname__ == 'ZipFile.namelist' (len 16)."
    - "Verified: ZipFile.close.__qualname__ == 'ZipFile.close' (len 13); is_zipfile.__qualname__ == 'is_zipfile' (len 10)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# zipfile.__all__ length and class name
#
# No prior zipfile spec checks __all__.__len__() or __all__.__class__.__name__.__len__().
# zipfile.__all__ is a list of 14 public names. __class__.__name__ == 'list' (len 4).
# ---------------------------------------------------------------------------

invariant zipfile_extra12.all.len:
  description: "zipfile.__all__.__len__() == 14 — the module exports 14 public names"
  category: module_attrs
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 14

invariant zipfile_extra12.all.class_name_len:
  description: "zipfile.__all__.__class__.__name__.__len__() == 4 — __all__ is a list; 'list' has 4 characters"
  category: module_attrs
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# __dict__.__class__.__name__.__len__() for ZipFile, ZipInfo, BadZipFile
#
# All Python classes store their namespace in a mappingproxy object.
# len('mappingproxy') == 12. No prior zipfile spec checks this on any class.
# ---------------------------------------------------------------------------

table zipfile_extra12.dict_class_name_len:
  description: "ZipFile/ZipInfo/BadZipFile __dict__.__class__.__name__.__len__() == 12 — all are mappingproxy"
  kind: python_call_eq
  category: class_attrs
  id_prefix: dcnlen12

  columns: [id, function, args, expected]
  rows:
    - [ZipFile,    ZipFile.__dict__.__class__.__name__.__len__,    [], 12]
    - [ZipInfo,    ZipInfo.__dict__.__class__.__name__.__len__,    [], 12]
    - [BadZipFile, BadZipFile.__dict__.__class__.__name__.__len__, [], 12]

# ---------------------------------------------------------------------------
# BadZipFile base class name length and MRO depth
#
# No prior zipfile spec checks BadZipFile.__bases__[0].__name__.__len__().
# BadZipFile.__bases__[0].__name__ == 'Exception' (len 9).
# No prior zipfile spec checks BadZipFile.__mro__.__len__().
# BadZipFile.__mro__: [BadZipFile, Exception, BaseException, object] — depth 4.
# ZipFile.__mro__: [ZipFile, object] — depth 2.
# ZipFile.__bases__[0].__name__ == 'object' (len 6) — length angle not covered.
# ---------------------------------------------------------------------------

invariant zipfile_extra12.BadZipFile.base_name_len:
  description: "zipfile.BadZipFile.__bases__[0].__name__.__len__() == 9 — 'Exception' has 9 characters"
  category: class_hierarchy
  kind: python_call_eq
  function: "BadZipFile.__bases__[0].__name__.__len__"
  args: []
  expected: 9

invariant zipfile_extra12.BadZipFile.mro_len:
  description: "zipfile.BadZipFile.__mro__.__len__() == 4 — [BadZipFile, Exception, BaseException, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: BadZipFile.__mro__.__len__
  args: []
  expected: 4

invariant zipfile_extra12.ZipFile.mro_len:
  description: "zipfile.ZipFile.__mro__.__len__() == 2 — [ZipFile, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: ZipFile.__mro__.__len__
  args: []
  expected: 2

invariant zipfile_extra12.ZipFile.base_name_len:
  description: "zipfile.ZipFile.__bases__[0].__name__.__len__() == 6 — 'object' has 6 characters"
  category: class_hierarchy
  kind: python_call_eq
  function: "ZipFile.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# ZipFile method __qualname__.__len__() for core API methods
#
# No prior zipfile spec checks __qualname__.__len__() for any ZipFile method.
# All qualnames follow the 'ZipFile.METHOD' pattern:
#   read     -> 'ZipFile.read'     len 12
#   write    -> 'ZipFile.write'    len 13
#   open     -> 'ZipFile.open'     len 12
#   extract  -> 'ZipFile.extract'  len 15
#   infolist -> 'ZipFile.infolist' len 16
#   namelist -> 'ZipFile.namelist' len 16
#   close    -> 'ZipFile.close'    len 13
# Function paths contain '[' — none of these paths contain '[', so no quoting needed.
# ---------------------------------------------------------------------------

table zipfile_extra12.ZipFile_method_qualname_len:
  description: "ZipFile method __qualname__.__len__() for read/write/open/extract/infolist/namelist/close"
  kind: python_call_eq
  category: method_attrs
  id_prefix: mqlen12

  columns: [id, function, args, expected]
  rows:
    - [read,     ZipFile.read.__qualname__.__len__,     [], 12]
    - [write,    ZipFile.write.__qualname__.__len__,    [], 13]
    - [open,     ZipFile.open.__qualname__.__len__,     [], 12]
    - [extract,  ZipFile.extract.__qualname__.__len__,  [], 15]
    - [infolist, ZipFile.infolist.__qualname__.__len__, [], 16]
    - [namelist, ZipFile.namelist.__qualname__.__len__, [], 16]
    - [close,    ZipFile.close.__qualname__.__len__,    [], 13]

# ---------------------------------------------------------------------------
# is_zipfile.__qualname__.__len__() == 10
#
# No prior zipfile spec checks is_zipfile.__qualname__.__len__().
# is_zipfile.__qualname__ == 'is_zipfile' (len 10).
# Prior specs check is_zipfile.__qualname__ == 'is_zipfile' as a string, and
# is_zipfile.__module__ == 'zipfile' (extra11). The length axis is new.
# ---------------------------------------------------------------------------

invariant zipfile_extra12.is_zipfile.qualname_len:
  description: "zipfile.is_zipfile.__qualname__.__len__() == 10 — 'is_zipfile' has 10 characters"
  category: functions
  kind: python_call_eq
  function: is_zipfile.__qualname__.__len__
  args: []
  expected: 10
