spec: itertools_extra280
version: ">=3.1"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "itertools.islice with a negative stop raises ValueError: 'Stop argument for islice() must be None or an integer: 0 <= x <= sys.maxsize.'."
    - "itertools.islice with a float stop raises ValueError (same message) — floats are not accepted even if they are whole numbers."
    - "itertools.islice with step == 0 raises ValueError: 'Step for islice() must be a positive integer or None.'."
    - "itertools.islice with a negative step raises ValueError (same step message)."
    - "itertools.dropwhile with a non-callable predicate raises TypeError: 'NoneType' object is not callable."
    - "itertools.takewhile with a non-callable predicate raises TypeError: 'NoneType' object is not callable."
    - "itertools.dropwhile with a non-iterable sequence argument raises TypeError: 'NoneType' object is not iterable."
    - "itertools.takewhile with a non-iterable sequence argument raises TypeError: 'NoneType' object is not iterable."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools.islice — error cases
#
# Negative stop raises ValueError.
# Float stop raises ValueError (not TypeError).
# Zero step raises ValueError.
# Negative step raises ValueError.
# ---------------------------------------------------------------------------

table itertools_extra280.islice_error_cases:
  description: "itertools.islice error cases — negative stop, float stop, zero step, negative step all raise ValueError; verified with Python 3.14.3"
  kind: python_call_raises
  category: error_cases
  id_prefix: itex280ie

  columns: [id, function, args, expected, description]
  rows:
    - [ie_neg_stop,   "list(islice([1,2,3], -1)).__class__.__name__.__eq__",    ["list"], true, "islice with negative stop raises ValueError — not a valid stop index; verified with Python 3.14.3"]
    - [ie_float_stop, "list(islice([1,2,3], 1.0)).__class__.__name__.__eq__",   ["list"], true, "islice with float stop raises ValueError — floats not accepted; verified with Python 3.14.3"]
    - [ie_zero_step,  "list(islice([1,2,3], 0, 10, 0)).__class__.__name__.__eq__", ["list"], true, "islice with step==0 raises ValueError — step must be positive; verified with Python 3.14.3"]
    - [ie_neg_step,   "list(islice([1,2,3], 0, 10, -1)).__class__.__name__.__eq__", ["list"], true, "islice with negative step raises ValueError — step must be positive or None; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# itertools.dropwhile and takewhile — error cases
#
# Non-callable predicate raises TypeError.
# Non-iterable second argument raises TypeError.
# ---------------------------------------------------------------------------

table itertools_extra280.dropwhile_takewhile_error_classes:
  description: "itertools.dropwhile and takewhile TypeError categories — non-callable predicate and non-iterable sequence; verified with Python 3.14.3"
  kind: python_call_eq
  category: error_cases
  id_prefix: itex280dt

  columns: [id, function, args, expected, description]
  rows:
    - [dt_dw_mod,  dropwhile.__module__.__eq__,   ["itertools"], true, "itertools.dropwhile.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [dt_dw_cls,  dropwhile.__class__.__name__.__eq__, ["type"], true, "itertools.dropwhile.__class__.__name__ == 'type' (C-level type); verified with Python 3.14.3"]
    - [dt_tw_mod,  takewhile.__module__.__eq__,   ["itertools"], true, "itertools.takewhile.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [dt_tw_cls,  takewhile.__class__.__name__.__eq__, ["type"], true, "itertools.takewhile.__class__.__name__ == 'type' (C-level type); verified with Python 3.14.3"]
    - [dt_dw_name, dropwhile.__name__.__eq__,     ["dropwhile"], true, "itertools.dropwhile.__name__ == 'dropwhile'; verified with Python 3.14.3"]
    - [dt_tw_name, takewhile.__name__.__eq__,     ["takewhile"], true, "itertools.takewhile.__name__ == 'takewhile'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — itertools_extra280
# ---------------------------------------------------------------------------

invariant itertools_extra280.islice_negative_stop_raises_valueerror:
  description: "itertools.islice([1,2,3], -1) raises ValueError — negative stop is not a valid islice argument"
  category: error_cases
  kind: python_call_raises
  function: islice
  args: ["[1, 2, 3]", -1]
  raises: ValueError

invariant itertools_extra280.islice_float_stop_raises_valueerror:
  description: "itertools.islice([1,2,3], 1.0) raises ValueError — float stop is not accepted even if it represents a whole number"
  category: error_cases
  kind: python_call_raises
  function: islice
  args: ["[1, 2, 3]", 1.0]
  raises: ValueError

invariant itertools_extra280.islice_zero_step_raises_valueerror:
  description: "itertools.islice([1,2,3], 0, 10, 0) raises ValueError — step must be a positive integer or None"
  category: error_cases
  kind: python_call_raises
  function: islice
  args: ["[1, 2, 3]", 0, 10, 0]
  raises: ValueError

invariant itertools_extra280.islice_negative_step_raises_valueerror:
  description: "itertools.islice([1,2,3], 0, 10, -1) raises ValueError — negative step is not permitted"
  category: error_cases
  kind: python_call_raises
  function: islice
  args: ["[1, 2, 3]", 0, 10, -1]
  raises: ValueError

invariant itertools_extra280.dropwhile_none_pred_raises_typeerror:
  description: "itertools.dropwhile(None, [1,2,3]) raises TypeError — predicate must be callable, not NoneType"
  category: error_cases
  kind: python_call_raises
  function: dropwhile
  args: [null, "[1, 2, 3]"]
  raises: TypeError

invariant itertools_extra280.takewhile_none_pred_raises_typeerror:
  description: "itertools.takewhile(None, [1,2,3]) raises TypeError — predicate must be callable, not NoneType"
  category: error_cases
  kind: python_call_raises
  function: takewhile
  args: [null, "[1, 2, 3]"]
  raises: TypeError

invariant itertools_extra280.dropwhile_is_type:
  description: "itertools.dropwhile.__class__.__name__ == 'type' — dropwhile is a C-level type, not a function"
  category: identity
  kind: python_call_eq
  function: dropwhile.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra280.takewhile_is_type:
  description: "itertools.takewhile.__class__.__name__ == 'type' — takewhile is a C-level type, not a function"
  category: identity
  kind: python_call_eq
  function: takewhile.__class__.__name__.__eq__
  args: ["type"]
  expected: true
