  columns: [id, function, args, expected]
  rows:
    - [SRV001, asyncio.AbstractServer.__name__.__eq__, ["AbstractServer"], true]
    - [SRV002, asyncio.AbstractServer.__module__.__eq__, ["asyncio.events"], true]
    - [SRV003, "asyncio.AbstractServer.__bases__[0].__name__.__eq__", ["object"], true]

table asyncio_extra486.handle_identity:
  description: "asyncio.Handle and asyncio.TimerHandle class identity"
  kind: python_call_eq
  category: identity
  id_prefix: HDL

  columns: [id, function, args, expected]
  rows:
    - [HDL001, asyncio.Handle.__name__.__eq__, ["Handle"], true]
    - [HDL002, asyncio.Handle.__module__.__eq__, ["asyncio.events"], true]
    - [HDL003, "asyncio.Handle.__bases__[0].__name__.__eq__", ["object"], true]
    - [HDL004, asyncio.TimerHandle.__name__.__eq__, ["TimerHandle"], true]
    - [HDL005, "asyncio.TimerHandle.__bases__[0].__name__.__eq__", ["Handle"], true]
