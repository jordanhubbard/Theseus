spec: asyncio_extra486
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-eventloop.html — asyncio event loop policy identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers identity of abstract base classes defined in asyncio.events"
    - "TimerHandle inherits from Handle, not object"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra486.policy_identity:
  description: "asyncio.AbstractEventLoopPolicy class identity"
  kind: python_call_eq
  category: identity
  id_prefix: POL

  columns: [id, function, args, expected]
  rows:
    - [POL001, asyncio.AbstractEventLoopPolicy.__name__.__eq__, ["AbstractEventLoopPolicy"], true]
    - [POL002, asyncio.AbstractEventLoopPolicy.__module__.__eq__, ["asyncio.events"], true]
    - [POL003, "asyncio.AbstractEventLoopPolicy.__bases__[0].__name__.__eq__", ["object"], true]

table asyncio_extra486.loop_identity:
  description: "asyncio.AbstractEventLoop class identity"
  kind: python_call_eq
  category: identity
  id_prefix: LOOP

  columns: [id, function, args, expected]
  rows:
    - [LOOP001, asyncio.AbstractEventLoop.__name__.__eq__, ["AbstractEventLoop"], true]
    - [LOOP002, asyncio.AbstractEventLoop.__module__.__eq__, ["asyncio.events"], true]
    - [LOOP003, "asyncio.AbstractEventLoop.__bases__[0].__name__.__eq__", ["object"], true]

table asyncio_extra486.server_identity:
  description: "asyncio.AbstractServer class identity"
  kind: python_call_eq
  category: identity
