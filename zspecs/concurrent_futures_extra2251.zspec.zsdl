spec: concurrent_futures_extra2251
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py, Lib/concurrent/futures/thread.py, Lib/concurrent/futures/process.py"
  notes:
    - "Wave 2251 (_extra2251): callable protocol and function-attribute dict-presence — __call__, __code__, __globals__, __defaults__, __kwdefaults__, __annotations__, __builtins__ checks."
    - "Classes checked: concurrent.futures.Future, concurrent.futures.Executor, concurrent.futures.ThreadPoolExecutor, concurrent.futures.ProcessPoolExecutor."
    - "Executor is an abstract base class; ThreadPoolExecutor and ProcessPoolExecutor are concrete subclasses."
    - "__call__ is NOT in __dict__ for any of these classes — none implement __call__ in their own class body."
    - "__code__ is NOT in __dict__ for any of these classes — __code__ is a function-object attribute, not a class attribute."
    - "__globals__ is NOT in __dict__ for any of these classes — __globals__ is a function-object attribute holding module globals."
    - "__defaults__ is NOT in __dict__ for any of these classes — __defaults__ is a function-object attribute for positional defaults."
    - "__kwdefaults__ is NOT in __dict__ for any of these classes — __kwdefaults__ is a function-object attribute for keyword-only defaults."
    - "__annotations__ is NOT in __dict__ for any of these classes — none of the four class bodies carry annotated class-level variables."
    - "__builtins__ is NOT in __dict__ for any of these classes — __builtins__ is a module-level name injected by the import machinery."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __call__ dict-presence — all 4 concurrent.futures classes
#
# __call__ is NOT in the __dict__ of any concurrent.futures class checked here.
# Future, Executor, ThreadPoolExecutor, and ProcessPoolExecutor do not define
# a __call__ method in their own class body. All 4 return False.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2251.call_dict_presence:
  description: "__call__ dict-presence for cf.Future/Executor/ThreadPoolExecutor/ProcessPoolExecutor — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2251

  columns: [id, function, args, expected]
  rows:
    - ["cf2251001", "concurrent.futures.Future.__dict__.__contains__", ["__call__"], false]
    - ["cf2251002", "concurrent.futures.Executor.__dict__.__contains__", ["__call__"], false]
    - ["cf2251003", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__call__"], false]
    - ["cf2251004", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__call__"], false]

# ---------------------------------------------------------------------------
# Table 2: __code__ dict-presence — all 4 concurrent.futures classes
#
# __code__ is NOT in the __dict__ of any concurrent.futures class. __code__
# is an attribute of function objects (holding the bytecode). Class objects
# do not carry this entry in their __dict__. All 4 return False.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2251.code_dict_presence:
  description: "__code__ dict-presence for cf.Future/Executor/ThreadPoolExecutor/ProcessPoolExecutor — all False"
