spec: xml2js
version: ">=0.4.0"
backend: node(xml2js)

docs: https://www.npmjs.com/package/xml2js

provenance:
  derived_from:
    - "xml2js README — https://www.npmjs.com/package/xml2js"
    - "Test vectors verified with xml2js via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "xml2js source"
  notes:
    - "xml2js is an npm package. Install: npm install xml2js"
    - "xml2js.Builder constructs XML from JavaScript objects."
    - "new Builder({headless: true}).buildObject(obj) returns an XML string without XML declaration."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns XML string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table xml2js.Builder.buildObject:
  kind: node_constructor_call_eq
  class: Builder
  ctor_args: [{"headless": true}]
  method: buildObject
  id_prefix: xmlbld

  columns: [id, args, expected]
  rows:
    - [simple, [{"foo": "bar"}],                    "<foo>bar</foo>"]
    - [nested, [{"root": {"item": "value"}}],        "<root>\n  <item>value</item>\n</root>"]
