spec: struct_extra95
version: ">=3.9"
backend: python_module(struct)
extends: struct_extra94

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra94.zspec.zsdl — covers Struct method __qualname__.__len__() / struct.error MRO depth and entry names / module-level function __qualname__.__len__() for pack/unpack/calcsize (table + invariants)."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ / Struct.format/__qualname__ / error __bases__ and __module__ / Struct __module__/__qualname__/__bases__/__mro__.__len__()==2 (table + invariants)."
    - "struct_extra92.zspec.zsdl — covers struct module-level function __class__.__name__ / Struct method __class__.__name__ / struct.error inheritance and __module__/__qualname__ (table + invariants)."
    - "struct_extra91.zspec.zsdl — covers struct.calcsize return values / struct.pack/__qualname__ / struct.Struct.__doc__/__class__.__name__ / struct.error/__class__.__name__ (table + invariants)."
    - "struct_extra90.zspec.zsdl — covers struct module-level function __qualname__ / Struct method __qualname__ and class names (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra94; it does NOT duplicate invariants present in those files."
    - "Wave 262 theme: struct module-level function __qualname__.__len__() for remaining functions — pack_into/unpack_from/iter_unpack lengths / Struct.__qualname__.__len__()==6 / error.__qualname__.__len__()==5 / module attribute cross-checks."
    - "struct.pack_into.__qualname__.__len__() == 9 ('pack_into'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__qualname__.__len__() == 11 ('unpack_from'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__qualname__.__len__() == 11 ('iter_unpack'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__qualname__.__len__() == 6 ('Struct'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__qualname__.__len__() == 5 ('error'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: pack_into and unpack_from both have qualname.__len__()==9 and 11 as simple function names; all module-level struct functions are C builtins from the _struct extension module."
    - "Note: unpack_from and iter_unpack share __qualname__.__len__()==11 (both 11-char names)."
    - "Note: Struct.__qualname__ is 'Struct' (6 chars, same as the class name); error.__qualname__ is 'error' (5 chars, same as the exception class name)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack_into.__qualname__.__len__()==9
# struct.unpack_from.__qualname__.__len__()==11
# struct.iter_unpack.__qualname__.__len__()==11
#
# Wave 262 theme: remaining module-level struct function __qualname__.__len__().
#
# struct_extra94 anchors pack (4), unpack (6), calcsize (8) lengths. This table
# anchors the remaining three: pack_into ('pack_into', 9), unpack_from
# ('unpack_from', 11), iter_unpack ('iter_unpack', 11). unpack_from and
# iter_unpack share the same length (11) because both names are 11 chars.
# All three are C builtins from the _struct extension. No prior spec anchors
# these three __qualname__.__len__() values under structqlen95.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra95.struct_remaining_fn_qualname_lengths:
  description: "struct.pack_into/__qualname__/__len__()==9 / unpack_from/__qualname__/__len__()==11 / iter_unpack/__qualname__/__len__()==11 — remaining module-level functions not covered by extra94; pack_into is 'pack_into' (9), unpack_from/iter_unpack share length 11; all are C builtins from _struct; extra94 anchors pack/unpack/calcsize; first structqlen95 anchor for pack_into/unpack_from/iter_unpack qualname lengths"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: structqlen95

  columns: [id, function, args, expected, description]
  rows:
    - [pack_into_qlen,   pack_into.__qualname__.__len__,   [], 9,  "'pack_into' is 9 chars, simple C builtin function name"]
    - [unpack_from_qlen, unpack_from.__qualname__.__len__, [], 11, "'unpack_from' is 11 chars, same length as 'iter_unpack'"]
    - [iter_unpack_qlen, iter_unpack.__qualname__.__len__, [], 11, "'iter_unpack' is 11 chars, same length as 'unpack_from'"]

# ---------------------------------------------------------------------------
# struct.Struct.__qualname__.__len__()==6
# struct.error.__qualname__.__len__()==5
#
# Wave 262 theme: Struct class and error exception __qualname__.__len__().
#
# Struct.__qualname__ is 'Struct' (6 chars), same as the class name — it is a
# top-level class in the _struct module so there is no enclosing class prefix.
# error.__qualname__ is 'error' (5 chars), same as the exception class name.
# Prior specs anchor __qualname__.__eq__ for both; this table first anchors
# __qualname__.__len__() for Struct and error under structqlen95.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra95.struct_Struct_error_qualname_lengths:
  description: "struct.Struct/__qualname__/__len__()==6 / error/__qualname__/__len__()==5 — Struct.__qualname__ is 'Struct' (6 chars, top-level class name from _struct); error.__qualname__ is 'error' (5 chars, exception class name); prior specs anchor __qualname__.__eq__; first structqlen95 anchor for Struct and error qualname lengths"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: structqlen95

  columns: [id, function, args, expected, description]
  rows:
    - [Struct_qlen, Struct.__qualname__.__len__, [], 6, "'Struct' is 6 chars, the C-extension class name from _struct"]
    - [error_qlen,  error.__qualname__.__len__,  [], 5, "'error' is 5 chars, the exception class name"]

# ---------------------------------------------------------------------------
# struct module-level function __module__ cross-checks
# struct.pack.__module__.__eq__('_struct')
# struct.unpack.__module__.__eq__('_struct')
# struct.calcsize.__module__.__eq__('_struct')
# struct.pack_into.__module__.__eq__('_struct')
# struct.unpack_from.__module__.__eq__('_struct')
# struct.iter_unpack.__module__.__eq__('_struct')
#
# Wave 262 supplemental: module-level function __module__ identity.
#
# All six module-level struct functions are C builtins from the _struct extension,
# so their __module__ attribute is '_struct'. struct_extra92 anchors module-level
# function __class__.__name__=='builtin_function_or_method'; no prior spec anchors
# __module__=='_struct' equality for all six together under structqlen95.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra95.struct_fn_module_identity:
  description: "struct.pack/__module__/__eq__('_struct')==True / unpack/__module__/__eq__('_struct')==True / calcsize/__module__/__eq__('_struct')==True / pack_into/__module__/__eq__('_struct')==True / unpack_from/__module__/__eq__('_struct')==True / iter_unpack/__module__/__eq__('_struct')==True — all six module-level functions are C builtins from the _struct C extension; extra92 anchors __class__.__name__; first structqlen95 anchor for __module__ equality on all six"
  kind: python_call_eq
  category: type_identity
  id_prefix: structqlen95

  columns: [id, function, args, expected, description]
  rows:
    - [pack_mod,        pack.__module__.__eq__,        ["_struct"], true, "struct.pack comes from the _struct C extension module"]
    - [unpack_mod,      unpack.__module__.__eq__,      ["_struct"], true, "struct.unpack comes from the _struct C extension module"]
    - [calcsize_mod,    calcsize.__module__.__eq__,    ["_struct"], true, "struct.calcsize comes from the _struct C extension module"]
    - [pack_into_mod,   pack_into.__module__.__eq__,   ["_struct"], true, "struct.pack_into comes from the _struct C extension module"]
    - [unpack_from_mod, unpack_from.__module__.__eq__, ["_struct"], true, "struct.unpack_from comes from the _struct C extension module"]
    - [iter_unpack_mod, iter_unpack.__module__.__eq__, ["_struct"], true, "struct.iter_unpack comes from the _struct C extension module"]

# ---------------------------------------------------------------------------
# struct.Struct.__qualname__.__len__()==6 — standalone
#
# struct.Struct.__qualname__.__len__() is 6. Struct.__qualname__ is 'Struct'
# (6 chars), the simple class name with no enclosing scope prefix. Struct is
# a C-extension type defined in the _struct module, exposed at the top level
# of the struct module. Since it is a top-level class, its __qualname__ equals
# its __name__. Prior specs (extra91/extra93) anchor __qualname__.__eq__ and
# __module__; no prior spec anchors Struct.__qualname__.__len__()==6 as a
# standalone under structqlen95. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra95.Struct_qualname_len_6:
  description: "struct.Struct.__qualname__.__len__() == 6 — Struct.__qualname__ is 'Struct' (6 chars); Struct is a top-level C-extension type from _struct so __qualname__ equals __name__; extra91/extra93 anchor __qualname__.__eq__ and __module__; first standalone for Struct.__qualname__.__len__() under structqlen95"
  category: qualname_lengths
  kind: python_call_eq
  function: Struct.__qualname__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# struct.error.__qualname__.__len__()==5 — standalone
#
# struct.error.__qualname__.__len__() is 5. error.__qualname__ is 'error'
# (5 chars), the simple exception class name. struct.error is a top-level
# exception class in the struct module (defined in _struct.c), so its
# __qualname__ equals its __name__. error is the only exception raised by
# struct operations (e.g., malformed format strings, buffer size mismatches).
# Prior specs anchor __qualname__.__eq__ and __module__; no prior spec anchors
# error.__qualname__.__len__()==5 as a standalone under structqlen95.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra95.error_qualname_len_5:
  description: "struct.error.__qualname__.__len__() == 5 — error.__qualname__ is 'error' (5 chars); error is a top-level exception from _struct.c so __qualname__ equals __name__; it is the only exception raised by struct operations; prior specs anchor __qualname__.__eq__ and __module__; first standalone for error.__qualname__.__len__() under structqlen95"
  category: qualname_lengths
  kind: python_call_eq
  function: error.__qualname__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# struct.pack_into.__qualname__.__len__()==9 — standalone
#
# struct.pack_into.__qualname__.__len__() is 9. pack_into.__qualname__ is
# 'pack_into' (9 chars). pack_into is a C builtin from _struct that writes
# packed bytes into a writable buffer (bytearray or mutable memoryview) at a
# given offset, without creating an intermediate bytes object. Unlike pack,
# it operates in-place. struct_extra94 anchors pack/unpack/calcsize qualname
# lengths; no prior spec anchors pack_into.__qualname__.__len__()==9 as a
# standalone under structqlen95. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra95.pack_into_qualname_len_9:
  description: "struct.pack_into.__qualname__.__len__() == 9 — pack_into.__qualname__ is 'pack_into' (9 chars); pack_into is a C builtin from _struct that writes packed bytes into a mutable buffer at a given offset without creating intermediate bytes; extra94 anchors pack/unpack/calcsize lengths; first standalone for pack_into.__qualname__.__len__() under structqlen95"
  category: qualname_lengths
  kind: python_call_eq
  function: pack_into.__qualname__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# struct.iter_unpack.__qualname__.__len__()==11 — standalone
#
# struct.iter_unpack.__qualname__.__len__() is 11. iter_unpack.__qualname__
# is 'iter_unpack' (11 chars). iter_unpack is a C builtin from _struct that
# returns an iterator that unpacks repeatedly from a buffer according to a
# format, advancing position by struct.calcsize(fmt) bytes each step. It
# shares length 11 with unpack_from. struct_extra94 anchors the Struct method
# iter_unpack qualname length (18); no prior spec anchors the module-level
# function iter_unpack.__qualname__.__len__()==11 as a standalone under
# structqlen95. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra95.iter_unpack_qualname_len_11:
  description: "struct.iter_unpack.__qualname__.__len__() == 11 — iter_unpack.__qualname__ is 'iter_unpack' (11 chars); iter_unpack is a C builtin from _struct returning an iterator that unpacks repeatedly from a buffer; shares length 11 with unpack_from; extra94 anchors Struct.iter_unpack method qualname length (18); first standalone for module-level iter_unpack.__qualname__.__len__() under structqlen95"
  category: qualname_lengths
  kind: python_call_eq
  function: iter_unpack.__qualname__.__len__
  args: []
  expected: 11
