spec: detect_indent
version: ">=7.0.0"
backend: node(detect-indent)

docs: https://github.com/sindresorhus/detect-indent#readme

provenance:
  derived_from:
    - "detect-indent README — https://github.com/sindresorhus/detect-indent#readme"
    - "Test vectors verified with detect-indent via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "detect-indent source"
  notes:
    - "detect-indent infers a source file's indentation style from a sample of its text."
    - "Install: npm install detect-indent"
    - "v7 is ESM with a CJS shim; default export is the function."
    - "Returns {amount: N, type: 'space'|'tab'|undefined, indent: '<chars>'}; for un-indented text, amount=0 and indent=''."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# .amount — number of characters in the inferred indent
table detect_indent.amount:
  kind: node_chain_eq
  category: amount
  entry: named
  function: default
  id_prefix: amount

  columns: [id, entry_args, chain, expected]
  rows:
    - [two_spaces,
       ["  hello\n  world\n"],
       [{get: amount}],
       2]

    - [four_spaces,
       ["    a\n    b\n"],
       [{get: amount}],
       4]

    - [single_tab,
       ["\thello\n\tworld"],
       [{get: amount}],
       1]

    - [no_indent,
       ["plain text\nwith no indent"],
       [{get: amount}],
       0]

# .type — 'space' | 'tab' | (undefined for no indent)
table detect_indent.type:
  kind: node_chain_eq
  category: type
  entry: named
  function: default
  id_prefix: type

  columns: [id, entry_args, chain, expected]
  rows:
    - [space,
       ["  hello\n  world\n"],
       [{get: type}],
       "space"]

    - [tab,
       ["\thello\n\tworld"],
       [{get: type}],
       "tab"]

    - [no_indent_undefined,
       ["plain"],
       [{get: type}],
       ~]

# .indent — the actual whitespace string
table detect_indent.indent:
  kind: node_chain_eq
  category: indent
  entry: named
  function: default
  id_prefix: indent

  columns: [id, entry_args, chain, expected]
  rows:
    - [two_spaces,
       ["  hello\n  world\n"],
       [{get: indent}],
       "  "]

    - [single_tab,
       ["\thello\n\tworld"],
       [{get: indent}],
       "\t"]

    - [no_indent_empty_string,
       ["plain"],
       [{get: indent}],
       ""]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:15:07Z
  iterations: 1
  pass_count: 10
  fail_count: 0
  total_invariants: 10
  notes: Synthesis succeeded in 1 iteration(s). 10 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
