spec: concurrent_futures_extra14
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures.zspec.zsdl and prior extras through concurrent_futures_extra13.zspec.zsdl."
    - "extra covers: Future/Executor/ThreadPoolExecutor/ProcessPoolExecutor/BrokenExecutor/InvalidStateError __name__; FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED string values and __class__.__name__; wait/__name__; as_completed/__name__."
    - "extra8 covers: CancelledError/__mro__[1].__name__=='Error'; CancelledError/__mro__[2].__name__=='Exception'; BrokenExecutor/__mro__[2].__name__=='Exception'; as_completed/wait __class__.__name__=='function'."
    - "extra9 covers: ThreadPoolExecutor/__class__.__name__=='type'; ProcessPoolExecutor/__class__.__name__=='type'; ThreadPoolExecutor/ProcessPoolExecutor __mro__[2].__name__=='object'."
    - "extra11 covers: BrokenExecutor/CancelledError/TimeoutError __class__.__name__=='type'; BrokenExecutor/__mro__[2].__name__=='Exception'."
    - "extra12 covers: Executor/Future __class__.__name__=='type'; Executor/__mro__[1].'object'; Future/__mro__[1].'object'; InvalidStateError/__mro__[2].'Exception'; Future.set_exception/__name__; ThreadPoolExecutor.map/__qualname__."
    - "extra13 covers: ThreadPoolExecutor/ProcessPoolExecutor __module__; Future/__module__; as_completed/wait __module__; ThreadPoolExecutor/ProcessPoolExecutor/Future __qualname__; FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED __eq__ values."
    - "NOT yet covered in any prior spec: TimeoutError.__mro__[1].__name__ — MRO index 1 for concurrent.futures.TimeoutError."
    - "NOT yet covered: TimeoutError.__mro__[2].__name__ — MRO index 2 for concurrent.futures.TimeoutError."
    - "NOT yet covered: InvalidStateError.__class__.__name__ == 'type' — metaclass check for InvalidStateError."
    - "NOT yet covered: TimeoutError.__mro__[3].__name__ == 'BaseException' — MRO index 3 for concurrent.futures.TimeoutError."
    - "concurrent.futures.TimeoutError is builtins.TimeoutError (aliased in Python 3.11+). Its MRO is [TimeoutError, OSError, Exception, BaseException, object], so index 1 is 'OSError', index 2 is 'Exception', index 3 is 'BaseException'."
    - "concurrent.futures.InvalidStateError.__class__.__name__ == 'type' — it is a plain Python class."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TimeoutError MRO access
#
# extra8 covers CancelledError/__mro__[1]=='Error' and CancelledError/__mro__[2]
# =='Exception', and BrokenExecutor/__mro__[2]=='Exception'. No prior spec
# checks TimeoutError.__mro__[1] or TimeoutError.__mro__[2].
# concurrent.futures.TimeoutError is builtins.TimeoutError in Python 3.11+;
# its MRO is [TimeoutError, OSError, Exception, BaseException, object].
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra14.TimeoutError.mro_index1:
  description: "concurrent.futures.TimeoutError.__mro__[1].__name__ == 'OSError'"
  category: class_hierarchy
  kind: python_call_eq
  function: TimeoutError.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "OSError"

invariant concurrent_futures_extra14.TimeoutError.mro_index2:
  description: "concurrent.futures.TimeoutError.__mro__[2].__name__ == 'Exception'"
  category: class_hierarchy
  kind: python_call_eq
  function: TimeoutError.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# InvalidStateError metaclass check
#
# extra9 covers ThreadPoolExecutor/ProcessPoolExecutor __class__.__name__.
# extra11 covers BrokenExecutor/CancelledError/TimeoutError __class__.__name__.
# extra12 covers Executor/Future __class__.__name__. No prior spec checks
# InvalidStateError.__class__.__name__. InvalidStateError is a plain Python
# class, so its metaclass is 'type'.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra14.InvalidStateError.class_name:
  description: "concurrent.futures.InvalidStateError.__class__.__name__ == 'type'"
  category: class_types
  kind: python_call_eq
  function: InvalidStateError.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# TimeoutError MRO index 3 — BaseException
#
# extra8 covers CancelledError MRO[1]/'Error' and MRO[2]/'Exception'.
# No prior spec checks TimeoutError.__mro__[3]. For TimeoutError whose MRO is
# [TimeoutError, OSError, Exception, BaseException, object], index 3 is
# 'BaseException'.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra14.TimeoutError.mro_index3:
  description: "concurrent.futures.TimeoutError.__mro__[3].__name__ == 'BaseException'"
  category: class_hierarchy
  kind: python_call_eq
  function: TimeoutError.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "BaseException"

# ---------------------------------------------------------------------------
# FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED — __contains__ checks
#
# extra13 covers __eq__ value checks for the three wait constants.
# extra8 covers __len__ for FIRST_COMPLETED and FIRST_EXCEPTION (len==15)
# and ALL_COMPLETED (len==13). No prior spec checks __contains__ for any
# wait constant — checking substring membership provides independent
# verification that the string values contain their expected substrings.
# ---------------------------------------------------------------------------

table concurrent_futures_extra14.wait_constant_contains:
  description: "concurrent.futures wait constants contain expected substrings"
  kind: python_call_eq
  category: constants
  id_prefix: waitcont14

  columns: [id, function, args, expected]
  rows:
    - [FIRST_COMPLETED_has_FIRST, FIRST_COMPLETED.__contains__, ["FIRST"],     true]
    - [FIRST_EXCEPTION_has_FIRST, FIRST_EXCEPTION.__contains__, ["FIRST"],     true]
    - [ALL_COMPLETED_has_ALL,     ALL_COMPLETED.__contains__,   ["ALL"],       true]
    - [ALL_COMPLETED_has_COMPL,   ALL_COMPLETED.__contains__,   ["COMPLETED"], true]

# ---------------------------------------------------------------------------
# TimeoutError __qualname__ — standalone invariant
#
# extra6 covers TimeoutError/__qualname__ in a table. No prior spec checks
# TimeoutError.__qualname__ as a standalone invariant. For a top-level class,
# __qualname__ == __name__ == 'TimeoutError'.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra14.TimeoutError.qualname:
  description: "concurrent.futures.TimeoutError.__qualname__ == 'TimeoutError'"
  category: class_names
  kind: python_call_eq
  function: TimeoutError.__qualname__.__eq__
  args: ["TimeoutError"]
  expected: true
