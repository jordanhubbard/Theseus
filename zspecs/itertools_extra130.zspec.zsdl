spec: itertools_extra130
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.groupby class slot qualnames and class identity attributes (Wave 260)."
    - "itertools.groupby.__iter__.__qualname__ == 'groupby.__iter__' (len 16). Verified with Python 3.14.3."
    - "itertools.groupby.__next__.__qualname__ == 'groupby.__next__' (len 16). Verified with Python 3.14.3."
    - "itertools.groupby.__new__.__qualname__ == 'groupby.__new__' (len 15). Verified with Python 3.14.3."
    - "itertools.groupby.__class__.__name__ == 'type' — groupby is a C extension type. Verified with Python 3.14.3."
    - "itertools.groupby.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "len(itertools.groupby.__mro__) == 2 — MRO is [groupby, object]. Verified with Python 3.14.3."
    - "itertools.groupby.__name__ == 'groupby' (len 7). Verified with Python 3.14.3."
    - "itertools.groupby.__qualname__ == 'groupby' (len 7). Verified with Python 3.14.3."
    - "itertools.groupby.__iter__.__class__.__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3."
    - "itertools.groupby.__next__.__class__.__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3."
    - "itertools.groupby.__new__.__class__.__name__ == 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.groupby slot __qualname__ values and lengths
#
# Wave 260 theme: itertools.groupby slot __qualname__ attribute values.
#
# itertools.groupby.__iter__.__qualname__ == 'groupby.__iter__' (len 16)
# itertools.groupby.__next__.__qualname__ == 'groupby.__next__' (len 16)
# itertools.groupby.__new__.__qualname__ == 'groupby.__new__' (len 15)
#
# The __qualname__ on C extension slot wrapper descriptors follows the
# 'TypeName.slot_name' pattern. New to extra130.
# ---------------------------------------------------------------------------

table itertools_extra130.groupby_slot_qualnames:
  description: "itertools.groupby slot __qualname__ values: __iter__/__next__/__new__; wrapper_descriptor qualname pattern 'groupby.slot'; wave 260; new to extra130"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsgroupby130

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_iter_qualname_eq,
       "groupby.__iter__.__qualname__.__eq__",
       ["groupby.__iter__"],
       true,
       "itertools.groupby.__iter__.__qualname__.__eq__('groupby.__iter__') == True — __iter__ on a C extension type is exposed as a wrapper_descriptor; its __qualname__ follows the 'TypeName.slot_name' convention; for groupby the qualname is 'groupby.__iter__'; str.__eq__ returns True; new to extra130"]
    - [groupby_iter_qualname_len_16,
       "groupby.__iter__.__qualname__.__len__",
       [],
       16,
       "itertools.groupby.__iter__.__qualname__.__len__() == 16 — 'groupby.__iter__' is 16 characters (7 for 'groupby' + 1 for '.' + 8 for '__iter__'); str.__len__() returns 16; new to extra130"]
    - [groupby_next_qualname_eq,
       "groupby.__next__.__qualname__.__eq__",
       ["groupby.__next__"],
       true,
       "itertools.groupby.__next__.__qualname__.__eq__('groupby.__next__') == True — __next__ on a C extension type is exposed as a wrapper_descriptor; its __qualname__ is 'groupby.__next__'; str.__eq__ returns True; new to extra130"]
    - [groupby_next_qualname_len_16,
       "groupby.__next__.__qualname__.__len__",
       [],
       16,
       "itertools.groupby.__next__.__qualname__.__len__() == 16 — 'groupby.__next__' is 16 characters (7 for 'groupby' + 1 for '.' + 8 for '__next__'); str.__len__() returns 16; new to extra130"]
    - [groupby_new_qualname_eq,
       "groupby.__new__.__qualname__.__eq__",
       ["groupby.__new__"],
       true,
       "itertools.groupby.__new__.__qualname__.__eq__('groupby.__new__') == True — __new__ on a C extension type is a builtin_function_or_method; its __qualname__ is 'groupby.__new__'; str.__eq__ returns True; new to extra130"]
    - [groupby_new_qualname_len_15,
       "groupby.__new__.__qualname__.__len__",
       [],
       15,
       "itertools.groupby.__new__.__qualname__.__len__() == 15 — 'groupby.__new__' is 15 characters (7 for 'groupby' + 1 for '.' + 7 for '__new__'); str.__len__() returns 15; new to extra130"]

# ---------------------------------------------------------------------------
# Table 2: itertools.groupby class identity attributes
#
# Wave 260 theme: itertools.groupby class-level identity.
#
# itertools.groupby.__class__.__name__ == 'type'
# itertools.groupby.__module__ == 'itertools'
# itertools.groupby.__name__ == 'groupby'
# itertools.groupby.__qualname__ == 'groupby'
#
# groupby is a C extension type with standard class identity attributes.
# New to extra130.
# ---------------------------------------------------------------------------

table itertools_extra130.groupby_class_identity:
  description: "itertools.groupby __class__.__name__=='type', __module__=='itertools', __name__=='groupby', __qualname__=='groupby'; C extension class identity; wave 260; new to extra130"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsgroupby130

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_class_name_eq_type,
       "groupby.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.groupby.__class__.__name__.__eq__('type') == True — groupby is a C extension type defined in Modules/itertoolsmodule.c; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra130"]
    - [groupby_module_eq_itertools,
       "groupby.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.groupby.__module__.__eq__('itertools') == True — groupby is defined in Modules/itertoolsmodule.c and its __module__ is set to 'itertools' by the module initializer; str.__eq__('itertools') returns True; new to extra130"]
    - [groupby_name_eq_groupby,
       "groupby.__name__.__eq__",
       ["groupby"],
       true,
       "itertools.groupby.__name__.__eq__('groupby') == True — the __name__ attribute of a C extension type is set from the PyTypeObject tp_name field; for itertools.groupby the name is 'groupby'; str.__eq__('groupby') returns True; new to extra130"]
    - [groupby_qualname_eq_groupby,
       "groupby.__qualname__.__eq__",
       ["groupby"],
       true,
       "itertools.groupby.__qualname__.__eq__('groupby') == True — groupby is defined at the module top level; its __qualname__ equals the simple class name 'groupby'; str.__eq__('groupby') returns True; new to extra130"]
    - [groupby_name_len_7,
       "groupby.__name__.__len__",
       [],
       7,
       "itertools.groupby.__name__.__len__() == 7 — 'groupby' has 7 characters; str.__len__() returns 7; new to extra130"]
    - [groupby_qualname_len_7,
       "groupby.__qualname__.__len__",
       [],
       7,
       "itertools.groupby.__qualname__.__len__() == 7 — 'groupby' has 7 characters; str.__len__() returns 7; new to extra130"]

# ---------------------------------------------------------------------------
# Table 3: itertools.groupby __mro__ and slot descriptor class names
#
# Wave 260 theme: itertools.groupby MRO and slot __class__.__name__.
#
# len(itertools.groupby.__mro__) == 2  ([groupby, object])
# itertools.groupby.__iter__.__class__.__name__ == 'wrapper_descriptor'
# itertools.groupby.__next__.__class__.__name__ == 'wrapper_descriptor'
# itertools.groupby.__new__.__class__.__name__ == 'builtin_function_or_method'
#
# groupby inherits only from object (MRO length 2). The iteration slots
# __iter__ and __next__ are wrapper_descriptors when accessed on the type;
# __new__ is a builtin_function_or_method. New to extra130.
# ---------------------------------------------------------------------------

table itertools_extra130.groupby_mro_slot_classnames:
  description: "itertools.groupby __mro__ len==2; __iter__/__next__ are wrapper_descriptor; __new__ is builtin_function_or_method; wave 260; new to extra130"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsgroupby130

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_mro_len_2,
       "groupby.__mro__.__len__",
       [],
       2,
       "itertools.groupby.__mro__.__len__() == 2 — groupby inherits only from object with no intermediate base classes; the MRO is [groupby, object]; tuple.__len__() returns 2; new to extra130"]
    - [groupby_iter_class_name_eq_wrapper_descriptor,
       "groupby.__iter__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.groupby.__iter__.__class__.__name__.__eq__('wrapper_descriptor') == True — when a C extension type defines the tp_iter slot, accessing __iter__ on the type object yields a wrapper_descriptor; __class__.__name__ is 'wrapper_descriptor'; str.__eq__ returns True; new to extra130"]
    - [groupby_next_class_name_eq_wrapper_descriptor,
       "groupby.__next__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.groupby.__next__.__class__.__name__.__eq__('wrapper_descriptor') == True — when a C extension type defines the tp_iternext slot, accessing __next__ on the type object yields a wrapper_descriptor; __class__.__name__ is 'wrapper_descriptor'; str.__eq__ returns True; new to extra130"]
    - [groupby_new_class_name_eq_builtin_function_or_method,
       "groupby.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.groupby.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — __new__ on a C extension type is exposed as a builtin_function_or_method (PyCFunction); __class__.__name__ is 'builtin_function_or_method'; str.__eq__ returns True; new to extra130"]
    - [groupby_doc_class_name_eq_str,
       "groupby.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.groupby.__doc__.__class__.__name__.__eq__('str') == True — groupby has a C-level docstring exposed via tp_doc; the __doc__ attribute is a plain Python string; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra130"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra130
# ---------------------------------------------------------------------------

invariant itertools_extra130.groupby_iter_qualname:
  description: "itertools.groupby.__iter__.__qualname__ == 'groupby.__iter__' — wrapper_descriptor qualname follows TypeName.slot pattern; wave 260; new to extra130"
  kind: python_call_eq
  function: groupby.__iter__.__qualname__.__eq__
  args: ["groupby.__iter__"]
  expected: true

invariant itertools_extra130.groupby_next_qualname:
  description: "itertools.groupby.__next__.__qualname__ == 'groupby.__next__' — wrapper_descriptor qualname; wave 260; new to extra130"
  kind: python_call_eq
  function: groupby.__next__.__qualname__.__eq__
  args: ["groupby.__next__"]
  expected: true

invariant itertools_extra130.groupby_class_name_type:
  description: "itertools.groupby.__class__.__name__ == 'type' — groupby is a C extension type; wave 260; new to extra130"
  kind: python_call_eq
  function: groupby.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra130.groupby_mro_len:
  description: "len(itertools.groupby.__mro__) == 2 — MRO is [groupby, object]; wave 260; new to extra130"
  kind: python_call_eq
  function: groupby.__mro__.__len__
  args: []
  expected: 2

invariant itertools_extra130.groupby_name_eq_groupby:
  description: "itertools.groupby.__name__ == 'groupby' — C extension type name; wave 260; new to extra130"
  kind: python_call_eq
  function: groupby.__name__.__eq__
  args: ["groupby"]
  expected: true
