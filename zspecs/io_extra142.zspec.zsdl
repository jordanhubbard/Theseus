spec: io_extra142
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bufferedio.c"
  notes:
    - "This spec covers: io.RawIOBase and io.BufferedIOBase abstract base class identity (__name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__(), __class__.__name__) and method descriptor identity (__class__.__name__ and __qualname__) for their C-inherited abstract methods."
    - "io.RawIOBase.__name__ == 'RawIOBase' (length 9) — defined as an ABC in the pure Python io module."
    - "io.RawIOBase.__module__ == 'io' (length 2) — the ABC wrapper lives in the Python io module, unlike the concrete C type _RawIOBase in _io."
    - "io.RawIOBase.__bases__[0].__name__ == '_RawIOBase' (length 10) — the ABC directly wraps the C extension _RawIOBase from _io."
    - "io.RawIOBase.__mro__.__len__() == 5 — MRO is [RawIOBase, _RawIOBase, IOBase, _IOBase, object]."
    - "io.RawIOBase.__class__.__name__ == 'ABCMeta' (length 7) — RawIOBase is an ABC; its metaclass is ABCMeta."
    - "io.BufferedIOBase.__name__ == 'BufferedIOBase' (length 14) — defined as an ABC in the pure Python io module."
    - "io.BufferedIOBase.__module__ == 'io' (length 2)."
    - "io.BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase' (length 15) — wraps the C extension _BufferedIOBase."
    - "io.BufferedIOBase.__mro__.__len__() == 5 — MRO is [BufferedIOBase, _BufferedIOBase, IOBase, _IOBase, object]."
    - "io.BufferedIOBase.__class__.__name__ == 'ABCMeta' (length 7)."
    - "Method descriptors on RawIOBase (read, readall, readinto, write) have qualnames from the underlying C type _RawIOBase, e.g. '_RawIOBase.read'."
    - "Method descriptors on BufferedIOBase (read, read1, readinto, readinto1, write, detach) have qualnames from _BufferedIOBase."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.RawIOBase class identity
# RawIOBase is an ABC in the pure Python io module.
# __name__ == 'RawIOBase' (9), __module__ == 'io' (2),
# __qualname__ == 'RawIOBase' (9).
# __bases__[0].__name__ == '_RawIOBase' (10). MRO length == 5.
# __class__.__name__ == 'ABCMeta' (7; not 'type').
# ---------------------------------------------------------------------------

table io_extra142.RawIOBase_class_identity:
  description: "io.RawIOBase class identity: __name__='RawIOBase' (9), __module__='io' (2), __qualname__='RawIOBase' (9), __bases__[0].__name__='_RawIOBase' (10), __mro__.__len__()==5, __class__.__name__='ABCMeta'"
  kind: python_call_eq
  category: class_identity
  id_prefix: iorib142

  columns: [id, function, args, expected]
  rows:
    - [rib_name_eq,      RawIOBase.__name__.__eq__,                   ["RawIOBase"],   true]
    - [rib_name_len,     RawIOBase.__name__.__len__,                  [],              9]
    - [rib_module_eq,    RawIOBase.__module__.__eq__,                 ["io"],          true]
    - [rib_module_not,   RawIOBase.__module__.__eq__,                 ["_io"],         false]
    - [rib_module_len,   RawIOBase.__module__.__len__,                [],              2]
    - [rib_qualname_eq,  RawIOBase.__qualname__.__eq__,               ["RawIOBase"],   true]
    - [rib_qualname_len, RawIOBase.__qualname__.__len__,              [],              9]
    - [rib_base_eq,      "RawIOBase.__bases__[0].__name__.__eq__",    ["_RawIOBase"],  true]
    - [rib_base_len,     "RawIOBase.__bases__[0].__name__.__len__",   [],              10]
    - [rib_mro_len,      RawIOBase.__mro__.__len__,                   [],              5]
    - [rib_cls_eq,       RawIOBase.__class__.__name__.__eq__,         ["ABCMeta"],     true]
    - [rib_cls_not_type, RawIOBase.__class__.__name__.__eq__,         ["type"],        false]

