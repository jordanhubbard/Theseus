# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra142.RawIOBase.name_is_RawIOBase:
  description: "io.RawIOBase.__name__ == 'RawIOBase' (length 9; the abstract base class for raw I/O, defined in the pure Python io module)"
  category: class_identity
  kind: python_call_eq
  function: RawIOBase.__name__.__eq__
  args: ["RawIOBase"]
  expected: true

invariant io_extra142.RawIOBase.module_is_io:
  description: "io.RawIOBase.__module__ == 'io' (length 2; RawIOBase is the ABC wrapper in io, not the C-level _RawIOBase from _io)"
  category: class_identity
  kind: python_call_eq
  function: RawIOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra142.RawIOBase.metaclass_is_ABCMeta:
  description: "io.RawIOBase.__class__.__name__ == 'ABCMeta' (length 7; RawIOBase is constructed with ABCMeta, distinguishing it from concrete C types whose metaclass is plain 'type')"
  category: class_identity
  kind: python_call_eq
  function: RawIOBase.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant io_extra142.RawIOBase.mro_len_5:
  description: "io.RawIOBase.__mro__.__len__() == 5 (MRO is [RawIOBase, _RawIOBase, IOBase, _IOBase, object]; two ABC layers plus two C layers plus object)"
  category: class_identity
  kind: python_call_eq
  function: RawIOBase.__mro__.__len__
  args: []
  expected: 5

invariant io_extra142.BufferedIOBase.metaclass_is_ABCMeta:
  description: "io.BufferedIOBase.__class__.__name__ == 'ABCMeta' (length 7; BufferedIOBase is an ABC, matching RawIOBase and IOBase pattern)"
  category: class_identity
  kind: python_call_eq
  function: BufferedIOBase.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

