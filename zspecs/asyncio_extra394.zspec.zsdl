spec: asyncio_extra394
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio-sync.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "asyncio.Lock lives in asyncio.locks and derives from _ContextManagerMixin"
    - "asyncio.Event lives in asyncio.locks and derives from _LoopBoundMixin"
    - "asyncio.Semaphore lives in asyncio.locks and derives from _ContextManagerMixin"
    - "asyncio.BoundedSemaphore lives in asyncio.locks and derives from Semaphore"
    - "asyncio.Condition lives in asyncio.locks and derives from _ContextManagerMixin"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra394.class_names:
  description: "Verify __name__ attribute of asyncio synchronization primitive classes"
  kind: python_call_eq
  category: identity
  id_prefix: aio394n

  columns: [id, function, args, expected]
  rows:
    - [aio394n001, asyncio.Lock.__name__.__eq__, ["Lock"], true]
    - [aio394n002, asyncio.Event.__name__.__eq__, ["Event"], true]
    - [aio394n003, asyncio.Semaphore.__name__.__eq__, ["Semaphore"], true]
    - [aio394n004, asyncio.BoundedSemaphore.__name__.__eq__, ["BoundedSemaphore"], true]
    - [aio394n005, asyncio.Condition.__name__.__eq__, ["Condition"], true]

table asyncio_extra394.class_modules:
  description: "Verify __module__ attribute of asyncio synchronization primitive classes"
  kind: python_call_eq
  category: identity
  id_prefix: aio394m

  columns: [id, function, args, expected]
  rows:
    - [aio394m001, asyncio.Lock.__module__.__eq__, ["asyncio.locks"], true]
    - [aio394m002, asyncio.Event.__module__.__eq__, ["asyncio.locks"], true]
    - [aio394m003, asyncio.Semaphore.__module__.__eq__, ["asyncio.locks"], true]
    - [aio394m004, asyncio.BoundedSemaphore.__module__.__eq__, ["asyncio.locks"], true]
    - [aio394m005, asyncio.Condition.__module__.__eq__, ["asyncio.locks"], true]

table asyncio_extra394.class_bases:
  description: "Verify __bases__[0].__name__ (first immediate base class name) of asyncio synchronization primitive classes"
  kind: python_call_eq
  category: identity
  id_prefix: aio394b

  columns: [id, function, args, expected]
  rows:
    - ["aio394b001", "asyncio.Lock.__bases__[0].__name__.__eq__", ["_ContextManagerMixin"], true]
    - ["aio394b002", "asyncio.Event.__bases__[0].__name__.__eq__", ["_LoopBoundMixin"], true]
    - ["aio394b003", "asyncio.Semaphore.__bases__[0].__name__.__eq__", ["_ContextManagerMixin"], true]
    - ["aio394b004", "asyncio.BoundedSemaphore.__bases__[0].__name__.__eq__", ["Semaphore"], true]
    - ["aio394b005", "asyncio.Condition.__bases__[0].__name__.__eq__", ["_ContextManagerMixin"], true]
