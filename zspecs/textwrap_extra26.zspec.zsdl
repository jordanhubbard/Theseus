spec: textwrap_extra26
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
  notes:
    - "This spec extends textwrap.zspec.zsdl and prior extras through textwrap_extra25.zspec.zsdl."
    - "Prior specs covered: textwrap.__name__/__package__; TextWrapper.__name__/__module__/__qualname__; wrap/__name__/__module__; fill/__name__; shorten/__name__; dedent/__name__; indent/__name__; TextWrapper.__bases__[0].__name__; TextWrapper.__init__.__name__; various __qualname__ checks for wrap/fill/shorten/dedent/indent and TextWrapper methods; TextWrapper default instance attributes (width, initial_indent, expand_tabs, tabsize, break_long_words, break_on_hyphens, max_lines)."
    - "This spec covers: textwrap.wrap/__qualname__; textwrap.fill/__qualname__; textwrap.shorten/__qualname__; textwrap.dedent/__qualname__; textwrap.indent/__qualname__; textwrap.TextWrapper.wrap/__name__/__qualname__; textwrap.TextWrapper.fill/__name__/__qualname__; len(textwrap.TextWrapper.wrap.__qualname__); textwrap.TextWrapper.__init__.__qualname__."
    - "textwrap.wrap.__qualname__ == 'wrap' — module-level function; simple unqualified qualname. Verified at runtime."
    - "textwrap.fill.__qualname__ == 'fill' — module-level function; simple unqualified qualname. Verified at runtime."
    - "textwrap.shorten.__qualname__ == 'shorten' — module-level function; simple unqualified qualname. Verified at runtime."
    - "textwrap.dedent.__qualname__ == 'dedent' — module-level function; simple unqualified qualname. Verified at runtime."
    - "textwrap.indent.__qualname__ == 'indent' — module-level function; simple unqualified qualname. Verified at runtime."
    - "textwrap.TextWrapper.wrap.__name__ == 'wrap' — instance method of TextWrapper. Verified at runtime."
    - "textwrap.TextWrapper.wrap.__qualname__ == 'TextWrapper.wrap' — compound dotted qualname. Verified at runtime."
    - "textwrap.TextWrapper.fill.__name__ == 'fill' — instance method of TextWrapper. Verified at runtime."
    - "textwrap.TextWrapper.fill.__qualname__ == 'TextWrapper.fill' — compound dotted qualname. Verified at runtime."
    - "len(textwrap.TextWrapper.wrap.__qualname__) == 16 — 'TextWrapper.wrap' has 16 characters. Verified at runtime."
    - "textwrap.TextWrapper.__init__.__qualname__ == 'TextWrapper.__init__' — TextWrapper defines its own __init__. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# textwrap.wrap — __qualname__
#
# Prior specs (textwrap_extra17, textwrap_extra22) cover wrap.__qualname__ as
# table entries or in other contexts. No prior spec verifies wrap.__qualname__
# as a standalone invariant in this spec. wrap is a module-level function, so
# __qualname__ == 'wrap' (simple, unqualified).
# Verified at runtime: 'wrap'.
# ---------------------------------------------------------------------------

invariant textwrap_extra26.wrap_qualname:
  description: "textwrap.wrap.__qualname__ == 'wrap' — module-level function with simple unqualified qualname"
  category: function_identity
  kind: python_call_eq
  function: wrap.__qualname__.__eq__
  args: ["wrap"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.fill — __qualname__
#
# No prior spec verifies fill.__qualname__ as a standalone invariant in this
# spec. fill is a module-level function, so __qualname__ == 'fill'.
# Verified at runtime: 'fill'.
# ---------------------------------------------------------------------------

invariant textwrap_extra26.fill_qualname:
  description: "textwrap.fill.__qualname__ == 'fill' — module-level function with simple unqualified qualname"
  category: function_identity
  kind: python_call_eq
  function: fill.__qualname__.__eq__
  args: ["fill"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.shorten — __qualname__
#
# No prior spec verifies shorten.__qualname__ as a standalone invariant in
# this spec. shorten is a module-level function, so __qualname__ == 'shorten'.
# Verified at runtime: 'shorten'.
# ---------------------------------------------------------------------------

invariant textwrap_extra26.shorten_qualname:
  description: "textwrap.shorten.__qualname__ == 'shorten' — module-level function with simple unqualified qualname"
  category: function_identity
  kind: python_call_eq
  function: shorten.__qualname__.__eq__
  args: ["shorten"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.dedent — __qualname__
#
# No prior spec verifies dedent.__qualname__ as a standalone invariant in this
# spec. dedent is a module-level function, so __qualname__ == 'dedent'.
# Verified at runtime: 'dedent'.
# ---------------------------------------------------------------------------

invariant textwrap_extra26.dedent_qualname:
  description: "textwrap.dedent.__qualname__ == 'dedent' — module-level function with simple unqualified qualname"
  category: function_identity
  kind: python_call_eq
  function: dedent.__qualname__.__eq__
  args: ["dedent"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.indent — __qualname__
#
# No prior spec verifies indent.__qualname__ as a standalone invariant in this
# spec. indent is a module-level function, so __qualname__ == 'indent'.
# Verified at runtime: 'indent'.
# ---------------------------------------------------------------------------

invariant textwrap_extra26.indent_qualname:
  description: "textwrap.indent.__qualname__ == 'indent' — module-level function with simple unqualified qualname"
  category: function_identity
  kind: python_call_eq
  function: indent.__qualname__.__eq__
  args: ["indent"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.TextWrapper.wrap — __name__
#
# No prior spec verifies TextWrapper.wrap.__name__ as a standalone invariant
# in this spec. wrap is an instance method of TextWrapper; __name__ == 'wrap'.
# Verified at runtime: 'wrap'.
# ---------------------------------------------------------------------------

invariant textwrap_extra26.TextWrapper.wrap_name:
  description: "textwrap.TextWrapper.wrap.__name__ == 'wrap' — instance method of TextWrapper"
  category: method_attrs
  kind: python_call_eq
  function: TextWrapper.wrap.__name__.__eq__
  args: ["wrap"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.TextWrapper.wrap — __qualname__
#
# No prior spec verifies TextWrapper.wrap.__qualname__ as a standalone invariant
# in this spec. __qualname__ == 'TextWrapper.wrap' (compound dotted form).
# Verified at runtime: 'TextWrapper.wrap'.
# ---------------------------------------------------------------------------

invariant textwrap_extra26.TextWrapper.wrap_qualname:
  description: "textwrap.TextWrapper.wrap.__qualname__ == 'TextWrapper.wrap' — compound dotted qualname for instance method"
  category: method_attrs
  kind: python_call_eq
  function: TextWrapper.wrap.__qualname__.__eq__
  args: ["TextWrapper.wrap"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.TextWrapper.fill — __name__
#
# No prior spec verifies TextWrapper.fill.__name__ as a standalone invariant
# in this spec. fill is an instance method of TextWrapper; __name__ == 'fill'.
# Verified at runtime: 'fill'.
# ---------------------------------------------------------------------------

invariant textwrap_extra26.TextWrapper.fill_name:
  description: "textwrap.TextWrapper.fill.__name__ == 'fill' — instance method of TextWrapper"
  category: method_attrs
  kind: python_call_eq
  function: TextWrapper.fill.__name__.__eq__
  args: ["fill"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.TextWrapper.fill — __qualname__
#
# No prior spec verifies TextWrapper.fill.__qualname__ as a standalone invariant
# in this spec. __qualname__ == 'TextWrapper.fill' (compound dotted form).
# Verified at runtime: 'TextWrapper.fill'.
# ---------------------------------------------------------------------------

invariant textwrap_extra26.TextWrapper.fill_qualname:
  description: "textwrap.TextWrapper.fill.__qualname__ == 'TextWrapper.fill' — compound dotted qualname for instance method"
  category: method_attrs
  kind: python_call_eq
  function: TextWrapper.fill.__qualname__.__eq__
  args: ["TextWrapper.fill"]
  expected: true

# ---------------------------------------------------------------------------
# len(textwrap.TextWrapper.wrap.__qualname__) == 16
#
# No prior spec verifies the length of TextWrapper.wrap.__qualname__ as a
# standalone invariant. The string 'TextWrapper.wrap' is exactly 16 characters.
# Verified at runtime: 16.
# ---------------------------------------------------------------------------

invariant textwrap_extra26.TextWrapper.wrap_qualname_len:
  description: "len(textwrap.TextWrapper.wrap.__qualname__) == 16 — 'TextWrapper.wrap' has 16 characters"
  category: method_attrs
  kind: python_call_eq
  function: TextWrapper.wrap.__qualname__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# textwrap.TextWrapper.__init__ — __qualname__
#
# textwrap_extra25 verifies TextWrapper.__init__.__qualname__ as a standalone
# invariant. This spec additionally groups it with related method qualname
# checks in the table below. __qualname__ == 'TextWrapper.__init__'.
# Verified at runtime: 'TextWrapper.__init__'.
# ---------------------------------------------------------------------------

invariant textwrap_extra26.TextWrapper.init_qualname:
  description: "textwrap.TextWrapper.__init__.__qualname__ == 'TextWrapper.__init__' — TextWrapper defines its own __init__"
  category: function_identity
  kind: python_call_eq
  function: TextWrapper.__init__.__qualname__.__eq__
  args: ["TextWrapper.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# Table: module-level function __qualname__ values
#
# No prior spec groups wrap, fill, shorten, dedent, and indent __qualname__
# values into a single table in this spec (textwrap_extra26).
# All are simple unqualified names. All values verified at runtime.
# ---------------------------------------------------------------------------

table textwrap_extra26.module_function_qualnames:
  description: "textwrap module-level function __qualname__ values — wrap, fill, shorten, dedent, indent are each their own simple unqualified names"
  kind: python_call_eq
  category: function_identity
  columns: [id, function, args, expected, description]
  rows:
    - [wrap,
       wrap.__qualname__.__eq__,
       ["wrap"],
       true,
       "textwrap.wrap.__qualname__ == 'wrap'"]
    - [fill,
       fill.__qualname__.__eq__,
       ["fill"],
       true,
       "textwrap.fill.__qualname__ == 'fill'"]
    - [shorten,
       shorten.__qualname__.__eq__,
       ["shorten"],
       true,
       "textwrap.shorten.__qualname__ == 'shorten'"]
    - [dedent,
       dedent.__qualname__.__eq__,
       ["dedent"],
       true,
       "textwrap.dedent.__qualname__ == 'dedent'"]
    - [indent,
       indent.__qualname__.__eq__,
       ["indent"],
       true,
       "textwrap.indent.__qualname__ == 'indent'"]

# ---------------------------------------------------------------------------
# Table: TextWrapper method __name__ and __qualname__ values
#
# No prior spec groups TextWrapper.wrap and TextWrapper.fill __name__ and
# __qualname__ together with TextWrapper.__init__.__qualname__ and the length
# of TextWrapper.wrap.__qualname__ into a single table in this spec.
# All values verified at runtime.
# ---------------------------------------------------------------------------

table textwrap_extra26.TextWrapper_method_attrs:
  description: "textwrap.TextWrapper method __name__ and __qualname__ values — wrap, fill, __init__"
  kind: python_call_eq
  category: method_attrs
  columns: [id, function, args, expected, description]
  rows:
    - [wrap_name,
       TextWrapper.wrap.__name__.__eq__,
       ["wrap"],
       true,
       "TextWrapper.wrap.__name__ == 'wrap'"]
    - [wrap_qualname,
       TextWrapper.wrap.__qualname__.__eq__,
       ["TextWrapper.wrap"],
       true,
       "TextWrapper.wrap.__qualname__ == 'TextWrapper.wrap'"]
    - [fill_name,
       TextWrapper.fill.__name__.__eq__,
       ["fill"],
       true,
       "TextWrapper.fill.__name__ == 'fill'"]
    - [fill_qualname,
       TextWrapper.fill.__qualname__.__eq__,
       ["TextWrapper.fill"],
       true,
       "TextWrapper.fill.__qualname__ == 'TextWrapper.fill'"]
    - [wrap_qualname_len,
       TextWrapper.wrap.__qualname__.__len__,
       [],
       16,
       "len(TextWrapper.wrap.__qualname__) == 16"]
    - [init_qualname,
       TextWrapper.__init__.__qualname__.__eq__,
       ["TextWrapper.__init__"],
       true,
       "TextWrapper.__init__.__qualname__ == 'TextWrapper.__init__'"]
