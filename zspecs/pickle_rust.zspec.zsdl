spec: pickle_rust
version: ">=3.9"
backend: rust_module(pickle_rust)

docs: https://docs.python.org/3/library/pickle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pickle.html — Python pickle documentation"
  not_derived_from:
    - "CPython source: Lib/pickle.py"
  notes:
    - "Clean-room Rust reimplementation of Python pickle.loads, exposed via PyO3."
    - "loads(data) deserializes pickle-format bytes back to a Python object."
    - "All test vectors use pickle protocol 2 bytes, pre-computed and base64-encoded."
    - "pickle.loads(b'\\x80\\x02K*.' ) == 42 — SHORT_BININT for 42."
    - "pickle.loads(b'\\x80\\x02K\\x00.') == 0 — SHORT_BININT for 0."
    - "pickle.loads(b'\\x80\\x02N.' ) == None — NONE opcode."
    - "pickle.loads(b'\\x80\\x02\\x88.') == True — NEWTRUE opcode."
    - "pickle.loads(b'\\x80\\x02\\x89.') == False — NEWFALSE opcode."
    - "All test vectors verified against Python 3.14.3 pickle module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# loads — deserialize protocol-2 pickle bytes
invariant pickle_rust.loads.int_42:
  description: "loads of protocol-2 bytes for 42 == 42"
  category: loads
  kind: python_call_eq
  function: loads
  args: [!b64 gAJLKi4=]
  expected: 42

invariant pickle_rust.loads.int_0:
  description: "loads of protocol-2 bytes for 0 == 0"
  category: loads
  kind: python_call_eq
  function: loads
  args: [!b64 gAJLAC4=]
  expected: 0

invariant pickle_rust.loads.none:
  description: "loads of protocol-2 bytes for None == None"
  category: loads
  kind: python_call_eq
  function: loads
  args: [!b64 gAJOLg==]
  expected: null

invariant pickle_rust.loads.true:
  description: "loads of protocol-2 bytes for True == True"
  category: loads
  kind: python_call_eq
  function: loads
  args: [!b64 gAKILg==]
  expected: true

invariant pickle_rust.loads.false:
  description: "loads of protocol-2 bytes for False == False"
  category: loads
  kind: python_call_eq
  function: loads
  args: [!b64 gAKJLg==]
  expected: false

invariant pickle_rust.loads.hello:
  description: "loads of protocol-2 bytes for 'hello' == 'hello'"
  category: loads
  kind: python_call_eq
  function: loads
  args: [!b64 gAJYBQAAAGhlbGxvcQAu]
  expected: "hello"

invariant pickle_rust.loads.list:
  description: "loads of protocol-2 bytes for [1,2,3] == [1,2,3]"
  category: loads
  kind: python_call_eq
  function: loads
  args: [!b64 gAJdcQAoSwFLAksDZS4=]
  expected: [1, 2, 3]

