spec: as2926
version: ">=3.9"
error_model: python_exceptions
provenance:
  derived_from: [asyncio source, Python docs, https://docs.python.org/3/library/asyncio-sync.html, https://docs.python.org/3/library/asyncio-task.html]
  not_derived_from: [asyncio_extra2911.zspec.zsdl — covers __ilshift__/__irshift__/__ipow__ dict-presence, asyncio_extra2896.zspec.zsdl — covers __itruediv__/__ifloordiv__/__imod__ dict-presence, asyncio_extra2881.zspec.zsdl — covers __iadd__/__isub__/__imul__ dict-presence, asyncio_extra2866.zspec.zsdl — covers __rand__/__ror__/__rxor__ dict-presence, any external dataset]
  notes: [Wave 642 theme — __iand__/__ior__/__ixor__ dict-presence checks for asyncio types. In-place bitwise AND, OR, XOR operators. Task/Future/Queue/Event/Semaphore/BoundedSemaphore/Lock/Condition/Handle/TimerHandle/Timeout/TaskGroup are async coordination primitives not set or bitfield types — none define these dunders. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0 2026-04-13.]
  created_at: "2026-04-13"

table as2926.iand:
