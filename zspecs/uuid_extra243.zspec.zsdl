spec: uuid_extra243
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "Wave 243 theme: uuid module variant constants identity and SafeUUID enum identity."
    - "uuid.RFC_4122 is a plain str constant: 'specified in RFC 4122'. type(uuid.RFC_4122).__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_NCS is a plain str constant: 'reserved for NCS compatibility'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_MICROSOFT is a plain str constant: 'reserved for Microsoft compatibility'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_FUTURE is a plain str constant: 'reserved for future definition'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__name__ == 'SafeUUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__bases__[0].__name__ == 'Enum'. SafeUUID inherits from Enum (not IntEnum). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.safe.value == 0. The 'safe' member has integer value 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.unsafe.value == -1. The 'unsafe' member has integer value -1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.safe.__class__.__name__ == 'SafeUUID'. Enum members are instances of their own enum class. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid variant string constants: RFC_4122, RESERVED_NCS, RESERVED_MICROSOFT,
# RESERVED_FUTURE
#
# Wave 243 theme: uuid variant constant identity.
#
# The four variant constants in the uuid module are plain Python str objects
# (not enum members, not integers). uuid.RFC_4122 == 'specified in RFC 4122';
# uuid.RESERVED_NCS == 'reserved for NCS compatibility';
# uuid.RESERVED_MICROSOFT == 'reserved for Microsoft compatibility';
# uuid.RESERVED_FUTURE == 'reserved for future definition'.
# These are used as the .variant attribute of UUID instances.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra243.variant_constants_identity:
  description: "uuid variant string constants __class__.__name__ identity — RFC_4122, RESERVED_NCS, RESERVED_MICROSOFT, RESERVED_FUTURE are all plain str objects (not enum members or ints); type(uuid.RFC_4122).__name__=='str'; type(uuid.RESERVED_NCS).__name__=='str'; type(uuid.RESERVED_MICROSOFT).__name__=='str'; type(uuid.RESERVED_FUTURE).__name__=='str'; wave 243 theme: uuid variant constant identity; verified with Python 3.14.3"
  kind: python_call_eq
  category: constant_identity
  id_prefix: uuidvarconst243

  columns: [id, function, args, expected, description]
  rows:
    - [rfc4122_class_eq,      RFC_4122.__class__.__name__.__eq__,        ["str"], true, "uuid.RFC_4122.__class__.__name__ == 'str'; plain Python string constant"]
    - [rfc4122_value_eq,      RFC_4122.__eq__,                           ["specified in RFC 4122"], true, "uuid.RFC_4122 == 'specified in RFC 4122'; the RFC 4122 variant string"]
    - [reserved_ncs_class_eq, RESERVED_NCS.__class__.__name__.__eq__,    ["str"], true, "uuid.RESERVED_NCS.__class__.__name__ == 'str'; plain Python string constant"]
    - [reserved_ncs_value_eq, RESERVED_NCS.__eq__,                       ["reserved for NCS compatibility"], true, "uuid.RESERVED_NCS == 'reserved for NCS compatibility'"]
    - [reserved_ms_class_eq,  RESERVED_MICROSOFT.__class__.__name__.__eq__, ["str"], true, "uuid.RESERVED_MICROSOFT.__class__.__name__ == 'str'; plain Python string constant"]
    - [reserved_ms_value_eq,  RESERVED_MICROSOFT.__eq__,                 ["reserved for Microsoft compatibility"], true, "uuid.RESERVED_MICROSOFT == 'reserved for Microsoft compatibility'"]
    - [reserved_fut_class_eq, RESERVED_FUTURE.__class__.__name__.__eq__, ["str"], true, "uuid.RESERVED_FUTURE.__class__.__name__ == 'str'; plain Python string constant"]
    - [reserved_fut_value_eq, RESERVED_FUTURE.__eq__,                    ["reserved for future definition"], true, "uuid.RESERVED_FUTURE == 'reserved for future definition'"]

# ---------------------------------------------------------------------------
# uuid.SafeUUID enum class identity
#
# Wave 243 theme: uuid.SafeUUID enum class and member identity.
#
# uuid.SafeUUID is an Enum (not IntEnum) with two members: safe (value=0) and
# unsafe (value=-1). It tracks whether a UUID was generated safely using
# platform-provided UUID generation APIs. SafeUUID.__bases__[0].__name__ is
# 'Enum' (pure enum, values are not usable as plain ints without .value).
# SafeUUID.safe.__class__.__name__ is 'SafeUUID' — enum members are instances
# of their own class. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra243.SafeUUID_class_identity:
  description: "uuid.SafeUUID enum class identity — SafeUUID.__name__=='SafeUUID'; SafeUUID.__module__=='uuid'; SafeUUID.__bases__[0].__name__=='Enum' (not IntEnum — members are not directly usable as ints without .value); SafeUUID.safe.value==0 (generated via platform UUID APIs); SafeUUID.unsafe.value==-1 (not generated safely); SafeUUID.safe.__class__.__name__=='SafeUUID' (enum members are instances of their own class); wave 243 theme: SafeUUID enum identity; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_identity
  id_prefix: uuidsafeuuid243

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,             SafeUUID.__name__.__eq__,                      ["SafeUUID"], true, "uuid.SafeUUID.__name__ == 'SafeUUID'"]
    - [module_eq,           SafeUUID.__module__.__eq__,                    ["uuid"],     true, "uuid.SafeUUID.__module__ == 'uuid'; defined in Lib/uuid.py"]
    - [base_name_eq,        "SafeUUID.__bases__[0].__name__.__eq__",       ["Enum"],     true, "uuid.SafeUUID.__bases__[0].__name__ == 'Enum'; inherits from Enum (not IntEnum)"]
    - [safe_value_eq,       SafeUUID.safe.value.__eq__,                    [0],          true, "uuid.SafeUUID.safe.value == 0; generated via platform UUID APIs"]
    - [unsafe_value_eq,     SafeUUID.unsafe.value.__eq__,                  [-1],         true, "uuid.SafeUUID.unsafe.value == -1; not generated safely"]
    - [safe_class_name_eq,  SafeUUID.safe.__class__.__name__.__eq__,       ["SafeUUID"], true, "uuid.SafeUUID.safe.__class__.__name__ == 'SafeUUID'; members are instances of their enum class"]

# ---------------------------------------------------------------------------
# Standalone invariants — uuid variant constants and SafeUUID
# ---------------------------------------------------------------------------

invariant uuid_extra243.RFC_4122_is_str:
  description: "uuid.RFC_4122.__class__.__name__.__eq__('str') == True — uuid.RFC_4122 is a plain Python str constant (not an enum member, not an int); its value is 'specified in RFC 4122'; it is returned as the .variant attribute of UUID instances whose variant bits follow RFC 4122; wave 243; verified with Python 3.14.3"
  category: constant_identity
  kind: python_call_eq
  function: RFC_4122.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant uuid_extra243.SafeUUID_base_is_Enum:
  description: "uuid.SafeUUID.__bases__[0].__name__.__eq__('Enum') == True — SafeUUID inherits from Enum (not IntEnum); as a result, SafeUUID members cannot be used directly as integers without accessing .value; SafeUUID.safe.value==0 and SafeUUID.unsafe.value==-1; the enum was added in Python 3.7 to indicate whether UUIDs were generated safely by the OS; wave 243; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "SafeUUID.__bases__[0].__name__.__eq__"
  args: ["Enum"]
  expected: true

invariant uuid_extra243.SafeUUID_safe_value_is_zero:
  description: "uuid.SafeUUID.safe.value.__eq__(0) == True — uuid.SafeUUID.safe has integer value 0, indicating that the UUID was generated using a platform-provided safe UUID generation API (e.g., uuid_generate_time_safe on Linux); contrasts with SafeUUID.unsafe (value=-1); the .is_safe attribute of UUID instances is SafeUUID.safe when generated safely; wave 243; verified with Python 3.14.3"
  category: enum_values
  kind: python_call_eq
  function: SafeUUID.safe.value.__eq__
  args: [0]
  expected: true
