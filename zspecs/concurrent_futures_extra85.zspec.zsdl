#
# BrokenExecutor.__name__ == 'BrokenExecutor'
# BrokenExecutor.__module__ == 'concurrent.futures._base'
# InvalidStateError.__name__ == 'InvalidStateError'
# InvalidStateError.__module__ == 'concurrent.futures._base'
# ---------------------------------------------------------------------------

table concurrent_futures_extra85.BrokenExecutor_InvalidStateError_name_module:
  description: "concurrent.futures BrokenExecutor and InvalidStateError __name__ and __module__ equality checks in cfnamemod85 namespace — wave 248 theme: concurrent.futures exception __name__ and __module__ string equality; BrokenExecutor.__name__=='BrokenExecutor'; BrokenExecutor.__module__=='concurrent.futures._base'; InvalidStateError.__name__=='InvalidStateError'; InvalidStateError.__module__=='concurrent.futures._base'; both are defined in concurrent.futures._base; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfnamemod85a

  columns: [id, function, args, expected, description]
  rows:
    - [broken_name,     BrokenExecutor.__name__.__eq__,     ["BrokenExecutor"],           true, "BrokenExecutor.__name__ == 'BrokenExecutor' — defined in concurrent.futures._base; verified with Python 3.14.3"]
    - [broken_module,   BrokenExecutor.__module__.__eq__,   ["concurrent.futures._base"], true, "BrokenExecutor.__module__ == 'concurrent.futures._base' — defined in concurrent.futures._base; verified with Python 3.14.3"]
    - [invstate_name,   InvalidStateError.__name__.__eq__,  ["InvalidStateError"],        true, "InvalidStateError.__name__ == 'InvalidStateError' — defined in concurrent.futures._base; verified with Python 3.14.3"]
    - [invstate_module, InvalidStateError.__module__.__eq__, ["concurrent.futures._base"], true, "InvalidStateError.__module__ == 'concurrent.futures._base' — defined in concurrent.futures._base; verified with Python 3.14.3"]

