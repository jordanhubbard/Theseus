spec: concurrent_futures_extra85
version: ">=3.9"
backend: python_module(concurrent.futures)
extends: concurrent_futures_extra84

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra84.zspec.zsdl."
    - "This spec covers: wave 248 theme — concurrent.futures exception __name__ and __module__ string equality. NEW in extra85: CancelledError.__name__=='CancelledError'; CancelledError.__module__=='concurrent.futures._base'; TimeoutError.__name__=='TimeoutError' (TimeoutError IS the builtin TimeoutError re-exported); TimeoutError.__module__=='builtins'; BrokenExecutor.__name__=='BrokenExecutor'; BrokenExecutor.__module__=='concurrent.futures._base'; InvalidStateError.__name__=='InvalidStateError'; InvalidStateError.__module__=='concurrent.futures._base'; Future.__name__=='Future'; Future.__module__=='concurrent.futures._base'; ThreadPoolExecutor.__name__=='ThreadPoolExecutor'; ThreadPoolExecutor.__module__=='concurrent.futures.thread'; ProcessPoolExecutor.__name__=='ProcessPoolExecutor'; ProcessPoolExecutor.__module__=='concurrent.futures.process'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.CancelledError.__name__ == 'CancelledError'. Defined in concurrent.futures._base. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.CancelledError.__module__ == 'concurrent.futures._base'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.TimeoutError.__name__ == 'TimeoutError'. TimeoutError is the builtin TimeoutError re-exported. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.TimeoutError.__module__ == 'builtins'. TimeoutError IS the built-in TimeoutError; its module is 'builtins'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.BrokenExecutor.__name__ == 'BrokenExecutor'. Defined in concurrent.futures._base. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.InvalidStateError.__name__ == 'InvalidStateError'. Defined in concurrent.futures._base. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.InvalidStateError.__module__ == 'concurrent.futures._base'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__name__ == 'Future'. Defined in concurrent.futures._base. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__module__ == 'concurrent.futures._base'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor'. Defined in concurrent.futures.thread. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor'. Defined in concurrent.futures.process. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__module__ == 'concurrent.futures.process'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures CancelledError and TimeoutError __name__ and __module__ — extra85
#
# Wave 248 theme: concurrent.futures exception __name__ and __module__ string equality.
#
# CancelledError.__name__ == 'CancelledError'
# CancelledError.__module__ == 'concurrent.futures._base'
# TimeoutError.__name__ == 'TimeoutError'
# TimeoutError.__module__ == 'builtins'
# ---------------------------------------------------------------------------

table concurrent_futures_extra85.CancelledError_TimeoutError_name_module:
  description: "concurrent.futures CancelledError and TimeoutError __name__ and __module__ equality checks in cfnamemod85 namespace — wave 248 theme: concurrent.futures exception __name__ and __module__ string equality; CancelledError.__name__=='CancelledError'; CancelledError.__module__=='concurrent.futures._base' (defined in _base); TimeoutError.__name__=='TimeoutError' (TimeoutError is the builtin TimeoutError re-exported); TimeoutError.__module__=='builtins' (TimeoutError IS the built-in TimeoutError); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfnamemod85

  columns: [id, function, args, expected, description]
  rows:
    - [cancelled_name,    CancelledError.__name__.__eq__,   ["CancelledError"],               true, "CancelledError.__name__ == 'CancelledError' — defined in concurrent.futures._base; verified with Python 3.14.3"]
    - [cancelled_module,  CancelledError.__module__.__eq__, ["concurrent.futures._base"],     true, "CancelledError.__module__ == 'concurrent.futures._base' — defined in concurrent.futures._base; verified with Python 3.14.3"]
    - [timeout_name,      TimeoutError.__name__.__eq__,     ["TimeoutError"],                 true, "TimeoutError.__name__ == 'TimeoutError' — TimeoutError is the builtin TimeoutError re-exported; verified with Python 3.14.3"]
    - [timeout_module,    TimeoutError.__module__.__eq__,   ["builtins"],                     true, "TimeoutError.__module__ == 'builtins' — TimeoutError IS the built-in TimeoutError; module is builtins; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
