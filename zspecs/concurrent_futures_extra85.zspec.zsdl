table concurrent_futures_extra85.Future_Executor_name_module:
  description: "concurrent.futures Future, ThreadPoolExecutor, ProcessPoolExecutor __name__ and __module__ equality checks in cfnamemod85 namespace — wave 248 theme: concurrent.futures exception __name__ and __module__ string equality; Future.__name__=='Future'; Future.__module__=='concurrent.futures._base'; ThreadPoolExecutor.__name__=='ThreadPoolExecutor'; ThreadPoolExecutor.__module__=='concurrent.futures.thread'; ProcessPoolExecutor.__name__=='ProcessPoolExecutor'; ProcessPoolExecutor.__module__=='concurrent.futures.process'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfnamemod85b

  columns: [id, function, args, expected, description]
  rows:
    - [future_name,   Future.__name__.__eq__,               ["Future"],                       true, "Future.__name__ == 'Future' — defined in concurrent.futures._base; verified with Python 3.14.3"]
    - [future_module, Future.__module__.__eq__,              ["concurrent.futures._base"],     true, "Future.__module__ == 'concurrent.futures._base' — defined in concurrent.futures._base; verified with Python 3.14.3"]
    - [tpe_name,      ThreadPoolExecutor.__name__.__eq__,   ["ThreadPoolExecutor"],           true, "ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor' — defined in concurrent.futures.thread; verified with Python 3.14.3"]
    - [tpe_module,    ThreadPoolExecutor.__module__.__eq__, ["concurrent.futures.thread"],    true, "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' — defined in concurrent.futures.thread; verified with Python 3.14.3"]
    - [ppe_name,      ProcessPoolExecutor.__name__.__eq__,  ["ProcessPoolExecutor"],          true, "ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor' — defined in concurrent.futures.process; verified with Python 3.14.3"]
    - [ppe_module,    ProcessPoolExecutor.__module__.__eq__, ["concurrent.futures.process"],  true, "ProcessPoolExecutor.__module__ == 'concurrent.futures.process' — defined in concurrent.futures.process; verified with Python 3.14.3"]

