table concurrent_futures_extra85.cross_checks:
  description: "concurrent.futures exception and class __name__/__module__ cross-checks in cfnamemod85 namespace — wave 248 theme: concurrent.futures exception __name__ and __module__ string equality; CancelledError.__name__=='CancelledError' (cross-check); BrokenExecutor.__module__=='concurrent.futures._base' (cross-check); Future.__name__=='Future' (cross-check); ThreadPoolExecutor.__module__=='concurrent.futures.thread' (cross-check); TimeoutError.__module__=='builtins' (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfnamemod85c

  columns: [id, function, args, expected, description]
  rows:
    - [cancelled_name_cross,  CancelledError.__name__.__eq__,     ["CancelledError"],               true, "CancelledError.__name__ == 'CancelledError' — cross-check; verified with Python 3.14.3"]
    - [broken_module_cross,   BrokenExecutor.__module__.__eq__,   ["concurrent.futures._base"],     true, "BrokenExecutor.__module__ == 'concurrent.futures._base' — cross-check; verified with Python 3.14.3"]
    - [future_name_cross,     Future.__name__.__eq__,             ["Future"],                       true, "Future.__name__ == 'Future' — cross-check; verified with Python 3.14.3"]
    - [tpe_module_cross,      ThreadPoolExecutor.__module__.__eq__, ["concurrent.futures.thread"],  true, "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' — cross-check; verified with Python 3.14.3"]
    - [timeout_module_cross,  TimeoutError.__module__.__eq__,     ["builtins"],                     true, "TimeoutError.__module__ == 'builtins' — cross-check; TimeoutError is the builtin re-exported; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra85
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra85.CancelledError_name:
  description: "concurrent.futures.CancelledError.__name__.__eq__('CancelledError') returns True — CancelledError is defined in concurrent.futures._base with this __name__; NEW in extra85: first standalone __name__ equality invariant for CancelledError in cfnamemod85 namespace; wave 248; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: CancelledError.__name__.__eq__
  args: ["CancelledError"]
  expected: true

invariant concurrent_futures_extra85.CancelledError_module:
  description: "concurrent.futures.CancelledError.__module__.__eq__('concurrent.futures._base') returns True — CancelledError is defined in the _base private submodule of concurrent.futures; NEW in extra85: first standalone __module__ equality invariant for CancelledError in cfnamemod85 namespace; wave 248; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: CancelledError.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra85.TimeoutError_module:
  description: "concurrent.futures.TimeoutError.__module__.__eq__('builtins') returns True — TimeoutError in concurrent.futures IS the built-in TimeoutError re-exported; its __module__ is 'builtins' not 'concurrent.futures._base'; NEW in extra85: first standalone __module__ equality invariant for TimeoutError in cfnamemod85 namespace; wave 248; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: TimeoutError.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant concurrent_futures_extra85.BrokenExecutor_name:
  description: "concurrent.futures.BrokenExecutor.__name__.__eq__('BrokenExecutor') returns True — BrokenExecutor is the base class for executor-related exceptions; defined in concurrent.futures._base; NEW in extra85: first standalone __name__ equality invariant for BrokenExecutor in cfnamemod85 namespace; wave 248; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: BrokenExecutor.__name__.__eq__
  args: ["BrokenExecutor"]
  expected: true

invariant concurrent_futures_extra85.ProcessPoolExecutor_module:
  description: "concurrent.futures.ProcessPoolExecutor.__module__.__eq__('concurrent.futures.process') returns True — ProcessPoolExecutor is defined in the concurrent.futures.process submodule; NEW in extra85: first standalone __module__ equality invariant for ProcessPoolExecutor in cfnamemod85 namespace; wave 248; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ProcessPoolExecutor.__module__.__eq__
  args: ["concurrent.futures.process"]
  expected: true
