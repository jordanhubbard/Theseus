spec: ast_extra4
version: ">=3.9"
backend: python_module(ast)

docs: https://docs.python.org/3/library/ast.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/ast.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ast.py"
    - "CPython source: Python/Python-ast.c"
    - "ast.zspec.zsdl — covers literal_eval primitives/containers/tuple-access, error cases, literal_eval.__name__, and node classnames"
    - "ast_extra.zspec.zsdl — covers parse.__name__, parse.__module__, dump.__name__, get_docstring.__name__, fix_missing_locations.__name__, NodeVisitor.__name__, NodeTransformer.__name__, NodeTransformer.__bases__[0].__name__, AST.__name__, literal_eval('42'), literal_eval('\"hello\"'), literal_eval('[1,2,3]')"
    - "ast_extra2.zspec.zsdl — covers literal_eval for int/str/list/dict/bool/None, get_docstring.__name__, NodeVisitor.__name__, NodeTransformer.__name__, fix_missing_locations.__name__"
    - "ast_extra3.zspec.zsdl — covers __module__ for parse/dump/literal_eval/get_docstring/fix_missing_locations/walk/NodeVisitor/NodeTransformer/Module/FunctionDef/Constant/Name/AST/Expr/ClassDef, NodeVisitor.__bases__[0].__name__=='object', NodeTransformer.__bases__[0].__name__, walk.__name__"
  notes:
    - "This spec covers __qualname__ attributes for ast classes and functions — not covered in prior ast specs."
    - "ast.NodeVisitor.__qualname__ == 'NodeVisitor' — qualname equals name for top-level classes."
    - "ast.NodeTransformer.__qualname__ == 'NodeTransformer' — top-level class qualname."
    - "ast.literal_eval.__qualname__ == 'literal_eval' — top-level function qualname."
    - "ast.get_docstring.__qualname__ == 'get_docstring' — top-level function qualname."
    - "ast.dump.__qualname__ == 'dump' — top-level function qualname."
    - "ast.walk.__qualname__ == 'walk' — top-level function qualname."
    - "ast.fix_missing_locations.__qualname__ == 'fix_missing_locations' — top-level function qualname."
    - "ast.AST.__qualname__ == 'AST' — root node base class qualname."
    - "ast.Module.__qualname__ == 'Module' — Module node class qualname."
    - "ast.Constant.__qualname__ == 'Constant' — Constant node class qualname."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for top-level ast functions
# (not covered in ast.zspec.zsdl, ast_extra, ast_extra2, or ast_extra3)
# ---------------------------------------------------------------------------

table ast_extra4.function_qualnames:
  kind: python_call_eq
  category: qualname_attrs
  id_prefix: fqname

  columns: [id, function, args, expected]
  rows:
    - [literal_eval,          literal_eval.__qualname__.__eq__,          ["literal_eval"],          true]
    - [get_docstring,         get_docstring.__qualname__.__eq__,         ["get_docstring"],         true]
    - [dump,                  dump.__qualname__.__eq__,                  ["dump"],                  true]
    - [walk,                  walk.__qualname__.__eq__,                  ["walk"],                  true]
    - [fix_missing_locations, fix_missing_locations.__qualname__.__eq__, ["fix_missing_locations"], true]

# ---------------------------------------------------------------------------
# __qualname__ checks for ast visitor/transformer and base classes
# ---------------------------------------------------------------------------

table ast_extra4.class_qualnames:
  kind: python_call_eq
  category: qualname_attrs
  id_prefix: cqname

  columns: [id, function, args, expected]
  rows:
    - [NodeVisitor,    NodeVisitor.__qualname__.__eq__,    ["NodeVisitor"],    true]
    - [NodeTransformer, NodeTransformer.__qualname__.__eq__, ["NodeTransformer"], true]
    - [AST,            AST.__qualname__.__eq__,            ["AST"],            true]
    - [Module,         Module.__qualname__.__eq__,         ["Module"],         true]
    - [Constant,       Constant.__qualname__.__eq__,       ["Constant"],       true]

# ---------------------------------------------------------------------------
# literal_eval — result class name checks (not covered in prior specs)
# These verify what Python type is returned, distinct from the value checks
# already in ast_extra.zspec.zsdl and ast_extra2.zspec.zsdl.
# ---------------------------------------------------------------------------

invariant ast_extra4.literal_eval.int_class:
  description: "ast.literal_eval('42').__class__.__name__ == 'int'"
  category: literal_eval_types
  kind: python_call_eq
  function: literal_eval
  args: ["42"]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["int"]
  expected: true

invariant ast_extra4.literal_eval.str_class:
  description: "ast.literal_eval('\"hello\"').__class__.__name__ == 'str'"
  category: literal_eval_types
  kind: python_call_eq
  function: literal_eval
  args: ["\"hello\""]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["str"]
  expected: true

invariant ast_extra4.literal_eval.list_class:
  description: "ast.literal_eval('[1, 2, 3]').__class__.__name__ == 'list'"
  category: literal_eval_types
  kind: python_call_eq
  function: literal_eval
  args: ["[1, 2, 3]"]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["list"]
  expected: true

invariant ast_extra4.literal_eval.bool_class:
  description: "ast.literal_eval('True').__class__.__name__ == 'bool'"
  category: literal_eval_types
  kind: python_call_eq
  function: literal_eval
  args: ["True"]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["bool"]
  expected: true

# ---------------------------------------------------------------------------
# parse.__qualname__ — not covered in prior specs
# ---------------------------------------------------------------------------

invariant ast_extra4.parse.qualname:
  description: "ast.parse.__qualname__ == 'parse'"
  category: qualname_attrs
  kind: python_call_eq
  function: parse.__qualname__.__eq__
  args: ["parse"]
  expected: true
