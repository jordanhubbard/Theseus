spec: socket_extra25
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra8.zspec.zsdl — covers __qualname__.__eq__ for socket class, error/timeout/gaierror/herror exceptions as exception class table."
    - "socket_extra20.zspec.zsdl — covers __qualname__.__len__() for socket.socket class and module-level functions."
    - "socket_extra22.zspec.zsdl — covers __qualname__.__eq__ for socket.socket instance methods connect/bind/listen/accept/close/recv/send."
    - "socket_extra23.zspec.zsdl — covers __qualname__.__eq__ and __len__() for setsockopt/getsockopt/getsockname/getpeername/setblocking/settimeout/gettimeout/fileno."
    - "socket_extra24.zspec.zsdl — covers socket.socket class __qualname__/__module__, __bases__[0].__name__, AddressFamily/SocketKind enum class qualnames/modules, AF_INET/SOCK_STREAM __class__.__qualname__, socket.error/__timeout__ __qualname__."
  notes:
    - "This spec extends the socket chain through socket_extra24; it does NOT duplicate invariants in any prior spec."
    - "Focus: (1) socket.error.__module__ == 'builtins' — socket.error is an alias for OSError which lives in builtins; (2) socket.timeout.__module__ == 'builtins' — same reason, alias for TimeoutError; (3) socket.gaierror.__module__ == 'socket' and socket.herror.__module__ == 'socket' — these are native socket exceptions; (4) socket.getfqdn.__qualname__ and __module__ — getfqdn is a pure-Python function in the socket module; (5) socket.gethostname.__qualname__ and __module__ — gethostname is a C-extension function from _socket; (6) socket.getaddrinfo.__qualname__ and __module__ — getaddrinfo is a C-extension; (7) socket.create_connection.__qualname__ and __module__ — pure-Python wrapper in socket."
    - "socket.error.__module__ == 'builtins' — socket.error is OSError, defined in builtins (len 8). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.timeout.__module__ == 'builtins' — socket.timeout is TimeoutError, defined in builtins (len 8). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.gaierror.__module__ == 'socket' — gaierror is a native socket exception (len 6). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.herror.__module__ == 'socket' — herror is a native socket exception (len 6). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__qualname__ == 'getfqdn' — len 7. Pure-Python function. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__module__ == 'socket' — len 6. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.gethostname.__qualname__ == 'gethostname' — len 11. C-extension function. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.gethostname.__module__ == '_socket' — len 7. gethostname is implemented in the _socket C extension. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__qualname__ == 'getaddrinfo' — len 11. C-extension function. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__module__ == 'socket' — len 6. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.create_connection.__qualname__ == 'create_connection' — len 17. Pure-Python wrapper. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.create_connection.__module__ == 'socket' — len 6. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.error and socket.timeout __module__ checks
#
# socket.error is an alias for OSError and socket.timeout is an alias for
# TimeoutError. Both are defined in the 'builtins' module (len 8).
# socket_extra24 covers their __qualname__; no prior spec checks __module__.
# ---------------------------------------------------------------------------

invariant socket_extra25.error.module_eq:
  description: "socket.error.__module__ == 'builtins' — socket.error is an alias for OSError which is defined in builtins"
  category: class_module
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant socket_extra25.error.module_len:
  description: "len(socket.error.__module__) == 8 — len('builtins') == 8"
  category: class_module
  kind: python_call_eq
  function: error.__module__.__len__
  args: []
  expected: 8

invariant socket_extra25.timeout.module_eq:
  description: "socket.timeout.__module__ == 'builtins' — socket.timeout is an alias for TimeoutError which is defined in builtins"
  category: class_module
  kind: python_call_eq
  function: timeout.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# socket.gaierror and socket.herror __module__ checks
#
# gaierror and herror are native socket exceptions defined in the socket module
# itself (not aliases for builtins). __module__ == 'socket' (len 6) for both.
# No prior spec checks __module__ for these exceptions.
# ---------------------------------------------------------------------------

table socket_extra25.native_exception_modules:
  description: "__module__.__eq__ for socket.gaierror and socket.herror — native socket exceptions defined in the socket module"
  kind: python_call_eq
  category: class_module
  id_prefix: nem25

  columns: [id, function, args, expected]
  rows:
    - [gaierror, gaierror.__module__.__eq__, ["socket"], true]
    - [herror,   herror.__module__.__eq__,   ["socket"], true]

table socket_extra25.native_exception_module_lengths:
  description: "len(__module__) for socket.gaierror and socket.herror — both 'socket' (len 6)"
  kind: python_call_eq
  category: class_module
  id_prefix: nemlen25

  columns: [id, function, args, expected]
  rows:
    - [gaierror, gaierror.__module__.__len__, [], 6]
    - [herror,   herror.__module__.__len__,   [], 6]

# ---------------------------------------------------------------------------
# socket.getfqdn __qualname__ and __module__
#
# getfqdn is a pure-Python helper function defined directly in Lib/socket.py.
# __qualname__ == 'getfqdn' (len 7); __module__ == 'socket' (len 6).
# No prior spec checks these attributes for getfqdn.
# ---------------------------------------------------------------------------

invariant socket_extra25.getfqdn.qualname_eq:
  description: "socket.getfqdn.__qualname__ == 'getfqdn' — pure-Python function defined in Lib/socket.py"
  category: function_qualnames
  kind: python_call_eq
  function: getfqdn.__qualname__.__eq__
  args: ["getfqdn"]
  expected: true

invariant socket_extra25.getfqdn.qualname_len:
  description: "len(socket.getfqdn.__qualname__) == 7 — len('getfqdn') == 7"
  category: function_qualnames
  kind: python_call_eq
  function: getfqdn.__qualname__.__len__
  args: []
  expected: 7

invariant socket_extra25.getfqdn.module_eq:
  description: "socket.getfqdn.__module__ == 'socket' — getfqdn is defined in the socket module"
  category: function_module
  kind: python_call_eq
  function: getfqdn.__module__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.gethostname __qualname__ and __module__
#
# gethostname is a C-extension function from the _socket module, re-exported
# by socket. __qualname__ == 'gethostname' (len 11); __module__ == '_socket'
# (len 7, note leading underscore). No prior spec checks these attributes.
# ---------------------------------------------------------------------------

invariant socket_extra25.gethostname.qualname_eq:
  description: "socket.gethostname.__qualname__ == 'gethostname' — C-extension function from _socket"
  category: function_qualnames
  kind: python_call_eq
  function: gethostname.__qualname__.__eq__
  args: ["gethostname"]
  expected: true

invariant socket_extra25.gethostname.qualname_len:
  description: "len(socket.gethostname.__qualname__) == 11 — len('gethostname') == 11"
  category: function_qualnames
  kind: python_call_eq
  function: gethostname.__qualname__.__len__
  args: []
  expected: 11

invariant socket_extra25.gethostname.module_eq:
  description: "socket.gethostname.__module__ == '_socket' — gethostname is implemented in the _socket C extension"
  category: function_module
  kind: python_call_eq
  function: gethostname.__module__.__eq__
  args: ["_socket"]
  expected: true

invariant socket_extra25.gethostname.module_len:
  description: "len(socket.gethostname.__module__) == 7 — len('_socket') == 7 (note leading underscore)"
  category: function_module
  kind: python_call_eq
  function: gethostname.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# socket.getaddrinfo __qualname__ and __module__
#
# getaddrinfo is a C-extension function. __qualname__ == 'getaddrinfo' (len 11);
# __module__ == 'socket' (len 6). No prior spec checks these attributes.
# ---------------------------------------------------------------------------

invariant socket_extra25.getaddrinfo.qualname_eq:
  description: "socket.getaddrinfo.__qualname__ == 'getaddrinfo' — C-extension function exposed via the socket module"
  category: function_qualnames
  kind: python_call_eq
  function: getaddrinfo.__qualname__.__eq__
  args: ["getaddrinfo"]
  expected: true

invariant socket_extra25.getaddrinfo.qualname_len:
  description: "len(socket.getaddrinfo.__qualname__) == 11 — len('getaddrinfo') == 11"
  category: function_qualnames
  kind: python_call_eq
  function: getaddrinfo.__qualname__.__len__
  args: []
  expected: 11

invariant socket_extra25.getaddrinfo.module_eq:
  description: "socket.getaddrinfo.__module__ == 'socket' — getaddrinfo reports module as 'socket'"
  category: function_module
  kind: python_call_eq
  function: getaddrinfo.__module__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.create_connection __qualname__ and __module__
#
# create_connection is a pure-Python convenience function in Lib/socket.py.
# __qualname__ == 'create_connection' (len 17); __module__ == 'socket' (len 6).
# No prior spec checks these attributes.
# ---------------------------------------------------------------------------

invariant socket_extra25.create_connection.qualname_eq:
  description: "socket.create_connection.__qualname__ == 'create_connection' — pure-Python convenience wrapper in Lib/socket.py"
  category: function_qualnames
  kind: python_call_eq
  function: create_connection.__qualname__.__eq__
  args: ["create_connection"]
  expected: true

invariant socket_extra25.create_connection.qualname_len:
  description: "len(socket.create_connection.__qualname__) == 17 — len('create_connection') == 17"
  category: function_qualnames
  kind: python_call_eq
  function: create_connection.__qualname__.__len__
  args: []
  expected: 17

invariant socket_extra25.create_connection.module_eq:
  description: "socket.create_connection.__module__ == 'socket' — create_connection is defined in the socket module"
  category: function_module
  kind: python_call_eq
  function: create_connection.__module__.__eq__
  args: ["socket"]
  expected: true
