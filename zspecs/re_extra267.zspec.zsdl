spec: re_extra267
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "re.match(r'(?P<word>\\w+)', 'hello world').group('word') == 'hello' — named group extraction."
    - "re.match(r'(?P<word>\\w+)', 'hello world').group(0) == 'hello' — group(0) is the whole match."
    - "re.match(r'(?P<year>\\d{4})-(?P<month>\\d{2})', '2024-03').group('year') == '2024'."
    - "re.match(r'(?P<year>\\d{4})-(?P<month>\\d{2})', '2024-03').group('month') == '03'."
    - "re.match(r'\\d+', '123abc') returns a Match object — match() allows partial match from start."
    - "re.fullmatch(r'\\d+', '123abc') returns None — fullmatch() requires entire string to match."
    - "re.fullmatch(r'\\d+', '123') returns a Match object — entire string of digits matches \\d+."
    - "re.fullmatch(r'\\d+', '123').group(0) == '123' — the full matched string."
    - "Match.__class__.__name__ == 'Match' — the match object type name."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Named group extraction — single named group
# ---------------------------------------------------------------------------

invariant re_extra267.match.named_group_word:
  description: "re.match(r'(?P<word>\\w+)', 'hello world').group('word') == 'hello'"
  category: named_groups
  kind: python_call_eq
  function: match
  args: ["(?P<word>\\w+)", "hello world"]
  method: group
  method_args: ["word"]
  expected: "hello"

invariant re_extra267.match.group0_whole_match:
  description: "re.match(r'(?P<word>\\w+)', 'hello world').group(0) == 'hello' — group(0) is the whole match"
  category: named_groups
  kind: python_call_eq
  function: match
  args: ["(?P<word>\\w+)", "hello world"]
  method: group
  method_args: [0]
  expected: "hello"

invariant re_extra267.match.named_group_class:
  description: "re.match(r'(?P<word>\\w+)', 'hello world').__class__.__name__ == 'Match'"
  category: named_groups
  kind: python_call_eq
  function: match
  args: ["(?P<word>\\w+)", "hello world"]
  method: __class__.__name__.__eq__
  method_args: ["Match"]
  expected: true

# ---------------------------------------------------------------------------
# Named groups — two named groups in one pattern
# ---------------------------------------------------------------------------

invariant re_extra267.match.named_group_year:
  description: "re.match(r'(?P<year>\\d{4})-(?P<month>\\d{2})', '2024-03').group('year') == '2024'"
  category: named_groups
  kind: python_call_eq
  function: match
  args: ["(?P<year>\\d{4})-(?P<month>\\d{2})", "2024-03"]
  method: group
  method_args: ["year"]
  expected: "2024"

invariant re_extra267.match.named_group_month:
  description: "re.match(r'(?P<year>\\d{4})-(?P<month>\\d{2})', '2024-03').group('month') == '03'"
  category: named_groups
  kind: python_call_eq
  function: match
  args: ["(?P<year>\\d{4})-(?P<month>\\d{2})", "2024-03"]
  method: group
  method_args: ["month"]
  expected: "03"

# ---------------------------------------------------------------------------
# re.match vs re.fullmatch — partial vs full string matching
# ---------------------------------------------------------------------------

invariant re_extra267.match.partial_returns_match:
  description: "re.match(r'\\d+', '123abc').__class__.__name__ == 'Match' — match() allows partial match from start"
  category: fullmatch
  kind: python_call_eq
  function: match
  args: ["\\d+", "123abc"]
  method: __class__.__name__.__eq__
  method_args: ["Match"]
  expected: true

invariant re_extra267.fullmatch.partial_returns_none:
  description: "re.fullmatch(r'\\d+', '123abc').__class__.__name__ == 'NoneType' — fullmatch() requires whole string to match"
  category: fullmatch
  kind: python_call_eq
  function: fullmatch
  args: ["\\d+", "123abc"]
  method: __class__.__name__.__eq__
  method_args: ["NoneType"]
  expected: true

invariant re_extra267.fullmatch.full_match_returns_match:
  description: "re.fullmatch(r'\\d+', '123').__class__.__name__ == 'Match' — fullmatch() succeeds when entire string matches"
  category: fullmatch
  kind: python_call_eq
  function: fullmatch
  args: ["\\d+", "123"]
  method: __class__.__name__.__eq__
  method_args: ["Match"]
  expected: true

invariant re_extra267.fullmatch.full_match_group0:
  description: "re.fullmatch(r'\\d+', '123').group(0) == '123' — the fully-matched string"
  category: fullmatch
  kind: python_call_eq
  function: fullmatch
  args: ["\\d+", "123"]
  method: group
  method_args: [0]
  expected: "123"

invariant re_extra267.match.partial_group0:
  description: "re.match(r'\\d+', '123abc').group(0) == '123' — match() captures digits at the start"
  category: fullmatch
  kind: python_call_eq
  function: match
  args: ["\\d+", "123abc"]
  method: group
  method_args: [0]
  expected: "123"

# ---------------------------------------------------------------------------
# Table: named group extraction from two-group pattern (tabular form)
# ---------------------------------------------------------------------------

table re_extra267.two_group_extraction:
  description: "Named group extraction from r'(?P<year>\\d{4})-(?P<month>\\d{2})' matched against '2024-03'"
  kind: python_call_eq
  category: named_groups
  id_prefix: twogrp

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [year,  match, ["(?P<year>\\d{4})-(?P<month>\\d{2})", "2024-03"], group, ["year"],  "2024"]
    - [month, match, ["(?P<year>\\d{4})-(?P<month>\\d{2})", "2024-03"], group, ["month"], "03"]
    - [full,  match, ["(?P<year>\\d{4})-(?P<month>\\d{2})", "2024-03"], group, [0],       "2024-03"]
