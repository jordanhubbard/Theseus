spec: re_extra62
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra61.zspec.zsdl — covers re.__loader__.__class__.__name__.__eq__('SourceFileLoader'); re.__spec__.__class__.__name__.__eq__('ModuleSpec'); re.__file__.__class__.__name__.__eq__('str'); re.__cached__.__class__.__name__.__eq__('str')."
    - "re_extra60.zspec.zsdl — covers re.__all__.__contains__ membership; re.__package__.__eq__('re'); re Pattern/error __doc__.__class__.__name__.__len__()==3."
    - "re_extra59.zspec.zsdl — covers re.__all__.__class__.__name__.__eq__('list') and __all__.__len__()==31; Pattern/Match/error/RegexFlag __eq__/__repr__/__hash__ class name chains."
    - "re_extra40.zspec.zsdl — covers re.__name__.__len__()==2; re.__package__.__len__()==2; re.__file__.__class__.__name__.__len__()==3."
  notes:
    - "This spec extends re_extra61.zspec.zsdl."
    - "Wave 226 theme: __spec__.origin values + __spec__.submodule_search_locations + __loader__.__name__ length checks."
    - "IMPORTANT: re in Python 3.11+ is a package (Lib/re/__init__.py). Its loader is a SourceFileLoader instance. SourceFileLoader instances do NOT have a __name__ attribute (AttributeError). The wave 226 theme of '__loader__.__name__ length checks' is interpreted for re as __loader__.__class__.__name__ (i.e. 'SourceFileLoader', 16 chars), which is the standard chain for SourceFileLoader-loaded modules. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.__loader__.__class__.__name__.__eq__('SourceFileLoader') and __len__()==16 — re is a pure Python package loaded by SourceFileLoader. The loader is an instance of SourceFileLoader. __loader__.__class__.__name__ is 'SourceFileLoader' (16 characters). re_extra61 covers the equality anchor in reloader61 namespace; this wave 226 spec adds the __len__()==16 length anchor in respec62 namespace. Novel length anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.__spec__.origin.__class__.__name__.__eq__('str') — re.__spec__.origin is the filesystem path to re/__init__.py (a str). Its __class__.__name__ is 'str'. No prior re spec checks __spec__.origin.__class__.__name__. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.__spec__.submodule_search_locations — re IS a package (Lib/re/__init__.py in Python 3.11+), so submodule_search_locations is NOT None. It is a list containing the re directory path. Its __class__.__name__ is 'list'. This contrasts with io and decimal where submodule_search_locations is None. No prior re spec checks submodule_search_locations. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.__spec__.has_location — True for SourceFileLoader modules. re is loaded from a filesystem path, so has_location is True. No prior re spec checks __spec__.has_location. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.__loader__.__class__.__name__ equality and length
#
# re is a pure Python package (Lib/re/__init__.py) loaded by SourceFileLoader.
# SourceFileLoader instances have no __name__ attribute. The class name of the
# loader is accessed via __loader__.__class__.__name__ == 'SourceFileLoader'.
#
#   re.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True
#   re.__loader__.__class__.__name__.__len__()                  == 16
#
# re_extra61 covers the equality anchor in reloader61 namespace.
# This wave 226 spec adds the __len__()==16 anchor in respec62 namespace.
# Novel length anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra62.loader_class_name:
  description: "re.__loader__.__class__.__name__ eq and len — re is a pure Python package (Lib/re/__init__.py) loaded by SourceFileLoader; SourceFileLoader instances have no __name__ attr so the wave 226 length check uses __loader__.__class__.__name__.__len__()==16 ('SourceFileLoader' is 16 chars); re_extra61 covers the equality in reloader61 namespace; this adds the len==16 anchor in respec62 namespace; novel length anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: respec62ldr

  columns: [id, function, args, expected]
  rows:
    - [loader_class_name_eq_SourceFileLoader, __loader__.__class__.__name__.__eq__,  ["SourceFileLoader"], true]
    - [loader_class_name_len_16,              __loader__.__class__.__name__.__len__, [],                  16  ]

# ---------------------------------------------------------------------------
# re.__spec__.origin.__class__.__name__.__eq__('str')
#
# re.__spec__.origin is the filesystem path to re/__init__.py.
# As a filesystem path string, its __class__.__name__ is 'str'.
#
#   re.__spec__.origin.__class__.__name__.__eq__('str') == True
#
# No prior re spec checks __spec__.origin.__class__.__name__. Novel.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra62.spec_origin_class_name:
  description: "re.__spec__.origin.__class__.__name__.__eq__('str') — re.__spec__.origin is the filesystem path to re/__init__.py; it is a str; __class__.__name__=='str'; contrasts with io.__spec__.origin which is 'frozen' (str with value 'frozen'); no prior re spec checks __spec__.origin.__class__.__name__; novel anchor in respec62 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: respec62origcls

  columns: [id, function, args, expected]
  rows:
    - [spec_origin_class_name_str, __spec__.origin.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# re.__spec__.submodule_search_locations — NOT None (re is a package)
#
# re IS a package (Lib/re/__init__.py in Python 3.11+). Therefore its
# __spec__.submodule_search_locations is a list (not None). The list contains
# the re directory path. Its __class__.__name__ is 'list'.
#
#   re.__spec__.submodule_search_locations.__class__.__name__.__eq__('list') == True
#
# This contrasts with io and decimal where submodule_search_locations is None.
# No prior re spec checks submodule_search_locations. Novel.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra62.spec_submodule_search_locations:
  description: "re.__spec__.submodule_search_locations — re IS a package (Lib/re/__init__.py in Python 3.11+) so submodule_search_locations is NOT None; it is a list containing the re directory; __class__.__name__=='list'; contrasts with io and decimal where it is None; no prior re spec checks submodule_search_locations; novel anchor in respec62 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: respec62ssl

  columns: [id, function, args, expected]
  rows:
    - [ssl_class_name_list, __spec__.submodule_search_locations.__class__.__name__.__eq__, ["list"], true]

# ---------------------------------------------------------------------------
# re.__spec__.has_location — True for SourceFileLoader modules
#
# re is loaded from a filesystem path by SourceFileLoader. Therefore
# has_location is True.
#
#   re.__spec__.has_location.__eq__(True) == True
#
# This contrasts with io where has_location is False (loaded by FrozenImporter).
# No prior re spec checks __spec__.has_location. Novel anchor.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra62.spec_has_location:
  description: "re.__spec__.has_location is True — re is loaded by SourceFileLoader from a filesystem path; has_location==True for file-backed modules; contrasts with io (FrozenImporter, has_location==False); no prior re spec checks __spec__.has_location; novel anchor in respec62 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: respec62hasloc

  columns: [id, function, args, expected]
  rows:
    - [has_location_true, __spec__.has_location.__eq__, [true], true]

invariant re_extra62.loader_class_name_eq_SourceFileLoader:
  description: "re.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — re is a pure Python package loaded by SourceFileLoader; re-anchored in respec62 namespace for cross-wave 226 traceability; re_extra61 covers this in reloader61 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant re_extra62.loader_class_name_len_16:
  description: "re.__loader__.__class__.__name__.__len__() == 16 — 'SourceFileLoader' has 16 characters; novel length anchor in respec62 namespace; re_extra61 does not cover this length; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__len__
  args: []
  expected: 16

invariant re_extra62.spec_origin_class_name_str:
  description: "re.__spec__.origin.__class__.__name__.__eq__('str') == True — re.__spec__.origin is the filesystem path to re/__init__.py; it is a str; no prior re spec checks __spec__.origin.__class__.__name__; novel anchor in respec62 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __spec__.origin.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant re_extra62.spec_ssl_list_class_name:
  description: "re.__spec__.submodule_search_locations.__class__.__name__.__eq__('list') == True — re is a package (Python 3.11+) so submodule_search_locations is a list (not None); __class__.__name__=='list'; contrasts with io and decimal where it is None; no prior re spec checks submodule_search_locations; novel anchor in respec62 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __spec__.submodule_search_locations.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant re_extra62.spec_has_location_true:
  description: "re.__spec__.has_location.__eq__(True) == True — re is loaded by SourceFileLoader from a filesystem path; has_location is True; contrasts with io (FrozenImporter, has_location==False); no prior re spec checks __spec__.has_location; novel anchor in respec62 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [true]
  expected: true
