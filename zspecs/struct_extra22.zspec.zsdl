spec: struct_extra22
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra4.zspec.zsdl — covers __qualname__ equality for pack/unpack/pack_into/unpack_from/calcsize/iter_unpack; Struct.__qualname__=='Struct'; error.__qualname__=='error'."
    - "struct_extra19.zspec.zsdl — covers Struct.__qualname__.__len__()==6; error.__qualname__.__len__()==5; module __name__/__package__ class checks."
    - "struct_extra20.zspec.zsdl — covers __qualname__.__len__() for module-level functions; __qualname__.__class__.__name__ for pack/unpack."
    - "struct_extra21.zspec.zsdl — covers Struct.__init__/__repr__ __qualname__; Struct method __qualname__.__len__()."
  notes:
    - "This spec extends struct_extra21.zspec.zsdl."
    - "Focus: __module__ for struct.Struct, struct.pack, struct.unpack, struct.calcsize (all '_struct'); struct.error.__module__ ('struct'); __bases__[0].__name__ for Struct and error; __module__.__class__.__name__ checks."
    - "struct.Struct.__module__ == '_struct' — Struct is implemented in the C extension _struct. No prior spec covers Struct.__module__."
    - "struct.pack.__module__ == '_struct' — pack is a C builtin function in _struct. struct_extra4 covers __qualname__ but not __module__."
    - "struct.unpack.__module__ == '_struct' — unpack is a C builtin in _struct. struct_extra4 covers __qualname__ but not __module__."
    - "struct.calcsize.__module__ == '_struct' — calcsize is a C builtin in _struct. No prior spec covers calcsize.__module__."
    - "struct.error.__module__ == 'struct' — error is defined in the Python struct wrapper, not the C extension. Verified."
    - "struct.Struct.__bases__[0].__name__ == 'object' — Struct inherits directly from object. Verified."
    - "struct.error.__bases__[0].__name__ == 'Exception' — error inherits from Exception. Verified."
    - "struct.Struct.__module__.__class__.__name__ == 'str' — __module__ is a str. Verified."
    - "struct.error.__module__.__class__.__name__ == 'str' — __module__ is a str. Verified."
    - "struct.Struct.__module__.__len__() == 7 — len('_struct') == 7. Verified."
    - "struct.error.__module__.__len__() == 6 — len('struct') == 6. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __module__ for struct.Struct, pack, unpack, calcsize, error
#
# struct_extra4 covers __qualname__ for all module-level functions.
# No prior struct spec covers __module__ for Struct, pack, unpack, calcsize,
# or error. On Python 3.12, Struct/pack/unpack/calcsize are implemented in
# the C extension _struct, so their __module__ is '_struct'. The error
# exception class is defined in the Python wrapper module 'struct'.
# Verified: Struct='_struct', pack='_struct', unpack='_struct',
#   calcsize='_struct', error='struct'.
# ---------------------------------------------------------------------------

table struct_extra22.function_and_class_modules:
  description: "__module__ for struct.Struct/pack/unpack/calcsize (C ext: '_struct') and error (Python: 'struct')"
  kind: python_call_eq
  category: module_identity
  id_prefix: fcmod22

  columns: [id, function, args, expected]
  rows:
    - [Struct,    Struct.__module__.__eq__,   ["_struct"], true]
    - [pack,      pack.__module__.__eq__,     ["_struct"], true]
    - [unpack,    unpack.__module__.__eq__,   ["_struct"], true]
    - [calcsize,  calcsize.__module__.__eq__, ["_struct"], true]
    - [error,     error.__module__.__eq__,    ["struct"],  true]

# ---------------------------------------------------------------------------
# Table: __bases__[0].__name__ for Struct and error
#
# struct.Struct inherits directly from object (it is a C extension type).
# struct.error inherits from Exception (it is a Python exception class).
# No prior struct spec covers __bases__[0].__name__ for either class.
# Verified: Struct.__bases__[0].__name__ == 'object',
#           error.__bases__[0].__name__ == 'Exception'.
# ---------------------------------------------------------------------------

table struct_extra22.class_base_names:
  description: "__bases__[0].__name__ for struct.Struct and struct.error — inheritance roots"
  kind: python_call_eq
  category: class_identity
  id_prefix: cbase22

  columns: [id, function, args, expected]
  rows:
    - [Struct_base, "Struct.__bases__[0].__name__.__eq__", ["object"],    true]
    - [error_base,  "error.__bases__[0].__name__.__eq__",  ["Exception"], true]

# ---------------------------------------------------------------------------
# Table: __module__.__class__.__name__ for Struct, pack, unpack, error
#
# No prior struct spec checks that __module__ attributes are str objects
# (as opposed to checking their string value). This verifies the type of
# the __module__ attribute for key struct objects.
# Verified: all yield 'str'.
# ---------------------------------------------------------------------------

table struct_extra22.module_attr_class_names:
  description: "__module__.__class__.__name__ == 'str' for struct.Struct/pack/unpack/error — module attr is a str"
  kind: python_call_eq
  category: module_identity
  id_prefix: macn22

  columns: [id, function, args, expected]
  rows:
    - [Struct, Struct.__module__.__class__.__name__.__eq__, ["str"], true]
    - [pack,   pack.__module__.__class__.__name__.__eq__,   ["str"], true]
    - [unpack, unpack.__module__.__class__.__name__.__eq__, ["str"], true]
    - [error,  error.__module__.__class__.__name__.__eq__,  ["str"], true]

# ---------------------------------------------------------------------------
# Standalone: struct.Struct.__module__.__len__() == 7
#
# '_struct' has 7 characters. No prior spec covers Struct.__module__.__len__().
# Provides a length-based cross-check independent of string equality.
# Verified: len('_struct') == 7.
# ---------------------------------------------------------------------------

invariant struct_extra22.Struct.module_len:
  description: "struct.Struct.__module__.__len__() == 7 — len('_struct') == 7"
  category: module_identity
  kind: python_call_eq
  function: Struct.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# Standalone: struct.error.__module__.__len__() == 6
#
# 'struct' has 6 characters. No prior spec covers error.__module__.__len__().
# Verified: len('struct') == 6.
# ---------------------------------------------------------------------------

invariant struct_extra22.error.module_len:
  description: "struct.error.__module__.__len__() == 6 — len('struct') == 6"
  category: module_identity
  kind: python_call_eq
  function: error.__module__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# Standalone: struct.Struct.__bases__[0].__name__ == 'object'
#
# Struct is a C extension type that inherits directly from the Python object
# base class. No prior spec covers struct.Struct.__bases__[0].__name__.
# Verified: struct.Struct.__bases__[0].__name__ == 'object'.
# ---------------------------------------------------------------------------

invariant struct_extra22.Struct.base_is_object:
  description: "struct.Struct.__bases__[0].__name__ == 'object' — Struct is a C extension type inheriting directly from object"
  category: class_identity
  kind: python_call_eq
  function: "Struct.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
