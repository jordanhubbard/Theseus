spec: statistics_extra19
version: ">=3.9"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html — Python statistics module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
  notes:
    - "This spec extends statistics_extra through statistics_extra18."
    - "statistics_extra17 covers mean/__qualname__.__eq__, NormalDist/__qualname__.__eq__, StatisticsError/__qualname__.__eq__."
    - "statistics_extra18 covers __qualname__.__eq__ for fmean/stdev/variance/pstdev/pvariance/mode/multimode/median/median_low/median_high/median_grouped/quantiles/geometric_mean/harmonic_mean."
    - "No prior spec covers __qualname__.__len__ for any statistics function or class."
    - "All statistics functions are top-level; __qualname__ equals the simple function name in each case."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__.__len__ — central tendency and spread functions
#
# Prior specs record __qualname__.__eq__ for all major functions.
# No prior spec records the character length of any function's __qualname__.
# Length confirms the exact spelling and catches unexpected nesting prefixes.
# ---------------------------------------------------------------------------

table statistics_extra19.function_qualname_lengths:
  kind: python_call_eq
  category: function_identity
  id_prefix: qualname_len

  columns: [id, function, args, expected, description]
  rows:
    - [mean,          mean.__qualname__.__len__,          [], 4,  "len('mean') == 4"]
    - [median,        median.__qualname__.__len__,        [], 6,  "len('median') == 6"]
    - [mode,          mode.__qualname__.__len__,          [], 4,  "len('mode') == 4"]
    - [stdev,         stdev.__qualname__.__len__,         [], 5,  "len('stdev') == 5"]
    - [pstdev,        pstdev.__qualname__.__len__,        [], 6,  "len('pstdev') == 6"]
    - [variance,      variance.__qualname__.__len__,      [], 8,  "len('variance') == 8"]
    - [pvariance,     pvariance.__qualname__.__len__,     [], 9,  "len('pvariance') == 9"]
    - [fmean,         fmean.__qualname__.__len__,         [], 5,  "len('fmean') == 5"]
    - [harmonic_mean, harmonic_mean.__qualname__.__len__, [], 13, "len('harmonic_mean') == 13"]
    - [geometric_mean, geometric_mean.__qualname__.__len__, [], 14, "len('geometric_mean') == 14"]

# ---------------------------------------------------------------------------
# Class and exception __qualname__.__len__
#
# No prior spec records __qualname__.__len__ for NormalDist or StatisticsError.
# ---------------------------------------------------------------------------

invariant statistics_extra19.NormalDist.qualname_len:
  description: "len(statistics.NormalDist.__qualname__) == 10 — 'NormalDist' has 10 characters"
  category: class_identity
  kind: python_call_eq
  function: NormalDist.__qualname__.__len__
  args: []
  expected: 10

invariant statistics_extra19.StatisticsError.qualname_len:
  description: "len(statistics.StatisticsError.__qualname__) == 15 — 'StatisticsError' has 15 characters"
  category: class_identity
  kind: python_call_eq
  function: StatisticsError.__qualname__.__len__
  args: []
  expected: 15

invariant statistics_extra19.multimode.qualname_len:
  description: "len(statistics.multimode.__qualname__) == 9 — 'multimode' has 9 characters"
  category: function_identity
  kind: python_call_eq
  function: multimode.__qualname__.__len__
  args: []
  expected: 9

invariant statistics_extra19.median_low.qualname_len:
  description: "len(statistics.median_low.__qualname__) == 10 — 'median_low' has 10 characters"
  category: function_identity
  kind: python_call_eq
  function: median_low.__qualname__.__len__
  args: []
  expected: 10

invariant statistics_extra19.median_high.qualname_len:
  description: "len(statistics.median_high.__qualname__) == 11 — 'median_high' has 11 characters"
  category: function_identity
  kind: python_call_eq
  function: median_high.__qualname__.__len__
  args: []
  expected: 11

invariant statistics_extra19.median_grouped.qualname_len:
  description: "len(statistics.median_grouped.__qualname__) == 14 — 'median_grouped' has 14 characters"
  category: function_identity
  kind: python_call_eq
  function: median_grouped.__qualname__.__len__
  args: []
  expected: 14
