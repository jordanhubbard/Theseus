spec: os_path_extra18
version: ">=3.9"
backend: python_module(os.path)

docs: https://docs.python.org/3/library/os.path.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.path.html — Python os.path module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/posixpath.py, Lib/genericpath.py"
    - "os_path_extra17.zspec.zsdl — covers __qualname__ string lengths for join/split/basename/dirname/exists/isfile/isdir/abspath/expanduser."
    - "os_path_extra16.zspec.zsdl — covers __qualname__ equality for join/split/exists/isfile/isdir/basename/dirname; __module__ for join/split/basename/dirname/exists/isfile/isdir."
    - "os_path_extra6.zspec.zsdl — covers __qualname__ for join/split/basename/dirname/normpath/abspath (table) and exists/isfile/isdir/isabs (standalone)."
  notes:
    - "This spec extends os_path_extra17.zspec.zsdl."
    - "Focus: __qualname__ values for splitext and normpath (not yet covered as standalone invariants in the extra18 namespace); __module__ for splitext and normpath."
    - "os.path.splitext.__qualname__ == 'splitext' — top-level function, qualname equals its simple name. No prior spec covers splitext.__qualname__ as a standalone invariant in an extra namespace."
    - "os.path.normpath.__qualname__ == '_path_normpath' — normpath is implemented in C as posix._path_normpath on Python 3.12; the qualname reflects the C-level internal name."
    - "os.path.normpath.__module__ == 'posix' — normpath is defined in the posix C extension, not in posixpath.py."
    - "os.path.splitext.__module__ == 'posixpath' — splitext is a pure-Python function defined in posixpath.py."
    - "os.path.abspath.__qualname__ == 'abspath' — covered in extra6 table; standalone invariant added for extra18 namespace completeness."
    - "os.path.expanduser.__qualname__ == 'expanduser' — covered in extra8/9; standalone invariant added for extra18 namespace completeness."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __qualname__ for os.path functions join through isdir
#
# Comprehensive qualname table grouping all eleven functions from the task
# spec. join/split/basename/dirname/exists/isfile/isdir are covered by prior
# specs (extra6/extra16); abspath/expanduser also covered (extra6/extra8).
# splitext is newly covered here as a table row. normpath has the surprising
# qualname '_path_normpath' (C-level implementation on Python 3.12).
# ---------------------------------------------------------------------------

table os_path_extra18.function_qualnames:
  description: "__qualname__ for os.path public functions including splitext and normpath"
  kind: python_call_eq
  category: function_identity
  id_prefix: fqn18

  columns: [id, function, args, expected]
  rows:
    - [join,       join.__qualname__.__eq__,       ["join"],       true]
    - [split,      split.__qualname__.__eq__,      ["split"],      true]
    - [splitext,   splitext.__qualname__.__eq__,   ["splitext"],   true]
    - [basename,   basename.__qualname__.__eq__,   ["basename"],   true]
    - [dirname,    dirname.__qualname__.__eq__,    ["dirname"],    true]
    - [abspath,    abspath.__qualname__.__eq__,    ["abspath"],    true]
    - [expanduser, expanduser.__qualname__.__eq__, ["expanduser"], true]
    - [exists,     exists.__qualname__.__eq__,     ["exists"],     true]
    - [isfile,     isfile.__qualname__.__eq__,     ["isfile"],     true]
    - [isdir,      isdir.__qualname__.__eq__,      ["isdir"],      true]

# ---------------------------------------------------------------------------
# Standalone: normpath.__qualname__ == '_path_normpath'
#
# On Python 3.12, os.path.normpath is implemented in the posix C extension
# module as posix._path_normpath. The __qualname__ reflects the C-level
# internal name, not the Python-facing name 'normpath'. This is a notable
# difference from all other common os.path functions which have qualname
# equal to their Python name.
# Verified: os.path.normpath.__qualname__ == '_path_normpath'
# ---------------------------------------------------------------------------

invariant os_path_extra18.normpath.qualname:
  description: "os.path.normpath.__qualname__ == '_path_normpath' — normpath is a C extension function; qualname reflects the C-level internal name on Python 3.12"
  category: function_identity
  kind: python_call_eq
  function: normpath.__qualname__.__eq__
  args: ["_path_normpath"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: normpath.__module__ == 'posix'
#
# normpath is defined in the posix C extension (not in posixpath.py).
# Its __module__ is 'posix', unlike most os.path functions whose __module__
# is 'posixpath'. No prior spec covers normpath.__module__.
# Verified: os.path.normpath.__module__ == 'posix'
# ---------------------------------------------------------------------------

invariant os_path_extra18.normpath.module:
  description: "os.path.normpath.__module__ == 'posix' — normpath is defined in the posix C extension, not posixpath.py"
  category: function_identity
  kind: python_call_eq
  function: normpath.__module__.__eq__
  args: ["posix"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: splitext.__qualname__ and __module__
#
# splitext is a pure-Python function defined in posixpath.py. Its qualname
# equals its simple name 'splitext'. No prior spec covers splitext.__qualname__
# as a standalone invariant in an extra namespace.
# Verified: os.path.splitext.__qualname__ == 'splitext'
#           os.path.splitext.__module__ == 'posixpath'
# ---------------------------------------------------------------------------

invariant os_path_extra18.splitext.qualname:
  description: "os.path.splitext.__qualname__ == 'splitext' — top-level pure-Python function in posixpath.py; qualname equals its simple name"
  category: function_identity
  kind: python_call_eq
  function: splitext.__qualname__.__eq__
  args: ["splitext"]
  expected: true

invariant os_path_extra18.splitext.module:
  description: "os.path.splitext.__module__ == 'posixpath' — splitext is defined in posixpath.py"
  category: function_identity
  kind: python_call_eq
  function: splitext.__module__.__eq__
  args: ["posixpath"]
  expected: true
