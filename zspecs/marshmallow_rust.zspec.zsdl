spec: marshmallow_rust
version: ">=3.9"
backend: rust_module(marshmallow_rust)

docs: https://marshmallow.readthedocs.io/

provenance:
  derived_from:
    - "https://marshmallow.readthedocs.io/ — marshmallow serialization"
  notes:
    - "marshmallow provides ORM-independent serialization/deserialization."
    - "marshmallow.Schema is a class."
    - "marshmallow.fields.String is a class."
    - "marshmallow.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant marshmallow_rust.has_schema:
  description: "marshmallow.Schema is a class"
  category: presence
  kind: python_call_eq
  function: marshmallow_has_schema
  args: []
  expected: true

invariant marshmallow_rust.has_fields_string:
  description: "marshmallow.fields.String is a class"
  category: presence
  kind: python_call_eq
  function: marshmallow_has_fields_string
  args: []
  expected: true

invariant marshmallow_rust.version_nonempty:
  description: "marshmallow.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: marshmallow_version_nonempty
  args: []
  expected: true

