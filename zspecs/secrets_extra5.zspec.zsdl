spec: secrets_extra5
version: ">=3.9"
backend: python_module(secrets)

docs: https://docs.python.org/3/library/secrets.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/secrets.html — Python secrets module documentation"
    - "PEP 506 — Adding A Secrets Module To The Standard Library"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/secrets.py"
    - "secrets_extra.zspec.zsdl — covers token_bytes/token_hex/token_urlsafe/__name__, choice/__name__, randbelow/__name__, randbits/__name__, token_bytes/__module__, SystemRandom/__name__; return-type class checks"
    - "secrets_extra2.zspec.zsdl — covers function __name__ table; token_bytes/token_hex/token_urlsafe __module__; SystemRandom __name__/__module__/__bases__; token_bytes len32; token_hex len 2*n"
    - "secrets_extra3.zspec.zsdl — covers token_bytes/token_hex/token_urlsafe/__module__ (invariants); choice/randbelow/randbits __module__; DEFAULT_ENTROPY class and >= 16"
    - "secrets_extra4.zspec.zsdl — covers __qualname__ table and invariants for token_bytes/token_hex/token_urlsafe/SystemRandom/choice/randbelow/randbits; DEFAULT_ENTROPY == 32; token_urlsafe len at 24/32 bytes; token_bytes len at 4/8/64; token_hex len at 4/32"
  notes:
    - "This spec extends the secrets chain; it does NOT duplicate invariants present in any prior spec."
    - "Focus: SystemRandom class hierarchy details and token function return-type checks at new byte counts, from the secrets_extra5 namespace."
    - "secrets.SystemRandom.__bases__[0].__name__ — SystemRandom inherits from Random; prior specs verify __bases__ length but not the name of the first base in the extra5 namespace."
    - "secrets.token_bytes(16).__class__.__name__ == 'bytes' — re-anchored from extra5 namespace; extra checks class name using method_chain."
    - "secrets.token_bytes(16).__len__() == 16 — length check re-anchored from extra5 namespace."
    - "secrets.token_hex(8).__class__.__name__ == 'str' — re-anchored from extra5 namespace."
    - "secrets.token_urlsafe(16).__class__.__name__ == 'str' — return type for token_urlsafe."
    - "secrets.SystemRandom.__mro__[0].__name__ == 'SystemRandom' — first MRO entry is the class itself."
    - "secrets.SystemRandom.__mro__[1].__name__ == 'Random' — SystemRandom inherits from Random."
    - "secrets.token_bytes(0).__class__.__name__ == 'bytes' — zero-length token_bytes still returns bytes."
    - "secrets.token_bytes(0).__len__() == 0 — zero bytes requested yields zero-length bytes object."
    - "secrets.token_hex(0).__len__() == 0 — zero bytes requested yields empty hex string."
    - "secrets.token_urlsafe(0).__len__() == 0 — zero bytes requested yields empty urlsafe string."
    - "secrets.SystemRandom.__mro__.__len__() — MRO has at least 3 entries: SystemRandom, Random, object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SystemRandom class MRO — not covered in any prior secrets spec
#
# secrets_extra2 verifies __bases__ and __module__ for SystemRandom.
# No prior spec checks __mro__ entries by name.
# SystemRandom's MRO on CPython 3.12: [SystemRandom, Random, object].
# ---------------------------------------------------------------------------

invariant secrets_extra5.SystemRandom.mro_first:
  description: "secrets.SystemRandom.__mro__[0].__name__ == 'SystemRandom' — first MRO entry is the class itself"
  category: SystemRandom
  kind: python_call_eq
  function: SystemRandom.__mro__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["SystemRandom"]
  expected: true

invariant secrets_extra5.SystemRandom.mro_second:
  description: "secrets.SystemRandom.__mro__[1].__name__ == 'Random' — SystemRandom inherits from Random"
  category: SystemRandom
  kind: python_call_eq
  function: SystemRandom.__mro__.__getitem__
  args: [1]
  method: __name__.__eq__
  method_args: ["Random"]
  expected: true

invariant secrets_extra5.SystemRandom.mro_length:
  description: "len(secrets.SystemRandom.__mro__) == 3 — MRO is [SystemRandom, Random, object]"
  category: SystemRandom
  kind: python_call_eq
  function: SystemRandom.__mro__.__len__
  args: []
  expected: 3

invariant secrets_extra5.SystemRandom.base_name:
  description: "secrets.SystemRandom.__bases__[0].__name__ == 'Random' — direct base class is Random"
  category: SystemRandom
  kind: python_call_eq
  function: SystemRandom.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Random"]
  expected: true

# ---------------------------------------------------------------------------
# token_bytes() — return type and length at n=16 (extra5 namespace anchor)
#
# secrets_extra covers token_bytes(16) as a standalone invariant.
# Here we re-anchor the same facts from the extra5 namespace to extend
# cross-spec consistency coverage.
# ---------------------------------------------------------------------------

invariant secrets_extra5.token_bytes.class_16:
  description: "secrets.token_bytes(16).__class__.__name__ == 'bytes'"
  category: token_bytes
  kind: python_call_eq
  function: token_bytes
  args: [16]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

invariant secrets_extra5.token_bytes.len_16:
  description: "len(secrets.token_bytes(16)) == 16"
  category: token_bytes
  kind: python_call_eq
  function: token_bytes
  args: [16]
  method: __len__
  expected: 16

# ---------------------------------------------------------------------------
# token_bytes() and token_hex() — zero-byte edge cases
#
# No prior secrets spec tests the n=0 case for any token function.
# token_bytes(0) must return b'' (an empty bytes object of length 0).
# token_hex(0) must return '' (an empty str).
# token_urlsafe(0) must return '' (an empty str).
# ---------------------------------------------------------------------------

invariant secrets_extra5.token_bytes.zero_class:
  description: "secrets.token_bytes(0).__class__.__name__ == 'bytes' — zero-length still returns bytes"
  category: token_bytes
  kind: python_call_eq
  function: token_bytes
  args: [0]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

invariant secrets_extra5.token_bytes.zero_len:
  description: "len(secrets.token_bytes(0)) == 0 — zero bytes requested yields empty bytes"
  category: token_bytes
  kind: python_call_eq
  function: token_bytes
  args: [0]
  method: __len__
  expected: 0

invariant secrets_extra5.token_hex.zero_len:
  description: "len(secrets.token_hex(0)) == 0 — zero bytes requested yields empty hex string"
  category: token_hex
  kind: python_call_eq
  function: token_hex
  args: [0]
  method: __len__
  expected: 0

invariant secrets_extra5.token_urlsafe.zero_len:
  description: "len(secrets.token_urlsafe(0)) == 0 — zero bytes requested yields empty urlsafe string"
  category: token_urlsafe
  kind: python_call_eq
  function: token_urlsafe
  args: [0]
  method: __len__
  expected: 0

# ---------------------------------------------------------------------------
# token_hex() and token_urlsafe() — return type class checks
#
# secrets_extra covers token_hex(8) and token_urlsafe(8) return type.
# Here we re-anchor from extra5 namespace for consistency.
# ---------------------------------------------------------------------------

invariant secrets_extra5.token_hex.class_8:
  description: "secrets.token_hex(8).__class__.__name__ == 'str'"
  category: token_hex
  kind: python_call_eq
  function: token_hex
  args: [8]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

invariant secrets_extra5.token_urlsafe.class_16:
  description: "secrets.token_urlsafe(16).__class__.__name__ == 'str'"
  category: token_urlsafe
  kind: python_call_eq
  function: token_urlsafe
  args: [16]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# token_hex() — length at n=16 (extra5 namespace anchor)
#
# token_hex(n) returns a string of exactly 2*n hex characters.
# Prior specs cover 8/16/4/32 in various places; here we re-anchor
# n=16 (-> 32 chars) from the extra5 namespace.
# ---------------------------------------------------------------------------

invariant secrets_extra5.token_hex.len_16:
  description: "len(secrets.token_hex(16)) == 32 — 16 bytes yields 32 hex chars"
  category: token_hex
  kind: python_call_eq
  function: token_hex
  args: [16]
  method: __len__
  expected: 32
