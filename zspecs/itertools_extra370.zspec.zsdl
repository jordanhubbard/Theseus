invariant itertools_extra370.combinations_with_replacement_name:
  description: "itertools.combinations_with_replacement.__name__ == 'combinations_with_replacement' — C extension type yielding combinations with repeated elements; new to extra370"
  kind: python_call_eq
  function: combinations_with_replacement.__name__.__eq__
  args: ["combinations_with_replacement"]
