spec: itertools_extra370
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "itertools.zip_longest.__name__ == 'zip_longest' — C type in itertools module. Verified with Python 3.14.4."
    - "itertools.zip_longest.__module__ == 'itertools' — defined in the itertools C extension. Verified with Python 3.14.4."
    - "itertools.product.__name__ == 'product' — C type in itertools module. Verified with Python 3.14.4."
    - "itertools.product.__module__ == 'itertools' — defined in the itertools C extension. Verified with Python 3.14.4."
    - "itertools.permutations.__name__ == 'permutations' — C type in itertools module. Verified with Python 3.14.4."
    - "itertools.permutations.__module__ == 'itertools' — defined in the itertools C extension. Verified with Python 3.14.4."
    - "itertools.combinations.__name__ == 'combinations' — C type in itertools module. Verified with Python 3.14.4."
    - "itertools.combinations.__module__ == 'itertools' — defined in the itertools C extension. Verified with Python 3.14.4."
    - "itertools.combinations_with_replacement.__name__ == 'combinations_with_replacement' — C type in itertools module. Verified with Python 3.14.4."
    - "itertools.combinations_with_replacement.__module__ == 'itertools' — defined in the itertools C extension. Verified with Python 3.14.4."
    - "itertools.tee.__name__ == 'tee' — C builtin_function_or_method in itertools module. Verified with Python 3.14.4."
    - "itertools.tee.__module__ == 'itertools' — defined in the itertools C extension. Verified with Python 3.14.4."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools combinatoric iterator class identity
#
# itertools.zip_longest.__name__ == 'zip_longest'
# itertools.zip_longest.__module__ == 'itertools'
# itertools.product.__name__ == 'product'
# itertools.product.__module__ == 'itertools'
# itertools.permutations.__name__ == 'permutations'
# itertools.permutations.__module__ == 'itertools'
# itertools.combinations.__name__ == 'combinations'
# itertools.combinations.__module__ == 'itertools'
# itertools.combinations_with_replacement.__name__ == 'combinations_with_replacement'
# itertools.combinations_with_replacement.__module__ == 'itertools'
#
# All are C extension types exposed directly from the itertools module.
# They are implemented in Modules/itertoolsmodule.c.
# ---------------------------------------------------------------------------

table itertools_extra370.combinatoric_iterator_identity:
  description: "itertools combinatoric iterator types identity: __name__ and __module__ for zip_longest, product, permutations, combinations, combinations_with_replacement; all C types in itertools; new to extra370"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolscomb370

  columns: [id, function, args, expected, description]
  rows:
    - [zip_longest_name_eq,
       "zip_longest.__name__.__eq__",
       ["zip_longest"],
       true,
       "itertools.zip_longest.__name__.__eq__('zip_longest') == True — zip_longest is a C extension type in Modules/itertoolsmodule.c that aggregates elements from multiple iterables padding shorter ones with a fill value; its __name__ is 'zip_longest'; str.__eq__('zip_longest') returns True; new to extra370"]
    - [zip_longest_module_eq,
       "zip_longest.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.zip_longest.__module__.__eq__('itertools') == True — zip_longest is implemented in the itertools C extension; its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra370"]
    - [product_name_eq,
       "product.__name__.__eq__",
       ["product"],
       true,
       "itertools.product.__name__.__eq__('product') == True — product is a C extension type in Modules/itertoolsmodule.c that yields the Cartesian product of input iterables; its __name__ is 'product'; str.__eq__('product') returns True; new to extra370"]
    - [product_module_eq,
       "product.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.product.__module__.__eq__('itertools') == True — product is implemented in the itertools C extension; its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra370"]
    - [permutations_name_eq,
       "permutations.__name__.__eq__",
       ["permutations"],
       true,
       "itertools.permutations.__name__.__eq__('permutations') == True — permutations is a C extension type in Modules/itertoolsmodule.c that yields successive permutations of the input iterable; its __name__ is 'permutations'; str.__eq__('permutations') returns True; new to extra370"]
    - [permutations_module_eq,
       "permutations.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.permutations.__module__.__eq__('itertools') == True — permutations is implemented in the itertools C extension; its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra370"]
    - [combinations_name_eq,
       "combinations.__name__.__eq__",
       ["combinations"],
       true,
       "itertools.combinations.__name__.__eq__('combinations') == True — combinations is a C extension type in Modules/itertoolsmodule.c that yields successive r-length combinations from the input; its __name__ is 'combinations'; str.__eq__('combinations') returns True; new to extra370"]
    - [combinations_module_eq,
       "combinations.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.combinations.__module__.__eq__('itertools') == True — combinations is implemented in the itertools C extension; its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra370"]
    - [combinations_with_replacement_name_eq,
       "combinations_with_replacement.__name__.__eq__",
       ["combinations_with_replacement"],
       true,
       "itertools.combinations_with_replacement.__name__.__eq__('combinations_with_replacement') == True — combinations_with_replacement is a C extension type in Modules/itertoolsmodule.c that yields r-length combinations allowing repeated elements; its __name__ is 'combinations_with_replacement'; str.__eq__('combinations_with_replacement') returns True; new to extra370"]
    - [combinations_with_replacement_module_eq,
       "combinations_with_replacement.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.combinations_with_replacement.__module__.__eq__('itertools') == True — combinations_with_replacement is implemented in the itertools C extension; its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra370"]

# ---------------------------------------------------------------------------
# Table 2: itertools.tee function identity
#
# itertools.tee.__name__ == 'tee'
# itertools.tee.__module__ == 'itertools'
#
# tee is a C builtin_function_or_method in the itertools module that returns
# n independent iterators from a single iterable.
# ---------------------------------------------------------------------------

table itertools_extra370.tee_identity:
  description: "itertools.tee builtin function identity: __name__ and __module__; tee creates n independent iterators from a single iterable; new to extra370"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolstee370

  columns: [id, function, args, expected, description]
  rows:
    - [tee_name_eq,
       "tee.__name__.__eq__",
       ["tee"],
       true,
       "itertools.tee.__name__.__eq__('tee') == True — tee is a C builtin_function_or_method in Modules/itertoolsmodule.c that splits a single iterable into n independent iterators; its __name__ is 'tee'; str.__eq__('tee') returns True; new to extra370"]
    - [tee_module_eq,
       "tee.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.tee.__module__.__eq__('itertools') == True — tee is implemented in the itertools C extension; its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra370"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra370
# ---------------------------------------------------------------------------

invariant itertools_extra370.zip_longest_name:
  description: "itertools.zip_longest.__name__ == 'zip_longest' — C extension type in itertools; new to extra370"
  kind: python_call_eq
  function: zip_longest.__name__.__eq__
  args: ["zip_longest"]
  expected: true

invariant itertools_extra370.zip_longest_module:
  description: "itertools.zip_longest.__module__ == 'itertools' — defined in itertools C extension; new to extra370"
  kind: python_call_eq
  function: zip_longest.__module__.__eq__
  args: ["itertools"]
  expected: true

