spec: inspect_extra316
version: ">=3.3"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "CO_OPTIMIZED == 1, CO_NEWLOCALS == 2, CO_VARARGS == 4, CO_VARKEYWORDS == 8."
    - "CO_NESTED == 16, CO_GENERATOR == 32, CO_NOFREE == 64, CO_COROUTINE == 128."
    - "CO_ITERABLE_COROUTINE == 256 — present on Python 3.14.4."
    - "All constants are integers exposed directly on the inspect module as int attributes."
    - "These values correspond to CPython code object flag bits (co_flags field)."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# CO_* flag constants — exact integer values
#
# These constants expose CPython code object flag bits (co_flags) through the
# inspect module's public API. All values verified on Python 3.14.4.
# ---------------------------------------------------------------------------

table inspect_extra316.co_flags:
  kind: python_call_eq
  category: co_flags
  id_prefix: coflag

  columns: [id, function, args, expected]
  rows:
    - [co_optimized,          CO_OPTIMIZED.__eq__,          [1],   true]
    - [co_newlocals,          CO_NEWLOCALS.__eq__,          [2],   true]
    - [co_varargs,            CO_VARARGS.__eq__,            [4],   true]
    - [co_varkeywords,        CO_VARKEYWORDS.__eq__,        [8],   true]
    - [co_nested,             CO_NESTED.__eq__,             [16],  true]
    - [co_generator,          CO_GENERATOR.__eq__,          [32],  true]
    - [co_nofree,             CO_NOFREE.__eq__,             [64],  true]
    - [co_coroutine,          CO_COROUTINE.__eq__,          [128], true]
    - [co_iterable_coroutine, CO_ITERABLE_COROUTINE.__eq__, [256], true]

# ---------------------------------------------------------------------------
# CO_* flag constants — class name checks (all are plain ints)
# ---------------------------------------------------------------------------

table inspect_extra316.co_flags_types:
  kind: python_call_eq
  category: co_flags_types
  id_prefix: coflagtype

  columns: [id, function, args, expected]
  rows:
    - [co_optimized,          CO_OPTIMIZED.__class__.__name__.__eq__,          ["int"], true]
    - [co_newlocals,          CO_NEWLOCALS.__class__.__name__.__eq__,          ["int"], true]
    - [co_varargs,            CO_VARARGS.__class__.__name__.__eq__,            ["int"], true]
    - [co_varkeywords,        CO_VARKEYWORDS.__class__.__name__.__eq__,        ["int"], true]
    - [co_nested,             CO_NESTED.__class__.__name__.__eq__,             ["int"], true]
    - [co_generator,          CO_GENERATOR.__class__.__name__.__eq__,          ["int"], true]
    - [co_nofree,             CO_NOFREE.__class__.__name__.__eq__,             ["int"], true]
    - [co_coroutine,          CO_COROUTINE.__class__.__name__.__eq__,          ["int"], true]
    - [co_iterable_coroutine, CO_ITERABLE_COROUTINE.__class__.__name__.__eq__, ["int"], true]
