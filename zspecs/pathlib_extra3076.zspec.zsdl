spec: pp3076
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 652 (pp3076): __get__, __set__, __delete__ dict-presence checks for pathlib types."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS)."
    - "None of the pathlib path classes define the descriptor protocol in their own __dict__: __get__, __set__, and __delete__ are all absent."
    - "pathlib classes represent filesystem path objects; they are not descriptors and do not implement the descriptor protocol."
    - "pathlib.PosixPath is available on macOS/POSIX platforms; pathlib.WindowsPath is only instantiable on Windows."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __get__ dict-presence — operator.contains(Cls.__dict__, '__get__')
#
# No pathlib path class defines __get__ in its own __dict__; all false.
# pathlib classes are filesystem path abstractions, not descriptor objects.
# ---------------------------------------------------------------------------

table pp3076.get:
  description: "pathlib types __get__ dict-presence checks; wave 652"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3076

  columns: [id, function, args, expected]
  rows:
    - ["pp3076001", operator.contains, [pathlib.PurePath.__dict__,        "__get__"], false]
    - ["pp3076002", operator.contains, [pathlib.PurePosixPath.__dict__,   "__get__"], false]
    - ["pp3076003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__get__"], false]
    - ["pp3076004", operator.contains, [pathlib.Path.__dict__,            "__get__"], false]
    - ["pp3076005", operator.contains, [pathlib.PosixPath.__dict__,       "__get__"], false]

