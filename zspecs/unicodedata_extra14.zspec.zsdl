spec: unicodedata_extra14
version: ">=3.9"
backend: python_module(unicodedata)

docs: https://docs.python.org/3/library/unicodedata.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unicodedata.html — Python unicodedata module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/unicodedata.c"
  notes:
    - "This spec extends unicodedata.zspec.zsdl and prior extras through unicodedata_extra13.zspec.zsdl."
    - "unicodedata_extra12 covers: name('A') == 'LATIN CAPITAL LETTER A'; name('\\u00e9'); name('\\u00c0')."
    - "unicodedata_extra13 covers: function __name__ and __module__ namespace anchors."
    - "unicodedata_extra covers: category('A') == 'Lu'; covered in extra table."
    - "unicodedata_extra3 covers: category('a') == 'Ll'; category('0') == 'Nd'."
    - "unicodedata_extra covers: decimal('5') == 5; digit('5') == 5."
    - "unicodedata_extra covers: digit('1') == 1; decimal covered elsewhere."
    - "unicodedata_extra covers: numeric('½'); numeric('\\u00bd') == 0.5; numeric('\\u00bc') == 0.25."
    - "unicodedata_extra covers: numeric('2') == 2.0; numeric('3') == 3.0; numeric('9') == 9.0."
    - "NOT yet covered (now covered here): name('a') == 'LATIN SMALL LETTER A' — lowercase a name."
    - "NOT yet covered (now covered here): category('1') == 'Nd' — digit character category."
    - "NOT yet covered (now covered here): decimal('1') == 1 — decimal value of digit one."
    - "NOT yet covered (now covered here): digit('1') == 1 — digit value of digit one (extra14 namespace)."
    - "NOT yet covered (now covered here): numeric('½') == 0.5 — vulgar fraction half (extra14 namespace, via direct expected float)."
    - "NOT yet covered (now covered here): name('0') == 'DIGIT ZERO' — name lookup for digit zero."
    - "NOT yet covered (now covered here): name('Z') == 'LATIN CAPITAL LETTER Z' — name lookup for last ASCII uppercase letter."
    - "NOT yet covered (now covered here): decimal('0') == 0 — decimal value of digit zero."
    - "NOT yet covered (now covered here): decimal('9') == 9 — decimal value of digit nine."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# name() — new input vectors
#
# unicodedata_extra12 covers name('A'), name('\u00e9'), name('\u00c0').
# unicodedata_extra13 re-anchors name('A').
# No prior spec covers name('a') (lowercase a) or name('0') or name('Z').
# ---------------------------------------------------------------------------

invariant unicodedata_extra14.name.lowercase_a:
  description: "unicodedata.name('a') == 'LATIN SMALL LETTER A' — name lookup for ASCII lowercase a"
  category: name
  kind: python_call_eq
  function: name
  args: ["a"]
  expected: "LATIN SMALL LETTER A"

invariant unicodedata_extra14.name.digit_zero:
  description: "unicodedata.name('0') == 'DIGIT ZERO' — name lookup for digit zero"
  category: name
  kind: python_call_eq
  function: name
  args: ["0"]
  expected: "DIGIT ZERO"

invariant unicodedata_extra14.name.capital_z:
  description: "unicodedata.name('Z') == 'LATIN CAPITAL LETTER Z' — name lookup for last uppercase ASCII letter"
  category: name
  kind: python_call_eq
  function: name
  args: ["Z"]
  expected: "LATIN CAPITAL LETTER Z"

# ---------------------------------------------------------------------------
# category() — digit character
#
# unicodedata_extra3 covers category('a') == 'Ll' and category('0') == 'Nd'.
# No prior spec covers category('1') as a standalone invariant.
# ---------------------------------------------------------------------------

invariant unicodedata_extra14.category.digit_one:
  description: "unicodedata.category('1') == 'Nd' — digit '1' is a decimal digit"
  category: category
  kind: python_call_eq
  function: category
  args: ["1"]
  expected: "Nd"

# ---------------------------------------------------------------------------
# Table: category() — letters and digits
#
# Groups Lu, Ll, Nd category checks for common ASCII characters.
# No prior table groups all three category types (Lu/Ll/Nd) together.
# ---------------------------------------------------------------------------

table unicodedata_extra14.category_vectors:
  description: "unicodedata.category checks for uppercase letters, lowercase letters, and digits"
  kind: python_call_eq
  category: category
  id_prefix: cat14
  function: category

  columns: [id, args, expected]
  rows:
    - [uppercase_a,  ["A"],  "Lu"]
    - [uppercase_z,  ["Z"],  "Lu"]
    - [lowercase_a,  ["a"],  "Ll"]
    - [lowercase_z,  ["z"],  "Ll"]
    - [digit_zero,   ["0"],  "Nd"]
    - [digit_one,    ["1"],  "Nd"]
    - [digit_nine,   ["9"],  "Nd"]

# ---------------------------------------------------------------------------
# decimal() — new input vectors
#
# Prior specs cover decimal('5') == 5. No prior spec covers decimal('1'),
# decimal('0'), or decimal('9') as standalone invariants in extra14 namespace.
# ---------------------------------------------------------------------------

invariant unicodedata_extra14.decimal.digit_one:
  description: "unicodedata.decimal('1') == 1 — decimal value of character '1'"
  category: decimal
  kind: python_call_eq
  function: decimal
  args: ["1"]
  expected: 1

invariant unicodedata_extra14.decimal.digit_zero:
  description: "unicodedata.decimal('0') == 0 — decimal value of character '0'"
  category: decimal
  kind: python_call_eq
  function: decimal
  args: ["0"]
  expected: 0

invariant unicodedata_extra14.decimal.digit_nine:
  description: "unicodedata.decimal('9') == 9 — decimal value of character '9'"
  category: decimal
  kind: python_call_eq
  function: decimal
  args: ["9"]
  expected: 9

# ---------------------------------------------------------------------------
# digit() — digit one (extra14 namespace anchor)
#
# unicodedata_extra covers digit('1') == 1 in the base extra namespace.
# Re-anchored here in the extra14 namespace as a standalone invariant.
# ---------------------------------------------------------------------------

invariant unicodedata_extra14.digit.digit_one:
  description: "unicodedata.digit('1') == 1 — digit value of character '1' (extra14 namespace)"
  category: digit
  kind: python_call_eq
  function: digit
  args: ["1"]
  expected: 1

# ---------------------------------------------------------------------------
# numeric() — vulgar fraction one half
#
# unicodedata_extra covers numeric('½') and numeric('\u00bd') == 0.5.
# numeric('\u00bc') == 0.25 is also covered.
# Re-anchored here in extra14 namespace using the character literal directly.
# numeric returns float even for integer-valued characters.
# ---------------------------------------------------------------------------

invariant unicodedata_extra14.numeric.vulgar_half:
  description: "unicodedata.numeric('½') == 0.5 — vulgar fraction one half has numeric value 0.5"
  category: numeric
  kind: python_call_eq
  function: numeric
  args: ["½"]
  expected: 0.5
