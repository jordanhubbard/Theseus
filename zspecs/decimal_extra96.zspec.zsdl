spec: decimal_extra96
version: ">=3.9"
backend: python_module(decimal)
extends: decimal_extra95

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal_extra95.zspec.zsdl."
    - "This spec covers: decimal.Decimal method class names and __qualname__ lengths; decimal.ROUND_* rounding mode constant string lengths."
    - "decimal.Decimal is a C extension type (_decimal.Decimal). Its arithmetic methods (quantize, sqrt, compare, to_integral, normalize) are method_descriptors."
    - "decimal.Decimal.__add__, __sub__, __mul__ are wrapper_descriptors (slot wrappers for C numeric protocol slots)."
    - "decimal.Decimal.quantize.__qualname__ = 'Decimal.quantize' (length 16)."
    - "decimal.Decimal.sqrt.__qualname__ = 'Decimal.sqrt' (length 12)."
    - "decimal.Decimal.compare.__qualname__ = 'Decimal.compare' (length 15)."
    - "decimal.Decimal.to_integral.__qualname__ = 'Decimal.to_integral' (length 19)."
    - "decimal.Decimal.normalize.__qualname__ = 'Decimal.normalize' (length 17)."
    - "decimal.Decimal.__add__.__qualname__ = 'Decimal.__add__' (length 15)."
    - "decimal.ROUND_UP = 'ROUND_UP' (length 8) — all ROUND_* constants are plain strings."
    - "decimal.ROUND_DOWN = 'ROUND_DOWN' (length 10)."
    - "decimal.ROUND_HALF_UP = 'ROUND_HALF_UP' (length 13)."
    - "decimal.ROUND_HALF_DOWN = 'ROUND_HALF_DOWN' (length 15)."
    - "decimal.ROUND_HALF_EVEN = 'ROUND_HALF_EVEN' (length 15)."
    - "decimal.ROUND_CEILING = 'ROUND_CEILING' (length 13)."
    - "decimal.ROUND_FLOOR = 'ROUND_FLOOR' (length 11)."
    - "decimal.ROUND_05UP = 'ROUND_05UP' (length 10)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal method class names
# Decimal is a C extension type. Its arithmetic methods (quantize, sqrt, etc.)
# are method_descriptors. The special dunder methods (__add__, __sub__, __mul__)
# are wrapper_descriptors (C-level slot wrappers for the numeric protocol).
# ---------------------------------------------------------------------------

table decimal_extra96.Decimal_method_class_names:
  description: "decimal.Decimal method class names: quantize/sqrt/compare/to_integral/normalize are 'method_descriptor'; __add__/__sub__/__mul__ are 'wrapper_descriptor'"
  kind: python_call_eq
  category: method_class_names
  id_prefix: decmethcls96

  columns: [id, function, args, expected, description]
  rows:
    - [quantize_cls,     Decimal.quantize.__class__.__name__.__eq__,     ["method_descriptor"],  true,  "Decimal.quantize.__class__.__name__ == 'method_descriptor' (C extension arithmetic method)"]
    - [sqrt_cls,         Decimal.sqrt.__class__.__name__.__eq__,         ["method_descriptor"],  true,  "Decimal.sqrt.__class__.__name__ == 'method_descriptor'"]
    - [compare_cls,      Decimal.compare.__class__.__name__.__eq__,      ["method_descriptor"],  true,  "Decimal.compare.__class__.__name__ == 'method_descriptor'"]
    - [to_integral_cls,  Decimal.to_integral.__class__.__name__.__eq__,  ["method_descriptor"],  true,  "Decimal.to_integral.__class__.__name__ == 'method_descriptor'"]
    - [normalize_cls,    Decimal.normalize.__class__.__name__.__eq__,    ["method_descriptor"],  true,  "Decimal.normalize.__class__.__name__ == 'method_descriptor'"]
    - [add_cls,          Decimal.__add__.__class__.__name__.__eq__,      ["wrapper_descriptor"], true,  "Decimal.__add__.__class__.__name__ == 'wrapper_descriptor' (C numeric protocol slot wrapper, not a regular method_descriptor)"]
    - [sub_cls,          Decimal.__sub__.__class__.__name__.__eq__,      ["wrapper_descriptor"], true,  "Decimal.__sub__.__class__.__name__ == 'wrapper_descriptor'"]
    - [mul_cls,          Decimal.__mul__.__class__.__name__.__eq__,      ["wrapper_descriptor"], true,  "Decimal.__mul__.__class__.__name__ == 'wrapper_descriptor'"]
    - [quantize_not_wd,  Decimal.quantize.__class__.__name__.__eq__,     ["wrapper_descriptor"], false, "Decimal.quantize.__class__.__name__ is NOT 'wrapper_descriptor' (quantize is a method_descriptor, not a slot wrapper)"]
    - [add_not_md,       Decimal.__add__.__class__.__name__.__eq__,      ["method_descriptor"],  false, "Decimal.__add__.__class__.__name__ is NOT 'method_descriptor' (dunder arithmetic ops use wrapper_descriptor, not method_descriptor)"]

# ---------------------------------------------------------------------------
# decimal.Decimal method __qualname__ lengths
# All Decimal methods follow the 'Decimal.method_name' qualname pattern.
# ---------------------------------------------------------------------------

table decimal_extra96.Decimal_method_qualname_lengths:
  description: "decimal.Decimal method __qualname__ lengths: quantize=16, sqrt=12, compare=15, to_integral=19, normalize=17, __add__=15"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: decmethcls96

  columns: [id, function, args, expected, description]
  rows:
    - [quantize_qn,     Decimal.quantize.__qualname__.__eq__,     ["Decimal.quantize"],     true, "Decimal.quantize.__qualname__ == 'Decimal.quantize'"]
    - [quantize_qn_len, Decimal.quantize.__qualname__.__len__,    [],                       16,   "Decimal.quantize.__qualname__.__len__() == 16 ('Decimal.quantize' has 16 characters)"]
    - [sqrt_qn,         Decimal.sqrt.__qualname__.__eq__,         ["Decimal.sqrt"],         true, "Decimal.sqrt.__qualname__ == 'Decimal.sqrt'"]
    - [sqrt_qn_len,     Decimal.sqrt.__qualname__.__len__,        [],                       12,   "Decimal.sqrt.__qualname__.__len__() == 12 ('Decimal.sqrt' has 12 characters)"]
    - [compare_qn,      Decimal.compare.__qualname__.__eq__,      ["Decimal.compare"],      true, "Decimal.compare.__qualname__ == 'Decimal.compare'"]
    - [compare_qn_len,  Decimal.compare.__qualname__.__len__,     [],                       15,   "Decimal.compare.__qualname__.__len__() == 15 ('Decimal.compare' has 15 characters)"]
    - [ti_qn,           Decimal.to_integral.__qualname__.__eq__,  ["Decimal.to_integral"],  true, "Decimal.to_integral.__qualname__ == 'Decimal.to_integral'"]
    - [ti_qn_len,       Decimal.to_integral.__qualname__.__len__, [],                       19,   "Decimal.to_integral.__qualname__.__len__() == 19 ('Decimal.to_integral' has 19 characters; longest method qualname in this table)"]
    - [norm_qn,         Decimal.normalize.__qualname__.__eq__,    ["Decimal.normalize"],    true, "Decimal.normalize.__qualname__ == 'Decimal.normalize'"]
    - [norm_qn_len,     Decimal.normalize.__qualname__.__len__,   [],                       17,   "Decimal.normalize.__qualname__.__len__() == 17 ('Decimal.normalize' has 17 characters)"]
    - [add_qn,          Decimal.__add__.__qualname__.__eq__,      ["Decimal.__add__"],      true, "Decimal.__add__.__qualname__ == 'Decimal.__add__'"]
    - [add_qn_len,      Decimal.__add__.__qualname__.__len__,     [],                       15,   "Decimal.__add__.__qualname__.__len__() == 15 ('Decimal.__add__' has 15 characters)"]

# ---------------------------------------------------------------------------
# decimal.ROUND_* rounding mode constant string lengths
# The ROUND_* constants are plain Python strings (type str).
# Their values equal their names (e.g., ROUND_UP == 'ROUND_UP').
# This table captures the exact length of each constant string.
# ---------------------------------------------------------------------------

table decimal_extra96.ROUND_constants_lengths:
  description: "decimal.ROUND_* rounding mode constants are plain strings whose lengths encode the character count of each constant name: ROUND_UP=8, ROUND_DOWN=10, ROUND_HALF_UP=13, ROUND_HALF_DOWN=15, ROUND_HALF_EVEN=15, ROUND_CEILING=13, ROUND_FLOOR=11, ROUND_05UP=10"
  kind: python_call_eq
  category: constant_lengths
  id_prefix: decmethcls96

  columns: [id, function, args, expected, description]
  rows:
    - [round_up_len,        ROUND_UP.__len__,        [], 8,  "decimal.ROUND_UP.__len__() == 8 ('ROUND_UP' has 8 characters)"]
    - [round_down_len,      ROUND_DOWN.__len__,      [], 10, "decimal.ROUND_DOWN.__len__() == 10 ('ROUND_DOWN' has 10 characters)"]
    - [round_half_up_len,   ROUND_HALF_UP.__len__,   [], 13, "decimal.ROUND_HALF_UP.__len__() == 13 ('ROUND_HALF_UP' has 13 characters)"]
    - [round_half_down_len, ROUND_HALF_DOWN.__len__, [], 15, "decimal.ROUND_HALF_DOWN.__len__() == 15 ('ROUND_HALF_DOWN' has 15 characters)"]
    - [round_half_even_len, ROUND_HALF_EVEN.__len__, [], 15, "decimal.ROUND_HALF_EVEN.__len__() == 15 ('ROUND_HALF_EVEN' has 15 characters; same as ROUND_HALF_DOWN)"]
    - [round_ceiling_len,   ROUND_CEILING.__len__,   [], 13, "decimal.ROUND_CEILING.__len__() == 13 ('ROUND_CEILING' has 13 characters; same as ROUND_HALF_UP)"]
    - [round_floor_len,     ROUND_FLOOR.__len__,     [], 11, "decimal.ROUND_FLOOR.__len__() == 11 ('ROUND_FLOOR' has 11 characters)"]
    - [round_05up_len,      ROUND_05UP.__len__,      [], 10, "decimal.ROUND_05UP.__len__() == 10 ('ROUND_05UP' has 10 characters; same as ROUND_DOWN)"]
    - [round_up_val,        ROUND_UP.__eq__,         ["ROUND_UP"],   true,  "decimal.ROUND_UP == 'ROUND_UP' (the constant's value is its own name as a string)"]
    - [round_down_val,      ROUND_DOWN.__eq__,       ["ROUND_DOWN"], true,  "decimal.ROUND_DOWN == 'ROUND_DOWN'"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra96.Decimal.quantize_is_method_descriptor:
  description: "decimal.Decimal.quantize.__class__.__name__ == 'method_descriptor' (Decimal is a C extension type; its arithmetic methods are C-level method_descriptors, not Python functions)"
  category: method_class_names
  kind: python_call_eq
  function: Decimal.quantize.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant decimal_extra96.Decimal.__add__is_wrapper_descriptor:
  description: "decimal.Decimal.__add__.__class__.__name__ == 'wrapper_descriptor' (the dunder arithmetic operators are C numeric protocol slot wrappers, distinct from regular method_descriptors)"
  category: method_class_names
  kind: python_call_eq
  function: Decimal.__add__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra96.Decimal.to_integral_qualname_len:
  description: "decimal.Decimal.to_integral.__qualname__.__len__() == 19 ('Decimal.to_integral' is 19 characters, making it the longest method qualname among the Decimal arithmetic methods covered in this spec)"
  category: method_qualnames
  kind: python_call_eq
  function: Decimal.to_integral.__qualname__.__len__
  args: []
  expected: 19

invariant decimal_extra96.ROUND_HALF_DOWN_len:
  description: "decimal.ROUND_HALF_DOWN.__len__() == 15 ('ROUND_HALF_DOWN' and 'ROUND_HALF_EVEN' both have 15 characters; they are the longest ROUND_* constant names)"
  category: constant_lengths
  kind: python_call_eq
  function: ROUND_HALF_DOWN.__len__
  args: []
  expected: 15

invariant decimal_extra96.ROUND_UP_value_eq_name:
  description: "decimal.ROUND_UP == 'ROUND_UP' (all decimal rounding mode constants are plain strings whose value equals their own name, making them self-documenting)"
  category: constant_values
  kind: python_call_eq
  function: ROUND_UP.__eq__
  args: ["ROUND_UP"]
  expected: true
