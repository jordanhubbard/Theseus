spec: traceback_extra7
version: ">=3.9"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/traceback.html — Python traceback documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
  notes:
    - "This spec extends traceback.zspec.zsdl through traceback_extra6.zspec.zsdl."
    - "Prior specs cover: function __name__ (traceback + traceback_extra4), class __name__/__module__ (traceback_extra4), function __module__ (traceback_extra3), class __qualname__ (traceback_extra5), function __qualname__ for print_exc/format_exc/format_tb/print_tb/extract_tb/extract_stack/format_stack (traceback_extra5), function __qualname__ for format_exception/print_exception/print_stack/walk_tb/walk_stack/clear_frames/format_exception_only/format_list/print_list (traceback_extra6), class __bases__ for StackSummary/FrameSummary/TracebackException (traceback_extra2/traceback_extra4/traceback_extra6)."
    - "This spec adds new axes: __module__ for format_exception/print_exception/walk_tb/walk_stack/clear_frames/format_exception_only/print_list/print_stack/format_list (all == 'traceback')."
    - "This spec adds StackSummary.from_list.__func__.__qualname__ == 'StackSummary.from_list'."
    - "This spec adds traceback.__spec__.name == 'traceback'."
    - "This spec adds traceback.__file__.__class__.__name__ == 'str' (traceback is a regular source module, not frozen)."
    - "All module-level functions in traceback are defined in traceback.py; their __module__ == 'traceback'."
    - "StackSummary.from_list is a classmethod; its __func__.__qualname__ is 'StackSummary.from_list'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ checks — functions whose __module__ was not yet verified
#
# All traceback module-level functions are defined in traceback.py; each
# has __module__ == 'traceback'.  Prior specs covered __name__/__qualname__
# for all these functions but did not check __module__ for this set.
# ---------------------------------------------------------------------------

table traceback_extra7.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [format_exception,      format_exception.__module__.__eq__,      ["traceback"], true]
    - [print_exception,       print_exception.__module__.__eq__,       ["traceback"], true]
    - [walk_tb,               walk_tb.__module__.__eq__,               ["traceback"], true]
    - [walk_stack,            walk_stack.__module__.__eq__,            ["traceback"], true]
    - [clear_frames,          clear_frames.__module__.__eq__,          ["traceback"], true]
    - [format_exception_only, format_exception_only.__module__.__eq__,  ["traceback"], true]
    - [print_list,            print_list.__module__.__eq__,            ["traceback"], true]
    - [print_stack,           print_stack.__module__.__eq__,           ["traceback"], true]
    - [format_list,           format_list.__module__.__eq__,           ["traceback"], true]

# ---------------------------------------------------------------------------
# StackSummary.from_list — __func__.__qualname__
#
# from_list is a classmethod on StackSummary.  Its underlying function's
# __qualname__ is 'StackSummary.from_list', reflecting its enclosing class.
# Prior specs checked __func__.__name__; this adds __func__.__qualname__.
# ---------------------------------------------------------------------------

invariant traceback_extra7.StackSummary.from_list_qualname:
  description: "traceback.StackSummary.from_list.__func__.__qualname__ == 'StackSummary.from_list'"
  category: StackSummary
  kind: python_call_eq
  function: StackSummary.from_list.__func__.__qualname__.__eq__
  args: ["StackSummary.from_list"]
  expected: true

# ---------------------------------------------------------------------------
# traceback module-level metadata
# traceback.__spec__.name records the canonical import name.
# traceback.__file__ is a str path ending in .py (source module, not frozen).
# ---------------------------------------------------------------------------

invariant traceback_extra7.spec_name:
  description: "traceback.__spec__.name == 'traceback'"
  category: module_attrs
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["traceback"]
  expected: true

invariant traceback_extra7.file_is_str:
  description: "traceback.__file__.__class__.__name__ == 'str'"
  category: module_attrs
  kind: python_call_eq
  function: __file__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
