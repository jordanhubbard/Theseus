spec: struct_extra1336
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "Wave 536 (_extra1336): focuses on __hash__ and __eq__ method class checks for struct types."
    - "struct.Struct is a C extension type; it does not define its own __hash__ or __eq__."
    - "Struct.__hash__.__class__.__name__ == 'wrapper_descriptor' — inherited from object at the C level."
    - "Struct.__hash__.__qualname__ == 'object.__hash__' — no override in the Struct C type."
    - "Struct.__eq__.__class__.__name__ == 'wrapper_descriptor' — also inherited from object."
    - "Struct.__eq__.__qualname__ == 'object.__eq__' — no custom equality defined in the Struct C type."
    - "struct.error is a Python exception class derived from Exception; both __hash__ and __eq__ are wrapper_descriptors."
    - "error.__hash__.__qualname__ == 'object.__hash__' — inherits from object, not BaseException."
    - "error.__eq__.__qualname__ == 'object.__eq__' — exception classes inherit object's __eq__ by default."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table struct_extra1336.Struct_hash_eq_descriptor_checks:
  description: "struct.Struct C extension type __hash__ and __eq__ inherited from object as wrapper_descriptors: class name and qualname"
  kind: python_call_eq
  category: hash_eq_class_checks
  id_prefix: st1336sh
  columns: [id, function, args, expected]
  rows:
    - [st1336sh001, struct.Struct.__hash__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [st1336sh002, struct.Struct.__hash__.__qualname__.__eq__,       ["object.__hash__"],    true]
    - [st1336sh003, struct.Struct.__eq__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true]
    - [st1336sh004, struct.Struct.__eq__.__qualname__.__eq__,         ["object.__eq__"],      true]
    - [st1336sh005, struct.Struct.__hash__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [st1336sh006, struct.Struct.__eq__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true]

table struct_extra1336.error_hash_eq_inheritance:
  description: "struct.error exception class __hash__ and __eq__ inherited from object: wrapper_descriptor checks and qualnames"
  kind: python_call_eq
  category: hash_eq_class_checks
  id_prefix: st1336eh
  columns: [id, function, args, expected]
  rows:
    - [st1336eh001, struct.error.__hash__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [st1336eh002, struct.error.__hash__.__qualname__.__eq__,       ["object.__hash__"],    true]
    - [st1336eh003, struct.error.__eq__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true]
    - [st1336eh004, struct.error.__eq__.__qualname__.__eq__,         ["object.__eq__"],      true]
    - [st1336eh005, struct.error.__hash__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [st1336eh006, struct.error.__eq__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true]

table struct_extra1336.Struct_error_hash_eq_qualname_parity:
  description: "struct.Struct and struct.error share the same __hash__ and __eq__ qualnames, both inheriting from object"
  kind: python_call_eq
  category: hash_eq_class_checks
  id_prefix: st1336pq
  columns: [id, function, args, expected]
  rows:
    - [st1336pq001, struct.Struct.__hash__.__qualname__.__eq__,  ["object.__hash__"],    true]
    - [st1336pq002, struct.error.__hash__.__qualname__.__eq__,   ["object.__hash__"],    true]
    - [st1336pq003, struct.Struct.__eq__.__qualname__.__eq__,    ["object.__eq__"],      true]
    - [st1336pq004, struct.error.__eq__.__qualname__.__eq__,     ["object.__eq__"],      true]
    - [st1336pq005, struct.Struct.__hash__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [st1336pq006, struct.error.__hash__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
