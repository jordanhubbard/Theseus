    - [brokenexec_qualname,   BrokenExecutor.__qualname__.__eq__,   ["BrokenExecutor"],    true, "BrokenExecutor.__qualname__ == 'BrokenExecutor' — BrokenExecutor is a top-level class in concurrent.futures._base; its qualified name is simply 'BrokenExecutor'; __qualname__.__eq__('BrokenExecutor') returns True; NEW in extra66: first __qualname__.__eq__ check for BrokenExecutor in the cfid66 namespace; verified with Python 3.14.3"]
    - [cancelled_qualname,    CancelledError.__qualname__.__eq__,   ["CancelledError"],    true, "CancelledError.__qualname__ == 'CancelledError' — CancelledError is a top-level class in concurrent.futures._base; its qualified name is simply 'CancelledError'; __qualname__.__eq__('CancelledError') returns True; NEW in extra66: first __qualname__.__eq__ check for CancelledError in the cfid66 namespace; verified with Python 3.14.3"]

