spec: inspect_extra227
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers inspect behavioral output contracts: is* predicate functions return False for integer 42 (not a function/builtin/module/class/routine); CO_* flag constants equal their documented integer values; is* function qualnames match their unqualified names."
    - "inspect.isfunction(42) == False — 42 is an integer, not a Python function defined with def; isfunction returns False. Verified with Python 3.14.3."
    - "inspect.isbuiltin(42) == False — 42 is not a built-in function or bound built-in method; isbuiltin returns False. Verified with Python 3.14.3."
    - "inspect.isclass(42) == False — 42 is an integer instance, not a class; isclass returns False. Verified with Python 3.14.3."
    - "inspect.ismodule(42) == False — 42 is not a module object; ismodule returns False. Verified with Python 3.14.3."
    - "inspect.isroutine(42) == False — 42 is not callable in the sense of being a function, method, or builtin; isroutine returns False. Verified with Python 3.14.3."
    - "inspect.isfunction(None) == False — None is the NoneType singleton, not a function; isfunction returns False. Verified with Python 3.14.3."
    - "inspect.ismodule(None) == False — None is not a module; ismodule returns False. Verified with Python 3.14.3."
    - "inspect.CO_OPTIMIZED == 1 — CO_OPTIMIZED is the flag bit 0x01 for optimized bytecode. Verified with Python 3.14.3."
    - "inspect.CO_NEWLOCALS == 2 — CO_NEWLOCALS is the flag bit 0x02. Verified with Python 3.14.3."
    - "inspect.CO_VARARGS == 4 — CO_VARARGS is the flag bit 0x04. Verified with Python 3.14.3."
    - "inspect.CO_VARKEYWORDS == 8 — CO_VARKEYWORDS is the flag bit 0x08. Verified with Python 3.14.3."
    - "inspect.CO_NESTED == 16 — CO_NESTED is the flag bit 0x10. Verified with Python 3.14.3."
    - "inspect.CO_GENERATOR == 32 — CO_GENERATOR is the flag bit 0x20. Verified with Python 3.14.3."
    - "inspect.CO_NOFREE == 64 — CO_NOFREE is the flag bit 0x40. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect is* predicate functions return False for integer 42
#
# inspect.isfunction(42) == False
# inspect.isbuiltin(42) == False
# inspect.isclass(42) == False
# inspect.ismodule(42) == False
# inspect.isroutine(42) == False
#
# Integer 42 is a plain Python int: not a function, builtin, class, module, or
# routine. All five is* predicates must return False. New to extra227.
# ---------------------------------------------------------------------------

table inspect_extra227.is_predicates_false_for_int:
  description: "inspect is* predicates all return False for integer 42; new to extra227"
  kind: python_call_eq
  category: behavioral
  id_prefix: inspectextra227isint

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_42_false,
       isfunction,
       [42],
       false,
       "inspect.isfunction(42) == False — 42 is an integer instance, not a Python function object created with def; isfunction checks isinstance(object, types.FunctionType); int is not FunctionType; isfunction(42) returns False; new to extra227"]
    - [isbuiltin_42_false,
       isbuiltin,
       [42],
       false,
       "inspect.isbuiltin(42) == False — 42 is an integer, not a built-in function or bound built-in method; isbuiltin checks isinstance(object, types.BuiltinFunctionType); int is not BuiltinFunctionType; isbuiltin(42) returns False; new to extra227"]
    - [isclass_42_false,
       isclass,
       [42],
       false,
       "inspect.isclass(42) == False — 42 is an instance of int, not a class itself; isclass checks isinstance(object, type); 42 is not a type; isclass(42) returns False; new to extra227"]
    - [ismodule_42_false,
       ismodule,
       [42],
       false,
       "inspect.ismodule(42) == False — 42 is an integer, not a module object; ismodule checks isinstance(object, types.ModuleType); int is not ModuleType; ismodule(42) returns False; new to extra227"]
    - [isroutine_42_false,
       isroutine,
       [42],
       false,
       "inspect.isroutine(42) == False — 42 is an integer, not callable as a routine; isroutine returns True only for functions, methods, lambdas, builtins, and classes; 42 is none of these; isroutine(42) returns False; new to extra227"]

# ---------------------------------------------------------------------------
# Table 2: inspect is* predicate functions return False for None
#
# inspect.isfunction(None) == False
# inspect.isbuiltin(None) == False
# inspect.isclass(None) == False
# inspect.ismodule(None) == False
# inspect.isroutine(None) == False
#
# None is the NoneType singleton: not a function, builtin, class, module, or
# routine. New to extra227.
# ---------------------------------------------------------------------------

table inspect_extra227.is_predicates_false_for_none:
  description: "inspect is* predicates all return False for None; new to extra227"
  kind: python_call_eq
  category: behavioral
  id_prefix: inspectextra227isnone

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_none_false,
       isfunction,
       [null],
       false,
       "inspect.isfunction(None) == False — None is the NoneType singleton, not a Python function; isinstance(None, types.FunctionType) is False; isfunction(None) returns False; new to extra227"]
    - [isbuiltin_none_false,
       isbuiltin,
       [null],
       false,
       "inspect.isbuiltin(None) == False — None is not a built-in function; isinstance(None, types.BuiltinFunctionType) is False; isbuiltin(None) returns False; new to extra227"]
    - [isclass_none_false,
       isclass,
       [null],
       false,
       "inspect.isclass(None) == False — None is the NoneType singleton (an instance), not a class; isinstance(None, type) is False; isclass(None) returns False; new to extra227"]
    - [ismodule_none_false,
       ismodule,
       [null],
       false,
       "inspect.ismodule(None) == False — None is not a module object; isinstance(None, types.ModuleType) is False; ismodule(None) returns False; new to extra227"]
    - [isroutine_none_false,
       isroutine,
       [null],
       false,
       "inspect.isroutine(None) == False — None is not callable as a routine; isroutine checks for function/method/lambda/builtin/class; None is none of these; isroutine(None) returns False; new to extra227"]

# ---------------------------------------------------------------------------
# Table 3: inspect CO_* flag constants
#
# inspect.CO_OPTIMIZED == 1
# inspect.CO_NEWLOCALS == 2
# inspect.CO_VARARGS == 4
# inspect.CO_VARKEYWORDS == 8
# inspect.CO_NESTED == 16
# inspect.CO_GENERATOR == 32
# inspect.CO_NOFREE == 64
#
# These are the documented bytecode flag constants re-exported by inspect.
# New to extra227.
# ---------------------------------------------------------------------------

table inspect_extra227.co_flag_constants:
  description: "inspect CO_OPTIMIZED=1, CO_NEWLOCALS=2, CO_VARARGS=4, CO_VARKEYWORDS=8, CO_NESTED=16, CO_GENERATOR=32, CO_NOFREE=64; new to extra227"
  kind: python_call_eq
  category: behavioral
  id_prefix: inspectextra227coflag

  columns: [id, function, args, expected, description]
  rows:
    - [co_optimized_eq_1,
       CO_OPTIMIZED.__eq__,
       [1],
       true,
       "inspect.CO_OPTIMIZED == 1 — CO_OPTIMIZED is flag bit 0x01 indicating the code object uses fast locals; its integer value is 1; CO_OPTIMIZED.__eq__(1) returns True; new to extra227"]
    - [co_newlocals_eq_2,
       CO_NEWLOCALS.__eq__,
       [2],
       true,
       "inspect.CO_NEWLOCALS == 2 — CO_NEWLOCALS is flag bit 0x02 indicating a new dict is created for locals at function call; its integer value is 2; CO_NEWLOCALS.__eq__(2) returns True; new to extra227"]
    - [co_varargs_eq_4,
       CO_VARARGS.__eq__,
       [4],
       true,
       "inspect.CO_VARARGS == 4 — CO_VARARGS is flag bit 0x04 indicating the code object takes *args; its integer value is 4; CO_VARARGS.__eq__(4) returns True; new to extra227"]
    - [co_varkeywords_eq_8,
       CO_VARKEYWORDS.__eq__,
       [8],
       true,
       "inspect.CO_VARKEYWORDS == 8 — CO_VARKEYWORDS is flag bit 0x08 indicating the code object takes **kwargs; its integer value is 8; CO_VARKEYWORDS.__eq__(8) returns True; new to extra227"]
    - [co_nested_eq_16,
       CO_NESTED.__eq__,
       [16],
       true,
       "inspect.CO_NESTED == 16 — CO_NESTED is flag bit 0x10 indicating the function is a nested function; its integer value is 16; CO_NESTED.__eq__(16) returns True; new to extra227"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra227
# ---------------------------------------------------------------------------

invariant inspect_extra227.isfunction_42_false:
  description: "inspect.isfunction(42) == False — integer 42 is not a function; new to extra227"
  kind: python_call_eq
  function: isfunction
  args: [42]
  expected: false

invariant inspect_extra227.isbuiltin_42_false:
  description: "inspect.isbuiltin(42) == False — integer 42 is not a builtin function; new to extra227"
  kind: python_call_eq
  function: isbuiltin
  args: [42]
  expected: false

invariant inspect_extra227.isclass_42_false:
  description: "inspect.isclass(42) == False — integer 42 is not a class; new to extra227"
  kind: python_call_eq
  function: isclass
  args: [42]
  expected: false

invariant inspect_extra227.ismodule_42_false:
  description: "inspect.ismodule(42) == False — integer 42 is not a module; new to extra227"
  kind: python_call_eq
  function: ismodule
  args: [42]
  expected: false

invariant inspect_extra227.isroutine_42_false:
  description: "inspect.isroutine(42) == False — integer 42 is not a routine; new to extra227"
  kind: python_call_eq
  function: isroutine
  args: [42]
  expected: false

invariant inspect_extra227.isfunction_none_false:
  description: "inspect.isfunction(None) == False — None is not a function; new to extra227"
  kind: python_call_eq
  function: isfunction
  args: [null]
  expected: false

invariant inspect_extra227.isbuiltin_none_false:
  description: "inspect.isbuiltin(None) == False — None is not a builtin; new to extra227"
  kind: python_call_eq
  function: isbuiltin
  args: [null]
  expected: false

invariant inspect_extra227.isclass_none_false:
  description: "inspect.isclass(None) == False — None is not a class; new to extra227"
  kind: python_call_eq
  function: isclass
  args: [null]
  expected: false

invariant inspect_extra227.ismodule_none_false:
  description: "inspect.ismodule(None) == False — None is not a module; new to extra227"
  kind: python_call_eq
  function: ismodule
  args: [null]
  expected: false

invariant inspect_extra227.isroutine_none_false:
  description: "inspect.isroutine(None) == False — None is not a routine; new to extra227"
  kind: python_call_eq
  function: isroutine
  args: [null]
  expected: false

invariant inspect_extra227.co_optimized_eq_1:
  description: "inspect.CO_OPTIMIZED == 1 — CO_OPTIMIZED flag bit is 1; new to extra227"
  kind: python_call_eq
  function: CO_OPTIMIZED.__eq__
  args: [1]
  expected: true

invariant inspect_extra227.co_newlocals_eq_2:
  description: "inspect.CO_NEWLOCALS == 2 — CO_NEWLOCALS flag bit is 2; new to extra227"
  kind: python_call_eq
  function: CO_NEWLOCALS.__eq__
  args: [2]
  expected: true

invariant inspect_extra227.co_varargs_eq_4:
  description: "inspect.CO_VARARGS == 4 — CO_VARARGS flag bit is 4; new to extra227"
  kind: python_call_eq
  function: CO_VARARGS.__eq__
  args: [4]
  expected: true

invariant inspect_extra227.co_varkeywords_eq_8:
  description: "inspect.CO_VARKEYWORDS == 8 — CO_VARKEYWORDS flag bit is 8; new to extra227"
  kind: python_call_eq
  function: CO_VARKEYWORDS.__eq__
  args: [8]
  expected: true

invariant inspect_extra227.co_nested_eq_16:
  description: "inspect.CO_NESTED == 16 — CO_NESTED flag bit is 16; new to extra227"
  kind: python_call_eq
  function: CO_NESTED.__eq__
  args: [16]
  expected: true

invariant inspect_extra227.co_generator_eq_32:
  description: "inspect.CO_GENERATOR == 32 — CO_GENERATOR flag bit is 32; new to extra227"
  kind: python_call_eq
  function: CO_GENERATOR.__eq__
  args: [32]
  expected: true

invariant inspect_extra227.co_nofree_eq_64:
  description: "inspect.CO_NOFREE == 64 — CO_NOFREE flag bit is 64; new to extra227"
  kind: python_call_eq
  function: CO_NOFREE.__eq__
  args: [64]
  expected: true
