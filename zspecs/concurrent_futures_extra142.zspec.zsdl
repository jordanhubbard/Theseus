    - [cld_argc,     concurrent.futures.Future.cancelled.__code__.co_argcount.__eq__, [1],              true,  "concurrent.futures.Future.cancelled.__code__.co_argcount == 1 ('self' only); verified with Python 3.14.3"]
    - [don_qn_eq,    concurrent.futures.Future.done.__qualname__.__eq__,        ["Future.done"],       true,  "concurrent.futures.Future.done.__qualname__ == 'Future.done' (len=11); verified with Python 3.14.3"]
    - [don_qn_len,   concurrent.futures.Future.done.__qualname__.__len__,        [],                    11,    "concurrent.futures.Future.done.__qualname__.__len__() == 11; verified with Python 3.14.3"]
