    - [exc_qn_eq,    concurrent.futures.Future.exception.__qualname__.__eq__,           ["Future.exception"],         true,  "concurrent.futures.Future.exception.__qualname__ == 'Future.exception' (len=16); verified with Python 3.14.3"]
