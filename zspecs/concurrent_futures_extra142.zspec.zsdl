    - [adc_qn_eq,    concurrent.futures.Future.add_done_callback.__qualname__.__eq__,   ["Future.add_done_callback"], true,  "concurrent.futures.Future.add_done_callback.__qualname__ == 'Future.add_done_callback' (len=24); verified with Python 3.14.3"]
