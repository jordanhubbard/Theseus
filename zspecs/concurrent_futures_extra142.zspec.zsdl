spec: concurrent_futures_extra142
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "https://docs.python.org/3/library/concurrent.futures.html#concurrent.futures.Future — Future documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: concurrent.futures.Future.result — __qualname__=='Future.result' (len=13); __module__=='concurrent.futures._base' (len=24); __doc__.__len__()==490; co_argcount==2 ('self','timeout'); co_varnames.__len__()==2. concurrent.futures.Future.exception — __qualname__=='Future.exception' (len=16); __doc__.__len__()==501; co_argcount==2; co_varnames.__len__()==2. concurrent.futures.Future.add_done_callback — __qualname__=='Future.add_done_callback' (len=24); __doc__.__len__()==485; co_argcount==2 ('self','fn'); co_varnames.__len__()==2. concurrent.futures.Future.cancel — __qualname__=='Future.cancel' (len=13); __doc__.__len__()==163; co_argcount==1. concurrent.futures.Future.cancelled — __qualname__=='Future.cancelled' (len=16); __doc__.__len__()==40; co_argcount==1. concurrent.futures.Future.done — __qualname__=='Future.done' (len=11); __doc__.__len__()==62; co_argcount==1. concurrent.futures.Future.running — __qualname__=='Future.running' (len=14); __doc__.__len__()==49; co_argcount==1. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All seven Future methods share __module__=='concurrent.futures._base' (len=24). Future.result and Future.cancel both have qualname len==13 (the shortest). Future.exception and Future.cancelled both have qualname len==16. Future.add_done_callback has the longest qualname (len=24) and the longest doc (501 chars) among the single-arg methods. Future.result has doc len==490 and Future.exception has doc len==501 (just 11 chars more). Future.cancelled has the shortest doc at 40 chars. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Future.result, exception, add_done_callback — extra142
#
# Future.result.__qualname__              == 'Future.result'           (len=13)
# Future.result.__module__                == 'concurrent.futures._base' (len=24)
# Future.result.__doc__.__len__()         == 490
# Future.result co_argcount               == 2
# Future.exception.__qualname__           == 'Future.exception'        (len=16)
# Future.exception.__doc__.__len__()      == 501
# Future.exception co_argcount            == 2
# Future.add_done_callback.__qualname__   == 'Future.add_done_callback' (len=24)
# Future.add_done_callback.__doc__.__len__() == 485
# Future.add_done_callback co_argcount    == 2
# ---------------------------------------------------------------------------

table concurrent_futures_extra142.future_result_exception_callback:
  description: "concurrent.futures.Future.result, exception, and add_done_callback qualname, doc, and code checks — result.__qualname__.__eq__('Future.result')==True (len=13: 'Future'=6+'.'=1+'result'=6=13; tied with cancel for shortest method qualname in this spec); result.__module__.__eq__('concurrent.futures._base')==True (len=24: all Future methods share this internal _base module); result.__doc__.__len__()==490 (multi-paragraph doc beginning 'Return the result of the call that the future represents.' and describing timeout and exception behaviour); result.__code__.co_argcount.__eq__(2)==True ('self','timeout'); result.__code__.co_varnames.__len__()==2; exception.__qualname__.__eq__('Future.exception')==True (len=16: 'Future'=6+'.'=1+'exception'=9=16; tied with cancelled for second-longest in this spec after add_done_callback); exception.__doc__.__len__()==501 (just 11 more than result.__doc__.__len__()==490; doc describes returning the exception or None); exception.__code__.co_argcount.__eq__(2)==True ('self','timeout'); add_done_callback.__qualname__.__eq__('Future.add_done_callback')==True (len=24: 'Future'=6+'.'=1+'add_done_callback'=17=24, the longest method qualname in this spec); add_done_callback.__doc__.__len__()==485 (doc beginning 'Add a callback to be invoked when the future finishes.'); add_done_callback.__code__.co_argcount.__eq__(2)==True ('self','fn'); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffuture_rec142

  columns: [id, function, args, expected, description]
  rows:
    - [res_qn_eq,    concurrent.futures.Future.result.__qualname__.__eq__,              ["Future.result"],           true,  "concurrent.futures.Future.result.__qualname__ == 'Future.result' (len=13); verified with Python 3.14.3"]
    - [res_qn_len,   concurrent.futures.Future.result.__qualname__.__len__,              [],                          13,    "concurrent.futures.Future.result.__qualname__.__len__() == 13; verified with Python 3.14.3"]
    - [res_mod_eq,   concurrent.futures.Future.result.__module__.__eq__,               ["concurrent.futures._base"], true,  "concurrent.futures.Future.result.__module__ == 'concurrent.futures._base' (len=24); verified with Python 3.14.3"]
