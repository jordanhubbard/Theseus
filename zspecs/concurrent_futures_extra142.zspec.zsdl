# Future.done.__qualname__      == 'Future.done'      (len=11)
# Future.done.__doc__.__len__() == 62
# Future.done co_argcount       == 1
# Future.running.__qualname__   == 'Future.running'   (len=14)
# Future.running.__doc__.__len__() == 49
# Future.running co_argcount    == 1
# ---------------------------------------------------------------------------

table concurrent_futures_extra142.future_cancel_state_methods:
  description: "concurrent.futures.Future cancel, cancelled, done, and running qualname, doc, and code checks — cancel.__qualname__.__eq__('Future.cancel')==True (len=13: 'Future'=6+'.'=1+'cancel'=6=13; tied with result for shortest method qualname in this spec); cancel.__doc__.__len__()==163 (multi-sentence doc describing cancel as attempting to cancel the future, returning True if successful and False if running or already done); cancel.__code__.co_argcount.__eq__(1)==True ('self' only); cancelled.__qualname__.__eq__('Future.cancelled')==True (len=16: 'Future'=6+'.'=1+'cancelled'=9=16; tied with exception qualname); cancelled.__doc__.__len__()==40 (shortest doc in this spec: 'Return True if the future was cancelled.'); cancelled.__code__.co_argcount.__eq__(1)==True ('self' only); done.__qualname__.__eq__('Future.done')==True (len=11: 'Future'=6+'.'=1+'done'=4=11, the shortest qualname in this spec); done.__doc__.__len__()==62 (doc is 'Return True if the future was cancelled or finished executing.'); done.__code__.co_argcount.__eq__(1)==True ('self' only); running.__qualname__.__eq__('Future.running')==True (len=14: 'Future'=6+'.'=1+'running'=7=14); running.__doc__.__len__()==49 (doc is 'Return True if the future is currently executing.'); running.__code__.co_argcount.__eq__(1)==True ('self' only); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffuture_cddr142

  columns: [id, function, args, expected, description]
  rows:
    - [can_qn_eq,    concurrent.futures.Future.cancel.__qualname__.__eq__,     ["Future.cancel"],     true,  "concurrent.futures.Future.cancel.__qualname__ == 'Future.cancel' (len=13); verified with Python 3.14.3"]
    - [can_qn_len,   concurrent.futures.Future.cancel.__qualname__.__len__,     [],                    13,    "concurrent.futures.Future.cancel.__qualname__.__len__() == 13; verified with Python 3.14.3"]
    - [can_doc_len,  concurrent.futures.Future.cancel.__doc__.__len__,          [],                    163,   "concurrent.futures.Future.cancel.__doc__.__len__() == 163; verified with Python 3.14.3"]
    - [can_argc,     concurrent.futures.Future.cancel.__code__.co_argcount.__eq__, [1],                true,  "concurrent.futures.Future.cancel.__code__.co_argcount == 1 ('self' only); verified with Python 3.14.3"]
    - [cld_qn_eq,    concurrent.futures.Future.cancelled.__qualname__.__eq__,   ["Future.cancelled"],  true,  "concurrent.futures.Future.cancelled.__qualname__ == 'Future.cancelled' (len=16); verified with Python 3.14.3"]
    - [cld_qn_len,   concurrent.futures.Future.cancelled.__qualname__.__len__,   [],                    16,    "concurrent.futures.Future.cancelled.__qualname__.__len__() == 16; verified with Python 3.14.3"]
