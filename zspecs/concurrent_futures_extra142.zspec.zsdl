invariant concurrent_futures_extra142.future_result_doc_len_490:
  description: "concurrent.futures.Future.result.__doc__.__len__() == 490 — concurrent.futures.Future.result.__doc__ is a 490-char multi-paragraph doc beginning 'Return the result of the call that the future represents.' and describing the timeout parameter and CancelledError/exception behaviour; result.__qualname__=='Future.result' (len=13); result.__module__=='concurrent.futures._base' (len=24); result co_argcount==2 ('self','timeout'); compare exception.__doc__.__len__()==501 (just 11 chars longer); NEW in extra142: first standalone Future.result doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.result.__doc__.__len__
  args: []
  expected: 490

invariant concurrent_futures_extra142.future_exception_doc_len_501:
  description: "concurrent.futures.Future.exception.__doc__.__len__() == 501 — concurrent.futures.Future.exception.__doc__ is a 501-char doc describing returning the exception raised by the call or None if no exception; exception.__qualname__=='Future.exception' (len=16); exception.__module__=='concurrent.futures._base' (len=24); exception co_argcount==2 ('self','timeout'); this is 11 chars longer than result.__doc__.__len__()==490; NEW in extra142: first standalone Future.exception doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.exception.__doc__.__len__
  args: []
  expected: 501

invariant concurrent_futures_extra142.future_add_done_callback_qualname_len_24:
  description: "concurrent.futures.Future.add_done_callback.__qualname__.__len__() == 24 — concurrent.futures.Future.add_done_callback.__qualname__ is 'Future.add_done_callback' (24 chars: 'Future'=6+'.'=1+'add_done_callback'=17=24); this is the longest method qualname in this spec (compare: exception=cancelled=16, running=14, result=cancel=13, done=11); add_done_callback.__doc__.__len__()==485; add_done_callback co_argcount==2 ('self','fn'); NEW in extra142: first standalone Future.add_done_callback qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.add_done_callback.__qualname__.__len__
  args: []
  expected: 24

invariant concurrent_futures_extra142.future_cancelled_doc_len_40:
  description: "concurrent.futures.Future.cancelled.__doc__.__len__() == 40 — concurrent.futures.Future.cancelled.__doc__ is 'Return True if the future was cancelled.' (40 chars: the shortest doc of all Future methods in this spec; compare: running=49, done=62, cancel=163, result=490, exception=501); cancelled.__qualname__=='Future.cancelled' (len=16); cancelled co_argcount==1 ('self' only); NEW in extra142: first standalone Future.cancelled doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.cancelled.__doc__.__len__
  args: []
  expected: 40

invariant concurrent_futures_extra142.future_done_qualname_len_11:
  description: "concurrent.futures.Future.done.__qualname__.__len__() == 11 — concurrent.futures.Future.done.__qualname__ is 'Future.done' (11 chars: 'Future'=6+'.'=1+'done'=4=11; the shortest method qualname in this spec); done.__doc__.__len__()==62; done.__module__=='concurrent.futures._base' (len=24); done co_argcount==1 ('self' only); compare Future.running.__qualname__.__len__()==14, Future.result/cancel==13, Future.exception/cancelled==16, Future.add_done_callback==24; NEW in extra142: first standalone Future.done qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.done.__qualname__.__len__
  args: []
  expected: 11

invariant concurrent_futures_extra142.future_cancel_doc_len_163:
  description: "concurrent.futures.Future.cancel.__doc__.__len__() == 163 — concurrent.futures.Future.cancel.__doc__ is a 163-char multi-sentence doc describing cancel as attempting to cancel the call; if the call is currently being executed or finished running and cannot be cancelled then the method will return False, otherwise the call will be cancelled and the method will return True; cancel.__qualname__=='Future.cancel' (len=13); cancel co_argcount==1 ('self' only); NEW in extra142: first standalone Future.cancel doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.cancel.__doc__.__len__
  args: []
  expected: 163

invariant concurrent_futures_extra142.future_running_doc_len_49:
  description: "concurrent.futures.Future.running.__doc__.__len__() == 49 — concurrent.futures.Future.running.__doc__ is 'Return True if the future is currently executing.' (49 chars); running.__qualname__=='Future.running' (len=14); running.__module__=='concurrent.futures._base' (len=24); running co_argcount==1 ('self' only); running.__doc__ is longer than cancelled (40) but shorter than done (62); NEW in extra142: first standalone Future.running doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.running.__doc__.__len__
  args: []
  expected: 49
