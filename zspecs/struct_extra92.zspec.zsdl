spec: struct_extra92
version: ">=3.9"
backend: python_module(struct)
extends: struct_extra91

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra91.zspec.zsdl — covers struct.calcsize return values for b/c/H/h/i/I/q/Q/f/d/e/x/?  format codes / struct.pack/__qualname__ / struct.calcsize/__qualname__ / struct.unpack/__qualname__ / Struct.__doc__/__class__.__name__ / struct.error/__class__.__name__ (table + invariants)."
    - "struct_extra90.zspec.zsdl — covers struct module-level function __qualname__ values / Struct method __qualname__ values / Struct.__doc__ and struct.error.__doc__ class names / Struct method class name cross-checks (table + invariants)."
    - "struct_extra89.zspec.zsdl — covers Struct.__dict__ membership for core methods and dunder attrs / module-level function __module__ cross-checks (table + invariants)."
    - "struct_extra88.zspec.zsdl — covers Struct.pack/pack_into/unpack/unpack_from/iter_unpack method_descriptor class names / Struct dunder and size class names (table + invariants)."
    - "struct_extra87.zspec.zsdl — covers struct module identity cross-checks / module-level function class names / struct.Struct class identity (table + invariants)."
    - "struct_extra86.zspec.zsdl — covers struct.Struct dunder method class names / struct.error MRO chain (table + invariants)."
    - "struct_extra85.zspec.zsdl — covers struct.Struct/__class__.__name__=='type' / module-level pack/unpack/calcsize builtin_function_or_method (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra91; it does NOT duplicate invariants present in those files."
    - "Wave 259 theme: struct module function identity — pack/unpack/calcsize/pack_into/unpack_from/iter_unpack __class__.__name__ / Struct.__init__ class / Struct.pack/unpack/pack_into/unpack_from/iter_unpack __class__.__name__ / struct.error inheritance."
    - "struct.pack.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__init__.__class__.__name__ == 'wrapper_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__bases__[0].__name__ == 'Exception'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__module__ == 'struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__qualname__ == 'error'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__init__.__qualname__ == 'Struct.__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__qualname__ == 'Struct.pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__qualname__ == 'Struct.unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.Struct.__init__ is a 'wrapper_descriptor' (C-level __init__ slot), while Struct methods are 'method_descriptor'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack.__class__.__name__.__eq__('builtin_function_or_method')
# struct.unpack.__class__.__name__.__eq__('builtin_function_or_method')
# struct.calcsize.__class__.__name__.__eq__('builtin_function_or_method')
# struct.pack_into.__class__.__name__.__eq__('builtin_function_or_method')
# struct.unpack_from.__class__.__name__.__eq__('builtin_function_or_method')
# struct.iter_unpack.__class__.__name__.__eq__('builtin_function_or_method')
#
# Wave 259 theme: all six module-level struct functions are builtin_function_or_method.
#
# All six module-level struct functions (pack, unpack, calcsize, pack_into,
# unpack_from, iter_unpack) are C-extension builtins from Modules/_struct.c.
# struct_extra85 and struct_extra87 anchor some of these; this table groups
# all six together for a complete cross-check under structfnident92.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra92.struct_module_fn_class_names:
  description: "struct.pack/__class__.__name__.__eq__('builtin_function_or_method')==True / unpack/__class__.__name__.__eq__==True / calcsize/__class__.__name__.__eq__==True / pack_into/__class__.__name__.__eq__==True / unpack_from/__class__.__name__.__eq__==True / iter_unpack/__class__.__name__.__eq__==True — all six module-level struct functions are C-extension builtins (Modules/_struct.c); struct_extra85/87 first anchor some; this table groups all six together; first structfnident92 anchor for all six module-level function class names"
  kind: python_call_eq
  category: type_identity
  id_prefix: structfnident92

  columns: [id, function, args, expected]
  rows:
    - [pack_class,        pack.__class__.__name__.__eq__,        ["builtin_function_or_method"], true]
    - [unpack_class,      unpack.__class__.__name__.__eq__,      ["builtin_function_or_method"], true]
    - [calcsize_class,    calcsize.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
    - [pack_into_class,   pack_into.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [unpack_from_class, unpack_from.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [iter_unpack_class, iter_unpack.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# struct.Struct.__init__.__class__.__name__.__eq__('wrapper_descriptor')
# struct.Struct.pack.__class__.__name__.__eq__('method_descriptor')
# struct.Struct.unpack.__class__.__name__.__eq__('method_descriptor')
# struct.Struct.pack_into.__class__.__name__.__eq__('method_descriptor')
# struct.Struct.unpack_from.__class__.__name__.__eq__('method_descriptor')
# struct.Struct.iter_unpack.__class__.__name__.__eq__('method_descriptor')
#
# Wave 259 theme: Struct class method types — __init__ vs method_descriptor.
#
# struct.Struct.__init__ is a 'wrapper_descriptor' (the C-level __init__ slot).
# The five Struct instance methods (pack, unpack, pack_into, unpack_from,
# iter_unpack) are 'method_descriptor' (C extension method objects). struct_extra88
# first anchors Struct methods as method_descriptor; this table groups all five
# plus __init__ together under structfnident92.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra92.struct_Struct_method_class_names:
  description: "struct.Struct.__init__/__class__.__name__.__eq__('wrapper_descriptor')==True / Struct.pack/__class__.__name__.__eq__('method_descriptor')==True / Struct.unpack/__class__.__name__.__eq__==True / Struct.pack_into/__class__.__name__.__eq__==True / Struct.unpack_from/__class__.__name__.__eq__==True / Struct.iter_unpack/__class__.__name__.__eq__==True — Struct.__init__ is a C-level wrapper_descriptor (init slot); Struct instance methods are method_descriptor; struct_extra88 first anchors method_descriptor; this table groups all together; first structfnident92 anchor for Struct.__init__ wrapper_descriptor class name"
  kind: python_call_eq
  category: type_identity
  id_prefix: structfnident92

  columns: [id, function, args, expected]
  rows:
    - [struct_init_class,        "Struct.__init__.__class__.__name__.__eq__",        ["wrapper_descriptor"], true]
    - [struct_pack_class,        "Struct.pack.__class__.__name__.__eq__",            ["method_descriptor"],  true]
    - [struct_unpack_class,      "Struct.unpack.__class__.__name__.__eq__",          ["method_descriptor"],  true]
    - [struct_pack_into_class,   "Struct.pack_into.__class__.__name__.__eq__",       ["method_descriptor"],  true]
    - [struct_unpack_from_class, "Struct.unpack_from.__class__.__name__.__eq__",     ["method_descriptor"],  true]
    - [struct_iter_unpack_class, "Struct.iter_unpack.__class__.__name__.__eq__",     ["method_descriptor"],  true]

# ---------------------------------------------------------------------------
# struct.error.__bases__[0].__name__.__eq__('Exception')
# struct.error.__module__.__eq__('struct')
# struct.error.__qualname__.__eq__('error')
# struct.Struct.__init__.__qualname__.__eq__('Struct.__init__')
# struct.Struct.pack.__qualname__.__eq__('Struct.pack')
# struct.Struct.unpack.__qualname__.__eq__('Struct.unpack')
#
# Wave 259 theme: struct.error inheritance + Struct method __qualname__ cross-check.
#
# struct.error inherits from Exception (not OSError or ValueError). Its __module__
# is 'struct' and __qualname__ is 'error' (lowercase, no enclosing class).
# Struct.__init__, Struct.pack, and Struct.unpack all have __qualname__ of the
# form 'Struct.<name>'. No prior struct spec anchors these six together as a
# cross-check under structfnident92. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra92.struct_error_inheritance_and_qualnames:
  description: "struct.error/__bases__[0]/__name__.__eq__('Exception')==True / error/__module__.__eq__('struct')==True / error/__qualname__.__eq__('error')==True / Struct/__init__/__qualname__.__eq__('Struct.__init__')==True / Struct/pack/__qualname__.__eq__('Struct.pack')==True / Struct/unpack/__qualname__.__eq__('Struct.unpack')==True — struct.error inherits from Exception (not OSError/ValueError); its __module__ is 'struct' and __qualname__ is 'error' (lowercase, no enclosing scope); Struct method __qualname__ values confirm class membership; no prior struct spec anchors these together; first structfnident92 anchor for error inheritance and Struct method __qualname__ cross-check"
  kind: python_call_eq
  category: type_identity
  id_prefix: structfnident92

  columns: [id, function, args, expected]
  rows:
    - [error_base_name,       "error.__bases__[0].__name__.__eq__",   ["Exception"],      true]
    - [error_module,          "error.__module__.__eq__",              ["struct"],          true]
    - [error_qualname,        "error.__qualname__.__eq__",            ["error"],           true]
    - [struct_init_qualname,  "Struct.__init__.__qualname__.__eq__",  ["Struct.__init__"], true]
    - [struct_pack_qualname,  "Struct.pack.__qualname__.__eq__",      ["Struct.pack"],     true]
    - [struct_unpack_qualname, "Struct.unpack.__qualname__.__eq__",   ["Struct.unpack"],   true]

# ---------------------------------------------------------------------------
# struct.pack.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# struct.pack.__class__.__name__ is 'builtin_function_or_method'. pack is the
# primary module-level struct function, packing values according to a format
# string into bytes. It is implemented in C (Modules/_struct.c) and is thus a
# builtin_function_or_method. No prior struct spec anchors pack.__class__.__name__
# as a standalone under structfnident92. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra92.pack_class_builtin:
  description: "struct.pack.__class__.__name__.__eq__('builtin_function_or_method') == True — pack is the primary struct packing function, implemented in C (Modules/_struct.c); it is a builtin_function_or_method; no prior struct spec anchors this as a standalone; first standalone for struct.pack __class__.__name__ under structfnident92"
  category: type_identity
  kind: python_call_eq
  function: pack.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__init__.__class__.__name__.__eq__('wrapper_descriptor') — standalone
#
# struct.Struct.__init__.__class__.__name__ is 'wrapper_descriptor'. Struct is a
# C extension type (not a Python class). Its __init__ is the C-level slot wrapper
# (a wrapper_descriptor), unlike Python classes where __init__ would be a
# 'function'. No prior struct spec anchors Struct.__init__.__class__.__name__ as
# a standalone under structfnident92. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra92.struct_init_wrapper_descriptor:
  description: "struct.Struct.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — Struct is a C extension type; its __init__ is a C-level slot wrapper (wrapper_descriptor), not a Python 'function'; no prior struct spec anchors this as a standalone; first standalone for Struct.__init__ class name under structfnident92"
  category: type_identity
  kind: python_call_eq
  function: "Struct.__init__.__class__.__name__.__eq__"
  args: ["wrapper_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__bases__[0].__name__.__eq__('Exception') — standalone
#
# struct.error.__bases__[0].__name__ is 'Exception'. struct.error is a C-level
# exception class that inherits directly from Exception (not from a more specific
# exception type like ValueError or OSError). This means catching Exception will
# catch struct.error. No prior struct spec anchors error.__bases__[0].__name__ as
# a standalone under structfnident92. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra92.error_base_exception:
  description: "struct.error.__bases__[0].__name__.__eq__('Exception') == True — struct.error is a C-level exception inheriting directly from Exception (not OSError or ValueError); catching Exception will catch struct.error; no prior struct spec anchors this as a standalone; first standalone for struct.error base class name under structfnident92"
  category: type_identity
  kind: python_call_eq
  function: "error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.pack.__qualname__.__eq__('Struct.pack') — standalone
#
# struct.Struct.pack.__qualname__ is 'Struct.pack'. Struct.pack is a C-level
# method_descriptor (not a Python function). Its __qualname__ of 'Struct.pack'
# confirms it is bound to the Struct class. struct_extra90 first anchors
# Struct.pack.__qualname__; this invariant cross-checks it as a standalone
# under structfnident92. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra92.struct_pack_qualname:
  description: "struct.Struct.pack.__qualname__.__eq__('Struct.pack') == True — Struct.pack is a C-level method_descriptor; its __qualname__ 'Struct.pack' confirms it is bound to the Struct class; struct_extra90 first anchors this; cross-checked as a standalone under structfnident92"
  category: type_identity
  kind: python_call_eq
  function: "Struct.pack.__qualname__.__eq__"
  args: ["Struct.pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.iter_unpack.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# struct.iter_unpack.__class__.__name__ is 'builtin_function_or_method'. iter_unpack
# (added in Python 3.4) is a C-extension function that returns an iterator yielding
# successive unpacked tuples from a buffer. It is implemented in Modules/_struct.c.
# No prior struct spec anchors iter_unpack.__class__.__name__ as a standalone under
# structfnident92. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra92.iter_unpack_class_builtin:
  description: "struct.iter_unpack.__class__.__name__.__eq__('builtin_function_or_method') == True — iter_unpack (Python 3.4+) is a C-extension function yielding successive unpacked tuples from a buffer; it is a builtin_function_or_method; no prior struct spec anchors this as a standalone; first standalone for iter_unpack __class__.__name__ under structfnident92"
  category: type_identity
  kind: python_call_eq
  function: iter_unpack.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
