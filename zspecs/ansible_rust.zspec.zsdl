spec: ansible_rust
version: ">=3.9"
backend: rust_module(ansible_rust)

docs: https://docs.ansible.com/ansible/latest/

provenance:
  derived_from:
    - "https://docs.ansible.com/ansible/latest/ — Ansible documentation"
  not_derived_from:
    - "ansible source: ansible/__init__.py"
  notes:
    - "Ansible is an IT automation platform."
    - "ansible.__version__ is a non-empty string."
    - "ansible.module_utils is available."
    - "int(ansible.__version__.split('.')[0]) >= 2."
    - "Expose ansible_version_nonempty() -> bool: len(ansible.__version__) > 0."
    - "Expose ansible_version_major() -> int: int(ansible.__version__.split('.')[0])."
    - "Expose ansible_has_module_utils() -> bool: hasattr(ansible, 'module_utils')."
    - "All test vectors verified against ansible 11.4.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# ansible_version_nonempty — version non-empty
invariant ansible_rust.version.nonempty:
  description: "ansible.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: ansible_version_nonempty
  args: []
  expected: true

# ansible_version_major — major version >= 2
invariant ansible_rust.version.major_ge2:
  description: "ansible major version >= 2"
  category: version
  kind: python_call_eq
  function: ansible_version_major
  args: []
  expected: 11

# ansible_has_module_utils — module_utils present
invariant ansible_rust.module.has_module_utils:
  description: "ansible.module_utils is available"
  category: module
  kind: python_call_eq
  function: ansible_has_module_utils
  args: []
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T02:14:40Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
