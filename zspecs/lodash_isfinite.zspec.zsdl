spec: lodash_isfinite
version: ">=3.3.2"
backend: node(lodash.isfinite)

docs: https://lodash.com/docs/#isFinite

provenance:
  derived_from:
    - "lodash.isfinite README — https://www.npmjs.com/package/lodash.isfinite"
    - "Test vectors verified with lodash.isfinite@3.3.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.isfinite exports the _.isFinite function directly as module.exports."
    - "isFinite checks if value is a finite primitive number."
    - "Stricter than native isFinite — does not coerce strings."
    - "JSON cannot represent Infinity or NaN, so only finite numbers and non-numbers are testable."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_isfinite.isfinite:
  kind: node_module_call_eq
  function: ~
  category: isfinite
  id_prefix: lisfi

  columns: [id, args, expected]
  rows:
    - [integer,   [42],       true]
    - [float,     [3.14],     true]
    - [zero,      [0],        true]
    - [negative,  [-1],       true]
    - [str_num,   ["1"],      false]
    - [null_val,  [null],     false]
    - [bool_val,  [true],     false]
