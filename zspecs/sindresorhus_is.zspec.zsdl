spec: sindresorhus_is
version: ">=8.0.0"
backend: node(@sindresorhus/is)

docs: https://github.com/sindresorhus/is#readme

provenance:
  derived_from:
    - "@sindresorhus/is README — https://github.com/sindresorhus/is#readme"
    - "Test vectors verified with @sindresorhus/is via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "@sindresorhus/is source"
  notes:
    - "Type-check predicates — over 70 helpers (string / number / array / blob / urlString / etc.)."
    - "Install: npm install @sindresorhus/is"
    - "v8 ESM only; default export is the 'is' object with named-property predicates."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure functions; never throw."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant sindresorhus_is.string_true:
  description: "is.string('hi') is true"
  category: predicate
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {method: string, args: ["hi"]}
  expected: true

invariant sindresorhus_is.string_false_for_number:
  description: "is.string(5) is false"
  category: predicate
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {method: string, args: [5]}
  expected: false

invariant sindresorhus_is.number_true:
  description: "is.number(5) is true"
  category: predicate
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {method: number, args: [5]}
  expected: true

invariant sindresorhus_is.array_true_for_empty:
  description: "is.array([]) is true"
  category: predicate
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {method: array, args: [[]]}
  expected: true

invariant sindresorhus_is.array_false_for_object:
  description: "is.array({}) is false"
  category: predicate
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {method: array, args: [{}]}
  expected: false

invariant sindresorhus_is.urlString_valid:
  description: "is.urlString('https://example.com') is true"
  category: predicate
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {method: urlString, args: ["https://example.com"]}
  expected: true

invariant sindresorhus_is.urlString_invalid:
  description: "is.urlString('not a url') is false"
  category: predicate
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {method: urlString, args: ["not a url"]}
  expected: false

invariant sindresorhus_is.emptyArray_true:
  description: "is.emptyArray([]) is true"
  category: predicate
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {method: emptyArray, args: [[]]}
  expected: true

invariant sindresorhus_is.emptyArray_false:
  description: "is.emptyArray([1]) is false"
  category: predicate
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {method: emptyArray, args: [[1]]}
  expected: false

invariant sindresorhus_is.boolean_true:
  description: "is.boolean(true) is true"
  category: predicate
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {method: boolean, args: [true]}
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T23:53:48Z
  iterations: 1
  pass_count: 10
  fail_count: 0
  total_invariants: 10
  notes: Synthesis succeeded in 1 iteration(s). 10 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
