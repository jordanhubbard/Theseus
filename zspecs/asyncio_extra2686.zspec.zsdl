spec: asyncio_extra2686
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio classes documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from: ["CPython source code"]
  notes: ["Checks asyncio Queue, Task, Future, Lock, Event, Semaphore, Condition, Barrier __dict__ for __and__, __or__, __xor__ presence (all false)"]
  created_at: "2026-04-13"
error_model: python_exceptions

table asyncio_extra2686.queue_task_future_dict_presence:
  description: "asyncio.Queue, asyncio.Task, asyncio.Future __dict__ does not contain __and__, __or__, __xor__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: as2686qtf
  columns: [id, function, args, expected]
  rows:
    - ["as2686qtf001", asyncio.Queue.__dict__.__contains__, ["__and__"], false]
    - ["as2686qtf002", asyncio.Queue.__dict__.__contains__, ["__or__"], false]
    - ["as2686qtf003", asyncio.Queue.__dict__.__contains__, ["__xor__"], false]
    - ["as2686qtf004", asyncio.Task.__dict__.__contains__, ["__and__"], false]
    - ["as2686qtf005", asyncio.Task.__dict__.__contains__, ["__or__"], false]
    - ["as2686qtf006", asyncio.Task.__dict__.__contains__, ["__xor__"], false]
    - ["as2686qtf007", asyncio.Future.__dict__.__contains__, ["__and__"], false]
    - ["as2686qtf008", asyncio.Future.__dict__.__contains__, ["__or__"], false]
    - ["as2686qtf009", asyncio.Future.__dict__.__contains__, ["__xor__"], false]

