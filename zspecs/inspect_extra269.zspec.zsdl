spec: inspect_extra269
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "inspect.Signature.__name__ == 'Signature' (len=9); __module__ == 'inspect' (len=7); __qualname__ == 'Signature'; __class__.__name__ == 'type'."
    - "inspect.Signature.__bases__[0].__name__ == 'object' — Signature inherits directly from object."
    - "inspect.Signature.bind.__name__ == 'bind' (len=4 — shortest method name in spec); __qualname__ == 'Signature.bind' (len=14); __class__.__name__ == 'function'."
    - "inspect.Signature.bind_partial.__name__ == 'bind_partial' (len=12); __qualname__ == 'Signature.bind_partial' (len=22 — longest qualname in spec)."
    - "inspect.Signature.replace.__name__ == 'replace' (len=7); __qualname__ == 'Signature.replace' (len=17)."
    - "inspect.Signature.parameters.fget.__name__ == 'parameters' (len=10); __qualname__ == 'Signature.parameters' (len=20)."
    - "inspect.Parameter.empty.__class__.__name__ == 'type' — empty is a class (sentinel type); __name__ == '_empty' (len=6); __module__ == 'inspect'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.Signature class identity
#
# Signature.__name__ (9) == module 'inspect'.__len__() + 2.
# Signature is a pure Python class with __class__.__name__ == 'type'.
# Signature inherits directly from object.
# ---------------------------------------------------------------------------

table inspect_extra269.signature_class_identity:
  description: "inspect.Signature(9) class identity — Signature is type in inspect(7); inherits from object; qualname(9) equals name(9); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex269s

  columns: [id, function, args, expected, description]
  rows:
    - [s_name_eq,           Signature.__name__.__eq__,                   ["Signature"],                  true, "inspect.Signature.__name__ == 'Signature'; verified with Python 3.14.3"]
    - [s_name_len,          Signature.__name__.__len__,                  [],                             9,    "inspect.Signature.__name__.__len__() == 9; verified with Python 3.14.3"]
    - [s_qn_eq,             Signature.__qualname__.__eq__,               ["Signature"],                  true, "inspect.Signature.__qualname__ == 'Signature' — qualname equals name; verified with Python 3.14.3"]
    - [s_mod_eq,            Signature.__module__.__eq__,                 ["inspect"],                    true, "inspect.Signature.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [s_mod_len,           Signature.__module__.__len__,                [],                             7,    "inspect.Signature.__module__.__len__() == 7; verified with Python 3.14.3"]
    - [s_cls_eq,            Signature.__class__.__name__.__eq__,         ["type"],                       true, "inspect.Signature.__class__.__name__ == 'type' — Signature is a regular Python class; verified with Python 3.14.3"]
    - [s_base_eq,           Signature.__bases__.__getitem__(0).__name__.__eq__, ["object"],              true, "inspect.Signature.__bases__[0].__name__ == 'object' — Signature inherits directly from object; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# inspect.Signature method identity: bind, bind_partial, replace
#
# bind.__name__ (4) is shortest method name in spec.
# bind_partial.__qualname__ (22) is longest qualname in spec.
# All three are 'function' class.
# ---------------------------------------------------------------------------

table inspect_extra269.signature_methods_identity:
  description: "inspect.Signature methods bind(4), bind_partial(12), replace(7) identity — all are function class; bind(4) shortest name; bind_partial qualname(22) longest qualname; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex269m

  columns: [id, function, args, expected, description]
  rows:
    - [bi_name_eq,          Signature.bind.__name__.__eq__,              ["bind"],                       true, "inspect.Signature.bind.__name__ == 'bind' (len=4 — shortest method name); verified with Python 3.14.3"]
    - [bi_name_len,         Signature.bind.__name__.__len__,             [],                             4,    "inspect.Signature.bind.__name__.__len__() == 4 — shortest method name in spec; verified with Python 3.14.3"]
    - [bi_qn_eq,            Signature.bind.__qualname__.__eq__,          ["Signature.bind"],             true, "inspect.Signature.bind.__qualname__ == 'Signature.bind'; verified with Python 3.14.3"]
    - [bi_qn_len,           Signature.bind.__qualname__.__len__,         [],                             14,   "inspect.Signature.bind.__qualname__.__len__() == 14; verified with Python 3.14.3"]
    - [bi_cls_eq,           Signature.bind.__class__.__name__.__eq__,    ["function"],                   true, "inspect.Signature.bind.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [bp_name_eq,          Signature.bind_partial.__name__.__eq__,      ["bind_partial"],               true, "inspect.Signature.bind_partial.__name__ == 'bind_partial'; verified with Python 3.14.3"]
    - [bp_name_len,         Signature.bind_partial.__name__.__len__,     [],                             12,   "inspect.Signature.bind_partial.__name__.__len__() == 12; verified with Python 3.14.3"]
    - [bp_qn_eq,            Signature.bind_partial.__qualname__.__eq__,  ["Signature.bind_partial"],     true, "inspect.Signature.bind_partial.__qualname__ == 'Signature.bind_partial'; verified with Python 3.14.3"]
    - [bp_qn_len,           Signature.bind_partial.__qualname__.__len__, [],                             22,   "inspect.Signature.bind_partial.__qualname__.__len__() == 22 — longest qualname in spec; verified with Python 3.14.3"]
    - [bp_cls_eq,           Signature.bind_partial.__class__.__name__.__eq__, ["function"],              true, "inspect.Signature.bind_partial.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [re_name_eq,          Signature.replace.__name__.__eq__,           ["replace"],                    true, "inspect.Signature.replace.__name__ == 'replace'; verified with Python 3.14.3"]
    - [re_name_len,         Signature.replace.__name__.__len__,          [],                             7,    "inspect.Signature.replace.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [re_qn_eq,            Signature.replace.__qualname__.__eq__,       ["Signature.replace"],          true, "inspect.Signature.replace.__qualname__ == 'Signature.replace'; verified with Python 3.14.3"]
    - [re_qn_len,           Signature.replace.__qualname__.__len__,      [],                             17,   "inspect.Signature.replace.__qualname__.__len__() == 17; verified with Python 3.14.3"]
    - [re_cls_eq,           Signature.replace.__class__.__name__.__eq__, ["function"],                   true, "inspect.Signature.replace.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [pa_fget_name_eq,     Signature.parameters.fget.__name__.__eq__,   ["parameters"],                 true, "inspect.Signature.parameters.fget.__name__ == 'parameters'; verified with Python 3.14.3"]
    - [pa_fget_name_len,    Signature.parameters.fget.__name__.__len__,  [],                             10,   "inspect.Signature.parameters.fget.__name__.__len__() == 10; verified with Python 3.14.3"]
    - [em_name_eq,          Parameter.empty.__name__.__eq__,             ["_empty"],                     true, "inspect.Parameter.empty.__name__ == '_empty' (len=6); verified with Python 3.14.3"]
    - [em_mod_eq,           Parameter.empty.__module__.__eq__,           ["inspect"],                    true, "inspect.Parameter.empty.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [em_cls_eq,           Parameter.empty.__class__.__name__.__eq__,   ["type"],                       true, "inspect.Parameter.empty.__class__.__name__ == 'type' — empty is a sentinel class (type); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — inspect_extra269
# ---------------------------------------------------------------------------

invariant inspect_extra269.signature_is_type:
  description: "inspect.Signature.__class__.__name__ == 'type' — Signature is a regular Python class; both Signature and Parameter are types in the inspect module"
  category: identity
  kind: python_call_eq
  function: Signature.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra269.signature_inherits_from_object:
  description: "inspect.Signature.__bases__[0].__name__ == 'object' — Signature inherits directly from object with a single base class"
  category: identity
  kind: python_call_eq
  function: Signature.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant inspect_extra269.bind_is_shortest_method_name:
  description: "inspect.Signature.bind.__name__.__len__() == 4 — 'bind' is the shortest method name in this spec; shorter than replace(7), bind_partial(12)"
  category: identity
  kind: python_call_eq
  function: Signature.bind.__name__.__len__
  args: []
  expected: 4

invariant inspect_extra269.bind_partial_qualname_is_longest:
  description: "inspect.Signature.bind_partial.__qualname__.__len__() == 22 — 'Signature.bind_partial' is the longest qualname in this spec"
  category: identity
  kind: python_call_eq
  function: Signature.bind_partial.__qualname__.__len__
  args: []
  expected: 22

invariant inspect_extra269.parameter_empty_is_sentinel_type:
  description: "inspect.Parameter.empty.__class__.__name__ == 'type' — Parameter.empty is a sentinel class (an instance of type), not a string or None; its __name__ is '_empty'"
  category: identity
  kind: python_call_eq
  function: Parameter.empty.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra269.parameter_empty_name_is_empty:
  description: "inspect.Parameter.empty.__name__ == '_empty' (len=6) — the sentinel class has a private name with leading underscore"
  category: identity
  kind: python_call_eq
  function: Parameter.empty.__name__.__eq__
  args: ["_empty"]
  expected: true
