spec: abc_extra347
version: ">=3.9"
backend: python_module(collections.abc)
docs: https://docs.python.org/3/library/collections.abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc ABCs documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "All ABCs in this spec live in module collections.abc"
    - "Iterator derives from Iterable"
    - "Iterable derives directly from object"
    - "Generator derives from Iterator"
    - "Awaitable derives directly from object"
    - "Coroutine derives from Awaitable"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra347.abc_names:
  description: "Verify __name__ attribute of collections.abc iterator and awaitable ABCs"
  kind: python_call_eq
  category: identity
  id_prefix: abc347n

  columns: [id, function, args, expected]
  rows:
    - [abc347n001, collections.abc.Iterator.__name__.__eq__, ["Iterator"], true]
    - [abc347n002, collections.abc.Iterable.__name__.__eq__, ["Iterable"], true]
    - [abc347n003, collections.abc.Generator.__name__.__eq__, ["Generator"], true]
    - [abc347n004, collections.abc.Awaitable.__name__.__eq__, ["Awaitable"], true]
    - [abc347n005, collections.abc.Coroutine.__name__.__eq__, ["Coroutine"], true]

table abc_extra347.abc_modules:
  description: "Verify __module__ attribute of collections.abc iterator and awaitable ABCs"
  kind: python_call_eq
  category: identity
  id_prefix: abc347m

  columns: [id, function, args, expected]
  rows:
    - [abc347m001, collections.abc.Iterator.__module__.__eq__, ["collections.abc"], true]
    - [abc347m002, collections.abc.Iterable.__module__.__eq__, ["collections.abc"], true]
    - [abc347m003, collections.abc.Generator.__module__.__eq__, ["collections.abc"], true]
    - [abc347m004, collections.abc.Awaitable.__module__.__eq__, ["collections.abc"], true]
    - [abc347m005, collections.abc.Coroutine.__module__.__eq__, ["collections.abc"], true]

table abc_extra347.abc_bases:
  description: "Verify __bases__[0].__name__ (immediate base class name) of collections.abc ABCs"
  kind: python_call_eq
  category: identity
  id_prefix: abc347b

  columns: [id, function, args, expected]
  rows:
    - [abc347b001, "collections.abc.Iterator.__bases__[0].__name__.__eq__", ["Iterable"], true]
    - [abc347b002, "collections.abc.Iterable.__bases__[0].__name__.__eq__", ["object"], true]
    - [abc347b003, "collections.abc.Generator.__bases__[0].__name__.__eq__", ["Iterator"], true]
    - [abc347b004, "collections.abc.Awaitable.__bases__[0].__name__.__eq__", ["object"], true]
    - [abc347b005, "collections.abc.Coroutine.__bases__[0].__name__.__eq__", ["Awaitable"], true]
