spec: io_extra1561
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 551 (_extra1561): numeric type conversion protocol dict-presence checks for io classes."
    - "io.IOBase, io.BytesIO, io.StringIO, io.RawIOBase, io.BufferedIOBase, io.TextIOBase are not numeric types."
    - "None of these classes define __bool__, __int__, __float__, __complex__, __index__, __trunc__, __floor__, __ceil__, or __round__ in their own __dict__."
    - "io.BytesIO.__dict__ contains: __init__, __new__, __iter__, __next__, __sizeof__, __getstate__, __setstate__."
    - "io.StringIO.__dict__ contains: __init__, __new__, __next__, __getstate__, __setstate__."
    - "io.IOBase.__dict__ contains: __abstractmethods__, __doc__, __firstlineno__, __module__, __static_attributes__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# IOBase — numeric type conversion protocol dict-presence (all False)
# ---------------------------------------------------------------------------

table io_extra1561.iobase_numeric_protocol:
  description: "io.IOBase.__dict__ does not contain any numeric type conversion dunder"
  kind: python_call_eq
  category: numeric_presence
  id_prefix: io1561ib

  columns: [id, function, args, expected]
  rows:
    - [io1561ib001, io.IOBase.__dict__.__contains__, ["__bool__"],    false]
    - [io1561ib002, io.IOBase.__dict__.__contains__, ["__int__"],     false]
    - [io1561ib003, io.IOBase.__dict__.__contains__, ["__float__"],   false]
    - [io1561ib004, io.IOBase.__dict__.__contains__, ["__complex__"], false]
    - [io1561ib005, io.IOBase.__dict__.__contains__, ["__index__"],   false]
    - [io1561ib006, io.IOBase.__dict__.__contains__, ["__trunc__"],   false]
    - [io1561ib007, io.IOBase.__dict__.__contains__, ["__floor__"],   false]
    - [io1561ib008, io.IOBase.__dict__.__contains__, ["__ceil__"],    false]
    - [io1561ib009, io.IOBase.__dict__.__contains__, ["__round__"],   false]

