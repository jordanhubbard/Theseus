spec: calendar_extra17
version: ">=3.9"
backend: python_module(calendar)

docs: https://docs.python.org/3/library/calendar.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/calendar.html — Python calendar module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/calendar.py"
    - "calendar_extra3.zspec.zsdl — covers __qualname__ for Calendar/TextCalendar/HTMLCalendar/isleap/monthrange/weekday; isleap/__module__ and Calendar/__module__"
    - "calendar_extra7.zspec.zsdl — covers Calendar/__qualname__; isleap; leapdays; monthrange; firstweekday/__module__; timegm/__module__"
    - "calendar_extra9.zspec.zsdl — covers TextCalendar/__module__/__qualname__; HTMLCalendar/__module__/__qualname__"
    - "calendar_extra13.zspec.zsdl — covers LocaleTextCalendar/__qualname__; LocaleHTMLCalendar/__qualname__; isleap/__qualname__; month/__qualname__; calendar/__qualname__"
    - "calendar_extra14.zspec.zsdl — covers leapdays/__qualname__; timegm/__qualname__; setfirstweekday/__qualname__; firstweekday/__qualname__; monthcalendar/__qualname__; prmonth/__qualname__; prcal/__qualname__"
    - "calendar_extra15.zspec.zsdl — covers TextCalendar/HTMLCalendar/Calendar instance method __qualname__ values"
    - "calendar_extra16.zspec.zsdl — covers TextCalendar/HTMLCalendar __module__/__bases__; Calendar __qualname__/__module__/__bases__; month_name/month_abbr/day_name/day_abbr class names; MONDAY/SUNDAY class names"
  notes:
    - "This spec extends calendar_extra16.zspec.zsdl."
    - "NEW in extra17 — Axis 1: Calendar.__init__.__qualname__ and Calendar.__init__.__module__ — init method identity for the root Calendar class."
    - "NEW in extra17 — Axis 2: TextCalendar.formatmonth/__qualname__/__module__ and TextCalendar.formatyear/__qualname__/__module__ — concrete formatting method identities."
    - "NEW in extra17 — Axis 3: HTMLCalendar.formatmonth/__qualname__/__module__ — HTML-specific formatting method identity."
    - "NEW in extra17 — Axis 4: monthrange/__module__, isleap/__module__, leapdays/__module__, weekday/__module__ as standalone extra17-namespace invariants (prior coverage was in table rows, not standalone invariants)."
    - "calendar.Calendar.__init__.__qualname__ == 'Calendar.__init__' — verified Python 3.12."
    - "calendar.Calendar.__init__.__module__ == 'calendar' — verified Python 3.12."
    - "calendar.TextCalendar.__init__.__qualname__ == 'Calendar.__init__' — TextCalendar inherits __init__ from Calendar."
    - "calendar.HTMLCalendar.__init__.__qualname__ == 'Calendar.__init__' — HTMLCalendar inherits __init__ from Calendar."
    - "calendar.TextCalendar.formatmonth.__qualname__ == 'TextCalendar.formatmonth' — verified Python 3.12."
    - "calendar.TextCalendar.formatmonth.__module__ == 'calendar' — verified Python 3.12."
    - "calendar.TextCalendar.formatyear.__qualname__ == 'TextCalendar.formatyear' — verified Python 3.12."
    - "calendar.TextCalendar.formatyear.__module__ == 'calendar' — verified Python 3.12."
    - "calendar.HTMLCalendar.formatmonth.__qualname__ == 'HTMLCalendar.formatmonth' — verified Python 3.12."
    - "calendar.HTMLCalendar.formatmonth.__module__ == 'calendar' — verified Python 3.12."
    - "calendar.monthrange.__module__ == 'calendar' — verified Python 3.12."
    - "calendar.isleap.__module__ == 'calendar' — verified Python 3.12."
    - "calendar.leapdays.__module__ == 'calendar' — verified Python 3.12."
    - "calendar.weekday.__module__ == 'calendar' — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Calendar.__init__ — method identity
#
# Calendar.__init__ defines the constructor signature for all Calendar
# subclasses (TextCalendar and HTMLCalendar both inherit it). Its __qualname__
# is 'Calendar.__init__' and its __module__ is 'calendar'. No prior spec
# anchors these as standalone extra17-namespace invariants.
# ---------------------------------------------------------------------------

invariant calendar_extra17.Calendar.init.qualname:
  description: "calendar.Calendar.__init__.__qualname__ == 'Calendar.__init__' — init method defined on the root Calendar class"
  category: method_identity
  kind: python_call_eq
  function: Calendar.__init__.__qualname__.__eq__
  args: ["Calendar.__init__"]
  expected: true

invariant calendar_extra17.Calendar.init.module:
  description: "calendar.Calendar.__init__.__module__ == 'calendar' — __init__ is defined in the calendar module"
  category: method_identity
  kind: python_call_eq
  function: Calendar.__init__.__module__.__eq__
  args: ["calendar"]
  expected: true

# ---------------------------------------------------------------------------
# TextCalendar.__init__ and HTMLCalendar.__init__ — inherited __qualname__
#
# Both TextCalendar and HTMLCalendar inherit __init__ from Calendar without
# override, so their __init__.__qualname__ resolves to 'Calendar.__init__'.
# This distinguishes inherited-without-override from methods with own
# definitions. No prior calendar spec checks these attributes.
# ---------------------------------------------------------------------------

table calendar_extra17.subclass_init_qualnames:
  description: "__init__.__qualname__ for TextCalendar and HTMLCalendar — both resolve to Calendar.__init__ (inherited)"
  kind: python_call_eq
  category: method_identity
  id_prefix: siq17

  columns: [id, function, args, expected]
  rows:
    - [TextCalendar, TextCalendar.__init__.__qualname__.__eq__, ["Calendar.__init__"], true]
    - [HTMLCalendar, HTMLCalendar.__init__.__qualname__.__eq__, ["Calendar.__init__"], true]

# ---------------------------------------------------------------------------
# TextCalendar.formatmonth and TextCalendar.formatyear — method identities
#
# formatmonth and formatyear are concrete methods defined on TextCalendar.
# Their __qualname__ values are dotted ('TextCalendar.formatmonth') and their
# __module__ is 'calendar'. No prior spec checks these two attributes for
# these methods as standalone extra17-namespace invariants.
# ---------------------------------------------------------------------------

table calendar_extra17.TextCalendar_format_methods:
  description: "__qualname__ and __module__ for TextCalendar.formatmonth and TextCalendar.formatyear"
  kind: python_call_eq
  category: method_identity
  id_prefix: tcf17

  columns: [id, function, args, expected]
  rows:
    - [formatmonth_qualname, TextCalendar.formatmonth.__qualname__.__eq__, ["TextCalendar.formatmonth"], true]
    - [formatmonth_module,   TextCalendar.formatmonth.__module__.__eq__,   ["calendar"],                  true]
    - [formatyear_qualname,  TextCalendar.formatyear.__qualname__.__eq__,  ["TextCalendar.formatyear"],  true]
    - [formatyear_module,    TextCalendar.formatyear.__module__.__eq__,    ["calendar"],                  true]

# ---------------------------------------------------------------------------
# HTMLCalendar.formatmonth — method identity
#
# HTMLCalendar overrides formatmonth from TextCalendar with its own
# HTML-specific implementation. Its __qualname__ is therefore
# 'HTMLCalendar.formatmonth' (not 'TextCalendar.formatmonth'). No prior
# calendar spec checks this method's __qualname__ or __module__.
# ---------------------------------------------------------------------------

invariant calendar_extra17.HTMLCalendar.formatmonth.qualname:
  description: "calendar.HTMLCalendar.formatmonth.__qualname__ == 'HTMLCalendar.formatmonth' — own override, not inherited from TextCalendar"
  category: method_identity
  kind: python_call_eq
  function: HTMLCalendar.formatmonth.__qualname__.__eq__
  args: ["HTMLCalendar.formatmonth"]
  expected: true

invariant calendar_extra17.HTMLCalendar.formatmonth.module:
  description: "calendar.HTMLCalendar.formatmonth.__module__ == 'calendar' — defined in the calendar module"
  category: method_identity
  kind: python_call_eq
  function: HTMLCalendar.formatmonth.__module__.__eq__
  args: ["calendar"]
  expected: true

# ---------------------------------------------------------------------------
# monthrange, isleap, leapdays, weekday — __module__ standalone invariants
#
# calendar_extra3 and calendar_extra7 touch these functions' __qualname__ and
# __module__ values in table rows. No prior spec anchors their __module__
# values as standalone extra17-namespace invariants. All four are pure-Python
# functions defined in calendar.py and registered under module 'calendar'.
# ---------------------------------------------------------------------------

table calendar_extra17.utility_function_modules:
  description: "__module__ for monthrange, isleap, leapdays, weekday utility functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: ufm17

  columns: [id, function, args, expected]
  rows:
    - [monthrange, monthrange.__module__.__eq__, ["calendar"], true]
    - [isleap,     isleap.__module__.__eq__,     ["calendar"], true]
    - [leapdays,   leapdays.__module__.__eq__,   ["calendar"], true]
    - [weekday,    weekday.__module__.__eq__,    ["calendar"], true]
