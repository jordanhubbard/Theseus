spec: decimal_extra2371
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/decimal.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2371 (_extra2371): __class__.__name__ of module-level objects."
    - "All values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "decimal.Decimal, decimal.Context, decimal.DecimalException and all exception subclasses are class objects; __class__.__name__ == 'type'."
    - "decimal.getcontext, decimal.setcontext, decimal.localcontext are C builtins; __class__.__name__ == 'builtin_function_or_method'."
    - "decimal.MAX_PREC, decimal.MAX_EMAX, decimal.MIN_EMIN are int constants; __class__.__name__ == 'int'."
    - "decimal.ROUND_UP, decimal.ROUND_DOWN, etc. are str constants; __class__.__name__ == 'str'."
    - "decimal.HAVE_THREADS and decimal.HAVE_CONTEXTVAR are bool constants; __class__.__name__ == 'bool'."
    - "decimal.localcontext is a builtin (C-implemented context manager factory), NOT a plain Python function or type."
  created_at: "2026-04-12"

