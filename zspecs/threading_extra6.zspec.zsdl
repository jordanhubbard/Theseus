spec: threading_extra6
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "This spec extends prior threading specs."
    - "Focus: Thread object attributes; threading event/lock instance behavior."
    - "threading.current_thread().__class__.__name__ == 'MainThread' (in main thread)."
    - "threading.main_thread().__class__.__name__ == 'MainThread'."
    - "threading.active_count().__class__.__name__ == 'int'."
    - "threading.Event().__class__.__name__ == 'Event'."
    - "threading.Lock().__class__.__name__ == '_thread.lock'."
    - "threading.RLock().__class__.__name__ == '_thread.RLock'."
    - "threading.Semaphore().__class__.__name__ == 'Semaphore'."
    - "threading.BoundedSemaphore().__class__.__name__ == 'BoundedSemaphore'."
    - "threading.Condition().__class__.__name__ == 'Condition'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table threading_extra6.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [current_thread, current_thread.__name__.__eq__, ["current_thread"], true]
    - [main_thread,    main_thread.__name__.__eq__,    ["main_thread"],    true]
    - [active_count,   active_count.__name__.__eq__,   ["active_count"],   true]
    - [enumerate,      enumerate.__name__.__eq__,      ["enumerate"],      true]
    - [settrace,       settrace.__name__.__eq__,       ["settrace"],       true]
    - [setprofile,     setprofile.__name__.__eq__,     ["setprofile"],     true]
    - [stack_size,     stack_size.__name__.__eq__,     ["stack_size"],     true]

invariant threading_extra6.current_thread.class_name:
  description: "threading.current_thread().__class__.__name__ == 'MainThread' or '_MainThread'"
  category: current_thread
  kind: python_call_eq
  function: current_thread
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["_MainThread"]
  expected: true

invariant threading_extra6.main_thread.class_name:
  description: "threading.main_thread().__class__.__name__ == '_MainThread'"
  category: main_thread
  kind: python_call_eq
  function: main_thread
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["_MainThread"]
  expected: true

invariant threading_extra6.active_count.returns_int:
  description: "threading.active_count().__class__.__name__ == 'int'"
  category: active_count
  kind: python_call_eq
  function: active_count
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["int"]
  expected: true

invariant threading_extra6.active_count.ge_one:
  description: "threading.active_count() >= 1 — at least the main thread"
  category: active_count
  kind: python_call_eq
  function: active_count
  args: []
  method: __ge__
  method_args: [1]
  expected: true

invariant threading_extra6.Event.instance_class:
  description: "threading.Event().__class__.__name__ == 'Event'"
  category: Event
  kind: python_call_eq
  function: Event
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["Event"]
  expected: true

invariant threading_extra6.Semaphore.instance_class:
  description: "threading.Semaphore().__class__.__name__ == 'Semaphore'"
  category: Semaphore
  kind: python_call_eq
  function: Semaphore
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["Semaphore"]
  expected: true

invariant threading_extra6.Condition.instance_class:
  description: "threading.Condition().__class__.__name__ == 'Condition'"
  category: Condition
  kind: python_call_eq
  function: Condition
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["Condition"]
  expected: true

invariant threading_extra6.Barrier.class_name:
  description: "threading.Barrier.__name__ == 'Barrier'"
  category: class_names
  kind: python_call_eq
  function: Barrier.__name__.__eq__
  args: ["Barrier"]
  expected: true
