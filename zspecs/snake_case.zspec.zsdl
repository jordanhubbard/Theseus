spec: snake_case
version: ">=4.0.0"
backend: node(snake-case)

docs: https://www.npmjs.com/package/snake-case

provenance:
  derived_from:
    - "snake-case README — https://www.npmjs.com/package/snake-case"
    - "Test vectors verified with snake-case via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "snake-case source"
  notes:
    - "snake-case is an npm package. Install: npm install snake-case"
    - "Converts a string to snake_case."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table snake_case.snakeCase:
  kind: node_module_call_eq
  function: snakeCase
  category: string
  id_prefix: sc

  columns: [id, args, expected]
  rows:
    - [spaces,  ["hello world"],  "hello_world"]
    - [camel,   ["fooBar"],       "foo_bar"]
    - [hyphen,  ["foo-bar"],      "foo_bar"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:05:52Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
