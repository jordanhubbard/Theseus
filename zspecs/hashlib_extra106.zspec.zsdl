spec: hashlib_extra106
version: ">=3.9"
backend: python_module(hashlib)
extends: hashlib_extra105

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra105.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 __qualname__.__len__() / sha3_*/shake_* __qualname__.__len__() / blake2b/blake2s __qualname__.__len__()==7 and __mro__.__len__()==2 and __bases__[0].__name__=='object' / pbkdf2_hmac.__module__.__eq__('_hashlib') and scrypt.__module__.__eq__('_hashlib') and scrypt.__qualname__.__eq__('scrypt') (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 __class__.__name__=='builtin_function_or_method' and __name__ equality / blake2b/blake2s __class__.__name__=='type' and __module__=='_blake2' and __qualname__ / new class name / algorithms_guaranteed.__len__()==14 (table + invariants)."
    - "hashlib_extra98.zspec.zsdl — covers sha3_*/shake_* __qualname__/__module__ equality / sha3_*/shake_* __class__.__name__=='builtin_function_or_method' / file_digest function class name and module and qualname equality / hashlib.__all__ class name and length (table + invariants)."
    - "hashlib_extra97.zspec.zsdl — covers algorithms_guaranteed membership / new/__qualname__.__len__()==10 (table + invariants)."
    - "hashlib_extra96.zspec.zsdl — covers module-level identity attrs / sha256/sha512/sha1/md5 __module__ cross-checks (table + invariants)."
    - "hashlib_extra95.zspec.zsdl — covers sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__ and __module__ equality (table + invariants)."
    - "hashlib_extra94.zspec.zsdl — covers algorithms_available/algorithms_guaranteed set class identity / sha256/sha512/sha1/md5 __class__.__name__ (table + invariants)."
  notes:
    - "This spec extends hashlib through hashlib_extra105; it does NOT duplicate invariants present in those files."
    - "Wave 266 theme: KDF function identity qualname lengths / file_digest qualname lengths / sha3_*/shake_* __name__.__len__() cross-check."
    - "hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__qualname__.__len__() == 11 ('pbkdf2_hmac'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__qualname__.__len__() == 6 ('scrypt'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__name__.__eq__('pbkdf2_hmac') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__name__.__eq__('scrypt') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__qualname__.__len__() == 11 ('file_digest'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__name__.__len__() == 11 ('file_digest'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__module__.__len__() == 7 ('hashlib'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_224.__name__.__len__() == 16 ('openssl_sha3_224'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__name__.__len__() == 16 ('openssl_sha3_256'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_384.__name__.__len__() == 16 ('openssl_sha3_384'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__name__.__len__() == 16 ('openssl_sha3_512'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_128.__name__.__len__() == 17 ('openssl_shake_128'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_256.__name__.__len__() == 17 ('openssl_shake_256'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: pbkdf2_hmac and scrypt are C builtins from _hashlib (builtin_function_or_method), not Python functions. Their __name__ == __qualname__ (no 'openssl_' prefix unlike the hash constructors)."
    - "Note: file_digest is a pure Python function (class 'function') in hashlib.py with __module__=='hashlib'; __name__==__qualname__=='file_digest' (11 chars)."
    - "Note: sha3_*/shake_* __name__.__len__() == __qualname__.__len__() since __name__==__qualname__ for C builtins; this table anchors __name__ lengths as distinct from __qualname__ lengths anchored in extra105."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.scrypt.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.pbkdf2_hmac.__qualname__.__len__()==11
# hashlib.scrypt.__qualname__.__len__()==6
# hashlib.pbkdf2_hmac.__name__.__eq__('pbkdf2_hmac')
# hashlib.scrypt.__name__.__eq__('scrypt')
#
# Wave 266 theme: KDF function (pbkdf2_hmac, scrypt) class name and qualname lengths.
#
# hashlib.pbkdf2_hmac is a Password-Based Key Derivation Function 2 (PBKDF2)
# implemented as a C builtin in the _hashlib extension. hashlib.scrypt is the
# scrypt key derivation function, also a C builtin from _hashlib. Both are
# builtin_function_or_method. Their __name__ equals their __qualname__ (no
# 'openssl_' prefix unlike the hash constructors). pbkdf2_hmac.__qualname__ is
# 'pbkdf2_hmac' (11 chars); scrypt.__qualname__ is 'scrypt' (6 chars). extra105
# anchors pbkdf2_hmac.__module__ and scrypt.__module__.__eq__ and
# scrypt.__qualname__.__eq__; no prior spec anchors pbkdf2_hmac __class__.__name__,
# pbkdf2_hmac.__qualname__.__len__(), or scrypt.__qualname__.__len__() under
# hashlib106. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra106.kdf_function_identity:
  description: "hashlib.pbkdf2_hmac/__class__.__name__.__eq__('builtin_function_or_method')==True / scrypt/__class__.__name__.__eq__('builtin_function_or_method')==True / pbkdf2_hmac/__qualname__/__len__()==11 / scrypt/__qualname__/__len__()==6 / pbkdf2_hmac/__name__.__eq__('pbkdf2_hmac')==True / scrypt/__name__.__eq__('scrypt')==True — both KDF functions are C builtins from _hashlib; __name__==__qualname__ (no 'openssl_' prefix unlike hash constructors); extra105 anchors module and scrypt qualname equality; first hashlib106 anchor for KDF class names and qualname lengths"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlib106

  columns: [id, function, args, expected, description]
  rows:
    - [pbkdf2_class,     pbkdf2_hmac.__class__.__name__.__eq__,  ["builtin_function_or_method"], true, "pbkdf2_hmac is a C builtin from _hashlib (PBKDF2 key derivation)"]
    - [scrypt_class,     scrypt.__class__.__name__.__eq__,        ["builtin_function_or_method"], true, "scrypt is a C builtin from _hashlib (scrypt key derivation)"]
    - [pbkdf2_qlen,      pbkdf2_hmac.__qualname__.__len__,        [], 11, "'pbkdf2_hmac' is 11 chars, no 'openssl_' prefix"]
    - [scrypt_qlen,      scrypt.__qualname__.__len__,              [], 6,  "'scrypt' is 6 chars, no 'openssl_' prefix"]
    - [pbkdf2_name_eq,   pbkdf2_hmac.__name__.__eq__,             ["pbkdf2_hmac"], true, "pbkdf2_hmac.__name__ == 'pbkdf2_hmac' (__name__==__qualname__ for C builtins)"]
    - [scrypt_name_eq,   scrypt.__name__.__eq__,                  ["scrypt"],      true, "scrypt.__name__ == 'scrypt' (__name__==__qualname__ for C builtins)"]

# ---------------------------------------------------------------------------
# hashlib.file_digest.__qualname__.__len__()==11
# hashlib.file_digest.__name__.__len__()==11
# hashlib.file_digest.__module__.__len__()==7
#
# Wave 266 theme: file_digest name/qualname/module lengths.
#
# hashlib.file_digest is a pure Python function (class 'function') defined in
# Lib/hashlib.py. Its __qualname__ is 'file_digest' (11 chars) and its __name__
# is also 'file_digest' (11 chars). Its __module__ is 'hashlib' (7 chars).
# hashlib_extra98 anchors file_digest class name, qualname equality, and module
# equality. No prior spec anchors file_digest __qualname__.__len__(),
# __name__.__len__(), or __module__.__len__() under hashlib106.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra106.file_digest_name_lengths:
  description: "hashlib.file_digest/__qualname__/__len__()==11 / file_digest/__name__/__len__()==11 / file_digest/__module__/__len__()==7 — file_digest is a pure Python function in hashlib.py; __qualname__=='file_digest' (11 chars) == __name__; __module__=='hashlib' (7 chars); extra98 anchors class name/qualname equality/module equality; first hashlib106 anchor for file_digest name and qualname lengths"
  kind: python_call_eq
  category: name_lengths
  id_prefix: hashlib106

  columns: [id, function, args, expected, description]
  rows:
    - [file_digest_qlen,    file_digest.__qualname__.__len__,  [], 11, "'file_digest' is 11 chars (__qualname__ of a pure Python function in hashlib.py)"]
    - [file_digest_nlen,    file_digest.__name__.__len__,      [], 11, "'file_digest' is 11 chars (__name__ == __qualname__ for top-level Python function)"]
    - [file_digest_mlen,    file_digest.__module__.__len__,    [], 7,  "'hashlib' is 7 chars (__module__ of file_digest)"]

# ---------------------------------------------------------------------------
# hashlib.sha3_224.__name__.__len__()==16
# hashlib.sha3_256.__name__.__len__()==16
# hashlib.sha3_384.__name__.__len__()==16
# hashlib.sha3_512.__name__.__len__()==16
# hashlib.shake_128.__name__.__len__()==17
# hashlib.shake_256.__name__.__len__()==17
#
# Wave 266 theme: sha3_*/shake_* __name__.__len__() cross-check.
#
# For C builtin functions, __name__ == __qualname__. hashlib_extra105 anchors
# __qualname__.__len__() for sha3_*/shake_*. This table anchors the parallel
# __name__.__len__() values to establish that __name__ and __qualname__ agree
# in length. sha3_224/sha3_256/sha3_384/sha3_512 all share length 16
# ('openssl_sha3_' prefix + 3-digit variant). shake_128 and shake_256 both
# have length 17 ('openssl_shake_' prefix + 3-digit variant).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra106.sha3_shake_name_lengths:
  description: "hashlib.sha3_224/__name__/__len__()==16 / sha3_256/__name__/__len__()==16 / sha3_384/__name__/__len__()==16 / sha3_512/__name__/__len__()==16 / shake_128/__name__/__len__()==17 / shake_256/__name__/__len__()==17 — for C builtins __name__==__qualname__; extra105 anchors __qualname__.__len__(); this table anchors __name__.__len__() to confirm agreement; sha3_* share length 16 ('openssl_sha3_' + 3 digits); shake_* share length 17; first hashlib106 anchor for sha3/shake __name__ lengths"
  kind: python_call_eq
  category: name_lengths
  id_prefix: hashlib106

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_224_nlen,  sha3_224.__name__.__len__,  [], 16, "'openssl_sha3_224' is 16 chars (__name__ == __qualname__ for C builtins)"]
    - [sha3_256_nlen,  sha3_256.__name__.__len__,  [], 16, "'openssl_sha3_256' is 16 chars (__name__ == __qualname__ for C builtins)"]
    - [sha3_384_nlen,  sha3_384.__name__.__len__,  [], 16, "'openssl_sha3_384' is 16 chars (__name__ == __qualname__ for C builtins)"]
    - [sha3_512_nlen,  sha3_512.__name__.__len__,  [], 16, "'openssl_sha3_512' is 16 chars (__name__ == __qualname__ for C builtins)"]
    - [shake_128_nlen, shake_128.__name__.__len__,  [], 17, "'openssl_shake_128' is 17 chars (__name__ == __qualname__ for C builtins)"]
    - [shake_256_nlen, shake_256.__name__.__len__,  [], 17, "'openssl_shake_256' is 17 chars (__name__ == __qualname__ for C builtins)"]

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# hashlib.pbkdf2_hmac.__class__.__name__ is 'builtin_function_or_method'. PBKDF2
# (Password-Based Key Derivation Function 2) is implemented as a C builtin in the
# _hashlib OpenSSL extension. Like the hash constructors (md5, sha256, etc.),
# pbkdf2_hmac is accessed via the _hashlib C extension as a builtin_function_or_method.
# hashlib_extra105 anchors pbkdf2_hmac.__module__.__eq__('_hashlib'); no prior spec
# anchors pbkdf2_hmac.__class__.__name__ as a standalone under hashlib106.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra106.pbkdf2_hmac_class_builtin:
  description: "hashlib.pbkdf2_hmac.__class__.__name__.__eq__('builtin_function_or_method') == True — pbkdf2_hmac is a C builtin from _hashlib implementing PBKDF2 key derivation; same class as hash constructors (md5, sha256, etc.); extra105 anchors pbkdf2_hmac.__module__; first standalone for pbkdf2_hmac __class__.__name__ under hashlib106"
  category: type_identity
  kind: python_call_eq
  function: pbkdf2_hmac.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__qualname__.__len__()==11 — standalone
#
# hashlib.pbkdf2_hmac.__qualname__.__len__() is 11. pbkdf2_hmac.__qualname__ is
# 'pbkdf2_hmac' (11 chars). Unlike the OpenSSL-backed hash constructors which
# carry the 'openssl_' prefix in their __qualname__, pbkdf2_hmac uses a plain
# name without this prefix. The 11 chars break down as: 'pbkdf2' (6) + '_' (1)
# + 'hmac' (4). hashlib_extra105 anchors scrypt.__qualname__.__eq__('scrypt');
# no prior spec anchors pbkdf2_hmac.__qualname__.__len__()==11 as a standalone
# under hashlib106. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra106.pbkdf2_hmac_qualname_len_11:
  description: "hashlib.pbkdf2_hmac.__qualname__.__len__() == 11 — pbkdf2_hmac.__qualname__ is 'pbkdf2_hmac' (11 chars = 'pbkdf2' + '_' + 'hmac'); no 'openssl_' prefix unlike hash constructors; extra105 anchors scrypt.__qualname__.__eq__; first standalone for pbkdf2_hmac.__qualname__.__len__() under hashlib106"
  category: name_lengths
  kind: python_call_eq
  function: pbkdf2_hmac.__qualname__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# hashlib.scrypt.__qualname__.__len__()==6 — standalone
#
# hashlib.scrypt.__qualname__.__len__() is 6. scrypt.__qualname__ is 'scrypt'
# (6 chars). The scrypt key derivation function is implemented as a C builtin
# in the _hashlib OpenSSL extension. Like pbkdf2_hmac, it carries no 'openssl_'
# prefix in its qualname. hashlib_extra105 anchors scrypt.__qualname__.__eq__
# ('scrypt') and scrypt.__module__.__eq__('_hashlib'); no prior spec anchors
# scrypt.__qualname__.__len__()==6 as a standalone under hashlib106.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra106.scrypt_qualname_len_6:
  description: "hashlib.scrypt.__qualname__.__len__() == 6 — scrypt.__qualname__ is 'scrypt' (6 chars); C builtin from _hashlib implementing the scrypt key derivation function; no 'openssl_' prefix; extra105 anchors scrypt.__qualname__.__eq__ and __module__; first standalone for scrypt.__qualname__.__len__() under hashlib106"
  category: name_lengths
  kind: python_call_eq
  function: scrypt.__qualname__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# hashlib.sha3_224.__name__.__len__()==16 — standalone
#
# hashlib.sha3_224.__name__.__len__() is 16. sha3_224.__name__ is
# 'openssl_sha3_224' (16 chars). For C builtin functions, __name__ and
# __qualname__ are identical, so sha3_224.__name__.__len__()==16 agrees with
# sha3_224.__qualname__.__len__()==16 anchored in hashlib_extra105. This
# cross-check confirms that __name__ and __qualname__ are equal for these
# OpenSSL-backed C builtins. No prior spec anchors sha3_224.__name__.__len__()
# as a standalone under hashlib106. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra106.sha3_224_name_len_16:
  description: "hashlib.sha3_224.__name__.__len__() == 16 — sha3_224.__name__ is 'openssl_sha3_224' (16 chars); for C builtins __name__==__qualname__ so this agrees with extra105's __qualname__.__len__()==16; confirms __name__/__qualname__ identity for sha3_* family; first standalone for sha3_224.__name__.__len__() under hashlib106"
  category: name_lengths
  kind: python_call_eq
  function: sha3_224.__name__.__len__
  args: []
  expected: 16
