spec: hl3556
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 684 (hl3556): __reduce__, __reduce_ex__, __getstate__ dict-presence checks for hashlib types."
    - "All values false — hashlib hash object types do not define __reduce__, __reduce_ex__, or __getstate__ in their own __dict__."
    - "Hash objects are not picklable by design; no custom pickle protocol is implemented."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl3556.reduce:
  description: "hashlib types __reduce__ dict-presence checks; wave 684"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: hl3556
  columns: [id, function, args, expected]
  rows:
    - ["hl3556001", operator.contains, [type(hashlib.md5()).__dict__,        "__reduce__"], false]
    - ["hl3556002", operator.contains, [type(hashlib.sha1()).__dict__,       "__reduce__"], false]
    - ["hl3556003", operator.contains, [type(hashlib.sha256()).__dict__,     "__reduce__"], false]
    - ["hl3556004", operator.contains, [type(hashlib.sha512()).__dict__,     "__reduce__"], false]
    - ["hl3556005", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__reduce__"], false]

