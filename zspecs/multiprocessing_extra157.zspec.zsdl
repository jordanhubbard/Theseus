spec: multiprocessing_extra157
version: ">=3.9"
backend: python_module(multiprocessing.pool)

docs: https://docs.python.org/3/library/multiprocessing.html#multiprocessing.pool.Pool

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "This spec covers: multiprocessing.pool.Pool class identity and method qualnames. multiprocessing.pool.Pool.__name__=='Pool' (len=4); multiprocessing.pool.Pool.__module__=='multiprocessing.pool' (len=20: 'multiprocessing'=15+'.'=1+'pool'=4=20); multiprocessing.pool.Pool.__bases__[0].__name__=='object' (Pool inherits directly from object); Pool.apply.__qualname__=='Pool.apply' (len=10); Pool.map.__qualname__=='Pool.map' (len=8); Pool.starmap.__qualname__=='Pool.starmap' (len=12); Pool.close.__qualname__=='Pool.close' (len=10). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.pool.Pool.__module__=='multiprocessing.pool' (len=20: 'multiprocessing'=15+'.'=1+'pool'=4=20); len('multiprocessing.pool')==20; compare module lengths: multiprocessing.pool (len=20) < multiprocessing.queues (len=22) < multiprocessing.context (len=23) < multiprocessing.managers (len=24) < multiprocessing.shared_memory (len=29); pool is the shortest multiprocessing submodule name by dotted path length. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "Pool method qualname length ordering: map(8) < apply(10) == close(10) < starmap(12); Pool.map.__qualname__=='Pool.map' (len=8: 'Pool'=4+'.'=1+'map'=3=8; shortest); Pool.apply.__qualname__=='Pool.apply' (len=10: 'Pool'=4+'.'=1+'apply'=5=10); Pool.close.__qualname__=='Pool.close' (len=10: 'Pool'=4+'.'=1+'close'=5=10; same as apply=10); Pool.starmap.__qualname__=='Pool.starmap' (len=12: 'Pool'=4+'.'=1+'starmap'=7=12; longest — 'starmap'=7 because 'star'=4+'map'=3=7); all four methods are defined directly on Pool (qualnames all start with 'Pool.'). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.pool.Pool.__bases__[0].__name__=='object' — Pool inherits directly from object; it is NOT a subclass of multiprocessing.queues.Queue or any other multiprocessing class; Pool manages a pool of worker processes and provides apply(), map(), starmap(), imap(), imap_unordered(), apply_async(), map_async(), starmap_async(), close(), terminate(), and join(); Pool.__bases__[0].__name__=='object' follows the same pattern as multiprocessing.queues.Queue.__bases__[0].__name__=='object'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool class identity — extra157
#
# multiprocessing.pool.Pool.__name__.__eq__('Pool')                     == True
# multiprocessing.pool.Pool.__module__.__eq__('multiprocessing.pool')   == True
# multiprocessing.pool.Pool.__bases__[0].__name__.__eq__('object')      == True
# ---------------------------------------------------------------------------

table multiprocessing_extra157.mp_pool_pool_identity:
  description: "multiprocessing.pool.Pool class identity checks in mppool157 namespace — multiprocessing.pool.Pool.__name__=='Pool' (len=4: 'P'+'o'+'o'+'l'=4; the multiprocessing worker pool class that manages a pool of worker processes for parallel function execution; supports apply(), map(), starmap(), imap(), imap_unordered(), and their async variants); multiprocessing.pool.Pool.__module__=='multiprocessing.pool' (len=20: 'multiprocessing'=15+'.'=1+'pool'=4=20; defined in Lib/multiprocessing/pool.py; 'pool'=4 is the shortest submodule name making this the shortest multiprocessing dotted module path); multiprocessing.pool.Pool.__bases__[0].__name__=='object' (len=6; Pool inherits directly from object — NOT from any other multiprocessing class); Pool.__name__.__len__()==4; compare: multiprocessing.queues.Queue.__name__.__len__()==5 (1 longer than Pool=4); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mppool157

  columns: [id, function, args, expected, description]
  rows:
    - [pool_name_eq,   multiprocessing.pool.Pool.__name__.__eq__,                ["Pool"],                  true,  "multiprocessing.pool.Pool.__name__ == 'Pool' (len=4); verified with Python 3.14.3"]
    - [pool_mod_eq,    multiprocessing.pool.Pool.__module__.__eq__,               ["multiprocessing.pool"],  true,  "multiprocessing.pool.Pool.__module__ == 'multiprocessing.pool' (len=20); verified with Python 3.14.3"]
    - [pool_base_eq,   "multiprocessing.pool.Pool.__bases__[0].__name__.__eq__",  ["object"],                true,  "multiprocessing.pool.Pool.__bases__[0].__name__ == 'object' (Pool inherits from object directly); verified with Python 3.14.3"]
    - [pool_name_len,  multiprocessing.pool.Pool.__name__.__len__,                [],                        4,     "multiprocessing.pool.Pool.__name__.__len__() == 4 ('Pool'; shortest mp class name in spec series); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool method qualnames (apply, map, starmap) — extra157
#
# multiprocessing.pool.Pool.apply.__qualname__   == 'Pool.apply'
# multiprocessing.pool.Pool.map.__qualname__     == 'Pool.map'
# multiprocessing.pool.Pool.starmap.__qualname__ == 'Pool.starmap'
# ---------------------------------------------------------------------------

table multiprocessing_extra157.mp_pool_method_qualnames_apply_map:
  description: "multiprocessing.pool.Pool method qualname checks for apply, map, and starmap in mppoolapply157 namespace — Pool.apply.__qualname__=='Pool.apply' (len=10: 'Pool'=4+'.'=1+'apply'=5=10; Pool.apply(func, args=(), kwds={}) calls func with args and kwds in a worker process, blocking until the result is ready); Pool.map.__qualname__=='Pool.map' (len=8: 'Pool'=4+'.'=1+'map'=3=8; Pool.map(func, iterable, chunksize=None) applies func to each item in iterable using worker processes, returning results in order; map is the shortest qualname at len=8); Pool.starmap.__qualname__=='Pool.starmap' (len=12: 'Pool'=4+'.'=1+'starmap'=7=12; Pool.starmap(func, iterable) where each element of iterable is a tuple of args unpacked as positional args to func; starmap is the longest at len=12 because 'starmap'=7 > 'apply'=5 > 'map'=3); all three are defined on Pool (qualnames start with 'Pool.'); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mppoolapply157

  columns: [id, function, args, expected, description]
  rows:
    - [pool_apply_qn_eq,    multiprocessing.pool.Pool.apply.__qualname__.__eq__,    ["Pool.apply"],    true,  "Pool.apply.__qualname__ == 'Pool.apply' (len=10; blocks until result is ready); verified with Python 3.14.3"]
    - [pool_map_qn_eq,      multiprocessing.pool.Pool.map.__qualname__.__eq__,       ["Pool.map"],      true,  "Pool.map.__qualname__ == 'Pool.map' (len=8; shortest Pool method qualname); verified with Python 3.14.3"]
    - [pool_starmap_qn_eq,  multiprocessing.pool.Pool.starmap.__qualname__.__eq__,   ["Pool.starmap"],  true,  "Pool.starmap.__qualname__ == 'Pool.starmap' (len=12; unpacks tuple args); verified with Python 3.14.3"]
    - [pool_map_qn_len,     multiprocessing.pool.Pool.map.__qualname__.__len__,      [],                8,     "Pool.map.__qualname__.__len__() == 8 ('Pool.map'; shortest Pool qualname); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool method qualnames (close, starmap) lengths — extra157
#
# multiprocessing.pool.Pool.close.__qualname__   == 'Pool.close'
# multiprocessing.pool.Pool.starmap.__qualname__.__len__() == 12
# ---------------------------------------------------------------------------

table multiprocessing_extra157.mp_pool_method_qualnames_close:
  description: "multiprocessing.pool.Pool.close and starmap qualname length checks in mppoolclose157 namespace — Pool.close.__qualname__=='Pool.close' (len=10: 'Pool'=4+'.'=1+'close'=5=10; Pool.close() signals that no more work will be submitted to the pool; worker processes finish their current work and then exit; close() enables joining with join()); Pool.close.__qualname__.__len__()==10 (same length as Pool.apply=10: both 'close'=5 and 'apply'=5 are 5-char method names); Pool.starmap.__qualname__.__len__()==12 ('starmap'=7 > 'close'=5 > 'map'=3); qualname length order: map(8) < apply(10) == close(10) < starmap(12); all Pool methods are defined on Pool itself (no inherited qualnames in this set); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mppoolclose157

  columns: [id, function, args, expected, description]
  rows:
    - [pool_close_qn_eq,      multiprocessing.pool.Pool.close.__qualname__.__eq__,    ["Pool.close"],    true,  "Pool.close.__qualname__ == 'Pool.close' (len=10; signals no more work, workers finish); verified with Python 3.14.3"]
    - [pool_close_qn_len,     multiprocessing.pool.Pool.close.__qualname__.__len__,   [],                10,    "Pool.close.__qualname__.__len__() == 10 ('Pool.close'; same as Pool.apply=10); verified with Python 3.14.3"]
    - [pool_starmap_qn_len,   multiprocessing.pool.Pool.starmap.__qualname__.__len__, [],                12,    "Pool.starmap.__qualname__.__len__() == 12 ('Pool.starmap'; longest in this spec); verified with Python 3.14.3"]
    - [pool_apply_qn_len,     multiprocessing.pool.Pool.apply.__qualname__.__len__,   [],                10,    "Pool.apply.__qualname__.__len__() == 10 ('Pool.apply'; same as Pool.close=10); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra157
# ---------------------------------------------------------------------------

invariant multiprocessing_extra157.mp_Pool_name_eq:
  description: "multiprocessing.pool.Pool.__name__.__eq__('Pool') returns True — multiprocessing.pool.Pool is the worker process pool class; Pool.__name__=='Pool' (len=4: 'P'+'o'+'o'+'l'=4); Pool manages a pool of worker processes and provides parallel function execution via apply(), map(), starmap(), imap(), imap_unordered(), and their async variants (*_async()); Pool.__module__=='multiprocessing.pool' (len=20: 'multiprocessing'=15+'.'=1+'pool'=4=20); Pool.__bases__[0].__name__=='object' (inherits from object directly); Pool.__name__.__len__()==4 is the shortest pool/queue class name in the multiprocessing spec series — compare: Queue=5, SimpleQueue=11, JoinableQueue=13; NEW in extra157: first standalone multiprocessing.pool.Pool.__name__ identity invariant in mppool157 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.__name__.__eq__
  args: ["Pool"]
  expected: true

invariant multiprocessing_extra157.mp_Pool_module_eq:
  description: "multiprocessing.pool.Pool.__module__.__eq__('multiprocessing.pool') returns True — multiprocessing.pool.Pool is defined in Lib/multiprocessing/pool.py; its __module__ is 'multiprocessing.pool' (len=20: 'multiprocessing'=15+'.'=1+'pool'=4=20); 'pool'=4 is the shortest submodule name among multiprocessing submodules making 'multiprocessing.pool' (len=20) the shortest dotted module path in the multiprocessing family; compare: multiprocessing.queues (len=22; +2), multiprocessing.context (len=23; +3), multiprocessing.managers (len=24; +4), multiprocessing.shared_memory (len=29; +9); pool (len=20) is the shortest; NEW in extra157: first standalone multiprocessing.pool.Pool.__module__ identity invariant in mppool157 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.__module__.__eq__
  args: ["multiprocessing.pool"]
  expected: true

invariant multiprocessing_extra157.mp_Pool_base_is_object:
  description: "multiprocessing.pool.Pool.__bases__[0].__name__.__eq__('object') returns True — Pool inherits directly from object; __bases__[0].__name__=='object' (len=6); Pool is the root of its class hierarchy in the pool submodule — it is NOT a subclass of multiprocessing.queues.Queue, BaseContext, or any other multiprocessing class; Pool.__bases__[0].__name__=='object' follows the same pattern as multiprocessing.queues.Queue.__bases__[0].__name__=='object' (also a root multiprocessing class inheriting from object); contrast: multiprocessing.queues.JoinableQueue.__bases__[0].__name__=='Queue' (JoinableQueue inherits from Queue, not object — it is NOT a root class); NEW in extra157: first standalone multiprocessing.pool.Pool.__bases__[0].__name__ identity invariant in mppool157 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.pool.Pool.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant multiprocessing_extra157.mp_Pool_map_qualname_eq:
  description: "multiprocessing.pool.Pool.map.__qualname__.__eq__('Pool.map') returns True — Pool.map is defined directly on Pool; map.__qualname__=='Pool.map' (len=8: 'Pool'=4+'.'=1+'map'=3=8; the shortest Pool method qualname — 'map' is a 3-character method name); Pool.map(func, iterable, chunksize=None) applies func to each item of iterable using worker processes and returns a list of results in the same order as the input; compare: Pool.apply.__qualname__=='Pool.apply' (len=10; 2 longer than Pool.map=8 because 'apply'=5 > 'map'=3) and Pool.starmap.__qualname__=='Pool.starmap' (len=12; 4 longer because 'starmap'=7 > 'map'=3); Pool.map(8) is the shortest qualname among Pool's blocking methods; NEW in extra157: first standalone Pool.map.__qualname__ identity invariant in mppoolapply157 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.map.__qualname__.__eq__
  args: ["Pool.map"]
  expected: true

invariant multiprocessing_extra157.mp_Pool_starmap_qualname_eq:
  description: "multiprocessing.pool.Pool.starmap.__qualname__.__eq__('Pool.starmap') returns True — Pool.starmap is defined directly on Pool; starmap.__qualname__=='Pool.starmap' (len=12: 'Pool'=4+'.'=1+'starmap'=7=12; 'starmap'='star'=4+'map'=3=7 — it is map with argument star-unpacking); Pool.starmap(func, iterable) where each element of iterable is an iterable of arguments that are unpacked as positional arguments to func; Pool.starmap is the multiprocessing analogue of itertools.starmap but uses worker processes; compare: Pool.map.__qualname__=='Pool.map' (len=8; 4 shorter because 'map'=3 < 'starmap'=7) and Pool.apply.__qualname__=='Pool.apply' (len=10; 2 shorter because 'apply'=5 < 'starmap'=7); Pool.starmap(12) is the longest in this spec; NEW in extra157: first standalone Pool.starmap.__qualname__ identity invariant in mppoolapply157 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.starmap.__qualname__.__eq__
  args: ["Pool.starmap"]
  expected: true
