spec: multiprocessing_extra157
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "multiprocessing.Process.__init__.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple; Process.__init__ co_varnames is ('self', 'group', 'target', 'name', 'args', 'kwargs', 'daemon', 'count') on Python 3.14.3."
    - "multiprocessing.Process.__init__.__code__.co_varnames.__contains__('target') returns True — 'target' is the second keyword parameter of Process.__init__(self, group=None, target=None, name=None, args=(), kwargs={}, *, daemon=None)."
    - "multiprocessing.Process.__dict__.__contains__('start') returns False — 'start' is NOT in Process.__dict__; it is defined on BaseProcess (multiprocessing.process.BaseProcess), the parent class."
    - "multiprocessing.Process.__dict__.__contains__('run') returns False — 'run' is NOT in Process.__dict__; inherited from BaseProcess."
    - "multiprocessing.Process.__dict__.__contains__('join') returns False — 'join' is NOT in Process.__dict__; inherited from BaseProcess."
    - "multiprocessing.Process.__dict__.__contains__('terminate') returns False — 'terminate' is NOT in Process.__dict__; inherited from BaseProcess."
    - "multiprocessing.Process.__dict__ on Python 3.14.3 only contains: __module__, __firstlineno__, _start_method, _Popen, _after_fork, __static_attributes__, __doc__."
    - "The methods start, run, join, terminate are all defined on multiprocessing.process.BaseProcess, not on the platform-specific Process subclass."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.Process.__init__ co_varnames type and membership checks
#
# multiprocessing.Process.__init__.__code__.co_varnames.__class__.__name__  == 'tuple'
# multiprocessing.Process.__init__.__code__.co_varnames.__contains__('target') == True
# multiprocessing.Process.__init__.__code__.co_varnames.__contains__('group')  == True
# multiprocessing.Process.__init__.__code__.co_varnames.__contains__('self')   == True
# ---------------------------------------------------------------------------

table multiprocessing_extra157.process_init_covarnames:
  description: "multiprocessing.Process.__init__ __code__.co_varnames type and membership checks in mpcovarnames157 namespace — Process.__init__.__code__.co_varnames.__class__.__name__=='tuple' (co_varnames is always a tuple); co_varnames.__contains__('target')==True ('target' is the callable to invoke in the subprocess); co_varnames.__contains__('group')==True ('group' is kept for API compatibility; must be None); co_varnames.__contains__('self')==True ('self' is the first element as expected for a method); full co_varnames on 3.14.3 is ('self', 'group', 'target', 'name', 'args', 'kwargs', 'daemon', 'count'); verified with Python 3.14.3"
  kind: python_call_eq
  category: covarnames
  id_prefix: mpcovarnames157

  columns: [id, function, args, expected, description]
  rows:
    - [init_covarnames_class_name,   "multiprocessing.Process.__init__.__code__.co_varnames.__class__.__name__.__eq__",   ["tuple"],  true, "multiprocessing.Process.__init__.__code__.co_varnames.__class__.__name__ == 'tuple'; verified Python 3.14.3"]
    - [init_covarnames_has_target,   "multiprocessing.Process.__init__.__code__.co_varnames.__contains__",                ["target"], true, "multiprocessing.Process.__init__.__code__.co_varnames.__contains__('target'); verified Python 3.14.3"]
    - [init_covarnames_has_group,    "multiprocessing.Process.__init__.__code__.co_varnames.__contains__",                ["group"],  true, "multiprocessing.Process.__init__.__code__.co_varnames.__contains__('group'); verified Python 3.14.3"]
    - [init_covarnames_has_self,     "multiprocessing.Process.__init__.__code__.co_varnames.__contains__",                ["self"],   true, "multiprocessing.Process.__init__.__code__.co_varnames.__contains__('self'); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: multiprocessing.Process.__dict__ membership checks — start/run/join/terminate
#
# multiprocessing.Process.__dict__.__contains__('start')     == False
# multiprocessing.Process.__dict__.__contains__('run')       == False
# multiprocessing.Process.__dict__.__contains__('join')      == False
# multiprocessing.Process.__dict__.__contains__('terminate') == False
# ---------------------------------------------------------------------------

table multiprocessing_extra157.process_dict_method_absence:
  description: "multiprocessing.Process.__dict__ membership checks for inherited methods in mpcovarnames157 namespace — Process.__dict__.__contains__('start')==False (start is inherited from BaseProcess, not defined directly on the platform-specific Process subclass); Process.__dict__.__contains__('run')==False (run is inherited from BaseProcess); Process.__dict__.__contains__('join')==False (join is inherited from BaseProcess); Process.__dict__.__contains__('terminate')==False (terminate is inherited from BaseProcess); Process.__dict__ on Python 3.14.3 only contains: __module__, __firstlineno__, _start_method, _Popen, _after_fork, __static_attributes__, __doc__; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: mpcovarnames157a

  columns: [id, function, args, expected, description]
  rows:
    - [process_dict_no_start,     "multiprocessing.Process.__dict__.__contains__",   ["start"],     false, "multiprocessing.Process.__dict__.__contains__('start') == False — inherited from BaseProcess; verified Python 3.14.3"]
    - [process_dict_no_run,       "multiprocessing.Process.__dict__.__contains__",   ["run"],       false, "multiprocessing.Process.__dict__.__contains__('run') == False — inherited from BaseProcess; verified Python 3.14.3"]
    - [process_dict_no_join,      "multiprocessing.Process.__dict__.__contains__",   ["join"],      false, "multiprocessing.Process.__dict__.__contains__('join') == False — inherited from BaseProcess; verified Python 3.14.3"]
    - [process_dict_no_terminate, "multiprocessing.Process.__dict__.__contains__",   ["terminate"], false, "multiprocessing.Process.__dict__.__contains__('terminate') == False — inherited from BaseProcess; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: multiprocessing.Process.__init__ co_varnames additional membership
#
# multiprocessing.Process.__init__.__code__.co_varnames.__contains__('name')   == True
# multiprocessing.Process.__init__.__code__.co_varnames.__contains__('kwargs') == True
# multiprocessing.Process.__init__.__code__.co_varnames.__contains__('daemon') == True
# multiprocessing.Process.__init__.__code__.co_varnames.__len__()              == 8
# ---------------------------------------------------------------------------

table multiprocessing_extra157.process_init_covarnames_extra:
  description: "multiprocessing.Process.__init__ co_varnames additional membership and length checks in mpcovarnames157 namespace — co_varnames.__contains__('name')==True ('name' is the optional process name parameter); co_varnames.__contains__('kwargs')==True ('kwargs' is a dict of keyword args for the target); co_varnames.__contains__('daemon')==True ('daemon' sets whether the process is a daemon); co_varnames.__len__()==8 (full tuple is ('self', 'group', 'target', 'name', 'args', 'kwargs', 'daemon', 'count') — 8 entries); length 8 confirms all parameters including internal 'count'; verified with Python 3.14.3"
  kind: python_call_eq
  category: covarnames
  id_prefix: mpcovarnames157b

  columns: [id, function, args, expected, description]
  rows:
    - [init_covarnames_has_name,   "multiprocessing.Process.__init__.__code__.co_varnames.__contains__",   ["name"],   true, "multiprocessing.Process.__init__.__code__.co_varnames.__contains__('name'); verified Python 3.14.3"]
    - [init_covarnames_has_kwargs, "multiprocessing.Process.__init__.__code__.co_varnames.__contains__",   ["kwargs"], true, "multiprocessing.Process.__init__.__code__.co_varnames.__contains__('kwargs'); verified Python 3.14.3"]
    - [init_covarnames_has_daemon, "multiprocessing.Process.__init__.__code__.co_varnames.__contains__",   ["daemon"], true, "multiprocessing.Process.__init__.__code__.co_varnames.__contains__('daemon'); verified Python 3.14.3"]
    - [init_covarnames_len,        "multiprocessing.Process.__init__.__code__.co_varnames.__len__",        [],         8,    "multiprocessing.Process.__init__.__code__.co_varnames.__len__() == 8; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra157
# ---------------------------------------------------------------------------

invariant multiprocessing_extra157.init_covarnames_class_name_tuple:
  description: "multiprocessing.Process.__init__.__code__.co_varnames.__class__.__name__.__eq__('tuple') returns True — Process.__init__.__code__.co_varnames is always a tuple of parameter and local variable name strings; __init__ co_varnames on Python 3.14.3 is ('self', 'group', 'target', 'name', 'args', 'kwargs', 'daemon', 'count') (length 8); co_varnames.__class__.__name__ is 'tuple' (len=5: t-u-p-l-e); NEW in extra157: first standalone mp.Process.__init__ co_varnames class name invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: covarnames
  kind: python_call_eq
  function: multiprocessing.Process.__init__.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant multiprocessing_extra157.init_covarnames_contains_target:
  description: "multiprocessing.Process.__init__.__code__.co_varnames.__contains__('target') returns True — 'target' is the callable to run in the subprocess; it is the second keyword parameter in Process.__init__(self, group=None, target=None, name=None, args=(), kwargs={}, *, daemon=None); 'target' appears at index 2 in co_varnames ('self', 'group', 'target', ...); NEW in extra157; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: covarnames
  kind: python_call_eq
  function: multiprocessing.Process.__init__.__code__.co_varnames.__contains__
  args: ["target"]
  expected: true

invariant multiprocessing_extra157.process_dict_no_start:
  description: "multiprocessing.Process.__dict__.__contains__('start') returns False — 'start' is NOT in Process.__dict__ because start() is defined on multiprocessing.process.BaseProcess, the parent class; the platform-specific Process subclass (e.g., the macOS/spawn variant) only defines _start_method, _Popen, and _after_fork in its own __dict__; hasattr(Process, 'start') is True because it is inherited, but 'start' not in Process.__dict__ is True; NEW in extra157; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: multiprocessing.Process.__dict__.__contains__
  args: ["start"]
  expected: false

invariant multiprocessing_extra157.process_dict_no_run:
  description: "multiprocessing.Process.__dict__.__contains__('run') returns False — 'run' is NOT in Process.__dict__; run() is defined on multiprocessing.process.BaseProcess; BaseProcess.run() invokes the target callable stored in self._target with self._args and self._kwargs; the platform-specific Process subclass does not override run(); hasattr(Process, 'run') is True (inherited), but 'run' not in Process.__dict__ is True; NEW in extra157; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: multiprocessing.Process.__dict__.__contains__
  args: ["run"]
  expected: false

invariant multiprocessing_extra157.process_dict_no_join:
  description: "multiprocessing.Process.__dict__.__contains__('join') returns False — 'join' is NOT in Process.__dict__; join() is defined on multiprocessing.process.BaseProcess; BaseProcess.join(timeout=None) blocks the calling process until the subprocess terminates or the timeout expires; 'join' is inherited, not defined directly on the Process subclass; NEW in extra157; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: multiprocessing.Process.__dict__.__contains__
  args: ["join"]
  expected: false

invariant multiprocessing_extra157.process_dict_no_terminate:
  description: "multiprocessing.Process.__dict__.__contains__('terminate') returns False — 'terminate' is NOT in Process.__dict__; terminate() is defined on multiprocessing.process.BaseProcess; BaseProcess.terminate() sends SIGTERM on Unix (or calls TerminateProcess on Windows); the platform-specific Process subclass does not override terminate(); NEW in extra157; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: multiprocessing.Process.__dict__.__contains__
  args: ["terminate"]
  expected: false

invariant multiprocessing_extra157.init_covarnames_len:
  description: "multiprocessing.Process.__init__.__code__.co_varnames.__len__() returns 8 — Process.__init__ co_varnames has exactly 8 entries on Python 3.14.3: ('self', 'group', 'target', 'name', 'args', 'kwargs', 'daemon', 'count'); 'self', 'group', 'target', 'name', 'args', 'kwargs', 'daemon' are the 7 declared parameters; 'count' is an internal local variable used to generate a default process name; len==8 confirms the exact tuple length; NEW in extra157; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: covarnames
  kind: python_call_eq
  function: multiprocessing.Process.__init__.__code__.co_varnames.__len__
  args: []
  expected: 8

invariant multiprocessing_extra157.init_covarnames_contains_group:
  description: "multiprocessing.Process.__init__.__code__.co_varnames.__contains__('group') returns True — 'group' is the first keyword parameter of Process.__init__; it must always be None (it exists purely for API compatibility with threading.Thread); 'group' appears at index 1 in co_varnames ('self', 'group', 'target', ...); the 'group' parameter has no effect and is reserved for future use; NEW in extra157; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: covarnames
  kind: python_call_eq
  function: multiprocessing.Process.__init__.__code__.co_varnames.__contains__
  args: ["group"]
  expected: true
