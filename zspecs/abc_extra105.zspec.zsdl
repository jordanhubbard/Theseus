spec: abc_extra105
version: ">=3.11"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra104.zspec.zsdl."
    - "This spec covers: wave 254 theme — abc module dunder attributes: abc.__name__, abc.__doc__, abc.__package__, abc.__spec__, abc.__loader__ class attributes; abc.ABCMeta and abc.ABC class identity. NEW in extra105: abc.__name__=='abc' (len=3, type is str); type(abc.__doc__).__name__=='str' (abc has a docstring of type str); abc.__package__=='' (empty string, type is str); abc.__spec__.__class__.__name__=='ModuleSpec'; abc.__spec__.name=='abc' (len=3, same as __name__); abc.__loader__.__class__.__name__=='type' (the loader is the FrozenImporter metaclass); abc.ABCMeta.__name__=='ABCMeta' (len=7); abc.ABCMeta.__module__=='abc'; abc.ABCMeta.__bases__[0].__name__=='type' (ABCMeta inherits from type, making it a metaclass); abc.ABCMeta.__mro__.__len__()==3 ([ABCMeta, type, object]); abc.ABC.__name__=='ABC' (len=3); abc.ABC.__bases__[0].__name__=='object' (ABC inherits directly from object, MRO=[ABC, object], length=2); abc.ABC.__mro__.__len__()==2. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__name__ == 'abc' (len=3, type is str). abc.__package__ == '' (empty string — abc is a top-level module, so package is ''). abc.__spec__.__class__.__name__ == 'ModuleSpec'; abc.__spec__.name == 'abc' (len=3, same as abc.__name__). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__loader__.__class__.__name__ == 'type'. The abc module is frozen (abc.__spec__.origin=='frozen'), and its loader is the FrozenImporter class object (whose type is 'type' — i.e., the metaclass of FrozenImporter is type). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__bases__[0].__name__ == 'type'. ABCMeta inherits from type (the standard metaclass), making ABCMeta a metaclass itself. MRO=[ABCMeta, type, object] (length=3). abc.ABC.__bases__[0].__name__ == 'object' (ABC is a simple helper class — MRO=[ABC, object], length=2). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc module dunder attributes: __name__, __doc__, __package__ — extra105
#
# Wave 254 theme: abc module dunder string attributes.
#
# abc.__name__    == 'abc'  (len=3, type str)
# type(abc.__doc__).__name__ == 'str'
# abc.__package__ == ''    (empty string, type str)
# ---------------------------------------------------------------------------

table abc_extra105.abc_module_dunder_string_attrs:
  description: "abc module dunder string attribute checks in abcmodule105 namespace — wave 254 theme: abc.__name__.__eq__('abc')==True (len=3: 'abc'=3; abc.__name__ is the module name as a string); type(abc.__name__).__name__.__eq__('str')==True (abc.__name__ is type str); abc.__name__.__len__()==3 (shortest string length in spec — len=3); type(abc.__doc__).__name__.__eq__('str')==True (abc has a module-level docstring, type is str); abc.__package__.__eq__('')==True (abc is a top-level module so package is empty string — not a subpackage); type(abc.__package__).__name__.__eq__('str')==True (abc.__package__ is type str); abc.__package__.__len__()==0 (empty string — unique in spec as the only zero-length string); abc.__spec__.name.__eq__('abc')==True (len=3, same value as abc.__name__); abc.__spec__.name.__len__()==3 (same length as abc.__name__=3); compare string lengths: abc.__package__=0 (empty) < abc.__name__=abc.__spec__.name=3 < abc.__loader__.__class__.__name__='type'=4; abc.__name__ and abc.__spec__.name are both 'abc' (len=3, tied); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmodule105

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,           abc.__name__.__eq__,                                            ["abc"],               true, "abc.__name__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [name_len,          abc.__name__.__len__,                                            [],                    3,    "abc.__name__.__len__() == 3 ('abc'=3); verified with Python 3.14.3"]
    - [name_type_eq,      type(abc.__name__).__name__.__eq__,                             ["str"],               true, "type(abc.__name__).__name__ == 'str'; verified with Python 3.14.3"]
    - [doc_type_eq,       type(abc.__doc__).__name__.__eq__,                              ["str"],               true, "type(abc.__doc__).__name__ == 'str' (abc has a docstring); verified with Python 3.14.3"]
    - [pkg_eq,            abc.__package__.__eq__,                                          [""],                  true, "abc.__package__ == '' (empty string — top-level module); verified with Python 3.14.3"]
    - [pkg_len,           abc.__package__.__len__,                                         [],                    0,    "abc.__package__.__len__() == 0 (empty string); verified with Python 3.14.3"]
    - [pkg_type_eq,       type(abc.__package__).__name__.__eq__,                          ["str"],               true, "type(abc.__package__).__name__ == 'str'; verified with Python 3.14.3"]
    - [spec_name_eq,      abc.__spec__.name.__eq__,                                        ["abc"],               true, "abc.__spec__.name == 'abc' (len=3, same as abc.__name__); verified with Python 3.14.3"]
    - [spec_name_len,     abc.__spec__.name.__len__,                                       [],                    3,    "abc.__spec__.name.__len__() == 3 ('abc'=3, tied with abc.__name__); verified with Python 3.14.3"]
    - [spec_class_eq,     abc.__spec__.__class__.__name__.__eq__,                         ["ModuleSpec"],        true, "abc.__spec__.__class__.__name__ == 'ModuleSpec'; verified with Python 3.14.3"]
    - [loader_class_eq,   abc.__loader__.__class__.__name__.__eq__,                       ["type"],              true, "abc.__loader__.__class__.__name__ == 'type' (FrozenImporter's metaclass is type); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta class identity — extra105
#
# Wave 254 theme: ABCMeta class identity (metaclass inheriting from type).
#
# abc.ABCMeta.__name__              == 'ABCMeta'  (len=7)
# abc.ABCMeta.__module__            == 'abc'
# abc.ABCMeta.__bases__[0].__name__ == 'type'     (metaclass, mro len=3)
# abc.ABCMeta.__mro__.__len__()     == 3
# ---------------------------------------------------------------------------

table abc_extra105.abc_abcmeta_class_identity:
  description: "abc.ABCMeta class identity checks in abcmodule105 namespace — wave 254 theme: abc.ABCMeta.__name__.__eq__('ABCMeta')==True (len=7: 'ABCMeta'=7); abc.ABCMeta.__module__.__eq__('abc')==True (ABCMeta is defined in the abc module); abc.ABCMeta.__bases__[0].__name__.__eq__('type')==True (ABCMeta inherits from type — making ABCMeta a metaclass; MRO=[ABCMeta, type, object], length=3); abc.ABCMeta.__mro__.__len__()==3; abc.ABCMeta.__qualname__.__eq__('ABCMeta')==True (len=7); compare: abc.ABC.__name__.__eq__('ABC')==True (len=3, shorter than ABCMeta=7); abc.ABC.__bases__[0].__name__.__eq__('object')==True (ABC inherits from object, not type — ABC is an ordinary class, not a metaclass); abc.ABC.__mro__.__len__()==2 (shorter than ABCMeta=3); ABCMeta is the metaclass: its MRO includes type (mro len=3); ABC is the helper base class: its MRO does not include type (mro len=2); compare name lengths: ABC=3 < ABCMeta=7; compare mro lengths: ABC=2 < ABCMeta=3; abc.__name__=='abc' (len=3), ABCMeta.__module__=='abc' (len=3, same); verified with Python 3.14.3"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: abcmodule105a

  columns: [id, function, args, expected, description]
  rows:
    - [meta_name_eq,      abc.ABCMeta.__name__.__eq__,                                    ["ABCMeta"],           true, "ABCMeta.__name__ == 'ABCMeta' (len=7); verified with Python 3.14.3"]
    - [meta_name_len,     abc.ABCMeta.__name__.__len__,                                    [],                    7,    "ABCMeta.__name__.__len__() == 7 ('ABCMeta'=7); verified with Python 3.14.3"]
    - [meta_module_eq,    abc.ABCMeta.__module__.__eq__,                                   ["abc"],               true, "ABCMeta.__module__ == 'abc' (len=3, same as abc.__name__); verified with Python 3.14.3"]
    - [meta_base_eq,      "abc.ABCMeta.__bases__[0].__name__.__eq__",                     ["type"],              true, "ABCMeta.__bases__[0].__name__ == 'type' (ABCMeta is a metaclass inheriting from type); verified with Python 3.14.3"]
    - [meta_mro_len,      abc.ABCMeta.__mro__.__len__,                                     [],                    3,    "ABCMeta.__mro__.__len__() == 3 ([ABCMeta, type, object]); verified with Python 3.14.3"]
    - [meta_qn_eq,        abc.ABCMeta.__qualname__.__eq__,                                 ["ABCMeta"],           true, "ABCMeta.__qualname__ == 'ABCMeta' (len=7); verified with Python 3.14.3"]
    - [abc_name_eq,       abc.ABC.__name__.__eq__,                                         ["ABC"],               true, "ABC.__name__ == 'ABC' (len=3); verified with Python 3.14.3"]
    - [abc_base_eq,       "abc.ABC.__bases__[0].__name__.__eq__",                         ["object"],            true, "ABC.__bases__[0].__name__ == 'object' (ABC is a plain helper class, not a metaclass); verified with Python 3.14.3"]
    - [abc_mro_len,       abc.ABC.__mro__.__len__,                                         [],                    2,    "ABC.__mro__.__len__() == 2 ([ABC, object], shorter than ABCMeta=3); verified with Python 3.14.3"]
    - [meta_vs_abc_mro,   abc.ABCMeta.__mro__.__len__,                                     [],                    3,    "ABCMeta.__mro__.__len__()==3 > ABC.__mro__.__len__()==2 (metaclass has longer MRO); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc module spec and loader identity — extra105
#
# Wave 254 theme: abc module ModuleSpec and loader identity.
#
# abc.__spec__.__class__.__name__    == 'ModuleSpec' (the module specification)
# abc.__spec__.name                  == 'abc'        (len=3)
# abc.__loader__.__class__.__name__  == 'type'       (FrozenImporter's metaclass)
# abc.__name__.__len__()             == 3
# ---------------------------------------------------------------------------

table abc_extra105.abc_module_spec_loader_identity:
  description: "abc module spec and loader identity checks in abcmodule105 namespace — wave 254 theme: abc.__spec__.__class__.__name__.__eq__('ModuleSpec')==True (abc.__spec__ is an instance of importlib.machinery.ModuleSpec; 'ModuleSpec'=10 chars); abc.__spec__.name.__eq__('abc')==True (len=3, same value as abc.__name__); abc.__spec__.name.__len__()==3 (tied with abc.__name__=3); abc.__loader__.__class__.__name__.__eq__('type')==True (the loader for the frozen abc module is the FrozenImporter class — its __class__ is 'type' because FrozenImporter is a class object and all class objects have type 'type'); abc.__name__.__len__()==3 (shortest name string in spec); compare: 'ModuleSpec'=10 chars (longest string in spec by class name length) > 'ABCMeta'=7 > 'type'=4 > 'str'=3 = 'abc'=3 (tied shortest); abc.__spec__ links the module to its loader and origin; abc.__spec__.origin=='frozen' (abc is a frozen module — compiled into the interpreter); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmodule105b

  columns: [id, function, args, expected, description]
  rows:
    - [spec_cls_eq,       abc.__spec__.__class__.__name__.__eq__,                         ["ModuleSpec"],        true, "abc.__spec__.__class__.__name__ == 'ModuleSpec'; verified with Python 3.14.3"]
    - [spec_cls_len,      abc.__spec__.__class__.__name__.__len__,                         [],                    10,   "abc.__spec__.__class__.__name__.__len__() == 10 ('ModuleSpec'=10, longest class name string in spec); verified with Python 3.14.3"]
    - [spec_name_eq2,     abc.__spec__.name.__eq__,                                        ["abc"],               true, "abc.__spec__.name == 'abc' (same as abc.__name__); verified with Python 3.14.3"]
    - [spec_name_len2,    abc.__spec__.name.__len__,                                        [],                    3,    "abc.__spec__.name.__len__() == 3 (tied with abc.__name__=3); verified with Python 3.14.3"]
    - [loader_cls_eq,     abc.__loader__.__class__.__name__.__eq__,                       ["type"],              true, "abc.__loader__.__class__.__name__ == 'type' (FrozenImporter metaclass is type); verified with Python 3.14.3"]
    - [loader_cls_len,    abc.__loader__.__class__.__name__.__len__,                        [],                    4,    "abc.__loader__.__class__.__name__.__len__() == 4 ('type'=4); verified with Python 3.14.3"]
    - [name_len2,         abc.__name__.__len__,                                             [],                    3,    "abc.__name__.__len__() == 3 ('abc'=3, tied with spec.name=3); verified with Python 3.14.3"]
    - [meta_module_len,   abc.ABCMeta.__module__.__len__,                                   [],                    3,    "ABCMeta.__module__.__len__() == 3 ('abc'=3, same as abc.__name__); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra105
# ---------------------------------------------------------------------------

invariant abc_extra105.abc_name_is_abc:
  description: "abc.__name__.__eq__('abc') returns True — abc.__name__ is 'abc' (len=3, type is str); abc.__name__ is the module's own name attribute; abc.__spec__.name=='abc' (len=3, same value — both reflect the module name 'abc'); abc.__package__=='' (empty string — abc is a top-level module, not a subpackage); compare: abc.__name__=3 chars, abc.__loader__.__class__.__name__='type'=4 chars, abc.ABCMeta.__name__='ABCMeta'=7 chars, abc.__spec__.__class__.__name__='ModuleSpec'=10 chars; abc module is a frozen built-in module (abc.__spec__.origin=='frozen'); type(abc.__name__).__name__=='str'; abc.__name__ and abc.__spec__.name are both 'abc' (len=3) — the two module name attributes agree; NEW in extra105: first standalone abc.__name__ invariant in abcmodule105 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.__name__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra105.ABCMeta_base_is_type:
  description: "abc.ABCMeta.__bases__[0].__name__.__eq__('type') returns True — ABCMeta inherits from type (the standard Python metaclass), making ABCMeta itself a metaclass; ABCMeta.__mro__.__len__()==3 ([ABCMeta, type, object]); ABCMeta.__name__=='ABCMeta' (len=7); ABCMeta.__module__=='abc' (len=3); compare: ABC.__bases__[0].__name__=='object' (ABC is an ordinary class inheriting from object, not a metaclass); ABC.__mro__.__len__()==2 (shorter than ABCMeta=3); ABCMeta's purpose as a metaclass: it intercepts class creation to detect and track @abstractmethod-decorated methods; ABCMeta.__new__ (verified in extra104) has co_argcount=4 (cls, name, bases, namespace) — the standard metaclass __new__ signature; the base 'type' makes ABCMeta's instances be class objects (not regular instances); NEW in extra105: first standalone ABCMeta base invariant in abcmodule105 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "abc.ABCMeta.__bases__[0].__name__.__eq__"
  args: ["type"]
  expected: true

invariant abc_extra105.ABC_mro_len_2:
  description: "abc.ABC.__mro__.__len__() == 2 — ABC has the simplest possible MRO: [ABC, object] (length=2); ABC.__bases__[0].__name__=='object' (ABC inherits directly from object); ABC.__name__=='ABC' (len=3); compare MRO lengths in spec: ABC=2 (shortest) < ABCMeta=3; ABC is the simple helper base class for defining abstract base classes using @abstractmethod without needing to explicitly use ABCMeta as the metaclass; ABC achieves this by having ABCMeta as its metaclass (class ABC, metaclass=ABCMeta); this means ABC's class itself is an instance of ABCMeta, but ABC's __bases__[0] is still 'object'; ABC.__mro__.__len__()==2 is the minimum for a user-defined class; abc.ABC.__module__=='abc'; NEW in extra105: first standalone ABC MRO length invariant in abcmodule105 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: abc.ABC.__mro__.__len__
  args: []
  expected: 2

invariant abc_extra105.abc_spec_class_is_ModuleSpec:
  description: "abc.__spec__.__class__.__name__.__eq__('ModuleSpec') returns True — abc.__spec__ is an instance of importlib.machinery.ModuleSpec; 'ModuleSpec'=10 chars (longest class name string in this spec); abc.__spec__.name=='abc' (len=3, same as abc.__name__); abc.__spec__.__class__.__name__.__len__()==10 (longest in spec: 'ModuleSpec'=10 > 'ABCMeta'=7 > 'type'=4 > 'str'=3 = 'abc'=3); abc.__spec__ is the module spec describing how the abc module was found and loaded; abc.__spec__.origin=='frozen' (abc is compiled into the interpreter as a frozen module); abc.__loader__.__class__.__name__=='type' (FrozenImporter class has metaclass 'type'); ModuleSpec stores: name='abc', origin='frozen', submodule_search_locations=None (not a package); NEW in extra105: first standalone abc.__spec__ class name invariant in abcmodule105 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.__spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant abc_extra105.abc_package_is_empty_string:
  description: "abc.__package__.__eq__('') returns True — abc.__package__ is an empty string (type str); abc is a top-level module (not inside any package), so its __package__ is '' (empty string, not None); abc.__package__.__len__()==0 (the only zero-length string value in this spec); type(abc.__package__).__name__=='str'; compare: abc.__name__=='abc' (len=3), abc.__package__=='' (len=0); abc.__spec__.name=='abc' (len=3); the empty package string distinguishes top-level modules (abc, os, sys) from submodule packages (concurrent.futures, multiprocessing.queues); abc.__package__=='' indicates abc has no parent package; contrast: multiprocessing.queues.__package__=='multiprocessing' (non-empty), concurrent.futures.__package__=='concurrent' (non-empty); NEW in extra105: first standalone abc.__package__ invariant in abcmodule105 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.__package__.__eq__
  args: [""]
  expected: true
