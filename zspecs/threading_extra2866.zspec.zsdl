spec: th2866
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 638 (th2866): __rand__, __ror__, __rxor__ dict-presence checks for threading module types."
    - "threading classes are synchronization/concurrency types — none define reflected bitwise AND, OR, or XOR operators."
    - "Verified types: Thread, Lock (type(threading.Lock())), RLock (type(threading.RLock())), Condition, Semaphore, BoundedSemaphore, Event, Timer, Barrier, local."
    - "Lock and RLock are C-level types accessed via type() on instances — their __dict__ is a mappingproxy."
    - "All values verified as False with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th2866.rand:
  description: "threading types __rand__ dict-presence checks; wave 638"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2866
  columns: [id, function, args, expected]
  rows:
    - ["th2866001", operator.contains, [threading.Thread.__dict__,           "__rand__"], false]
    - ["th2866002", operator.contains, [threading.Condition.__dict__,        "__rand__"], false]
    - ["th2866003", operator.contains, [threading.Semaphore.__dict__,        "__rand__"], false]
    - ["th2866004", operator.contains, [threading.BoundedSemaphore.__dict__,  "__rand__"], false]
    - ["th2866005", operator.contains, [threading.Event.__dict__,            "__rand__"], false]
    - ["th2866006", operator.contains, [threading.Barrier.__dict__,          "__rand__"], false]

