    - ["ft3496002", operator.contains, [functools.partialmethod.__dict__,                    "__aenter__"], false]
    - ["ft3496003", operator.contains, [functools.cached_property.__dict__,                  "__aenter__"], false]
    - ["ft3496004", operator.contains, [type(functools.lru_cache(lambda: None)).__dict__,    "__aenter__"], false]

