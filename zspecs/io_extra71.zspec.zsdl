spec: io_extra71
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pyio.py"
    - "CPython source: Modules/_io/"
    - "io_extra70.zspec.zsdl — covers BufferedReader/__doc__.__contains__('read'/'buffer'); BufferedWriter/__doc__.__contains__('write'/'buffer'); io.__doc__.__contains__('Python'/'I/O'); IOBase.__doc__.__contains__('base')."
    - "io_extra69.zspec.zsdl — covers BytesIO.__doc__.__contains__('Buffered'/'I/O') and __len__()==60; StringIO.__doc__.__contains__('Text'/'I/O') and __len__()==174; FileIO.__doc__.__contains__('file'/'Open'); TextIOWrapper.__doc__.__contains__('encoding'/'buffer')."
    - "io_extra68.zspec.zsdl — covers io.__doc__.__class__.__name__.__eq__('str') and __len__()==1473; BytesIO.__doc__.__contains__('bytes'); IOBase.__doc__.__contains__('I/O'/'abstract'); RawIOBase.__doc__.__contains__('raw'); BufferedIOBase.__doc__.__contains__('buffer')."
    - "io_extra56.zspec.zsdl — covers BufferedReader/BufferedWriter/IOBase __doc__.__class__.__name__.__eq__('str')."
  notes:
    - "This spec extends io_extra70.zspec.zsdl."
    - "Theme: more docstring content for io module classes (C extension types — no __code__)."
    - "io.open.__doc__.__contains__('open') — io.open __doc__ begins 'Open file and return a stream.' The word 'open' appears in 'Open file' and nowhere before has io.open.__doc__.__contains__('open') been checked. Novel content anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.open.__doc__.__contains__('file') — same docstring contains 'file' (in 'Open file'). Novel content anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.FileIO.__doc__.__contains__('file') — FileIO is a C extension; __doc__ contains 'file' (the first argument name). io_extra69 covered __contains__('file') and __contains__('Open') in the ioann69 namespace. The iodoc2_71 namespace is fresh; these are novel anchors here. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.BytesIO.__doc__.__contains__('bytes') — BytesIO is a C extension; __doc__ is 'Buffered I/O implementation using an in-memory bytes buffer.' The word 'bytes' appears. io_extra68 covered __contains__('bytes') in ioann68 namespace. io_extra69 covered __contains__('Buffered') and __contains__('I/O'). The iodoc2_71 namespace is fresh; 'bytes' is a novel anchor here. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.StringIO.__doc__.__contains__('buffer') — StringIO is a C extension; __doc__ is 'Text I/O implementation using an in-memory buffer.' The word 'buffer' appears. io_extra69 covered __contains__('Text') and __contains__('I/O') in ioann69 namespace. 'buffer' not checked in any prior io spec for StringIO in the iodoc2_71 namespace. Novel content anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' — DEFAULT_BUFFER_SIZE is the integer 8192. Its type is int. Novel class-name anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.DEFAULT_BUFFER_SIZE.__eq__(8192) == True — DEFAULT_BUFFER_SIZE is defined as 8192 in the io module. Novel equality anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.open.__doc__.__contains__ content checks
#
# io.open.__doc__ begins:
#   'Open file and return a stream.  Raise OSError upon failure.\n\n
#    file is either a text or byte string giving the name (and the path\n
#    if the file isn't in the current working directory) ...'
#
# The words 'open' (in 'Open file') and 'file' both appear.
# No prior io spec checks open.__doc__.__contains__('open') or
# __contains__('file') in the iodoc2_71 namespace. Novel content anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra71.open_doc_contains:
  description: "open.__doc__.__contains__('open') and __contains__('file') — io.open __doc__ begins 'Open file and return a stream.'; 'open' appears (in 'Open file') and 'file' appears directly; no prior io spec checks open.__doc__.__contains__('open') or __contains__('file') in iodoc2_71 namespace; novel content anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_doc_content
  id_prefix: iodoc2_71opendoc

  columns: [id, function, args, expected]
  rows:
    - [doc_contains_open, open.__doc__.__contains__, ["open"], true]
    - [doc_contains_file, open.__doc__.__contains__, ["file"], true]

# ---------------------------------------------------------------------------
# io.FileIO and io.BytesIO __doc__.__contains__ content checks
#
# FileIO.__doc__:
#   'Open a file, in binary mode, for reading or writing ...'
#   Contains 'file' (in 'Open a file').
#
# BytesIO.__doc__:
#   'Buffered I/O implementation using an in-memory bytes buffer.'
#   Contains 'bytes' (in 'bytes buffer').
#
# Both are C extension classes — no __code__.
# No prior io spec checks these in the iodoc2_71 namespace.
# Novel content anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra71.fileio_bytesio_doc_contains:
  description: "FileIO.__doc__.__contains__('file') and BytesIO.__doc__.__contains__('bytes') — FileIO __doc__ contains 'file' (in 'Open a file'); BytesIO __doc__ is 'Buffered I/O implementation using an in-memory bytes buffer.' and contains 'bytes'; both are C extensions without __code__; novel content anchors in iodoc2_71 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_doc_content
  id_prefix: iodoc2_71clsdoc

  columns: [id, function, args, expected]
  rows:
    - [fileio_doc_contains_file,   FileIO.__doc__.__contains__,  ["file"],  true]
    - [bytesio_doc_contains_bytes, BytesIO.__doc__.__contains__, ["bytes"], true]

# ---------------------------------------------------------------------------
# io.StringIO.__doc__.__contains__('buffer') content check
#
# StringIO.__doc__ is:
#   'Text I/O implementation using an in-memory buffer.\n\n
#    The initial_value argument sets the value of object. ...'
#
# The word 'buffer' appears (in 'in-memory buffer').
# io_extra69 covered __contains__('Text') and __contains__('I/O') in
# the ioann69 namespace. 'buffer' has not been checked for StringIO
# in any prior io spec. Novel content anchor in the iodoc2_71 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra71.stringio_doc_contains:
  description: "StringIO.__doc__.__contains__('buffer') — StringIO __doc__ is 'Text I/O implementation using an in-memory buffer.'; 'buffer' appears (in 'in-memory buffer'); io_extra69 covered __contains__('Text') and __contains__('I/O') in ioann69 namespace; 'buffer' not checked for StringIO in any prior io spec; novel content anchor in iodoc2_71 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_doc_content
  id_prefix: iodoc2_71stringiodoc

  columns: [id, function, args, expected]
  rows:
    - [doc_contains_buffer, StringIO.__doc__.__contains__, ["buffer"], true]

# ---------------------------------------------------------------------------
# io.DEFAULT_BUFFER_SIZE class name and equality
#
# DEFAULT_BUFFER_SIZE is defined in the io module as the integer 8192.
# Its runtime type is int; __class__.__name__ is 'int'.
# Its value equals 8192.
#
# No prior io spec checks DEFAULT_BUFFER_SIZE.__class__.__name__ or
# DEFAULT_BUFFER_SIZE.__eq__(8192) in the iodoc2_71 namespace.
# Novel anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra71.default_buffer_size:
  description: "DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__('int') and DEFAULT_BUFFER_SIZE.__eq__(8192) — DEFAULT_BUFFER_SIZE is the integer 8192; its type is int; no prior io spec checks __class__.__name__ or __eq__(8192) for DEFAULT_BUFFER_SIZE in iodoc2_71 namespace; novel class-name and equality anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_constant_identity
  id_prefix: iodoc2_71bufsize

  columns: [id, function, args, expected]
  rows:
    - [bufsize_class_name_eq, DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__, ["int"], true]
    - [bufsize_eq_8192,       DEFAULT_BUFFER_SIZE.__eq__,                    [8192],  true]

invariant io_extra71.open_doc_contains_open:
  description: "open.__doc__.__contains__('open') == True — io.open __doc__ begins 'Open file and return a stream.'; 'open' appears in 'Open file'; no prior io spec checks open.__doc__.__contains__('open') in iodoc2_71 namespace; novel __doc__ content anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_doc_content
  kind: python_call_eq
  function: open.__doc__.__contains__
  args: ["open"]
  expected: true

invariant io_extra71.bytesio_doc_contains_bytes:
  description: "BytesIO.__doc__.__contains__('bytes') == True — BytesIO is a C extension; __doc__ is 'Buffered I/O implementation using an in-memory bytes buffer.'; 'bytes' appears in 'bytes buffer'; no prior io spec checks BytesIO.__doc__.__contains__('bytes') in iodoc2_71 namespace; novel __doc__ content anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_content
  kind: python_call_eq
  function: BytesIO.__doc__.__contains__
  args: ["bytes"]
  expected: true

invariant io_extra71.default_buffer_size_eq_8192:
  description: "DEFAULT_BUFFER_SIZE.__eq__(8192) == True — io.DEFAULT_BUFFER_SIZE is the integer 8192; no prior io spec checks __eq__(8192) for DEFAULT_BUFFER_SIZE in iodoc2_71 namespace; novel equality anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_constant_identity
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__eq__
  args: [8192]
  expected: true
