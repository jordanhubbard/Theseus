spec: undici
version: ">=8.0.0"
backend: node(undici)

docs: https://undici.nodejs.org

provenance:
  derived_from:
    - "Undici docs — https://undici.nodejs.org"
    - "Test vectors verified with undici via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "undici source"
  notes:
    - "Official Node.js HTTP/1.1 + HTTP/2 client — powers Node's built-in fetch."
    - "Install: npm install undici"
    - "v8 CJS; named exports include Client / Pool / Agent / fetch / request / errors namespace."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Errors raised through the errors namespace; HTTPParserError, HeadersTimeoutError, etc."
  stderr: "null"
  stickiness: "Pools/clients persist connections."
  codes:
    UndiciError: "Base class for all undici errors"
    HeadersTimeoutError: "Headers received slower than configured timeout"
    HTTPParserError: "Malformed HTTP response"

invariant undici.has_Client_class:
  description: "Client class exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Client.constructor.name"}
  expected: "Function"

invariant undici.has_Pool_class:
  description: "Pool class exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Pool.constructor.name"}
  expected: "Function"

invariant undici.has_Agent_class:
  description: "Agent class exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Agent.constructor.name"}
  expected: "Function"

invariant undici.has_BalancedPool:
  description: "BalancedPool class exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "BalancedPool.constructor.name"}
  expected: "Function"

invariant undici.has_Dispatcher:
  description: "Dispatcher base class exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Dispatcher.constructor.name"}
  expected: "Function"

invariant undici.has_fetch_function:
  description: "fetch() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "fetch.constructor.name"}
  expected: "Function"

invariant undici.has_request_function:
  description: "request() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "request.constructor.name"}
  expected: "Function"

invariant undici.has_ProxyAgent:
  description: "ProxyAgent class exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "ProxyAgent.constructor.name"}
  expected: "Function"

invariant undici.has_RetryAgent:
  description: "RetryAgent class exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "RetryAgent.constructor.name"}
  expected: "Function"

invariant undici.errors_UndiciError:
  description: "errors.UndiciError is the base error class"
  category: errors
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "errors.UndiciError.name"}
  expected: "UndiciError"

invariant undici.errors_HeadersTimeoutError:
  description: "errors.HeadersTimeoutError exposed"
  category: errors
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "errors.HeadersTimeoutError.name"}
  expected: "HeadersTimeoutError"

