invariant itertools_extra234.combinations_mro0_eq:
  description: "itertools.combinations.__mro__[0].__name__ == 'combinations'; new to extra234"
  kind: python_call_eq
  function: "combinations.__mro__[0].__name__.__eq__"
  args: ["combinations"]
