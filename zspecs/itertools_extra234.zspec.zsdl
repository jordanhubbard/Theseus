spec: itertools_extra234
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers itertools.combinations_with_replacement, itertools.permutations, and itertools.combinations class hierarchy."
    - "itertools.combinations_with_replacement.__name__ == 'combinations_with_replacement' (len=29). Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__class__.__name__ == 'type' — it is a C extension type. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__bases__[0].__name__ == 'object' — inherits directly from object. Verified with Python 3.14.3."
    - "itertools.permutations.__name__ == 'permutations' (len=12). Verified with Python 3.14.3."
    - "itertools.permutations.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.combinations.__name__ == 'combinations' (len=12). Verified with Python 3.14.3."
    - "itertools.combinations.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.combinations.__mro__[0].__name__ == 'combinations'. Verified with Python 3.14.3."
    - "itertools.combinations.__mro__[1].__name__ == 'object'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.combinations_with_replacement class identity contracts
#
# itertools.combinations_with_replacement.__name__ == 'combinations_with_replacement' (len=29)
# itertools.combinations_with_replacement.__module__ == 'itertools'
# itertools.combinations_with_replacement.__qualname__ == 'combinations_with_replacement'
# itertools.combinations_with_replacement.__class__.__name__ == 'type'
# itertools.combinations_with_replacement.__bases__[0].__name__ == 'object'
#
# combinations_with_replacement is a C extension type in itertoolsmodule.c
# that generates combinations allowing repeated elements. New to extra234.
# ---------------------------------------------------------------------------

table itertools_extra234.cwr_class_identity:
  description: "itertools.combinations_with_replacement class identity: name, module, qualname, metaclass, base; new to extra234"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra234cwrclassid

  columns: [id, function, args, expected, description]
  rows:
    - [cwr_name_eq,
       combinations_with_replacement.__name__.__eq__,
       ["combinations_with_replacement"],
       true,
       "itertools.combinations_with_replacement.__name__.__eq__('combinations_with_replacement') == True — combinations_with_replacement is a C extension type generating r-length tuples with repeated elements; __name__ is 'combinations_with_replacement' (len=29); new to extra234"]
    - [cwr_name_len_29,
       combinations_with_replacement.__name__.__len__,
       [],
       29,
       "itertools.combinations_with_replacement.__name__.__len__() == 29 — 'combinations_with_replacement' has exactly 29 characters; str.__len__() returns 29; new to extra234"]
    - [cwr_module_eq,
       combinations_with_replacement.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.combinations_with_replacement.__module__.__eq__('itertools') == True — combinations_with_replacement is defined in the itertools C extension module; __module__ is 'itertools'; new to extra234"]
    - [cwr_qualname_eq,
       combinations_with_replacement.__qualname__.__eq__,
       ["combinations_with_replacement"],
       true,
       "itertools.combinations_with_replacement.__qualname__.__eq__('combinations_with_replacement') == True — top-level class with unqualified qualname 'combinations_with_replacement'; new to extra234"]
    - [cwr_class_is_type,
       combinations_with_replacement.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.combinations_with_replacement.__class__.__name__.__eq__('type') == True — combinations_with_replacement is a C extension type whose metaclass is the built-in type; new to extra234"]

# ---------------------------------------------------------------------------
# Table 2: itertools.combinations_with_replacement base and mro contracts
#
# itertools.combinations_with_replacement.__bases__[0].__name__ == 'object'
# itertools.combinations_with_replacement.__mro__[0].__name__ == 'combinations_with_replacement'
# itertools.combinations_with_replacement.__mro__[1].__name__ == 'object'
# itertools.permutations.__name__ == 'permutations' (len=12)
# itertools.permutations.__module__ == 'itertools'
#
# combinations_with_replacement has a two-element MRO. New to extra234.
# ---------------------------------------------------------------------------

table itertools_extra234.cwr_mro_and_permutations:
  description: "itertools.combinations_with_replacement base and MRO contracts; permutations name and module; new to extra234"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra234cwrmroid

  columns: [id, function, args, expected, description]
  rows:
    - [cwr_base_is_object,
       "combinations_with_replacement.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.combinations_with_replacement.__bases__[0].__name__.__eq__('object') == True — combinations_with_replacement inherits directly from object with no intermediate base; new to extra234"]
    - [cwr_mro0_eq,
       "combinations_with_replacement.__mro__[0].__name__.__eq__",
       ["combinations_with_replacement"],
       true,
       "itertools.combinations_with_replacement.__mro__[0].__name__.__eq__('combinations_with_replacement') == True — MRO slot 0 is the class itself; new to extra234"]
    - [cwr_mro1_eq,
       "combinations_with_replacement.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "itertools.combinations_with_replacement.__mro__[1].__name__.__eq__('object') == True — MRO slot 1 is object; combinations_with_replacement has a two-element MRO; new to extra234"]
    - [permutations_name_eq,
       permutations.__name__.__eq__,
       ["permutations"],
       true,
       "itertools.permutations.__name__.__eq__('permutations') == True — permutations is a C extension type generating all ordered arrangements; __name__ is 'permutations' (len=12); new to extra234"]
    - [permutations_module_eq,
       permutations.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.permutations.__module__.__eq__('itertools') == True — permutations is defined in the itertools C extension module; __module__ is 'itertools'; new to extra234"]

# ---------------------------------------------------------------------------
# Table 3: itertools.permutations class and itertools.combinations contracts
#
# itertools.permutations.__class__.__name__ == 'type'
# itertools.permutations.__bases__[0].__name__ == 'object'
# itertools.combinations.__name__ == 'combinations' (len=12)
# itertools.combinations.__mro__[0].__name__ == 'combinations'
# itertools.combinations.__mro__[1].__name__ == 'object'
#
# All three combinatoric types share the same pattern: C extension type,
# inherits directly from object, two-element MRO. New to extra234.
# ---------------------------------------------------------------------------

table itertools_extra234.permutations_class_combinations_mro:
  description: "itertools.permutations metaclass and base; combinations name and MRO slots; new to extra234"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra234permsclassid

  columns: [id, function, args, expected, description]
  rows:
    - [permutations_class_is_type,
       permutations.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.permutations.__class__.__name__.__eq__('type') == True — permutations is a C extension type whose metaclass is the built-in type; __class__.__name__ is 'type'; new to extra234"]
    - [permutations_base_is_object,
       "permutations.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.permutations.__bases__[0].__name__.__eq__('object') == True — permutations inherits directly from object with no intermediate base; new to extra234"]
    - [combinations_name_eq,
       combinations.__name__.__eq__,
       ["combinations"],
       true,
       "itertools.combinations.__name__.__eq__('combinations') == True — combinations is a C extension type generating r-length sorted tuples; __name__ is 'combinations' (len=12); new to extra234"]
    - [combinations_mro0_eq,
       "combinations.__mro__[0].__name__.__eq__",
       ["combinations"],
       true,
       "itertools.combinations.__mro__[0].__name__.__eq__('combinations') == True — combinations MRO slot 0 is the class itself; __mro__[0].__name__ is 'combinations'; new to extra234"]
    - [combinations_mro1_eq,
       "combinations.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "itertools.combinations.__mro__[1].__name__.__eq__('object') == True — combinations MRO slot 1 is object; combinations has a two-element MRO; new to extra234"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra234
# ---------------------------------------------------------------------------

invariant itertools_extra234.cwr_name_eq:
  description: "itertools.combinations_with_replacement.__name__ == 'combinations_with_replacement' (len=29); new to extra234"
  kind: python_call_eq
  function: combinations_with_replacement.__name__.__eq__
  args: ["combinations_with_replacement"]
  expected: true

invariant itertools_extra234.cwr_name_len_29:
  description: "itertools.combinations_with_replacement.__name__.__len__() == 29 — name has 29 characters; new to extra234"
  kind: python_call_eq
  function: combinations_with_replacement.__name__.__len__
  args: []
  expected: 29

invariant itertools_extra234.cwr_module_eq:
  description: "itertools.combinations_with_replacement.__module__ == 'itertools'; new to extra234"
  kind: python_call_eq
  function: combinations_with_replacement.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra234.cwr_class_is_type:
  description: "itertools.combinations_with_replacement.__class__.__name__ == 'type'; new to extra234"
  kind: python_call_eq
  function: combinations_with_replacement.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra234.cwr_base_is_object:
  description: "itertools.combinations_with_replacement.__bases__[0].__name__ == 'object'; new to extra234"
  kind: python_call_eq
  function: "combinations_with_replacement.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra234.cwr_mro0_eq:
  description: "itertools.combinations_with_replacement.__mro__[0].__name__ == 'combinations_with_replacement'; new to extra234"
  kind: python_call_eq
  function: "combinations_with_replacement.__mro__[0].__name__.__eq__"
  args: ["combinations_with_replacement"]
  expected: true

invariant itertools_extra234.cwr_mro1_eq:
  description: "itertools.combinations_with_replacement.__mro__[1].__name__ == 'object'; new to extra234"
  kind: python_call_eq
  function: "combinations_with_replacement.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra234.permutations_name_eq:
  description: "itertools.permutations.__name__ == 'permutations' (len=12); new to extra234"
  kind: python_call_eq
  function: permutations.__name__.__eq__
  args: ["permutations"]
  expected: true

invariant itertools_extra234.permutations_module_eq:
  description: "itertools.permutations.__module__ == 'itertools'; new to extra234"
  kind: python_call_eq
  function: permutations.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra234.permutations_class_is_type:
  description: "itertools.permutations.__class__.__name__ == 'type'; new to extra234"
  kind: python_call_eq
  function: permutations.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra234.permutations_base_is_object:
  description: "itertools.permutations.__bases__[0].__name__ == 'object'; new to extra234"
  kind: python_call_eq
  function: "permutations.__bases__[0].__name__.__eq__"
  args: ["object"]
