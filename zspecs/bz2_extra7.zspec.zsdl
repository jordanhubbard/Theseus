spec: bz2_extra7
version: ">=3.9"
backend: python_module(bz2)

docs: https://docs.python.org/3/library/bz2.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bz2.html — Python bz2 documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_bz2module.c"
    - "CPython source: Lib/bz2.py"
  notes:
    - "This spec extends bz2.zspec.zsdl through bz2_extra6.zspec.zsdl."
    - "bz2 (base) covers: class_names, module_checks, function_names tables, compress magic bytes, compress nonempty output, BZ2Compressor/BZ2Decompressor is_type, BZ2Decompressor.eof initially false."
    - "bz2_extra covers: BZ2File/BZ2Compressor/BZ2Decompressor __name__/__module__, compress/decompress/open __name__, compress returns bytes (method_chain)."
    - "bz2_extra2 covers: compress/decompress/open __module__ table, BZ2Compressor/BZ2Decompressor instance method names, BZ2File method names, base class checks, class_is_type checks."
    - "bz2_extra3 covers: BZ2File/__name__, BZ2Compressor/__name__, BZ2Decompressor/__name__, compress/decompress/open __name__ table, BZ2File/__module__, BZ2Compressor/__module__, compress returns bytes (method_chain on b'hello'), compress magic B/Z, compress/__module__, decompress/__module__."
    - "bz2_extra4 covers: BZ2File/BZ2Compressor/BZ2Decompressor __qualname__ table, open/compress/decompress __qualname__ table, compress(b'') class name (method_chain), BZ2File.__qualname__ is str, compress(b'') nonempty output."
    - "bz2_extra5 covers: BZ2File/BZ2Compressor/BZ2Decompressor __name__ table (cn5), BZ2File.__module__ table, BZ2File.__qualname__ standalone, open.__name__ standalone, BZ2File.__bases__[0].__name__ == 'BaseStream' (bool form)."
    - "bz2_extra6 covers: BZ2Compressor/__module__=='_bz2' and BZ2Decompressor/__module__=='_bz2' (C extension), BZ2Compressor/BZ2Decompressor base is object, compress/decompress/open __code__.co_name table, BZ2Decompressor().needs_input==True, BZ2Decompressor().unused_data==b'', BZ2Compressor.__qualname__.__class__.__name__=='str'."
    - "This spec adds: BZ2File.__name__ == 'BZ2File' standalone (new id prefix bz7); BZ2Compressor.__name__ == 'BZ2Compressor' standalone (new id prefix bz7); BZ2Decompressor.__name__ == 'BZ2Decompressor' standalone (new id prefix bz7); BZ2File.__module__ == 'bz2' standalone (new id prefix bz7); BZ2Compressor.__module__ == '_bz2' standalone (new id prefix bz7); BZ2Decompressor.__module__ == '_bz2' standalone (new id prefix bz7); open.__module__ == 'bz2' standalone (new id prefix bz7); compress.__module__ == 'bz2' standalone (new id prefix bz7); decompress.__module__ == 'bz2' standalone (new id prefix bz7); BZ2File.__bases__[0].__name__ == 'BaseStream' direct-return form (bz2_extra5 uses bool form, this uses string return); BZ2Compressor().__class__.__name__ == 'BZ2Compressor' (instance type check via method chain); BZ2Decompressor.__qualname__.__class__.__name__ == 'str' (bz2_extra6 checks BZ2Compressor; BZ2Decompressor is new)."
    - "bz2.BZ2File.__module__ == 'bz2' — BZ2File is defined in Lib/bz2.py."
    - "bz2.BZ2Compressor.__module__ == '_bz2' — BZ2Compressor is a C extension type in _bz2."
    - "bz2.BZ2Decompressor.__module__ == '_bz2' — BZ2Decompressor is a C extension type in _bz2."
    - "bz2.open.__module__ == 'bz2' — open is a pure-Python function in Lib/bz2.py."
    - "bz2.compress.__module__ == 'bz2' — compress is a pure-Python function in Lib/bz2.py."
    - "bz2.decompress.__module__ == 'bz2' — decompress is a pure-Python function in Lib/bz2.py."
    - "bz2.BZ2File.__bases__[0].__name__ == 'BaseStream' — BZ2File subclasses the internal BaseStream class."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ standalone invariants — new id prefix bz7
# Prior specs cover these with prefixes classname/cname/cn5; bz7 is distinct.
# ---------------------------------------------------------------------------

invariant bz2_extra7.BZ2File.name_eq:
  description: "bz2.BZ2File.__name__ == 'BZ2File'"
  category: class_names
  kind: python_call_eq
  function: BZ2File.__name__.__eq__
  args: ["BZ2File"]
  expected: true

invariant bz2_extra7.BZ2Compressor.name_eq:
  description: "bz2.BZ2Compressor.__name__ == 'BZ2Compressor'"
  category: class_names
  kind: python_call_eq
  function: BZ2Compressor.__name__.__eq__
  args: ["BZ2Compressor"]
  expected: true

invariant bz2_extra7.BZ2Decompressor.name_eq:
  description: "bz2.BZ2Decompressor.__name__ == 'BZ2Decompressor'"
  category: class_names
  kind: python_call_eq
  function: BZ2Decompressor.__name__.__eq__
  args: ["BZ2Decompressor"]
  expected: true

# ---------------------------------------------------------------------------
# Class __module__ standalone invariants — new id prefix bz7
# bz2_extra/bz2_extra3/bz2_extra5/bz2_extra6 cover these with other prefixes.
# ---------------------------------------------------------------------------

invariant bz2_extra7.BZ2File.module_eq:
  description: "bz2.BZ2File.__module__ == 'bz2' — defined in Lib/bz2.py"
  category: module_attrs
  kind: python_call_eq
  function: BZ2File.__module__.__eq__
  args: ["bz2"]
  expected: true

invariant bz2_extra7.BZ2Compressor.module_eq:
  description: "bz2.BZ2Compressor.__module__ == '_bz2' — C extension type"
  category: module_attrs
  kind: python_call_eq
  function: BZ2Compressor.__module__.__eq__
  args: ["_bz2"]
  expected: true

invariant bz2_extra7.BZ2Decompressor.module_eq:
  description: "bz2.BZ2Decompressor.__module__ == '_bz2' — C extension type"
  category: module_attrs
  kind: python_call_eq
  function: BZ2Decompressor.__module__.__eq__
  args: ["_bz2"]
  expected: true

# ---------------------------------------------------------------------------
# Function __module__ standalone invariants — new id prefix bz7
# bz2_extra2/bz2_extra3/bz2_extra6 cover these in tables with other prefixes.
# ---------------------------------------------------------------------------

invariant bz2_extra7.open.module_eq:
  description: "bz2.open.__module__ == 'bz2' — pure-Python function in Lib/bz2.py"
  category: function_modules
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["bz2"]
  expected: true

invariant bz2_extra7.compress.module_eq:
  description: "bz2.compress.__module__ == 'bz2' — pure-Python function in Lib/bz2.py"
  category: function_modules
  kind: python_call_eq
  function: compress.__module__.__eq__
  args: ["bz2"]
  expected: true

invariant bz2_extra7.decompress.module_eq:
  description: "bz2.decompress.__module__ == 'bz2' — pure-Python function in Lib/bz2.py"
  category: function_modules
  kind: python_call_eq
  function: decompress.__module__.__eq__
  args: ["bz2"]
  expected: true

# ---------------------------------------------------------------------------
# BZ2File base class — direct-return string form
# bz2_extra5 uses bool form: method: __name__.__eq__, method_args, expected: true.
# This uses string form: method: __name__, expected: "BaseStream".
# ---------------------------------------------------------------------------

invariant bz2_extra7.BZ2File.base_name_string:
  description: "bz2.BZ2File.__bases__[0].__name__ == 'BaseStream' — direct string return form"
  category: hierarchy
  kind: python_call_eq
  function: BZ2File.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BaseStream"

# ---------------------------------------------------------------------------
# BZ2Compressor().__class__.__name__ — instance type check
# Verifies that instantiating BZ2Compressor yields a BZ2Compressor instance.
# Not covered in this form in any prior bz2 spec.
# ---------------------------------------------------------------------------

invariant bz2_extra7.BZ2Compressor.instance_class_name:
  description: "bz2.BZ2Compressor().__class__.__name__ == 'BZ2Compressor'"
  category: types
  kind: python_call_eq
  function: BZ2Compressor
  args: []
  method: __class__.__name__.__eq__
  method_args: ["BZ2Compressor"]
  expected: true

# ---------------------------------------------------------------------------
# BZ2Decompressor.__qualname__.__class__.__name__ == 'str'
# bz2_extra6 checks this for BZ2Compressor; BZ2Decompressor is new.
# ---------------------------------------------------------------------------

invariant bz2_extra7.BZ2Decompressor.qualname_is_str:
  description: "bz2.BZ2Decompressor.__qualname__.__class__.__name__ == 'str' — __qualname__ is always a str"
  category: qualnames
  kind: python_call_eq
  function: BZ2Decompressor.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
