spec: abc_extra2131
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "abc_extra2116.zspec.zsdl — covers __or__/__ror__/__ior__, __and__/__rand__/__iand__, __xor__/__rxor__/__ixor__ dict-presence checks"
  notes:
    - "Wave (_extra2131): exception protocol dict-presence — checking __cause__, __context__, __traceback__, __suppress_context__, __notes__, args, with_traceback in class __dict__."
    - "The abc module contains no exception types; ABCMeta, ABC, and abstractmethod are all non-exception types."
    - "Exception protocol attributes are instance-level attrs set at raise time — they never appear in any class __dict__ for non-exception types."
    - "ABCMeta is a metaclass (type subclass); its __dict__ contains __new__, register, __instancecheck__, __subclasscheck__, and related machinery only."
    - "ABC is a plain helper base class; its __dict__ contains __slots__, __abstractmethods__, and _abc_impl only."
    - "abstractmethod is a descriptor class; its instance __dict__ is empty (no class-level exception protocol entries)."
    - "This wave contrasts with asyncio_extra2131, concurrent_futures_extra2131, and multiprocessing_extra2131 which include genuine exception types."
    - "All values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table abc_extra2131.abcmeta_exception_protocol:
  description: "abc.ABCMeta.__dict__ exception protocol dict-presence — metaclass (non-exception), all attrs absent from class dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2131

  columns: [id, function, args, expected]
  rows:
    - ["ab2131001", "abc.ABCMeta.__dict__.__contains__", ["__cause__"], false]
    - ["ab2131002", "abc.ABCMeta.__dict__.__contains__", ["__context__"], false]
    - ["ab2131003", "abc.ABCMeta.__dict__.__contains__", ["__traceback__"], false]
    - ["ab2131004", "abc.ABCMeta.__dict__.__contains__", ["__suppress_context__"], false]
    - ["ab2131005", "abc.ABCMeta.__dict__.__contains__", ["__notes__"], false]
    - ["ab2131006", "abc.ABCMeta.__dict__.__contains__", ["args"], false]
    - ["ab2131007", "abc.ABCMeta.__dict__.__contains__", ["with_traceback"], false]

