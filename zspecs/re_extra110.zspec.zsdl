spec: re_extra110
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec extends re_extra109.zspec.zsdl."
    - "This spec covers: re module function __module__ attributes, re.NOFLAG value, and re.Pattern/re.Match __module__ strings."
    - "re.match.__module__ == 're'; same for search, findall, sub, compile, fullmatch, split, finditer, escape, purge."
    - "All re module-level functions have __module__ == 're' (length 2)."
    - "re.NOFLAG exists in Python 3.11+; int(re.NOFLAG) == 0; type(re.NOFLAG).__name__ == 'RegexFlag'."
    - "re.Pattern.__module__ == 're'; re.Match.__module__ == 're'."
    - "type(re.match).__name__ == 'function'; type(re.compile).__name__ == 'function'; type(re.escape).__name__ == 'function'."
    - "All re module-level callable names are pure Python functions (type 'function'), not C builtins."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module function __module__ attributes
# All public functions (match, search, findall, sub, compile, fullmatch,
# split, finditer, escape, purge) have __module__ == 're' (length 2).
# They are pure Python functions defined in re/__init__.py.
# ---------------------------------------------------------------------------

table re_extra110.function_modules:
  description: "re module-level functions __module__: match/search/findall/sub/compile/fullmatch/split/finditer/escape/purge all have __module__=='re'; type=='function'"
  kind: python_call_eq
  category: module_attrs
  id_prefix: remod110a

  columns: [id, function, args, expected, description]
  rows:
    - [match_module,    "match.__module__.__eq__",    ["re"], true,  "re.match.__module__ == 're' (pure Python function defined in re module)"]
    - [search_module,   "search.__module__.__eq__",   ["re"], true,  "re.search.__module__ == 're'"]
    - [findall_module,  "findall.__module__.__eq__",  ["re"], true,  "re.findall.__module__ == 're'"]
    - [sub_module,      "sub.__module__.__eq__",      ["re"], true,  "re.sub.__module__ == 're'"]
    - [compile_module,  "compile.__module__.__eq__",  ["re"], true,  "re.compile.__module__ == 're'"]
    - [fullmatch_module,"fullmatch.__module__.__eq__",["re"], true,  "re.fullmatch.__module__ == 're'"]
    - [split_module,    "split.__module__.__eq__",    ["re"], true,  "re.split.__module__ == 're'"]
    - [finditer_module, "finditer.__module__.__eq__", ["re"], true,  "re.finditer.__module__ == 're'"]
    - [escape_module,   "escape.__module__.__eq__",   ["re"], true,  "re.escape.__module__ == 're'"]
    - [purge_module,    "purge.__module__.__eq__",    ["re"], true,  "re.purge.__module__ == 're'"]
    - [match_mod_len,   "match.__module__.__len__",   [],     2,     "re.match.__module__.__len__() == 2 (the module name 're' has 2 characters)"]

# ---------------------------------------------------------------------------
# re.NOFLAG value and type
# re.NOFLAG is a RegexFlag constant with integer value 0 (Python 3.11+).
# int(re.NOFLAG) == 0; type(re.NOFLAG).__name__ == 'RegexFlag'.
# NOFLAG can be used where no flags are needed, as an explicit zero-value flag.
# ---------------------------------------------------------------------------

table re_extra110.NOFLAG_value:
  description: "re.NOFLAG: int value 0, type 'RegexFlag', class module 're'; NOFLAG is the zero-value flag member introduced in Python 3.11"
  kind: python_call_eq
  category: flag_values
  id_prefix: remod110b

  columns: [id, function, args, expected, description]
  rows:
    - [noflag_int,    "NOFLAG.__int__",              [],      0,      "int(re.NOFLAG) == 0 (the zero-value flag; combining any flag with NOFLAG leaves it unchanged)"]
    - [noflag_type,   "NOFLAG.__class__.__name__.__eq__", ["RegexFlag"], true, "type(re.NOFLAG).__name__ == 'RegexFlag' (NOFLAG is a member of the RegexFlag IntFlag enum)"]
    - [noflag_module, "NOFLAG.__class__.__module__.__eq__", ["re"], true, "re.NOFLAG.__class__.__module__ == 're' (RegexFlag and all its members are defined in the 're' module)"]
    - [noflag_ne_A,   "NOFLAG.__eq__",               ["A"],   false,  "re.NOFLAG != re.A (0 != 256; NOFLAG is the identity element for flag bitwise OR)"]
    - [noflag_ne_I,   "NOFLAG.__eq__",               ["I"],   false,  "re.NOFLAG != re.I (0 != 2)"]

# ---------------------------------------------------------------------------
# re.Pattern and re.Match __module__ attributes
# Both re.Pattern and re.Match are C extension types from _sre module, but
# their __module__ attribute is set to 're' (the public-facing module).
# This aligns with re function __module__ == 're'.
# ---------------------------------------------------------------------------

table re_extra110.Pattern_Match_modules:
  description: "re.Pattern and re.Match __module__: both == 're'; function types: match/compile/escape/purge are all 'function' (not builtin_function_or_method)"
  kind: python_call_eq
  category: module_attrs
  id_prefix: remod110c

  columns: [id, function, args, expected, description]
  rows:
    - [pattern_module,   "Pattern.__module__.__eq__",          ["re"],      true,  "re.Pattern.__module__ == 're' (the C type sre.SRE_Pattern is exposed as re.Pattern with module 're')"]
    - [match_cls_module, "Match.__module__.__eq__",            ["re"],      true,  "re.Match.__module__ == 're' (the C type sre.SRE_Match is exposed as re.Match with module 're')"]
    - [pattern_eq_match_mod, "Pattern.__module__.__eq__",      ["re"],      true,  "re.Pattern.__module__ == re.Match.__module__ (both equal 're')"]
    - [match_fn_type,    "match.__class__.__name__.__eq__",    ["function"], true, "type(re.match).__name__ == 'function' (re functions are pure Python, not C builtins)"]
    - [compile_fn_type,  "compile.__class__.__name__.__eq__",  ["function"], true, "type(re.compile).__name__ == 'function'"]
    - [escape_fn_type,   "escape.__class__.__name__.__eq__",   ["function"], true, "type(re.escape).__name__ == 'function'"]
    - [purge_fn_type,    "purge.__class__.__name__.__eq__",    ["function"], true, "type(re.purge).__name__ == 'function'"]
    - [pattern_mod_len,  "Pattern.__module__.__len__",         [],           2,    "re.Pattern.__module__.__len__() == 2 (the string 're' has 2 characters)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra110.match.module_is_re:
  description: "re.match.__module__ == 're' (length 2; all re module-level functions are pure Python functions defined in re/__init__.py and report __module__ == 're'; this distinguishes them from functions in sub-modules or C extensions that might report '_sre' or 're._compiler')"
  category: module_attrs
  kind: python_call_eq
  function: "match.__module__.__eq__"
  args: ["re"]
  expected: true

invariant re_extra110.NOFLAG.int_value_zero:
  description: "int(re.NOFLAG) == 0 (NOFLAG is the zero-valued member of re.RegexFlag; it was added in Python 3.11 to provide an explicit name for 'no flags'; combining any flag with NOFLAG via bitwise OR leaves that flag unchanged)"
  category: flag_values
  kind: python_call_eq
  function: "NOFLAG.__int__"
  args: []
  expected: 0

invariant re_extra110.Pattern.module_is_re:
  description: "re.Pattern.__module__ == 're' (the Pattern type is implemented in the C extension _sre but is exposed through the 're' module; its __module__ attribute is set to 're' to match the public API, aligning with re.Match.__module__ and the __module__ of all re functions)"
  category: module_attrs
  kind: python_call_eq
  function: "Pattern.__module__.__eq__"
  args: ["re"]
  expected: true

invariant re_extra110.compile.type_is_function:
  description: "type(re.compile).__name__ == 'function' (re.compile is a pure Python function defined in re/__init__.py, not a C builtin_function_or_method; all re module-level callables share this Python-level 'function' type)"
  category: module_attrs
  kind: python_call_eq
  function: "compile.__class__.__name__.__eq__"
  args: ["function"]
  expected: true

invariant re_extra110.module_names_all_len_2:
  description: "re.match.__module__.__len__() == 2 (the module name 're' is exactly 2 characters; every re function and type has __module__ equal to this 2-character string)"
  category: module_attrs
  kind: python_call_eq
  function: "match.__module__.__len__"
  args: []
  expected: 2
