spec: inspect_extra261
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect.zspec.zsdl — covers isfunction, isbuiltin, isclass, ismodule, isroutine, isgeneratorfunction, iscoroutinefunction, isasyncgenfunction, signature, getmembers, getdoc classname checks"
    - "inspect_extra.zspec.zsdl — covers ismethod, isgenerator, iscoroutine, getsourcefile __name__/__module__; behavioral checks"
    - "inspect_extra260.zspec.zsdl — covers stack, currentframe, getframeinfo, FrameInfo, iscoroutine, iscoroutinefunction, isawaitable"
  notes:
    - "inspect.getattr_static.__name__ == 'getattr_static'; __qualname__ == 'getattr_static'; __module__ == 'inspect'; __class__.__name__ == 'function'."
    - "inspect.getmro.__name__ == 'getmro'; __qualname__ == 'getmro'; __module__ == 'inspect'; __class__.__name__ == 'function'."
    - "inspect.classify_class_attrs.__name__ == 'classify_class_attrs'; __qualname__ == 'classify_class_attrs'; __module__ == 'inspect'; __class__.__name__ == 'function'."
    - "inspect.getdoc.__name__ == 'getdoc'; __qualname__ == 'getdoc'; __module__ == 'inspect'; __class__.__name__ == 'function'."
    - "inspect.getcomments.__name__ == 'getcomments'; __qualname__ == 'getcomments'; __module__ == 'inspect'; __class__.__name__ == 'function'."
    - "All five functions are Python-level functions (not C builtins): __class__.__name__ == 'function'."
    - "All values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ checks — five inspect utility functions
# ---------------------------------------------------------------------------

table inspect_extra261.function_names:
  description: "getattr_static, getmro, classify_class_attrs, getdoc, getcomments __name__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [getattr_static,        getattr_static.__name__.__eq__,        ["getattr_static"],        true]
    - [getmro,                getmro.__name__.__eq__,                ["getmro"],                true]
    - [classify_class_attrs,  classify_class_attrs.__name__.__eq__,  ["classify_class_attrs"],  true]
    - [getdoc,                getdoc.__name__.__eq__,                ["getdoc"],                true]
    - [getcomments,           getcomments.__name__.__eq__,           ["getcomments"],           true]

# ---------------------------------------------------------------------------
# __qualname__ checks — all five match __name__ (not nested)
# ---------------------------------------------------------------------------

table inspect_extra261.function_qualnames:
  description: "getattr_static, getmro, classify_class_attrs, getdoc, getcomments __qualname__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: fqname

  columns: [id, function, args, expected]
  rows:
    - [getattr_static,        getattr_static.__qualname__.__eq__,        ["getattr_static"],        true]
    - [getmro,                getmro.__qualname__.__eq__,                ["getmro"],                true]
    - [classify_class_attrs,  classify_class_attrs.__qualname__.__eq__,  ["classify_class_attrs"],  true]
    - [getdoc,                getdoc.__qualname__.__eq__,                ["getdoc"],                true]
    - [getcomments,           getcomments.__qualname__.__eq__,           ["getcomments"],           true]

# ---------------------------------------------------------------------------
# __module__ checks — all five belong to the 'inspect' module
# ---------------------------------------------------------------------------

table inspect_extra261.function_modules:
  description: "getattr_static, getmro, classify_class_attrs, getdoc, getcomments __module__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [getattr_static,        getattr_static.__module__.__eq__,        ["inspect"], true]
    - [getmro,                getmro.__module__.__eq__,                ["inspect"], true]
    - [classify_class_attrs,  classify_class_attrs.__module__.__eq__,  ["inspect"], true]
    - [getdoc,                getdoc.__module__.__eq__,                ["inspect"], true]
    - [getcomments,           getcomments.__module__.__eq__,           ["inspect"], true]

# ---------------------------------------------------------------------------
# __class__.__name__ checks — all five are Python-level functions
# ---------------------------------------------------------------------------

table inspect_extra261.function_class_names:
  description: "getattr_static, getmro, classify_class_attrs, getdoc, getcomments are Python functions"
  kind: python_call_eq
  category: identity
  id_prefix: fclass

  columns: [id, function, args, expected]
  rows:
    - [getattr_static,        getattr_static.__class__.__name__.__eq__,        ["function"], true]
    - [getmro,                getmro.__class__.__name__.__eq__,                ["function"], true]
    - [classify_class_attrs,  classify_class_attrs.__class__.__name__.__eq__,  ["function"], true]
    - [getdoc,                getdoc.__class__.__name__.__eq__,                ["function"], true]
    - [getcomments,           getcomments.__class__.__name__.__eq__,           ["function"], true]
