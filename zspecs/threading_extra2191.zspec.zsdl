spec: threading_extra2191
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2191: context manager protocol dict-presence checks — __enter__, __exit__, __aenter__, __aexit__, acquire, release, __wrapped__, __closure__."
    - "threading.Lock defines __enter__, __exit__, acquire, and release in its own __dict__; it is a full sync context manager."
    - "threading._RLock (pure Python RLock) defines __enter__, __exit__, acquire, and release in its own __dict__."
    - "threading._CRLock (C extension RLock) defines __enter__, __exit__, acquire, and release in its own __dict__."
    - "threading._LockType (C extension lock type) defines __enter__, __exit__, acquire, and release in its own __dict__."
    - "threading.Semaphore defines __enter__, __exit__, acquire, and release in its own __dict__."
    - "threading.BoundedSemaphore defines only release in its own __dict__; __enter__, __exit__, and acquire are NOT in its own __dict__ (inherited from Semaphore)."
    - "threading.Condition defines __enter__ and __exit__ in its own __dict__ but NOT acquire or release."
    - "threading.Thread, Event, and Barrier do NOT define any context manager or lock protocol methods in their own __dict__."
    - "None of the threading classes define __aenter__, __aexit__, __wrapped__, or __closure__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table threading_extra2191.lock_context_protocol:
  description: "threading.Lock dict-presence checks — Lock IS a full sync context manager with acquire/release"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2191

  columns: [id, function, args, expected]
  rows:
    - ["th2191001", "threading.Lock.__dict__.__contains__", ["__enter__"], true]
    - ["th2191002", "threading.Lock.__dict__.__contains__", ["__exit__"], true]
    - ["th2191003", "threading.Lock.__dict__.__contains__", ["__aenter__"], false]
    - ["th2191004", "threading.Lock.__dict__.__contains__", ["__aexit__"], false]
    - ["th2191005", "threading.Lock.__dict__.__contains__", ["acquire"], true]
    - ["th2191006", "threading.Lock.__dict__.__contains__", ["release"], true]
    - ["th2191007", "threading.Lock.__dict__.__contains__", ["__wrapped__"], false]
    - ["th2191008", "threading.Lock.__dict__.__contains__", ["__closure__"], false]

