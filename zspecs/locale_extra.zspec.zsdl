spec: locale_extra
version: ">=3.x"
backend: python_module(locale)

docs: https://docs.python.org/3/library/locale.html

provenance:
  derived_from:
    - "Python locale documentation — https://docs.python.org/3/library/locale.html"
    - "Test vectors verified by running Python 3.14.3 locale module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/locale.py"
  notes:
    - "This spec extends locale.zspec.zsdl with additional class identity and function name checks."
    - "locale.Error is a subclass of Exception and is raised when an unsupported locale is requested."
    - "locale.str is a module-level function (not the built-in str type) that formats a float using locale conventions."
    - "getdefaultlocale is deprecated in Python 3.11; its presence is tested here for completeness."
    - "resetlocale is deprecated in Python 3.11 and removed in Python 3.13."
    - "LC_ALL and LC_COLLATE are platform-specific integer constants."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "locale functions raise locale.Error (a subclass of Exception) when an unsupported locale is requested."
  stderr: "null"
  stickiness: "N/A"
  codes: {}

# ---------------------------------------------------------------------------
# Error class identity
# ---------------------------------------------------------------------------

invariant locale_extra.Error.class_name:
  description: "locale.Error.__name__ == 'Error'"
  category: classnames
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

invariant locale_extra.Error.base_class:
  description: "locale.Error.__bases__[0].__name__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

table locale_extra.func_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [setlocale,           "setlocale.__name__.__eq__",           ["setlocale"],           true]
    - [getlocale,           "getlocale.__name__.__eq__",           ["getlocale"],           true]
    - [getdefaultlocale,    "getdefaultlocale.__name__.__eq__",    ["getdefaultlocale"],    true]
    - [getpreferredencoding,"getpreferredencoding.__name__.__eq__",["getpreferredencoding"],true]
    - [normalize,           "normalize.__name__.__eq__",           ["normalize"],           true]
    - [resetlocale,         "resetlocale.__name__.__eq__",         ["resetlocale"],         true]
    - [format_string,       "format_string.__name__.__eq__",       ["format_string"],       true]
    - [currency,            "currency.__name__.__eq__",            ["currency"],            true]
    - [locale_str,          "str.__name__.__eq__",                 ["str"],                 true]
    - [atof,                "atof.__name__.__eq__",                ["atof"],                true]
    - [atoi,                "atoi.__name__.__eq__",                ["atoi"],                true]

# ---------------------------------------------------------------------------
# LC_* constants — integer type checks
# ---------------------------------------------------------------------------

invariant locale_extra.LC_ALL.is_int:
  description: "locale.LC_ALL.__class__.__name__ == 'int' — LC_ALL is a plain int"
  category: constants
  kind: python_call_eq
  function: "LC_ALL.__class__.__name__.__eq__"
  args: ["int"]
  expected: true

invariant locale_extra.LC_COLLATE.is_int:
  description: "locale.LC_COLLATE.__class__.__name__ == 'int' — LC_COLLATE is a plain int"
  category: constants
  kind: python_call_eq
  function: "LC_COLLATE.__class__.__name__.__eq__"
  args: ["int"]
  expected: true
