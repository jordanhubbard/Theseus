spec: asyncio_extra1861
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
  notes:
    - "Wave 571 theme: bitwise operators (__or__/__and__/__xor__/__invert__) and in-place operators (__iadd__/__imul__/__ior__)."
    - "asyncio.Future and asyncio.Task are C-accelerated types from _asyncio; no bitwise or in-place operator dunders in own __dict__."
    - "asyncio.Queue, asyncio.Lock, asyncio.Event, asyncio.Semaphore, asyncio.Condition are pure-Python classes; no bitwise or in-place operator dunders."
    - "asyncio module exports transport and protocol ABCs: BaseTransport, ReadTransport, WriteTransport, Transport, DatagramTransport, SubprocessTransport."
    - "asyncio module exports protocol ABCs: BaseProtocol, Protocol, DatagramProtocol, SubprocessProtocol."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: bitwise operators absent from asyncio class own __dict__
# ---------------------------------------------------------------------------

table asyncio_extra1861.bitwise_operators:
  description: "Bitwise operator dunder methods absent from asyncio class own __dict__"
  kind: python_call_eq
  category: bitwise_operators
  id_prefix: as1861

  columns: [id, function, args, expected]
  rows:
    - ["as1861001", asyncio.Future.__dict__.__contains__,    ["__or__"],   false]
    - ["as1861002", asyncio.Future.__dict__.__contains__,    ["__and__"],  false]
    - ["as1861003", asyncio.Future.__dict__.__contains__,    ["__xor__"],  false]
    - ["as1861004", asyncio.Task.__dict__.__contains__,      ["__or__"],   false]
    - ["as1861005", asyncio.Queue.__dict__.__contains__,     ["__or__"],   false]
    - ["as1861006", asyncio.Lock.__dict__.__contains__,      ["__or__"],   false]
    - ["as1861007", asyncio.Event.__dict__.__contains__,     ["__or__"],   false]
    - ["as1861008", asyncio.Semaphore.__dict__.__contains__,  ["__or__"],   false]

# ---------------------------------------------------------------------------
# Table 2: in-place operators absent from asyncio class own __dict__
# ---------------------------------------------------------------------------

table asyncio_extra1861.inplace_operators:
  description: "In-place operator dunder methods absent from asyncio class own __dict__"
  kind: python_call_eq
  category: inplace_operators
  id_prefix: as1861

  columns: [id, function, args, expected]
  rows:
    - ["as1861009", asyncio.Future.__dict__.__contains__,     ["__iadd__"], false]
    - ["as1861010", asyncio.Future.__dict__.__contains__,     ["__ior__"],  false]
    - ["as1861011", asyncio.Task.__dict__.__contains__,       ["__iadd__"], false]
    - ["as1861012", asyncio.Queue.__dict__.__contains__,      ["__iadd__"], false]
    - ["as1861013", asyncio.Lock.__dict__.__contains__,       ["__iadd__"], false]
    - ["as1861014", asyncio.Event.__dict__.__contains__,      ["__ior__"],  false]
    - ["as1861015", asyncio.Semaphore.__dict__.__contains__,  ["__iadd__"], false]
    - ["as1861016", asyncio.Condition.__dict__.__contains__,  ["__iadd__"], false]

# ---------------------------------------------------------------------------
# Table 3: asyncio transport and protocol ABCs present in asyncio module dict
# ---------------------------------------------------------------------------

table asyncio_extra1861.asyncio_transport_attrs:
  description: "asyncio transport and protocol ABCs exported at top-level asyncio module"
  kind: python_call_eq
  category: module_contents
  id_prefix: as1861

  columns: [id, function, args, expected]
  rows:
    - ["as1861017", asyncio.__dict__.__contains__, ["BaseTransport"],       true]
    - ["as1861018", asyncio.__dict__.__contains__, ["ReadTransport"],       true]
    - ["as1861019", asyncio.__dict__.__contains__, ["WriteTransport"],      true]
    - ["as1861020", asyncio.__dict__.__contains__, ["Transport"],           true]
    - ["as1861021", asyncio.__dict__.__contains__, ["DatagramTransport"],   true]
    - ["as1861022", asyncio.__dict__.__contains__, ["SubprocessTransport"], true]
    - ["as1861023", asyncio.__dict__.__contains__, ["BaseProtocol"],        true]
    - ["as1861024", asyncio.__dict__.__contains__, ["Protocol"],            true]
    - ["as1861025", asyncio.__dict__.__contains__, ["DatagramProtocol"],    true]
    - ["as1861026", asyncio.__dict__.__contains__, ["SubprocessProtocol"],  true]
