error_model:
  semantics: "Returns an array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table array_flatten.flatten:
  kind: node_module_call_eq
  function: ~
  category: array
  id_prefix: arrflat

  columns: [id, args, expected]
  rows:
    - [nested,   [[1, [2, [3]]]],         [1, 2, 3]]
    - [flat,     [[1, 2, 3]],             [1, 2, 3]]
    - [two_deep, [[[1, 2], [3, 4]]],      [1, 2, 3, 4]]

