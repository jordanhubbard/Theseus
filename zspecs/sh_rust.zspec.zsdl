spec: sh_rust
version: ">=3.9"
backend: rust_module(sh_rust)

docs: https://sh.readthedocs.io/en/latest/

provenance:
  derived_from:
    - "https://sh.readthedocs.io/en/latest/ — sh documentation"
  not_derived_from:
    - "sh source: sh.py"
  notes:
    - "sh allows calling shell programs as if they were functions."
    - "sh.echo('hello').strip() == 'hello'."
    - "sh.pwd() returns the current directory as a string."
    - "len(str(sh.echo('hello')).strip()) > 0."
    - "Expose sh_echo(text) -> str: sh.echo(text).strip()."
    - "Expose sh_echo_len_positive(text) -> bool: len(sh.echo(text).strip()) > 0."
    - "All test vectors verified against sh 2.2.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# sh_echo — echo command
table sh_rust.commands.echo:
  kind: python_call_eq
  category: echo
  id_prefix: sh_e
  function: sh_echo

  columns: [id, args, expected]
  rows:
    - [hello, ["hello"], "hello"]
    - [world, ["world"], "world"]

# sh_echo_len_positive — echo output non-empty
invariant sh_rust.commands.echo_len:
  description: "sh.echo('hello') has positive length"
  category: echo_len
  kind: python_call_eq
  function: sh_echo_len_positive
  args: ["hello"]
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T02:17:18Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
