spec: io_extra167
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/bytesio.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: io.BytesIO method __qualname__ values for read, write, getvalue, seek, tell, readline."
    - "All BytesIO method qualnames use the public class name 'BytesIO' (7 characters) as the prefix, plus a dot separator."
    - "The 'BytesIO.' prefix is 8 characters (7 chars for 'BytesIO' + 1 for '.')."
    - "io.BytesIO.read.__qualname__ == 'BytesIO.read' (len=12; 'BytesIO.' (8) + 'read' (4) = 12; tied with seek and tell at 12)."
    - "io.BytesIO.seek.__qualname__ == 'BytesIO.seek' (len=12; 'BytesIO.' (8) + 'seek' (4) = 12; tied with read and tell at 12)."
    - "io.BytesIO.tell.__qualname__ == 'BytesIO.tell' (len=12; 'BytesIO.' (8) + 'tell' (4) = 12; tied with read and seek at 12)."
    - "io.BytesIO.write.__qualname__ == 'BytesIO.write' (len=13; 'BytesIO.' (8) + 'write' (5) = 13; the sole occupant of length 13)."
    - "io.BytesIO.getvalue.__qualname__ == 'BytesIO.getvalue' (len=16; 'BytesIO.' (8) + 'getvalue' (8) = 16; tied with readline at 16)."
    - "io.BytesIO.readline.__qualname__ == 'BytesIO.readline' (len=16; 'BytesIO.' (8) + 'readline' (8) = 16; tied with getvalue at 16)."
    - "Three-way tie at 12: read, seek, tell — all 4-character method names."
    - "write stands alone at 13 — the only 5-character method name in this spec."
    - "Two-way tie at 16: getvalue and readline — both 8-character method names."
    - "Length ranking: read=seek=tell=12, write=13, getvalue=readline=16."
    - "Comparison with StringIO (from io_extra166): BytesIO qualnames are all exactly 1 character shorter than their StringIO counterparts because 'BytesIO' (7 chars) is 1 character shorter than 'StringIO' (8 chars), making the 'BytesIO.' prefix (8 chars) 1 char shorter than 'StringIO.' (9 chars)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BytesIO method __qualname__ values (group 1)
# read, seek, tell — all tied at length 12 (4-character method names).
# write — sole occupant of length 13 (5-character method name).
# All use 'BytesIO.' prefix (8 characters).
# ---------------------------------------------------------------------------

table io_extra167.BytesIO_method_qualnames_group1:
  description: "io.BytesIO method __qualname__ values: read=seek=tell='BytesIO.*' (len=12), write='BytesIO.write' (len=13); three-way tie at 12 for 4-char method names; write is the sole occupant at 13"
  kind: python_call_eq
  category: qualname
  id_prefix: bioq167

  columns: [id, function, args, expected, description]
  rows:
    - [bio_read_qeq,  BytesIO.read.__qualname__.__eq__,   ["BytesIO.read"],  true, "io.BytesIO.read.__qualname__ == 'BytesIO.read' (BytesIO.read() reads and returns at most size bytes from the in-memory buffer; with no argument or size=-1 reads all remaining content; returns a bytes object; 'BytesIO.read' has 12 characters: 'BytesIO.' (8) + 'read' (4) = 12; part of the three-way tie at 12 with seek and tell — all three have 4-character method names; BytesIO.read() is the primary way to extract bytes from a BytesIO buffer; compare with StringIO.read.__qualname__ == 'StringIO.read' (len=13) — one character longer due to 'StringIO.' (9 chars) vs 'BytesIO.' (8 chars))"]
    - [bio_seek_qeq,  BytesIO.seek.__qualname__.__eq__,   ["BytesIO.seek"],  true, "io.BytesIO.seek.__qualname__ == 'BytesIO.seek' (BytesIO.seek() sets the stream position within the in-memory bytes buffer; seek(0) rewinds to the beginning for rereading; accepts whence=0 (absolute), 1 (relative), 2 (from end); 'BytesIO.seek' has 12 characters: 'BytesIO.' (8) + 'seek' (4) = 12; tied with read and tell at length 12; all three share the same 4-character method name length; 'BytesIO.seek' (12) is 1 shorter than 'StringIO.seek' (13) — the only difference is the class name prefix length)"]
    - [bio_tell_qeq,  BytesIO.tell.__qualname__.__eq__,   ["BytesIO.tell"],  true, "io.BytesIO.tell.__qualname__ == 'BytesIO.tell' (BytesIO.tell() returns the current stream position as an integer byte offset from the beginning of the bytes buffer; 'BytesIO.tell' has 12 characters: 'BytesIO.' (8) + 'tell' (4) = 12; tied with read and seek at length 12; the three-way tie at 12 reflects that 'read', 'seek', and 'tell' all have exactly 4 characters; 'BytesIO.tell' (12) vs 'StringIO.tell' (13) — one shorter because 'BytesIO.' (8) < 'StringIO.' (9) by one character)"]
    - [bio_write_qeq, BytesIO.write.__qualname__.__eq__,  ["BytesIO.write"], true, "io.BytesIO.write.__qualname__ == 'BytesIO.write' (BytesIO.write() writes the given bytes-like object to the in-memory buffer and returns the number of bytes written; BytesIO.write() accepts bytes, bytearray, or any bytes-like object; 'BytesIO.write' has 13 characters: 'BytesIO.' (8) + 'write' (5) = 13; write is the sole occupant of length 13 — the only 5-character method name among the six covered; 'BytesIO.write' (13) is exactly 1 shorter than 'StringIO.write' (14) due to the same prefix length difference)"]

# ---------------------------------------------------------------------------
# io.BytesIO method __qualname__ values (group 2)
# getvalue, readline — both tied at length 16 (8-character method names).
# The two longest BytesIO method qualnames in this spec.
# ---------------------------------------------------------------------------

table io_extra167.BytesIO_method_qualnames_group2:
  description: "io.BytesIO method __qualname__ values: getvalue='BytesIO.getvalue' (len=16), readline='BytesIO.readline' (len=16); two-way tie at 16 — both 8-character method names; the longest BytesIO method qualnames in this spec"
  kind: python_call_eq
  category: qualname
  id_prefix: bioq167

  columns: [id, function, args, expected, description]
  rows:
    - [bio_getvalue_qeq,  BytesIO.getvalue.__qualname__.__eq__,   ["BytesIO.getvalue"],  true, "io.BytesIO.getvalue.__qualname__ == 'BytesIO.getvalue' (BytesIO.getvalue() returns the entire contents of the in-memory buffer as a bytes object, regardless of the current stream position; unlike read(), getvalue() does not advance the position and always returns all content; 'BytesIO.getvalue' has 16 characters: 'BytesIO.' (8) + 'getvalue' (8) = 16; tied with 'BytesIO.readline' (also 16) — both have 8-character names; 'BytesIO.getvalue' (16) is exactly 1 shorter than 'StringIO.getvalue' (17) due to the prefix length difference)"]
    - [bio_readline_qeq,  BytesIO.readline.__qualname__.__eq__,   ["BytesIO.readline"],  true, "io.BytesIO.readline.__qualname__ == 'BytesIO.readline' (BytesIO.readline() reads one line from the in-memory bytes buffer, up to and including the newline byte (0x0a); if size is specified reads at most size bytes; returns a bytes object; 'BytesIO.readline' has 16 characters: 'BytesIO.' (8) + 'readline' (8) = 16; tied with 'BytesIO.getvalue' (also 16); 'BytesIO.readline' (16) vs 'StringIO.readline' (17) — one shorter because the 'BytesIO.' prefix (8) is one character shorter than the 'StringIO.' prefix (9))"]
    - [bio_getvalue_qlen, BytesIO.getvalue.__qualname__.__len__,  [],                    16,   "io.BytesIO.getvalue.__qualname__.__len__() == 16 ('BytesIO.getvalue' has 16 characters: 'BytesIO.' (8) + 'getvalue' (8) = 16; tied with 'BytesIO.readline' (also 16); both getvalue and readline have 8-character method names, producing the same qualname length; 16 is the maximum qualname length in this spec; complete length ranking: read=seek=tell=12, write=13, getvalue=readline=16; compare: StringIO.getvalue (17) and StringIO.readline (17) — both BytesIO counterparts are exactly 1 shorter)"]
    - [bio_readline_qlen, BytesIO.readline.__qualname__.__len__,  [],                    16,   "io.BytesIO.readline.__qualname__.__len__() == 16 ('BytesIO.readline' has 16 characters: 'BytesIO.' (8) + 'readline' (8) = 16; tied with 'BytesIO.getvalue' (also 16); 16 is the longest BytesIO method qualname in this spec; the complete ascending order: read=seek=tell=12, write=13, getvalue=readline=16; the systematic 1-character shortening vs StringIO: BytesIO prefix (8) < StringIO prefix (9) by 1, so every corresponding qualname is exactly 1 shorter across all six methods)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra167.BytesIO_read_seek_tell_three_way_tie_at_12:
  description: "io.BytesIO.read.__qualname__.__len__() == 12 — 'BytesIO.read' has 12 characters: 'BytesIO.' (8) + 'read' (4) = 12; read is part of a three-way tie at 12 with seek (also 12) and tell (also 12); the three-way tie at 12 occurs because read, seek, and tell are all exactly 4-character method names; this mirrors the three-way tie at 13 for StringIO.read/seek/tell from io_extra166 — BytesIO qualnames are exactly 1 shorter because 'BytesIO.' (8 chars) < 'StringIO.' (9 chars) by 1; complete length ranking: read=seek=tell=12, write=13, getvalue=readline=16; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: BytesIO.read.__qualname__.__len__
  args: []
  expected: 12

invariant io_extra167.BytesIO_write_is_sole_at_13:
  description: "io.BytesIO.write.__qualname__.__len__() == 13 — 'BytesIO.write' has 13 characters: 'BytesIO.' (8) + 'write' (5) = 13; write is the sole occupant of length 13 in this spec — the only 5-character method name among the six covered; it falls between the three-way tie at 12 (read, seek, tell) and the two-way tie at 16 (getvalue, readline); 'BytesIO.write' (13) is exactly 1 shorter than 'StringIO.write' (14) from io_extra166; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: BytesIO.write.__qualname__.__len__
  args: []
  expected: 13

invariant io_extra167.BytesIO_getvalue_readline_tied_at_16:
  description: "io.BytesIO.getvalue.__qualname__.__len__() == 16 — 'BytesIO.getvalue' has 16 characters: 'BytesIO.' (8) + 'getvalue' (8) = 16; tied with 'BytesIO.readline' (also 16: 'BytesIO.' (8) + 'readline' (8) = 16); getvalue and readline are tied because both have 8-character method names; 16 is the maximum qualname length in this spec; compare with StringIO: 'StringIO.getvalue' (17) and 'StringIO.readline' (17) — BytesIO counterparts are each exactly 1 shorter; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: BytesIO.getvalue.__qualname__.__len__
  args: []
  expected: 16

invariant io_extra167.BytesIO_getvalue_qualname_eq:
  description: "io.BytesIO.getvalue.__qualname__ == 'BytesIO.getvalue' — getvalue() is the BytesIO-specific method with no direct counterpart on RawIOBase or FileIO; it returns the entire buffer contents regardless of position; its qualname uses the public class name 'BytesIO' (7 chars) + '.' (1) + 'getvalue' (8) = 16 characters total; 'BytesIO.getvalue' (16) matches 'BytesIO.readline' (16) — both are the longest BytesIO method qualnames in this spec; 'BytesIO.getvalue' is exactly 1 shorter than 'StringIO.getvalue' (17) from io_extra166; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: BytesIO.getvalue.__qualname__.__eq__
  args: ["BytesIO.getvalue"]
  expected: true

