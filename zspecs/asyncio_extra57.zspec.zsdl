spec: asyncio_extra57
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio queue documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/__init__.py"
  notes:
    - "This spec extends asyncio_extra56.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__()==13, Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__(), InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__.__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, Queue/Lock method qualname string equality, asyncio class __module__ string equality (extra52), Queue/Lock __doc__/__class__/__name__=='str' (extra50), asyncio.__all__.__class__.__name__=='list' (extra51 — recorded as 'list'; actual value in Python 3.14.3 is 'tuple'), gather/sleep/__qualname__.__eq__ (extra3/extra22/extra26/extra28/extra43), Queue/__name__.__eq__ (extra/extra2/extra5), Lock/__name__.__eq__ (extra/extra2/extra5), run/__qualname__.__eq__('run') (extra6/extra22/extra43), Condition/__name__/__qualname__/__len__() (extra53), BoundedSemaphore/__name__/__qualname__/__len__() (extra53), run/__name__.__eq__('run') (extra53), BoundedSemaphore/__bases__[0].__qualname__=='Semaphore' (extra53), Condition/__bases__[0].__qualname__=='object' (extra53), class __dict__.__class__.__name__/__qualname__ == 'mappingproxy' (extra54), class __class__.__module__.__eq__('builtins') for Queue/Lock/Event/Semaphore/Condition (extra55), gather/sleep/wait __class__.__module__.__eq__('builtins') (extra55), Queue/Lock/Event/Semaphore/Condition __init__.__class__.__name__.__eq__('function') (extra55), class __repr__.__class__.__name__ for Queue/Lock/Event/Semaphore (extra56), class __weakref__.__class__.__name__ for Queue/Lock/Event/Semaphore (extra56), gather/sleep/wait function __repr__.__class__.__name__ (extra56)."
    - "This spec covers (asyncioall57 namespace): asyncio.__all__.__class__.__name__.__eq__('tuple') — asyncio.__all__ is a tuple in Python 3.14.3 (95 items); __class__.__name__ == 'tuple'; __eq__('tuple') returns True. asyncio.__all__.__len__()==95 cross-check via __eq__ on the int. Queue/Lock/Event/Semaphore __eq__.__class__.__name__.__eq__('wrapper_descriptor') — these pure-Python asyncio classes do not define custom __eq__; they inherit object.__eq__ which is a C-level slot wrapper; __class__.__name__ == 'wrapper_descriptor'. Queue/Lock/Event __subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') — __subclasshook__ is inherited from object; object.__subclasshook__ is a classmethod whose underlying function is a C built-in; __class__.__name__ == 'builtin_function_or_method'. No prior asyncio spec has captured __eq__.__class__.__name__ or __subclasshook__.__class__.__name__ as string equality checks."
    - "asyncio.__all__.__class__.__name__ == 'tuple'. In Python 3.14.3, asyncio.__all__ is a tuple of 95 exported names. A tuple is a built-in type; __class__.__name__ == 'tuple'. Note: asyncio_extra51 recorded __all__.__class__.__name__.__eq__('list') as expected: true, but actual Python 3.14.3 behavior returns False for that call ('list' != 'tuple'). This spec records the correct value: __eq__('tuple') returns True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__eq__.__class__.__name__ == 'wrapper_descriptor'. Queue is a pure-Python class defined in Lib/asyncio/queues.py. It does not define a custom __eq__ method; it inherits object.__eq__, which is a C-level slot wrapper (wrapper_descriptor). No prior asyncio spec has captured __eq__.__class__.__name__ as a string equality check. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__eq__.__class__.__name__ == 'wrapper_descriptor'. Lock is a pure-Python class defined in Lib/asyncio/locks.py. It does not define __eq__; it inherits object.__eq__ (C-level slot wrapper). __eq__.__class__.__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__eq__.__class__.__name__ == 'wrapper_descriptor'. Event is a pure-Python class in Lib/asyncio/locks.py. It inherits object.__eq__ (C-level slot wrapper); __eq__.__class__.__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.__eq__.__class__.__name__ == 'wrapper_descriptor'. Semaphore is a pure-Python class in Lib/asyncio/locks.py. It inherits object.__eq__ (C-level slot wrapper); __eq__.__class__.__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. __subclasshook__ is a classmethod defined on object in C. When accessed on Queue (which inherits from object), __subclasshook__ is a bound C built-in method; its __class__.__name__ == 'builtin_function_or_method'. No prior asyncio spec captured __subclasshook__.__class__.__name__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. Lock inherits __subclasshook__ from object (C classmethod); __class__.__name__ == 'builtin_function_or_method'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. Event inherits __subclasshook__ from object (C classmethod); __class__.__name__ == 'builtin_function_or_method'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.__all__ container type string equality — extra57
#
# In Python 3.14.3, asyncio.__all__ is a tuple (95 items), not a list.
# Checking __class__.__name__.__eq__('tuple') returns True.
# Checking __class__.__name__.__eq__('list') returns False.
#
# No prior asyncio spec has captured __all__.__class__.__name__.__eq__('tuple').
# (asyncio_extra51 recorded __eq__('list') as true, which is incorrect for
# Python 3.14.3 where the actual type is tuple.)
#
# Extra57 introduces the corrected tuple type check in the asyncioall57 namespace.
# ---------------------------------------------------------------------------

table asyncio_extra57.all_class_name_eq:
  description: "asyncio.__all__ container type string equality in asyncioall57 namespace — __all__ is a tuple in Python 3.14.3 (95 items); __class__.__name__.__eq__('tuple') returns True; __eq__('list') returns False; no prior asyncio spec captured the tuple type equality"
  kind: python_call_eq
  category: class_names
  id_prefix: asyncioall57alltype

  columns: [id, function, args, expected, description]
  rows:
    - [all_is_tuple, __all__.__class__.__name__.__eq__, ["tuple"], true,  "asyncio.__all__.__class__.__name__ == 'tuple' — asyncio.__all__ is a tuple of 95 exported names in Python 3.14.3; tuple is a built-in type; __class__.__name__ == 'tuple'; __eq__('tuple') returns True"]
    - [all_not_list, __all__.__class__.__name__.__eq__, ["list"],  false, "asyncio.__all__.__class__.__name__.__eq__('list') returns False — asyncio.__all__ is a tuple, not a list; 'tuple' != 'list'"]

# ---------------------------------------------------------------------------
# asyncio Queue/Lock/Event/Semaphore __eq__.__class__.__name__ — extra57
#
# Queue, Lock, Event, and Semaphore are pure-Python classes in Lib/asyncio.
# None of them define a custom __eq__ method. They inherit object.__eq__,
# which is a C-level slot wrapper (wrapper_descriptor):
#   Queue.__eq__.__class__.__name__     == 'wrapper_descriptor'
#   Lock.__eq__.__class__.__name__      == 'wrapper_descriptor'
#   Event.__eq__.__class__.__name__     == 'wrapper_descriptor'
#   Semaphore.__eq__.__class__.__name__ == 'wrapper_descriptor'
#
# No prior asyncio spec has captured __eq__.__class__.__name__ as a string
# equality check. Extra57 introduces this dimension in the asyncioall57 namespace.
# ---------------------------------------------------------------------------

table asyncio_extra57.eq_class_name_eq:
  description: "asyncio Queue/Lock/Event/Semaphore __eq__.__class__.__name__ in asyncioall57 namespace — these pure-Python classes inherit object.__eq__ (C-level slot wrapper); __eq__.__class__.__name__ == 'wrapper_descriptor'; no prior asyncio spec captured __eq__.__class__.__name__ as string equality"
  kind: python_call_eq
  category: class_names
  id_prefix: asyncioall57eqname

  columns: [id, function, args, expected, description]
  rows:
    - [Queue,     Queue.__eq__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true, "Queue.__eq__.__class__.__name__ == 'wrapper_descriptor' — Queue inherits object.__eq__ which is a C-level slot wrapper; Queue defines no custom __eq__; first __eq__.__class__.__name__ check in any asyncio spec"]
    - [Lock,      Lock.__eq__.__class__.__name__.__eq__,      ["wrapper_descriptor"], true, "Lock.__eq__.__class__.__name__ == 'wrapper_descriptor' — Lock inherits object.__eq__ (C-level slot wrapper); Lock defines no custom __eq__"]
    - [Event,     Event.__eq__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true, "Event.__eq__.__class__.__name__ == 'wrapper_descriptor' — Event inherits object.__eq__ (C-level slot wrapper); Event defines no custom __eq__"]
    - [Semaphore, Semaphore.__eq__.__class__.__name__.__eq__, ["wrapper_descriptor"], true, "Semaphore.__eq__.__class__.__name__ == 'wrapper_descriptor' — Semaphore inherits object.__eq__ (C-level slot wrapper); Semaphore defines no custom __eq__"]

# ---------------------------------------------------------------------------
# asyncio Queue/Lock/Event __subclasshook__.__class__.__name__ — extra57
#
# __subclasshook__ is a classmethod defined on object in C. When accessed on
# a pure-Python class that inherits from object (without overriding
# __subclasshook__), it is a bound C built-in method:
#   Queue.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'
#   Lock.__subclasshook__.__class__.__name__  == 'builtin_function_or_method'
#   Event.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'
#
# No prior asyncio spec has captured __subclasshook__.__class__.__name__.
# Extra57 introduces this dimension in the asyncioall57 namespace.
# ---------------------------------------------------------------------------

table asyncio_extra57.subclasshook_class_name_eq:
  description: "asyncio Queue/Lock/Event __subclasshook__.__class__.__name__ in asyncioall57 namespace — __subclasshook__ is inherited from object (C classmethod); accessed on pure-Python asyncio classes it is a bound C built-in method; __class__.__name__ == 'builtin_function_or_method'; no prior asyncio spec captured __subclasshook__.__class__.__name__"
  kind: python_call_eq
  category: class_names
  id_prefix: asyncioall57subhook

  columns: [id, function, args, expected, description]
  rows:
    - [Queue, Queue.__subclasshook__.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "Queue.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — Queue inherits __subclasshook__ from object (C classmethod); the bound C method's __class__.__name__ == 'builtin_function_or_method'; first __subclasshook__.__class__.__name__ check in any asyncio spec"]
    - [Lock,  Lock.__subclasshook__.__class__.__name__.__eq__,  ["builtin_function_or_method"], true, "Lock.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — Lock inherits __subclasshook__ from object (C classmethod); bound C method's __class__.__name__ == 'builtin_function_or_method'"]
    - [Event, Event.__subclasshook__.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "Event.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — Event inherits __subclasshook__ from object (C classmethod); bound C method's __class__.__name__ == 'builtin_function_or_method'"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra57
# ---------------------------------------------------------------------------

invariant asyncio_extra57.all_class_name_tuple_eq:
  description: "asyncio.__all__.__class__.__name__ == 'tuple' — asyncio.__all__ is a tuple of 95 exported names in Python 3.14.3; tuple is a built-in type; __class__.__name__ == 'tuple'; __eq__('tuple') returns True; first correct __all__ container-type equality check in any asyncio spec"
  category: class_names
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant asyncio_extra57.Queue_eq_class_name_eq:
  description: "asyncio.Queue.__eq__.__class__.__name__ == 'wrapper_descriptor' — Queue inherits object.__eq__ which is a C-level slot wrapper (wrapper_descriptor); Queue defines no custom __eq__; first __eq__.__class__.__name__ equality check in any asyncio spec"
  category: class_names
  kind: python_call_eq
  function: Queue.__eq__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant asyncio_extra57.Lock_eq_class_name_eq:
  description: "asyncio.Lock.__eq__.__class__.__name__ == 'wrapper_descriptor' — Lock inherits object.__eq__ (C-level slot wrapper); Lock defines no custom __eq__; novel __eq__.__class__.__name__ check for Lock"
  category: class_names
  kind: python_call_eq
  function: Lock.__eq__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant asyncio_extra57.Queue_subclasshook_class_name_eq:
  description: "asyncio.Queue.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — Queue inherits __subclasshook__ from object (C classmethod); bound C method's __class__.__name__ == 'builtin_function_or_method'; first __subclasshook__.__class__.__name__ check in any asyncio spec"
  category: class_names
  kind: python_call_eq
  function: Queue.__subclasshook__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant asyncio_extra57.Lock_subclasshook_class_name_eq:
  description: "asyncio.Lock.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — Lock inherits __subclasshook__ from object (C classmethod); bound C method's __class__.__name__ == 'builtin_function_or_method'; novel __subclasshook__.__class__.__name__ check for Lock"
  category: class_names
  kind: python_call_eq
  function: Lock.__subclasshook__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
