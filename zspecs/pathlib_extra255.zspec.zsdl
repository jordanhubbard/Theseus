spec: pathlib_extra255
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "This spec covers pathlib class identity: PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath — __name__, __module__, and __bases__[0].__name__ for each."
    - "pathlib.PurePath.__bases__[0].__name__ == 'object' — PurePath is the root of the pathlib hierarchy; it inherits directly from object."
    - "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' — PurePosixPath inherits from PurePath; it provides POSIX path semantics without filesystem access."
    - "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' — PureWindowsPath inherits from PurePath; it provides Windows path semantics without filesystem access."
    - "pathlib.Path.__bases__[0].__name__ == 'PurePath' — on Python 3.12+ Path inherits directly from PurePath (not from PurePosixPath or PureWindowsPath at the class level); the concrete platform-specific class is selected at instantiation time."
    - "pathlib.PosixPath.__bases__: ['Path', 'PurePosixPath'] — PosixPath has two bases: Path (for the concrete filesystem operations) and PurePosixPath (for POSIX semantics); __bases__[0].__name__ is 'Path', __bases__[1].__name__ is 'PurePosixPath'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib class hierarchy — __name__ values
#
# All five public pathlib classes have __name__ equal to their unqualified
# class name. Covers: PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath.
# ---------------------------------------------------------------------------

table pathlib_extra255.class_names:
  description: "pathlib class hierarchy __name__ values — PurePath through PosixPath"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibxn255

  columns: [id, function, args, expected, description]
  rows:
    - [purepath_name,
       "PurePath.__name__.__eq__",
       ["PurePath"],
       true,
       "pathlib.PurePath.__name__.__eq__('PurePath') == True — PurePath is the root abstract class of the pathlib hierarchy, providing pure path manipulation without filesystem access; its unqualified class name is 'PurePath'; str.__eq__('PurePath') returns True; new to extra255"]
    - [pureposixpath_name,
       "PurePosixPath.__name__.__eq__",
       ["PurePosixPath"],
       true,
       "pathlib.PurePosixPath.__name__.__eq__('PurePosixPath') == True — PurePosixPath is the POSIX-flavoured pure path class (no filesystem access); its unqualified class name is 'PurePosixPath'; str.__eq__('PurePosixPath') returns True; new to extra255"]
    - [purewindowspath_name,
       "PureWindowsPath.__name__.__eq__",
       ["PureWindowsPath"],
       true,
       "pathlib.PureWindowsPath.__name__.__eq__('PureWindowsPath') == True — PureWindowsPath is the Windows-flavoured pure path class (no filesystem access); its unqualified class name is 'PureWindowsPath'; str.__eq__('PureWindowsPath') returns True; new to extra255"]
    - [path_name,
       "Path.__name__.__eq__",
       ["Path"],
       true,
       "pathlib.Path.__name__.__eq__('Path') == True — Path is the concrete path class providing filesystem operations; its unqualified class name is 'Path'; str.__eq__('Path') returns True; new to extra255"]
    - [posixpath_name,
       "PosixPath.__name__.__eq__",
       ["PosixPath"],
       true,
       "pathlib.PosixPath.__name__.__eq__('PosixPath') == True — PosixPath is the concrete POSIX filesystem path class instantiated on POSIX systems; its unqualified class name is 'PosixPath'; str.__eq__('PosixPath') returns True; new to extra255"]

# ---------------------------------------------------------------------------
# Table 2: pathlib class hierarchy — __module__ values
#
# All five public pathlib classes have __module__ == 'pathlib'.
# ---------------------------------------------------------------------------

table pathlib_extra255.class_modules:
  description: "pathlib class hierarchy __module__ values — all five classes have module 'pathlib'"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibxm255

  columns: [id, function, args, expected, description]
  rows:
    - [purepath_module,
       "PurePath.__module__.__eq__",
       ["pathlib"],
       true,
       "pathlib.PurePath.__module__.__eq__('pathlib') == True — PurePath is defined in the pathlib module; its __module__ is 'pathlib'; str.__eq__('pathlib') returns True; new to extra255"]
    - [pureposixpath_module,
       "PurePosixPath.__module__.__eq__",
       ["pathlib"],
       true,
       "pathlib.PurePosixPath.__module__.__eq__('pathlib') == True — PurePosixPath is defined in the pathlib module; its __module__ is 'pathlib'; str.__eq__('pathlib') returns True; new to extra255"]
    - [purewindowspath_module,
       "PureWindowsPath.__module__.__eq__",
       ["pathlib"],
       true,
       "pathlib.PureWindowsPath.__module__.__eq__('pathlib') == True — PureWindowsPath is defined in the pathlib module; its __module__ is 'pathlib'; str.__eq__('pathlib') returns True; new to extra255"]
    - [path_module,
       "Path.__module__.__eq__",
       ["pathlib"],
       true,
       "pathlib.Path.__module__.__eq__('pathlib') == True — Path is defined in the pathlib module; its __module__ is 'pathlib'; str.__eq__('pathlib') returns True; new to extra255"]
    - [posixpath_module,
       "PosixPath.__module__.__eq__",
       ["pathlib"],
       true,
       "pathlib.PosixPath.__module__.__eq__('pathlib') == True — PosixPath is defined in the pathlib module; its __module__ is 'pathlib'; str.__eq__('pathlib') returns True; new to extra255"]

# ---------------------------------------------------------------------------
# Table 3: pathlib class hierarchy — __bases__[0].__name__ values
#
# Direct base class (index 0 in __bases__) for each pathlib class.
# PurePath -> object; PurePosixPath -> PurePath; PureWindowsPath -> PurePath;
# Path -> PurePath; PosixPath -> Path (with PurePosixPath as __bases__[1]).
#
# YAML quoting: all function fields containing "[" must be double-quoted.
# ---------------------------------------------------------------------------

table pathlib_extra255.class_bases:
  description: "pathlib class hierarchy __bases__[0].__name__ values — inheritance chain from PurePath to PosixPath"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibxb255

  columns: [id, function, args, expected, description]
  rows:
    - [purepath_base,
       "PurePath.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "pathlib.PurePath.__bases__[0].__name__.__eq__('object') == True — PurePath is the root of the pathlib hierarchy and inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra255"]
    - [pureposixpath_base,
       "PurePosixPath.__bases__[0].__name__.__eq__",
       ["PurePath"],
       true,
       "pathlib.PurePosixPath.__bases__[0].__name__.__eq__('PurePath') == True — PurePosixPath inherits from PurePath, adding POSIX-specific path handling (forward slashes, case-sensitive); __bases__[0].__name__ is 'PurePath'; str.__eq__('PurePath') returns True; new to extra255"]
    - [purewindowspath_base,
       "PureWindowsPath.__bases__[0].__name__.__eq__",
       ["PurePath"],
       true,
       "pathlib.PureWindowsPath.__bases__[0].__name__.__eq__('PurePath') == True — PureWindowsPath inherits from PurePath, adding Windows-specific path handling (backslashes, drive letters, case-insensitive); __bases__[0].__name__ is 'PurePath'; str.__eq__('PurePath') returns True; new to extra255"]
    - [path_base,
       "Path.__bases__[0].__name__.__eq__",
       ["PurePath"],
       true,
       "pathlib.Path.__bases__[0].__name__.__eq__('PurePath') == True — Path inherits from PurePath and adds concrete filesystem operations; on Python 3.12+ Path's __bases__[0] is PurePath directly; __bases__[0].__name__ is 'PurePath'; str.__eq__('PurePath') returns True; new to extra255"]
    - [posixpath_base,
       "PosixPath.__bases__[0].__name__.__eq__",
       ["Path"],
       true,
       "pathlib.PosixPath.__bases__[0].__name__.__eq__('Path') == True — PosixPath has two bases: Path (index 0) for concrete filesystem operations and PurePosixPath (index 1) for POSIX semantics; __bases__[0].__name__ is 'Path'; str.__eq__('Path') returns True; new to extra255"]

# ---------------------------------------------------------------------------
# Table 4: PosixPath second base — __bases__[1].__name__
#
# PosixPath uses multiple inheritance: Path for filesystem ops and
# PurePosixPath for POSIX-specific semantics. __bases__[1].__name__ is
# 'PurePosixPath'. This is unique in the pathlib hierarchy.
# ---------------------------------------------------------------------------

table pathlib_extra255.posixpath_second_base:
  description: "pathlib.PosixPath.__bases__[1].__name__ == 'PurePosixPath' — multiple inheritance; cross-checks"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibpsb255

  columns: [id, function, args, expected, description]
  rows:
    - [posixpath_base1,
       "PosixPath.__bases__[1].__name__.__eq__",
       ["PurePosixPath"],
       true,
       "pathlib.PosixPath.__bases__[1].__name__.__eq__('PurePosixPath') == True — PosixPath uses multiple inheritance; its second base (index 1) is PurePosixPath, which supplies the POSIX-flavoured pure path behavior; __bases__[1].__name__ is 'PurePosixPath'; str.__eq__('PurePosixPath') returns True; new to extra255"]
    - [posixpath_base0_xcheck,
       "PosixPath.__bases__[0].__name__.__eq__",
       ["Path"],
       true,
       "pathlib.PosixPath.__bases__[0].__name__.__eq__('Path') == True — cross-check confirming PosixPath's first base is Path (supplying concrete filesystem operations); __bases__[0].__name__ is 'Path'; str.__eq__('Path') returns True; new to extra255"]
    - [pureposixpath_base_xcheck,
       "PurePosixPath.__bases__[0].__name__.__eq__",
       ["PurePath"],
       true,
       "pathlib.PurePosixPath.__bases__[0].__name__.__eq__('PurePath') == True — cross-check confirming PurePosixPath inherits from PurePath; __bases__[0].__name__ is 'PurePath'; str.__eq__('PurePath') returns True; new to extra255"]
    - [purepath_base_xcheck,
       "PurePath.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "pathlib.PurePath.__bases__[0].__name__.__eq__('object') == True — cross-check confirming PurePath is the hierarchy root; its only base is object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra255"]

# ---------------------------------------------------------------------------
# Standalone invariants — pathlib_extra255
# ---------------------------------------------------------------------------

invariant pathlib_extra255.purepath_name:
  description: "pathlib.PurePath.__name__ == 'PurePath' — PurePath is the root of the pathlib hierarchy; new to extra255"
  kind: python_call_eq
  function: PurePath.__name__.__eq__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra255.purepath_module:
  description: "pathlib.PurePath.__module__ == 'pathlib' — PurePath is defined in the pathlib module; new to extra255"
  kind: python_call_eq
  function: PurePath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra255.pureposixpath_inherits_purepath:
  description: "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' — PurePosixPath adds POSIX semantics on top of PurePath; new to extra255"
  kind: python_call_eq
  function: "PurePosixPath.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra255.path_inherits_purepath:
  description: "pathlib.Path.__bases__[0].__name__ == 'PurePath' — Path adds concrete filesystem ops to PurePath; new to extra255"
  kind: python_call_eq
  function: "Path.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra255.posixpath_module:
  description: "pathlib.PosixPath.__module__ == 'pathlib' — PosixPath is defined in the pathlib module; new to extra255"
  kind: python_call_eq
  function: PosixPath.__module__.__eq__
  args: ["pathlib"]
  expected: true
