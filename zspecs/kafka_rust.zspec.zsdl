spec: kafka_rust
version: ">=3.9"
backend: rust_module(kafka_rust)

docs: https://kafka-python.readthedocs.io/en/master/

provenance:
  derived_from:
    - "https://kafka-python.readthedocs.io/en/master/ — kafka-python documentation"
  not_derived_from:
    - "kafka source: kafka/__init__.py"
  notes:
    - "kafka-python is a Python client for Apache Kafka."
    - "kafka.KafkaProducer is available."
    - "kafka.KafkaConsumer is available."
    - "kafka.KafkaProducer.__name__ == 'KafkaProducer'."
    - "kafka.KafkaConsumer.__name__ == 'KafkaConsumer'."
    - "Expose kafka_producer_name() -> str: kafka.KafkaProducer.__name__."
    - "Expose kafka_consumer_name() -> str: kafka.KafkaConsumer.__name__."
    - "Expose kafka_has_admin_client() -> bool: hasattr(kafka, 'KafkaAdminClient')."
    - "All test vectors verified against kafka-python 2.0.6."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# kafka_producer_name — KafkaProducer class name
invariant kafka_rust.producer.class_name:
  description: "kafka.KafkaProducer.__name__ == 'KafkaProducer'"
  category: producer
  kind: python_call_eq
  function: kafka_producer_name
  args: []
  expected: "KafkaProducer"

# kafka_consumer_name — KafkaConsumer class name
invariant kafka_rust.consumer.class_name:
  description: "kafka.KafkaConsumer.__name__ == 'KafkaConsumer'"
  category: consumer
  kind: python_call_eq
  function: kafka_consumer_name
  args: []
  expected: "KafkaConsumer"

# kafka_has_admin_client — KafkaAdminClient present
invariant kafka_rust.admin.has_client:
  description: "kafka.KafkaAdminClient is available"
  category: admin
  kind: python_call_eq
  function: kafka_has_admin_client
  args: []
  expected: true

