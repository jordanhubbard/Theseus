spec: io_extra294
version: ">=3.9"
backend: python_module(io)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — BufferedReader, BufferedWriter, BufferedRandom method identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/bufferedio.c"
  notes:
    - "io.BufferedRandom.__bases__[0].__name__ == '_BufferedIOBase' (not 'BufferedWriter') verified at runtime"
    - "io.BufferedRandom.__module__ == '_io' verified at runtime"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table io_extra294.buffered_reader_qualnames:
  description: "BufferedReader method __qualname__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: ior294

  columns: [id, function, args, expected, description]
  rows:
    - [ior294_001, io.BufferedReader.read.__qualname__.__eq__, ["BufferedReader.read"], true, "BufferedReader.read qualname"]
    - [ior294_002, io.BufferedReader.read1.__qualname__.__eq__, ["BufferedReader.read1"], true, "BufferedReader.read1 qualname"]
    - [ior294_003, io.BufferedReader.readline.__qualname__.__eq__, ["BufferedReader.readline"], true, "BufferedReader.readline qualname"]
    - [ior294_004, io.BufferedReader.peek.__qualname__.__eq__, ["BufferedReader.peek"], true, "BufferedReader.peek qualname"]
    - [ior294_005, io.BufferedReader.seek.__qualname__.__eq__, ["BufferedReader.seek"], true, "BufferedReader.seek qualname"]
    - [ior294_006, io.BufferedReader.tell.__qualname__.__eq__, ["BufferedReader.tell"], true, "BufferedReader.tell qualname"]

table io_extra294.buffered_writer_qualnames:
  description: "BufferedWriter method __qualname__ and BufferedRandom identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: iow294

  columns: [id, function, args, expected, description]
  rows:
    - [iow294_001, io.BufferedWriter.write.__qualname__.__eq__, ["BufferedWriter.write"], true, "BufferedWriter.write qualname"]
    - [iow294_002, io.BufferedWriter.flush.__qualname__.__eq__, ["BufferedWriter.flush"], true, "BufferedWriter.flush qualname"]
    - [iow294_003, io.BufferedWriter.seek.__qualname__.__eq__, ["BufferedWriter.seek"], true, "BufferedWriter.seek qualname"]
    - [iow294_004, io.BufferedWriter.tell.__qualname__.__eq__, ["BufferedWriter.tell"], true, "BufferedWriter.tell qualname"]
    - [iow294_005, io.BufferedRandom.__name__.__eq__, ["BufferedRandom"], true, "BufferedRandom __name__"]
    - [iow294_006, io.BufferedRandom.__module__.__eq__, ["_io"], true, "BufferedRandom __module__ is _io"]

invariant io_extra294.buffered_random_base_name:
  description: "BufferedRandom first base class name is _BufferedIOBase"
  category: identity
  kind: python_call_eq
  function: io.BufferedRandom.__bases__.__getitem__(0).__name__.__eq__
  args: ["_BufferedIOBase"]
  expected: true
