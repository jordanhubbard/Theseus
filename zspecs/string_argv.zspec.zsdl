spec: string_argv
version: ">=0.3.0"
backend: node(string-argv)

docs: https://github.com/mccormicka/string-argv#readme

provenance:
  derived_from:
    - "string-argv README — https://github.com/mccormicka/string-argv#readme"
    - "Test vectors verified with string-argv via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "string-argv source"
  notes:
    - "Splits a shell-style command string into an argv array, respecting quotes and escapes."
    - "Install: npm install string-argv"
    - "Named export 'parseArgsStringToArgv' takes a string and returns an array."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table string_argv.parse:
  kind: node_module_call_eq
  category: parse
  function: parseArgsStringToArgv
  id_prefix: parse

  columns: [id, args, expected]
  rows:
    - [simple_words,
       ["foo bar baz"],
       ["foo", "bar", "baz"]]

    - [double_quoted_arg,
       ["foo \"bar baz\" qux"],
       ["foo", "bar baz", "qux"]]

    - [flags_with_values,
       ["--name Alice --age 30"],
       ["--name", "Alice", "--age", "30"]]

    - [single_quoted_args,
       ["'a b' 'c d'"],
       ["a b", "c d"]]

    - [empty_string,
       [""],
       []]

    - [single_word,
       ["solo"],
       ["solo"]]

    - [multiple_spaces_collapsed,
       ["foo    bar"],
       ["foo", "bar"]]
