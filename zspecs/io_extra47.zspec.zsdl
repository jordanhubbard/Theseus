spec: io_extra47
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra46.zspec.zsdl — covers BufferedWriter/__name__=='BufferedWriter'/__module__=='_io'; BufferedWriter.write/flush __qualname__.__len__()==20; BufferedReader/__name__=='BufferedReader'/__module__=='_io'; BufferedReader.read/__qualname__.__len__()==19, read1==20; DEFAULT_BUFFER_SIZE==131072."
    - "io_extra45.zspec.zsdl — covers io.StringIO.tell.__qualname__.__len__()==13; io.StringIO.__name__.__eq__('StringIO'); io.StringIO.__module__.__eq__('_io')."
    - "io_extra44.zspec.zsdl — covers io.__name__.__len__()==2; BytesIO lifecycle and IO-status method qualname lengths; FileIO navigation and status method qualname lengths."
    - "io_extra43.zspec.zsdl — covers IOBase.truncate/readline/readlines/writelines/fileno/isatty __qualname__.__len__(); StringIO.__init__(17)/__new__(16)/close(14) qualname lengths."
    - "io_extra42.zspec.zsdl — covers BufferedRandom method __qualname__.__len__() for all main methods; IncrementalNewlineDecoder method qualname lengths."
    - "io_extra41.zspec.zsdl — covers StringIO.readline/BytesIO.tell/TextIOWrapper/BufferedWriter method qualname lengths."
    - "io_extra38.zspec.zsdl — covers StringIO/BytesIO method qualname lengths for read/write/getvalue/seek."
  notes:
    - "This spec extends io_extra46.zspec.zsdl."
    - "Prior specs collectively covered: __name__/__module__/__qualname__ and their lengths for BufferedWriter/BufferedReader/StringIO; all method __qualname__.__len__() for the main io classes; DEFAULT_BUFFER_SIZE; SEEK_* constants; BytesIO/FileIO/TextIOWrapper/BufferedRandom lifecycle methods."
    - "This spec covers: io.IOBase.__name__ == 'IOBase' (NOVEL equality anchor in io_extra47 namespace; prior specs cover method __qualname__.__len__() for IOBase but not the class __name__.__eq__ as a standalone invariant); io.IOBase.__module__ == 'io' (NOVEL — IOBase is implemented in the C extension _io but its __module__ attribute reports 'io', not '_io', on Python 3.14; no prior io spec checks IOBase.__module__.__eq__); io.IOBase.__bases__[0].__name__ == '_IOBase' (NOVEL — IOBase's immediate base class is the internal C-level _IOBase; verified Python 3.14: __bases__[0].__name__ == '_IOBase'; no prior spec anchors this equality); io.RawIOBase.__name__ == 'RawIOBase' (NOVEL equality anchor in io_extra47 namespace); io.RawIOBase.__module__ == 'io' (NOVEL — reports 'io', not '_io', on Python 3.14); io.RawIOBase.__bases__[0].__name__ == '_RawIOBase' (NOVEL — immediate base is the C-level _RawIOBase; verified Python 3.14); io.BufferedIOBase.__name__ == 'BufferedIOBase' (NOVEL equality anchor); io.BufferedIOBase.__module__ == 'io' (NOVEL); io.BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase' (NOVEL — base is the C-level _BufferedIOBase); io.TextIOBase.__name__ == 'TextIOBase' (NOVEL equality anchor); io.TextIOBase.__module__ == 'io' (NOVEL); io.TextIOBase.__bases__[0].__name__ == '_TextIOBase' (NOVEL — base is the C-level _TextIOBase)."
    - "io.IOBase.__name__ == 'IOBase'. The abstract base class for all I/O classes. Its __name__ attribute is 'IOBase'. Prior specs cover IOBase method __qualname__.__len__() but not the class __name__.__eq__ as a standalone invariant. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.IOBase.__module__ == 'io'. Although IOBase is implemented in the C extension _io, on Python 3.14 its __module__ attribute reports 'io' (the public wrapper module), not '_io'. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.IOBase.__bases__[0].__name__ == '_IOBase'. IOBase's MRO includes the internal C-level _IOBase as its immediate base. __bases__[0].__name__ == '_IOBase'. No prior io spec anchors this equality. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.RawIOBase.__name__ == 'RawIOBase'. Abstract base for raw binary I/O. __name__ == 'RawIOBase'. Novel equality anchor in io_extra47. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.RawIOBase.__module__ == 'io'. Like IOBase, RawIOBase reports __module__ == 'io' (not '_io') on Python 3.14. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.RawIOBase.__bases__[0].__name__ == '_RawIOBase'. RawIOBase's immediate base is the internal C-level _RawIOBase. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedIOBase.__name__ == 'BufferedIOBase'. Abstract base for buffered binary I/O. __name__ == 'BufferedIOBase'. Novel equality anchor in io_extra47. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedIOBase.__module__ == 'io'. BufferedIOBase reports __module__ == 'io' on Python 3.14. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase'. BufferedIOBase's immediate base is the internal C-level _BufferedIOBase. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.TextIOBase.__name__ == 'TextIOBase'. Abstract base for text I/O. __name__ == 'TextIOBase'. Novel equality anchor in io_extra47. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.TextIOBase.__module__ == 'io'. TextIOBase reports __module__ == 'io' on Python 3.14. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.TextIOBase.__bases__[0].__name__ == '_TextIOBase'. TextIOBase's immediate base is the internal C-level _TextIOBase. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.IOBase class identity: __name__, __module__, and base class name
#
# IOBase is the root abstract base class for all I/O classes. It is
# implemented in the C extension _io but its __module__ reports 'io'.
# Its immediate base class is the internal C-level _IOBase.
#
#   IOBase.__name__          == 'IOBase'
#   IOBase.__module__        == 'io'    (NOT '_io' — reports the public wrapper)
#   IOBase.__bases__[0].__name__ == '_IOBase'
#
# All three novel equality anchors in io_extra47 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant io_extra47.IOBase_name_eq:
  description: "io.IOBase.__name__ == 'IOBase' — the root abstract base class for all I/O classes; prior specs cover IOBase method qualname lengths but not IOBase.__name__.__eq__ as a standalone invariant; novel equality anchor in io_extra47; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: IOBase.__name__.__eq__
  args: ["IOBase"]
  expected: true

invariant io_extra47.IOBase_module_eq:
  description: "io.IOBase.__module__ == 'io' — IOBase is implemented in _io (C extension) but its __module__ attribute reports 'io' (the public wrapper module) on Python 3.14; novel equality anchor in io_extra47; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: IOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra47.IOBase_base_name_eq:
  description: "io.IOBase.__bases__[0].__name__ == '_IOBase' — IOBase's immediate base class is the internal C-level _IOBase; no prior io spec anchors this equality; novel standalone invariant; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: "IOBase.__bases__[0].__name__.__eq__"
  args: ["_IOBase"]
  expected: true

# ---------------------------------------------------------------------------
# io.RawIOBase class identity: __name__, __module__, and base class name
#
# RawIOBase is the abstract base for raw binary I/O (unbuffered). Like IOBase,
# it is in _io (C extension) but reports __module__ == 'io'. Its immediate
# base is the internal C-level _RawIOBase.
#
#   RawIOBase.__name__          == 'RawIOBase'
#   RawIOBase.__module__        == 'io'
#   RawIOBase.__bases__[0].__name__ == '_RawIOBase'
#
# Novel equality anchors in io_extra47 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra47.RawIOBase_identity:
  description: "io.RawIOBase class identity: __name__=='RawIOBase', __module__=='io', __bases__[0].__name__=='_RawIOBase' — abstract base for raw binary I/O; all three novel equality anchors in io_extra47 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: ribi47

  columns: [id, function, args, expected]
  rows:
    - [RawIOBase_name,   RawIOBase.__name__.__eq__,   ["RawIOBase"], true]
    - [RawIOBase_module, RawIOBase.__module__.__eq__,  ["io"],        true]

invariant io_extra47.RawIOBase_base_name_eq:
  description: "io.RawIOBase.__bases__[0].__name__ == '_RawIOBase' — RawIOBase's immediate base is the internal C-level _RawIOBase; novel standalone invariant in io_extra47; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: "RawIOBase.__bases__[0].__name__.__eq__"
  args: ["_RawIOBase"]
  expected: true

# ---------------------------------------------------------------------------
