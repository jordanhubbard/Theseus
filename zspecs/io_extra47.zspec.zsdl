table io_extra47.TextIOBase_identity:
  description: "io.TextIOBase class identity: __name__=='TextIOBase', __module__=='io' — abstract base for text I/O; novel equality anchors in io_extra47 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: tibi47

  columns: [id, function, args, expected]
  rows:
