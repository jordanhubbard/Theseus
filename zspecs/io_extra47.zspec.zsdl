#
#   BufferedIOBase.__name__          == 'BufferedIOBase'
#   BufferedIOBase.__module__        == 'io'
#   BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase'
#
# Novel equality anchors in io_extra47 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra47.BufferedIOBase_identity:
  description: "io.BufferedIOBase class identity: __name__=='BufferedIOBase', __module__=='io', — abstract base for buffered binary I/O; novel equality anchors in io_extra47 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: bibi47

  columns: [id, function, args, expected]
  rows:
    - [BufferedIOBase_name,   BufferedIOBase.__name__.__eq__,   ["BufferedIOBase"], true]
    - [BufferedIOBase_module, BufferedIOBase.__module__.__eq__,  ["io"],             true]

invariant io_extra47.BufferedIOBase_base_name_eq:
  description: "io.BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase' — BufferedIOBase's immediate base is the internal C-level _BufferedIOBase; novel standalone invariant in io_extra47; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: "BufferedIOBase.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

