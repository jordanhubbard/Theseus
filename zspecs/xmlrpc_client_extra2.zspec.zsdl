spec: xmlrpc_client_extra2
version: ">=3.9"
backend: python_module(xmlrpc.client)

docs: https://docs.python.org/3/library/xmlrpc.client.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/xmlrpc.client.html — Python xmlrpc.client module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/xmlrpc/client.py"
  notes:
    - "This spec extends xmlrpc_client.zspec.zsdl and xmlrpc_client_extra.zspec.zsdl — it does NOT duplicate invariants already present there."
    - "xmlrpc_client.zspec.zsdl covers: class __name__ table (ServerProxy, Fault, ProtocolError, MultiCall, Binary, DateTime, ResponseError, Unmarshaller, Marshaller), Fault/ProtocolError base hierarchy, loads/dumps __name__, type checks for ServerProxy/Fault/ProtocolError/Binary/DateTime, Binary.data roundtrip, Fault.faultCode/faultString, dumps returns str."
    - "xmlrpc_client_extra.zspec.zsdl covers: individual __name__ invariants for ServerProxy/Fault/ProtocolError/Binary/DateTime/Error, ServerProxy.__module__ and Error.__module__, Error.__bases__[0].__name__=='Exception', Fault/ProtocolError base hierarchy, is_type checks."
    - "This spec adds: Fault.__module__, ProtocolError.__module__, Binary.__module__, DateTime.__module__, ResponseError.__module__, Unmarshaller.__name__, Marshaller.__name__, MultiCall.__name__, Error.__qualname__, Fault.__qualname__, ResponseError.__qualname__, loads.__module__, dumps.__module__."
    - "xmlrpc.client.Fault.__module__ == 'xmlrpc.client' — all exception classes are defined in xmlrpc.client."
    - "xmlrpc.client.Unmarshaller.__name__ == 'Unmarshaller' — lower-level deserialization class."
    - "xmlrpc.client.Marshaller.__name__ == 'Marshaller' — lower-level serialization class."
    - "xmlrpc.client.MultiCall.__name__ == 'MultiCall' — batch call proxy class."
    - "Qualified names for top-level classes equal their simple __name__ (not nested)."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module membership — exception and utility classes live in xmlrpc.client
# (xmlrpc_client_extra covers ServerProxy.__module__ and Error.__module__
#  only; this spec adds Fault, ProtocolError, Binary, DateTime, ResponseError)
# ---------------------------------------------------------------------------

table xmlrpc_client_extra2.class_modules:
  kind: python_call_eq
  category: modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [Fault,         Fault.__module__.__eq__,         ["xmlrpc.client"], true]
    - [ProtocolError, ProtocolError.__module__.__eq__, ["xmlrpc.client"], true]
    - [Binary,        Binary.__module__.__eq__,        ["xmlrpc.client"], true]
    - [DateTime,      DateTime.__module__.__eq__,      ["xmlrpc.client"], true]
    - [ResponseError, ResponseError.__module__.__eq__, ["xmlrpc.client"], true]

# ---------------------------------------------------------------------------
# Class name checks — classes not covered individually in prior specs
# (xmlrpc_client.zspec.zsdl covers them in a table, but the invariants below
#  verify names not yet tested as standalone invariants: Unmarshaller,
#  Marshaller, MultiCall)
# ---------------------------------------------------------------------------

invariant xmlrpc_client_extra2.Unmarshaller.name:
  description: "xmlrpc.client.Unmarshaller.__name__ == 'Unmarshaller'"
  category: class_names
  kind: python_call_eq
  function: Unmarshaller.__name__.__eq__
  args: ["Unmarshaller"]
  expected: true

invariant xmlrpc_client_extra2.Marshaller.name:
  description: "xmlrpc.client.Marshaller.__name__ == 'Marshaller'"
  category: class_names
  kind: python_call_eq
  function: Marshaller.__name__.__eq__
  args: ["Marshaller"]
  expected: true

invariant xmlrpc_client_extra2.MultiCall.name:
  description: "xmlrpc.client.MultiCall.__name__ == 'MultiCall'"
  category: class_names
  kind: python_call_eq
  function: MultiCall.__name__.__eq__
  args: ["MultiCall"]
  expected: true

# ---------------------------------------------------------------------------
# Qualified name checks — top-level classes have __qualname__ == __name__
# ---------------------------------------------------------------------------

table xmlrpc_client_extra2.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [ServerProxy,   ServerProxy.__qualname__.__eq__,   ["ServerProxy"],   true]
    - [Fault,         Fault.__qualname__.__eq__,         ["Fault"],         true]
    - [ProtocolError, ProtocolError.__qualname__.__eq__, ["ProtocolError"], true]
    - [ResponseError, ResponseError.__qualname__.__eq__, ["ResponseError"], true]
    - [Error,         Error.__qualname__.__eq__,         ["Error"],         true]
    - [Binary,        Binary.__qualname__.__eq__,        ["Binary"],        true]
    - [DateTime,      DateTime.__qualname__.__eq__,      ["DateTime"],      true]

# ---------------------------------------------------------------------------
# Function module checks — loads and dumps live in xmlrpc.client
# ---------------------------------------------------------------------------

invariant xmlrpc_client_extra2.loads.module:
  description: "xmlrpc.client.loads.__module__ == 'xmlrpc.client'"
  category: modules
  kind: python_call_eq
  function: loads.__module__.__eq__
  args: ["xmlrpc.client"]
  expected: true

invariant xmlrpc_client_extra2.dumps.module:
  description: "xmlrpc.client.dumps.__module__ == 'xmlrpc.client'"
  category: modules
  kind: python_call_eq
  function: dumps.__module__.__eq__
  args: ["xmlrpc.client"]
  expected: true

# ---------------------------------------------------------------------------
# ResponseError — standalone hierarchy check
# ResponseError inherits from Error (same pattern as Fault and ProtocolError,
# but not yet tested as a standalone invariant in prior specs)
# ---------------------------------------------------------------------------

invariant xmlrpc_client_extra2.ResponseError.base_is_Error:
  description: "xmlrpc.client.ResponseError.__bases__[0].__name__ == 'Error'"
  category: hierarchy
  kind: python_call_eq
  function: ResponseError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Error"

# ---------------------------------------------------------------------------
# MultiCall — module membership
# ---------------------------------------------------------------------------

invariant xmlrpc_client_extra2.MultiCall.module:
  description: "xmlrpc.client.MultiCall.__module__ == 'xmlrpc.client'"
  category: modules
  kind: python_call_eq
  function: MultiCall.__module__.__eq__
  args: ["xmlrpc.client"]
  expected: true

# ---------------------------------------------------------------------------
# Unmarshaller and Marshaller — module membership
# ---------------------------------------------------------------------------

invariant xmlrpc_client_extra2.Unmarshaller.module:
  description: "xmlrpc.client.Unmarshaller.__module__ == 'xmlrpc.client'"
  category: modules
  kind: python_call_eq
  function: Unmarshaller.__module__.__eq__
  args: ["xmlrpc.client"]
  expected: true

invariant xmlrpc_client_extra2.Marshaller.module:
  description: "xmlrpc.client.Marshaller.__module__ == 'xmlrpc.client'"
  category: modules
  kind: python_call_eq
  function: Marshaller.__module__.__eq__
  args: ["xmlrpc.client"]
  expected: true
