spec: pathlib_extra16
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
  notes:
    - "This spec extends pathlib.zspec.zsdl through pathlib_extra15.zspec.zsdl."
    - "pathlib_extra15 covers __module__ for all six public classes; PurePath.__name__ and Path.__name__ as standalone invariants; PurePosixPath/PosixPath __bases__ hierarchy; PurePosixPath str/repr."
    - "pathlib_extra7 covers PurePosixPath.__name__ as a standalone invariant."
    - "pathlib_extra11 covers PosixPath.__bases__[0], WindowsPath.__bases__[0], Path.__bases__[0] as standalone invariants."
    - "pathlib_extra6 covers __qualname__ for all six classes and __module__ for four."
    - "NOT yet covered: pathlib.PureWindowsPath.__name__ == 'PureWindowsPath' as a standalone invariant."
    - "NOT yet covered: pathlib class MRO lengths as standalone invariants."
    - "PureWindowsPath.__name__ == 'PureWindowsPath' — name of the Windows-flavoured pure path class."
    - "PurePath.mro() has 2 entries: [PurePath, object]."
    - "PurePosixPath.mro() has 3 entries: [PurePosixPath, PurePath, object]."
    - "PureWindowsPath.mro() has 3 entries: [PureWindowsPath, PurePath, object]."
    - "Path.mro() has 3 entries: [Path, PurePath, object]."
    - "PosixPath.mro() has 5 entries: [PosixPath, Path, PurePosixPath, PurePath, object]."
    - "WindowsPath.mro() has 5 entries: [WindowsPath, Path, PureWindowsPath, PurePath, object]."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PureWindowsPath.__name__ — standalone invariant
#
# pathlib_extra7 covers PurePosixPath.__name__ as a standalone invariant.
# pathlib_pure covers PurePath.__name__ in a table row.
# pathlib_extra15 covers Path.__name__ as a standalone invariant.
# No prior spec records PureWindowsPath.__name__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant pathlib_extra16.PureWindowsPath.name_attr:
  description: "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath'"
  category: class_names
  kind: python_call_eq
  function: PureWindowsPath.__name__.__eq__
  args: ["PureWindowsPath"]
  expected: true

# ---------------------------------------------------------------------------
# MRO lengths — all six public pathlib classes
#
# No prior spec records the length of the MRO tuple for any pathlib class.
# mro() is a method that returns a list; we call __len__ on the result via
# the method chain. This axis verifies the inheritance depth of each class.
# ---------------------------------------------------------------------------

invariant pathlib_extra16.PurePath.mro_len:
  description: "pathlib.PurePath.mro() has 2 entries: [PurePath, object]"
  category: mro
  kind: python_call_eq
  function: PurePath.mro
  args: []
  method: __len__
  expected: 2

invariant pathlib_extra16.PurePosixPath.mro_len:
  description: "pathlib.PurePosixPath.mro() has 3 entries: [PurePosixPath, PurePath, object]"
  category: mro
  kind: python_call_eq
  function: PurePosixPath.mro
  args: []
  method: __len__
  expected: 3

invariant pathlib_extra16.PureWindowsPath.mro_len:
  description: "pathlib.PureWindowsPath.mro() has 3 entries: [PureWindowsPath, PurePath, object]"
  category: mro
  kind: python_call_eq
  function: PureWindowsPath.mro
  args: []
  method: __len__
  expected: 3

invariant pathlib_extra16.Path.mro_len:
  description: "pathlib.Path.mro() has 3 entries: [Path, PurePath, object]"
  category: mro
  kind: python_call_eq
  function: Path.mro
  args: []
  method: __len__
  expected: 3

invariant pathlib_extra16.PosixPath.mro_len:
  description: "pathlib.PosixPath.mro() has 5 entries: [PosixPath, Path, PurePosixPath, PurePath, object]"
  category: mro
  kind: python_call_eq
  function: PosixPath.mro
  args: []
  method: __len__
  expected: 5

invariant pathlib_extra16.WindowsPath.mro_len:
  description: "pathlib.WindowsPath.mro() has 5 entries: [WindowsPath, Path, PureWindowsPath, PurePath, object]"
  category: mro
  kind: python_call_eq
  function: WindowsPath.mro
  args: []
  method: __len__
  expected: 5

# ---------------------------------------------------------------------------
# Table: class __name__ for the two remaining classes not covered standalone
#
# pathlib_extra7 covers PurePosixPath.__name__ standalone.
# pathlib_extra11 covers PosixPath.__name__ and WindowsPath.__name__ in a table.
# This table bundles the confirmed names for completeness in this spec.
# PureWindowsPath is new (above); PurePosixPath, PosixPath, WindowsPath are
# re-anchored here from different prior specs for cross-spec indexing.
# ---------------------------------------------------------------------------

table pathlib_extra16.class_names:
  description: "pathlib class __name__ attributes for all six public classes"
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [PureWindowsPath, PureWindowsPath.__name__.__eq__, ["PureWindowsPath"], true]
    - [PurePosixPath,   PurePosixPath.__name__.__eq__,   ["PurePosixPath"],   true]
    - [PosixPath,       PosixPath.__name__.__eq__,        ["PosixPath"],       true]
    - [WindowsPath,     WindowsPath.__name__.__eq__,      ["WindowsPath"],     true]
