    - ["mp3391018",  operator.contains, [multiprocessing.pool.Pool.__dict__,               "__complex__"], false]
    - ["mp3391019",  operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__complex__"], false]
    - ["mp3391020",  operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__complex__"], false]
    - ["mp3391021",  operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__complex__"], false]
    - ["mp3391022",  operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__complex__"], false]
    - ["mp3391023",  operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__complex__"], false]
    - ["mp3391024",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__complex__"], false]

# ---------------------------------------------------------------------------
# combined — __int__, __float__, __complex__ across all 8 mp subjects
#
# Covers the full matrix: 8 classes x 3 methods = 24 rows.
# __int__: false for all 8 — not in any type's own __dict__.
# __float__: false for all 8 — not in any type's own __dict__.
# __complex__: false for all 8 — not in any type's own __dict__.
# All 24 values are false.
# The proxy types (_BaseSetProxy, _BaseDictProxy, BaseListProxy) are the most
#   analytically interesting subjects here. _BaseSetProxy proxies set, which
#   has no __int__, __float__, or __complex__ — set is an unordered collection,
#   not a number. _BaseDictProxy proxies dict — dict has no numeric conversion
#   operators. BaseListProxy proxies list — while list exposes __add__ and __mul__
#   (the only true results across mp waves 658–670), it defines neither __int__
#   nor __float__ nor __complex__, because list items may have numeric values but
#   the list container itself has no numeric conversion semantics.
# multiprocessing is a process-based concurrency library; its types interact
#   exclusively through explicit method calls, subprocess lifecycle management,
#   and IPC — never through Python's integer, float, or complex conversion
#   data model operators.
# ---------------------------------------------------------------------------

