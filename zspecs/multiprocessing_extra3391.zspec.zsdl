spec: mp3391
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "https://docs.python.org/3/library/multiprocessing.managers.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 673 (mp3391): __int__, __float__, __complex__ dict-presence (int(x), float(x), complex(x)) for multiprocessing types."
    - "Theme: __int__/__float__/__complex__ dict-presence (int(x), float(x), complex(x))."
    - "All values False — multiprocessing types are process-based concurrency primitives with no numeric conversion support."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: multiprocessing.Process, pool.Pool, pool.AsyncResult, pool.MapResult, managers.SyncManager, managers.BaseListProxy, managers._BaseDictProxy, managers._BaseSetProxy."
    - "Key finding (__int__): all 8 multiprocessing classes return false for __int__. int() delegates to __int__ (numbers.Integral protocol) when defined. None of the 8 multiprocessing types model a numeric integer value that can be losslessly converted. multiprocessing.Process is a subprocess lifecycle manager; int(process) is not a defined Python expression. pool.Pool/AsyncResult/MapResult: work-dispatch and result-handle types with no numeric data model. managers.SyncManager: server process manager; int(manager) is undefined. managers.BaseListProxy: proxies list — list defines no __int__; list length is obtained via len(), not int(). managers._BaseDictProxy: proxies dict — dict defines no __int__. managers._BaseSetProxy: proxies set — set defines no __int__; set cardinality is len(), not int()."
    - "Key finding (__float__): all 8 multiprocessing classes return false for __float__. float() delegates to __float__ (numbers.Real protocol). multiprocessing types define no arithmetic protocol — confirmed false across waves 658–672. managers._BaseSetProxy key note: set defines no __float__; set cardinality is len(s), not float(s). managers._BaseDictProxy: dict defines no __float__. managers.BaseListProxy: list defines no __float__; list length is len(l), not float(l). multiprocessing.Process/pool.Pool/pool.AsyncResult/pool.MapResult/managers.SyncManager: process-management types with no float conversion semantics whatsoever."
    - "Key finding (__complex__): all 8 multiprocessing classes return false for __complex__. complex() delegates to __complex__ (numbers.Complex protocol). multiprocessing types are not complex number types. managers.BaseListProxy key note: BaseListProxy defines __getitem__, but __complex__ is distinct — it signals that the proxy object itself can be used as a complex number, which it cannot. managers._BaseDictProxy: dict defines no __complex__; the dict object is not a complex number. managers._BaseSetProxy: set defines no __complex__; set is an unordered collection, not a complex number. multiprocessing.Process: even though Process.pid returns an int, Process itself does not define __complex__. pool.Pool/AsyncResult/MapResult/SyncManager: none of these types represent a complex number."
    - "All 24 values in this wave are false. multiprocessing is a process-based concurrency library; its types interact exclusively through explicit method calls, subprocess lifecycle management, and IPC — never through Python's integer, float, or complex conversion operators."
    - "Cross-wave summary for mp subjects:"
    - "  Wave 658 (mp3166): __add__/__sub__/__mul__ — BaseListProxy __add__=true, __mul__=true; others false."
    - "  Wave 659 (mp3181): __truediv__/__floordiv__/__mod__ — all false for all 8."
    - "  Wave 660 (mp3196): __pow__/__lshift__/__rshift__ — all false for all 8."
    - "  Wave 661 (mp3211): __and__/__or__/__xor__ — all false for all 8."
    - "  Wave 662 (mp3226): __radd__/__rsub__/__rmul__ — all false for all 8."
    - "  Wave 663 (mp3241): __rtruediv__/__rfloordiv__/__rmod__ — all false for all 8."
    - "  Wave 664 (mp3256): __rpow__/__rlshift__/__rrshift__ — all false for all 8."
    - "  Wave 665 (mp3271): __rand__/__ror__/__rxor__ — all false for all 8."
    - "  Wave 666 (mp3286): __iadd__/__isub__/__imul__ — all false for all 8."
    - "  Wave 667 (mp3301): __itruediv__/__ifloordiv__/__imod__ — all false for all 8."
    - "  Wave 668 (mp3316): __ipow__/__ilshift__/__irshift__ — all false for all 8."
    - "  Wave 669 (mp3331): __iand__/__ior__/__ixor__ — all false for all 8."
    - "  Wave 670 (mp3346): __neg__/__pos__/__abs__ — all false for all 8."
    - "  Wave 671 (mp3361): __invert__/__floor__/__ceil__ — all false for all 8."
    - "  Wave 672 (mp3376): __trunc__/__round__/__index__ — all false for all 8."
    - "  Wave 673 (mp3391): __int__/__float__/__complex__ — all false for all 8."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __int__ dict-presence — operator.contains(Cls.__dict__, '__int__')
#
# All 8 multiprocessing classes return false for __int__.
# int() delegates to __int__ (numbers.Integral protocol) when defined.
# multiprocessing.Process: subprocess lifecycle manager; int(process)
#   is not a valid Python expression.
# pool.Pool/AsyncResult/MapResult: work-dispatch and result-handle types;
#   no integer value is associated with any of them.
# managers.SyncManager: server process manager; int(manager) is not defined.
# managers.BaseListProxy: proxies list — list defines no __int__.
#   List length is obtained via len(), not int().
# managers._BaseDictProxy: proxies dict — dict defines no __int__.
#   Dict size is len(d), not int(d).
# managers._BaseSetProxy: proxies set — set defines no __int__.
#   Set cardinality is len(s), not int(s).
# ---------------------------------------------------------------------------

table mp3391.int:
  description: "multiprocessing types __int__ dict-presence checks; wave 673"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3391

  columns: [id, function, args, expected]
  rows:
    - ["mp3391001", operator.contains, [multiprocessing.Process.__dict__,                 "__int__"], false]
    - ["mp3391002", operator.contains, [multiprocessing.pool.Pool.__dict__,               "__int__"], false]
    - ["mp3391003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__int__"], false]
    - ["mp3391004", operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__int__"], false]
    - ["mp3391005", operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__int__"], false]
    - ["mp3391006", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__int__"], false]
    - ["mp3391007", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__int__"], false]
    - ["mp3391008", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__int__"], false]

# ---------------------------------------------------------------------------
# __float__ dict-presence — operator.contains(Cls.__dict__, '__float__')
#
# All 8 multiprocessing classes return false for __float__.
# float() delegates to __float__ (numbers.Real protocol). multiprocessing
#   types define no arithmetic protocol — confirmed false across waves 658–672.
# managers._BaseSetProxy key note: set defines no __float__. Set cardinality
#   is obtained via len(s), not float(s). The proxy does not define __float__.
# managers._BaseDictProxy: dict defines no __float__. Dict size is len(d).
# managers.BaseListProxy: list defines no __float__. List length is len(l).
# multiprocessing.Process: subprocess lifecycle manager; float(process) is
#   not a meaningful Python operation.
# pool.Pool/AsyncResult/MapResult: task dispatchers and result handles;
#   no float conversion semantics are defined.
# managers.SyncManager: server process manager; float(manager) is not defined.
# ---------------------------------------------------------------------------

