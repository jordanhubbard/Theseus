    - ["mp3391010",  operator.contains, [multiprocessing.pool.Pool.__dict__,               "__float__"], false]
    - ["mp3391011",  operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__float__"], false]
    - ["mp3391012",  operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__float__"], false]
    - ["mp3391013",  operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__float__"], false]
    - ["mp3391014",  operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__float__"], false]
    - ["mp3391015",  operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__float__"], false]
    - ["mp3391016",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__float__"], false]

# ---------------------------------------------------------------------------
# __complex__ dict-presence — operator.contains(Cls.__dict__, '__complex__')
#
# All 8 multiprocessing classes return false for __complex__.
# complex() delegates to __complex__ (numbers.Complex protocol). multiprocessing
#   types are not complex number types.
# managers.BaseListProxy key note: BaseListProxy defines __getitem__
#   (enabling item access by integer subscript), but __complex__ is distinct —
#   it signals that the proxy object itself is a complex number, which it is not.
#   The list proxy is a list; a list is not a complex number.
# managers._BaseDictProxy: dict defines no __complex__. The dict object itself
#   is not a complex number; complex(d) raises TypeError.
# managers._BaseSetProxy: set defines no __complex__. Set is an unordered
#   collection; it is not a complex number.
# multiprocessing.Process: the process object is not a complex number. Even though
#   Process.pid returns an int, Process itself does not define __complex__.
# pool.Pool/AsyncResult/MapResult/SyncManager: none of these types represent
#   a complex number; __complex__ is absent from all four.
# ---------------------------------------------------------------------------

table mp3391.complex:
  description: "multiprocessing types __complex__ dict-presence checks; wave 673"
  kind: python_call_eq
  version: ">=3.9"
