{
  "schema_version": "0.1",

  "identity": {
    "canonical_name": "minimist",
    "spec_for_versions": ">=1.2.0",
    "api_header": "N/A — Node.js npm package",
    "public_docs_url": "https://github.com/minimistjs/minimist#readme",
    "rfc_references": []
  },

  "provenance": {
    "derived_from": [
      "minimist npm package README — https://github.com/minimistjs/minimist#readme",
      "Test vectors verified with minimist@1.2.8 via Node.js 22.20.0 on macOS/Darwin 25.3.0, 2026-03-31"
    ],
    "not_derived_from": ["minimist package source"],
    "spec_authors": ["Theseus Z-layer"],
    "created_at": "2026-03-31T00:00:00Z",
    "notes": [
      "minimist exports the parse function directly as the module default export, not as a named method. Invariants use function: null to call the module itself.",
      "Positional arguments land in the '_' array.",
      "Arguments after '--' are treated as positional (added to '_').",
      "Short flags like -x without a value become {x: true}.",
      "Numeric strings after '--num' become integers (type coercion is default behavior)."
    ]
  },

  "library": {
    "backend": "cli",
    "command": "node",
    "module_name": "minimist",
    "soname_patterns": [],
    "notes": "node must be in PATH and the minimist npm package must be installed. Compatible with minimist >= 1.2.0."
  },

  "constants": {},
  "types": {},
  "wire_formats": {},

  "functions": {
    "(module)": {
      "description": "Parse an argv array. Returns an object with parsed flags as keys and positional args in '_'.",
      "parameters": [
        {"name": "argv", "type": "string[]", "direction": "in"},
        {"name": "opts", "type": "object",   "direction": "in", "description": "Optional parsing options"}
      ],
      "return_type": "object"
    }
  },

  "invariants": [
    {
      "id": "minimist.parse.long_flag_with_value",
      "description": "--foo bar sets foo to 'bar'",
      "category": "long_flags",
      "kind": "node_module_call_eq",
      "spec": {
        "function": null,
        "args": [["--foo", "bar"]],
        "expected": {"_": [], "foo": "bar"}
      }
    },
    {
      "id": "minimist.parse.long_flag_equals_syntax",
      "description": "--foo=bar sets foo to 'bar'",
      "category": "long_flags",
      "kind": "node_module_call_eq",
      "spec": {
        "function": null,
        "args": [["--foo=bar"]],
        "expected": {"_": [], "foo": "bar"}
      }
    },
    {
      "id": "minimist.parse.long_boolean_flag",
      "description": "--flag without a value sets flag to true",
      "category": "long_flags",
      "kind": "node_module_call_eq",
      "spec": {
        "function": null,
        "args": [["--flag"]],
        "expected": {"_": [], "flag": true}
      }
    },
    {
      "id": "minimist.parse.short_boolean_flags",
      "description": "-x -y sets x and y to true",
      "category": "short_flags",
      "kind": "node_module_call_eq",
      "spec": {
        "function": null,
        "args": [["-x", "-y"]],
        "expected": {"_": [], "x": true, "y": true}
      }
    },
    {
      "id": "minimist.parse.short_combined_flags",
      "description": "-xy sets both x and y to true (combined short flags)",
      "category": "short_flags",
      "kind": "node_module_call_eq",
      "spec": {
        "function": null,
        "args": [["-xy"]],
        "expected": {"_": [], "x": true, "y": true}
      }
    },
    {
      "id": "minimist.parse.positional_args",
      "description": "Non-flag arguments land in '_'",
      "category": "positional",
      "kind": "node_module_call_eq",
      "spec": {
        "function": null,
        "args": [["a", "b", "c"]],
        "expected": {"_": ["a", "b", "c"]}
      }
    },
    {
      "id": "minimist.parse.double_dash_separator",
      "description": "Arguments after '--' are treated as positional",
      "category": "positional",
      "kind": "node_module_call_eq",
      "spec": {
        "function": null,
        "args": [["a", "b", "--", "c"]],
        "expected": {"_": ["a", "b", "c"]}
      }
    },
    {
      "id": "minimist.parse.numeric_value",
      "description": "Numeric string after a flag is coerced to a number",
      "category": "coercion",
      "kind": "node_module_call_eq",
      "spec": {
        "function": null,
        "args": [["--num", "42"]],
        "expected": {"_": [], "num": 42}
      }
    },
    {
      "id": "minimist.parse.empty_argv",
      "description": "Empty argv returns {_: []}",
      "category": "edge_cases",
      "kind": "node_module_call_eq",
      "spec": {
        "function": null,
        "args": [[]],
        "expected": {"_": []}
      }
    }
  ],

  "error_model": {
    "return_code_semantics": "minimist does not throw for normal inputs. node exits 0 for all invariants in this spec.",
    "stream_error_field": "null",
    "error_stickiness": "N/A — each function call is stateless.",
    "error_codes": []
  }
}
