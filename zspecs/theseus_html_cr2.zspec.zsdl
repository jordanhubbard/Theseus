spec: theseus_html_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_html_cr2)
blocks: html

docs: https://docs.python.org/3/library/html.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/html.html"
    - "https://html.spec.whatwg.org/multipage/named-characters.html"
  notes:
    - "Clean-room HTML unescape. Do NOT import html or html.parser."
    - "unescape(s): replace HTML entities with their characters."
    - "Handle named entities: &lt; -> <, &gt; -> >, &amp; -> &, &quot; -> \"."
    - "Handle numeric entities: &#65; -> A, &#x41; -> A (hex)."
    - "html2_unescape_lt(): unescape('&lt;') == '<'."
    - "html2_unescape_amp(): unescape('&amp;') == '&'."
    - "html2_unescape_quot(): unescape('&quot;') == '\"'."
    - "Zero-arg invariant signatures — def html2_unescape_lt(): return hardcoded_result"
    - "Export: unescape(s) -> str."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_html_cr2.unescape_lt:
  description: "unescape('&lt;') == '<'"
  category: unescape
  kind: python_call_eq
  function: html2_unescape_lt
  args: []
  expected: "<"

invariant theseus_html_cr2.unescape_amp:
  description: "unescape('&amp;') == '&'"
  category: unescape
  kind: python_call_eq
  function: html2_unescape_amp
  args: []
  expected: "&"

invariant theseus_html_cr2.unescape_quot:
  description: "unescape('&quot;') == '\"'"
  category: unescape
  kind: python_call_eq
  function: html2_unescape_quot
  args: []
  expected: "\""
