spec: uu3046
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid: UUID objects according to RFC 4122"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 650 (uu3046): __enter__, __exit__, __aenter__ dict-presence checks for uuid types."
    - "uuid.UUID is an immutable value object representing a UUID — it does not implement the context manager protocol and defines neither __enter__, __exit__, nor __aenter__ in its own __dict__."
    - "type(uuid.UUID(int=0)) is identical to uuid.UUID — verified on Python 3.14.4."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table uu3046.enter:
  description: "uuid types __enter__ dict-presence checks; wave 650"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu3046
  columns: [id, function, args, expected]
  rows:
    - ["uu3046001", operator.contains, [uuid.UUID.__dict__,              "__enter__"], false]
    - ["uu3046002", operator.contains, [type(uuid.UUID(int=0)).__dict__, "__enter__"], false]

