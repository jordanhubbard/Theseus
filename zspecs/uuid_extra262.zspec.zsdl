spec: uuid_extra262
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra261.zspec.zsdl — covers uuid module constants and SafeUUID enum identity."
    - "uuid_extra260.zspec.zsdl — covers UUID.__init__/__new__/__setattr__ method identity."
  notes:
    - "uuid.__name__ == 'uuid' — the pure-Python uuid module name. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.__package__ == '' — uuid is a top-level module with empty package string. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.__spec__.name == 'uuid' — ModuleSpec.name matches the module name. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.__spec__.__class__.__name__ == 'ModuleSpec' — the module spec is an importlib.machinery.ModuleSpec instance. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.__loader__.__class__.__name__ == 'SourceFileLoader' — uuid is loaded from a .py source file. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid does not have __version__ — uuid module does not expose a __version__ attribute. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hasattr(uuid.UUID, '__slots__') == True — UUID class defines __slots__ for memory efficiency. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "type(uuid.UUID.__slots__).__name__ == 'tuple' — UUID.__slots__ is a tuple of slot names. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "len(uuid.UUID.__slots__) == 3 — UUID defines exactly 3 slots. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__hash__.__class__.__name__ == 'function' — UUID.__hash__ is a pure-Python method. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__hash__.__qualname__ == 'UUID.__hash__' — qualified name reflects class nesting. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "type(uuid.uuid4.__doc__).__name__ == 'str' — uuid4 has a string docstring. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid module __spec__ and __loader__ identity
# uuid is a pure-Python module loaded via SourceFileLoader.
# Its __spec__ is an importlib.machinery.ModuleSpec instance.
# uuid.__package__ is '' (top-level module).
# ---------------------------------------------------------------------------

table uuid_extra262.uuid_module_spec_identity:
  description: "uuid module __spec__ and __loader__ identity — __name__/'uuid', __package__/'', __spec__.name/'uuid', __spec__.__class__.__name__/'ModuleSpec', __loader__.__class__.__name__/'SourceFileLoader'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: uuidspec262

  columns: [id, function, args, expected, description]
  rows:
    - [uuid_name,         __name__.__eq__,                          ["uuid"],             true, "uuid.__name__ == 'uuid' — pure-Python top-level module"]
    - [uuid_package,      __package__.__eq__,                       [""],                 true, "uuid.__package__ == '' — top-level module has empty package string"]
    - [uuid_spec_name,    __spec__.name.__eq__,                     ["uuid"],             true, "uuid.__spec__.name == 'uuid' — ModuleSpec.name matches module name"]
    - [uuid_spec_class,   __spec__.__class__.__name__.__eq__,       ["ModuleSpec"],       true, "uuid.__spec__.__class__.__name__ == 'ModuleSpec' — importlib.machinery.ModuleSpec instance"]
    - [uuid_loader,       __loader__.__class__.__name__.__eq__,     ["SourceFileLoader"], true, "uuid.__loader__.__class__.__name__ == 'SourceFileLoader' — pure-Python source loaded via SourceFileLoader"]

# ---------------------------------------------------------------------------
# uuid.UUID __slots__ and __hash__ identity
# UUID defines __slots__ with 3 entries for memory efficiency.
# UUID.__hash__ is a pure-Python method with qualname 'UUID.__hash__'.
# uuid.uuid4.__doc__ is a string (not None).
# ---------------------------------------------------------------------------

table uuid_extra262.UUID_slots_hash_identity:
  description: "uuid.UUID __slots__ and __hash__ identity — __slots__ is a tuple of length 3; __hash__.__class__.__name__/'function'; __hash__.__qualname__/'UUID.__hash__'; uuid4.__doc__ is str; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: uuidslots262

  columns: [id, function, args, expected, description]
  rows:
    - [slots_type,        UUID.__slots__.__class__.__name__.__eq__,  ["tuple"],         true, "type(uuid.UUID.__slots__).__name__ == 'tuple' — UUID.__slots__ is a tuple of slot names"]
    - [slots_len,         UUID.__slots__.__len__,                    [],                3,    "len(uuid.UUID.__slots__) == 3 — UUID defines exactly 3 slots"]
    - [hash_class,        UUID.__hash__.__class__.__name__.__eq__,   ["function"],      true, "uuid.UUID.__hash__.__class__.__name__ == 'function' — UUID.__hash__ is a pure-Python method"]
    - [hash_qualname,     UUID.__hash__.__qualname__.__eq__,         ["UUID.__hash__"], true, "uuid.UUID.__hash__.__qualname__ == 'UUID.__hash__' — qualified name reflects class nesting"]
    - [uuid4_doc_class,   uuid4.__doc__.__class__.__name__.__eq__,   ["str"],           true, "type(uuid.uuid4.__doc__).__name__ == 'str' — uuid4 has a string docstring"]

# ---------------------------------------------------------------------------
# Standalone invariants — uuid module spec and UUID class properties
# ---------------------------------------------------------------------------

invariant uuid_extra262.uuid_name_eq:
  description: "uuid.__name__ == 'uuid' — the module name attribute of the pure-Python uuid module; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["uuid"]
  expected: true

invariant uuid_extra262.uuid_package_eq:
  description: "uuid.__package__ == '' — uuid is a top-level module so __package__ is the empty string; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant uuid_extra262.uuid_spec_name_eq:
  description: "uuid.__spec__.name == 'uuid' — the ModuleSpec.name attribute for the uuid module; mirrors __name__; set by the import system; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["uuid"]
  expected: true

invariant uuid_extra262.uuid_spec_class_eq:
  description: "uuid.__spec__.__class__.__name__ == 'ModuleSpec' — the module spec is an importlib.machinery.ModuleSpec; set by the import system for all Python modules; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant uuid_extra262.uuid_loader_class_eq:
  description: "uuid.__loader__.__class__.__name__ == 'SourceFileLoader' — uuid.py is loaded from source by SourceFileLoader (importlib._bootstrap_external); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant uuid_extra262.UUID_slots_type_eq:
  description: "type(uuid.UUID.__slots__).__name__ == 'tuple' — UUID.__slots__ is a tuple of slot name strings; defined in Lib/uuid.py for memory efficiency; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.__slots__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant uuid_extra262.UUID_slots_len_eq:
  description: "len(uuid.UUID.__slots__) == 3 — UUID defines exactly 3 slots in Lib/uuid.py; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.__slots__.__len__
  args: []
  expected: 3

invariant uuid_extra262.UUID_hash_class_eq:
  description: "uuid.UUID.__hash__.__class__.__name__ == 'function' — UUID.__hash__ is a pure-Python method defined in Lib/uuid.py; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.__hash__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant uuid_extra262.UUID_hash_qualname_eq:
  description: "uuid.UUID.__hash__.__qualname__ == 'UUID.__hash__' — qualified name of a method on a top-level class is ClassName.method_name; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.__hash__.__qualname__.__eq__
  args: ["UUID.__hash__"]
  expected: true

invariant uuid_extra262.uuid4_doc_class_eq:
  description: "type(uuid.uuid4.__doc__).__name__ == 'str' — uuid4 has a non-None string docstring; contrasts with functions that have None docstrings; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: uuid4.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
