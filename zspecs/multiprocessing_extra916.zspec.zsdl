spec: multiprocessing_extra916
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module Process, Queue, Pool, Value, Array, exception documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks multiprocessing class __qualname__ and __module__ identity for core process and synchronization primitives"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra916.process_pool_qualnames:
  description: "multiprocessing.Process and multiprocessing.Pool __qualname__ identity"
  kind: python_call_eq
  category: process_pool_qualnames
  id_prefix: mp916pp
  columns: [id, function, args, expected]
  rows:
    - [mp916pp001, multiprocessing.Process.__qualname__.__eq__,              ["Process"],                         true]
    - [mp916pp002, multiprocessing.Pool.__qualname__.__eq__,                 ["Pool"],                            true]
    - [mp916pp003, multiprocessing.Process.__module__.__eq__,                ["multiprocessing.process"],         true]
    - [mp916pp004, multiprocessing.Pool.__module__.__eq__,                   ["multiprocessing.pool"],            true]
    - [mp916pp005, multiprocessing.Process.__class__.__name__.__eq__,        ["type"],                            true]
    - [mp916pp006, multiprocessing.Pool.__class__.__name__.__eq__,           ["type"],                            true]
    - [mp916pp007, multiprocessing.Process.__qualname__.__class__.__name__.__eq__, ["str"],                       true]

table multiprocessing_extra916.queue_shared_memory:
  description: "multiprocessing.Queue, Value, and Array __qualname__ and __module__ identity"
  kind: python_call_eq
  category: queue_shared_memory
  id_prefix: mp916qm
  columns: [id, function, args, expected]
  rows:
    - [mp916qm001, multiprocessing.Queue.__qualname__.__eq__,                ["Queue"],                           true]
    - [mp916qm002, multiprocessing.Queue.__module__.__eq__,                  ["multiprocessing.queues"],          true]
    - [mp916qm003, multiprocessing.Value.__qualname__.__eq__,                ["Value"],                           true]
    - [mp916qm004, multiprocessing.Array.__qualname__.__eq__,                ["Array"],                           true]
    - [mp916qm005, multiprocessing.Value.__module__.__eq__,                  ["multiprocessing.sharedctypes"],    true]
    - [mp916qm006, multiprocessing.Array.__module__.__eq__,                  ["multiprocessing.sharedctypes"],    true]
    - [mp916qm007, multiprocessing.Queue.__class__.__name__.__eq__,          ["type"],                            true]

table multiprocessing_extra916.exception_modules:
  description: "multiprocessing exception __module__ identity"
  kind: python_call_eq
  category: exception_modules
  id_prefix: mp916ex
  columns: [id, function, args, expected]
  rows:
    - [mp916ex001, multiprocessing.AuthenticationError.__module__.__eq__,    ["multiprocessing.context"],         true]
    - [mp916ex002, multiprocessing.ProcessError.__module__.__eq__,           ["multiprocessing.context"],         true]
    - [mp916ex003, multiprocessing.AuthenticationError.__qualname__.__eq__,  ["AuthenticationError"],             true]
    - [mp916ex004, multiprocessing.ProcessError.__qualname__.__eq__,         ["ProcessError"],                    true]
    - [mp916ex005, multiprocessing.AuthenticationError.__class__.__name__.__eq__, ["type"],                       true]
    - [mp916ex006, multiprocessing.ProcessError.__class__.__name__.__eq__,   ["type"],                            true]
    - [mp916ex007, multiprocessing.AuthenticationError.__qualname__.__class__.__name__.__eq__, ["str"],           true]
