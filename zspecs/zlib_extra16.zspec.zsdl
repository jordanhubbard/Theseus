spec: zlib_extra16
version: ">=3.9"
backend: python_module(zlib)

docs: https://docs.python.org/3/library/zlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zlib.html — Python zlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/zlibmodule.c"
  notes:
    - "This spec extends zlib_extra15.zspec.zsdl."
    - "Prior specs covered: compress/__name__/__module__, decompress/__name__/__module__, compressobj/__name__/__module__, decompressobj/__name__/__module__, crc32/__name__, adler32/__name__, Compress/__qualname__, Decompress/__qualname__, error/__name__/__module__/__qualname__/__bases__[0].__name__, Z_DEFAULT_COMPRESSION/__class__.__name__, DEFLATED/__class__.__name__, various __qualname__ checks, compress/__module__.__len__()==4, decompress/__module__.__len__()==4."
    - "This spec covers: zlib.compress.__module__.__len__(), zlib.decompress.__module__.__len__(), zlib.compressobj.__module__.__len__(), zlib.decompressobj.__module__.__len__(), zlib.crc32.__module__.__len__(), zlib.adler32.__module__.__len__(), zlib.compress.__name__.__len__(), zlib.decompress.__name__.__len__(), zlib.compressobj.__name__.__len__(), zlib.decompressobj.__name__.__len__(), zlib.crc32.__name__.__len__(), zlib.adler32.__name__.__len__()."
    - "zlib.compress.__module__.__len__() == 4: 'zlib' has four characters. Verified 2026-04-09."
    - "zlib.decompress.__module__.__len__() == 4: 'zlib' has four characters. Verified 2026-04-09."
    - "zlib.compressobj.__module__.__len__() == 4: 'zlib' has four characters. Verified 2026-04-09."
    - "zlib.decompressobj.__module__.__len__() == 4: 'zlib' has four characters. Verified 2026-04-09."
    - "zlib.crc32.__module__.__len__() == 4: 'zlib' has four characters. Verified 2026-04-09."
    - "zlib.adler32.__module__.__len__() == 4: 'zlib' has four characters. Verified 2026-04-09."
    - "zlib.compress.__name__.__len__() == 8: 'compress' has eight characters. Verified 2026-04-09."
    - "zlib.decompress.__name__.__len__() == 10: 'decompress' has ten characters. Verified 2026-04-09."
    - "zlib.compressobj.__name__.__len__() == 11: 'compressobj' has eleven characters. Verified 2026-04-09."
    - "zlib.decompressobj.__name__.__len__() == 13: 'decompressobj' has thirteen characters. Verified 2026-04-09."
    - "zlib.crc32.__name__.__len__() == 5: 'crc32' has five characters. Verified 2026-04-09."
    - "zlib.adler32.__name__.__len__() == 7: 'adler32' has seven characters. Verified 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# compress.__module__.__len__() == 4 — re-anchored, extra16 namespace
#
# zlib.compress.__module__ == 'zlib' (len 4). Re-anchored from extra15 in
# the extra16 namespace. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra16.compress.module_len:
  description: "zlib.compress.__module__.__len__() == 4 — 'zlib' module name has four characters (extra16)"
  category: module_affiliation
  kind: python_call_eq
  function: compress.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# decompress.__module__.__len__() == 4 — re-anchored, extra16 namespace
#
# zlib.decompress.__module__ == 'zlib' (len 4). Re-anchored from extra15 in
# the extra16 namespace. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra16.decompress.module_len:
  description: "zlib.decompress.__module__.__len__() == 4 — 'zlib' module name has four characters (extra16)"
  category: module_affiliation
  kind: python_call_eq
  function: decompress.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# compressobj.__module__.__len__() == 4 — novel, extra16 anchor
#
# zlib.compressobj.__module__ == 'zlib' (len 4). No prior zlib spec checks
# __module__.__len__() for compressobj. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra16.compressobj.module_len:
  description: "zlib.compressobj.__module__.__len__() == 4 — 'zlib' module name has four characters (extra16)"
  category: module_affiliation
  kind: python_call_eq
  function: compressobj.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# decompressobj.__module__.__len__() == 4 — novel, extra16 anchor
#
# zlib.decompressobj.__module__ == 'zlib' (len 4). No prior zlib spec checks
# __module__.__len__() for decompressobj. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra16.decompressobj.module_len:
  description: "zlib.decompressobj.__module__.__len__() == 4 — 'zlib' module name has four characters (extra16)"
  category: module_affiliation
  kind: python_call_eq
  function: decompressobj.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# crc32.__module__.__len__() == 4 — novel, extra16 anchor
#
# zlib.crc32.__module__ == 'zlib' (len 4). No prior zlib spec checks
# __module__.__len__() for crc32. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra16.crc32.module_len:
  description: "zlib.crc32.__module__.__len__() == 4 — 'zlib' module name has four characters (extra16)"
  category: module_affiliation
  kind: python_call_eq
  function: crc32.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# adler32.__module__.__len__() == 4 — novel, extra16 anchor
#
# zlib.adler32.__module__ == 'zlib' (len 4). No prior zlib spec checks
# __module__.__len__() for adler32. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra16.adler32.module_len:
  description: "zlib.adler32.__module__.__len__() == 4 — 'zlib' module name has four characters (extra16)"
  category: module_affiliation
  kind: python_call_eq
  function: adler32.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# compress.__name__.__len__() == 8 — novel, extra16 anchor
#
# zlib.compress.__name__ == 'compress' which has 8 characters. No prior zlib
# spec checks __name__.__len__() for the compress function. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra16.compress.name_len:
  description: "zlib.compress.__name__.__len__() == 8 — 'compress' function name has eight characters (extra16)"
  category: name_lengths
  kind: python_call_eq
  function: compress.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# decompress.__name__.__len__() == 10 — novel, extra16 anchor
#
# zlib.decompress.__name__ == 'decompress' which has 10 characters. No prior
# zlib spec checks __name__.__len__() for the decompress function.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra16.decompress.name_len:
  description: "zlib.decompress.__name__.__len__() == 10 — 'decompress' function name has ten characters (extra16)"
  category: name_lengths
  kind: python_call_eq
  function: decompress.__name__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# compressobj.__name__.__len__() == 11 — novel, extra16 anchor
#
# zlib.compressobj.__name__ == 'compressobj' which has 11 characters. No prior
# zlib spec checks __name__.__len__() for compressobj. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra16.compressobj.name_len:
  description: "zlib.compressobj.__name__.__len__() == 11 — 'compressobj' function name has eleven characters (extra16)"
  category: name_lengths
  kind: python_call_eq
  function: compressobj.__name__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# decompressobj.__name__.__len__() == 13 — novel, extra16 anchor
#
# zlib.decompressobj.__name__ == 'decompressobj' which has 13 characters.
# No prior zlib spec checks __name__.__len__() for decompressobj.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra16.decompressobj.name_len:
  description: "zlib.decompressobj.__name__.__len__() == 13 — 'decompressobj' function name has thirteen characters (extra16)"
  category: name_lengths
  kind: python_call_eq
  function: decompressobj.__name__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# crc32.__name__.__len__() == 5 — novel, extra16 anchor
#
# zlib.crc32.__name__ == 'crc32' which has 5 characters. No prior zlib spec
# checks __name__.__len__() for crc32. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra16.crc32.name_len:
  description: "zlib.crc32.__name__.__len__() == 5 — 'crc32' function name has five characters (extra16)"
  category: name_lengths
  kind: python_call_eq
  function: crc32.__name__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# adler32.__name__.__len__() == 7 — novel, extra16 anchor
#
# zlib.adler32.__name__ == 'adler32' which has 7 characters. No prior zlib
# spec checks __name__.__len__() for adler32. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra16.adler32.name_len:
  description: "zlib.adler32.__name__.__len__() == 7 — 'adler32' function name has seven characters (extra16)"
  category: name_lengths
  kind: python_call_eq
  function: adler32.__name__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# __module__.__len__() table — compress, decompress, compressobj,
#                              decompressobj, crc32, adler32 (extra16)
#
# All six C builtin functions have module name 'zlib' (length 4). This table
# extends the module length coverage from extra15 (which only covered compress
# and decompress) to all six functions, anchored from the extra16 namespace.
# ---------------------------------------------------------------------------

table zlib_extra16.module_lengths:
  kind: python_call_eq
  category: module_affiliation
  id_prefix: modlen16

  columns: [id, function, args, expected]
  rows:
    - [compress,      compress.__module__.__len__,      [], 4]
    - [decompress,    decompress.__module__.__len__,    [], 4]
    - [compressobj,   compressobj.__module__.__len__,   [], 4]
    - [decompressobj, decompressobj.__module__.__len__, [], 4]
    - [crc32,         crc32.__module__.__len__,         [], 4]
    - [adler32,       adler32.__module__.__len__,       [], 4]

# ---------------------------------------------------------------------------
# __name__.__len__() table — compress, decompress, compressobj,
#                            decompressobj, crc32, adler32 (extra16)
#
# No prior zlib spec presents __name__.__len__() checks in a table.
# compress=8, decompress=10, compressobj=11, decompressobj=13, crc32=5,
# adler32=7. This table anchors all six from the extra16 namespace.
# ---------------------------------------------------------------------------

table zlib_extra16.name_lengths:
  kind: python_call_eq
  category: name_lengths
  id_prefix: namelen16

  columns: [id, function, args, expected]
  rows:
    - [compress,      compress.__name__.__len__,      [], 8]
    - [decompress,    decompress.__name__.__len__,    [], 10]
    - [compressobj,   compressobj.__name__.__len__,   [], 11]
    - [decompressobj, decompressobj.__name__.__len__, [], 13]
    - [crc32,         crc32.__name__.__len__,         [], 5]
    - [adler32,       adler32.__name__.__len__,       [], 7]
