spec: functools_extra2041
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 583 (_extra2041): __lshift__, __rshift__, __and__, __or__, __xor__, __invert__ dict-presence checks."
    - "functools classes are not bitwise types — none define bitwise operators."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"
error_model: python_exceptions

table functools_extra2041.lshift_protocol:
  description: "functools types __lshift__/__rlshift__/__ilshift__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2041
  columns: [id, function, args, expected]
  rows:
    - ["ft2041001", "functools.partial.__dict__.__contains__",           ["__lshift__"],  false]
    - ["ft2041002", "functools.partialmethod.__dict__.__contains__",     ["__lshift__"],  false]
    - ["ft2041003", "functools.cached_property.__dict__.__contains__",   ["__lshift__"],  false]
    - ["ft2041004", "functools.partial.__dict__.__contains__",           ["__rlshift__"], false]
    - ["ft2041005", "functools.partialmethod.__dict__.__contains__",     ["__rlshift__"], false]
    - ["ft2041006", "functools.cached_property.__dict__.__contains__",   ["__rlshift__"], false]
    - ["ft2041007", "functools.partial.__dict__.__contains__",           ["__ilshift__"], false]
    - ["ft2041008", "functools.partialmethod.__dict__.__contains__",     ["__ilshift__"], false]
    - ["ft2041009", "functools.cached_property.__dict__.__contains__",   ["__ilshift__"], false]

