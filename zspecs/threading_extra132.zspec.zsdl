spec: threading_extra132
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.get_ident and threading.get_native_id function identity; threading.enumerate, active_count, current_thread code attrs (Wave 261)."
    - "threading.get_ident.__class__.__name__ == 'builtin_function_or_method' — get_ident is a C builtin from _thread module. Verified with Python 3.14.3."
    - "threading.get_ident.__module__ == '_thread' — get_ident is defined in Modules/_threadmodule.c. Verified with Python 3.14.3."
    - "threading.get_ident.__qualname__ == 'get_ident' (len 9). Verified with Python 3.14.3."
    - "threading.get_ident.__name__ == 'get_ident' (len 9). Verified with Python 3.14.3."
    - "threading.get_native_id.__class__.__name__ == 'builtin_function_or_method' — get_native_id is also a C builtin from _thread. Verified with Python 3.14.3."
    - "threading.get_native_id.__module__ == '_thread'. Verified with Python 3.14.3."
    - "threading.get_native_id.__name__ == 'get_native_id' (len 13). Verified with Python 3.14.3."
    - "threading.get_native_id.__qualname__ == 'get_native_id' (len 13). Verified with Python 3.14.3."
    - "threading.enumerate.__code__.co_varnames.__len__() == 0 — enumerate is a simple wrapper; no local variables. Verified with Python 3.14.3."
    - "threading.active_count.__code__.co_varnames.__len__() == 0 — active_count is a simple wrapper; no local variables. Verified with Python 3.14.3."
    - "threading.current_thread.__code__.co_argcount == 0. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.get_ident C builtin identity attributes
#
# Wave 261 theme: threading.get_ident C builtin function identity.
#
# threading.get_ident.__class__.__name__ == 'builtin_function_or_method'
# threading.get_ident.__module__ == '_thread'
# threading.get_ident.__qualname__ == 'get_ident'
# threading.get_ident.__name__ == 'get_ident'
#
# get_ident is a C function from Modules/_threadmodule.c exposed via the
# _thread module and re-exported by threading. New to extra132.
# ---------------------------------------------------------------------------

table threading_extra132.get_ident_identity:
  description: "threading.get_ident __class__.__name__=='builtin_function_or_method', __module__=='_thread', __qualname__=='get_ident' len 9, __name__=='get_ident'; C builtin identity; wave 261; new to extra132"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadinggetident132

  columns: [id, function, args, expected, description]
  rows:
    - [get_ident_class_name_eq_builtin,
       "get_ident.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "threading.get_ident.__class__.__name__.__eq__('builtin_function_or_method') == True — threading.get_ident is a C function defined in Modules/_threadmodule.c; it is exposed as a builtin_function_or_method (PyCFunction); __class__.__name__ is 'builtin_function_or_method'; str.__eq__ returns True; new to extra132"]
    - [get_ident_module_eq__thread,
       "get_ident.__module__.__eq__",
       ["_thread"],
       true,
       "threading.get_ident.__module__.__eq__('_thread') == True — get_ident is defined in the _thread C extension module (Modules/_threadmodule.c) and re-exported by the threading module; its __module__ reflects the origin module '_thread'; str.__eq__('_thread') returns True; new to extra132"]
    - [get_ident_qualname_eq,
       "get_ident.__qualname__.__eq__",
       ["get_ident"],
       true,
       "threading.get_ident.__qualname__.__eq__('get_ident') == True — get_ident is a top-level C function; its __qualname__ is the simple function name 'get_ident'; str.__eq__('get_ident') returns True; new to extra132"]
    - [get_ident_qualname_len_9,
       "get_ident.__qualname__.__len__",
       [],
       9,
       "threading.get_ident.__qualname__.__len__() == 9 — 'get_ident' has 9 characters; str.__len__() returns 9; new to extra132"]
    - [get_ident_name_eq,
       "get_ident.__name__.__eq__",
       ["get_ident"],
       true,
       "threading.get_ident.__name__.__eq__('get_ident') == True — the __name__ attribute of get_ident is 'get_ident', matching the C function name; str.__eq__('get_ident') returns True; new to extra132"]
    - [get_ident_name_len_9,
       "get_ident.__name__.__len__",
       [],
       9,
       "threading.get_ident.__name__.__len__() == 9 — 'get_ident' has 9 characters; str.__len__() returns 9; new to extra132"]

# ---------------------------------------------------------------------------
# Table 2: threading.get_native_id C builtin identity attributes
#
# Wave 261 theme: threading.get_native_id C builtin function identity.
#
# threading.get_native_id.__class__.__name__ == 'builtin_function_or_method'
# threading.get_native_id.__module__ == '_thread'
# threading.get_native_id.__name__ == 'get_native_id'
# threading.get_native_id.__qualname__ == 'get_native_id'
#
# get_native_id was added in Python 3.8; it returns the native OS thread ID.
# Like get_ident it is a C builtin from _thread. New to extra132.
# ---------------------------------------------------------------------------

table threading_extra132.get_native_id_identity:
  description: "threading.get_native_id __class__.__name__=='builtin_function_or_method', __module__=='_thread', __name__=='get_native_id' len 13, __qualname__=='get_native_id'; wave 261; new to extra132"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadinggetnatid132

  columns: [id, function, args, expected, description]
  rows:
    - [get_native_id_class_name_eq_builtin,
       "get_native_id.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "threading.get_native_id.__class__.__name__.__eq__('builtin_function_or_method') == True — threading.get_native_id is a C function from Modules/_threadmodule.c (added in Python 3.8); it is exposed as a builtin_function_or_method; __class__.__name__ is 'builtin_function_or_method'; str.__eq__ returns True; new to extra132"]
    - [get_native_id_module_eq__thread,
       "get_native_id.__module__.__eq__",
       ["_thread"],
       true,
       "threading.get_native_id.__module__.__eq__('_thread') == True — get_native_id is defined in the _thread C extension module and re-exported by threading; its __module__ is '_thread'; str.__eq__('_thread') returns True; new to extra132"]
    - [get_native_id_name_eq,
       "get_native_id.__name__.__eq__",
       ["get_native_id"],
       true,
       "threading.get_native_id.__name__.__eq__('get_native_id') == True — the __name__ attribute of get_native_id is 'get_native_id', matching the C function name; str.__eq__('get_native_id') returns True; new to extra132"]
    - [get_native_id_name_len_13,
       "get_native_id.__name__.__len__",
       [],
       13,
       "threading.get_native_id.__name__.__len__() == 13 — 'get_native_id' has 13 characters; str.__len__() returns 13; new to extra132"]
    - [get_native_id_qualname_eq,
       "get_native_id.__qualname__.__eq__",
       ["get_native_id"],
       true,
       "threading.get_native_id.__qualname__.__eq__('get_native_id') == True — get_native_id is a top-level C function; its __qualname__ is the simple function name 'get_native_id'; str.__eq__('get_native_id') returns True; new to extra132"]
    - [get_native_id_qualname_len_13,
       "get_native_id.__qualname__.__len__",
       [],
       13,
       "threading.get_native_id.__qualname__.__len__() == 13 — 'get_native_id' has 13 characters; str.__len__() returns 13; new to extra132"]

# ---------------------------------------------------------------------------
# Table 3: threading.enumerate, active_count, current_thread code attrs
#
# Wave 261 theme: threading utility function co_varnames and co_argcount.
#
# threading.enumerate.__code__.co_varnames.__len__() == 0
# threading.enumerate.__code__.co_argcount == 0
# threading.active_count.__code__.co_varnames.__len__() == 0
# threading.active_count.__code__.co_argcount == 0
# threading.current_thread.__code__.co_argcount == 0
# threading.current_thread.__qualname__ == 'current_thread'
#
# enumerate, active_count, and current_thread are simple no-arg wrapper functions.
# They have no local variables and co_argcount == 0. New to extra132.
# ---------------------------------------------------------------------------

table threading_extra132.utility_func_code_attrs:
  description: "threading.enumerate/active_count/current_thread co_varnames len==0 and co_argcount==0; simple no-arg wrapper functions; wave 261; new to extra132"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingutil132

  columns: [id, function, args, expected, description]
  rows:
    - [enumerate_co_varnames_len_0,
       "enumerate.__code__.co_varnames.__len__",
       [],
       0,
       "threading.enumerate.__code__.co_varnames.__len__() == 0 — threading.enumerate is a no-argument wrapper function that returns a list of all active Thread objects; it has no local variables; co_varnames is an empty tuple; tuple.__len__() returns 0; new to extra132"]
    - [enumerate_co_argcount_eq_0,
       "enumerate.__code__.co_argcount.__eq__",
       [0],
       true,
       "threading.enumerate.__code__.co_argcount.__eq__(0) == True — threading.enumerate takes no positional parameters; co_argcount is 0; int.__eq__(0) returns True; new to extra132"]
    - [active_count_co_varnames_len_0,
       "active_count.__code__.co_varnames.__len__",
       [],
       0,
       "threading.active_count.__code__.co_varnames.__len__() == 0 — threading.active_count is a no-argument wrapper function returning the count of active Thread objects; it has no local variables; co_varnames is an empty tuple; tuple.__len__() returns 0; new to extra132"]
    - [active_count_co_argcount_eq_0,
       "active_count.__code__.co_argcount.__eq__",
       [0],
       true,
       "threading.active_count.__code__.co_argcount.__eq__(0) == True — threading.active_count takes no positional parameters; co_argcount is 0; int.__eq__(0) returns True; new to extra132"]
    - [current_thread_co_argcount_eq_0,
       "current_thread.__code__.co_argcount.__eq__",
       [0],
       true,
       "threading.current_thread.__code__.co_argcount.__eq__(0) == True — threading.current_thread takes no positional parameters and returns the Thread object for the calling thread; co_argcount is 0; int.__eq__(0) returns True; new to extra132"]
    - [current_thread_qualname_eq,
       "current_thread.__qualname__.__eq__",
       ["current_thread"],
       true,
       "threading.current_thread.__qualname__.__eq__('current_thread') == True — current_thread is defined at module scope in Lib/threading.py; its __qualname__ is the simple function name 'current_thread'; str.__eq__('current_thread') returns True; new to extra132"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra132
# ---------------------------------------------------------------------------

invariant threading_extra132.get_ident_class_name:
  description: "threading.get_ident.__class__.__name__ == 'builtin_function_or_method' — C builtin from _thread module; wave 261; new to extra132"
  kind: python_call_eq
  function: get_ident.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant threading_extra132.get_ident_module:
  description: "threading.get_ident.__module__ == '_thread' — defined in _thread C extension; wave 261; new to extra132"
  kind: python_call_eq
  function: get_ident.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra132.get_native_id_class_name:
  description: "threading.get_native_id.__class__.__name__ == 'builtin_function_or_method' — C builtin from _thread; added in Python 3.8; wave 261; new to extra132"
  kind: python_call_eq
  function: get_native_id.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant threading_extra132.get_native_id_name:
  description: "threading.get_native_id.__name__ == 'get_native_id' — C function name; wave 261; new to extra132"
  kind: python_call_eq
  function: get_native_id.__name__.__eq__
  args: ["get_native_id"]
  expected: true

invariant threading_extra132.enumerate_co_varnames_len:
  description: "threading.enumerate.__code__.co_varnames.__len__() == 0 — no-arg wrapper; no local variables; wave 261; new to extra132"
  kind: python_call_eq
  function: enumerate.__code__.co_varnames.__len__
  args: []
  expected: 0
