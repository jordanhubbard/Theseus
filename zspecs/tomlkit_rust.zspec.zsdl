spec: tomlkit_rust
version: ">=3.9"
backend: rust_module(tomlkit_rust)

docs: https://tomlkit.readthedocs.io/en/latest/

provenance:
  derived_from:
    - "https://tomlkit.readthedocs.io/ — tomlkit documentation"
  not_derived_from:
    - "tomlkit source: tomlkit/toml_document.py"
  notes:
    - "tomlkit: TOML parsing and serialization library that preserves formatting."
    - "tomlkit.loads(toml_str) returns a TOMLDocument (dict-like) with parsed values."
    - "tomlkit.dumps(dict) returns a TOML string representation."
    - "loads('key = \"value\"\\n')['key'] == 'value'."
    - "loads('num = 42\\n')['num'] == 42."
    - "loads('flag = true\\n')['flag'] == True."
    - "dumps({'key': 'value'}) == 'key = \"value\"\\n'."
    - "dumps({'num': 42}) == 'num = 42\\n'."
    - "All test vectors verified against tomlkit 0.13.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# loads — parse TOML string to dict-like document
table tomlkit_rust.loads.scalars:
  kind: python_call_eq
  category: loads
  id_prefix: tk_ld
  function: loads

  columns: [id, args, method, method_args, expected]
  rows:
    - [string_val,  ["key = \"value\"\n"],  __getitem__, ["key"],  "value"]
    - [int_val,     ["num = 42\n"],          __getitem__, ["num"],  42]
    - [bool_true,   ["flag = true\n"],       __getitem__, ["flag"], true]
    - [bool_false,  ["ok = false\n"],        __getitem__, ["ok"],   false]
    - [float_val,   ["pi = 3.14\n"],         __getitem__, ["pi"],   3.14]

# dumps — serialize dict to TOML string
table tomlkit_rust.dumps.scalars:
  kind: python_call_eq
  category: dumps
  id_prefix: tk_dp
  function: dumps

  columns: [id, args, expected]
  rows:
    - [string_kv, [{"key": "value"}], "key = \"value\"\n"]
    - [int_kv,    [{"num": 42}],      "num = 42\n"]
    - [bool_kv,   [{"flag": true}],   "flag = true\n"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-19T23:19:20Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
