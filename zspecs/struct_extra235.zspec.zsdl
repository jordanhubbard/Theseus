spec: struct_extra235
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified by running Python 3.14.3 struct module on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "This spec extends struct.zspec.zsdl and struct_extra.zspec.zsdl; it does NOT duplicate invariants present in those files."
    - "struct.zspec.zsdl covers: pack/unpack/calcsize vectors; roundtrip invariants; error cases."
    - "struct_extra.zspec.zsdl covers: Struct.format, Struct.size, calcsize extra formats, pack_into/__name__, unpack_from vectors and __name__, iter_unpack, struct.error.__name__ and base class."
    - "struct.Struct.__module__ == '_struct' — Struct is implemented in the C extension _struct, not in pure Python."
    - "struct.Struct.__bases__[0].__name__ == 'object' — Struct inherits directly from object."
    - "struct.Struct.__name__ == 'Struct' — the class is named Struct."
    - "Struct instance method __name__ values: pack/unpack/pack_into/unpack_from/iter_unpack are their unqualified names."
    - "Struct instance method __qualname__ values: 'Struct.pack', 'Struct.unpack', 'Struct.pack_into', 'Struct.unpack_from', 'Struct.iter_unpack'."
    - "Module-level function __name__: pack, unpack, calcsize, pack_into, unpack_from, iter_unpack."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model:
  semantics: "struct.error is raised for mismatched buffer sizes and invalid format strings. It is a subclass of Exception."
  stderr: "null"
  stickiness: "N/A — struct functions are pure; Struct objects are immutable after construction."
  codes: {}

# ---------------------------------------------------------------------------
# struct.Struct class identity
# ---------------------------------------------------------------------------

invariant struct_extra235.Struct.class_name:
  description: "struct.Struct.__name__ == 'Struct'"
  category: class_identity
  kind: python_call_eq
  function: Struct.__name__.__eq__
  args: ["Struct"]
  expected: true

invariant struct_extra235.Struct.module:
  description: "struct.Struct.__module__ == '_struct' — Struct is defined in the C extension _struct"
  category: class_identity
  kind: python_call_eq
  function: Struct.__module__.__eq__
  args: ["_struct"]
  expected: true

invariant struct_extra235.Struct.base_class_name:
  description: "struct.Struct.__bases__[0].__name__ == 'object' — Struct inherits directly from object"
  category: class_identity
  kind: python_call_eq
  function: Struct.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct class identity — table for related class attrs
# ---------------------------------------------------------------------------

table struct_extra235.Struct.class_attrs:
  kind: python_call_eq
  category: class_identity
  id_prefix: struct235cls

  columns: [id, function, args, expected]
  rows:
    - [class_name_eq,    Struct.__name__.__eq__,    ["Struct"],  true]
    - [module_eq,        Struct.__module__.__eq__,  ["_struct"], true]
    - [bases_len,        Struct.__bases__.__len__,  [],          1]

# ---------------------------------------------------------------------------
# struct.Struct instance method names (via Struct('>H').method.__name__)
# struct_extra covers pack_into.__func__.__name__ via workaround;
# this spec tests the direct __name__ on bound methods.
# ---------------------------------------------------------------------------

table struct_extra235.Struct.method_names:
  kind: python_call_eq
  category: method_names
  function: Struct
  id_prefix: struct235m

  columns: [id, args, method, method_args, expected]
  rows:
    - [pack_name,        [">H"], pack.__name__.__eq__,        ["pack"],        true]
    - [unpack_name,      [">H"], unpack.__name__.__eq__,      ["unpack"],      true]
    - [pack_into_name,   [">H"], pack_into.__name__.__eq__,   ["pack_into"],   true]
    - [unpack_from_name, [">H"], unpack_from.__name__.__eq__,  ["unpack_from"], true]
    - [iter_unpack_name, [">H"], iter_unpack.__name__.__eq__,  ["iter_unpack"], true]

# ---------------------------------------------------------------------------
# struct.Struct instance method qualnames (Struct.pack, Struct.unpack, etc.)
# ---------------------------------------------------------------------------

table struct_extra235.Struct.method_qualnames:
  kind: python_call_eq
  category: method_names
  function: Struct
  id_prefix: struct235m

  columns: [id, args, method, method_args, expected]
  rows:
    - [pack_qualname,        [">H"], pack.__qualname__.__eq__,        ["Struct.pack"],        true]
    - [unpack_qualname,      [">H"], unpack.__qualname__.__eq__,      ["Struct.unpack"],      true]
    - [pack_into_qualname,   [">H"], pack_into.__qualname__.__eq__,   ["Struct.pack_into"],   true]
    - [unpack_from_qualname, [">H"], unpack_from.__qualname__.__eq__,  ["Struct.unpack_from"], true]
    - [iter_unpack_qualname, [">H"], iter_unpack.__qualname__.__eq__,  ["Struct.iter_unpack"], true]

# ---------------------------------------------------------------------------
# Module-level function __name__ for calcsize, pack, unpack
# (struct_extra covers calcsize.__name__ via unpack_from.__name__.__eq__
#  and iter_unpack.__name__.__eq__; this adds calcsize standalone)
# ---------------------------------------------------------------------------

invariant struct_extra235.calcsize.name:
  description: "struct.calcsize.__name__ == 'calcsize'"
  category: method_names
  kind: python_call_eq
  function: calcsize.__name__.__eq__
  args: ["calcsize"]
  expected: true

invariant struct_extra235.pack.module_level_name:
  description: "struct.pack.__name__ == 'pack'"
  category: method_names
  kind: python_call_eq
  function: pack.__name__.__eq__
  args: ["pack"]
  expected: true

invariant struct_extra235.unpack.module_level_name:
  description: "struct.unpack.__name__ == 'unpack'"
  category: method_names
  kind: python_call_eq
  function: unpack.__name__.__eq__
  args: ["unpack"]
  expected: true

invariant struct_extra235.pack_into.module_level_name:
  description: "struct.pack_into.__name__ == 'pack_into'"
  category: method_names
  kind: python_call_eq
  function: pack_into.__name__.__eq__
  args: ["pack_into"]
  expected: true
