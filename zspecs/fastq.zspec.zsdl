spec: fastq
version: ">=1.15.0"
backend: node(fastq)

docs: https://github.com/mcollina/fastq#readme

provenance:
  derived_from:
    - "fastq README — https://github.com/mcollina/fastq#readme"
    - "Test vectors verified with fastq via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "fastq source"
  notes:
    - "High-throughput callback-style task queue with bounded concurrency."
    - "Install: npm install fastq"
    - "v1 CJS; module export IS the queue factory (worker, [concurrency]). Has .promise() variant for async/await users."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Worker errors propagate via callback's first arg or via the queue's .error() handler."
  stderr: "null"
  stickiness: "Each queue instance owns its own concurrency state."
  codes: {}

invariant fastq.module_is_function:
  description: "Module export is a function (queue factory)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant fastq.has_promise_variant:
  description: ".promise() factory exposed (async/await)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "promise.constructor.name"}
  expected: "Function"

invariant fastq.module_name:
  description: "Factory function name is 'fastqueue'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: name}
  expected: "fastqueue"

invariant fastq.module_arity:
  description: "Factory takes 3 args (context, worker, concurrency)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 3

invariant fastq.promise_name:
  description: "Promise variant function name is 'queueAsPromised'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "promise.name"}
  expected: "queueAsPromised"
