spec: asyncio_extra2221
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py, Lib/asyncio/futures.py, Lib/asyncio/locks.py, Lib/asyncio/queues.py, Lib/asyncio/streams.py"
    - "CPython source: Modules/_asynciomodule.c — C implementation of Task and Future"
  notes:
    - "Wave 2221 (_extra2221): identity/display protocol dict-presence — __hash__, __repr__, __str__, __doc__, __module__, __qualname__, __name__ checks for asyncio classes."
    - "asyncio.Task and asyncio.Future are C extension types from _asyncio (Modules/_asynciomodule.c); their __qualname__ is NOT in __dict__ because C types store qualname as a slot, not a dict entry."
    - "asyncio.Event, Lock, Semaphore, Condition, StreamReader are pure Python classes (Lib/asyncio/locks.py, streams.py); their __qualname__ is also not in __dict__ as Python stores it differently."
    - "asyncio.Task.__module__ == '_asyncio' (C extension); asyncio.Future.__module__ == '_asyncio' (C extension)."
    - "asyncio.Event.__module__ == 'asyncio.locks'; asyncio.Lock.__module__ == 'asyncio.locks'; asyncio.Semaphore.__module__ == 'asyncio.locks'; asyncio.Condition.__module__ == 'asyncio.locks'."
    - "asyncio.Queue.__module__ == 'asyncio.queues'; asyncio.StreamReader.__module__ == 'asyncio.streams'."
    - "__repr__ IS in __dict__ for all 8 classes: Task and Future have wrapper_descriptor __repr__; Event/Lock/Queue/Semaphore/Condition/StreamReader have function __repr__."
    - "__hash__ is NOT in __dict__ for any asyncio class — none explicitly define or suppress __hash__ in their own dict; they inherit from object."
    - "__str__ is NOT in __dict__ for most classes — asyncio.Queue is the only one that defines __str__ in its dict."
    - "__doc__ IS in __dict__ for all 8 classes."
    - "__module__ IS in __dict__ for all 8 classes."
    - "__qualname__ is NOT in __dict__ for any of the 8 classes (C types store it as a slot; pure Python class qualname is in the type's tp_name/co_qualname, not the instance dict)."
    - "__name__ is NOT in __dict__ for any of the 8 classes — __name__ is an attribute of the type object, not stored in class __dict__ under that key."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __hash__ dict-presence — all 8 asyncio classes
#
# __hash__ is NOT in the __dict__ of any asyncio class. None of these classes
# explicitly define or suppress __hash__ in their own namespace; they inherit
# hash behavior from object. C extension Task/Future likewise do not put
# __hash__ in their dict slot. All 8 return False.
# ---------------------------------------------------------------------------

table asyncio_extra2221.hash_dict_presence:
  description: "__hash__ dict-presence for asyncio Task/Future/Event/Lock/Queue/Semaphore/Condition/StreamReader — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2221

  columns: [id, function, args, expected]
  rows:
    - ["as2221001", "asyncio.Task.__dict__.__contains__", ["__hash__"], false]
    - ["as2221002", "asyncio.Future.__dict__.__contains__", ["__hash__"], false]
    - ["as2221003", "asyncio.Event.__dict__.__contains__", ["__hash__"], false]
    - ["as2221004", "asyncio.Lock.__dict__.__contains__", ["__hash__"], false]
    - ["as2221005", "asyncio.Queue.__dict__.__contains__", ["__hash__"], false]
    - ["as2221006", "asyncio.Semaphore.__dict__.__contains__", ["__hash__"], false]
    - ["as2221007", "asyncio.Condition.__dict__.__contains__", ["__hash__"], false]
    - ["as2221008", "asyncio.StreamReader.__dict__.__contains__", ["__hash__"], false]

# ---------------------------------------------------------------------------
# Table 2: __repr__ dict-presence — all 8 asyncio classes
#
# __repr__ IS in the __dict__ of all 8 asyncio classes. Task and Future
# (C extension types) have a wrapper_descriptor __repr__. The pure Python
# classes Event, Lock, Queue, Semaphore, Condition, StreamReader all define
# a custom __repr__ function in their class body. All 8 return True.
# ---------------------------------------------------------------------------

table asyncio_extra2221.repr_dict_presence:
  description: "__repr__ dict-presence for asyncio Task/Future/Event/Lock/Queue/Semaphore/Condition/StreamReader — all True"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2221

  columns: [id, function, args, expected]
  rows:
    - ["as2221009", "asyncio.Task.__dict__.__contains__", ["__repr__"], true]
    - ["as2221010", "asyncio.Future.__dict__.__contains__", ["__repr__"], true]
    - ["as2221011", "asyncio.Event.__dict__.__contains__", ["__repr__"], true]
    - ["as2221012", "asyncio.Lock.__dict__.__contains__", ["__repr__"], true]
    - ["as2221013", "asyncio.Queue.__dict__.__contains__", ["__repr__"], true]
    - ["as2221014", "asyncio.Semaphore.__dict__.__contains__", ["__repr__"], true]
    - ["as2221015", "asyncio.Condition.__dict__.__contains__", ["__repr__"], true]
    - ["as2221016", "asyncio.StreamReader.__dict__.__contains__", ["__repr__"], true]

# ---------------------------------------------------------------------------
# Table 3: __str__ dict-presence — all 8 asyncio classes
#
# __str__ is NOT in the __dict__ of most asyncio classes. asyncio.Queue is
# the sole exception: it defines __str__ directly in its class body
# (returning a human-readable queue state string). All others return False.
# ---------------------------------------------------------------------------

table asyncio_extra2221.str_dict_presence:
  description: "__str__ dict-presence for asyncio Task/Future/Event/Lock/Queue/Semaphore/Condition/StreamReader — Queue True, rest False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2221

  columns: [id, function, args, expected]
  rows:
    - ["as2221017", "asyncio.Task.__dict__.__contains__", ["__str__"], false]
    - ["as2221018", "asyncio.Future.__dict__.__contains__", ["__str__"], false]
    - ["as2221019", "asyncio.Event.__dict__.__contains__", ["__str__"], false]
    - ["as2221020", "asyncio.Lock.__dict__.__contains__", ["__str__"], false]
    - ["as2221021", "asyncio.Queue.__dict__.__contains__", ["__str__"], true]
    - ["as2221022", "asyncio.Semaphore.__dict__.__contains__", ["__str__"], false]
    - ["as2221023", "asyncio.Condition.__dict__.__contains__", ["__str__"], false]
    - ["as2221024", "asyncio.StreamReader.__dict__.__contains__", ["__str__"], false]

# ---------------------------------------------------------------------------
# Table 4: __doc__ dict-presence — all 8 asyncio classes
#
# __doc__ IS in the __dict__ of all 8 asyncio classes. Both C extension types
# (Task, Future) and pure Python classes store their docstring in __dict__.
# All 8 return True.
# ---------------------------------------------------------------------------

table asyncio_extra2221.doc_dict_presence:
  description: "__doc__ dict-presence for asyncio Task/Future/Event/Lock/Queue/Semaphore/Condition/StreamReader — all True"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2221

  columns: [id, function, args, expected]
  rows:
    - ["as2221025", "asyncio.Task.__dict__.__contains__", ["__doc__"], true]
    - ["as2221026", "asyncio.Future.__dict__.__contains__", ["__doc__"], true]
    - ["as2221027", "asyncio.Event.__dict__.__contains__", ["__doc__"], true]
    - ["as2221028", "asyncio.Lock.__dict__.__contains__", ["__doc__"], true]
    - ["as2221029", "asyncio.Queue.__dict__.__contains__", ["__doc__"], true]
    - ["as2221030", "asyncio.Semaphore.__dict__.__contains__", ["__doc__"], true]
    - ["as2221031", "asyncio.Condition.__dict__.__contains__", ["__doc__"], true]
    - ["as2221032", "asyncio.StreamReader.__dict__.__contains__", ["__doc__"], true]

# ---------------------------------------------------------------------------
# Table 5: __module__ dict-presence — all 8 asyncio classes
#
# __module__ IS in the __dict__ of all 8 asyncio classes. For Task and Future
# (C extension), __module__ is stored in the dict as '_asyncio'. For the pure
# Python lock/queue/stream classes, __module__ is stored as the submodule name
# (e.g., 'asyncio.locks', 'asyncio.queues', 'asyncio.streams'). All 8 True.
# ---------------------------------------------------------------------------

table asyncio_extra2221.module_dict_presence:
  description: "__module__ dict-presence for asyncio Task/Future/Event/Lock/Queue/Semaphore/Condition/StreamReader — all True"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2221

  columns: [id, function, args, expected]
  rows:
    - ["as2221033", "asyncio.Task.__dict__.__contains__", ["__module__"], true]
    - ["as2221034", "asyncio.Future.__dict__.__contains__", ["__module__"], true]
    - ["as2221035", "asyncio.Event.__dict__.__contains__", ["__module__"], true]
    - ["as2221036", "asyncio.Lock.__dict__.__contains__", ["__module__"], true]
    - ["as2221037", "asyncio.Queue.__dict__.__contains__", ["__module__"], true]
    - ["as2221038", "asyncio.Semaphore.__dict__.__contains__", ["__module__"], true]
    - ["as2221039", "asyncio.Condition.__dict__.__contains__", ["__module__"], true]
    - ["as2221040", "asyncio.StreamReader.__dict__.__contains__", ["__module__"], true]

# ---------------------------------------------------------------------------
# Table 6: __qualname__ dict-presence — all 8 asyncio classes
#
# __qualname__ is NOT in the __dict__ of any asyncio class. For C extension
# types (Task, Future), qualname is stored as a C-level slot, not a dict entry.
# For pure Python classes (Event, Lock, Queue, etc.), Python also does not
# store __qualname__ in the class __dict__ at class-body execution time in
# this version. All 8 return False.
# ---------------------------------------------------------------------------

table asyncio_extra2221.qualname_dict_presence:
  description: "__qualname__ dict-presence for asyncio Task/Future/Event/Lock/Queue/Semaphore/Condition/StreamReader — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2221

  columns: [id, function, args, expected]
  rows:
    - ["as2221041", "asyncio.Task.__dict__.__contains__", ["__qualname__"], false]
    - ["as2221042", "asyncio.Future.__dict__.__contains__", ["__qualname__"], false]
    - ["as2221043", "asyncio.Event.__dict__.__contains__", ["__qualname__"], false]
    - ["as2221044", "asyncio.Lock.__dict__.__contains__", ["__qualname__"], false]
    - ["as2221045", "asyncio.Queue.__dict__.__contains__", ["__qualname__"], false]
    - ["as2221046", "asyncio.Semaphore.__dict__.__contains__", ["__qualname__"], false]
    - ["as2221047", "asyncio.Condition.__dict__.__contains__", ["__qualname__"], false]
    - ["as2221048", "asyncio.StreamReader.__dict__.__contains__", ["__qualname__"], false]

# ---------------------------------------------------------------------------
# Table 7: __name__ dict-presence — all 8 asyncio classes
#
# __name__ is NOT in the __dict__ of any asyncio class. __name__ is exposed
# as an attribute of type objects via a slot (tp_name) on C types, and via
# the type machinery for Python classes, but it is not stored as a key in
# the class __dict__. All 8 return False.
# ---------------------------------------------------------------------------

table asyncio_extra2221.name_dict_presence:
  description: "__name__ dict-presence for asyncio Task/Future/Event/Lock/Queue/Semaphore/Condition/StreamReader — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2221

  columns: [id, function, args, expected]
  rows:
    - ["as2221049", "asyncio.Task.__dict__.__contains__", ["__name__"], false]
    - ["as2221050", "asyncio.Future.__dict__.__contains__", ["__name__"], false]
    - ["as2221051", "asyncio.Event.__dict__.__contains__", ["__name__"], false]
    - ["as2221052", "asyncio.Lock.__dict__.__contains__", ["__name__"], false]
    - ["as2221053", "asyncio.Queue.__dict__.__contains__", ["__name__"], false]
    - ["as2221054", "asyncio.Semaphore.__dict__.__contains__", ["__name__"], false]
    - ["as2221055", "asyncio.Condition.__dict__.__contains__", ["__name__"], false]
    - ["as2221056", "asyncio.StreamReader.__dict__.__contains__", ["__name__"], false]
