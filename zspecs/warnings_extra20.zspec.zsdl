spec: warnings_extra20
version: ">=3.9"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/warnings.html — Python warnings module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
  notes:
    - "This spec extends prior warnings specs through warnings_extra19.zspec.zsdl."
    - "warnings_extra18 covers: warn/warn_explicit/filterwarnings/simplefilter/resetwarnings function __qualname__ and catch_warnings class __qualname__."
    - "warnings_extra19 covers: catch_warnings.__enter__/__exit__/__init__ method __qualname__, WarningMessage class and __str__ __qualname__, UserWarning/RuntimeWarning/FutureWarning builtin class __qualname__."
    - "Focus: __module__ attributes for WarningMessage and catch_warnings classes; catch_warnings base class; WarningMessage.__init__.__qualname__; PendingDeprecationWarning builtin class __qualname__."
    - "warnings.WarningMessage.__module__ == '_py_warnings' — WarningMessage is defined in the C-accelerated warnings implementation. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.catch_warnings.__module__ == '_py_warnings' — catch_warnings is defined in the C-accelerated warnings implementation. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.catch_warnings.__bases__[0].__name__ == 'object' — catch_warnings inherits directly from object. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.WarningMessage.__init__.__qualname__ == 'WarningMessage.__init__' — constructor qualname includes owning class. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "PendingDeprecationWarning.__qualname__ == 'PendingDeprecationWarning' — builtin warning class; qualname equals class name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# warnings.WarningMessage.__module__ and catch_warnings.__module__
#
# WarningMessage and catch_warnings are both defined in the C-accelerated
# warnings backend (_py_warnings). No prior warnings spec records __module__
# for either class.
# ---------------------------------------------------------------------------

invariant warnings_extra20.WarningMessage.module:
  description: "warnings.WarningMessage.__module__ == '_py_warnings' — class defined in the C-accelerated warnings backend"
  category: class_module
  kind: python_call_eq
  function: WarningMessage.__module__.__eq__
  args: ["_py_warnings"]
  expected: true

invariant warnings_extra20.catch_warnings.module:
  description: "warnings.catch_warnings.__module__ == '_py_warnings' — class defined in the C-accelerated warnings backend"
  category: class_module
  kind: python_call_eq
  function: catch_warnings.__module__.__eq__
  args: ["_py_warnings"]
  expected: true

# ---------------------------------------------------------------------------
# warnings.catch_warnings base class
#
# catch_warnings inherits directly from object — it has no intermediate base.
# No prior warnings spec records the name of catch_warnings.__bases__[0].
# ---------------------------------------------------------------------------

invariant warnings_extra20.catch_warnings.base_name:
  description: "warnings.catch_warnings.__bases__[0].__name__ == 'object' — catch_warnings inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: "catch_warnings.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# warnings.WarningMessage.__init__.__qualname__
#
# WarningMessage.__init__ is the constructor. Its __qualname__ takes the form
# 'WarningMessage.__init__' (class-prefixed). No prior warnings spec records
# __qualname__ for WarningMessage.__init__.
# ---------------------------------------------------------------------------

invariant warnings_extra20.WarningMessage.__init__.qualname:
  description: "warnings.WarningMessage.__init__.__qualname__ == 'WarningMessage.__init__' — constructor qualname includes owning class"
  category: method_qualname
  kind: python_call_eq
  function: "WarningMessage.__init__.__qualname__.__eq__"
  args: ["WarningMessage.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# PendingDeprecationWarning.__qualname__
#
# PendingDeprecationWarning is a builtin warning class. Its __qualname__
# equals its class name. warnings_extra19 covers FutureWarning, UserWarning,
# and RuntimeWarning. No prior warnings spec covers PendingDeprecationWarning.
# ---------------------------------------------------------------------------

invariant warnings_extra20.PendingDeprecationWarning.qualname:
  description: "PendingDeprecationWarning.__qualname__ == 'PendingDeprecationWarning' — builtin warning class"
  category: class_qualname
  kind: python_call_eq
  function: PendingDeprecationWarning.__qualname__.__eq__
  args: ["PendingDeprecationWarning"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all five checks
#
# Covers WarningMessage.__module__ and catch_warnings.__module__ (class
# module), catch_warnings.__bases__[0].__name__ (class hierarchy),
# WarningMessage.__init__.__qualname__ (method qualname), and
# PendingDeprecationWarning.__qualname__ (builtin class qualname).
# ---------------------------------------------------------------------------

table warnings_extra20.module_and_hierarchy_checks:
  description: "__module__, base class name, init qualname, and builtin warning class qualname checks"
  kind: python_call_eq
  category: class_module

  columns: [id, function, args, expected]
  rows:
    - [WarningMessage_module,       WarningMessage.__module__.__eq__,               ["_py_warnings"],               true]
    - [catch_warnings_module,       catch_warnings.__module__.__eq__,               ["_py_warnings"],               true]
    - [catch_warnings_base,         "catch_warnings.__bases__[0].__name__.__eq__",  ["object"],                     true]
    - [WarningMessage_init_qualname, "WarningMessage.__init__.__qualname__.__eq__", ["WarningMessage.__init__"],    true]
    - [PendingDeprecationWarning,   PendingDeprecationWarning.__qualname__.__eq__,  ["PendingDeprecationWarning"],  true]
