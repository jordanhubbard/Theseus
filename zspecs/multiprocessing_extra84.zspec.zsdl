# ---------------------------------------------------------------------------
# Standalone invariants — extra84
# ---------------------------------------------------------------------------

invariant multiprocessing_extra84.Process_mro_len:
  description: "multiprocessing.Process.__mro__.__len__() == 3 — MRO is [Process, BaseProcess, object], so length is 3; Process subclasses BaseProcess which subclasses object; NEW in extra84: first standalone __mro__.__len__ invariant for Process in mpextra84 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Process.__mro__.__len__
  args: []
  expected: 3

invariant multiprocessing_extra84.BaseManager_name:
  description: "multiprocessing.managers.BaseManager.__name__.__eq__('BaseManager') returns True — BaseManager is a top-level class in multiprocessing.managers used as the base for all manager classes; NEW in extra84: first standalone __name__ invariant for BaseManager in mpextra84 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: managers.BaseManager.__name__.__eq__
  args: ["BaseManager"]
  expected: true

invariant multiprocessing_extra84.BaseManager_mro_len:
  description: "multiprocessing.managers.BaseManager.__mro__.__len__() == 2 — MRO is [BaseManager, object], so length is 2; BaseManager directly subclasses object with no intermediate bases; NEW in extra84: first standalone __mro__.__len__ invariant for BaseManager in mpextra84 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: managers.BaseManager.__mro__.__len__
  args: []
  expected: 2

invariant multiprocessing_extra84.SyncManager_base_name:
  description: "multiprocessing.managers.SyncManager.__bases__[0].__name__.__eq__('BaseManager') returns True — SyncManager directly subclasses BaseManager, providing synchronization primitives via the manager protocol; NEW in extra84: first standalone __bases__[0].__name__ invariant for SyncManager in mpextra84 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: managers.SyncManager.__bases__[0].__name__.__eq__
  args: ["BaseManager"]
  expected: true

invariant multiprocessing_extra84.BaseProxy_mro_len:
  description: "multiprocessing.managers.BaseProxy.__mro__.__len__() == 2 — MRO is [BaseProxy, object], so length is 2; BaseProxy directly subclasses object and acts as the base for all proxy classes; NEW in extra84: first standalone __mro__.__len__ invariant for BaseProxy in mpextra84 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: managers.BaseProxy.__mro__.__len__
  args: []
  expected: 2
