    - [bm_mro_len,     "managers.BaseManager.__mro__.__len__",              [],              2,    "managers.BaseManager.__mro__.__len__() == 2 — MRO is [BaseManager, object]; verified with Python 3.14.3"]
    - [sm_name,        managers.SyncManager.__name__.__eq__,                ["SyncManager"], true, "managers.SyncManager.__name__ == 'SyncManager' — top-level class in multiprocessing.managers; verified with Python 3.14.3"]
    - [sm_base_name,   "managers.SyncManager.__bases__[0].__name__.__eq__", ["BaseManager"], true, "managers.SyncManager.__bases__[0].__name__ == 'BaseManager' — SyncManager directly subclasses BaseManager; verified with Python 3.14.3"]
    - [sm_mro_len,     "managers.SyncManager.__mro__.__len__",              [],              3,    "managers.SyncManager.__mro__.__len__() == 3 — MRO is [SyncManager, BaseManager, object]; verified with Python 3.14.3"]

