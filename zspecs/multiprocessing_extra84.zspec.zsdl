spec: multiprocessing_extra84
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/managers.py"
  notes:
    - "This spec extends multiprocessing_extra83.zspec.zsdl."
    - "This spec covers: wave 246 theme — multiprocessing Process __mro__ structure and managers module identity. NEW in extra84: Process.__mro__.__len__()==3 (MRO: [Process, BaseProcess, object]); Process.__bases__[0].__name__=='BaseProcess'; managers.BaseManager.__name__=='BaseManager'; managers.BaseManager.__module__=='multiprocessing.managers'; managers.BaseManager.__bases__[0].__name__=='object'; managers.BaseManager.__mro__.__len__()==2; managers.SyncManager.__name__=='SyncManager'; managers.SyncManager.__bases__[0].__name__=='BaseManager'; managers.SyncManager.__mro__.__len__()==3; managers.BaseProxy.__name__=='BaseProxy'; managers.BaseProxy.__bases__[0].__name__=='object'; managers.BaseProxy.__mro__.__len__()==2. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__mro__.__len__() == 3. MRO is [Process, BaseProcess, object], length 3. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__bases__[0].__name__ == 'BaseProcess'. Process directly subclasses BaseProcess. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.managers.BaseManager.__name__ == 'BaseManager'. BaseManager is a top-level class in multiprocessing.managers. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.managers.BaseManager.__module__ == 'multiprocessing.managers'. BaseManager is defined in multiprocessing.managers. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.managers.BaseManager.__bases__[0].__name__ == 'object'. BaseManager directly subclasses object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.managers.BaseManager.__mro__.__len__() == 2. MRO is [BaseManager, object], length 2. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.managers.SyncManager.__name__ == 'SyncManager'. SyncManager is a top-level class in multiprocessing.managers. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.managers.SyncManager.__bases__[0].__name__ == 'BaseManager'. SyncManager directly subclasses BaseManager. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.managers.SyncManager.__mro__.__len__() == 3. MRO is [SyncManager, BaseManager, object], length 3. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.managers.BaseProxy.__name__ == 'BaseProxy'. BaseProxy is a top-level class in multiprocessing.managers. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.managers.BaseProxy.__bases__[0].__name__ == 'object'. BaseProxy directly subclasses object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.managers.BaseProxy.__mro__.__len__() == 2. MRO is [BaseProxy, object], length 2. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing Process __mro__ structure — extra84
#
# Wave 246 theme: multiprocessing Process __mro__ structure and managers module identity.
#
# Process.__mro__.__len__() == 3  (MRO: [Process, BaseProcess, object])
# Process.__bases__[0].__name__ == 'BaseProcess'
# managers.BaseManager.__name__ == 'BaseManager'
# managers.BaseManager.__module__ == 'multiprocessing.managers'
# ---------------------------------------------------------------------------

table multiprocessing_extra84.Process_mro_structure:
  description: "multiprocessing Process __mro__ structure checks in mpextra84 namespace — wave 246 theme: multiprocessing Process __mro__ structure and managers module identity; Process.__mro__.__len__()==3 (MRO: [Process, BaseProcess, object]); Process.__bases__[0].__name__=='BaseProcess' (Process directly subclasses BaseProcess); managers.BaseManager.__name__=='BaseManager'; managers.BaseManager.__module__=='multiprocessing.managers'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpextra84

  columns: [id, function, args, expected, description]
  rows:
    - [proc_mro_len,       "Process.__mro__.__len__",                [],                           3,    "Process.__mro__.__len__() == 3 — MRO is [Process, BaseProcess, object]; verified with Python 3.14.3"]
    - [proc_base_name,     "Process.__bases__[0].__name__.__eq__",   ["BaseProcess"],              true, "Process.__bases__[0].__name__ == 'BaseProcess' — Process directly subclasses BaseProcess; verified with Python 3.14.3"]
    - [bm_name,            managers.BaseManager.__name__.__eq__,     ["BaseManager"],              true, "managers.BaseManager.__name__ == 'BaseManager' — top-level class in multiprocessing.managers; verified with Python 3.14.3"]
    - [bm_module,          managers.BaseManager.__module__.__eq__,   ["multiprocessing.managers"], true, "managers.BaseManager.__module__ == 'multiprocessing.managers' — defined in multiprocessing.managers; verified with Python 3.14.3"]

