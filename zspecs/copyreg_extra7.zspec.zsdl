spec: copyreg_extra7
version: ">=3.9"
backend: python_module(copyreg)

docs: https://docs.python.org/3/library/copyreg.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/copyreg.html — Python copyreg module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/copyreg.py"
    - "copyreg_extra6.zspec.zsdl — covers module __name__/__package__; dispatch_table.__class__.__name__; __newobj__/__newobj_ex__/_reconstructor __qualname__ re-anchors in extra6 namespace."
    - "copyreg_extra5.zspec.zsdl — covers _reconstructor.__qualname__ and pickle_complex.__qualname__ as standalone invariants."
    - "copyreg_extra3.zspec.zsdl — covers __qualname__ for pickle/constructor/add_extension/remove_extension/clear_extension_cache/__newobj__/__newobj_ex__ via table."
    - "copyreg.zspec.zsdl — covers dispatch_table type check; pickle/__name__/__module__; constructor/add_extension/remove_extension/clear_extension_cache __name__."
    - "copyreg_extra.zspec.zsdl — covers dispatch_table.__class__.__name__ == 'dict' standalone."
  notes:
    - "This spec extends copyreg.zspec.zsdl through copyreg_extra6.zspec.zsdl."
    - "Focus: __qualname__ values for pickle/constructor/add_extension/remove_extension/clear_extension_cache re-anchored as standalones in the extra7 namespace; dispatch_table.__class__.__name__ in extra7 namespace; copyreg.__name__ in extra7 namespace."
    - "copyreg.pickle.__qualname__ == 'pickle' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "copyreg.constructor.__qualname__ == 'constructor' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "copyreg.add_extension.__qualname__ == 'add_extension' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "copyreg.remove_extension.__qualname__ == 'remove_extension' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "copyreg.clear_extension_cache.__qualname__ == 'clear_extension_cache' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "copyreg.dispatch_table.__class__.__name__ == 'dict' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "copyreg.__name__ == 'copyreg' — verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# copyreg.pickle.__qualname__ — extra7 namespace standalone
#
# copyreg_extra3 covers pickle.__qualname__ via a combined table.
# Re-anchored here in the extra7 namespace as an independent standalone
# invariant. pickle is defined at module top level in Lib/copyreg.py,
# so its __qualname__ equals its simple name 'pickle'.
# ---------------------------------------------------------------------------

invariant copyreg_extra7.pickle.qualname:
  description: "copyreg.pickle.__qualname__ == 'pickle' — top-level function; qualname equals simple name"
  category: function_qualname
  kind: python_call_eq
  function: pickle.__qualname__.__eq__
  args: ["pickle"]
  expected: true

# ---------------------------------------------------------------------------
# copyreg.constructor.__qualname__ — extra7 namespace standalone
#
# copyreg_extra3 covers constructor.__qualname__ via a combined table.
# Re-anchored here in the extra7 namespace as an independent standalone
# invariant.
# ---------------------------------------------------------------------------

invariant copyreg_extra7.constructor.qualname:
  description: "copyreg.constructor.__qualname__ == 'constructor' — top-level function; qualname equals simple name"
  category: function_qualname
  kind: python_call_eq
  function: constructor.__qualname__.__eq__
  args: ["constructor"]
  expected: true

# ---------------------------------------------------------------------------
# copyreg.add_extension.__qualname__ — extra7 namespace standalone
#
# copyreg_extra3 covers add_extension.__qualname__ via a combined table.
# Re-anchored here in the extra7 namespace as an independent standalone
# invariant.
# ---------------------------------------------------------------------------

invariant copyreg_extra7.add_extension.qualname:
  description: "copyreg.add_extension.__qualname__ == 'add_extension' — top-level function; qualname equals simple name"
  category: function_qualname
  kind: python_call_eq
  function: add_extension.__qualname__.__eq__
  args: ["add_extension"]
  expected: true

# ---------------------------------------------------------------------------
# copyreg.remove_extension.__qualname__ — extra7 namespace standalone
#
# copyreg_extra3 covers remove_extension.__qualname__ via a combined table.
# Re-anchored here in the extra7 namespace as an independent standalone
# invariant.
# ---------------------------------------------------------------------------

invariant copyreg_extra7.remove_extension.qualname:
  description: "copyreg.remove_extension.__qualname__ == 'remove_extension' — top-level function; qualname equals simple name"
  category: function_qualname
  kind: python_call_eq
  function: remove_extension.__qualname__.__eq__
  args: ["remove_extension"]
  expected: true

# ---------------------------------------------------------------------------
# copyreg.clear_extension_cache.__qualname__ — extra7 namespace standalone
#
# copyreg_extra3 covers clear_extension_cache.__qualname__ via a combined
# table. Re-anchored here in the extra7 namespace as an independent standalone
# invariant.
# ---------------------------------------------------------------------------

invariant copyreg_extra7.clear_extension_cache.qualname:
  description: "copyreg.clear_extension_cache.__qualname__ == 'clear_extension_cache' — top-level function; qualname equals simple name"
  category: function_qualname
  kind: python_call_eq
  function: clear_extension_cache.__qualname__.__eq__
  args: ["clear_extension_cache"]
  expected: true

# ---------------------------------------------------------------------------
# copyreg.dispatch_table.__class__.__name__ — extra7 namespace standalone
#
# copyreg_extra and copyreg_extra6 cover this in their own namespaces.
# Re-anchored here in the extra7 namespace as an independent standalone
# invariant alongside the function __qualname__ checks.
# ---------------------------------------------------------------------------

invariant copyreg_extra7.dispatch_table.class_name:
  description: "copyreg.dispatch_table.__class__.__name__ == 'dict' — dispatch_table is a plain dict"
  category: module_attrs
  kind: python_call_eq
  function: dispatch_table.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# copyreg.__name__ — extra7 namespace standalone
#
# copyreg_extra6 covers __name__ == 'copyreg' via a module_identity
# invariant. Re-anchored here in the extra7 namespace as an independent
# standalone invariant.
# ---------------------------------------------------------------------------

invariant copyreg_extra7.module.name:
  description: "copyreg.__name__ == 'copyreg' — module self-identifies by its own name"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["copyreg"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — __qualname__ for all five public functions plus
# dispatch_table class name and module name (extra7 namespace)
# ---------------------------------------------------------------------------

table copyreg_extra7.function_qualnames:
  description: "__qualname__ values for copyreg public functions, dispatch_table class name, and module name"
  kind: python_call_eq
  category: function_qualname

  columns: [id, function, args, expected]
  rows:
    - [pickle,                 pickle.__qualname__.__eq__,                 ["pickle"],                 true]
    - [constructor,            constructor.__qualname__.__eq__,            ["constructor"],            true]
    - [add_extension,          add_extension.__qualname__.__eq__,          ["add_extension"],          true]
    - [remove_extension,       remove_extension.__qualname__.__eq__,       ["remove_extension"],       true]
    - [clear_extension_cache,  clear_extension_cache.__qualname__.__eq__,  ["clear_extension_cache"],  true]
    - [dispatch_table_type,    dispatch_table.__class__.__name__.__eq__,   ["dict"],                   true]
    - [module_name,            __name__.__eq__,                            ["copyreg"],                true]
