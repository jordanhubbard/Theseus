spec: string_extra3_rust
version: ">=3.9"
backend: rust_module(string_extra3_rust)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string documentation"
  not_derived_from:
    - "CPython source: Lib/string.py"
  notes:
    - "Additional string module constants not covered in string_rust or string_extra_rust."
    - "string.whitespace == ' \\t\\n\\r\\x0b\\x0c' — 6 whitespace characters."
    - "string.punctuation has 32 characters: !\"#$%&'()*+,-./:;<=>?@[\\]^_`{|}~"
    - "string.printable has 100 characters (digits + letters + punctuation + whitespace)."
    - "string.ascii_letters + digits = all alphanumeric characters."
    - "len(string.whitespace) == 6, len(string.punctuation) == 32, len(string.printable) == 100."
    - "All test vectors verified against Python 3.14.3 string module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# string constant lengths
table string_extra3_rust.lengths.vectors:
  kind: python_call_eq
  category: lengths
  id_prefix: se3_len
  function: len

  columns: [id, args, expected]
  rows:
    - [whitespace,  ["whitespace"],  6]
    - [punctuation, ["punctuation"], 32]
    - [printable,   ["printable"],   100]

# whitespace membership
table string_extra3_rust.whitespace.contains:
  kind: python_call_eq
  category: whitespace
  id_prefix: se3_ws
  function: whitespace_contains

  columns: [id, args, expected]
  rows:
    - [space,    [" "],   true]
    - [tab,      ["\t"],  true]
    - [newline,  ["\n"],  true]
    - [letter_a, ["a"],   false]
    - [digit_1,  ["1"],   false]

# punctuation membership
table string_extra3_rust.punctuation.contains:
  kind: python_call_eq
  category: punctuation
  id_prefix: se3_pu
  function: punctuation_contains

  columns: [id, args, expected]
  rows:
    - [exclaim,  ["!"],  true]
    - [period,   ["."],  true]
    - [at_sign,  ["@"],  true]
    - [letter_a, ["a"],  false]
    - [digit_5,  ["5"],  false]

# printable membership
invariant string_extra3_rust.printable.letter_in:
  description: "'a' in string.printable"
  category: printable
  kind: python_call_eq
  function: printable_contains
  args: ["a"]
  expected: true

invariant string_extra3_rust.printable.digit_in:
  description: "'5' in string.printable"
  category: printable
  kind: python_call_eq
  function: printable_contains
  args: ["5"]
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-19T23:43:51Z
  iterations: 2
  pass_count: 15
  fail_count: 0
  total_invariants: 15
  notes: Synthesis succeeded in 2 iteration(s). 15 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
