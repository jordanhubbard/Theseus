spec: flatley
version: ">=5.2.0"
backend: node(flatley)

docs: https://www.npmjs.com/package/flatley

provenance:
  derived_from:
    - "flatley README — https://www.npmjs.com/package/flatley"
    - "Test vectors verified with flatley via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "flatley source"
  notes:
    - "flatley is an npm package. Install: npm install flatley"
    - "Flattens a nested object to dot-separated keys."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a flat object with dot-separated keys."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table flatley.flatten:
  kind: node_module_call_eq
  function: flatten
  category: object
  id_prefix: flatley

  columns: [id, args, expected]
  rows:
    - [two_level,   [{"a": {"b": 1, "c": 2}}],   {"a.b": 1, "a.c": 2}]
    - [three_level, [{"a": {"b": {"c": 3}}}],     {"a.b.c": 3}]
    - [already,     [{"x": 1, "y": 2}],           {"x": 1, "y": 2}]
