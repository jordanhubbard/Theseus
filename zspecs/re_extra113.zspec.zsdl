spec: re_extra113
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec extends re_extra112.zspec.zsdl."
    - "This spec covers: re.VERBOSE/re.DEBUG/re.UNICODE/re.LOCALE flag integer values, alias equality, RegexFlag .name strings and their lengths."
    - "re.VERBOSE == 64, re.X == 64; re.VERBOSE == re.X is True."
    - "re.DEBUG == 128."
    - "re.UNICODE == 32, re.U == 32; re.UNICODE == re.U is True."
    - "re.LOCALE == 4, re.L == 4; re.LOCALE == re.L is True."
    - "re.NOFLAG == 0."
    - "re.RegexFlag.VERBOSE.name == 'VERBOSE' (len 7)."
    - "re.RegexFlag.DEBUG.name == 'DEBUG' (len 5)."
    - "re.RegexFlag.UNICODE.name == 'UNICODE' (len 7)."
    - "re.RegexFlag.LOCALE.name == 'LOCALE' (len 6)."
    - "re.RegexFlag.NOFLAG.name == 'NOFLAG' (len 6)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.VERBOSE and re.DEBUG flag integer values and alias equality
# re.VERBOSE == 64; re.X == 64; re.VERBOSE == re.X is True.
# re.DEBUG == 128; no short alias for DEBUG.
# Both are RegexFlag enum members.
# ---------------------------------------------------------------------------

table re_extra113.VERBOSE_DEBUG_flag_values:
  description: "re.VERBOSE=64 (alias re.X=64; re.VERBOSE==re.X True); re.DEBUG=128; both are RegexFlag enum members; VERBOSE enables whitespace/comments in patterns"
  kind: python_call_eq
  category: flag_values
  id_prefix: reflag113a

  columns: [id, function, args, expected, description]
  rows:
    - [verbose_int,        "VERBOSE.__int__",               [],    64,    "int(re.VERBOSE) == 64 (enables verbose regex patterns with whitespace and comments)"]
    - [verbose_x_int,      "X.__int__",                     [],    64,    "int(re.X) == 64 (re.X is the short alias for re.VERBOSE; same integer value 64)"]
    - [verbose_eq_x,       "VERBOSE.__eq__",                ["X"], true,  "re.VERBOSE == re.X is True (VERBOSE and X are the same RegexFlag enum member value)"]
    - [debug_int,          "DEBUG.__int__",                 [],    128,   "int(re.DEBUG) == 128 (displays debug information about compiled regex; no short alias)"]
    - [debug_eq_self,      "DEBUG.__eq__",                  ["DEBUG"], true, "re.DEBUG == re.DEBUG is True (self-equality of the DEBUG flag)"]
    - [verbose_ne_debug,   "VERBOSE.__eq__",                ["DEBUG"], false, "re.VERBOSE != re.DEBUG (64 != 128; these are different flags with different bit positions)"]
    - [verbose_lt_debug,   "VERBOSE.__lt__",                ["DEBUG"], true,  "re.VERBOSE < re.DEBUG (64 < 128; VERBOSE bit value is half that of DEBUG)"]
    - [debug_type,         "DEBUG.__class__.__name__.__eq__", ["RegexFlag"], true, "type(re.DEBUG).__name__ == 'RegexFlag' (DEBUG is a RegexFlag enum member)"]

# ---------------------------------------------------------------------------
# re.UNICODE, re.LOCALE flag integer values and alias equality
# re.UNICODE == 32, re.U == 32; re.UNICODE == re.U is True.
# re.LOCALE == 4, re.L == 4; re.LOCALE == re.L is True.
# re.NOFLAG == 0.
# ---------------------------------------------------------------------------

table re_extra113.UNICODE_LOCALE_NOFLAG_flag_values:
  description: "re.UNICODE=32 (alias re.U=32); re.LOCALE=4 (alias re.L=4); re.NOFLAG=0; UNICODE and LOCALE are alias pairs with equal values"
  kind: python_call_eq
  category: flag_values
  id_prefix: reflag113b

  columns: [id, function, args, expected, description]
  rows:
    - [unicode_int,        "UNICODE.__int__",               [],       32,    "int(re.UNICODE) == 32 (makes \\w, \\b, \\d, \\s match Unicode characters; default in Python 3)"]
    - [unicode_u_int,      "U.__int__",                     [],       32,    "int(re.U) == 32 (re.U is the short alias for re.UNICODE; same integer value 32)"]
    - [unicode_eq_u,       "UNICODE.__eq__",                ["U"],    true,  "re.UNICODE == re.U is True (UNICODE and U are the same RegexFlag enum member value)"]
    - [locale_int,         "LOCALE.__int__",                [],       4,     "int(re.LOCALE) == 4 (makes \\w, \\b, \\d, \\s depend on the current locale; deprecated)"]
    - [locale_l_int,       "L.__int__",                     [],       4,     "int(re.L) == 4 (re.L is the short alias for re.LOCALE; same integer value 4)"]
    - [locale_eq_l,        "LOCALE.__eq__",                 ["L"],   true,  "re.LOCALE == re.L is True (LOCALE and L are the same RegexFlag enum member value)"]
    - [noflag_int,         "NOFLAG.__int__",                [],       0,     "int(re.NOFLAG) == 0 (represents the absence of any flags; added in Python 3.11)"]
    - [locale_lt_unicode,  "LOCALE.__lt__",                 ["UNICODE"], true, "re.LOCALE < re.UNICODE (4 < 32; LOCALE has a smaller bit value than UNICODE)"]
    - [unicode_lt_verbose, "UNICODE.__lt__",                ["VERBOSE"], true, "re.UNICODE < re.VERBOSE (32 < 64; UNICODE bit value is less than VERBOSE)"]

# ---------------------------------------------------------------------------
# re.RegexFlag .name string values and lengths
# RegexFlag.VERBOSE.name == 'VERBOSE' (7 chars).
# RegexFlag.DEBUG.name == 'DEBUG' (5 chars; shortest).
# RegexFlag.UNICODE.name == 'UNICODE' (7 chars; same length as VERBOSE).
# RegexFlag.LOCALE.name == 'LOCALE' (6 chars).
# RegexFlag.NOFLAG.name == 'NOFLAG' (6 chars; same length as LOCALE).
# ---------------------------------------------------------------------------

table re_extra113.RegexFlag_name_strings:
  description: "re.RegexFlag .name attribute values: VERBOSE='VERBOSE'(7), DEBUG='DEBUG'(5), UNICODE='UNICODE'(7), LOCALE='LOCALE'(6), NOFLAG='NOFLAG'(6)"
  kind: python_call_eq
  category: flag_values
  id_prefix: reflag113c

  columns: [id, function, args, expected, description]
  rows:
    - [verbose_name_eq,    "RegexFlag.VERBOSE.name.__eq__",      ["VERBOSE"],  true,  "re.RegexFlag.VERBOSE.name == 'VERBOSE' (the canonical enum member name)"]
    - [verbose_name_len,   "RegexFlag.VERBOSE.name.__len__",     [],           7,     "len(re.RegexFlag.VERBOSE.name) == 7 ('VERBOSE' has 7 chars)"]
    - [debug_name_eq,      "RegexFlag.DEBUG.name.__eq__",        ["DEBUG"],    true,  "re.RegexFlag.DEBUG.name == 'DEBUG' (the canonical enum member name)"]
    - [debug_name_len,     "RegexFlag.DEBUG.name.__len__",       [],           5,     "len(re.RegexFlag.DEBUG.name) == 5 ('DEBUG' has 5 chars; shortest among the five flag names)"]
    - [unicode_name_eq,    "RegexFlag.UNICODE.name.__eq__",      ["UNICODE"],  true,  "re.RegexFlag.UNICODE.name == 'UNICODE' (the canonical enum member name)"]
    - [unicode_name_len,   "RegexFlag.UNICODE.name.__len__",     [],           7,     "len(re.RegexFlag.UNICODE.name) == 7 ('UNICODE' has 7 chars; same length as VERBOSE)"]
    - [locale_name_eq,     "RegexFlag.LOCALE.name.__eq__",       ["LOCALE"],   true,  "re.RegexFlag.LOCALE.name == 'LOCALE' (the canonical enum member name)"]
    - [locale_name_len,    "RegexFlag.LOCALE.name.__len__",      [],           6,     "len(re.RegexFlag.LOCALE.name) == 6 ('LOCALE' has 6 chars)"]
    - [verbose_eq_unicode_namelen, "RegexFlag.VERBOSE.name.__len__.__eq__", [7], true, "len(re.RegexFlag.VERBOSE.name) == len(re.RegexFlag.UNICODE.name) == 7 (VERBOSE and UNICODE share identical name length)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra113.VERBOSE_int_value:
  description: "int(re.VERBOSE) == 64 (re.VERBOSE enables verbose mode which allows whitespace and comments in patterns; it has the integer value 64; its short alias re.X has the same value 64; re.VERBOSE == re.X is True because they are the same RegexFlag enum member)"
  category: flag_values
  kind: python_call_eq
  function: "VERBOSE.__int__"
  args: []
  expected: 64

invariant re_extra113.DEBUG_int_value:
  description: "int(re.DEBUG) == 128 (re.DEBUG causes the compiled regex engine to display debug information about the compiled expression; it has integer value 128 which is the next power of two above VERBOSE(64); there is no short single-letter alias for DEBUG unlike VERBOSE(X)/UNICODE(U)/LOCALE(L))"
  category: flag_values
  kind: python_call_eq
  function: "DEBUG.__int__"
  args: []
  expected: 128

invariant re_extra113.UNICODE_eq_U:
  description: "re.UNICODE == re.U is True (both have integer value 32; UNICODE and U are alias names for the same RegexFlag enum member; UNICODE enables Unicode matching for pattern metacharacters like \\w, \\b, \\d, \\s and is the default in Python 3 string patterns)"
  category: flag_values
  kind: python_call_eq
  function: "UNICODE.__eq__"
  args: ["U"]
  expected: true

invariant re_extra113.LOCALE_int_value:
  description: "int(re.LOCALE) == 4 (re.LOCALE / re.L has integer value 4; it makes \\w, \\b, \\d, \\s character class matches depend on the current locale setting; deprecated since Python 3.6 and mutually incompatible with re.UNICODE; its short alias re.L has the same value 4)"
  category: flag_values
  kind: python_call_eq
  function: "LOCALE.__int__"
  args: []
  expected: 4

invariant re_extra113.RegexFlag_DEBUG_name:
  description: "re.RegexFlag.DEBUG.name == 'DEBUG' (length 5; it is the shortest name among the five flag names examined — VERBOSE(7)/DEBUG(5)/UNICODE(7)/LOCALE(6)/NOFLAG(6); the name attribute returns the string used to identify this enum member in the RegexFlag enumeration)"
  category: flag_values
  kind: python_call_eq
  function: "RegexFlag.DEBUG.name.__eq__"
  args: ["DEBUG"]
  expected: true

