spec: hashlib_extra275
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "hashlib_extra274.zspec.zsdl — covers BLAKE2 constructor identity and hmac.HMAC method identity."
    - "hashlib_extra273.zspec.zsdl — covers hmac module identity and HMAC class/function identity."
    - "hashlib_extra272.zspec.zsdl — covers hashlib module __spec__ and __loader__ identity."
  notes:
    - "hashlib.sha256(b'').hexdigest() == 'e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855' — well-known SHA-256 digest of the empty byte string. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.md5(b'').hexdigest() == 'd41d8cd98f00b204e9800998ecf8427e' — well-known MD5 digest of the empty byte string. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha1(b'').hexdigest() == 'da39a3ee5e6b4b0d3255bfef95601890afd80709' — well-known SHA-1 digest of the empty byte string. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha256(b'').digest_size == 32 — SHA-256 output is 256 bits / 32 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.md5(b'').digest_size == 16 — MD5 output is 128 bits / 16 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha1(b'').digest_size == 20 — SHA-1 output is 160 bits / 20 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha256(b'').block_size == 64 — SHA-256 internal block size is 512 bits / 64 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha256(b'').name == 'sha256' — .name attribute returns the algorithm name string. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha256(b'').__class__.__name__ == 'HASH' — all OpenSSL-backed hash objects are instances of the C HASH type. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Empty-input digest values for SHA-256, MD5, and SHA-1
# These are universal test vectors: the hexdigest of b'' is a fixed,
# well-known value for each algorithm.
# ---------------------------------------------------------------------------

table hashlib_extra275.empty_input_hexdigest:
  description: "hashlib empty-input hexdigest test vectors — sha256(b'') / md5(b'') / sha1(b'') produce well-known fixed hex strings; verified with Python 3.14.3"
  kind: python_call_eq
  category: behavior
  id_prefix: emptydig275

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_hex,  sha256_hexdigest_of_empty.__eq__,  ["e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"], true, "hashlib.sha256(b'').hexdigest() == known SHA-256 of empty bytes"]
    - [md5_hex,     md5_hexdigest_of_empty.__eq__,     ["d41d8cd98f00b204e9800998ecf8427e"],                                     true, "hashlib.md5(b'').hexdigest() == known MD5 of empty bytes"]
    - [sha1_hex,    sha1_hexdigest_of_empty.__eq__,    ["da39a3ee5e6b4b0d3255bfef95601890afd80709"],                             true, "hashlib.sha1(b'').hexdigest() == known SHA-1 of empty bytes"]
    - [sha256_name, sha256_name_attr.__eq__,           ["sha256"],                                                               true, "hashlib.sha256(b'').name == 'sha256' — .name attribute returns the algorithm string"]
    - [md5_name,    md5_name_attr.__eq__,              ["md5"],                                                                  true, "hashlib.md5(b'').name == 'md5' — .name attribute returns the algorithm string"]

# ---------------------------------------------------------------------------
# digest_size and block_size attributes for SHA-256, MD5, SHA-1
# These structural attributes are fixed per algorithm regardless of input.
# ---------------------------------------------------------------------------

table hashlib_extra275.digest_and_block_sizes:
  description: "hashlib digest_size and block_size attributes — sha256: 32/64; md5: 16/64; sha1: 20/64; HASH class name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: sizeid275

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_dsize,  sha256_digest_size.__eq__,   [32], true, "hashlib.sha256(b'').digest_size == 32 — SHA-256 output is 32 bytes"]
    - [md5_dsize,     md5_digest_size.__eq__,      [16], true, "hashlib.md5(b'').digest_size == 16 — MD5 output is 16 bytes"]
    - [sha1_dsize,    sha1_digest_size.__eq__,     [20], true, "hashlib.sha1(b'').digest_size == 20 — SHA-1 output is 20 bytes"]
    - [sha256_bsize,  sha256_block_size.__eq__,    [64], true, "hashlib.sha256(b'').block_size == 64 — SHA-256 internal block is 64 bytes"]
    - [sha256_cls,    sha256_class_name.__eq__,    ["HASH"], true, "hashlib.sha256(b'').__class__.__name__ == 'HASH' — OpenSSL-backed hash object type"]

# ---------------------------------------------------------------------------
# Standalone invariants — empty-input digest values and hash object attributes
# ---------------------------------------------------------------------------

invariant hashlib_extra275.sha256_empty_hexdigest_eq:
  description: "hashlib.sha256(b'').hexdigest() == 'e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855' — canonical SHA-256 test vector for the empty byte string; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: sha256_hexdigest_of_empty.__eq__
  args: ["e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"]
  expected: true

invariant hashlib_extra275.md5_empty_hexdigest_eq:
  description: "hashlib.md5(b'').hexdigest() == 'd41d8cd98f00b204e9800998ecf8427e' — canonical MD5 test vector for the empty byte string; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: md5_hexdigest_of_empty.__eq__
  args: ["d41d8cd98f00b204e9800998ecf8427e"]
  expected: true

invariant hashlib_extra275.sha1_empty_hexdigest_eq:
  description: "hashlib.sha1(b'').hexdigest() == 'da39a3ee5e6b4b0d3255bfef95601890afd80709' — canonical SHA-1 test vector for the empty byte string; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: sha1_hexdigest_of_empty.__eq__
  args: ["da39a3ee5e6b4b0d3255bfef95601890afd80709"]
  expected: true

invariant hashlib_extra275.sha256_digest_size_eq:
  description: "hashlib.sha256(b'').digest_size == 32 — SHA-256 produces a 256-bit / 32-byte digest; this attribute is fixed for the algorithm; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: sha256_digest_size.__eq__
  args: [32]
  expected: true

invariant hashlib_extra275.md5_digest_size_eq:
  description: "hashlib.md5(b'').digest_size == 16 — MD5 produces a 128-bit / 16-byte digest; this attribute is fixed for the algorithm; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: md5_digest_size.__eq__
  args: [16]
  expected: true

invariant hashlib_extra275.sha1_digest_size_eq:
  description: "hashlib.sha1(b'').digest_size == 20 — SHA-1 produces a 160-bit / 20-byte digest; this attribute is fixed for the algorithm; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: sha1_digest_size.__eq__
  args: [20]
  expected: true

invariant hashlib_extra275.sha256_block_size_eq:
  description: "hashlib.sha256(b'').block_size == 64 — SHA-256 operates on 512-bit / 64-byte input blocks; block_size is a fixed attribute of the HASH object; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: sha256_block_size.__eq__
  args: [64]
  expected: true

invariant hashlib_extra275.sha256_name_eq:
  description: "hashlib.sha256(b'').name == 'sha256' — the .name attribute of a hash object is the lowercase algorithm name string; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: sha256_name_attr.__eq__
  args: ["sha256"]
  expected: true

invariant hashlib_extra275.md5_name_eq:
  description: "hashlib.md5(b'').name == 'md5' — the .name attribute of a hash object is the lowercase algorithm name string; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: md5_name_attr.__eq__
  args: ["md5"]
  expected: true

invariant hashlib_extra275.sha256_class_name_eq:
  description: "hashlib.sha256(b'').__class__.__name__ == 'HASH' — all OpenSSL-backed hash objects (sha256, md5, sha1) are instances of the C extension type HASH from _hashlib; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: sha256_class_name.__eq__
  args: ["HASH"]
  expected: true
