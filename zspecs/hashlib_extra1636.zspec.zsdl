spec: hashlib_extra1636
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
  notes:
    - "behavioral invariants for ABC virtual subclassing protocol"
    - "hashlib hash types are C extension types; they do not define __subclasshook__, __instancecheck__, or __subclasscheck__ in their own __dict__."
    - "type(hashlib.md5(b'')) is the C-level HASH type; its __dict__ does not contain __subclasshook__."
    - "type(hashlib.sha256(b'')) similarly has no __subclasshook__ in its __dict__."
    - "isinstance and issubclass work normally on these types through the default object machinery."
    - "hashlib.algorithms_guaranteed is a plain Python set (not frozenset) on Python 3.9+."
    - "hashlib.algorithms_available is also a plain Python set."
    - "type(hashlib.algorithms_guaranteed).__name__ == 'set' (verified Python 3.14.3)."
    - "hashlib does not define a HashError or any hashlib-specific exception class at module level."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: hash type __dict__ does not contain ABC hook methods
#
# C-extension hash types (md5, sha256, sha1, sha512, sha3_256, sha3_512,
# blake2b, blake2s) are not ABCs and do not define __subclasshook__,
# __instancecheck__, or __subclasscheck__ in their own __dict__.
#
# We test this via the constructor's .__class__.__dict__.__contains__ path:
# md5 is the module-level constructor; md5.__class__ is the C type object
# for the md5 hash type; .__dict__.__contains__ checks its slot mapping.
# ---------------------------------------------------------------------------

table hashlib_extra1636.hash_type_no_virtual_subclassing:
  description: "C-extension hash types do not define ABC virtual-subclassing hooks in their __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1636

  columns: [id, function, args, expected]
  rows:
    - ["hl1636001", "md5.__class__.__dict__.__contains__",      ["__subclasshook__"],  false]
    - ["hl1636002", "md5.__class__.__dict__.__contains__",      ["__instancecheck__"], false]
    - ["hl1636003", "md5.__class__.__dict__.__contains__",      ["__subclasscheck__"], false]
    - ["hl1636004", "sha256.__class__.__dict__.__contains__",   ["__subclasshook__"],  false]
    - ["hl1636005", "sha256.__class__.__dict__.__contains__",   ["__instancecheck__"], false]
    - ["hl1636006", "sha256.__class__.__dict__.__contains__",   ["__subclasscheck__"], false]
    - ["hl1636007", "sha1.__class__.__dict__.__contains__",     ["__subclasshook__"],  false]
    - ["hl1636008", "sha1.__class__.__dict__.__contains__",     ["__instancecheck__"], false]
    - ["hl1636009", "sha1.__class__.__dict__.__contains__",     ["__subclasscheck__"], false]
    - ["hl1636010", "sha512.__class__.__dict__.__contains__",   ["__subclasshook__"],  false]
    - ["hl1636011", "sha512.__class__.__dict__.__contains__",   ["__instancecheck__"], false]
    - ["hl1636012", "sha512.__class__.__dict__.__contains__",   ["__subclasscheck__"], false]
    - ["hl1636013", "sha3_256.__class__.__dict__.__contains__", ["__subclasshook__"],  false]
    - ["hl1636014", "sha3_256.__class__.__dict__.__contains__", ["__instancecheck__"], false]
    - ["hl1636015", "sha3_256.__class__.__dict__.__contains__", ["__subclasscheck__"], false]
    - ["hl1636016", "sha3_512.__class__.__dict__.__contains__", ["__subclasshook__"],  false]
    - ["hl1636017", "sha3_512.__class__.__dict__.__contains__", ["__instancecheck__"], false]
    - ["hl1636018", "sha3_512.__class__.__dict__.__contains__", ["__subclasscheck__"], false]
    - ["hl1636019", "blake2b.__class__.__dict__.__contains__",  ["__subclasshook__"],  false]
    - ["hl1636020", "blake2b.__class__.__dict__.__contains__",  ["__instancecheck__"], false]
    - ["hl1636021", "blake2b.__class__.__dict__.__contains__",  ["__subclasscheck__"], false]
    - ["hl1636022", "blake2s.__class__.__dict__.__contains__",  ["__subclasshook__"],  false]
    - ["hl1636023", "blake2s.__class__.__dict__.__contains__",  ["__instancecheck__"], false]
    - ["hl1636024", "blake2s.__class__.__dict__.__contains__",  ["__subclasscheck__"], false]

# ---------------------------------------------------------------------------
# Table 2: isinstance / issubclass checks for hash objects and their types
#
# Even without ABC hooks, the default object machinery makes isinstance and
# issubclass work correctly for hash types.
# ---------------------------------------------------------------------------

table hashlib_extra1636.hash_isinstance_checks:
  description: "isinstance and issubclass work normally for C-extension hash types without ABC hooks"
  kind: python_call_eq
  category: isinstance_issubclass
  id_prefix: hl1636

  columns: [id, function, args, expected]
  rows:
    - ["hl1636025", "md5.__class__.__name__.__class__.__name__.__eq__",     ["str"],   true]
    - ["hl1636026", "sha256.__class__.__name__.__class__.__name__.__eq__",  ["str"],   true]
    - ["hl1636027", "md5.__class__.__bases__.__len__",                      [],         1]
    - ["hl1636028", "md5.__class__.__bases__.__getitem__",                  [0],       "object"]
    - ["hl1636029", "sha256.__class__.__bases__.__getitem__",               [0],       "object"]
    - ["hl1636030", "sha1.__class__.__bases__.__getitem__",                 [0],       "object"]
    - ["hl1636031", "sha512.__class__.__bases__.__getitem__",               [0],       "object"]
    - ["hl1636032", "sha3_256.__class__.__bases__.__getitem__",             [0],       "object"]
    - ["hl1636033", "sha3_512.__class__.__bases__.__getitem__",             [0],       "object"]
    - ["hl1636034", "blake2b.__class__.__bases__.__getitem__",              [0],       "object"]
    - ["hl1636035", "blake2s.__class__.__bases__.__getitem__",              [0],       "object"]
    - ["hl1636036", "md5.__class__.__name__.__eq__",                        ["md5"],   true]
    - ["hl1636037", "sha256.__class__.__name__.__eq__",                     ["sha256"],true]
    - ["hl1636038", "sha1.__class__.__name__.__eq__",                       ["sha1"],  true]
    - ["hl1636039", "sha3_256.__class__.__name__.__eq__",                   ["sha3_256"], true]
    - ["hl1636040", "sha3_512.__class__.__name__.__eq__",                   ["sha3_512"], true]
    - ["hl1636041", "md5.__class__.__dict__.__contains__",                  ["digest"],   true]
    - ["hl1636042", "md5.__class__.__dict__.__contains__",                  ["hexdigest"],true]
    - ["hl1636043", "sha256.__class__.__dict__.__contains__",               ["digest"],   true]
    - ["hl1636044", "sha256.__class__.__dict__.__contains__",               ["update"],   true]

# ---------------------------------------------------------------------------
# Table 3: algorithms_guaranteed and algorithms_available type checks
#
# Both attributes are plain Python sets (not frozenset, not list).
# issubclass(type(algorithms_guaranteed), set) is True.
# hashlib has no HashError at module level.
# ---------------------------------------------------------------------------

table hashlib_extra1636.algorithms_type_checks:
  description: "algorithms_guaranteed and algorithms_available are plain sets; no HashError at module level"
  kind: python_call_eq
  category: module_attributes
  id_prefix: hl1636

  columns: [id, function, args, expected]
  rows:
    - ["hl1636045", "algorithms_guaranteed.__class__.__name__.__eq__", ["set"],       true]
    - ["hl1636046", "algorithms_available.__class__.__name__.__eq__",  ["set"],       true]
    - ["hl1636047", "algorithms_guaranteed.__class__.__name__.__eq__", ["frozenset"], false]
    - ["hl1636048", "algorithms_available.__class__.__name__.__eq__",  ["frozenset"], false]
    - ["hl1636049", "algorithms_guaranteed.__class__.__name__.__eq__", ["list"],      false]
    - ["hl1636050", "algorithms_guaranteed.__contains__",              ["sha256"],    true]
    - ["hl1636051", "algorithms_guaranteed.__contains__",              ["sha512"],    true]
    - ["hl1636052", "algorithms_guaranteed.__contains__",              ["md5"],       true]
    - ["hl1636053", "algorithms_guaranteed.__contains__",              ["sha1"],      true]
    - ["hl1636054", "algorithms_guaranteed.__contains__",              ["blake2b"],   true]
    - ["hl1636055", "algorithms_guaranteed.__contains__",              ["blake2s"],   true]
    - ["hl1636056", "algorithms_guaranteed.__contains__",              ["sha3_256"],  true]
    - ["hl1636057", "algorithms_guaranteed.__contains__",              ["sha3_512"],  true]
    - ["hl1636058", "algorithms_available.__contains__",               ["sha256"],    true]
    - ["hl1636059", "algorithms_available.__contains__",               ["md5"],       true]
    - ["hl1636060", "algorithms_guaranteed.__class__.__mro__.__len__", [],            3]
