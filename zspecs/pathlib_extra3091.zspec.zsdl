spec: pp3091
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 653 (pp3091): __hash__, __eq__, __bool__ dict-presence checks for pathlib types."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS)."
    - "pathlib.PurePath defines both __hash__ and __eq__ in its own __dict__: pure paths are value-typed and support hashing and equality by path value."
    - "pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, and pathlib.PosixPath do NOT define __hash__ or __eq__ in their own __dict__: they inherit from PurePath."
    - "No pathlib class defines __bool__ in its own __dict__; boolean coercion is inherited from object."
    - "pathlib.PosixPath is available on macOS/POSIX platforms; pathlib.WindowsPath is only instantiable on Windows."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __hash__ dict-presence — operator.contains(Cls.__dict__, '__hash__')
#
# pathlib.PurePath defines __hash__ (true); subclasses inherit it (false).
# Pure path objects are hashable by path value; __hash__ is defined on the
# base PurePath class, not on each subclass.
# ---------------------------------------------------------------------------

table pp3091.hash:
  description: "pathlib types __hash__ dict-presence checks; wave 653"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3091

  columns: [id, function, args, expected]
  rows:
    - ["pp3091001", operator.contains, [pathlib.PurePath.__dict__,        "__hash__"], true]
    - ["pp3091002", operator.contains, [pathlib.PurePosixPath.__dict__,   "__hash__"], false]
    - ["pp3091003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__hash__"], false]
    - ["pp3091004", operator.contains, [pathlib.Path.__dict__,            "__hash__"], false]
    - ["pp3091005", operator.contains, [pathlib.PosixPath.__dict__,       "__hash__"], false]

# ---------------------------------------------------------------------------
# __eq__ dict-presence — operator.contains(Cls.__dict__, '__eq__')
#
# pathlib.PurePath defines __eq__ (true); subclasses inherit it (false).
# Pure path equality compares path components; __eq__ is on PurePath, not subclasses.
# ---------------------------------------------------------------------------

table pp3091.eq:
  description: "pathlib types __eq__ dict-presence checks; wave 653"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3091

  columns: [id, function, args, expected]
  rows:
    - ["pp3091006", operator.contains, [pathlib.PurePath.__dict__,        "__eq__"], true]
    - ["pp3091007", operator.contains, [pathlib.PurePosixPath.__dict__,   "__eq__"], false]
    - ["pp3091008", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__eq__"], false]
    - ["pp3091009", operator.contains, [pathlib.Path.__dict__,            "__eq__"], false]
    - ["pp3091010", operator.contains, [pathlib.PosixPath.__dict__,       "__eq__"], false]

# ---------------------------------------------------------------------------
# __bool__ dict-presence — operator.contains(Cls.__dict__, '__bool__')
#
# No pathlib path class defines __bool__ in its own __dict__; all false.
# Boolean coercion is not overridden by any pathlib class.
# ---------------------------------------------------------------------------

table pp3091.bool:
  description: "pathlib types __bool__ dict-presence checks; wave 653"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3091

  columns: [id, function, args, expected]
  rows:
    - ["pp3091011", operator.contains, [pathlib.PurePath.__dict__,        "__bool__"], false]
    - ["pp3091012", operator.contains, [pathlib.PurePosixPath.__dict__,   "__bool__"], false]
    - ["pp3091013", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__bool__"], false]
    - ["pp3091014", operator.contains, [pathlib.Path.__dict__,            "__bool__"], false]
    - ["pp3091015", operator.contains, [pathlib.PosixPath.__dict__,       "__bool__"], false]

# ---------------------------------------------------------------------------
