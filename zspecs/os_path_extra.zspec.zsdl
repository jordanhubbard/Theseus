spec: os_path_extra
version: ">=3.2"
backend: python_module(os.path)

docs: https://docs.python.org/3/library/os.path.html

provenance:
  derived_from:
    - "Python os.path documentation — https://docs.python.org/3/library/os.path.html"
    - "Test vectors verified by running Python 3.14.3 os.path module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/posixpath.py"
    - "CPython source: Lib/ntpath.py"
    - "os_path.zspec.zsdl — covers join (two/three/abs/reset/empty), basename, dirname, isabs, normpath (dotdot/dot/double_sep/empty/dot/dotdot_rel), commonprefix, splitext, splitdrive, split"
  notes:
    - "This spec extends os_path.zspec.zsdl with additional join, splitext, normpath, and function identity invariants."
    - "os.path.join('/a', 'b', 'c') == '/a/b/c' — three args with leading absolute component."
    - "os.path.join('a', 'b', '/c') == '/c' — absolute component in a later position resets the result."
    - "os.path.splitext('/a/b/c.tar.gz')[0] == '/a/b/c.tar' — only the last extension is stripped."
    - "os.path.splitext('/a/b/c.tar.gz')[1] == '.gz' — only the last extension is returned."
    - "os.path.normpath('/a//b/../c') == '/a/c' — collapses double-sep and resolves dotdot."
    - "Function identity invariants (.__name__) confirm the expected symbol is present in the module."
    - "abspath, realpath, expanduser, expandvars, commonpath, commonprefix are verified by name only."
    - "All expected values verified by running Python 3.14.3 os.path module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# join — additional vectors not in os_path.zspec.zsdl
# os_path.zspec.zsdl already has: two_parts, three_parts('a','b','c'), abs_root,
#   abs_reset('a','/abs'), empty_head, empty_tail.
# We add a three-arg absolute path and an absolute-reset with three args.
# ---------------------------------------------------------------------------

invariant os_path_extra.join.three_abs:
  description: "join('/a', 'b', 'c') == '/a/b/c'"
  category: join
  kind: python_call_eq
  function: join
  args: ["/a", "b", "c"]
  expected: "/a/b/c"

invariant os_path_extra.join.abs_reset_three:
  description: "join('a', 'b', '/c') == '/c' — absolute path in third position resets result"
  category: join
  kind: python_call_eq
  function: join
  args: ["a", "b", "/c"]
  expected: "/c"

# ---------------------------------------------------------------------------
# basename — additional specific vectors
# os_path.zspec.zsdl has: '/foo/bar.py' -> 'bar.py', '/foo/' -> '', 'bar.py', ''
# We add the canonical '/a/b/c.txt' -> 'c.txt' vector
# ---------------------------------------------------------------------------

invariant os_path_extra.basename.path_with_ext:
  description: "basename('/a/b/c.txt') == 'c.txt'"
  category: basename
  kind: python_call_eq
  function: basename
  args: ["/a/b/c.txt"]
  expected: "c.txt"

# ---------------------------------------------------------------------------
# dirname — additional specific vectors
# os_path.zspec.zsdl has: '/foo/bar.py' -> '/foo', 'bar.py' -> '', '/foo/' -> '/foo', '' -> ''
# We add the canonical '/a/b/c.txt' -> '/a/b' vector
# ---------------------------------------------------------------------------

invariant os_path_extra.dirname.path_with_ext:
  description: "dirname('/a/b/c.txt') == '/a/b'"
  category: dirname
  kind: python_call_eq
  function: dirname
  args: ["/a/b/c.txt"]
  expected: "/a/b"

# ---------------------------------------------------------------------------
# splitext — vectors for /a/b/c.txt and /a/b/c.tar.gz
# os_path.zspec.zsdl covers 'hello.py', 'a.b.c', 'noext', '.hidden'
# We add path-qualified vectors and the tar.gz two-extension case
# ---------------------------------------------------------------------------

invariant os_path_extra.splitext.txt_base:
  description: "splitext('/a/b/c.txt')[0] == '/a/b/c'"
  category: splitext
  kind: python_call_eq
  function: splitext
  args: ["/a/b/c.txt"]
  method: __getitem__
  method_args: [0]
  expected: "/a/b/c"

invariant os_path_extra.splitext.txt_ext:
  description: "splitext('/a/b/c.txt')[1] == '.txt'"
  category: splitext
  kind: python_call_eq
  function: splitext
  args: ["/a/b/c.txt"]
  method: __getitem__
  method_args: [1]
  expected: ".txt"

invariant os_path_extra.splitext.tar_gz_base:
  description: "splitext('/a/b/c.tar.gz')[0] == '/a/b/c.tar' — only last extension is stripped"
  category: splitext
  kind: python_call_eq
  function: splitext
  args: ["/a/b/c.tar.gz"]
  method: __getitem__
  method_args: [0]
  expected: "/a/b/c.tar"

invariant os_path_extra.splitext.tar_gz_ext:
  description: "splitext('/a/b/c.tar.gz')[1] == '.gz' — only last extension is returned"
  category: splitext
  kind: python_call_eq
  function: splitext
  args: ["/a/b/c.tar.gz"]
  method: __getitem__
  method_args: [1]
  expected: ".gz"

# ---------------------------------------------------------------------------
# normpath — additional vectors
# os_path.zspec.zsdl has: '/foo/../bar', 'a/./b', 'a//b', '', '.', '..'
# We add the '/a//b/../c' -> '/a/c' case (double-sep + dotdot in same path)
# ---------------------------------------------------------------------------

invariant os_path_extra.normpath.double_sep_dotdot:
  description: "normpath('/a//b/../c') == '/a/c' — collapses double separator and resolves dotdot"
  category: normpath
  kind: python_call_eq
  function: normpath
  args: ["/a//b/../c"]
  expected: "/a/c"

invariant os_path_extra.normpath.dot_segment:
  description: "normpath('a/./b') == 'a/b' — dot segment is collapsed"
  category: normpath
  kind: python_call_eq
  function: normpath
  args: ["a/./b"]
  expected: "a/b"

# ---------------------------------------------------------------------------
# Function identity checks — confirm symbols exist under expected names
# ---------------------------------------------------------------------------

invariant os_path_extra.abspath.name:
  description: "os.path.abspath.__name__ == 'abspath'"
  category: function_identity
  kind: python_call_eq
  function: abspath.__name__.__eq__
  args: ["abspath"]
  expected: true

invariant os_path_extra.realpath.name:
  description: "os.path.realpath.__name__ == 'realpath'"
  category: function_identity
  kind: python_call_eq
  function: realpath.__name__.__eq__
  args: ["realpath"]
  expected: true

invariant os_path_extra.expanduser.name:
  description: "os.path.expanduser.__name__ == 'expanduser'"
  category: function_identity
  kind: python_call_eq
  function: expanduser.__name__.__eq__
  args: ["expanduser"]
  expected: true

invariant os_path_extra.expandvars.name:
  description: "os.path.expandvars.__name__ == 'expandvars'"
  category: function_identity
  kind: python_call_eq
  function: expandvars.__name__.__eq__
  args: ["expandvars"]
  expected: true

invariant os_path_extra.commonpath.name:
  description: "os.path.commonpath.__name__ == 'commonpath'"
  category: function_identity
  kind: python_call_eq
  function: commonpath.__name__.__eq__
  args: ["commonpath"]
  expected: true

invariant os_path_extra.commonprefix.name:
  description: "os.path.commonprefix.__name__ == 'commonprefix'"
  category: function_identity
  kind: python_call_eq
  function: commonprefix.__name__.__eq__
  args: ["commonprefix"]
  expected: true
