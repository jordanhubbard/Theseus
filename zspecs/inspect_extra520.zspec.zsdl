spec: inspect_extra520
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "inspect.FrameInfo, Traceback, ArgInfo, Arguments, FullArgSpec are NamedTuples with __bases__[0].__name__ == 'tuple'"
    - "All these types have __module__ == 'inspect'"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra520.namedtuple_names:
  description: "inspect NamedTuple class __name__ identity — FrameInfo, Traceback, ArgInfo, Arguments, FullArgSpec"
  kind: python_call_eq
  category: class_names
  id_prefix: ins520nn

  columns: [id, function, args, expected]
  rows:
    - [ins520nn001, FrameInfo.__name__.__eq__,    ["FrameInfo"],    true]
    - [ins520nn002, Traceback.__name__.__eq__,    ["Traceback"],    true]
    - [ins520nn003, ArgInfo.__name__.__eq__,      ["ArgInfo"],      true]
    - [ins520nn004, Arguments.__name__.__eq__,    ["Arguments"],    true]
    - [ins520nn005, FullArgSpec.__name__.__eq__,  ["FullArgSpec"],  true]

table inspect_extra520.namedtuple_modules:
  description: "inspect NamedTuple class __module__ == 'inspect'"
  kind: python_call_eq
  category: class_modules
  id_prefix: ins520nm

  columns: [id, function, args, expected]
  rows:
    - [ins520nm001, FrameInfo.__module__.__eq__,   ["inspect"], true]
    - [ins520nm002, Traceback.__module__.__eq__,   ["inspect"], true]
    - [ins520nm003, ArgInfo.__module__.__eq__,     ["inspect"], true]
    - [ins520nm004, FullArgSpec.__module__.__eq__,  ["inspect"], true]

table inspect_extra520.namedtuple_bases:
  description: "inspect NamedTuple class __bases__[0].__name__ == 'tuple' — all are NamedTuple subclasses of tuple"
  kind: python_call_eq
  category: class_bases
  id_prefix: ins520nb

  columns: [id, function, args, expected]
  rows:
    - [ins520nb001, "FrameInfo.__bases__[0].__name__.__eq__",   ["tuple"], true]
    - [ins520nb002, "Traceback.__bases__[0].__name__.__eq__",   ["tuple"], true]
    - [ins520nb003, "ArgInfo.__bases__[0].__name__.__eq__",     ["tuple"], true]
    - [ins520nb004, "FullArgSpec.__bases__[0].__name__.__eq__", ["tuple"], true]
