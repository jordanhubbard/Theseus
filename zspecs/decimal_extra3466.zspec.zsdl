spec: dc3466
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal: Decimal fixed-point and floating-point arithmetic"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 678 (dc3466): __iter__, __next__, __len__ dict-presence checks for decimal types."
    - "Classes covered: decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow."
    - "Theme: __iter__/__next__/__len__ dict-presence (iterator/sequence protocol)."
    - "No decimal class defines __iter__ in its own __dict__: decimal types are numeric and exception types, not iterable containers."
    - "No decimal class defines __next__ in its own __dict__: decimal types do not implement the iterator advancement method."
    - "decimal.Decimal defines many numeric operators but NOT __iter__, __next__, or __len__ in its own __dict__."
    - "No decimal class defines __len__ in its own __dict__: decimal types have no defined length protocol."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Consistent with prior waves: all iterator/sequence protocols absent from decimal class __dict__s."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __iter__ dict-presence — operator.contains(Cls.__dict__, '__iter__')
#
# No decimal class defines __iter__ in its own __dict__; all false.
# decimal.Decimal is a numeric type, not an iterable container; __iter__
# is not defined. Context and exception subclasses are also false.
# ---------------------------------------------------------------------------

table dc3466.iter:
  description: "decimal types __iter__ dict-presence checks; wave 678"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3466

  columns: [id, function, args, expected]
  rows:
    - ["dc3466001", operator.contains, [decimal.Decimal.__dict__,          "__iter__"], false]
    - ["dc3466002", operator.contains, [decimal.Context.__dict__,           "__iter__"], false]
    - ["dc3466003", operator.contains, [decimal.DecimalException.__dict__,  "__iter__"], false]
    - ["dc3466004", operator.contains, [decimal.InvalidOperation.__dict__,  "__iter__"], false]
    - ["dc3466005", operator.contains, [decimal.Overflow.__dict__,          "__iter__"], false]
    - ["dc3466006", operator.contains, [decimal.Underflow.__dict__,         "__iter__"], false]

