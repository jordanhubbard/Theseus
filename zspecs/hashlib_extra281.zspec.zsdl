spec: hashlib_extra281
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "RFC 2898 — PKCS #5: Password-Based Cryptography Specification Version 2.0"
  - "FIPS 180-4 — Secure Hash Standard (SHS)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "RFC 2898 — PKCS #5: Password-Based Cryptography Specification Version 2.0"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
  notes:
    - "This spec extends hashlib.zspec.zsdl through hashlib_extra280.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "hashlib.zspec.zsdl covers: sha256/sha1/md5/sha512/sha3_256/sha3_512/blake2b/blake2s known vectors; digest_size/block_size; algorithms_guaranteed; digest_consistency."
    - "hashlib_extra280.zspec.zsdl covers: HASH/__class__/__name__/__module__/__qualname__/__bases__[0]/__name__ for sha256/md5/sha1; hmac.HMAC class identity."
    - "This spec focuses on: hashlib.pbkdf2_hmac() — known test vectors for sha256/sha1; output length invariants; dklen parameter; function class name."
    - "hashlib.pbkdf2_hmac('sha256', b'password', b'salt', 1).hex() == '120fb6cffcf8b32c43e7225256c4f837a86548c92ccc35480805987cb70be17b' — RFC 2898 vector. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.pbkdf2_hmac('sha1', b'password', b'salt', 1).hex() == '0c60c80f961f0e71f3a9b524af6012062fe037a6' — SHA-1 based PBKDF2 vector. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.pbkdf2_hmac('sha256', b'password', b'salt', 2).hex() == 'ae4d0c95af6b46d32d0adff928f06dd02a303f8ef3c251dfd6e2d85a95474c43' — second iteration changes output significantly. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.pbkdf2_hmac('sha256', ..., dklen=16) truncates to first 16 bytes of full output. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "len(hashlib.pbkdf2_hmac('sha256', b'password', b'salt', 1)) == 32 — sha256 PRF yields 32-byte derived key by default. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "len(hashlib.pbkdf2_hmac('sha1', b'password', b'salt', 1)) == 20 — sha1 PRF yields 20-byte derived key by default. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method' — pbkdf2_hmac is a C-level function in _hashlib. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model:
  semantics: "hashlib.pbkdf2_hmac raises ValueError for unsupported hash names and TypeError for incorrect argument types."
  stderr: "null"
  stickiness: "N/A — pbkdf2_hmac is a pure deterministic function with no shared state."
  codes: {}

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac — known test vectors
# RFC 2898 §5.2 defines PBKDF2. The vectors below use password=b'password',
# salt=b'salt', and iterations=1 or 2. These are widely-cited reference
# values. No prior spec in hashlib.zspec.zsdl through hashlib_extra280 encodes
# pbkdf2_hmac output as machine-readable python_call_eq invariants.
# ---------------------------------------------------------------------------

table hashlib_extra281.pbkdf2_hmac_vectors:
  description: "hashlib.pbkdf2_hmac() known test vectors — sha256/sha1 with password=b'password', salt=b'salt', iterations=1/2; verified with Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: pbkdf2_vector
  function: pbkdf2_hmac
  id_prefix: pbk281

  columns: [id, args, expected, description]
  rows:
    - [sha256_1iter, ["sha256", "password", "salt", 1], !hex 120fb6cffcf8b32c43e7225256c4f837a86548c92ccc35480805987cb70be17b, "sha256 PBKDF2 with password/salt/iterations=1; RFC 2898 reference vector"]
    - [sha256_2iter, ["sha256", "password", "salt", 2], !hex ae4d0c95af6b46d32d0adff928f06dd02a303f8ef3c251dfd6e2d85a95474c43, "sha256 PBKDF2 iterations=2; output differs substantially from iterations=1"]
    - [sha1_1iter,   ["sha1",   "password", "salt", 1], !hex 0c60c80f961f0e71f3a9b524af6012062fe037a6, "sha1 PBKDF2 with password/salt/iterations=1; 20-byte default output"]

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac — dklen parameter truncates output
# When dklen is provided, the derived key is truncated to the first dklen
# bytes of the full output. dklen=16 returns the first 16 bytes of the
# sha256 output (120fb6cffcf8b32c43e7225256c4f837).
# ---------------------------------------------------------------------------

invariant hashlib_extra281.pbkdf2_hmac.sha256_dklen16:
  description: "hashlib.pbkdf2_hmac('sha256', b'password', b'salt', 1, dklen=16) == first 16 bytes of sha256 full output; dklen truncates rather than extends; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: pbkdf2_vector
  kind: python_call_eq
  function: pbkdf2_hmac
  args: ["sha256", "password", "salt", 1]
  kwargs: {dklen: 16}
  expected: !hex 120fb6cffcf8b32c43e7225256c4f837

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac — output length equals hash digest_size by default
# Without dklen, the derived key length equals the underlying hash's
# digest_size: sha256 → 32 bytes, sha1 → 20 bytes.
# ---------------------------------------------------------------------------

table hashlib_extra281.pbkdf2_hmac_output_lengths:
  description: "hashlib.pbkdf2_hmac() default output length equals underlying hash digest_size — sha256→32, sha1→20; dklen=16 yields 16 bytes; verified with Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: output_length
  function: pbkdf2_hmac
  id_prefix: pbklen281

  columns: [id, args, method, method_args, expected, description]
  rows:
    - [sha256_default_len, ["sha256", "password", "salt", 1],             __len__, [], 32, "sha256 PBKDF2 default output is 32 bytes (sha256 digest_size)"]
    - [sha1_default_len,   ["sha1",   "password", "salt", 1],             __len__, [], 20, "sha1 PBKDF2 default output is 20 bytes (sha1 digest_size)"]
    - [sha256_dklen16_len, ["sha256", "password", "salt", 1, 16], __len__, [], 16, "sha256 PBKDF2 with dklen=16 yields exactly 16 bytes"]

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac — empty password and salt
# PBKDF2 is well-defined for empty password and salt strings. The output
# is deterministic. No prior spec checks the empty-input case.
# ---------------------------------------------------------------------------

invariant hashlib_extra281.pbkdf2_hmac.empty_inputs_length:
  description: "len(hashlib.pbkdf2_hmac('sha256', b'', b'', 1)) == 32 — empty password and salt still yield 32-byte output for sha256; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: output_length
  kind: python_call_eq
  function: pbkdf2_hmac
  args: ["sha256", "", "", 1]
  method: __len__
  method_args: []
  expected: 32

invariant hashlib_extra281.pbkdf2_hmac.empty_inputs_vector:
  description: "hashlib.pbkdf2_hmac('sha256', b'', b'', 1).hex() == 'f7ce0b653d2d72a4108cf5abe912ffdd777616dbbb27a70e8204f3ae2d0f6fad' — deterministic output for empty inputs; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: pbkdf2_vector
  kind: python_call_eq
  function: pbkdf2_hmac
  args: ["sha256", "", "", 1]
  method: hex
  method_args: []
  expected: "f7ce0b653d2d72a4108cf5abe912ffdd777616dbbb27a70e8204f3ae2d0f6fad"

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac — function identity: builtin_function_or_method
# pbkdf2_hmac is implemented in the _hashlib C extension, making it a
# builtin_function_or_method rather than a Python-level callable.
# ---------------------------------------------------------------------------

invariant hashlib_extra281.pbkdf2_hmac.class_name:
  description: "hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method' — pbkdf2_hmac is a C-level builtin from the _hashlib extension, not a pure-Python function; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: function_identity
  kind: python_call_eq
  function: pbkdf2_hmac.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac — raises ValueError for unknown hash name
# An unsupported algorithm name raises ValueError with a descriptive message.
# ---------------------------------------------------------------------------

invariant hashlib_extra281.pbkdf2_hmac.unknown_hash_raises:
  description: "hashlib.pbkdf2_hmac('not_a_hash', b'password', b'salt', 1) raises ValueError — unknown algorithm name is rejected; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: error
  kind: python_call_raises
  function: pbkdf2_hmac
  args: ["not_a_hash", "password", "salt", 1]
  raises: ValueError
