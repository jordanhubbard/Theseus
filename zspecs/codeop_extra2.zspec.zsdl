spec: codeop_extra2
version: ">=3.9"
backend: python_module(codeop)

docs: https://docs.python.org/3/library/codeop.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/codeop.html — Python codeop module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/codeop.py"
  notes:
    - "This spec extends codeop.zspec.zsdl and codeop_extra.zspec.zsdl."
    - "Focus: __name__, __module__, __qualname__, and __bases__ attributes for compile_command, CommandCompiler, and Compile."
    - "CommandCompiler and Compile both have object as their direct base class."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# names — compile_command function and CommandCompiler, Compile classes
# ---------------------------------------------------------------------------

invariant codeop_extra2.compile_command.name:
  description: "codeop.compile_command.__name__ == 'compile_command'"
  category: names
  kind: python_call_eq
  function: compile_command.__name__.__eq__
  args: ["compile_command"]
  expected: true

# Table for class names: CommandCompiler, Compile

table codeop_extra2.class_names:
  kind: python_call_eq
  category: names
  id_prefix: name

  columns: [id, function, args, expected]
  rows:
    - [CommandCompiler, CommandCompiler.__name__.__eq__, ["CommandCompiler"], true]
    - [Compile,         Compile.__name__.__eq__,         ["Compile"],         true]

# ---------------------------------------------------------------------------
# modules — compile_command, CommandCompiler, Compile
# ---------------------------------------------------------------------------

invariant codeop_extra2.compile_command.module:
  description: "codeop.compile_command.__module__ == 'codeop'"
  category: modules
  kind: python_call_eq
  function: compile_command.__module__.__eq__
  args: ["codeop"]
  expected: true

invariant codeop_extra2.CommandCompiler.module:
  description: "codeop.CommandCompiler.__module__ == 'codeop'"
  category: modules
  kind: python_call_eq
  function: CommandCompiler.__module__.__eq__
  args: ["codeop"]
  expected: true

invariant codeop_extra2.Compile.module:
  description: "codeop.Compile.__module__ == 'codeop'"
  category: modules
  kind: python_call_eq
  function: Compile.__module__.__eq__
  args: ["codeop"]
  expected: true

# ---------------------------------------------------------------------------
# bases — CommandCompiler and Compile both inherit from object
# ---------------------------------------------------------------------------

invariant codeop_extra2.CommandCompiler.base:
  description: "codeop.CommandCompiler.__bases__[0].__name__ == 'object'"
  category: bases
  kind: python_call_eq
  function: CommandCompiler.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant codeop_extra2.Compile.base:
  description: "codeop.Compile.__bases__[0].__name__ == 'object'"
  category: bases
  kind: python_call_eq
  function: Compile.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# qualnames — compile_command, CommandCompiler, Compile
# ---------------------------------------------------------------------------

invariant codeop_extra2.compile_command.qualname:
  description: "codeop.compile_command.__qualname__ == 'compile_command'"
  category: qualnames
  kind: python_call_eq
  function: compile_command.__qualname__.__eq__
  args: ["compile_command"]
  expected: true

invariant codeop_extra2.CommandCompiler.qualname:
  description: "codeop.CommandCompiler.__qualname__ == 'CommandCompiler'"
  category: qualnames
  kind: python_call_eq
  function: CommandCompiler.__qualname__.__eq__
  args: ["CommandCompiler"]
  expected: true
