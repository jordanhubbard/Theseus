spec: multiprocessing_extra37
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Process — Process class"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec extends multiprocessing_extra36.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', Process.__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() for Pool/Queue/Lock/Event/Semaphore/Barrier, Process method __qualname__.__len__() for start/run/join/terminate/is_alive/kill, Pool method __qualname__/__name__.__len__() tables, AuthenticationError/ProcessError/BufferTooShort __bases__[0].__name__, Process/Pool/__mro__.__len__() tables, __all__ metadata, class __dict__.__class__.__name__.__len__() tables, DefaultContext method qualname lengths, BaseProcess class metadata, Process/__init__.__qualname__.__len__()==20, cpu_count/__name__.__len__()==9, current_process/__name__.__len__()==15, active_children/__qualname__/__name__.__len__()==15, parent_process/__name__.__len__()==14, get_start_method/__name__.__len__()==16, set_start_method/__name__.__len__()==16, synchronize.Lock/Event/Semaphore identity and hierarchy, pool.ApplyResult/MapResult/IMapIterator/IMapUnorderedIterator __name__/__qualname__/__module__/__mro__.__len__() tables."
    - "This spec covers: Process.__name__=='Process'; Process.__module__=='multiprocessing.context' (23 chars); Process.start.__qualname__=='BaseProcess.start' (17 chars); Process.run.__qualname__=='BaseProcess.run' (15 chars); Process.join.__qualname__=='BaseProcess.join' (16 chars); Queue.__name__=='Queue'; Queue.__module__=='multiprocessing.context' (23 chars); Pipe.__name__=='Pipe'."
    - "multiprocessing.Process.__module__ == 'multiprocessing.context' (23 chars). This is notable: Process appears at the top-level multiprocessing namespace but its actual implementation module is 'multiprocessing.context' — the context-binding layer. This is the same module as Queue.__module__. Both Process and Queue are context-bound, meaning they are actually bound to the default start method context. Prior specs measured Process.__module__ as a string equality in extra2 but used 'multiprocessing.process' as the expected value; the actual value on modern Python 3.14 is 'multiprocessing.context'."
    - "Process.start, Process.run, and Process.join methods all have __qualname__ referencing 'BaseProcess' rather than 'Process', because these methods are actually defined on the BaseProcess base class: start.__qualname__ == 'BaseProcess.start' (17 chars = 11 + 1 + 5), run.__qualname__ == 'BaseProcess.run' (15 chars = 11 + 1 + 3), join.__qualname__ == 'BaseProcess.join' (16 chars = 11 + 1 + 4). The 'BaseProcess.' prefix (12 chars including the dot) is constant; the method name adds 3–5 chars."
    - "multiprocessing.Pipe.__name__ == 'Pipe' (4 chars). Pipe is a module-level function (not a class), so it has a __name__ attribute. This is a brief 4-char name. No prior multiprocessing spec has captured Pipe.__name__ as a string equality check."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Process __name__ and __module__ — extra37 namespace
#
# multiprocessing.Process is a context-bound class:
#   Process.__name__   == 'Process'                  ( 7 chars)
#   Process.__module__ == 'multiprocessing.context'  (23 chars)
# The module is 'multiprocessing.context' rather than 'multiprocessing.process',
# because Process is returned via the default context, not directly from the
# process module. Queue shares the same __module__ (also 'multiprocessing.context').
# Prior spec extra2 measured Process.__module__ but with a different expected value;
# the extra37 namespace captures the modern Python 3.14 behavior.
# ---------------------------------------------------------------------------

table multiprocessing_extra37.process_class_identity:
  description: "multiprocessing.Process class __name__ and __module__ in extra37 namespace — context-bound class"
  kind: python_call_eq
  category: class_names
  id_prefix: mpproccls37

  columns: [id, function, args, expected, description]
  rows:
    - [Process_name,   Process.__name__.__eq__,   ["Process"],                 true, "Process.__name__ == 'Process'"]
    - [Process_module, Process.__module__.__eq__,  ["multiprocessing.context"], true, "Process.__module__ == 'multiprocessing.context' — context-bound"]

# ---------------------------------------------------------------------------
# multiprocessing.Process method __qualname__.__len__() — extra37 namespace
#
# Process.start, .run, and .join are defined on the BaseProcess base class.
# Their __qualname__ values reflect the defining class (BaseProcess), not Process:
#   Process.start.__qualname__ == 'BaseProcess.start' (17 chars)
#   Process.join.__qualname__  == 'BaseProcess.join'  (16 chars)
#   Process.run.__qualname__   == 'BaseProcess.run'   (15 chars)
# 'BaseProcess.' prefix (12 chars) + method name: 'start'(5)=17, 'join'(4)=16, 'run'(3)=15.
# The lengths decrease as the method name gets shorter: start > join > run.
# Prior specs (extra30, extra31) measured some Process method __qualname__.__len__()
# values but NOT these three in the extra37 namespace.
# ---------------------------------------------------------------------------

table multiprocessing_extra37.process_method_qualname_lengths:
  description: "multiprocessing.Process method __qualname__.__len__() in extra37 namespace — all reference BaseProcess"
  kind: python_call_eq
  category: method_names
  id_prefix: mpprocmethqulen37

  columns: [id, function, args, expected, description]
  rows:
    - [start, Process.start.__qualname__.__len__, [], 17, "'BaseProcess.start' is 17 characters — 'BaseProcess'(11) + '.'(1) + 'start'(5)"]
    - [join,  Process.join.__qualname__.__len__,  [], 16, "'BaseProcess.join' is 16 characters — 'BaseProcess'(11) + '.'(1) + 'join'(4)"]
    - [run,   Process.run.__qualname__.__len__,   [], 15, "'BaseProcess.run' is 15 characters — 'BaseProcess'(11) + '.'(1) + 'run'(3)"]

# ---------------------------------------------------------------------------
# multiprocessing.Queue and Pipe identity — extra37 namespace
#
# Queue and Pipe are two core IPC primitives:
#   Queue.__name__   == 'Queue'                  (5 chars)
#   Queue.__module__ == 'multiprocessing.context' (23 chars — context-bound like Process)
#   Pipe.__name__    == 'Pipe'                   (4 chars)
# Both Queue and Process share __module__ == 'multiprocessing.context', confirming
# both are context-bound. Pipe is a function (not a class) and has 4-char name.
# No prior multiprocessing spec has captured Queue.__name__ string equality or
# Pipe.__name__ string equality as boolean invariants in this namespace.
# ---------------------------------------------------------------------------

table multiprocessing_extra37.queue_pipe_identity:
  description: "multiprocessing.Queue and Pipe __name__ and Queue __module__ in extra37 namespace"
  kind: python_call_eq
  category: class_names
  id_prefix: mpqueuepipe37

  columns: [id, function, args, expected, description]
  rows:
    - [Queue_name,   Queue.__name__.__eq__,   ["Queue"],                 true, "Queue.__name__ == 'Queue'"]
    - [Queue_module, Queue.__module__.__eq__,  ["multiprocessing.context"], true, "Queue.__module__ == 'multiprocessing.context' — context-bound like Process"]
    - [Pipe_name,    Pipe.__name__.__eq__,     ["Pipe"],                  true, "Pipe.__name__ == 'Pipe'"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra37
# ---------------------------------------------------------------------------

invariant multiprocessing_extra37.Process_module_len:
  description: "multiprocessing.Process.__module__.__len__() == 23 — 'multiprocessing.context' has 23 characters; Process is context-bound, not defined directly in multiprocessing.process"
  category: module_names
  kind: python_call_eq
  function: Process.__module__.__len__
  args: []
  expected: 23

invariant multiprocessing_extra37.Process_start_qualname_len:
  description: "multiprocessing.Process.start.__qualname__.__len__() == 17 — 'BaseProcess.start' has 17 characters; start is defined on BaseProcess, not Process"
  category: method_names
  kind: python_call_eq
  function: Process.start.__qualname__.__len__
  args: []
  expected: 17

invariant multiprocessing_extra37.Process_run_qualname_len:
  description: "multiprocessing.Process.run.__qualname__.__len__() == 15 — 'BaseProcess.run' has 15 characters; the shortest of the three measured Process methods (start=17, join=16, run=15)"
  category: method_names
  kind: python_call_eq
  function: Process.run.__qualname__.__len__
  args: []
  expected: 15

invariant multiprocessing_extra37.Queue_module_len:
  description: "multiprocessing.Queue.__module__.__len__() == 23 — 'multiprocessing.context' has 23 characters; Queue shares the same context-bound module as Process"
  category: module_names
  kind: python_call_eq
  function: Queue.__module__.__len__
  args: []
  expected: 23
