spec: multiprocessing_extra154
version: ">=3.8"
backend: python_module(multiprocessing.shared_memory)

docs: https://docs.python.org/3/library/multiprocessing.shared_memory.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.shared_memory.html — Python multiprocessing.shared_memory documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/shared_memory.py"
  notes:
    - "This spec covers: multiprocessing.shared_memory.SharedMemory and ShareableList class identity, and module __name__. multiprocessing.shared_memory.SharedMemory.__name__=='SharedMemory' (len=12; added in Python 3.8 — the first Python version with shared memory support); multiprocessing.shared_memory.SharedMemory.__module__=='multiprocessing.shared_memory' (len=29); multiprocessing.shared_memory.SharedMemory.__bases__[0].__name__=='object' (SharedMemory inherits from object directly); multiprocessing.shared_memory.ShareableList.__name__=='ShareableList' (len=13); multiprocessing.shared_memory.ShareableList.__module__=='multiprocessing.shared_memory' (len=29; same module as SharedMemory); multiprocessing.shared_memory.__name__=='multiprocessing.shared_memory' (len=29; the module's __name__ matches its dotted path). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.shared_memory was added in Python 3.8 (PEP 619) — SharedMemory provides POSIX-style shared memory blocks that can be accessed by multiple processes without pickling; SharedMemory.__bases__[0].__name__=='object' (inherits from object, not from any multiprocessing.Process or BaseManager class); SharedMemory.__module__=='multiprocessing.shared_memory' (len=29: 'multiprocessing'=15+'.'=1+'shared_memory'=13=29); compare: multiprocessing.managers.BaseManager.__module__=='multiprocessing.managers' (len=24, 5 chars shorter because 'managers'=8 < 'shared_memory'=13). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.shared_memory.ShareableList.__name__=='ShareableList' (len=13; 1 char longer than SharedMemory=12 because 'ShareableList'=13 vs 'SharedMemory'=12); ShareableList wraps a SharedMemory block to provide a mutable list-like object that can be shared between processes; supported element types are limited to str, bytes, int, float, bool, and None (not arbitrary Python objects); ShareableList.__module__=='multiprocessing.shared_memory' (same as SharedMemory — both defined in Lib/multiprocessing/shared_memory.py). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.shared_memory.__name__=='multiprocessing.shared_memory' — the module's __name__ attribute equals its dotted import path (len=29); this is the standard behavior for submodules: module.__name__ == the fully-qualified import path; compare: multiprocessing.managers.__name__=='multiprocessing.managers' (len=24); the shared_memory module (len=29) is the longest-named multiprocessing submodule in the specs so far. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.shared_memory.SharedMemory class identity — extra154
#
# multiprocessing.shared_memory.SharedMemory.__name__.__eq__('SharedMemory')                    == True
# multiprocessing.shared_memory.SharedMemory.__module__.__eq__('multiprocessing.shared_memory') == True
# multiprocessing.shared_memory.SharedMemory.__bases__[0].__name__.__eq__('object')             == True
# ---------------------------------------------------------------------------

table multiprocessing_extra154.mp_shared_memory_identity:
  description: "multiprocessing.shared_memory.SharedMemory class identity checks in mpshm154 namespace — multiprocessing.shared_memory.SharedMemory.__name__=='SharedMemory' (len=12: 'Shared'=6+'Memory'=6=12; the POSIX shared memory class added in Python 3.8; allows multiple processes to access the same memory block without pickling); multiprocessing.shared_memory.SharedMemory.__module__=='multiprocessing.shared_memory' (len=29: 'multiprocessing'=15+'.'=1+'shared_memory'=13=29; defined in Lib/multiprocessing/shared_memory.py; __module__ matches the full dotted submodule path); multiprocessing.shared_memory.SharedMemory.__bases__[0].__name__=='object' (len=6; SharedMemory inherits directly from object — it is NOT a subclass of any multiprocessing manager or process class); SharedMemory.__name__.__len__()==12; module len==29 (longest multiprocessing submodule in the spec series so far); compare multiprocessing.managers.BaseManager.__module__=='multiprocessing.managers' (len=24, 5 shorter); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpshm154

  columns: [id, function, args, expected, description]
  rows:
    - [shm_name_eq,   multiprocessing.shared_memory.SharedMemory.__name__.__eq__,                ["SharedMemory"],                true,  "multiprocessing.shared_memory.SharedMemory.__name__ == 'SharedMemory' (len=12; added in Python 3.8); verified with Python 3.14.3"]
    - [shm_mod_eq,    multiprocessing.shared_memory.SharedMemory.__module__.__eq__,               ["multiprocessing.shared_memory"], true, "multiprocessing.shared_memory.SharedMemory.__module__ == 'multiprocessing.shared_memory' (len=29); verified with Python 3.14.3"]
    - [shm_base_eq,   "multiprocessing.shared_memory.SharedMemory.__bases__[0].__name__.__eq__",  ["object"],                      true,  "multiprocessing.shared_memory.SharedMemory.__bases__[0].__name__ == 'object' (inherits from object); verified with Python 3.14.3"]
    - [shm_name_len,  multiprocessing.shared_memory.SharedMemory.__name__.__len__,                [],                              12,    "multiprocessing.shared_memory.SharedMemory.__name__.__len__() == 12 ('SharedMemory'); verified with Python 3.14.3"]
    - [shm_mod_len,   multiprocessing.shared_memory.SharedMemory.__module__.__len__,              [],                              29,    "multiprocessing.shared_memory.SharedMemory.__module__.__len__() == 29 ('multiprocessing.shared_memory'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.shared_memory.ShareableList class identity — extra154
#
# multiprocessing.shared_memory.ShareableList.__name__.__eq__('ShareableList')                    == True
# multiprocessing.shared_memory.ShareableList.__module__.__eq__('multiprocessing.shared_memory') == True
# ---------------------------------------------------------------------------

table multiprocessing_extra154.mp_shareable_list_identity:
  description: "multiprocessing.shared_memory.ShareableList class identity checks in mpsl154 namespace — multiprocessing.shared_memory.ShareableList.__name__=='ShareableList' (len=13: 'Shareable'=9+'List'=4=13; 1 char longer than SharedMemory=12 because 'ShareableList'=13 vs 'SharedMemory'=12); multiprocessing.shared_memory.ShareableList.__module__=='multiprocessing.shared_memory' (len=29; same module as SharedMemory — both defined in Lib/multiprocessing/shared_memory.py); ShareableList wraps a SharedMemory block to provide a mutable list-like container shareable between processes; supported element types are limited to str, bytes, int, float, bool, None (fixed-size slots); ShareableList.__name__.__len__()==13; compare: SharedMemory.__name__.__len__()==12 (ShareableList is 1 char longer); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpsl154

  columns: [id, function, args, expected, description]
  rows:
    - [sl_name_eq,   multiprocessing.shared_memory.ShareableList.__name__.__eq__,    ["ShareableList"],                true,  "multiprocessing.shared_memory.ShareableList.__name__ == 'ShareableList' (len=13); verified with Python 3.14.3"]
    - [sl_mod_eq,    multiprocessing.shared_memory.ShareableList.__module__.__eq__,   ["multiprocessing.shared_memory"], true, "multiprocessing.shared_memory.ShareableList.__module__ == 'multiprocessing.shared_memory' (len=29; same as SharedMemory); verified with Python 3.14.3"]
    - [sl_name_len,  multiprocessing.shared_memory.ShareableList.__name__.__len__,    [],                               13,    "multiprocessing.shared_memory.ShareableList.__name__.__len__() == 13 ('ShareableList'; 1 longer than SharedMemory=12); verified with Python 3.14.3"]
    - [sl_mod_len,   multiprocessing.shared_memory.ShareableList.__module__.__len__,  [],                               29,    "multiprocessing.shared_memory.ShareableList.__module__.__len__() == 29 ('multiprocessing.shared_memory'; same as SharedMemory module len); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.shared_memory module __name__ — extra154
#
# multiprocessing.shared_memory.__name__.__eq__('multiprocessing.shared_memory') == True
# ---------------------------------------------------------------------------

table multiprocessing_extra154.mp_shared_memory_module_name:
  description: "multiprocessing.shared_memory module __name__ checks in mpshmodname154 namespace — multiprocessing.shared_memory.__name__=='multiprocessing.shared_memory' (len=29; the module's __name__ attribute equals its fully-qualified import path 'multiprocessing.shared_memory'; this is the standard Python behavior for submodules); multiprocessing.shared_memory.__name__.__len__()==29 (the same length as SharedMemory.__module__ and ShareableList.__module__ — all three equal 'multiprocessing.shared_memory'); compare: multiprocessing.managers.__name__=='multiprocessing.managers' (len=24, 5 chars shorter); multiprocessing.shared_memory is the longest-named multiprocessing submodule covered in the spec series; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpshmodname154

  columns: [id, function, args, expected, description]
  rows:
    - [shmod_name_eq,   multiprocessing.shared_memory.__name__.__eq__,    ["multiprocessing.shared_memory"],  true,  "multiprocessing.shared_memory.__name__ == 'multiprocessing.shared_memory' (len=29); verified with Python 3.14.3"]
    - [shmod_name_len,  multiprocessing.shared_memory.__name__.__len__,   [],                                 29,    "multiprocessing.shared_memory.__name__.__len__() == 29 ('multiprocessing.shared_memory'); verified with Python 3.14.3"]
    - [shm_mod_eq2,     multiprocessing.shared_memory.SharedMemory.__module__.__eq__, ["multiprocessing.shared_memory"], true, "SharedMemory.__module__ == multiprocessing.shared_memory.__name__ == 'multiprocessing.shared_memory' (len=29); verified with Python 3.14.3"]
    - [sl_mod_eq2,      multiprocessing.shared_memory.ShareableList.__module__.__eq__, ["multiprocessing.shared_memory"], true, "ShareableList.__module__ == 'multiprocessing.shared_memory' (len=29; same as SharedMemory and module __name__); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra154
# ---------------------------------------------------------------------------

invariant multiprocessing_extra154.mp_SharedMemory_name_eq:
  description: "multiprocessing.shared_memory.SharedMemory.__name__.__eq__('SharedMemory') returns True — multiprocessing.shared_memory.SharedMemory was added in Python 3.8 (PEP 619) as a new way for processes to share data without pickling; SharedMemory.__name__=='SharedMemory' (len=12: 'Shared'=6+'Memory'=6=12); SharedMemory creates a named or anonymous POSIX shared memory block; multiple processes can attach to the same block by name and read/write raw bytes; SharedMemory.__module__=='multiprocessing.shared_memory' (len=29); SharedMemory.__bases__[0].__name__=='object' (inherits from object); NEW in extra154: first standalone multiprocessing.shared_memory.SharedMemory.__name__ identity invariant in mpshm154 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.shared_memory.SharedMemory.__name__.__eq__
  args: ["SharedMemory"]
  expected: true

invariant multiprocessing_extra154.mp_SharedMemory_module_eq:
  description: "multiprocessing.shared_memory.SharedMemory.__module__.__eq__('multiprocessing.shared_memory') returns True — SharedMemory is defined in Lib/multiprocessing/shared_memory.py; its __module__ is 'multiprocessing.shared_memory' (len=29: 'multiprocessing'=15+'.'=1+'shared_memory'=13=29); this is the longest __module__ value for any multiprocessing class covered in the spec series (compare: multiprocessing.managers.BaseManager.__module__=='multiprocessing.managers', len=24; multiprocessing.pool.Pool.__module__=='multiprocessing.pool', len=20); len=29 because 'shared_memory'=13 is longer than 'managers'=8 and 'pool'=4; NEW in extra154: first standalone SharedMemory.__module__ identity invariant in mpshm154 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.shared_memory.SharedMemory.__module__.__eq__
  args: ["multiprocessing.shared_memory"]
  expected: true

invariant multiprocessing_extra154.mp_SharedMemory_bases0_is_object:
  description: "multiprocessing.shared_memory.SharedMemory.__bases__[0].__name__.__eq__('object') returns True — SharedMemory inherits directly from object (single inheritance); SharedMemory is not a subclass of multiprocessing.Process, BaseManager, BaseProxy, or Pool; it is an independent class that manages a shared memory segment via OS primitives; SharedMemory.__bases__[0].__name__=='object' (len=6); this follows the same pattern as multiprocessing.pool.Pool.__bases__[0].__name__=='object' and multiprocessing.managers.BaseManager.__bases__[0].__name__=='object' — all multiprocessing manager-style root classes inherit from object; NEW in extra154: first standalone SharedMemory.__bases__[0] name identity invariant in mpshm154 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.shared_memory.SharedMemory.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant multiprocessing_extra154.mp_ShareableList_name_eq:
  description: "multiprocessing.shared_memory.ShareableList.__name__.__eq__('ShareableList') returns True — ShareableList.__name__=='ShareableList' (len=13: 'Shareable'=9+'List'=4=13; 1 char longer than SharedMemory=12 because 'ShareableList'=13 vs 'SharedMemory'=12); ShareableList is a mutable list-like container backed by a SharedMemory block; it supports a fixed-length list of primitive types (int, float, bool, str, bytes, None) — NOT arbitrary Python objects; each element occupies a fixed-size slot determined at creation time; ShareableList.__module__=='multiprocessing.shared_memory' (same module as SharedMemory); NEW in extra154: first standalone ShareableList.__name__ identity invariant in mpsl154 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.shared_memory.ShareableList.__name__.__eq__
  args: ["ShareableList"]
  expected: true

invariant multiprocessing_extra154.mp_shared_memory_module_name_eq:
  description: "multiprocessing.shared_memory.__name__.__eq__('multiprocessing.shared_memory') returns True — the module's __name__ attribute is 'multiprocessing.shared_memory' (len=29); Python sets module.__name__ to the fully-qualified import path for submodules; len('multiprocessing.shared_memory')==29: 'multiprocessing'=15+'.'=1+'shared_memory'=13=29; SharedMemory.__module__ and ShareableList.__module__ both equal this same string, confirming all three are the same value; compare: multiprocessing.managers.__name__=='multiprocessing.managers' (len=24); multiprocessing.pool.__name__=='multiprocessing.pool' (len=20); the shared_memory submodule has the longest __name__ of all multiprocessing submodules in the spec series; NEW in extra154: first standalone multiprocessing.shared_memory.__name__ identity invariant in mpshmodname154 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.shared_memory.__name__.__eq__
  args: ["multiprocessing.shared_memory"]
  expected: true
