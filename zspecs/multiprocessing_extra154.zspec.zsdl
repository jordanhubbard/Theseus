invariant multiprocessing_extra154.pe_mro_is_tuple:
  description: "multiprocessing.ProcessError.__mro__.__class__.__name__.__eq__('tuple') == True — __mro__ is always a tuple in Python; ProcessError.__mro__ is a tuple of 4 class objects [ProcessError, Exception, BaseException, object]; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: ProcessError_mro
  kind: python_call_eq
  function: ProcessError.__mro__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant multiprocessing_extra154.pe_mro_len_4:
  description: "multiprocessing.ProcessError.__mro__.__len__() == 4 — MRO is (ProcessError, Exception, BaseException, object); ProcessError is a direct subclass of Exception and is the root of the multiprocessing exception hierarchy; ProcessError.__mro__.__len__(4) < AuthenticationError.__mro__.__len__(5) by 1 — subclasses have deeper MROs; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: ProcessError_mro
  kind: python_call_eq
  function: ProcessError.__mro__.__len__
  args: []
  expected: 4

invariant multiprocessing_extra154.pe_mro0_name_eq:
  description: "multiprocessing.ProcessError.__mro__[0].__name__.__eq__('ProcessError') returns True — ProcessError.__mro__[0].__name__=='ProcessError' (len=12: P-r-o-c-e-s-s-E-r-r-o-r); the first entry in any Python MRO is always the class itself; ProcessError.__mro__[0].__name__ (12) == TimeoutError.__mro__[0].__name__ (12) — both names have length 12; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: ProcessError_mro
  kind: python_call_eq
  function: "multiprocessing.ProcessError.__mro__.__getitem__(0).__name__.__eq__"
  args: ["ProcessError"]
  expected: true

invariant multiprocessing_extra154.pe_mro1_name_eq:
  description: "multiprocessing.ProcessError.__mro__[1].__name__.__eq__('Exception') returns True — ProcessError.__mro__[1].__name__=='Exception' (len=9); ProcessError's direct base is Exception, not BaseException directly; this means ProcessError instances are caught by 'except Exception' handlers; ProcessError.__mro__[1].__name__ (9: 'Exception') != 'BaseException' (13) — the direct base is Exception; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: ProcessError_mro
  kind: python_call_eq
  function: "multiprocessing.ProcessError.__mro__.__getitem__(1).__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant multiprocessing_extra154.ae_mro_len_5:
  description: "multiprocessing.AuthenticationError.__mro__.__len__() == 5 — MRO is (AuthenticationError, ProcessError, Exception, BaseException, object); AuthenticationError is a deeper subclass in the multiprocessing exception hierarchy; AuthenticationError.__mro__.__len__(5) == TimeoutError.__mro__.__len__(5) — sibling exceptions have the same MRO depth; AuthenticationError.__mro__.__len__(5) > ProcessError.__mro__.__len__(4) by 1; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
