spec: hashlib_extra260
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
  notes:
    - "hashlib.algorithms_guaranteed is a set (not frozenset) in CPython 3.x — type(hashlib.algorithms_guaranteed).__name__ == 'set'."
    - "hashlib.algorithms_available is also a plain set."
    - "All six core algorithms (sha256, sha512, sha1, md5, sha224, sha384) must be in algorithms_guaranteed per the Python docs."
    - "sha3_256 and blake2b are also in algorithms_guaranteed on all supported Python 3.x platforms."
    - "algorithms_available is a superset of algorithms_guaranteed; it includes OpenSSL-provided aliases."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# algorithms_guaranteed type identity
# ---------------------------------------------------------------------------

invariant hashlib_extra260.algorithms_guaranteed.class_is_set:
  description: "type(hashlib.algorithms_guaranteed).__name__ == 'set'"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__eq__
  args: ["set"]
  expected: true

# ---------------------------------------------------------------------------
# algorithms_guaranteed — core six membership
# ---------------------------------------------------------------------------

table hashlib_extra260.algorithms_guaranteed.core_membership:
  kind: python_call_eq
  category: algorithms
  id_prefix: alg_guaranteed

  columns: [id, function, args, expected]
  rows:
    - [sha256, algorithms_guaranteed.__contains__, ["sha256"], true]
    - [sha512, algorithms_guaranteed.__contains__, ["sha512"], true]
    - [sha1,   algorithms_guaranteed.__contains__, ["sha1"],   true]
    - [md5,    algorithms_guaranteed.__contains__, ["md5"],    true]
    - [sha224, algorithms_guaranteed.__contains__, ["sha224"], true]
    - [sha384, algorithms_guaranteed.__contains__, ["sha384"], true]

# ---------------------------------------------------------------------------
# algorithms_guaranteed — extended membership (sha3_256, blake2b)
# ---------------------------------------------------------------------------

table hashlib_extra260.algorithms_guaranteed.extended_membership:
  kind: python_call_eq
  category: algorithms
  id_prefix: alg_guaranteed_ext

  columns: [id, function, args, expected]
  rows:
    - [sha3_256, algorithms_guaranteed.__contains__, ["sha3_256"], true]
    - [blake2b,  algorithms_guaranteed.__contains__, ["blake2b"],  true]

# ---------------------------------------------------------------------------
# algorithms_available type identity and sha256 membership
# ---------------------------------------------------------------------------

invariant hashlib_extra260.algorithms_available.class_is_set:
  description: "type(hashlib.algorithms_available).__name__ == 'set'"
  category: algorithms
  kind: python_call_eq
  function: algorithms_available.__class__.__name__.__eq__
  args: ["set"]
  expected: true

invariant hashlib_extra260.algorithms_available.contains_sha256:
  description: "hashlib.algorithms_available.__contains__('sha256') == True"
  category: algorithms
  kind: python_call_eq
  function: algorithms_available.__contains__
  args: ["sha256"]
  expected: true
