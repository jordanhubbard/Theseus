spec: concurrent_futures_extra586
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Future and Executor method qualname identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __qualname__ and __module__ identity for concurrent.futures classes and methods"
  created_at: "2026-04-12T00:00:00Z"

table cf_future_method_qualname:
  description: "__qualname__ identity for concurrent.futures.Future methods"
  columns: [id, function, args, expected]
  rows:
    - [cf586qn01, concurrent.futures.Future.__init__.__qualname__.__eq__, ["Future.__init__"], true]
    - [cf586qn02, concurrent.futures.Future.cancel.__qualname__.__eq__, ["Future.cancel"], true]
    - [cf586qn03, concurrent.futures.Future.result.__qualname__.__eq__, ["Future.result"], true]
    - [cf586qn04, concurrent.futures.Future.exception.__qualname__.__eq__, ["Future.exception"], true]
    - [cf586qn05, concurrent.futures.Future.add_done_callback.__qualname__.__eq__, ["Future.add_done_callback"], true]

table cf_executor_method_qualname:
  description: "__qualname__ identity for concurrent.futures.Executor methods"
  columns: [id, function, args, expected]
  rows:
    - [cf586qn06, concurrent.futures.Executor.submit.__qualname__.__eq__, ["Executor.submit"], true]
    - [cf586qn07, concurrent.futures.Executor.map.__qualname__.__eq__, ["Executor.map"], true]
    - [cf586qn08, concurrent.futures.Executor.shutdown.__qualname__.__eq__, ["Executor.shutdown"], true]
    - [cf586qn09, concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__eq__, ["ThreadPoolExecutor.__init__"], true]
    - [cf586qn10, concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__eq__, ["ProcessPoolExecutor.__init__"], true]

table cf_class_module:
  description: "__module__ identity for concurrent.futures classes"
  columns: [id, function, args, expected]
  rows:
    - [cf586md01, concurrent.futures.Future.__module__.__eq__, ["concurrent.futures._base"], true]
    - [cf586md02, concurrent.futures.Executor.__module__.__eq__, ["concurrent.futures._base"], true]
