spec: io_extra110
version: ">=3.9"
backend: python_module(io)
extends: io_extra109

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bytesio.c"
  notes:
    - "This spec extends io_extra109.zspec.zsdl."
    - "This spec covers: io class __module__ string values for all major io classes."
    - "io.IOBase.__module__ = 'io' — IOBase is a pure Python abstract class defined in the io module wrapper."
    - "io.RawIOBase.__module__ = 'io' — RawIOBase is a pure Python abstract class re-exported from io."
    - "io.BufferedIOBase.__module__ = 'io' — BufferedIOBase is a pure Python abstract class."
    - "io.TextIOBase.__module__ = 'io' — TextIOBase is a pure Python abstract class."
    - "io.UnsupportedOperation.__module__ = 'io' — UnsupportedOperation is defined in the pure Python io wrapper."
    - "io.BytesIO.__module__ = '_io' — BytesIO is a C extension type from the _io module."
    - "io.StringIO.__module__ = '_io' — StringIO is a C extension type from the _io module."
    - "io.BufferedReader.__module__ = '_io' — BufferedReader is a C extension type from the _io module."
    - "io.BufferedWriter.__module__ = '_io' — BufferedWriter is a C extension type from the _io module."
    - "io.FileIO.__module__ = '_io' — FileIO is a C extension type from the _io module."
    - "io.TextIOWrapper.__module__ = '_io' — TextIOWrapper is a C extension type from the _io module."
    - "io.BufferedRandom.__module__ = '_io' — BufferedRandom is a C extension type from the _io module."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io abstract base classes: __module__ == 'io'
# IOBase, RawIOBase, BufferedIOBase, TextIOBase, UnsupportedOperation
# are all defined in the pure Python io wrapper and report __module__ == 'io'.
# ---------------------------------------------------------------------------

table io_extra110.abstract_class_modules:
  description: "io abstract classes have __module__ == 'io': IOBase, RawIOBase, BufferedIOBase, TextIOBase, UnsupportedOperation"
  kind: python_call_eq
  category: class_names
  id_prefix: iomodule110a

  columns: [id, function, args, expected, description]
  rows:
    - [iobase_mod_eq,      IOBase.__module__.__eq__,            ["io"],  true,  "io.IOBase.__module__ == 'io' (pure Python abstract base)"]
    - [iobase_mod_not_io,  IOBase.__module__.__eq__,            ["_io"], false, "io.IOBase.__module__ != '_io' (not a C extension type)"]
    - [rawiobase_mod_eq,   RawIOBase.__module__.__eq__,         ["io"],  true,  "io.RawIOBase.__module__ == 'io' (pure Python abstract base)"]
    - [bufiobase_mod_eq,   BufferedIOBase.__module__.__eq__,    ["io"],  true,  "io.BufferedIOBase.__module__ == 'io' (pure Python abstract base)"]
    - [txiobase_mod_eq,    TextIOBase.__module__.__eq__,        ["io"],  true,  "io.TextIOBase.__module__ == 'io' (pure Python abstract base)"]
    - [unsupop_mod_eq,     UnsupportedOperation.__module__.__eq__, ["io"], true, "io.UnsupportedOperation.__module__ == 'io' (defined in pure Python wrapper)"]
    - [unsupop_mod_not_io, UnsupportedOperation.__module__.__eq__, ["_io"], false, "io.UnsupportedOperation.__module__ != '_io' (not from the C extension)"]

# ---------------------------------------------------------------------------
# io concrete C extension classes: __module__ == '_io'
# BytesIO, StringIO, BufferedReader, BufferedWriter, FileIO,
# TextIOWrapper, BufferedRandom are all C extension types from the _io
# extension module; their __module__ reports '_io', not 'io'.
# ---------------------------------------------------------------------------

table io_extra110.concrete_class_modules:
  description: "io concrete C extension classes have __module__ == '_io': BytesIO, StringIO, BufferedReader, BufferedWriter, FileIO, TextIOWrapper, BufferedRandom"
  kind: python_call_eq
  category: class_names
  id_prefix: iomodule110b

  columns: [id, function, args, expected, description]
  rows:
    - [bytesio_mod_eq,   BytesIO.__module__.__eq__,       ["_io"], true,  "io.BytesIO.__module__ == '_io' (C extension type)"]
    - [stringio_mod_eq,  StringIO.__module__.__eq__,      ["_io"], true,  "io.StringIO.__module__ == '_io' (C extension type)"]
    - [br_mod_eq,        BufferedReader.__module__.__eq__, ["_io"], true,  "io.BufferedReader.__module__ == '_io' (C extension type)"]
    - [bw_mod_eq,        BufferedWriter.__module__.__eq__, ["_io"], true,  "io.BufferedWriter.__module__ == '_io' (C extension type)"]
    - [fileio_mod_eq,    FileIO.__module__.__eq__,         ["_io"], true,  "io.FileIO.__module__ == '_io' (C extension type)"]
    - [tiow_mod_eq,      TextIOWrapper.__module__.__eq__,  ["_io"], true,  "io.TextIOWrapper.__module__ == '_io' (C extension type)"]
    - [bufrnd_mod_eq,    BufferedRandom.__module__.__eq__, ["_io"], true,  "io.BufferedRandom.__module__ == '_io' (C extension type)"]
    - [bytesio_not_io,   BytesIO.__module__.__eq__,        ["io"],  false, "io.BytesIO.__module__ != 'io' (C type from _io, not pure Python io)"]
    - [tiow_not_io,      TextIOWrapper.__module__.__eq__,  ["io"],  false, "io.TextIOWrapper.__module__ != 'io' (C type from _io, not pure Python io)"]

# ---------------------------------------------------------------------------
# Cross-check: abstract-vs-concrete __module__ inequality
# ---------------------------------------------------------------------------

table io_extra110.abstract_vs_concrete_module:
  description: "io abstract classes report __module__ 'io' while concrete C classes report '_io'; confirm inequality between representatives"
  kind: python_call_eq
  category: class_names
  id_prefix: iomodule110c

  columns: [id, function, args, expected, description]
  rows:
    - [iobase_ne_bytesio, IOBase.__module__.__eq__,      ["_io"], false, "io.IOBase.__module__ != '_io' (IOBase is 'io', BytesIO is '_io')"]
    - [bytesio_ne_iobase, BytesIO.__module__.__eq__,     ["io"],  false, "io.BytesIO.__module__ != 'io' (BytesIO is '_io', IOBase is 'io')"]
    - [rawio_ne_fileio,   RawIOBase.__module__.__eq__,   ["_io"], false, "io.RawIOBase.__module__ != '_io' (RawIOBase is 'io', FileIO is '_io')"]
    - [bufbase_ne_br,     BufferedIOBase.__module__.__eq__,["_io"],false, "io.BufferedIOBase.__module__ != '_io' (BufferedIOBase is 'io', BufferedReader is '_io')"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra110.IOBase.module_is_io:
  description: "io.IOBase.__module__ == 'io' (IOBase is the pure Python abstract root of the io class hierarchy; its __module__ reports the wrapper module name 'io', not the C extension '_io')"
  category: class_names
  kind: python_call_eq
  function: IOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra110.BytesIO.module_is_underscore_io:
  description: "io.BytesIO.__module__ == '_io' (BytesIO is a C extension type; its canonical home is the _io extension module even though it is re-exported via the io wrapper)"
  category: class_names
  kind: python_call_eq
  function: BytesIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra110.UnsupportedOperation.module_is_io:
  description: "io.UnsupportedOperation.__module__ == 'io' (UnsupportedOperation is the one exception class defined in the pure Python io wrapper, not in the _io C extension)"
  category: class_names
  kind: python_call_eq
  function: UnsupportedOperation.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra110.BufferedRandom.module_is_underscore_io:
  description: "io.BufferedRandom.__module__ == '_io' (BufferedRandom is a C extension type from _io despite being accessible as io.BufferedRandom)"
  category: class_names
  kind: python_call_eq
  function: BufferedRandom.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra110.TextIOBase.module_is_io:
  description: "io.TextIOBase.__module__ == 'io' (TextIOBase is the pure Python abstract base for text I/O; contrasts with TextIOWrapper whose __module__ is '_io')"
  category: class_names
  kind: python_call_eq
  function: TextIOBase.__module__.__eq__
  args: ["io"]
  expected: true

