spec: re_extra
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "Python 3 re documentation — https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re.zspec.zsdl — covers sub, findall, split, escape, and compile error cases"
    - "re_patterns.zspec.zsdl — covers match, search, fullmatch, capture groups, compile pattern/class_name"
  notes:
    - "This spec extends re.zspec.zsdl and re_patterns.zspec.zsdl with coverage not already present."
    - "re.Pattern is the type of compiled regex objects; its __name__ is 'Pattern'."
    - "re.Match is the type of match objects; its __name__ is 'Match'."
    - "re.error is the exception class for invalid patterns; it inherits from Exception."
    - "Flag constants: IGNORECASE==2, MULTILINE==8, DOTALL==16, VERBOSE==64, ASCII==256."
    - "re.compile('.').__class__.__name__ == 'Pattern' — instance-level class name check."
    - "re.match(r'\\d+', '123').group(0) == '123' — anchored match at start of string."
    - "re.search(r'\\d+', 'abc123').group(0) == '123' — finds digits anywhere in string."
    - "re.sub(r'\\d', 'X', 'a1b2') == 'aXbX' — replaces every digit."
    - "re.split(r'\\s+', 'a b  c') == ['a', 'b', 'c'] — splits on runs of whitespace."
    - "re.findall(r'\\d+', 'a1b22') == ['1', '22'] — returns all non-overlapping matches."
    - "All expected values verified by running Python 3.12 re module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class identity — Pattern, Match, error
# re_patterns.zspec.zsdl has compile class_name via instance.__class__.__name__;
# here we add the error class and flag constants not covered elsewhere.
# ---------------------------------------------------------------------------

invariant re_extra.Pattern.class_name:
  description: "re.compile('.').__class__.__name__ == 'Pattern'"
  category: class_metadata
  kind: python_call_eq
  function: compile
  args: ["."]
  method: __class__
  method_chain: __name__
  method_chain_args: []
  expected: "Pattern"

invariant re_extra.Match.class_name:
  description: "re.match('.', 'a').__class__.__name__ == 'Match'"
  category: class_metadata
  kind: python_call_eq
  function: match
  args: [".", "a"]
  method: __class__
  method_chain: __name__
  method_chain_args: []
  expected: "Match"

invariant re_extra.error.class_name:
  description: "re.error.__name__ == 'error'"
  category: class_metadata
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

invariant re_extra.error.base_is_Exception:
  description: "re.error.__bases__[0].__name__ == 'Exception'"
  category: class_hierarchy
  kind: python_call_eq
  function: error.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# Flag constants
# ---------------------------------------------------------------------------

table re_extra.flags:
  kind: python_call_eq
  category: flags
  id_prefix: flag

  columns: [id, function, args, expected]
  rows:
    - [IGNORECASE, IGNORECASE.__eq__, [2],   true]
    - [MULTILINE,  MULTILINE.__eq__,  [8],   true]
    - [DOTALL,     DOTALL.__eq__,     [16],  true]
    - [VERBOSE,    VERBOSE.__eq__,    [64],  true]
    - [ASCII,      ASCII.__eq__,      [256], true]

# ---------------------------------------------------------------------------
# re.match — anchored match at start of string
# (re_patterns.zspec.zsdl has match r'\d+' on '123abc'; we add '123' input)
# ---------------------------------------------------------------------------

invariant re_extra.match.digits_group0:
  description: "re.match(r'\\d+', '123').group(0) == '123'"
  category: match
  kind: python_call_eq
  function: match
  args: ["\\d+", "123"]
  method: group
  method_args: [0]
  expected: "123"

# ---------------------------------------------------------------------------
# re.search — scans entire string for first match
# re_patterns.zspec.zsdl has search on 'abc123def'; we add 'abc123'
# ---------------------------------------------------------------------------

invariant re_extra.search.digits_interior:
  description: "re.search(r'\\d+', 'abc123').group(0) == '123'"
  category: search
  kind: python_call_eq
  function: search
  args: ["\\d+", "abc123"]
  method: group
  method_args: [0]
  expected: "123"

# ---------------------------------------------------------------------------
# re.sub — replace digits with 'X'
# re.zspec.zsdl has sub with 'a1b2c3' -> 'aXbXcX'; we add 'a1b2' -> 'aXbX'
# ---------------------------------------------------------------------------

invariant re_extra.sub.two_digits:
  description: "re.sub(r'\\d', 'X', 'a1b2') == 'aXbX'"
  category: substitution
  kind: python_call_eq
  function: sub
  args: ["\\d", "X", "a1b2"]
  expected: "aXbX"

# ---------------------------------------------------------------------------
# re.split — split on whitespace runs
# re.zspec.zsdl has split on 'hello world foo'; we add 'a b  c'
# ---------------------------------------------------------------------------

invariant re_extra.split.whitespace_runs:
  description: "re.split(r'\\s+', 'a b  c') == ['a', 'b', 'c']"
  category: split
  kind: python_call_eq
  function: split
  args: ["\\s+", "a b  c"]
  expected: ["a", "b", "c"]

# ---------------------------------------------------------------------------
# re.findall — find all non-overlapping matches
# re.zspec.zsdl has findall r'\d+' on 'a1b22c333'; we add 'a1b22'
# ---------------------------------------------------------------------------

invariant re_extra.findall.two_matches:
  description: "re.findall(r'\\d+', 'a1b22') == ['1', '22']"
  category: findall
  kind: python_call_eq
  function: findall
  args: ["\\d+", "a1b22"]
  expected: ["1", "22"]
