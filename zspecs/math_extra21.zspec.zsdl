spec: math_extra21
version: ">=3.9"
backend: python_module(math)

docs: https://docs.python.org/3/library/math.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/math.html — Python math module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/mathmodule.c"
  notes:
    - "This spec extends math.zspec.zsdl and prior extras through math_extra20.zspec.zsdl."
    - "math_extra20 covers __qualname__ for floor/ceil/sqrt (as standalone invariants) and __module__ for floor/ceil/sqrt/log/gcd/isfinite/isinf/isnan/factorial/fabs."
    - "No prior spec covers __qualname__ for log/gcd/lcm/isnan/isinf as standalone invariants."
    - "math.log.__qualname__ == 'log' — top-level builtin qualname equals __name__."
    - "math.gcd.__qualname__ == 'gcd' — top-level builtin qualname equals __name__."
    - "math.lcm.__qualname__ == 'lcm' — top-level builtin qualname equals __name__."
    - "math.isnan.__qualname__ == 'isnan' — top-level builtin qualname equals __name__."
    - "math.isinf.__qualname__ == 'isinf' — top-level builtin qualname equals __name__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# math function __qualname__ table
#
# math_extra20 covered __qualname__ for floor/ceil/sqrt as standalone
# invariants and __module__ for a broader set. No prior spec checks
# __qualname__ for log/gcd/lcm/isnan/isinf. For C builtins at module level,
# __qualname__ always equals __name__. This table confirms that invariant
# for the remaining representative set of math functions.
# ---------------------------------------------------------------------------

table math_extra21.function_qualnames:
  description: "__qualname__ == function name for math builtin functions not covered in prior specs"
  kind: python_call_eq
  category: function_identity
  id_prefix: mqn

  columns: [id, function, args, expected]
  rows:
    - [log,   log.__qualname__.__eq__,   ["log"],   true]
    - [gcd,   gcd.__qualname__.__eq__,   ["gcd"],   true]
    - [lcm,   lcm.__qualname__.__eq__,   ["lcm"],   true]
    - [isnan, isnan.__qualname__.__eq__, ["isnan"], true]
    - [isinf, isinf.__qualname__.__eq__, ["isinf"], true]
