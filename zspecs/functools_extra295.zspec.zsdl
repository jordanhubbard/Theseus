spec: functools_extra295
version: ">=3.14"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools.Placeholder and functools.partial class attributes"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py, Modules/_functoolsmodule.c"
  notes:
    - "functools.Placeholder is a singleton instance of _PlaceholderType, not a class itself"
    - "functools.partial.func/args/keywords are member_descriptor (not getset_descriptor)"
    - "Placeholder is a Python 3.14 addition for partial application with positional placeholders"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table functools_extra295.placeholder_identity:
  description: "Identity attributes of the functools.Placeholder singleton instance"
  kind: python_call_eq
  category: identity
  id_prefix: fex295a

  columns: [id, function, args, expected, description]
  rows:
    - [fex295a01, functools.Placeholder.__class__.__name__.__eq__, ["_PlaceholderType"], true, "Placeholder class name is _PlaceholderType"]
    - [fex295a02, functools.Placeholder.__class__.__module__.__eq__, ["functools"], true, "Placeholder class module is functools"]
    - [fex295a03, functools.Placeholder.__module__.__eq__, ["functools"], true, "Placeholder instance __module__ is functools"]
    - [fex295a04, functools.Placeholder.__doc__.__class__.__name__.__eq__, ["str"], true, "Placeholder __doc__ is a str"]
    - [fex295a05, functools.Placeholder.__class__.__class__.__name__.__eq__, ["type"], true, "Placeholder class's metaclass is type"]

table functools_extra295.partial_descriptor_types:
  description: "Class names of functools.partial descriptor attributes func, args, keywords"
  kind: python_call_eq
  category: identity
  id_prefix: fex295b

  columns: [id, function, args, expected, description]
  rows:
    - [fex295b01, functools.partial.func.__class__.__name__.__eq__, ["member_descriptor"], true, "partial.func descriptor is member_descriptor"]
    - [fex295b02, functools.partial.args.__class__.__name__.__eq__, ["member_descriptor"], true, "partial.args descriptor is member_descriptor"]
    - [fex295b03, functools.partial.keywords.__class__.__name__.__eq__, ["member_descriptor"], true, "partial.keywords descriptor is member_descriptor"]
    - [fex295b04, functools.partial.func.__class__.__module__.__eq__, ["builtins"], true, "partial.func descriptor module is builtins"]
    - [fex295b05, functools.partial.args.__class__.__module__.__eq__, ["builtins"], true, "partial.args descriptor module is builtins"]

invariant functools_extra295.inv_placeholder_class_name:
  description: "Placeholder singleton class name equals _PlaceholderType"
  category: identity
  kind: python_call_eq
  function: functools.Placeholder.__class__.__name__.__eq__
  args: ["_PlaceholderType"]
  expected: true

invariant functools_extra295.inv_partial_func_descriptor:
  description: "partial.func is a member_descriptor"
  category: identity
  kind: python_call_eq
  function: functools.partial.func.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant functools_extra295.inv_partial_args_descriptor:
  description: "partial.args is a member_descriptor"
  category: identity
  kind: python_call_eq
  function: functools.partial.args.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true
