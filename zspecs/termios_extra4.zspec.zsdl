spec: termios_extra4
version: ">=3.9"
backend: python_module(termios)

docs: https://docs.python.org/3/library/termios.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/termios.html — Python termios module documentation"
    - "POSIX.1-2017 — termios(3) terminal I/O interface specification"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/termios.c"
  notes:
    - "This spec extends termios.zspec.zsdl through termios_extra3.zspec.zsdl with new, non-duplicate invariants."
    - "termios covers: all 6 function __name__; TCSANOW/TCSADRAIN/TCSAFLUSH values; ECHO/ICANON/NOFLSH type; ECHO > 0."
    - "termios_extra covers: 5 function __name__; TCSANOW/TCSADRAIN/TCSAFLUSH class (int); IFLAG/OFLAG/CFLAG/LFLAG/ISPEED/OSPEED/CC values."
    - "termios_extra2 covers: tcsendbreak __name__; all-function __qualname__ and type; TCSANOW/TCSADRAIN/TCSAFLUSH compact value table; index constant class checks; TCSANOW<TCSADRAIN and TCSADRAIN<TCSAFLUSH."
    - "termios_extra3 covers: module __name__/__package__; tcflush/tcflow action constants; B0/B9600/B115200 values; NCCS; VMIN/VTIME."
    - "function __module__ covered in termios_extra3 — not repeated here."
    - "New here: function __doc__ type checks; ISIG/OPOST type checks (termios module); ICANON/NOFLSH positivity; additional baud rates B300/B1200/B4800/B38400; VINTR/VQUIT/VSUSP c_cc index values."
    - "termios is POSIX-only; not available on Windows. All invariants apply to macOS and Linux."
    - "ISIG and OPOST are lflag/oflag bit constants; their types are int on all POSIX platforms."
    - "B300=300, B1200=1200, B4800=4800, B38400=38400 on macOS (numeric value equals baud rate)."
    - "VINTR=8, VQUIT=9, VSUSP=10 on macOS — indices into the c_cc control-character array."
    - "ICANON > 0 and NOFLSH > 0 — both are positive bitmask values on all POSIX platforms."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __doc__ type checks
# termios functions are C-level builtins; they all expose string docstrings.
# Not covered in any prior termios spec.
# ---------------------------------------------------------------------------

table termios_extra4.function_doc_types:
  kind: python_call_eq
  category: function_docs
  id_prefix: doc_type

  columns: [id, function, args, expected]
  rows:
    - [tcgetattr,   tcgetattr.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [tcsetattr,   tcsetattr.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [tcsendbreak, tcsendbreak.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [tcdrain,     tcdrain.__doc__.__class__.__name__.__eq__,     ["str"], true]
    - [tcflush,     tcflush.__doc__.__class__.__name__.__eq__,     ["str"], true]
    - [tcflow,      tcflow.__doc__.__class__.__name__.__eq__,      ["str"], true]

# ---------------------------------------------------------------------------
# ISIG and OPOST — type checks
# termios.zspec.zsdl covers ECHO/ICANON/NOFLSH type checks but NOT ISIG or OPOST.
# Both are standard POSIX termios flag bits available on macOS and Linux.
# ---------------------------------------------------------------------------

invariant termios_extra4.ISIG.is_int:
  description: "termios.ISIG.__class__.__name__ == 'int' — lflag bit enabling signal-generating characters"
  category: constants
  kind: python_call_eq
  function: ISIG.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant termios_extra4.OPOST.is_int:
  description: "termios.OPOST.__class__.__name__ == 'int' — oflag bit enabling output post-processing"
  category: constants
  kind: python_call_eq
  function: OPOST.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# ICANON and NOFLSH — positivity checks
# termios.zspec.zsdl checks ECHO > 0; ICANON > 0 and NOFLSH > 0 are new here.
# Both are guaranteed non-zero bitmask values on all POSIX platforms.
# ---------------------------------------------------------------------------

invariant termios_extra4.ICANON.positive:
  description: "termios.ICANON > 0 — ICANON bitmask is a positive integer on all POSIX platforms"
  category: constants
  kind: python_call_eq
  function: ICANON.__gt__
  args: [0]
  expected: true

invariant termios_extra4.NOFLSH.positive:
  description: "termios.NOFLSH > 0 — NOFLSH bitmask is a positive integer on all POSIX platforms"
  category: constants
  kind: python_call_eq
  function: NOFLSH.__gt__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# Additional baud rate constants — value pins
# termios_extra3 covers B0/B9600/B115200. New here: B300/B1200/B4800/B38400.
# On macOS, these constants equal the corresponding baud rate numerically.
# ---------------------------------------------------------------------------

table termios_extra4.baud_rates.values:
  kind: python_call_eq
  category: constants
  id_prefix: baud_val

  columns: [id, function, args, expected]
  rows:
    - [B300,   B300.__eq__,   [300],   true]
    - [B1200,  B1200.__eq__,  [1200],  true]
    - [B4800,  B4800.__eq__,  [4800],  true]
    - [B38400, B38400.__eq__, [38400], true]

# ---------------------------------------------------------------------------
# VINTR, VQUIT, VSUSP — c_cc array index values (macOS)
# termios_extra3 covers VMIN=16 and VTIME=17; VINTR/VQUIT/VSUSP are new here.
# VINTR=8, VQUIT=9, VSUSP=10 on macOS/Darwin.
# ---------------------------------------------------------------------------

table termios_extra4.vcc_indices.values:
  kind: python_call_eq
  category: constants
  id_prefix: vcc_val

  columns: [id, function, args, expected]
  rows:
    - [VINTR, VINTR.__eq__, [8],  true]
    - [VQUIT, VQUIT.__eq__, [9],  true]
    - [VSUSP, VSUSP.__eq__, [10], true]
