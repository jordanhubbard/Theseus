spec: statistics_extra24
version: ">=3.9"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html — Python statistics module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
  notes:
    - "This spec extends statistics_extra24.zspec.zsdl."
    - "Prior specs covered: mean/median/mode/stdev/variance/pstdev/pvariance, statistics.__name__/__package__, StatisticsError.__name__/__module__, NormalDist.__name__/__module__/__qualname__, various function __name__ and __module__ attributes, NormalDist.__bases__[0].__name__, statistics.__all__ type and length, NormalDist method qualnames, property fget qualnames, pdf/cdf qualnames, StatisticsError base/module, function qualnames and modules."
    - "This spec covers: NormalDist.__init__.__name__, NormalDist.__class__.__name__ (via Fraction.__name__ equivalent — NormalDist.__name__), NormalDist default mu and sigma via __init__.__defaults__, StatisticsError.__bases__[0].__name__ (standalone invariant confirming ValueError), fmean/__name__, geometric_mean/__name__, harmonic_mean/__name__, median_low/__name__, median_high/__name__, median_grouped/__name__."
    - "NormalDist.__init__.__name__ == '__init__' — standard dunder name for the initializer method."
    - "NormalDist.__init__.__defaults__ == (0.0, 1.0) — default mu=0.0 and sigma=1.0; this proves NormalDist(0,1) is the standard normal distribution."
    - "NormalDist.mean, NormalDist.stdev, NormalDist.variance are Python property descriptors."
    - "StatisticsError.__bases__[0].__name__ == 'ValueError' — already in extra22; repeated here as standalone for completeness of this series."
    - "fmean, geometric_mean, harmonic_mean, median_low, median_high, median_grouped are all module-level functions; their __name__ equals the function name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# NormalDist.__init__.__name__
#
# No prior spec records NormalDist.__init__.__name__ (extra23 records
# __qualname__ for NormalDist.__init__ but not __name__).
# ---------------------------------------------------------------------------

invariant statistics_extra24.NormalDist.init_name:
  description: "statistics.NormalDist.__init__.__name__ == '__init__'"
  category: method_identity
  kind: python_call_eq
  function: NormalDist.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

invariant statistics_extra24.NormalDist.init_name_len:
  description: "len(statistics.NormalDist.__init__.__name__) == 8 — '__init__' is 8 chars"
  category: method_identity
  kind: python_call_eq
  function: NormalDist.__init__.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# NormalDist.__name__ (class name string)
#
# NormalDist.__name__ == 'NormalDist' — this is the class name and is also
# the value of NormalDist(mu, sigma).__class__.__name__ for any valid params.
# No prior spec records NormalDist.__name__ as a simple string equality check
# (prior specs use __qualname__.__eq__).
# ---------------------------------------------------------------------------

invariant statistics_extra24.NormalDist.class_name:
  description: "statistics.NormalDist.__name__ == 'NormalDist'"
  category: class_identity
  kind: python_call_eq
  function: NormalDist.__name__.__eq__
  args: ["NormalDist"]
  expected: true

invariant statistics_extra24.NormalDist.class_name_len:
  description: "len(statistics.NormalDist.__name__) == 10 — 'NormalDist' is 10 chars"
  category: class_identity
  kind: python_call_eq
  function: NormalDist.__name__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# NormalDist default parameter values via __init__.__defaults__
#
# No prior spec records NormalDist.__init__.__defaults__.
# NormalDist(mu=0.0, sigma=1.0) is the standard normal distribution;
# the default arguments confirm that NormalDist() constructs N(0,1) by default,
# and thus NormalDist(0, 1).mean == 0.0, .stdev == 1.0, .variance == 1.0.
# ---------------------------------------------------------------------------

invariant statistics_extra24.NormalDist.default_mu:
  description: "statistics.NormalDist.__init__.__defaults__[0] == 0.0 — default mu for N(0,1)"
  category: method_identity
  kind: python_call_eq
  function: "NormalDist.__init__.__defaults__[0].__eq__"
  args: [0.0]
  expected: true

invariant statistics_extra24.NormalDist.default_sigma:
  description: "statistics.NormalDist.__init__.__defaults__[1] == 1.0 — default sigma for N(0,1)"
  category: method_identity
  kind: python_call_eq
  function: "NormalDist.__init__.__defaults__[1].__eq__"
  args: [1.0]
  expected: true

# ---------------------------------------------------------------------------
# NormalDist property descriptor class names
#
# No prior spec records that NormalDist.mean, .stdev, and .variance are
# property descriptors (i.e. __class__.__name__ == 'property').
# ---------------------------------------------------------------------------

table statistics_extra24.normaldist_property_class_names:
  kind: python_call_eq
  category: type_identity
  id_prefix: class_name

  columns: [id, function, args, expected, description]
  rows:
    - [mean,     NormalDist.mean.__class__.__name__.__eq__,     ["property"], true, "NormalDist.mean is a property descriptor"]
    - [stdev,    NormalDist.stdev.__class__.__name__.__eq__,    ["property"], true, "NormalDist.stdev is a property descriptor"]
    - [variance, NormalDist.variance.__class__.__name__.__eq__, ["property"], true, "NormalDist.variance is a property descriptor"]

# ---------------------------------------------------------------------------
# StatisticsError base class name (standalone invariant)
#
# statistics_extra22 records this in a standalone invariant; repeated here
# for self-containedness of this series step.
# StatisticsError.__bases__[0].__name__ == 'ValueError'.
# ---------------------------------------------------------------------------

invariant statistics_extra24.StatisticsError.base_name:
  description: "statistics.StatisticsError.__bases__[0].__name__ == 'ValueError'"
  category: class_identity
  kind: python_call_eq
  function: "StatisticsError.__bases__[0].__name__.__eq__"
  args: ["ValueError"]
  expected: true

invariant statistics_extra24.StatisticsError.base_name_len:
  description: "len(statistics.StatisticsError.__bases__[0].__name__) == 10 — 'ValueError' is 10 chars"
  category: class_identity
  kind: python_call_eq
  function: "StatisticsError.__bases__[0].__name__.__len__"
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# Additional module-level function __name__ values
#
# No prior spec records __name__ for fmean, geometric_mean, harmonic_mean,
# median_low, median_high, or median_grouped.  All are module-level functions;
# their __name__ equals the simple function name string.
# ---------------------------------------------------------------------------

table statistics_extra24.extra_function_names:
  kind: python_call_eq
  category: function_identity
  id_prefix: name

  columns: [id, function, args, expected, description]
  rows:
    - [fmean,           fmean.__name__.__eq__,           ["fmean"],           true, "statistics.fmean.__name__ == 'fmean'"]
    - [geometric_mean,  geometric_mean.__name__.__eq__,  ["geometric_mean"],  true, "statistics.geometric_mean.__name__ == 'geometric_mean'"]
    - [harmonic_mean,   harmonic_mean.__name__.__eq__,   ["harmonic_mean"],   true, "statistics.harmonic_mean.__name__ == 'harmonic_mean'"]
    - [median_low,      median_low.__name__.__eq__,      ["median_low"],      true, "statistics.median_low.__name__ == 'median_low'"]
    - [median_high,     median_high.__name__.__eq__,     ["median_high"],     true, "statistics.median_high.__name__ == 'median_high'"]
    - [median_grouped,  median_grouped.__name__.__eq__,  ["median_grouped"],  true, "statistics.median_grouped.__name__ == 'median_grouped'"]

# ---------------------------------------------------------------------------
# Additional module-level function __name__ length invariants
# ---------------------------------------------------------------------------

invariant statistics_extra24.fmean.name_len:
  description: "len(statistics.fmean.__name__) == 5 — 'fmean' is 5 chars"
  category: function_identity
  kind: python_call_eq
  function: fmean.__name__.__len__
  args: []
  expected: 5

invariant statistics_extra24.geometric_mean.name_len:
  description: "len(statistics.geometric_mean.__name__) == 14 — 'geometric_mean' is 14 chars"
  category: function_identity
  kind: python_call_eq
  function: geometric_mean.__name__.__len__
  args: []
  expected: 14

invariant statistics_extra24.harmonic_mean.name_len:
  description: "len(statistics.harmonic_mean.__name__) == 13 — 'harmonic_mean' is 13 chars"
  category: function_identity
  kind: python_call_eq
  function: harmonic_mean.__name__.__len__
  args: []
  expected: 13

invariant statistics_extra24.median_low.name_len:
  description: "len(statistics.median_low.__name__) == 10 — 'median_low' is 10 chars"
  category: function_identity
  kind: python_call_eq
  function: median_low.__name__.__len__
  args: []
  expected: 10

invariant statistics_extra24.median_high.name_len:
  description: "len(statistics.median_high.__name__) == 11 — 'median_high' is 11 chars"
  category: function_identity
  kind: python_call_eq
  function: median_high.__name__.__len__
  args: []
  expected: 11

invariant statistics_extra24.median_grouped.name_len:
  description: "len(statistics.median_grouped.__name__) == 14 — 'median_grouped' is 14 chars"
  category: function_identity
  kind: python_call_eq
  function: median_grouped.__name__.__len__
  args: []
  expected: 14
