spec: functools_extra20
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools.zspec.zsdl and prior extras through functools_extra19.zspec.zsdl."
    - "functools_extra19 covers: __module__.__eq__ for partial, lru_cache, wraps, total_ordering, singledispatch, cached_property, cache (all 'functools'); reduce.__module__.__eq__('_functools'); WRAPPER_UPDATES.__len__()==1 and [0]=='__dict__'; WRAPPER_ASSIGNMENTS.__len__()==6; partial.__module__.__len__()==9; cache.__module__.__len__()==9."
    - "functools_extra14 covers: __name__.__len__() for cmp_to_key(10)/total_ordering(14)/lru_cache(9)/singledispatch(14)/singledispatchmethod(20)."
    - "functools_extra13 covers: __name__.__len__() for reduce(6)/partial(7)/wraps(5)/cached_property(15)."
    - "No prior functools spec covers __module__.__len__() for wraps, total_ordering, singledispatch, cached_property, lru_cache, singledispatchmethod, or cmp_to_key."
    - "functools.wraps.__module__.__len__() == 9 — len('functools')."
    - "functools.total_ordering.__module__.__len__() == 9 — len('functools')."
    - "functools.singledispatch.__module__.__len__() == 9 — len('functools')."
    - "functools.cached_property.__module__.__len__() == 9 — len('functools')."
    - "functools.lru_cache.__module__.__len__() == 9 — len('functools')."
    - "functools.singledispatchmethod.__module__.__len__() == 9 — len('functools')."
    - "functools.cmp_to_key.__module__ == '_functools' — C extension; __module__.__len__() == 10."
    - "functools.reduce.__module__.__len__() == 10 — len('_functools'), confirmed from extra19 value '_functools'."
    - "No prior functools spec covers partialmethod.__module__.__eq__ or partialmethod.__module__.__len__()."
    - "functools.partialmethod.__module__ == 'functools'; __module__.__len__() == 9."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__len__() cross-checks for Python-level functools members
#
# functools_extra19 covers __module__.__len__() for partial (9) and cache (9).
# No prior spec covers __module__.__len__() for wraps, total_ordering,
# singledispatch, cached_property, lru_cache, singledispatchmethod, or
# partialmethod — all have __module__ == 'functools' (len == 9).
# ---------------------------------------------------------------------------

invariant functools_extra20.wraps.module_len:
  description: "functools.wraps.__module__.__len__() == 9 — len('functools')"
  category: module_attr_lengths
  kind: python_call_eq
  function: wraps.__module__.__len__
  args: []
  expected: 9

invariant functools_extra20.total_ordering.module_len:
  description: "functools.total_ordering.__module__.__len__() == 9 — len('functools')"
  category: module_attr_lengths
  kind: python_call_eq
  function: total_ordering.__module__.__len__
  args: []
  expected: 9

invariant functools_extra20.singledispatch.module_len:
  description: "functools.singledispatch.__module__.__len__() == 9 — len('functools')"
  category: module_attr_lengths
  kind: python_call_eq
  function: singledispatch.__module__.__len__
  args: []
  expected: 9

invariant functools_extra20.cached_property.module_len:
  description: "functools.cached_property.__module__.__len__() == 9 — len('functools')"
  category: module_attr_lengths
  kind: python_call_eq
  function: cached_property.__module__.__len__
  args: []
  expected: 9

invariant functools_extra20.lru_cache.module_len:
  description: "functools.lru_cache.__module__.__len__() == 9 — len('functools')"
  category: module_attr_lengths
  kind: python_call_eq
  function: lru_cache.__module__.__len__
  args: []
  expected: 9

invariant functools_extra20.singledispatchmethod.module_len:
  description: "functools.singledispatchmethod.__module__.__len__() == 9 — len('functools')"
  category: module_attr_lengths
  kind: python_call_eq
  function: singledispatchmethod.__module__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# __module__.__len__() for C-extension members: cmp_to_key, reduce
#
# functools_extra19 confirms reduce.__module__ == '_functools' (len == 10).
# No prior spec records reduce.__module__.__len__() == 10 as a standalone
# invariant. cmp_to_key.__module__.__len__() == 10 is also not yet recorded.
# ---------------------------------------------------------------------------

invariant functools_extra20.reduce.module_len:
  description: "functools.reduce.__module__.__len__() == 10 — len('_functools')"
  category: module_attr_lengths
  kind: python_call_eq
  function: reduce.__module__.__len__
  args: []
  expected: 10

invariant functools_extra20.cmp_to_key.module_len:
  description: "functools.cmp_to_key.__module__.__len__() == 10 — len('_functools')"
  category: module_attr_lengths
  kind: python_call_eq
  function: cmp_to_key.__module__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# partialmethod — __module__ equality and length
#
# No prior functools spec covers partialmethod.__module__.__eq__ as a standalone
# invariant (extra15 covers __name__ and __qualname__ for partialmethod only).
# partialmethod is defined in functools.py so __module__ == 'functools'.
# ---------------------------------------------------------------------------

invariant functools_extra20.partialmethod.module_eq:
  description: "functools.partialmethod.__module__ == 'functools' — pure-Python class"
  category: module_attrs
  kind: python_call_eq
  function: partialmethod.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra20.partialmethod.module_len:
  description: "functools.partialmethod.__module__.__len__() == 9 — len('functools')"
  category: module_attr_lengths
  kind: python_call_eq
  function: partialmethod.__module__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# __qualname__.__len__() cross-checks — selected members not yet covered
#
# functools_extra14 covers __qualname__.__len__() for cmp_to_key/total_ordering/
# lru_cache/singledispatch/singledispatchmethod.
# functools_extra13 covers __qualname__.__len__() for reduce and partial.
# functools_extra15 covers __qualname__.__len__() for partialmethod.
# functools_extra18 covers __qualname__.__len__() for cache (5) and
# singledispatchmethod (20).
# No prior spec records __qualname__.__len__() for wraps (5) or
# cached_property (15) as standalone invariants.
# ---------------------------------------------------------------------------

invariant functools_extra20.wraps.qualname_len:
  description: "functools.wraps.__qualname__.__len__() == 5 — len('wraps')"
  category: qualname_lengths
  kind: python_call_eq
  function: wraps.__qualname__.__len__
  args: []
  expected: 5

invariant functools_extra20.cached_property.qualname_len:
  description: "functools.cached_property.__qualname__.__len__() == 15 — len('cached_property')"
  category: qualname_lengths
  kind: python_call_eq
  function: cached_property.__qualname__.__len__
  args: []
  expected: 15
