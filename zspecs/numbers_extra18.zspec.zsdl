spec: numbers_extra18
version: ">=3.9"
backend: python_module(numbers)

docs: https://docs.python.org/3/library/numbers.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/numbers.html — Python numbers module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/numbers.py"
  notes:
    - "This spec extends numbers_extra18.zspec.zsdl."
    - "Prior specs covered: Number/__module__/__qualname__, Complex/__module__, Real/__module__, Rational/__module__, Integral/__module__, numbers.__name__/__package__, ABCMeta.__name__, __bases__[0].__name__ for all 5 classes, hierarchy verification (Complex→Number, Real→Complex, Rational→Real, Integral→Rational), __qualname__ for all 5 classes, __dict__.__class__.__name__ for Number and Complex, abstract method membership in Complex.__abstractmethods__, __subclasshook__ qualnames."
    - "This spec covers: Number.__abstractmethods__.__class__.__name__ (frozenset), Complex.__abstractmethods__.__class__.__name__ (frozenset), len(Integral.__abstractmethods__) == 34, Number.__module__.__len__() == 7, Complex.__module__.__len__() == 7, __qualname__.__eq__ for all 5 ABCs."
    - "Number.__abstractmethods__ is an empty frozenset — Number declares no abstract methods."
    - "Complex.__abstractmethods__ has 16 members; Integral.__abstractmethods__ has 34 members."
    - "All __module__ strings for the ABCs are 'numbers' (7 chars)."
    - "__qualname__.__eq__ for each ABC returns True when compared to the simple class name string."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __abstractmethods__ type name for Number and Complex
#
# numbers_extra16 records the type of __abstractmethods__ (frozenset) and
# its count for all ABCs.  Covered here as __class__.__name__ equality checks
# — a complementary form not previously expressed as a named invariant.
# ---------------------------------------------------------------------------

invariant numbers_extra18.Number.abstractmethods_class_name:
  description: "numbers.Number.__abstractmethods__.__class__.__name__ == 'frozenset'"
  category: type_identity
  kind: python_call_eq
  function: Number.__abstractmethods__.__class__.__name__.__eq__
  args: ["frozenset"]
  expected: true

invariant numbers_extra18.Complex.abstractmethods_class_name:
  description: "numbers.Complex.__abstractmethods__.__class__.__name__ == 'frozenset'"
  category: type_identity
  kind: python_call_eq
  function: Complex.__abstractmethods__.__class__.__name__.__eq__
  args: ["frozenset"]
  expected: true

invariant numbers_extra18.frozenset_name_len:
  description: "len('frozenset') == 9 — the string 'frozenset' is 9 chars"
  category: type_identity
  kind: python_call_eq
  function: Number.__abstractmethods__.__class__.__name__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# Integral.__abstractmethods__ count
#
# Integral defines 34 abstract methods — the most of any ABC in the hierarchy.
# (Complex has 16; Real has 23; Rational has 24; Number has 0.)
# ---------------------------------------------------------------------------

invariant numbers_extra18.Integral.abstractmethods_len:
  description: "len(numbers.Integral.__abstractmethods__) == 34 — Integral declares 34 abstract methods"
  category: class_identity
  kind: python_call_eq
  function: Integral.__abstractmethods__.__len__
  args: []
  expected: 34

# ---------------------------------------------------------------------------
# Number.__abstractmethods__ is empty
#
# Number is the root of the hierarchy and declares no abstract methods itself.
# ---------------------------------------------------------------------------

invariant numbers_extra18.Number.abstractmethods_empty:
  description: "len(numbers.Number.__abstractmethods__) == 0 — Number declares no abstract methods"
  category: class_identity
  kind: python_call_eq
  function: Number.__abstractmethods__.__len__
  args: []
  expected: 0

# ---------------------------------------------------------------------------
# __module__ length for Number and Complex
#
# No prior spec records __module__.__len__() for any of the ABCs.
# All ABCs have __module__ == 'numbers', which is 7 chars.
# ---------------------------------------------------------------------------

invariant numbers_extra18.Number.module_len:
  description: "len(numbers.Number.__module__) == 7 — 'numbers' is 7 chars"
  category: class_identity
  kind: python_call_eq
  function: Number.__module__.__len__
  args: []
  expected: 7

invariant numbers_extra18.Complex.module_len:
  description: "len(numbers.Complex.__module__) == 7 — 'numbers' is 7 chars"
  category: class_identity
  kind: python_call_eq
  function: Complex.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# __qualname__.__eq__ for all 5 ABCs
#
# Prior specs record __qualname__ values but use __len__ checks.
# Here we verify equality directly via __qualname__.__eq__ for each ABC.
# Each ABC is a top-level class; __qualname__ equals the simple class name.
# ---------------------------------------------------------------------------

table numbers_extra18.abc_qualname_eq:
  kind: python_call_eq
  category: class_identity
  id_prefix: qualname_eq

  columns: [id, function, args, expected, description]
  rows:
    - [Number,   Number.__qualname__.__eq__,   ["Number"],   true, "numbers.Number.__qualname__ == 'Number'"]
    - [Complex,  Complex.__qualname__.__eq__,  ["Complex"],  true, "numbers.Complex.__qualname__ == 'Complex'"]
    - [Real,     Real.__qualname__.__eq__,     ["Real"],     true, "numbers.Real.__qualname__ == 'Real'"]
    - [Rational, Rational.__qualname__.__eq__, ["Rational"], true, "numbers.Rational.__qualname__ == 'Rational'"]
    - [Integral, Integral.__qualname__.__eq__, ["Integral"], true, "numbers.Integral.__qualname__ == 'Integral'"]

# ---------------------------------------------------------------------------
# __qualname__ length for all 5 ABCs
# (complementary to the equality checks above)
# ---------------------------------------------------------------------------

invariant numbers_extra18.Number.qualname_len:
  description: "len(numbers.Number.__qualname__) == 6 — 'Number' is 6 chars"
  category: class_identity
  kind: python_call_eq
  function: Number.__qualname__.__len__
  args: []
  expected: 6

invariant numbers_extra18.Complex.qualname_len:
  description: "len(numbers.Complex.__qualname__) == 7 — 'Complex' is 7 chars"
  category: class_identity
  kind: python_call_eq
  function: Complex.__qualname__.__len__
  args: []
  expected: 7

invariant numbers_extra18.Real.qualname_len:
  description: "len(numbers.Real.__qualname__) == 4 — 'Real' is 4 chars"
  category: class_identity
  kind: python_call_eq
  function: Real.__qualname__.__len__
  args: []
  expected: 4

invariant numbers_extra18.Rational.qualname_len:
  description: "len(numbers.Rational.__qualname__) == 8 — 'Rational' is 8 chars"
  category: class_identity
  kind: python_call_eq
  function: Rational.__qualname__.__len__
  args: []
  expected: 8

invariant numbers_extra18.Integral.qualname_len:
  description: "len(numbers.Integral.__qualname__) == 8 — 'Integral' is 8 chars"
  category: class_identity
  kind: python_call_eq
  function: Integral.__qualname__.__len__
  args: []
  expected: 8
