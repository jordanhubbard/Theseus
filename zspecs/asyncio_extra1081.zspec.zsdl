spec: asyncio_extra1081
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio BaseEventLoop, Handle, and exception class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks asyncio.BaseEventLoop class module/qualname/name identity, asyncio.Handle method qualnames (cancel, cancelled, __repr__), asyncio.InvalidStateError/TimeoutError/CancelledError module and qualname — behaviors not covered by extra1051 or extra1066"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra1081.base_event_loop_identity:
  description: "asyncio.BaseEventLoop module, qualname, and name class identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: as1081be
  columns: [id, function, args, expected]
  rows:
    - [as1081be001, asyncio.BaseEventLoop.__module__.__eq__,               ["asyncio.base_events"], true]
    - [as1081be002, asyncio.BaseEventLoop.__qualname__.__eq__,             ["BaseEventLoop"],        true]
    - [as1081be003, asyncio.BaseEventLoop.__name__.__eq__,                 ["BaseEventLoop"],        true]
    - [as1081be004, asyncio.BaseEventLoop.__class__.__name__.__eq__,       ["type"],                 true]
    - [as1081be005, asyncio.BaseEventLoop.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [as1081be006, asyncio.AbstractEventLoop.__module__.__eq__,           ["asyncio.events"],      true]
    - [as1081be007, asyncio.AbstractEventLoop.__qualname__.__eq__,         ["AbstractEventLoop"],   true]

table asyncio_extra1081.handle_method_qualnames:
  description: "asyncio.Handle cancel, cancelled, and __repr__ method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: as1081hm
  columns: [id, function, args, expected]
  rows:
    - [as1081hm001, asyncio.Handle.__module__.__eq__,                 ["asyncio.events"], true]
    - [as1081hm002, asyncio.Handle.__qualname__.__eq__,               ["Handle"],         true]
    - [as1081hm003, asyncio.Handle.__name__.__eq__,                   ["Handle"],         true]
    - [as1081hm004, asyncio.Handle.cancel.__qualname__.__eq__,        ["Handle.cancel"],        true]
    - [as1081hm005, asyncio.Handle.cancelled.__qualname__.__eq__,     ["Handle.cancelled"],     true]
    - [as1081hm006, asyncio.Handle.__repr__.__qualname__.__eq__,      ["Handle.__repr__"],      true]
    - [as1081hm007, asyncio.Handle.cancel.__class__.__name__.__eq__,  ["function"],             true]

table asyncio_extra1081.exception_class_identity:
  description: "asyncio.InvalidStateError, TimeoutError, and CancelledError module and qualname identity"
  kind: python_call_eq
  category: exception_identity
  id_prefix: as1081ex
  columns: [id, function, args, expected]
  rows:
    - [as1081ex001, asyncio.InvalidStateError.__module__.__eq__,       ["asyncio.exceptions"],  true]
    - [as1081ex002, asyncio.InvalidStateError.__qualname__.__eq__,     ["InvalidStateError"],   true]
    - [as1081ex003, asyncio.InvalidStateError.__name__.__eq__,         ["InvalidStateError"],   true]
    - [as1081ex004, asyncio.TimeoutError.__module__.__eq__,            ["asyncio.exceptions"],  true]
    - [as1081ex005, asyncio.TimeoutError.__qualname__.__eq__,          ["TimeoutError"],        true]
    - [as1081ex006, asyncio.CancelledError.__module__.__eq__,          ["asyncio.exceptions"],  true]
    - [as1081ex007, asyncio.CancelledError.__qualname__.__eq__,        ["CancelledError"],      true]
