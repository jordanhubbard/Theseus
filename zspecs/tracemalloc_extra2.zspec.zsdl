spec: tracemalloc_extra2
version: ">=3.9"
backend: python_module(tracemalloc)

docs: https://docs.python.org/3/library/tracemalloc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tracemalloc.html — Python tracemalloc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tracemalloc.py"
    - "CPython source: Modules/_tracemalloc.c"
    - "tracemalloc.zspec.zsdl — covers module-level function __name__ checks and is_tracing/start/stop behavior"
    - "tracemalloc_extra.zspec.zsdl — covers class __name__ checks via table, Snapshot.__module__, and function __name__ table"
  notes:
    - "This spec covers class __module__ affiliation and additional class identity invariants not in tracemalloc.zspec.zsdl or tracemalloc_extra.zspec.zsdl."
    - "Frame, Snapshot, Statistic, StatisticDiff, Traceback, Filter, DomainFilter are all pure-Python classes defined in tracemalloc."
    - "All classes have __module__ == 'tracemalloc' — they are defined directly in the module, not in a submodule."
    - "DomainFilter.__name__ == 'DomainFilter' — added in Python 3.6 to filter by memory domain."
    - "Frame.__name__ == 'Frame' — represents a single frame in a traceback."
    - "Traceback.__name__ == 'Traceback' — a sequence of Frame objects."
    - "Statistic.__name__ == 'Statistic' — a memory allocation statistic."
    - "StatisticDiff.__name__ == 'StatisticDiff' — difference between two Statistic snapshots."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ checks
# ---------------------------------------------------------------------------

invariant tracemalloc_extra2.Frame.name:
  description: "tracemalloc.Frame.__name__ == 'Frame'"
  category: class_names
  kind: python_call_eq
  function: Frame.__name__.__eq__
  args: ["Frame"]
  expected: true

invariant tracemalloc_extra2.Snapshot.name:
  description: "tracemalloc.Snapshot.__name__ == 'Snapshot'"
  category: class_names
  kind: python_call_eq
  function: Snapshot.__name__.__eq__
  args: ["Snapshot"]
  expected: true

invariant tracemalloc_extra2.Statistic.name:
  description: "tracemalloc.Statistic.__name__ == 'Statistic'"
  category: class_names
  kind: python_call_eq
  function: Statistic.__name__.__eq__
  args: ["Statistic"]
  expected: true

invariant tracemalloc_extra2.StatisticDiff.name:
  description: "tracemalloc.StatisticDiff.__name__ == 'StatisticDiff'"
  category: class_names
  kind: python_call_eq
  function: StatisticDiff.__name__.__eq__
  args: ["StatisticDiff"]
  expected: true

invariant tracemalloc_extra2.Traceback.name:
  description: "tracemalloc.Traceback.__name__ == 'Traceback'"
  category: class_names
  kind: python_call_eq
  function: Traceback.__name__.__eq__
  args: ["Traceback"]
  expected: true

invariant tracemalloc_extra2.Filter.name:
  description: "tracemalloc.Filter.__name__ == 'Filter'"
  category: class_names
  kind: python_call_eq
  function: Filter.__name__.__eq__
  args: ["Filter"]
  expected: true

invariant tracemalloc_extra2.DomainFilter.name:
  description: "tracemalloc.DomainFilter.__name__ == 'DomainFilter'"
  category: class_names
  kind: python_call_eq
  function: DomainFilter.__name__.__eq__
  args: ["DomainFilter"]
  expected: true

# ---------------------------------------------------------------------------
# Class __module__ affiliation — all defined in 'tracemalloc'
# ---------------------------------------------------------------------------

table tracemalloc_extra2.class_modules:
  kind: python_call_eq
  category: class_modules
  id_prefix: mod

  columns: [id, function, args, expected]
  rows:
    - [frame,          Frame.__module__.__eq__,          ["tracemalloc"], true]
    - [snapshot,       Snapshot.__module__.__eq__,       ["tracemalloc"], true]
    - [statistic,      Statistic.__module__.__eq__,      ["tracemalloc"], true]
    - [statistic_diff, StatisticDiff.__module__.__eq__,  ["tracemalloc"], true]
    - [traceback,      Traceback.__module__.__eq__,      ["tracemalloc"], true]
    - [filter,         Filter.__module__.__eq__,         ["tracemalloc"], true]
    - [domain_filter,  DomainFilter.__module__.__eq__,   ["tracemalloc"], true]
