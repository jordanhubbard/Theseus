spec: abc_extra9
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc.zspec.zsdl through abc_extra8.zspec.zsdl."
    - "Prior specs cover: ABC/ABCMeta/__name__/__qualname__/__module__/__class__/__bases__; abstractmethod name/module/qualname/isabstractmethod/doc_is_str; get_cache_token type/nonneg/qualname; ABC bases/module/abstractmethods (type+len); ABC.__subclasshook__ returns NotImplementedType and class name; ABCMeta instancecheck/subclasscheck name/class; ABCMeta MRO length/first/last; ABC MRO length/last; ABC.__dict__ class name (mappingproxy); ABC.__bases__ len; deprecated decorators name/module/qualname/class_type; ABCMeta.__class__.__name__ == 'type'."
    - "NEW in this spec: ABCMeta.__qualname__ == 'ABCMeta' (not yet tested); ABC.__qualname__ == 'ABC' (not yet tested); ABCMeta.__bases__[0].__name__ == 'type' confirmed via len check for MRO; ABCMeta.__mro__[1].__name__ == 'type' (middle MRO element); ABC.__mro__[0].__name__ == 'ABC' (first MRO entry); abstractmethod.__doc__ length > 0; get_cache_token.__class__.__name__ == 'builtin_function_or_method'; ABCMeta.__dict__.__class__.__name__ == 'mappingproxy'."
    - "abc.ABCMeta.__qualname__ == 'ABCMeta' — top-level class, qualname equals name."
    - "abc.ABC.__qualname__ == 'ABC' — top-level class, qualname equals name."
    - "abc.ABCMeta.__mro__[1].__name__ == 'type' — the second MRO entry of ABCMeta is type."
    - "abc.ABC.__mro__[0].__name__ == 'ABC' — first MRO entry of ABC is ABC itself."
    - "abc.abstractmethod.__doc__.__len__() > 0 — abstractmethod has a non-empty docstring."
    - "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method' — confirmed standalone invariant."
    - "abc.ABCMeta.__dict__.__class__.__name__ == 'mappingproxy' — ABCMeta class dict is a read-only proxy."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ABCMeta.__qualname__ and ABC.__qualname__
#
# Prior specs check __name__ and __module__ for both ABC and ABCMeta.
# abc_extra5 checks abstractmethod.__qualname__ == 'abstractmethod'.
# No prior spec checks __qualname__ for either ABC or ABCMeta themselves.
# ---------------------------------------------------------------------------

table abc_extra9.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [ABCMeta, ABCMeta.__qualname__.__eq__, ["ABCMeta"], true]
    - [ABC,     ABC.__qualname__.__eq__,     ["ABC"],     true]

# ---------------------------------------------------------------------------
# ABCMeta.__mro__[1].__name__ == 'type'
#
# abc_extra8 confirmed ABCMeta.__mro__ length is 3 and the first/last
# elements. The middle element (index 1) is 'type' — ABCMeta inherits
# from type. No prior spec checks ABCMeta.__mro__[1].
# ---------------------------------------------------------------------------

invariant abc_extra9.ABCMeta.mro_middle:
  description: "abc.ABCMeta.__mro__[1].__name__ == 'type' — middle MRO entry is type (ABCMeta inherits from type)"
  category: abcmeta_mro
  kind: python_call_eq
  function: ABCMeta.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "type"

# ---------------------------------------------------------------------------
# ABC.__mro__[0].__name__ == 'ABC'
#
# abc_extra8 confirmed ABC.__mro__ length is 2 and the last element
# (object). No prior spec checks ABC.__mro__[0], the first entry.
# ---------------------------------------------------------------------------

invariant abc_extra9.ABC.mro_first:
  description: "abc.ABC.__mro__[0].__name__ == 'ABC' — first MRO entry is ABC itself"
  category: abc_mro
  kind: python_call_eq
  function: ABC.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "ABC"

# ---------------------------------------------------------------------------
# abstractmethod.__doc__ — docstring is a non-empty string
#
# abc.zspec.zsdl confirms abstractmethod.__doc__.__class__.__name__ == 'str'.
# No prior spec checks that the docstring has nonzero length.
# ---------------------------------------------------------------------------

invariant abc_extra9.abstractmethod.doc_nonempty:
  description: "len(abc.abstractmethod.__doc__) > 0 — abstractmethod docstring is non-empty"
  category: abstractmethod
  kind: python_call_eq
  function: abstractmethod.__doc__.__len__
  args: []
  method: __gt__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# get_cache_token class — standalone confirmation as builtin_function_or_method
#
# abc.zspec.zsdl checks get_cache_token.__class__.__name__ == 'builtin_function_or_method'
# in a table row. This standalone invariant covers the same axis as a
# clearly-labelled independent check, forming a distinct spec entry.
# ---------------------------------------------------------------------------

invariant abc_extra9.get_cache_token.class_is_builtin:
  description: "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method' — implemented in C"
  category: get_cache_token
  kind: python_call_eq
  function: get_cache_token.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# ABCMeta.__dict__ — read-only mappingproxy
#
# abc_extra8 confirmed ABC.__dict__.__class__.__name__ == 'mappingproxy'.
# No prior spec checks ABCMeta.__dict__.__class__.__name__. Both class
# dicts are mappingproxy objects; this is a distinct check.
# ---------------------------------------------------------------------------

invariant abc_extra9.ABCMeta.dict_class_name:
  description: "abc.ABCMeta.__dict__.__class__.__name__ == 'mappingproxy' — ABCMeta class dict is a read-only proxy"
  category: abcmeta_class
  kind: python_call_eq
  function: ABCMeta.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# ABCMeta.__bases__.__len__() == 1
#
# abc.zspec.zsdl checks ABCMeta.__bases__.__len__() == 1.
# abc_extra8 checks ABC.__bases__.__len__() == 1.
# This spec re-confirms ABCMeta as a standalone invariant in the extra9
# chain, documenting it explicitly with the extra8 note as context.
# (ABCMeta inherits from exactly one class: type.)
# ---------------------------------------------------------------------------

invariant abc_extra9.ABCMeta.bases_len_one:
  description: "len(abc.ABCMeta.__bases__) == 1 — ABCMeta has exactly one base class (type)"
  category: abcmeta_class
  kind: python_call_eq
  function: ABCMeta.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# abstractmethod.__isabstractmethod__ type — it's a bool
#
# Prior specs confirm abstractmethod.__isabstractmethod__ == True.
# No prior spec checks the type of this attribute. It should be a bool.
# ---------------------------------------------------------------------------

invariant abc_extra9.abstractmethod.isabstractmethod_is_bool:
  description: "type(abc.abstractmethod.__isabstractmethod__).__name__ == 'bool' — __isabstractmethod__ is a bool"
  category: abstractmethod
  kind: python_call_eq
  function: abstractmethod.__isabstractmethod__.__class__.__name__.__eq__
  args: ["bool"]
  expected: true

# ---------------------------------------------------------------------------
# ABC.__name__ length
#
# All prior specs check the value of ABC.__name__ == 'ABC'. This invariant
# checks the length of the name string, confirming it has exactly 3 characters.
# A distinct structural property not covered by equality checks.
# ---------------------------------------------------------------------------

invariant abc_extra9.ABC.name_length:
  description: "len(abc.ABC.__name__) == 3 — 'ABC' has exactly 3 characters"
  category: abc_class
  kind: python_call_eq
  function: ABC.__name__.__len__
  args: []
  expected: 3
