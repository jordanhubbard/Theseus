    - [as1336hc002, asyncio.Future.__hash__.__class__.__name__.__eq__,          ["wrapper_descriptor"], true]
    - [as1336hc003, asyncio.Task.__hash__.__class__.__name__.__eq__,            ["wrapper_descriptor"], true]
    - [as1336hc004, asyncio.Lock.__hash__.__class__.__name__.__eq__,            ["wrapper_descriptor"], true]
    - [as1336hc005, asyncio.Event.__hash__.__class__.__name__.__eq__,           ["wrapper_descriptor"], true]
    - [as1336hc006, asyncio.Semaphore.__hash__.__class__.__name__.__eq__,       ["wrapper_descriptor"], true]

