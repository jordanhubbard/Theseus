spec: asyncio_extra1336
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
  notes:
    - "Wave 536 (_extra1336): focuses on __hash__ and __eq__ method checks for asyncio primitives."
    - "asyncio.Queue.__hash__.__class__.__name__ == 'wrapper_descriptor' — inherits object.__hash__, hashable by identity."
    - "asyncio.Future.__hash__.__class__.__name__ == 'wrapper_descriptor' — C-level slot from object."
    - "asyncio.Task.__hash__.__class__.__name__ == 'wrapper_descriptor' — inherits from Future via object.__hash__."
    - "asyncio.Lock.__hash__.__class__.__name__ == 'wrapper_descriptor' — lock primitives are hashable by identity."
    - "asyncio.Event.__hash__.__class__.__name__ == 'wrapper_descriptor' — event primitives are hashable by identity."
    - "asyncio.Semaphore.__hash__.__class__.__name__ == 'wrapper_descriptor' — semaphore inherits object.__hash__."
    - "All asyncio primitives inherit __eq__ from object — qualname is 'object.__eq__'."
    - "asyncio.Future.__eq__.__qualname__ == 'object.__eq__' — no custom equality defined."
    - "asyncio.Task.__eq__.__qualname__ == 'object.__eq__' — Task inherits equality from object."
    - "All __hash__.__qualname__ values are 'object.__hash__' — no asyncio class overrides __hash__."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

