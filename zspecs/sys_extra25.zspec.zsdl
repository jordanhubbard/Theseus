spec: sys_extra25
version: ">=3.9"
backend: python_module(sys)

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sys.html — Python sys module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/sysmodule.c"
    - "sys_extra8.zspec.zsdl — covers argv.__class__.__name__=='list'; prior specs cover __class__.__name__ for byteorder/path/builtin_module_names/prefix/exec_prefix/executable."
    - "sys_extra23.zspec.zsdl — covers argv.__class__.__qualname__=='list'; path.__class__.__qualname__=='list'; modules.__class__.__qualname__=='dict'."
    - "sys_extra24.zspec.zsdl — covers byteorder.__class__.__qualname__=='str'; flags.__class__.__qualname__=='flags'."
  notes:
    - "This spec extends sys.zspec.zsdl through sys_extra24.zspec.zsdl."
    - "Focus: __class__.__qualname__ for sys.builtin_module_names, sys.executable, sys.prefix, and sys.exec_prefix — none covered in any prior sys spec."
    - "sys_extra23 covers argv.__class__.__qualname__ and path.__class__.__qualname__ and modules.__class__.__qualname__. This spec fills the remaining __class__.__qualname__ gaps: builtin_module_names, executable, prefix, exec_prefix."
    - "sys.builtin_module_names.__class__.__qualname__ == 'tuple' — builtin_module_names is always a plain tuple; qualname of tuple is 'tuple'."
    - "sys.executable.__class__.__qualname__ == 'str' — executable is always a str; qualname of str is 'str'."
    - "sys.prefix.__class__.__qualname__ == 'str' — prefix is always a str; qualname of str is 'str'."
    - "sys.exec_prefix.__class__.__qualname__ == 'str' — exec_prefix is always a str; qualname of str is 'str'."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sys attribute __class__.__qualname__ table
#
# sys_extra23 covers argv/__class__/__qualname__, path/__class__/__qualname__,
# modules/__class__/__qualname__. sys_extra24 covers byteorder/__class__/
# __qualname__ and flags/__class__/__qualname__. This table covers the four
# remaining sys attributes whose __class__.__qualname__ has not been checked
# in any prior sys spec: builtin_module_names, executable, prefix, exec_prefix.
# ---------------------------------------------------------------------------

table sys_extra25.class_qualnames:
  description: "__class__.__qualname__ for sys.builtin_module_names, executable, prefix, exec_prefix"
  kind: python_call_eq
  category: type_attrs
  id_prefix: cqname25

  columns: [id, function, args, expected]
  rows:
    - [builtin_module_names, builtin_module_names.__class__.__qualname__.__eq__, ["tuple"], true]
    - [executable,           executable.__class__.__qualname__.__eq__,           ["str"],   true]
    - [prefix,               prefix.__class__.__qualname__.__eq__,               ["str"],   true]
    - [exec_prefix,          exec_prefix.__class__.__qualname__.__eq__,          ["str"],   true]

# ---------------------------------------------------------------------------
# sys.builtin_module_names — __class__.__qualname__ standalone
#
# builtin_module_names is always a plain tuple of built-in module name strings.
# sys_extra15 covers builtin_module_names.__class__.__name__ == 'tuple'.
# No prior sys spec covers builtin_module_names.__class__.__qualname__.
# ---------------------------------------------------------------------------

invariant sys_extra25.builtin_module_names.class_qualname:
  description: "sys.builtin_module_names.__class__.__qualname__ == 'tuple'"
  category: type_attrs
  kind: python_call_eq
  function: builtin_module_names.__class__.__qualname__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# sys.executable — __class__.__qualname__ standalone
#
# sys.executable is the path to the Python interpreter as a plain str.
# Prior specs cover executable.__class__.__name__ == 'str' (via table in
# sys_extra10). No prior sys spec covers executable.__class__.__qualname__.
# ---------------------------------------------------------------------------

invariant sys_extra25.executable.class_qualname:
  description: "sys.executable.__class__.__qualname__ == 'str'"
  category: type_attrs
  kind: python_call_eq
  function: executable.__class__.__qualname__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# sys.prefix — __class__.__qualname__ standalone
#
# sys.prefix is the installation prefix as a plain str.
# Prior specs cover prefix.__class__.__name__ == 'str' (sys_extra4/extra16).
# No prior sys spec covers prefix.__class__.__qualname__.
# ---------------------------------------------------------------------------

invariant sys_extra25.prefix.class_qualname:
  description: "sys.prefix.__class__.__qualname__ == 'str'"
  category: type_attrs
  kind: python_call_eq
  function: prefix.__class__.__qualname__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# sys.exec_prefix — __class__.__qualname__ standalone
#
# sys.exec_prefix is the platform-specific installation prefix as a plain str.
# Prior specs cover exec_prefix.__class__.__name__ == 'str' (sys_extra4/extra16).
# No prior sys spec covers exec_prefix.__class__.__qualname__.
# ---------------------------------------------------------------------------

invariant sys_extra25.exec_prefix.class_qualname:
  description: "sys.exec_prefix.__class__.__qualname__ == 'str'"
  category: type_attrs
  kind: python_call_eq
  function: exec_prefix.__class__.__qualname__.__eq__
  args: ["str"]
  expected: true
