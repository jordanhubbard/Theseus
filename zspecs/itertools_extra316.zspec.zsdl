spec: itertools_extra316
version: ">=3.0"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "itertools.tee is a builtin_function_or_method on Python 3.14, not a class; it has no __bases__."
    - "tee.__class__.__name__ == 'builtin_function_or_method'."
    - "tee.__name__ == 'tee', tee.__module__ == 'itertools'."
    - "zip_longest, product, permutations, combinations, combinations_with_replacement are C-level types (class 'type')."
    - "Doc lengths verified on Python 3.14.4: zip_longest=427, product=681, permutations=140, combinations=134, combinations_with_replacement=234, tee=43."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# tee — name, module, and class name
#
# itertools.tee is a builtin_function_or_method on Python 3.14.
# It has __name__ and __module__ but no __bases__.
# ---------------------------------------------------------------------------

invariant itertools_extra316.tee.name:
  description: "itertools.tee.__name__ == 'tee'"
  category: tee_identity
  kind: python_call_eq
  function: tee.__name__.__eq__
  args: ["tee"]
  expected: true

invariant itertools_extra316.tee.module:
  description: "itertools.tee.__module__ == 'itertools'"
  category: tee_identity
  kind: python_call_eq
  function: tee.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra316.tee.class_name:
  description: "itertools.tee.__class__.__name__ == 'builtin_function_or_method'"
  category: tee_identity
  kind: python_call_eq
  function: tee.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# __doc__ length checks
#
# These verify the exact byte-length of each C-level type's __doc__ string
# as observed on Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12.
#
# zip_longest : 427
# product     : 681
# permutations: 140
# combinations: 134
# combinations_with_replacement: 234
# tee         :  43
# ---------------------------------------------------------------------------

table itertools_extra316.doc_lengths:
  kind: python_call_eq
  category: doc_lengths
  id_prefix: doclen

  columns: [id, function, args, expected]
  rows:
    - [zip_longest,                   zip_longest.__doc__.__len__,                   [], 427]
    - [product,                       product.__doc__.__len__,                       [], 681]
    - [permutations,                  permutations.__doc__.__len__,                  [], 140]
    - [combinations,                  combinations.__doc__.__len__,                  [], 134]
    - [combinations_with_replacement, combinations_with_replacement.__doc__.__len__, [], 234]
    - [tee,                           tee.__doc__.__len__,                           [],  43]
