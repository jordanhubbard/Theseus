spec: hashlib_extra2161
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/hashlib.html"
    - "CPython source: Modules/_blake2/"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave _extra2161: descriptor protocol dict-presence — __get__, __set__, __delete__, __set_name__, fget, fset, fdel, __objclass__, __func__."
    - "hashlib.blake2b and hashlib.blake2s are C extension types (from _blake2). They are NOT descriptor classes themselves."
    - "Neither blake2b nor blake2s defines __get__, __set__, __delete__, __set_name__, fget, fset, fdel, __objclass__, or __func__ in its own __dict__."
    - "Both classes do contain getset_descriptor objects (name, block_size, digest_size) which are descriptors — but the CLASS itself is not a descriptor."
    - "Non-descriptor-protocol keys present in blake2b.__dict__: copy, digest, hexdigest, update, name, block_size, digest_size, SALT_SIZE, PERSON_SIZE, MAX_KEY_SIZE, MAX_DIGEST_SIZE, __new__, __doc__, __module__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table hashlib_extra2161.blake2b_descriptor_protocol:
  description: "hashlib.blake2b descriptor protocol dict-presence: __get__, __set__, __delete__, __set_name__ — blake2b is a C extension type, not a descriptor class"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2161

  columns: [id, function, args, expected]
  rows:
    - ["hl2161001", "hashlib.blake2b.__dict__.__contains__", ["__get__"], false]
    - ["hl2161002", "hashlib.blake2b.__dict__.__contains__", ["__set__"], false]
    - ["hl2161003", "hashlib.blake2b.__dict__.__contains__", ["__delete__"], false]
    - ["hl2161004", "hashlib.blake2b.__dict__.__contains__", ["__set_name__"], false]
    - ["hl2161005", "hashlib.blake2b.__dict__.__contains__", ["fget"], false]
    - ["hl2161006", "hashlib.blake2b.__dict__.__contains__", ["fset"], false]
    - ["hl2161007", "hashlib.blake2b.__dict__.__contains__", ["fdel"], false]
    - ["hl2161008", "hashlib.blake2b.__dict__.__contains__", ["__objclass__"], false]
    - ["hl2161009", "hashlib.blake2b.__dict__.__contains__", ["__func__"], false]

