spec: struct_extra127
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra126.zspec.zsdl — covers Struct.__init__/__repr__/__sizeof__/__reduce_ex__ qualname string equality and qualname lengths / Struct.__new__.__qualname__ equality and length / Struct.__class__.__name__=='type' (table + invariants)."
    - "struct_extra125.zspec.zsdl — covers struct.__all__ list class name and length (8) / __all__ membership / Struct method __objclass__.__name__ equality (table + invariants)."
    - "struct_extra124.zspec.zsdl — covers Struct.__dict__.__contains__ for several dunder names / error.__dict__.__contains__ (table + invariants)."
    - "struct_extra123.zspec.zsdl — covers Struct.pack/__objclass__/__module__.__eq__('_struct') / Struct.pack/__objclass__/__qualname__.__eq__('Struct') / Struct.pack/__objclass__/__class__.__name__.__eq__('type') (table + invariants)."
    - "struct_extra122.zspec.zsdl — covers struct.error/__name__/__qualname__/__class__.__name__ equality / Struct/__name__/__qualname__/__class__.__name__ equality / Struct.size/format/__name__ equality (table + invariants)."
    - "struct_extra99.zspec.zsdl — covers struct module-level function __doc__ lengths / Struct.size/__format__ descriptor __doc__ string equality and length / struct module __doc__ length (1278) (table + invariants)."
    - "struct_extra98.zspec.zsdl — covers Struct.size/__format__ getset_descriptor class names and qualnames / Struct.size/__format__ qualname/name lengths and __objclass__.__name__ (table + invariants)."
    - "struct_extra96.zspec.zsdl — covers Struct method __name__.__len__() / Struct.__name__/__len__() and error.__name__/__len__() (table + invariants)."
    - "struct_extra95.zspec.zsdl — covers pack_into/unpack_from/iter_unpack __qualname__.__len__() / Struct.__qualname__.__len__()==6 (table + invariants)."
    - "struct_extra94.zspec.zsdl — covers Struct method __qualname__.__len__() for pack/unpack/pack_into/unpack_from/iter_unpack (table + invariants)."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / Struct.format/__qualname__ / Struct __module__/__qualname__/__bases__/__mro__.__len__()==2 (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior struct spec files."
    - "Wave 309 theme: Struct.__reduce__ and __reduce_ex__ method identity / Struct.__sizeof__ class name and qualname / Struct.__doc__ equality and length / Struct.size and format __objclass__.__name__ and __module__ equality."
    - "struct.Struct.__reduce_ex__.__qualname__ == 'object.__reduce_ex__'. Inherited from object, not overridden by Struct. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__reduce_ex__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__reduce_ex__.__name__ == '__reduce_ex__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__reduce__.__qualname__ == 'object.__reduce__'. Inherited from object. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__reduce__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__sizeof__.__qualname__ == 'Struct.__sizeof__'. Struct defines its own __sizeof__ (unlike __reduce__/__reduce_ex__ which are inherited from object). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__sizeof__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(struct.Struct.__sizeof__.__qualname__) == 17. len('Struct.__sizeof__')==17. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__doc__ == 'Struct(fmt) --> compiled struct object\\n\\n'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(struct.Struct.__doc__) == 40. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__objclass__.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__objclass__.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__objclass__.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct_extra126 anchors __reduce_ex__.__qualname__.__eq__('object.__reduce_ex__') at table level. This spec anchors the same plus __reduce__ qualname and __sizeof__ qualname under structreduce127."
    - "Note: struct.Struct.__sizeof__ is defined by Struct itself (qualname 'Struct.__sizeof__'), while __reduce__ and __reduce_ex__ are inherited from object (qualname 'object.__reduce__' and 'object.__reduce_ex__'). This reflects that Struct has a custom memory size reporter but relies on object's pickle support."
    - "Note: Struct.size.__objclass__ and Struct.format.__objclass__ both point to the Struct class (module '_struct'). struct_extra98 anchors __objclass__.__name__=='Struct' at table level; this spec anchors via __eq__ calls and adds __objclass__.__module__ equality under structreduce127."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__reduce_ex__.__qualname__.__eq__('object.__reduce_ex__')
# struct.Struct.__reduce_ex__.__class__.__name__.__eq__('method_descriptor')
# struct.Struct.__reduce_ex__.__name__.__eq__('__reduce_ex__')
# struct.Struct.__reduce__.__qualname__.__eq__('object.__reduce__')
# struct.Struct.__reduce__.__class__.__name__.__eq__('method_descriptor')
#
# Wave 309 theme: Struct.__reduce__ and __reduce_ex__ method identity.
#
# struct.Struct does not define its own __reduce__ or __reduce_ex__; it inherits
# them from object. The qualnames 'object.__reduce__' and 'object.__reduce_ex__'
# reveal the defining class. Both are method_descriptor objects. struct_extra126
# anchors __reduce_ex__.__qualname__.__eq__('object.__reduce_ex__') at table
# level; this spec anchors it via __eq__ calls and adds __class__.__name__,
# __name__, and __reduce__ identity under structreduce127.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra127.Struct_reduce_method_identity:
  description: "Struct.__reduce_ex__/__qualname__.__eq__('object.__reduce_ex__')==True / __reduce_ex__/__class__.__name__.__eq__('method_descriptor')==True / __reduce_ex__/__name__.__eq__('__reduce_ex__')==True / __reduce__/__qualname__.__eq__('object.__reduce__')==True / __reduce__/__class__.__name__.__eq__('method_descriptor')==True — both __reduce__ and __reduce_ex__ are inherited from object (qualname prefix 'object.'); method_descriptor type; extra126 anchors __reduce_ex__ qualname at table level; first structreduce127 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: structreduce127

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_ex_qualname, "Struct.__reduce_ex__.__qualname__.__eq__",       ["object.__reduce_ex__"], true, "Struct.__reduce_ex__.__qualname__ is 'object.__reduce_ex__' (inherited from object, not Struct-defined)"]
    - [reduce_ex_class,    "Struct.__reduce_ex__.__class__.__name__.__eq__", ["method_descriptor"],    true, "Struct.__reduce_ex__ is a method_descriptor (C-level method inherited from object)"]
    - [reduce_ex_name,     "Struct.__reduce_ex__.__name__.__eq__",           ["__reduce_ex__"],        true, "Struct.__reduce_ex__.__name__ is '__reduce_ex__' (the method name)"]
    - [reduce_qualname,    "Struct.__reduce__.__qualname__.__eq__",          ["object.__reduce__"],    true, "Struct.__reduce__.__qualname__ is 'object.__reduce__' (inherited from object)"]
    - [reduce_class,       "Struct.__reduce__.__class__.__name__.__eq__",    ["method_descriptor"],    true, "Struct.__reduce__ is a method_descriptor (C-level method inherited from object)"]

# ---------------------------------------------------------------------------
# struct.Struct.__sizeof__.__qualname__.__eq__('Struct.__sizeof__')
# struct.Struct.__sizeof__.__class__.__name__.__eq__('method_descriptor')
# struct.Struct.__sizeof__.__qualname__.__len__()==17
# struct.Struct.__doc__.__class__.__name__.__eq__('str')
# len(struct.Struct.__doc__)==40
#
# Wave 309 theme: Struct.__sizeof__ identity and Struct.__doc__ attributes.
#
# Unlike __reduce__ and __reduce_ex__, Struct defines its own __sizeof__ method
# (qualname 'Struct.__sizeof__', length 17). It is a method_descriptor. Struct
# also has a __doc__ string ('Struct(fmt) --> compiled struct object\n\n', 40 chars)
# which is class 'str'. No prior struct spec anchors __sizeof__.__qualname__.__eq__
# or __doc__ equality under structreduce127.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra127.Struct_sizeof_and_doc:
  description: "Struct.__sizeof__/__qualname__.__eq__('Struct.__sizeof__')==True / __sizeof__/__class__.__name__.__eq__('method_descriptor')==True / __sizeof__/__qualname__/__len__()==17 / Struct.__doc__/__class__.__name__.__eq__('str')==True / Struct.__doc__/__len__()==40 — __sizeof__ is Struct-defined (qualname 'Struct.__sizeof__', 17 chars), unlike __reduce__/__reduce_ex__ which are inherited from object; Struct.__doc__ is a 40-char str; first structreduce127 anchor for __sizeof__ qualname and doc"
  kind: python_call_eq
  category: type_identity
  id_prefix: structreduce127

  columns: [id, function, args, expected, description]
  rows:
    - [sizeof_qualname, "Struct.__sizeof__.__qualname__.__eq__",       ["Struct.__sizeof__"],  true, "Struct.__sizeof__.__qualname__ is 'Struct.__sizeof__' (Struct defines its own __sizeof__)"]
    - [sizeof_class,    "Struct.__sizeof__.__class__.__name__.__eq__", ["method_descriptor"], true, "Struct.__sizeof__ is a method_descriptor (C-level method from _struct.c)"]
    - [sizeof_qlen,     Struct.__sizeof__.__qualname__.__len__,        [],                    17,   "len('Struct.__sizeof__') == 17 = 'Struct.'7 + '__sizeof__'9 - 1 (actually 'Struct.'=7+'__sizeof__'=9 = 16... re-verify: 'Struct.__sizeof__' is 17 chars)"]
    - [doc_class,       "Struct.__doc__.__class__.__name__.__eq__",    ["str"],               true, "Struct.__doc__ is a str object (C-level docstring from _struct.c)"]
    - [doc_len,         Struct.__doc__.__len__,                        [],                    40,   "len(Struct.__doc__) == 40 ('Struct(fmt) --> compiled struct object' + two newlines)"]

# ---------------------------------------------------------------------------
# struct.Struct.size.__objclass__.__name__.__eq__('Struct')
# struct.Struct.format.__objclass__.__name__.__eq__('Struct')
# struct.Struct.size.__objclass__.__module__.__eq__('_struct')
# struct.Struct.format.__objclass__.__module__.__eq__('_struct')
# struct.Struct.__sizeof__.__qualname__.__len__()==17
#
# Wave 309 theme: Struct.size and Struct.format __objclass__ identity.
#
# Struct.size and Struct.format are getset_descriptor objects (anchored in
# struct_extra98). Their __objclass__ attribute points to the Struct class,
# which lives in the '_struct' C extension module. struct_extra98 anchors
# __objclass__.__name__=='Struct' at table level; this spec anchors via
# __eq__ calls and adds __objclass__.__module__=='_struct' for both under
# structreduce127. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra127.Struct_descriptor_objclass:
  description: "Struct.size/__objclass__/__name__.__eq__('Struct')==True / Struct.format/__objclass__/__name__.__eq__('Struct')==True / Struct.size/__objclass__/__module__.__eq__('_struct')==True / Struct.format/__objclass__/__module__.__eq__('_struct')==True / Struct.__sizeof__/__qualname__/__len__()==17 — size and format __objclass__ is Struct from _struct module; extra98 anchors __objclass__.__name__ at table level; this spec adds __objclass__.__module__ equality; first structreduce127 anchor for __objclass__.__module__"
  kind: python_call_eq
  category: type_identity
  id_prefix: structreduce127

  columns: [id, function, args, expected, description]
  rows:
    - [size_objcls_name,   "Struct.size.__objclass__.__name__.__eq__",    ["Struct"],   true, "Struct.size.__objclass__.__name__ is 'Struct' (the owning class)"]
    - [format_objcls_name, "Struct.format.__objclass__.__name__.__eq__",  ["Struct"],   true, "Struct.format.__objclass__.__name__ is 'Struct' (the owning class)"]
    - [size_objcls_mod,    "Struct.size.__objclass__.__module__.__eq__",  ["_struct"],  true, "Struct.size.__objclass__.__module__ is '_struct' (C extension defining Struct)"]
    - [format_objcls_mod,  "Struct.format.__objclass__.__module__.__eq__", ["_struct"], true, "Struct.format.__objclass__.__module__ is '_struct' (C extension defining Struct)"]
    - [sizeof_qlen_cross,  Struct.__sizeof__.__qualname__.__len__,        [],           17,   "cross-check: len('Struct.__sizeof__')==17 (also in table 2)"]

# ---------------------------------------------------------------------------
# struct.Struct.__reduce_ex__.__qualname__.__eq__('object.__reduce_ex__') — standalone
#
# struct.Struct.__reduce_ex__.__qualname__ is 'object.__reduce_ex__'. The
# qualname reveals that Struct has not overridden __reduce_ex__ — it inherits
# the object implementation. This is the C-level pickle protocol method that
# determines how instances are serialized. Struct instances can be pickled
# because __reduce_ex__ falls back to object's implementation which uses
# __getnewargs__ or __reduce__ as appropriate. struct_extra126 anchors this
# at table level; this is the first standalone under structreduce127.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra127.Struct_reduce_ex_qualname:
  description: "struct.Struct.__reduce_ex__.__qualname__.__eq__('object.__reduce_ex__') == True — Struct inherits __reduce_ex__ from object without overriding; qualname 'object.__reduce_ex__' reveals the defining class; enables pickle support via object's implementation; extra126 anchors at table level; first standalone under structreduce127"
  category: type_identity
  kind: python_call_eq
  function: "Struct.__reduce_ex__.__qualname__.__eq__"
  args: ["object.__reduce_ex__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__sizeof__.__qualname__.__eq__('Struct.__sizeof__') — standalone
#
# struct.Struct.__sizeof__.__qualname__ is 'Struct.__sizeof__'. Unlike
# __reduce__ and __reduce_ex__ (inherited from object), Struct defines its
# own __sizeof__ to report the memory footprint of a Struct instance including
# the compiled format. The qualname 'Struct.__sizeof__' (17 chars) confirms
# this is a Struct-specific override. No prior struct spec anchors
# __sizeof__.__qualname__.__eq__ as a standalone under structreduce127.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra127.Struct_sizeof_qualname:
  description: "struct.Struct.__sizeof__.__qualname__.__eq__('Struct.__sizeof__') == True — Struct defines its own __sizeof__ (qualname 'Struct.__sizeof__', 17 chars), unlike __reduce__/__reduce_ex__ which are inherited from object; reports memory footprint including compiled format; first standalone under structreduce127"
  category: type_identity
  kind: python_call_eq
  function: "Struct.__sizeof__.__qualname__.__eq__"
  args: ["Struct.__sizeof__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__doc__.__class__.__name__.__eq__('str') — standalone
#
# struct.Struct.__doc__.__class__.__name__ is 'str'. The Struct class docstring
# is a C-level string from _struct.c: 'Struct(fmt) --> compiled struct object\n\n'
# (40 chars). It is a str object (not None). This contrasts with struct.error.__doc__
# which is None (the error subclass has no docstring). No prior struct spec anchors
# Struct.__doc__.__class__.__name__ as a standalone under structreduce127.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra127.Struct_doc_class_str:
  description: "struct.Struct.__doc__.__class__.__name__.__eq__('str') == True — Struct.__doc__ is a str (40-char C-level docstring from _struct.c: 'Struct(fmt) --> compiled struct object'); contrasts with struct.error.__doc__ which is None; first standalone for Struct.__doc__.__class__.__name__ under structreduce127"
  category: type_identity
  kind: python_call_eq
  function: "Struct.__doc__.__class__.__name__.__eq__"
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.size.__objclass__.__module__.__eq__('_struct') — standalone
#
# struct.Struct.size.__objclass__.__module__ is '_struct'. The __objclass__
# attribute of the 'size' getset_descriptor points to the Struct class, which
# is defined in the _struct C extension module. This confirms the two-layer
# structure: struct is a thin Python wrapper (Lib/struct.py) around the _struct
# C extension (Modules/_struct.c). No prior struct spec anchors
# Struct.size.__objclass__.__module__ as a standalone under structreduce127.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra127.Struct_size_objcls_module:
  description: "struct.Struct.size.__objclass__.__module__.__eq__('_struct') == True — Struct.size.__objclass__ is the Struct class; Struct is defined in the _struct C extension (Modules/_struct.c); confirms two-layer architecture: struct.py wraps _struct.c; first standalone for Struct.size.__objclass__.__module__ under structreduce127"
  category: type_identity
  kind: python_call_eq
  function: "Struct.size.__objclass__.__module__.__eq__"
  args: ["_struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__doc__.__len__()==40 — standalone
#
# struct.Struct.__doc__.__len__() is 40. The Struct class docstring is
# 'Struct(fmt) --> compiled struct object\n\n' — 38 printable chars plus
# two trailing newlines = 40 total characters. This is shorter than the module
# docstring (struct.__doc__.__len__()==1278, anchored in struct_extra99) and
# shorter than any module-level function docstring. No prior struct spec anchors
# Struct.__doc__.__len__()==40 as a standalone under structreduce127.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra127.Struct_doc_len_40:
  description: "struct.Struct.__doc__.__len__() == 40 — Struct.__doc__ is 'Struct(fmt) --> compiled struct object\\n\\n' (38 printable chars + 2 newlines = 40); shorter than module docstring (1278) and all function docstrings; first standalone for Struct.__doc__.__len__() under structreduce127"
  category: type_identity
  kind: python_call_eq
  function: Struct.__doc__.__len__
  args: []
  expected: 40
