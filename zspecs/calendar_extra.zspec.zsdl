spec: calendar_extra
version: ">=3.2"
backend: python_module(calendar)

docs: https://docs.python.org/3/library/calendar.html

provenance:
  derived_from:
    - "Python calendar documentation — https://docs.python.org/3/library/calendar.html"
    - "Test vectors verified by running Python 3.14.3 calendar module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/calendar.py"
  notes:
    - "This spec covers class identity and additional invariants not present in calendar.zspec.zsdl."
    - "Calendar is the base class for all calendar formatters; TextCalendar and HTMLCalendar both inherit from it."
    - "TextCalendar.__bases__[0].__name__ == 'Calendar' — direct base is Calendar."
    - "HTMLCalendar.__bases__[0].__name__ == 'Calendar' — direct base is Calendar."
    - "isleap is a module-level function; isleap.__name__ == 'isleap'."
    - "leapdays(2000, 2024) counts leap years in [2000, 2024) — exclusive upper bound — yielding 2000,2004,2008,2012,2016,2020 = 6."
    - "month_name is an instance of _localized_month, a private sequence class."
    - "weekheader(n) returns a string of day abbreviations each n characters wide."
    - "MONDAY == 0 and SUNDAY == 6 are also covered in calendar.zspec.zsdl; repeated here per task specification."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Calendar base class — name and module
# ---------------------------------------------------------------------------

invariant calendar_extra.calendar_class.name:
  description: "calendar.Calendar.__name__ == 'Calendar'"
  category: calendar_class
  kind: python_call_eq
  function: Calendar.__name__.__eq__
  args: ["Calendar"]
  expected: true

invariant calendar_extra.calendar_class.module:
  description: "calendar.Calendar.__module__ == 'calendar'"
  category: calendar_class
  kind: python_call_eq
  function: Calendar.__module__.__eq__
  args: ["calendar"]
  expected: true

# ---------------------------------------------------------------------------
# TextCalendar — name and base class
# ---------------------------------------------------------------------------

invariant calendar_extra.text_calendar.name:
  description: "calendar.TextCalendar.__name__ == 'TextCalendar'"
  category: text_calendar
  kind: python_call_eq
  function: TextCalendar.__name__.__eq__
  args: ["TextCalendar"]
  expected: true

invariant calendar_extra.text_calendar.base:
  description: "calendar.TextCalendar.__bases__[0].__name__ == 'Calendar'"
  category: text_calendar
  kind: python_call_eq
  function: TextCalendar.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Calendar"

# ---------------------------------------------------------------------------
# HTMLCalendar — name and base class
# ---------------------------------------------------------------------------

invariant calendar_extra.html_calendar.name:
  description: "calendar.HTMLCalendar.__name__ == 'HTMLCalendar'"
  category: html_calendar
  kind: python_call_eq
  function: HTMLCalendar.__name__.__eq__
  args: ["HTMLCalendar"]
  expected: true

invariant calendar_extra.html_calendar.base:
  description: "calendar.HTMLCalendar.__bases__[0].__name__ == 'Calendar'"
  category: html_calendar
  kind: python_call_eq
  function: HTMLCalendar.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Calendar"

# ---------------------------------------------------------------------------
# isleap — function identity and correctness
# ---------------------------------------------------------------------------

invariant calendar_extra.isleap.function_name:
  description: "calendar.isleap.__name__ == 'isleap'"
  category: isleap
  kind: python_call_eq
  function: isleap.__name__.__eq__
  args: ["isleap"]
  expected: true

invariant calendar_extra.isleap.year_2000:
  description: "calendar.isleap(2000) == True — 2000 is divisible by 400"
  category: isleap
  kind: python_call_eq
  function: isleap
  args: [2000]
  expected: true

invariant calendar_extra.isleap.year_1900:
  description: "calendar.isleap(1900) == False — 1900 is divisible by 100 but not 400"
  category: isleap
  kind: python_call_eq
  function: isleap
  args: [1900]
  expected: false

invariant calendar_extra.isleap.year_2024:
  description: "calendar.isleap(2024) == True — 2024 is divisible by 4 but not 100"
  category: isleap
  kind: python_call_eq
  function: isleap
  args: [2024]
  expected: true

# ---------------------------------------------------------------------------
# leapdays — count of leap years in [y1, y2) with exclusive upper bound
#
# leapdays(2000, 2024): leap years are 2000,2004,2008,2012,2016,2020 = 6
# (2024 is excluded because the upper bound is exclusive)
# ---------------------------------------------------------------------------

invariant calendar_extra.leapdays.2000_to_2024:
  description: "calendar.leapdays(2000, 2024) == 6 — leap years 2000,2004,2008,2012,2016,2020 (2024 excluded)"
  category: leapdays
  kind: python_call_eq
  function: leapdays
  args: [2000, 2024]
  expected: 6

# ---------------------------------------------------------------------------
# month_name — class identity of the sequence object
# ---------------------------------------------------------------------------

invariant calendar_extra.month_name.class_name:
  description: "calendar.month_name.__class__.__name__ == '_localized_month'"
  category: month_name
  kind: python_call_eq
  function: month_name.__class__.__name__.__eq__
  args: ["_localized_month"]
  expected: true

# ---------------------------------------------------------------------------
# weekheader — returns a str containing column headers for a week
# ---------------------------------------------------------------------------

invariant calendar_extra.weekheader.returns_str:
  description: "calendar.weekheader(2).__class__.__name__ == 'str'"
  category: weekheader
  kind: python_call_eq
  function: weekheader
  args: [2]
  method: __class__
  method_chain: __name__
  method_chain_args: []
  expected: "str"

# ---------------------------------------------------------------------------
# Constants — MONDAY and SUNDAY
# ---------------------------------------------------------------------------

invariant calendar_extra.constants.MONDAY:
  description: "calendar.MONDAY == 0"
  category: constants
  kind: python_call_eq
  function: MONDAY.__eq__
  args: [0]
  expected: true

invariant calendar_extra.constants.SUNDAY:
  description: "calendar.SUNDAY == 6"
  category: constants
  kind: python_call_eq
  function: SUNDAY.__eq__
  args: [6]
  expected: true
