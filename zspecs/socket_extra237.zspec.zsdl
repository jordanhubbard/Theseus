spec: socket_extra237
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html
rfcs:
  - "RFC 791 — Internet Protocol"
  - "RFC 4291 — IP Version 6 Addressing Architecture"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "RFC 791 — Internet Protocol (AF_INET address family)"
    - "RFC 4291 — IP Version 6 Addressing Architecture (AF_INET6 address family)"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
    - "socket_extra236.zspec.zsdl — covers inet_pton/inet_ntop IPv4 address contracts"
    - "socket_extra235.zspec.zsdl — covers ntohs/htons/ntohl/htonl function name and round-trip contracts"
    - "socket_extra234.zspec.zsdl — covers AF_UNIX, AddressFamily, SocketKind class identity contracts"
    - "socket_extra233.zspec.zsdl — covers getdefaulttimeout/__doc__/__contains__ and setdefaulttimeout contracts"
    - "socket_extra232.zspec.zsdl — covers socket module identity contracts"
    - "_socket_extra.zspec.zsdl — covers _socket C extension identity"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.AF_INET == 2 — address family for IPv4; value 2 on both macOS and Linux."
    - "socket.AF_INET6 == 30 — address family for IPv6; value 30 on macOS (Darwin); Linux uses 10."
    - "socket.SOCK_STREAM == 1 — socket type for TCP (connection-oriented reliable streams)."
    - "socket.SOCK_DGRAM == 2 — socket type for UDP (connectionless datagrams)."
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily' — AF_INET is an IntEnum member."
    - "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' — SOCK_STREAM is an IntEnum member."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.AF_INET and socket.AF_INET6 constant identity contracts
#
# socket.AF_INET.__eq__(2)   == True   (IPv4 address family, value 2 universally)
# socket.AF_INET6.__eq__(30) == True   (IPv6 address family, value 30 on macOS/Darwin)
# socket.AF_INET.__class__.__name__.__eq__("AddressFamily") == True
#
# AF_INET and AF_INET6 are members of the socket.AddressFamily IntEnum.
# AF_INET == 2 is consistent across POSIX platforms.
# AF_INET6 == 30 is specific to macOS/Darwin (Linux uses 10).
# Novel to socket_extra237: no prior socket spec anchors AF_INET/AF_INET6 int values.
# ---------------------------------------------------------------------------

table socket_extra237.address_family_value_contracts:
  description: "AF_INET.__eq__(2)==True; AF_INET6.__eq__(30)==True; AF_INET class is AddressFamily; socket address family integer value contracts; new to socket_extra237"
  kind: python_call_eq
  category: constants
  id_prefix: socket237af

  columns: [id, function, args, expected, description]
  rows:
    - [af_inet_value_eq_2,
       AF_INET.__eq__,
       [2],
       true,
       "socket.AF_INET.__eq__(2) == True — AF_INET (IPv4 address family) has integer value 2 on macOS/Darwin and all POSIX platforms; AF_INET is a member of socket.AddressFamily IntEnum; value 2 is defined by POSIX; novel AF_INET value anchor; new to socket_extra237 namespace; verified Python 3.14.3"]
    - [af_inet6_value_eq_30,
       AF_INET6.__eq__,
       [30],
       true,
       "socket.AF_INET6.__eq__(30) == True — AF_INET6 (IPv6 address family) has integer value 30 on macOS/Darwin; this is platform-specific (Linux uses 10); AF_INET6 is a member of socket.AddressFamily IntEnum; novel AF_INET6 value anchor for macOS; new to socket_extra237 namespace; verified Python 3.14.3"]
    - [af_inet_class_name_eq,
       AF_INET.__class__.__name__.__eq__,
       ["AddressFamily"],
       true,
       "socket.AF_INET.__class__.__name__.__eq__('AddressFamily') == True — AF_INET is an instance of socket.AddressFamily which is an IntEnum subclass; __class__.__name__ is 'AddressFamily'; novel AF_INET class name anchor; new to socket_extra237 namespace; verified Python 3.14.3"]
    - [af_inet6_class_name_eq,
       AF_INET6.__class__.__name__.__eq__,
       ["AddressFamily"],
       true,
       "socket.AF_INET6.__class__.__name__.__eq__('AddressFamily') == True — AF_INET6 is an instance of socket.AddressFamily IntEnum; __class__.__name__ is 'AddressFamily'; both AF_INET and AF_INET6 share the AddressFamily enum class; novel AF_INET6 class name anchor; new to socket_extra237 namespace; verified Python 3.14.3"]
    - [af_inet_int_eq,
       AF_INET.__int__,
       [],
       2,
       "socket.AF_INET.__int__() == 2 — AF_INET as an IntEnum member converts to integer 2 via __int__(); consistent with __eq__(2); novel AF_INET __int__ anchor; new to socket_extra237 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# socket.SOCK_STREAM and socket.SOCK_DGRAM constant identity contracts
#
# socket.SOCK_STREAM.__eq__(1) == True  (TCP-style reliable stream socket)
# socket.SOCK_DGRAM.__eq__(2)  == True  (UDP-style datagram socket)
# socket.SOCK_STREAM.__class__.__name__.__eq__("SocketKind") == True
#
# SOCK_STREAM and SOCK_DGRAM are members of the socket.SocketKind IntEnum.
# These values (1 and 2) are consistent across all POSIX platforms.
# Novel to socket_extra237.
# ---------------------------------------------------------------------------

table socket_extra237.socket_kind_value_contracts:
  description: "SOCK_STREAM.__eq__(1)==True; SOCK_DGRAM.__eq__(2)==True; SOCK_STREAM class is SocketKind; socket type integer value contracts; new to socket_extra237"
  kind: python_call_eq
  category: constants
  id_prefix: socket237sock

  columns: [id, function, args, expected, description]
  rows:
    - [sock_stream_value_eq_1,
       SOCK_STREAM.__eq__,
       [1],
       true,
       "socket.SOCK_STREAM.__eq__(1) == True — SOCK_STREAM (connection-oriented reliable stream socket, used for TCP) has integer value 1 on all POSIX platforms; SOCK_STREAM is a member of socket.SocketKind IntEnum; novel SOCK_STREAM value anchor; new to socket_extra237 namespace; verified Python 3.14.3"]
    - [sock_dgram_value_eq_2,
       SOCK_DGRAM.__eq__,
       [2],
       true,
       "socket.SOCK_DGRAM.__eq__(2) == True — SOCK_DGRAM (connectionless datagram socket, used for UDP) has integer value 2 on all POSIX platforms; SOCK_DGRAM is a member of socket.SocketKind IntEnum; novel SOCK_DGRAM value anchor; new to socket_extra237 namespace; verified Python 3.14.3"]
    - [sock_stream_class_name_eq,
       SOCK_STREAM.__class__.__name__.__eq__,
       ["SocketKind"],
       true,
       "socket.SOCK_STREAM.__class__.__name__.__eq__('SocketKind') == True — SOCK_STREAM is an instance of socket.SocketKind IntEnum; __class__.__name__ is 'SocketKind'; novel SOCK_STREAM class name anchor; new to socket_extra237 namespace; verified Python 3.14.3"]
    - [sock_dgram_class_name_eq,
       SOCK_DGRAM.__class__.__name__.__eq__,
       ["SocketKind"],
       true,
       "socket.SOCK_DGRAM.__class__.__name__.__eq__('SocketKind') == True — SOCK_DGRAM is an instance of socket.SocketKind IntEnum; __class__.__name__ is 'SocketKind'; both SOCK_STREAM and SOCK_DGRAM share the SocketKind enum class; novel SOCK_DGRAM class name anchor; new to socket_extra237 namespace; verified Python 3.14.3"]
    - [sock_stream_int_eq,
       SOCK_STREAM.__int__,
       [],
       1,
       "socket.SOCK_STREAM.__int__() == 1 — SOCK_STREAM as an IntEnum member converts to integer 1 via __int__(); consistent with __eq__(1); novel SOCK_STREAM __int__ anchor; new to socket_extra237 namespace; verified Python 3.14.3"]
    - [sock_dgram_int_eq,
       SOCK_DGRAM.__int__,
       [],
       2,
       "socket.SOCK_DGRAM.__int__() == 2 — SOCK_DGRAM as an IntEnum member converts to integer 2 via __int__(); consistent with __eq__(2); novel SOCK_DGRAM __int__ anchor; new to socket_extra237 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# socket constant .name attribute contracts
#
# socket.AF_INET.name      == 'AF_INET'
# socket.AF_INET6.name     == 'AF_INET6'
# socket.SOCK_STREAM.name  == 'SOCK_STREAM'
# socket.SOCK_DGRAM.name   == 'SOCK_DGRAM'
#
# IntEnum members have a .name attribute returning the enum member name as a
# string. Novel to socket_extra237.
# ---------------------------------------------------------------------------

table socket_extra237.constant_name_contracts:
  description: "AF_INET.name=='AF_INET'; AF_INET6.name=='AF_INET6'; SOCK_STREAM.name=='SOCK_STREAM'; SOCK_DGRAM.name=='SOCK_DGRAM'; socket constant name attribute contracts; new to socket_extra237"
  kind: python_call_eq
  category: constant_names
  id_prefix: socket237n

  columns: [id, function, args, expected, description]
  rows:
    - [af_inet_name_eq,
       AF_INET.name.__eq__,
       ["AF_INET"],
       true,
       "socket.AF_INET.name.__eq__('AF_INET') == True — the .name attribute of IntEnum member AF_INET returns the string 'AF_INET'; novel AF_INET.name anchor; new to socket_extra237 namespace; verified Python 3.14.3"]
    - [af_inet6_name_eq,
       AF_INET6.name.__eq__,
       ["AF_INET6"],
       true,
       "socket.AF_INET6.name.__eq__('AF_INET6') == True — the .name attribute of IntEnum member AF_INET6 returns the string 'AF_INET6'; novel AF_INET6.name anchor; new to socket_extra237 namespace; verified Python 3.14.3"]
    - [sock_stream_name_eq,
       SOCK_STREAM.name.__eq__,
       ["SOCK_STREAM"],
       true,
       "socket.SOCK_STREAM.name.__eq__('SOCK_STREAM') == True — the .name attribute of IntEnum member SOCK_STREAM returns the string 'SOCK_STREAM'; novel SOCK_STREAM.name anchor; new to socket_extra237 namespace; verified Python 3.14.3"]
    - [sock_dgram_name_eq,
       SOCK_DGRAM.name.__eq__,
       ["SOCK_DGRAM"],
       true,
       "socket.SOCK_DGRAM.name.__eq__('SOCK_DGRAM') == True — the .name attribute of IntEnum member SOCK_DGRAM returns the string 'SOCK_DGRAM'; novel SOCK_DGRAM.name anchor; new to socket_extra237 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant socket_extra237.af_inet_value_2:
  description: "socket.AF_INET.__eq__(2) == True — AF_INET is the address family constant for IPv4 (Internet Protocol version 4); it has integer value 2 which is defined by POSIX and consistent across all Unix-like platforms including macOS and Linux; AF_INET is used as the first argument to socket.socket() to create an IPv4 socket; as a socket.AddressFamily IntEnum member, it compares equal to the integer 2 via __eq__; no prior socket spec anchors the integer value of AF_INET; socket_extra237 is the first namespace to record this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: constants
  kind: python_call_eq
  function: AF_INET.__eq__
  args: [2]
  expected: true

invariant socket_extra237.af_inet6_value_30:
  description: "socket.AF_INET6.__eq__(30) == True — AF_INET6 is the address family constant for IPv6 (Internet Protocol version 6); on macOS/Darwin it has integer value 30 (Linux uses value 10); the divergence is a platform ABI difference; AF_INET6 is a socket.AddressFamily IntEnum member; it is used as the first argument to socket.socket() to create an IPv6 socket; this spec is specific to macOS/Darwin 25.4.0; no prior socket spec anchors the integer value of AF_INET6 on macOS; socket_extra237 is the first namespace to record this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: constants
  kind: python_call_eq
  function: AF_INET6.__eq__
  args: [30]
  expected: true

invariant socket_extra237.sock_stream_value_1:
  description: "socket.SOCK_STREAM.__eq__(1) == True — SOCK_STREAM is the socket type constant for connection-oriented reliable byte stream sockets (used with TCP); it has integer value 1 on all POSIX platforms; SOCK_STREAM is a socket.SocketKind IntEnum member; it is used as the second argument to socket.socket() to create a TCP socket; no prior socket spec anchors the integer value of SOCK_STREAM; socket_extra237 is the first namespace to record this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: constants
  kind: python_call_eq
  function: SOCK_STREAM.__eq__
  args: [1]
  expected: true

invariant socket_extra237.sock_dgram_value_2:
  description: "socket.SOCK_DGRAM.__eq__(2) == True — SOCK_DGRAM is the socket type constant for connectionless datagram sockets (used with UDP); it has integer value 2 on all POSIX platforms; SOCK_DGRAM is a socket.SocketKind IntEnum member; it is used as the second argument to socket.socket() to create a UDP socket; no prior socket spec anchors the integer value of SOCK_DGRAM; socket_extra237 is the first namespace to record this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: constants
  kind: python_call_eq
  function: SOCK_DGRAM.__eq__
  args: [2]
  expected: true

invariant socket_extra237.af_inet_class_name:
  description: "socket.AF_INET.__class__.__name__.__eq__('AddressFamily') == True — AF_INET is an instance of socket.AddressFamily which is an IntEnum subclass introduced in Python 3.4; __class__.__name__ returns 'AddressFamily' confirming the type; AddressFamily wraps the integer address family constants providing named access; this confirms AF_INET is an enum member not a plain integer; no prior socket spec anchors AF_INET.__class__.__name__; socket_extra237 is the first namespace to record this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: constants
  kind: python_call_eq
  function: AF_INET.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

invariant socket_extra237.sock_stream_class_name:
  description: "socket.SOCK_STREAM.__class__.__name__.__eq__('SocketKind') == True — SOCK_STREAM is an instance of socket.SocketKind which is an IntEnum subclass introduced in Python 3.4; __class__.__name__ returns 'SocketKind' confirming the type; SocketKind wraps the integer socket type constants providing named access; this confirms SOCK_STREAM is an enum member not a plain integer; no prior socket spec anchors SOCK_STREAM.__class__.__name__; socket_extra237 is the first namespace to record this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: constants
  kind: python_call_eq
  function: SOCK_STREAM.__class__.__name__.__eq__
  args: ["SocketKind"]
  expected: true
