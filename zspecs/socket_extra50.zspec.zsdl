spec: socket_extra50
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra49.zspec.zsdl — covers gethostname/gethostbyname/getaddrinfo/getfqdn/module __doc__.__class__.__name__.__eq__('str'), module __doc__.__class__.__qualname__/__module__, and socket.socket.connect/bind/listen/accept/send/recv/close __qualname__.__len__()."
    - "socket_extra48.zspec.zsdl — covers herror/gaierror/timeout __bases__[0].__qualname__.__eq__('OSError') and herror/gaierror/timeout/socket __doc__.__class__.__name__.__eq__('str')."
    - "socket_extra47.zspec.zsdl — covers socket/herror/gaierror/timeout __class__.__qualname__.__eq__('type'), gethostname/gethostbyname __class__.__qualname__.__eq__('builtin_function_or_method'), getaddrinfo/getfqdn __class__.__qualname__.__eq__('function'), socket/gethostname/getaddrinfo __class__.__module__.__eq__('builtins')."
    - "socket_extra25.zspec.zsdl — covers herror/gaierror/__module__.__eq__('socket'), timeout/__module__.__eq__('builtins')."
    - "socket_extra26.zspec.zsdl — covers timeout/herror/gaierror/__bases__[0].__name__.__eq__('OSError') and socket.socket/__init__.__name__."
  notes:
    - "This spec extends socket through socket_extra49; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: No prior socket spec checks socket.socket method __qualname__.__eq__ string values. socket_extra49 covers __qualname__.__len__() for connect/bind/listen/accept/send/recv/close (length axis). The complementary string equality via __qualname__.__eq__ is a distinct axis: it confirms the exact method qualname string rather than just its length. socket.socket class methods have __qualname__ of the form 'socket.<method>' where 'socket' is the class name. No prior spec checks __qualname__.__eq__ for any socket.socket method. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.connect.__qualname__ == 'socket.connect'. The connect method descriptor's __qualname__ is 'socket.connect' (14 chars; length verified in extra49). No prior spec checks connect.__qualname__.__eq__('socket.connect'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.bind.__qualname__ == 'socket.bind'. The bind method descriptor's __qualname__ is 'socket.bind' (11 chars). No prior spec checks bind.__qualname__.__eq__('socket.bind'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.listen.__qualname__ == 'socket.listen'. The listen method descriptor's __qualname__ is 'socket.listen' (13 chars). No prior spec checks listen.__qualname__.__eq__('socket.listen'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__qualname__ == 'socket.accept'. The accept method descriptor's __qualname__ is 'socket.accept' (13 chars). No prior spec checks accept.__qualname__.__eq__('socket.accept'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.send.__qualname__ == 'socket.send'. The send method descriptor's __qualname__ is 'socket.send' (11 chars). No prior spec checks send.__qualname__.__eq__('socket.send'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.recv.__qualname__ == 'socket.recv'. The recv method descriptor's __qualname__ is 'socket.recv' (11 chars). No prior spec checks recv.__qualname__.__eq__('socket.recv'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.close.__qualname__ == 'socket.close'. The close method descriptor's __qualname__ is 'socket.close' (12 chars). No prior spec checks close.__qualname__.__eq__('socket.close'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior socket spec checks __module__.__eq__ for module-level functions (getaddrinfo, getfqdn) or for gethostname. socket_extra25 covers herror/gaierror/__module__.__eq__('socket') and timeout/__module__.__eq__('builtins') (exception classes only). socket_extra47 covers __class__.__module__ for some objects, which is the class-level meta-attribute rather than the function's own __module__. getaddrinfo and getfqdn are Python functions defined in Lib/socket.py; their __module__ is 'socket'. gethostname is a C builtin exposed through the socket module; its __module__ is 'socket'. No prior spec checks these function __module__ values via __eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.gethostname.__module__ == 'socket'. gethostname is a C builtin function; its __module__ is 'socket'. socket_extra47 covers gethostname.__class__.__module__.__eq__('builtins') (the class-level meta-attribute, a different chain). No prior spec checks gethostname.__module__.__eq__('socket'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__module__ == 'socket'. getaddrinfo is a Python function defined in Lib/socket.py; its __module__ is 'socket'. No prior spec checks getaddrinfo.__module__.__eq__('socket'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__module__ == 'socket'. getfqdn is a Python function defined in Lib/socket.py; its __module__ is 'socket'. No prior spec checks getfqdn.__module__.__eq__('socket'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 3: No prior socket spec checks __module__.__class__.__name__.__eq__('str') for any socket module-level function. socket_extra49 covers __doc__.__class__.__name__ (doc type axis). The __module__.__class__.__name__ chain is entirely novel: for all socket functions, __module__ is a Python str. Three objects confirm the pattern. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.gethostname.__module__.__class__.__name__ == 'str'. gethostname.__module__ is 'socket' (a str). No prior spec checks gethostname.__module__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__module__.__class__.__name__ == 'str'. getaddrinfo.__module__ is 'socket' (a str). No prior spec checks getaddrinfo.__module__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__module__.__class__.__name__ == 'str'. getfqdn.__module__ is 'socket' (a str). No prior spec checks getfqdn.__module__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket method __qualname__.__eq__ string values
#
# socket_extra49 covers socket.socket method __qualname__.__len__() for
# connect/bind/listen/accept/send/recv/close (length axis). No prior socket
# spec checks __qualname__.__eq__ string values for any socket.socket method.
# socket.socket class methods have __qualname__ 'socket.<method>' — using the
# class name 'socket', not the module name. The __eq__ method call form is a
# distinct regression axis from __len__(): it confirms the exact string value.
# Functions containing '[' in the dotted chain must be double-quoted; none
# appear here as these are simple dotted method descriptor accesses.
# ---------------------------------------------------------------------------

table socket_extra50.socket_method_qualname_eq:
  description: "socket.socket.connect/bind/listen/accept/send/recv/close __qualname__.__eq__ string values — method qualnames follow 'socket.<method>' pattern; socket_extra49 covers __qualname__.__len__() (different axis); no prior socket spec checks __qualname__.__eq__ for any socket.socket method"
  kind: python_call_eq
  category: type_structure
  id_prefix: socketmeth50

  columns: [id, function, args, expected]
  rows:
    - [socket_connect_qualname_eq, socket.connect.__qualname__.__eq__, ["socket.connect"], true]
    - [socket_bind_qualname_eq,    socket.bind.__qualname__.__eq__,    ["socket.bind"],    true]
    - [socket_listen_qualname_eq,  socket.listen.__qualname__.__eq__,  ["socket.listen"],  true]
    - [socket_accept_qualname_eq,  socket.accept.__qualname__.__eq__,  ["socket.accept"],  true]
    - [socket_send_qualname_eq,    socket.send.__qualname__.__eq__,    ["socket.send"],    true]
    - [socket_recv_qualname_eq,    socket.recv.__qualname__.__eq__,    ["socket.recv"],    true]
    - [socket_close_qualname_eq,   socket.close.__qualname__.__eq__,   ["socket.close"],   true]

# ---------------------------------------------------------------------------
# socket module-level function __module__.__eq__('socket')
#
# socket_extra25 covers herror/gaierror/__module__.__eq__('socket') (exception
# classes only). socket_extra47 covers __class__.__module__ for gethostname
# and getaddrinfo (__class__.__module__.__eq__('builtins') — a class-level
# meta-attribute, not the function's own __module__). No prior socket spec
# checks the function-level __module__ attribute for gethostname, getaddrinfo,
# or getfqdn. All three are exposed through the socket module and have
# __module__ == 'socket'.
# ---------------------------------------------------------------------------

table socket_extra50.function_modules:
  description: "socket.gethostname/getaddrinfo/getfqdn __module__.__eq__('socket') — all three are exposed through the socket module; socket_extra25 covers exception __module__ (different objects); socket_extra47 covers __class__.__module__ (different chain); no prior socket spec checks __module__.__eq__('socket') for gethostname/getaddrinfo/getfqdn"
  kind: python_call_eq
  category: type_structure
  id_prefix: socketfnmod50

  columns: [id, function, args, expected]
  rows:
    - [gethostname_module_eq, gethostname.__module__.__eq__, ["socket"], true]
    - [getaddrinfo_module_eq, getaddrinfo.__module__.__eq__, ["socket"], true]
    - [getfqdn_module_eq,     getfqdn.__module__.__eq__,     ["socket"], true]

# ---------------------------------------------------------------------------
# socket module-level function __module__.__class__.__name__.__eq__('str')
#
# No prior socket spec checks the TYPE of any module-level function's __module__
# attribute. socket_extra49 covers __doc__.__class__.__name__ (doc type axis).
# The __module__.__class__.__name__ chain is entirely novel: for all socket
# module-level functions, __module__ is a Python str. Three representative
# objects confirm this structural invariant as an independent regression vector.
# ---------------------------------------------------------------------------

table socket_extra50.function_module_class_names:
  description: "socket.gethostname/getaddrinfo/getfqdn __module__.__class__.__name__.__eq__('str') — verifies each function's __module__ attribute is a Python str; novel __module__.__class__.__name__ axis; socket_extra49 covers __doc__.__class__.__name__ (different attribute); no prior socket spec checks __module__.__class__.__name__ for any socket module-level function"
  kind: python_call_eq
  category: type_structure
  id_prefix: socketfnmodcls50

  columns: [id, function, args, expected]
  rows:
    - [gethostname_module_class_name_eq, gethostname.__module__.__class__.__name__.__eq__, ["str"], true]
    - [getaddrinfo_module_class_name_eq, getaddrinfo.__module__.__class__.__name__.__eq__, ["str"], true]
    - [getfqdn_module_class_name_eq,     getfqdn.__module__.__class__.__name__.__eq__,     ["str"], true]
