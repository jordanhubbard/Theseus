spec: array_union
version: ">=3.0.1"
backend: node(array-union)

docs: https://www.npmjs.com/package/array-union

provenance:
  derived_from:
    - "array-union README — https://www.npmjs.com/package/array-union"
    - "Test vectors verified with array-union via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "array-union source"
  notes:
    - "array-union is an npm package. Install: npm install array-union"
    - "Returns the union of multiple arrays (all unique values). ESM; use function: default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a new array of unique values from all input arrays."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table array_union.union:
  kind: node_module_call_eq
  function: "default"
  category: set
  id_prefix: arrunion

  columns: [id, args, expected]
  rows:
    - [overlap,  [[1, 2], [2, 3]], [1, 2, 3]]
    - [disjoint, [[1, 2], [3, 4]], [1, 2, 3, 4]]
