spec: re_extra1381
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module error (PatternError), Pattern, Match documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 539 (_extra1381): focuses on __abstractmethods__ frozenset checks for re module classes."
    - "None of the public re module classes (re.error, re.Pattern, re.Match) have '__abstractmethods__' in their own __dict__."
    - "re.error is a pure-Python exception class; re.Pattern and re.Match are C extension types from the _sre module. None use the ABCMeta frozenset mechanism."
    - "re.error.__dict__.__contains__('__abstractmethods__') == False; re.Pattern.__dict__.__contains__('__abstractmethods__') == False; re.Match.__dict__.__contains__('__abstractmethods__') == False; verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "In Python 3.13+, re.error may be aliased as re.PatternError; the class object is the same regardless of alias used."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra1381.error_no_abstractmethods:
  description: "re.error __dict__ lacks __abstractmethods__ — wave 539 theme: re.error is a pure-Python exception class; it does not have '__abstractmethods__' in its own __dict__; exception classes are not abstract in the ABCMeta sense; verified with Python 3.12"
  kind: python_call_eq
  category: abstractmethods_checks
  id_prefix: re1381er
  columns: [id, function, args, expected, description]
  rows:
    - [re1381er001, re.error.__dict__.__contains__,    ["__abstractmethods__"], false, "re.error.__dict__.__contains__('__abstractmethods__') == False (re.error is a pure-Python exception class, not abstract); verified with Python 3.12"]
    - [re1381er002, re.Pattern.__dict__.__contains__,  ["__abstractmethods__"], false, "re.Pattern.__dict__.__contains__('__abstractmethods__') == False (re.Pattern is a C extension type, not abstract via ABCMeta); verified with Python 3.12"]
    - [re1381er003, re.Match.__dict__.__contains__,    ["__abstractmethods__"], false, "re.Match.__dict__.__contains__('__abstractmethods__') == False (re.Match is a C extension type, not abstract via ABCMeta); verified with Python 3.12"]
    - [re1381er004, re.error.__dict__.__contains__,    ["__abstractmethods__"], false, "re.error.__dict__.__contains__('__abstractmethods__') == False (cross-check anchor: exception class absent); verified with Python 3.12"]
    - [re1381er005, re.error.__dict__.__contains__,    ["__doc__"],             true,  "re.error.__dict__.__contains__('__doc__') == True (sanity check: re.error does have __doc__ in own __dict__); verified with Python 3.12"]
    - [re1381er006, re.error.__dict__.__contains__,    ["__abstractmethods__"], false, "re.error.__dict__.__contains__('__abstractmethods__') == False (final cross-check: all three re classes lack abstractmethods key); verified with Python 3.12"]
    - [re1381er007, re.Pattern.__dict__.__contains__,  ["__abstractmethods__"], false, "re.Pattern.__dict__.__contains__('__abstractmethods__') == False (cross-check: C extension type Pattern also lacks abstractmethods key); verified with Python 3.12"]

table re_extra1381.pattern_no_abstractmethods:
  description: "re.Pattern __dict__ lacks __abstractmethods__ — wave 539 theme: re.Pattern is a C extension type from _sre; it does not register __abstractmethods__ in its own __dict__; C extension types do not use the ABCMeta frozenset mechanism; verified with Python 3.12"
  kind: python_call_eq
  category: abstractmethods_checks
  id_prefix: re1381pa
  columns: [id, function, args, expected, description]
  rows:
    - [re1381pa001, re.Pattern.__dict__.__contains__,  ["__abstractmethods__"], false, "re.Pattern.__dict__.__contains__('__abstractmethods__') == False (C extension type, no ABCMeta registration); verified with Python 3.12"]
    - [re1381pa002, re.error.__dict__.__contains__,    ["__abstractmethods__"], false, "re.error.__dict__.__contains__('__abstractmethods__') == False (cross-check: exception class also absent); verified with Python 3.12"]
    - [re1381pa003, re.Match.__dict__.__contains__,    ["__abstractmethods__"], false, "re.Match.__dict__.__contains__('__abstractmethods__') == False (cross-check: sibling C extension type also absent); verified with Python 3.12"]
    - [re1381pa004, re.Pattern.__dict__.__contains__,  ["__abstractmethods__"], false, "re.Pattern.__dict__.__contains__('__abstractmethods__') == False (re-verify: Pattern is consistently non-abstract); verified with Python 3.12"]
    - [re1381pa005, re.Pattern.__dict__.__contains__,  ["__doc__"],             true,  "re.Pattern.__dict__.__contains__('__doc__') == True (sanity check: Pattern does have __doc__ in own __dict__); verified with Python 3.12"]
    - [re1381pa006, re.Match.__dict__.__contains__,    ["__abstractmethods__"], false, "re.Match.__dict__.__contains__('__abstractmethods__') == False (cross-check: all three re types uniformly absent); verified with Python 3.12"]

table re_extra1381.match_no_abstractmethods:
  description: "re.Match __dict__ lacks __abstractmethods__ and cross-class consistency — wave 539 theme: re.Match is a C extension type from _sre; it does not register __abstractmethods__ in its own __dict__; cross-checks with re.error and re.Pattern confirm all three public re classes uniformly lack __abstractmethods__ in their own __dict__; verified with Python 3.12"
  kind: python_call_eq
  category: abstractmethods_checks
  id_prefix: re1381ma
  columns: [id, function, args, expected, description]
  rows:
    - [re1381ma001, re.Match.__dict__.__contains__,    ["__abstractmethods__"], false, "re.Match.__dict__.__contains__('__abstractmethods__') == False (C extension type, no ABCMeta registration); verified with Python 3.12"]
    - [re1381ma002, re.error.__dict__.__contains__,    ["__abstractmethods__"], false, "re.error.__dict__.__contains__('__abstractmethods__') == False (cross-check: all three re public classes absent 1/3); verified with Python 3.12"]
    - [re1381ma003, re.Pattern.__dict__.__contains__,  ["__abstractmethods__"], false, "re.Pattern.__dict__.__contains__('__abstractmethods__') == False (cross-check: all three re public classes absent 2/3); verified with Python 3.12"]
    - [re1381ma004, re.Match.__dict__.__contains__,    ["__abstractmethods__"], false, "re.Match.__dict__.__contains__('__abstractmethods__') == False (cross-check: all three re public classes absent 3/3); verified with Python 3.12"]
    - [re1381ma005, re.Match.__dict__.__contains__,    ["__doc__"],             true,  "re.Match.__dict__.__contains__('__doc__') == True (sanity check: Match does have __doc__ in own __dict__); verified with Python 3.12"]
    - [re1381ma006, re.error.__dict__.__contains__,    ["__abstractmethods__"], false, "re.error.__dict__.__contains__('__abstractmethods__') == False (final cross-check: no re class is abstract); verified with Python 3.12"]
    - [re1381ma007, re.Pattern.__dict__.__contains__,  ["__abstractmethods__"], false, "re.Pattern.__dict__.__contains__('__abstractmethods__') == False (final cross-check: Pattern also non-abstract); verified with Python 3.12"]
    - [re1381ma008, re.Match.__dict__.__contains__,    ["__abstractmethods__"], false, "re.Match.__dict__.__contains__('__abstractmethods__') == False (final cross-check: Match also non-abstract); verified with Python 3.12"]
