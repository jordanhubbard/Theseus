spec: stringprep_extra2
version: ">=3.9"
backend: python_module(stringprep)

docs: https://docs.python.org/3/library/stringprep.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/stringprep.html — Python stringprep documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/stringprep.py"
  notes:
    - "This spec extends stringprep.zspec.zsdl and stringprep_extra.zspec.zsdl."
    - "Covers additional table functions not checked in prior specs: in_table_c22, in_table_c3, in_table_c9, in_table_c11_c12."
    - "in_table_c22 checks Private Use characters (RFC 3454 C.2.2, subset)."
    - "in_table_c3 checks Private Use characters (RFC 3454 Appendix C.3); U+E000 is in range."
    - "in_table_c9 checks Tagging Characters (RFC 3454 Appendix C.9); U+E0001 is a tagging character."
    - "in_table_b1(soft hyphen) is True — U+00AD (soft hyphen) maps to nothing per RFC 3454 B.1."
    - "in_table_b1(ASCII letter) is False — ordinary ASCII letters are not in table B.1."
    - "in_table_d1(Hebrew Alef U+05D0) is True — Hebrew letters are R/AL characters."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name checks for additional table functions not in prior specs
# ---------------------------------------------------------------------------

table stringprep_extra2.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [in_table_c22,      "in_table_c22.__name__.__eq__",      ["in_table_c22"],      true]
    - [in_table_c3,       "in_table_c3.__name__.__eq__",       ["in_table_c3"],       true]
    - [in_table_c9,       "in_table_c9.__name__.__eq__",       ["in_table_c9"],       true]
    - [in_table_c11_c12,  "in_table_c11_c12.__name__.__eq__",  ["in_table_c11_c12"],  true]

# ---------------------------------------------------------------------------
# __module__ checks for additional table functions
# ---------------------------------------------------------------------------

table stringprep_extra2.function_modules:
  kind: python_call_eq
  category: functions
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [in_table_c22,      "in_table_c22.__module__.__eq__",      ["stringprep"],  true]
    - [in_table_c3,       "in_table_c3.__module__.__eq__",       ["stringprep"],  true]
    - [in_table_c9,       "in_table_c9.__module__.__eq__",       ["stringprep"],  true]
    - [in_table_c11_c12,  "in_table_c11_c12.__module__.__eq__",  ["stringprep"],  true]

# ---------------------------------------------------------------------------
# Behavioral invariants — in_table_b1 (Commonly Mapped To Nothing)
# ---------------------------------------------------------------------------

invariant stringprep_extra2.in_table_b1.soft_hyphen:
  description: "in_table_b1(soft hyphen U+00AD) == True — soft hyphen maps to nothing per RFC 3454 B.1"
  category: behavior
  kind: python_call_eq
  function: in_table_b1
  args: ["\xad"]
  expected: true

invariant stringprep_extra2.in_table_b1.ascii_letter:
  description: "in_table_b1('a') == False — ordinary ASCII letters are not in table B.1"
  category: behavior
  kind: python_call_eq
  function: in_table_b1
  args: ["a"]
  expected: false

# ---------------------------------------------------------------------------
# Behavioral invariants — in_table_d1 (R and AL categories)
# ---------------------------------------------------------------------------

invariant stringprep_extra2.in_table_d1.hebrew_alef:
  description: "in_table_d1(Hebrew Alef U+05D0) == True — Hebrew letters are R/AL characters"
  category: behavior
  kind: python_call_eq
  function: in_table_d1
  args: ["\u05D0"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral invariants — in_table_c3 (Private Use Characters)
# ---------------------------------------------------------------------------

invariant stringprep_extra2.in_table_c3.private_use:
  description: "in_table_c3(U+E000) == True — U+E000 is a Private Use character (RFC 3454 C.3)"
  category: behavior
  kind: python_call_eq
  function: in_table_c3
  args: ["\uE000"]
  expected: true
