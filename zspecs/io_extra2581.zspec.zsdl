spec: io_extra2581
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 io documentation — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bytesio.c"
    - "CPython source: Modules/_io/stringio.c"
    - "io_extra.zspec.zsdl — covers existing io invariants"
  notes:
    - "Wave 2581 theme: __call__ dict-presence. None of the io classes define __call__ in their own __dict__."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase are abstract base classes; none define __call__."
    - "io.BytesIO defines __iter__ and __next__ (it is iterable) but does NOT define __call__."
    - "io.StringIO defines __next__ but does NOT define __call__."
    - "io.BufferedReader defines __next__ but does NOT define __call__."
    - "io.TextIOWrapper does NOT define __call__ in its own __dict__."
    - "No io class acts as a functor/callable object — none define __call__ in their own __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __call__ dict-presence — abstract base classes
# io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase
# ---------------------------------------------------------------------------

table io_extra2581.abstract_base_no_call:
  description: "__call__ is absent from all io abstract base class __dict__s — none are callable objects"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2581

  columns: [id, function, args, expected]
  rows:
    - ["io2581001", "io.IOBase.__dict__.__contains__",       ["__call__"], false]
    - ["io2581002", "io.RawIOBase.__dict__.__contains__",    ["__call__"], false]
    - ["io2581003", "io.BufferedIOBase.__dict__.__contains__", ["__call__"], false]
    - ["io2581004", "io.TextIOBase.__dict__.__contains__",   ["__call__"], false]

# ---------------------------------------------------------------------------
# __call__ dict-presence — concrete io classes
# io.BytesIO, io.StringIO, io.FileIO, io.BufferedReader,
# io.BufferedWriter, io.TextIOWrapper
# ---------------------------------------------------------------------------

table io_extra2581.concrete_class_no_call:
  description: "__call__ is absent from all concrete io class __dict__s — stream objects are not functors"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2581

  columns: [id, function, args, expected]
  rows:
    - ["io2581005", "io.BytesIO.__dict__.__contains__",       ["__call__"], false]
    - ["io2581006", "io.StringIO.__dict__.__contains__",      ["__call__"], false]
    - ["io2581007", "io.FileIO.__dict__.__contains__",        ["__call__"], false]
    - ["io2581008", "io.BufferedReader.__dict__.__contains__", ["__call__"], false]
    - ["io2581009", "io.BufferedWriter.__dict__.__contains__", ["__call__"], false]
    - ["io2581010", "io.TextIOWrapper.__dict__.__contains__", ["__call__"], false]

# ---------------------------------------------------------------------------
# Complementary: io.BytesIO DOES define __iter__ and __next__ (iterable, not callable)
# Confirms that io classes can define other protocol methods without defining __call__
# ---------------------------------------------------------------------------

table io_extra2581.bytesio_iterator_protocol:
  description: "io.BytesIO defines __iter__ and __next__ (iterable) but not __call__ (not a functor)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2581

  columns: [id, function, args, expected]
  rows:
    - ["io2581011", "io.BytesIO.__dict__.__contains__", ["__iter__"], true]
    - ["io2581012", "io.BytesIO.__dict__.__contains__", ["__next__"], true]
    - ["io2581013", "io.BytesIO.__dict__.__contains__", ["__init__"], true]
    - ["io2581014", "io.BytesIO.__dict__.__contains__", ["__call__"], false]
    - ["io2581015", "io.BytesIO.__dict__.__contains__", ["__new__"],  true]

# ---------------------------------------------------------------------------
# Complementary: io.BufferedReader defines __next__ (iterable) but not __call__
# ---------------------------------------------------------------------------

table io_extra2581.bufferedreader_iterator_not_callable:
  description: "io.BufferedReader defines __next__ (iterable) but NOT __call__ — confirms the pattern holds for buffered I/O"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2581

  columns: [id, function, args, expected]
  rows:
    - ["io2581016", "io.BufferedReader.__dict__.__contains__", ["__next__"], true]
    - ["io2581017", "io.BufferedReader.__dict__.__contains__", ["__call__"], false]
    - ["io2581018", "io.BufferedReader.__dict__.__contains__", ["__init__"], true]
    - ["io2581019", "io.StringIO.__dict__.__contains__",       ["__next__"], true]
    - ["io2581020", "io.StringIO.__dict__.__contains__",       ["__call__"], false]
