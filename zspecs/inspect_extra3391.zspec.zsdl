spec: in3391
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 673 (in3391): __int__, __float__, __complex__ dict-presence checks for inspect types."
    - "Theme: __int__/__float__/__complex__ dict-presence (int(x), float(x), complex(x))."
    - "All values False — inspect introspection types have no numeric conversion support."
    - "None of the inspect types define __int__, __float__, or __complex__ in their own __dict__."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception types."
    - "inspect.Parameter, inspect.BoundArguments, and inspect.Signature are pure Python classes."
    - "None of these types implement int, float, or complex conversion protocols directly."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3391.int:
  description: "inspect types __int__ dict-presence checks; wave 673"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: in3391
  columns: [id, function, args, expected]
  rows:
    - ["in3391001", operator.contains, [inspect.Parameter.__dict__,           "__int__"], false]
    - ["in3391002", operator.contains, [inspect.Signature.__dict__,           "__int__"], false]
    - ["in3391003", operator.contains, [inspect.BoundArguments.__dict__,      "__int__"], false]
    - ["in3391004", operator.contains, [inspect.FrameInfo.__dict__,           "__int__"], false]
    - ["in3391005", operator.contains, [inspect.ArgInfo.__dict__,             "__int__"], false]
    - ["in3391006", operator.contains, [inspect.FullArgSpec.__dict__,         "__int__"], false]
    - ["in3391007", operator.contains, [inspect.Attribute.__dict__,           "__int__"], false]
    - ["in3391008", operator.contains, [inspect.ClassFoundException.__dict__, "__int__"], false]
    - ["in3391009", operator.contains, [inspect.EndOfBlock.__dict__,          "__int__"], false]

