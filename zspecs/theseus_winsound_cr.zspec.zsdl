spec: theseus_winsound_cr
version: ">=3.0"
backend: python_cleanroom(theseus_winsound_cr)
blocks: winsound

docs: https://docs.python.org/3/library/winsound.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/winsound.html"
  not_derived_from:
    - "CPython source: PC/winsound.c"
  notes:
    - "Clean-room winsound stub. Do NOT import winsound."
    - "Windows-only module; stubs raise OSError on non-Windows."

error_model: python_exceptions

invariant theseus_winsound_cr.winsound2_constants:
  description: "winsound constants have correct values"
  category: behavior
  kind: python_call_eq
  function: winsound2_constants
  args: []
  expected: true

invariant theseus_winsound_cr.winsound2_platform:
  description: "winsound stubs correctly reflect platform"
  category: behavior
  kind: python_call_eq
  function: winsound2_platform
  args: []
  expected: true

invariant theseus_winsound_cr.winsound2_functions:
  description: "winsound function stubs are callable"
  category: behavior
  kind: python_call_eq
  function: winsound2_functions
  args: []
  expected: true
