       "concurrent.futures._base.Executor.__bases__[0].__name__.__eq__('object') == True — Executor directly subclasses object; str.__eq__ returns True; new to concurrent_futures_extra185"]

# ---------------------------------------------------------------------------
# Table 3: Future vs Executor name length ordering
#
# Future(6) < Executor(8) — length ordering anchor
# ---------------------------------------------------------------------------

table concurrent_futures_extra185.future_executor_length_ordering:
  description: "concurrent.futures._base.Future and Executor name length ordering: Future(6) < Executor(8); new to concurrent_futures_extra185"
  kind: python_call_eq
  category: identity
  id_prefix: cfbase185

  columns: [id, function, args, expected, description]
  rows:
    - [future_name_len_ordering,
       Future.__name__.__len__,
       [],
       6,
       "concurrent.futures._base.Future.__name__.__len__() == 6 — ordering anchor: Future(6) is shorter than Executor(8); str.__len__() returns 6; new to concurrent_futures_extra185"]
    - [executor_name_len_ordering,
       Executor.__name__.__len__,
       [],
       8,
       "concurrent.futures._base.Executor.__name__.__len__() == 8 — ordering ceiling: Future(6) < Executor(8); str.__len__() returns 8; new to concurrent_futures_extra185"]
    - [future_module_len_eq,
       Future.__module__.__len__,
       [],
       24,
       "concurrent.futures._base.Future.__module__.__len__() == 24 — 'concurrent.futures._base' has 24 characters; str.__len__() returns 24; new to concurrent_futures_extra185"]
    - [executor_module_len_eq,
       Executor.__module__.__len__,
       [],
       24,
       "concurrent.futures._base.Executor.__module__.__len__() == 24 — 'concurrent.futures._base' has 24 characters; same module as Future; str.__len__() returns 24; new to concurrent_futures_extra185"]
    - [future_name_len_6_eq,
       Future.__name__.__len__,
       [],
       6,
       "concurrent.futures._base.Future.__name__.__len__() == 6 — cross-check: str.__len__() returns 6; new to concurrent_futures_extra185"]

