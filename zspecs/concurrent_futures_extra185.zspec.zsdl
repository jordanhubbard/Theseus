spec: concurrent_futures_extra185
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "concurrent.futures._base.Future.__name__ == 'Future' (len=6); __module__ == 'concurrent.futures._base'; __qualname__ == 'Future'."
    - "concurrent.futures._base.Future.__bases__[0].__name__ == 'object' — Future directly subclasses object."
    - "concurrent.futures._base.Executor.__name__ == 'Executor' (len=8); __module__ == 'concurrent.futures._base'; __qualname__ == 'Executor'."
    - "concurrent.futures._base.Executor.__bases__[0].__name__ == 'object' — Executor directly subclasses object."
    - "Length ordering: Future(6) < Executor(8)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: concurrent.futures._base.Future class identity — name, module, qualname
#
# concurrent.futures._base.Future.__name__.__len__().__eq__(6) == True
# concurrent.futures._base.Future.__module__.__eq__('concurrent.futures._base') == True
# concurrent.futures._base.Future.__qualname__.__eq__('Future') == True
# concurrent.futures._base.Future.__bases__[0].__name__.__eq__('object') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra185.future_identity:
  description: "concurrent.futures._base.Future name (len=6), module, qualname, and base class identity; new to concurrent_futures_extra185"
  kind: python_call_eq
  category: identity
  id_prefix: cfbase185

  columns: [id, function, args, expected, description]
  rows:
    - [future_name_eq,
       Future.__name__.__eq__,
       ["Future"],
       true,
       "concurrent.futures._base.Future.__name__.__eq__('Future') == True — class name string identity; str.__eq__ returns True; new to concurrent_futures_extra185"]
    - [future_name_len_6,
       Future.__name__.__len__,
       [],
       6,
       "concurrent.futures._base.Future.__name__.__len__() == 6 — 'Future' has 6 characters: F-u-t-u-r-e; str.__len__() returns 6; new to concurrent_futures_extra185"]
    - [future_module_eq,
       Future.__module__.__eq__,
       ["concurrent.futures._base"],
       true,
       "concurrent.futures._base.Future.__module__.__eq__('concurrent.futures._base') == True — Future is defined in the private _base submodule; str.__eq__ returns True; new to concurrent_futures_extra185"]
    - [future_qualname_eq,
       Future.__qualname__.__eq__,
       ["Future"],
       true,
       "concurrent.futures._base.Future.__qualname__.__eq__('Future') == True — top-level class so qualname equals simple name; str.__eq__ returns True; new to concurrent_futures_extra185"]
    - [future_bases0_name_eq,
       "Future.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "concurrent.futures._base.Future.__bases__[0].__name__.__eq__('object') == True — Future directly subclasses object; str.__eq__ returns True; new to concurrent_futures_extra185"]

