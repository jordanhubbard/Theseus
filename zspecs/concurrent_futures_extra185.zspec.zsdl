       true,
       "concurrent.futures._base.Executor.__name__.__eq__('Executor') == True — class name string identity; str.__eq__ returns True; new to concurrent_futures_extra185"]
    - [executor_name_len_8,
       Executor.__name__.__len__,
       [],
       8,
       "concurrent.futures._base.Executor.__name__.__len__() == 8 — 'Executor' has 8 characters: E-x-e-c-u-t-o-r; str.__len__() returns 8; new to concurrent_futures_extra185"]
    - [executor_module_eq,
       Executor.__module__.__eq__,
       ["concurrent.futures._base"],
       true,
       "concurrent.futures._base.Executor.__module__.__eq__('concurrent.futures._base') == True — Executor is defined in the private _base submodule; str.__eq__ returns True; new to concurrent_futures_extra185"]
    - [executor_qualname_eq,
       Executor.__qualname__.__eq__,
       ["Executor"],
       true,
       "concurrent.futures._base.Executor.__qualname__.__eq__('Executor') == True — top-level class so qualname equals simple name; str.__eq__ returns True; new to concurrent_futures_extra185"]
    - [executor_bases0_name_eq,
