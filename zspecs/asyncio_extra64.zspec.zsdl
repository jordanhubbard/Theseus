spec: asyncio_extra64
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#inspect — Python code object co_name and co_argcount documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "This spec extends asyncio_extra63.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__()==13, Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__() tables, InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__/__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, Queue/Lock method qualname string equality, asyncio class __module__ string equality (extra52), Queue/Lock __doc__/__class__/__name__=='str' (extra50), asyncio.__all__.__class__.__name__=='list' (extra51), gather/sleep/__qualname__.__eq__ (extra3/extra22/extra26/extra28/extra43), Queue/__name__.__eq__ and Lock/__name__.__eq__ (extra/extra2/extra5), run/__qualname__.__eq__('run') (extra6/extra22/extra43), Condition/__name__/__qualname__/__len__() (extra53), BoundedSemaphore/__name__/__qualname__/__len__() (extra53), run/__name__.__eq__('run') (extra53), class __dict__.__class__.__name__/__qualname__ == 'mappingproxy' (extra54), class __class__.__module__.__eq__('builtins') (extra55), gather/sleep/wait __class__.__module__.__eq__('builtins') (extra55), Queue/Lock/Event/Semaphore/Condition __init__.__class__.__name__.__eq__('function') (extra55), class __repr__.__class__.__name__ (extra56), class __weakref__.__class__.__name__ (extra56), gather/sleep/wait function __repr__.__class__.__name__ (extra56), asyncio.__all__.__class__.__name__.__eq__('tuple') (extra57), class __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra57), class __subclasshook__.__class__.__name__ (extra57), asyncio.__all__.__contains__ membership checks (extra58), asyncio.__package__.__eq__('asyncio') (extra58), Queue/Lock __doc__.__class__.__name__.__eq__('str') (extra58), __loader__/__spec__/__file__/__cached__ __class__.__name__ (extra59), __spec__.origin/__spec__.submodule_search_locations/__spec__.has_location/__loader__.__class__.__name__.__len__() (extra60), Queue/Lock __init__ and put/get/empty/full/qsize/acquire/release __qualname__.__eq__ (extra61), gather/sleep/wait __annotations__.__class__.__name__.__eq__('dict'), gather __globals__.__class__.__name__.__eq__('dict'), gather __globals__.__contains__('gather'), Queue.__doc__.__contains__('Queue') (extra62), gather/__code__/__defaults__/__class__.__name__ checks, sleep/__code__/__defaults__/__class__.__name__ checks, Queue.__init__/__defaults__/__class__.__name__ checks (extra63)."
    - "This spec covers (asynciocode2_64 namespace): wave 230 theme — __code__.co_name equality + co_argcount values + co_name __class__.__name__ checks. NEW in extra64: gather.__code__.co_name.__eq__('gather') — gather is a pure-Python coroutine function; co_name is the string name of the code object which equals the function name 'gather'; no prior asyncio spec has checked gather.__code__.co_name via __eq__; sleep.__code__.co_name.__eq__('sleep') — co_name of sleep is 'sleep'; Queue.__init__.__code__.co_name.__eq__('__init__') and Lock.__init__.__code__.co_name.__eq__('__init__') — co_name for initializer methods equals '__init__'; gather.__code__.co_argcount.__eq__(0) — gather(*coros_or_futures, return_exceptions=False) uses *args so co_argcount==0 (no positional-or-keyword params); sleep.__code__.co_argcount.__eq__(2) — sleep(delay, result=None) has 2 positional-or-keyword params; Queue.__init__.__code__.co_argcount.__eq__(2) — Queue.__init__(self, maxsize=0) has 2; Lock.__init__.__code__.co_argcount.__eq__(1) — Lock.__init__(self) has 1."
    - "asyncio.gather.__code__.co_name == 'gather'. The co_name attribute of a code object stores the name with which the function was defined. gather is defined as 'async def gather(...)' in Lib/asyncio/tasks.py, so co_name is 'gather'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.sleep.__code__.co_name == 'sleep'. sleep is defined as 'async def sleep(delay, result=None)' in Lib/asyncio/tasks.py, so co_name is 'sleep'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__init__.__code__.co_name == '__init__'. Queue.__init__ is defined as 'def __init__(self, maxsize=0)' in Lib/asyncio/queues.py, so co_name is '__init__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__init__.__code__.co_name == '__init__'. Lock.__init__ is defined as 'def __init__(self)' in Lib/asyncio/locks.py, so co_name is '__init__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.gather.__code__.co_argcount == 0. gather(*coros_or_futures, return_exceptions=False) takes no positional-or-keyword parameters — the coros_or_futures parameter is a *args collector, and return_exceptions is keyword-only. co_argcount counts only positional-or-keyword parameters, so it is 0. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.sleep.__code__.co_argcount == 2. sleep(delay, result=None) has two positional-or-keyword parameters: delay and result. co_argcount is 2. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__init__.__code__.co_argcount == 2. Queue.__init__(self, maxsize=0) has two positional-or-keyword parameters: self and maxsize. co_argcount is 2. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__init__.__code__.co_argcount == 1. Lock.__init__(self) has one positional-or-keyword parameter: self. co_argcount is 1. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "co_name.__class__.__name__ == 'str'. The co_name attribute on all code objects is a str. str.__class__.__name__ is 'str'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "co_argcount.__class__.__name__ == 'int'. The co_argcount attribute on all code objects is an int. int.__class__.__name__ is 'int'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio __code__.co_name.__eq__ checks — extra64
#
# Wave 230 theme: __code__.co_name equality checks.
#
# The co_name attribute of a code object is the string name with which the
# function was defined. For gather, sleep, Queue.__init__, and Lock.__init__
# the co_name equals the function's definition name.
#
# NEW: no prior asyncio spec has checked __code__.co_name via __eq__ for any
# of these functions.
# ---------------------------------------------------------------------------

table asyncio_extra64.function_code_co_name_eq:
  description: "asyncio __code__.co_name.__eq__ checks in asynciocode2_64 namespace — wave 230 theme: co_name equality; gather.__code__.co_name=='gather', sleep.__code__.co_name=='sleep', Queue.__init__.__code__.co_name=='__init__', Lock.__init__.__code__.co_name=='__init__'; co_name is the string name stored in the code object matching the function definition name; NEW in extra64: no prior asyncio spec has checked __code__.co_name via __eq__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: asynciocode2_64

  columns: [id, function, args, expected, description]
  rows:
    - [gather_co_name_eq,     gather.__code__.co_name.__eq__,          ["gather"],   true, "gather.__code__.co_name == 'gather' — gather is defined as 'async def gather(...)' in Lib/asyncio/tasks.py; co_name stores the function's definition name as a str; __eq__('gather') returns True; NEW in extra64: first __code__.co_name.__eq__ check for gather in any asyncio spec; verified with Python 3.14.3"]
    - [sleep_co_name_eq,      sleep.__code__.co_name.__eq__,           ["sleep"],    true, "sleep.__code__.co_name == 'sleep' — sleep is defined as 'async def sleep(delay, result=None)' in Lib/asyncio/tasks.py; co_name stores the definition name; __eq__('sleep') returns True; NEW in extra64: first __code__.co_name.__eq__ check for sleep in any asyncio spec; verified with Python 3.14.3"]
    - [queue_init_co_name_eq, Queue.__init__.__code__.co_name.__eq__,  ["__init__"], true, "Queue.__init__.__code__.co_name == '__init__' — Queue.__init__ is defined as 'def __init__(self, maxsize=0)' in Lib/asyncio/queues.py; co_name is '__init__'; __eq__('__init__') returns True; NEW in extra64: first __code__.co_name.__eq__ check for Queue.__init__ in any asyncio spec; verified with Python 3.14.3"]
    - [lock_init_co_name_eq,  Lock.__init__.__code__.co_name.__eq__,   ["__init__"], true, "Lock.__init__.__code__.co_name == '__init__' — Lock.__init__ is defined as 'def __init__(self)' in Lib/asyncio/locks.py; co_name is '__init__'; __eq__('__init__') returns True; NEW in extra64: first __code__.co_name.__eq__ check for Lock.__init__ in any asyncio spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio __code__.co_argcount.__eq__ checks — extra64
#
# Wave 230 theme: co_argcount values.
#
# co_argcount counts positional-or-keyword parameters only. *args, **kwargs,
# and keyword-only parameters do NOT contribute to co_argcount.
#
# gather(*coros_or_futures, return_exceptions=False): co_argcount == 0
#   (coros_or_futures is *args; return_exceptions is keyword-only)
# sleep(delay, result=None): co_argcount == 2 (delay + result)
# Queue.__init__(self, maxsize=0): co_argcount == 2 (self + maxsize)
# Lock.__init__(self): co_argcount == 1 (self only)
# ---------------------------------------------------------------------------

table asyncio_extra64.function_code_co_argcount_eq:
  description: "asyncio __code__.co_argcount.__eq__ checks in asynciocode2_64 namespace — wave 230 theme: co_argcount values; co_argcount counts positional-or-keyword parameters only (*args/**kwargs/keyword-only excluded); gather==0 (*args only), sleep==2 (delay+result), Queue.__init__==2 (self+maxsize), Lock.__init__==1 (self); NEW in extra64: no prior asyncio spec has checked __code__.co_argcount via __eq__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: asynciocode2_64a

  columns: [id, function, args, expected, description]
  rows:
    - [gather_co_argcount_eq,     gather.__code__.co_argcount.__eq__,         [0], true, "gather.__code__.co_argcount == 0 — gather(*coros_or_futures, return_exceptions=False) has no positional-or-keyword parameters; coros_or_futures is a *args collector (not counted by co_argcount); return_exceptions is keyword-only (not counted by co_argcount); co_argcount is 0; NEW in extra64: first __code__.co_argcount.__eq__ check for gather in any asyncio spec; verified with Python 3.14.3"]
    - [sleep_co_argcount_eq,      sleep.__code__.co_argcount.__eq__,          [2], true, "sleep.__code__.co_argcount == 2 — sleep(delay, result=None) has two positional-or-keyword parameters: delay (no default) and result (default None); co_argcount is 2; NEW in extra64: first __code__.co_argcount.__eq__ check for sleep in any asyncio spec; verified with Python 3.14.3"]
    - [queue_init_co_argcount_eq, Queue.__init__.__code__.co_argcount.__eq__, [2], true, "Queue.__init__.__code__.co_argcount == 2 — Queue.__init__(self, maxsize=0) has two positional-or-keyword parameters: self and maxsize; co_argcount is 2; NEW in extra64: first __code__.co_argcount.__eq__ check for Queue.__init__ in any asyncio spec; verified with Python 3.14.3"]
    - [lock_init_co_argcount_eq,  Lock.__init__.__code__.co_argcount.__eq__,  [1], true, "Lock.__init__.__code__.co_argcount == 1 — Lock.__init__(self) has one positional-or-keyword parameter: self; co_argcount is 1; NEW in extra64: first __code__.co_argcount.__eq__ check for Lock.__init__ in any asyncio spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio __code__.co_name.__class__.__name__.__eq__ checks — extra64
#
# Wave 230 theme: co_name __class__.__name__ checks.
#
# co_name is always a str on all code objects. str.__class__.__name__ == 'str'.
# ---------------------------------------------------------------------------

table asyncio_extra64.function_code_co_name_class_name_eq:
  description: "asyncio __code__.co_name.__class__.__name__.__eq__('str') checks in asynciocode2_64 namespace — wave 230 theme: co_name type identity; co_name is always a str on all code objects; gather/sleep/Queue.__init__/Lock.__init__ all have co_name.__class__.__name__=='str'; NEW in extra64: no prior asyncio spec has checked __code__.co_name.__class__.__name__ via __eq__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: asynciocode2_64c

  columns: [id, function, args, expected, description]
  rows:
    - [gather_co_name_class_eq,     gather.__code__.co_name.__class__.__name__.__eq__,         ["str"], true, "gather.__code__.co_name.__class__.__name__ == 'str' — the co_name attribute of any code object is a str; gather.__code__.co_name is 'gather', a str; str.__class__.__name__ is 'str'; NEW in extra64: first __code__.co_name.__class__.__name__.__eq__ check for gather in any asyncio spec; verified with Python 3.14.3"]
    - [sleep_co_name_class_eq,      sleep.__code__.co_name.__class__.__name__.__eq__,          ["str"], true, "sleep.__code__.co_name.__class__.__name__ == 'str' — sleep.__code__.co_name is 'sleep', a str; str.__class__.__name__ is 'str'; NEW in extra64: first __code__.co_name.__class__.__name__.__eq__ check for sleep in any asyncio spec; verified with Python 3.14.3"]
    - [queue_init_co_name_class_eq, Queue.__init__.__code__.co_name.__class__.__name__.__eq__, ["str"], true, "Queue.__init__.__code__.co_name.__class__.__name__ == 'str' — Queue.__init__.__code__.co_name is '__init__', a str; str.__class__.__name__ is 'str'; NEW in extra64: first __code__.co_name.__class__.__name__.__eq__ check for Queue.__init__ in any asyncio spec; verified with Python 3.14.3"]
    - [lock_init_co_name_class_eq,  Lock.__init__.__code__.co_name.__class__.__name__.__eq__,  ["str"], true, "Lock.__init__.__code__.co_name.__class__.__name__ == 'str' — Lock.__init__.__code__.co_name is '__init__', a str; str.__class__.__name__ is 'str'; NEW in extra64: first __code__.co_name.__class__.__name__.__eq__ check for Lock.__init__ in any asyncio spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra64
# ---------------------------------------------------------------------------

invariant asyncio_extra64.gather_co_name_eq:
  description: "asyncio.gather.__code__.co_name.__eq__('gather') returns True — gather is defined as 'async def gather(...)' in Lib/asyncio/tasks.py; the co_name attribute of a code object stores the function's definition name; co_name.__eq__('gather') returns True; NEW in extra64: no prior asyncio spec has checked gather.__code__.co_name via __eq__; wave 230 first co_name equality invariant for gather in any asyncio spec; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: gather.__code__.co_name.__eq__
  args: ["gather"]
  expected: true

invariant asyncio_extra64.sleep_co_name_eq:
  description: "asyncio.sleep.__code__.co_name.__eq__('sleep') returns True — sleep is defined as 'async def sleep(delay, result=None)' in Lib/asyncio/tasks.py; co_name stores the definition name 'sleep'; __eq__('sleep') returns True; NEW in extra64: no prior asyncio spec has checked sleep.__code__.co_name via __eq__; wave 230 invariant alongside gather co_name check; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: sleep.__code__.co_name.__eq__
  args: ["sleep"]
  expected: true

invariant asyncio_extra64.queue_init_co_name_eq:
  description: "asyncio.Queue.__init__.__code__.co_name.__eq__('__init__') returns True — Queue.__init__ is defined as 'def __init__(self, maxsize=0)' in Lib/asyncio/queues.py; co_name is '__init__'; __eq__('__init__') returns True; NEW in extra64: no prior asyncio spec has checked Queue.__init__.__code__.co_name via __eq__; wave 230 first co_name equality invariant for Queue.__init__; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Queue.__init__.__code__.co_name.__eq__
  args: ["__init__"]
  expected: true

invariant asyncio_extra64.lock_init_co_name_eq:
  description: "asyncio.Lock.__init__.__code__.co_name.__eq__('__init__') returns True — Lock.__init__ is defined as 'def __init__(self)' in Lib/asyncio/locks.py; co_name is '__init__'; __eq__('__init__') returns True; NEW in extra64: no prior asyncio spec has checked Lock.__init__.__code__.co_name via __eq__; wave 230 first co_name equality invariant for Lock.__init__; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Lock.__init__.__code__.co_name.__eq__
  args: ["__init__"]
  expected: true

invariant asyncio_extra64.gather_co_argcount_eq:
  description: "asyncio.gather.__code__.co_argcount.__eq__(0) returns True — gather(*coros_or_futures, return_exceptions=False) has no positional-or-keyword parameters; coros_or_futures is a *args collector and return_exceptions is keyword-only, neither of which is counted by co_argcount; co_argcount is 0; NEW in extra64: no prior asyncio spec has checked gather.__code__.co_argcount via __eq__; wave 230 first co_argcount value invariant for gather; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: gather.__code__.co_argcount.__eq__
  args: [0]
  expected: true

invariant asyncio_extra64.sleep_co_argcount_eq:
  description: "asyncio.sleep.__code__.co_argcount.__eq__(2) returns True — sleep(delay, result=None) has two positional-or-keyword parameters: delay and result; co_argcount is 2; NEW in extra64: no prior asyncio spec has checked sleep.__code__.co_argcount via __eq__; wave 230 first co_argcount value invariant for sleep; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: sleep.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant asyncio_extra64.queue_init_co_argcount_eq:
  description: "asyncio.Queue.__init__.__code__.co_argcount.__eq__(2) returns True — Queue.__init__(self, maxsize=0) has two positional-or-keyword parameters: self and maxsize; co_argcount is 2; NEW in extra64: no prior asyncio spec has checked Queue.__init__.__code__.co_argcount via __eq__; wave 230 first co_argcount value invariant for Queue.__init__; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Queue.__init__.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant asyncio_extra64.lock_init_co_argcount_eq:
  description: "asyncio.Lock.__init__.__code__.co_argcount.__eq__(1) returns True — Lock.__init__(self) has one positional-or-keyword parameter: self; co_argcount is 1; NEW in extra64: no prior asyncio spec has checked Lock.__init__.__code__.co_argcount via __eq__; wave 230 first co_argcount value invariant for Lock.__init__; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Lock.__init__.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant asyncio_extra64.gather_co_name_class_name_eq:
  description: "asyncio.gather.__code__.co_name.__class__.__name__.__eq__('str') returns True — co_name on any code object is always a str; gather.__code__.co_name is 'gather', a str; str.__class__.__name__ is 'str'; NEW in extra64: no prior asyncio spec has checked gather.__code__.co_name.__class__.__name__ via __eq__; wave 230 co_name type identity invariant for gather; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: gather.__code__.co_name.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant asyncio_extra64.queue_init_co_name_class_name_eq:
  description: "asyncio.Queue.__init__.__code__.co_name.__class__.__name__.__eq__('str') returns True — Queue.__init__.__code__.co_name is '__init__', a str; str.__class__.__name__ is 'str'; NEW in extra64: no prior asyncio spec has checked Queue.__init__.__code__.co_name.__class__.__name__ via __eq__; wave 230 co_name type identity invariant for Queue.__init__; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Queue.__init__.__code__.co_name.__class__.__name__.__eq__
  args: ["str"]
  expected: true
