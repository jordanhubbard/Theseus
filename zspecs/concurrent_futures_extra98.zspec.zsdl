spec: concurrent_futures_extra98
version: ">=3.9"
backend: python_module(concurrent.futures)
extends: concurrent_futures_extra97

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec extends concurrent_futures_extra97.zspec.zsdl."
    - "This spec covers: wave 254 theme — concurrent.futures.Future method __qualname__ lengths (all core methods). NEW in extra98: Future.result.__qualname__=='Future.result' (len=13); Future.cancel.__qualname__=='Future.cancel' (len=13); Future.done.__qualname__=='Future.done' (len=11); Future.running.__qualname__=='Future.running' (len=14); Future.cancelled.__qualname__=='Future.cancelled' (len=16); Future.exception.__qualname__=='Future.exception' (len=16, tied with cancelled); Future.add_done_callback.__qualname__=='Future.add_done_callback' (len=24); Future.set_running_or_notify_cancel.__qualname__=='Future.set_running_or_notify_cancel' (len=35, longest); Future.__init__.__qualname__=='Future.__init__' (len=15); Future.__module__=='concurrent.futures._base'; Future.__mro__.__len__()==2 ([Future, object]). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__mro__.__len__() == 2. Future's MRO is [Future, object] — Future inherits directly from object (depth=2), the same minimal depth as asyncio.Future and multiprocessing.pool.Pool. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.set_running_or_notify_cancel.__qualname__.__len__() == 35. This is the longest method qualname in concurrent.futures.Future: len('Future.set_running_or_notify_cancel')=35. The compound method name 'set_running_or_notify_cancel' is 28 chars. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Future core method qualnames — extra98
#
# Wave 254 theme: concurrent.futures.Future method __qualname__ lengths.
#
# Future.result.__qualname__    == 'Future.result'    (len=13)
# Future.cancel.__qualname__    == 'Future.cancel'    (len=13)
# Future.done.__qualname__      == 'Future.done'      (len=11)
# Future.running.__qualname__   == 'Future.running'   (len=14)
# Future.exception.__qualname__ == 'Future.exception' (len=16)
# Future.__module__ == 'concurrent.futures._base'
# Future.__mro__.__len__() == 2
# ---------------------------------------------------------------------------

table concurrent_futures_extra98.cf_future_core_qualnames:
  description: "concurrent.futures.Future core method __qualname__ checks in cffutureqn98 namespace — wave 254 theme: all Future methods are defined in Lib/concurrent/futures/_base.py; Future.__module__=='concurrent.futures._base'; Future.__mro__.__len__()==2 ([Future, object], same minimal depth as asyncio.Future and multiprocessing.pool.Pool); Future.result.__qualname__.__eq__('Future.result')==True (len=13: 'Future.'=7 + 'result'=6); Future.cancel.__qualname__.__eq__('Future.cancel')==True (len=13: same as result, 'Future.'=7 + 'cancel'=6); Future.done.__qualname__.__eq__('Future.done')==True (len=11: 'Future.'=7 + 'done'=4, the shortest non-dunder Future method qualname); Future.running.__qualname__.__eq__('Future.running')==True (len=14: 'Future.'=7 + 'running'=7); Future.exception.__qualname__.__eq__('Future.exception')==True (len=16: 'Future.'=7 + 'exception'=9); all have class='function' (pure-Python in _base.py); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffutureqn98

  columns: [id, function, args, expected, description]
  rows:
    - [fut_result_qeq,   "Future.result.__qualname__.__eq__",     ["Future.result"],    true, "Future.result.__qualname__ == 'Future.result' (len=13); verified with Python 3.14.3"]
    - [fut_result_qlen,  "Future.result.__qualname__.__len__",    [],                   13,   "Future.result.__qualname__.__len__() == 13; verified with Python 3.14.3"]
    - [fut_cancel_qeq,   "Future.cancel.__qualname__.__eq__",     ["Future.cancel"],    true, "Future.cancel.__qualname__ == 'Future.cancel' (len=13, same as result); verified with Python 3.14.3"]
    - [fut_cancel_qlen,  "Future.cancel.__qualname__.__len__",    [],                   13,   "Future.cancel.__qualname__.__len__() == 13 (tied with result); verified with Python 3.14.3"]
    - [fut_done_qeq,     "Future.done.__qualname__.__eq__",       ["Future.done"],      true, "Future.done.__qualname__ == 'Future.done' (len=11, shortest); verified with Python 3.14.3"]
    - [fut_done_qlen,    "Future.done.__qualname__.__len__",      [],                   11,   "Future.done.__qualname__.__len__() == 11 (shortest Future method qualname); verified with Python 3.14.3"]
    - [fut_run_qeq,      "Future.running.__qualname__.__eq__",    ["Future.running"],   true, "Future.running.__qualname__ == 'Future.running' (len=14); verified with Python 3.14.3"]
    - [fut_run_qlen,     "Future.running.__qualname__.__len__",   [],                   14,   "Future.running.__qualname__.__len__() == 14; verified with Python 3.14.3"]
    - [fut_exc_qeq,      "Future.exception.__qualname__.__eq__",  ["Future.exception"], true, "Future.exception.__qualname__ == 'Future.exception' (len=16); verified with Python 3.14.3"]
    - [fut_exc_qlen,     "Future.exception.__qualname__.__len__", [],                   16,   "Future.exception.__qualname__.__len__() == 16 (tied with Future.cancelled); verified with Python 3.14.3"]
    - [fut_module,       "Future.__module__.__eq__",              ["concurrent.futures._base"], true, "Future.__module__ == 'concurrent.futures._base' — defined in _base.py; verified with Python 3.14.3"]
    - [fut_mro_len,      "Future.__mro__.__len__",                [],                   2,    "Future.__mro__.__len__() == 2 — [Future, object], same depth as asyncio.Future; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.Future callback and state methods — extra98
#
# Future.add_done_callback.__qualname__          == 'Future.add_done_callback'          (len=24)
# Future.cancelled.__qualname__                  == 'Future.cancelled'                  (len=16)
# Future.__init__.__qualname__                   == 'Future.__init__'                   (len=15)
# Future.set_running_or_notify_cancel.__qualname__ == 'Future.set_running_or_notify_cancel' (len=35)
# ---------------------------------------------------------------------------

table concurrent_futures_extra98.cf_future_callback_qualnames:
  description: "concurrent.futures.Future callback and state method __qualname__ checks in cffutureqn98 namespace — wave 254 theme: Future methods beyond the core query methods; Future.add_done_callback.__qualname__.__eq__('Future.add_done_callback')==True (len=24: 'Future.'=7 + 'add_done_callback'=17); Future.add_done_callback.__qualname__.__len__()==24 (compound name; same length as asyncio.Future.add_done_callback if it existed — but asyncio.Future.add_done_callback is a C-level method_descriptor); Future.cancelled.__qualname__.__eq__('Future.cancelled')==True (len=16: 'Future.'=7 + 'cancelled'=9, tied with Future.exception.__qualname__.__len__()==16); Future.__init__.__qualname__.__eq__('Future.__init__')==True (len=15: 'Future.'=7 + '__init__'=8); Future.set_running_or_notify_cancel.__qualname__.__eq__('Future.set_running_or_notify_cancel')==True (len=35: 'Future.'=7 + 'set_running_or_notify_cancel'=28; the longest method qualname in the concurrent.futures.Future class); all methods have class='function' (pure-Python in _base.py); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffutureqn98a

  columns: [id, function, args, expected, description]
  rows:
    - [fut_adc_qeq,   "Future.add_done_callback.__qualname__.__eq__",               ["Future.add_done_callback"],          true, "Future.add_done_callback.__qualname__ == 'Future.add_done_callback' (len=24); verified with Python 3.14.3"]
    - [fut_adc_qlen,  "Future.add_done_callback.__qualname__.__len__",              [],                                    24,   "Future.add_done_callback.__qualname__.__len__() == 24; verified with Python 3.14.3"]
    - [fut_adc_cls,   "Future.add_done_callback.__class__.__name__.__eq__",         ["function"],                          true, "Future.add_done_callback.__class__.__name__ == 'function' — pure-Python; verified with Python 3.14.3"]
    - [fut_canc_qeq,  "Future.cancelled.__qualname__.__eq__",                       ["Future.cancelled"],                  true, "Future.cancelled.__qualname__ == 'Future.cancelled' (len=16, tied with exception); verified with Python 3.14.3"]
    - [fut_canc_qlen, "Future.cancelled.__qualname__.__len__",                      [],                                    16,   "Future.cancelled.__qualname__.__len__() == 16 (tied with Future.exception len=16); verified with Python 3.14.3"]
    - [fut_init_qeq,  "Future.__init__.__qualname__.__eq__",                        ["Future.__init__"],                   true, "Future.__init__.__qualname__ == 'Future.__init__' (len=15); verified with Python 3.14.3"]
    - [fut_init_qlen, "Future.__init__.__qualname__.__len__",                       [],                                    15,   "Future.__init__.__qualname__.__len__() == 15; verified with Python 3.14.3"]
    - [fut_srnc_qeq,  "Future.set_running_or_notify_cancel.__qualname__.__eq__",    ["Future.set_running_or_notify_cancel"], true, "Future.set_running_or_notify_cancel.__qualname__ == 'Future.set_running_or_notify_cancel' (len=35, longest); verified with Python 3.14.3"]
    - [fut_srnc_qlen, "Future.set_running_or_notify_cancel.__qualname__.__len__",   [],                                    35,   "Future.set_running_or_notify_cancel.__qualname__.__len__() == 35 (longest Future method qualname); verified with Python 3.14.3"]
    - [fut_srnc_cls,  "Future.set_running_or_notify_cancel.__class__.__name__.__eq__", ["function"],                       true, "Future.set_running_or_notify_cancel.__class__.__name__ == 'function' — pure-Python; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra98
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra98.Future_done_qualname_shortest:
  description: "concurrent.futures.Future.done.__qualname__.__len__() == 11 — Future.done.__qualname__ is 'Future.done' (11 chars: 'Future.'=7 + 'done'=4); this is the shortest qualname among all public Future method names: done=11, result=13, cancel=13, running=14, __init__=15, exception=16, cancelled=16, add_done_callback=24, set_result=17, set_exception=20, set_running_or_notify_cancel=35; Future.done.__class__.__name__ is 'function' (pure-Python); Future.done returns True if the future was successfully cancelled or finished running; NEW in extra98: first standalone Future.done qualname length invariant in cffutureqn98 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Future.done.__qualname__.__len__"
  args: []
  expected: 11

invariant concurrent_futures_extra98.Future_set_running_qualname_longest:
  description: "concurrent.futures.Future.set_running_or_notify_cancel.__qualname__.__len__() == 35 — Future.set_running_or_notify_cancel.__qualname__ is 'Future.set_running_or_notify_cancel' (35 chars: 'Future.'=7 + 'set_running_or_notify_cancel'=28); this is the longest qualname among all concurrent.futures.Future methods by a wide margin (next longest is add_done_callback=24); set_running_or_notify_cancel is an internal method called by Executor implementations to transition a Future from PENDING to RUNNING state, or cancel it if a cancel was requested; Future.set_running_or_notify_cancel.__class__.__name__ is 'function'; NEW in extra98: first standalone Future.set_running_or_notify_cancel qualname length invariant in cffutureqn98 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Future.set_running_or_notify_cancel.__qualname__.__len__"
  args: []
  expected: 35

invariant concurrent_futures_extra98.Future_add_done_callback_qualname_len_24:
  description: "concurrent.futures.Future.add_done_callback.__qualname__.__len__() == 24 — Future.add_done_callback.__qualname__ is 'Future.add_done_callback' (24 chars: 'Future.'=7 + 'add_done_callback'=17); this is the second-longest qualname in Future (after set_running_or_notify_cancel=35); add_done_callback registers a function to be called when the future completes (either by cancellation or completion); Future.add_done_callback.__class__.__name__ is 'function' (pure-Python, in Lib/concurrent/futures/_base.py); Future.__module__ is 'concurrent.futures._base'; compare with Future.cancel.__qualname__.__len__()==13 and Future.done.__qualname__.__len__()==11; NEW in extra98: first standalone Future.add_done_callback qualname length invariant in cffutureqn98 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Future.add_done_callback.__qualname__.__len__"
  args: []
  expected: 24

invariant concurrent_futures_extra98.Future_mro_len_is_2:
  description: "concurrent.futures.Future.__mro__.__len__() == 2 — Future's MRO is [Future, object] (length=2); this minimal 2-element chain means concurrent.futures.Future inherits directly from object with no intermediate classes; Future.__bases__[0].__name__ is 'object'; this depth-2 MRO is shared by asyncio.Future (also depth=2, module='_asyncio') and multiprocessing.pool.Pool (also depth=2, module='multiprocessing.pool'); all three are direct object subclasses despite serving different concurrency paradigms (thread pool futures, C-extension event loop futures, and process pool workers); Future.__module__ is 'concurrent.futures._base'; NEW in extra98: first standalone concurrent.futures.Future MRO length invariant in cffutureqn98 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Future.__mro__.__len__"
  args: []
  expected: 2

invariant concurrent_futures_extra98.Future_result_and_cancel_qualname_same_len:
  description: "concurrent.futures.Future.result.__qualname__.__len__() == 13 — Future.result.__qualname__ is 'Future.result' (13 chars: 'Future.'=7 + 'result'=6); this is the same length as Future.cancel.__qualname__.__len__()==13 ('Future.'=7 + 'cancel'=6); both 'result' and 'cancel' are 6-character method names that produce the same qualname length; Future.result returns the value returned by the call, blocking until the future completes or raises an exception; Future.cancel attempts to cancel the future; Future.result.__class__.__name__ is 'function'; Future.cancel.__class__.__name__ is 'function'; the tied length (13) contrasts with Future.done (len=11), Future.running (len=14), Future.exception (len=16), and Future.add_done_callback (len=24); NEW in extra98: first standalone Future.result qualname length invariant in cffutureqn98 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Future.result.__qualname__.__len__"
  args: []
  expected: 13
