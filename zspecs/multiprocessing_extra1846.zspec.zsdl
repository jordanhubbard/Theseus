spec: multiprocessing_extra1846
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "multiprocessing stdlib documentation"
    - "CPython source: Lib/multiprocessing/"
  not_derived_from:
    - "any third-party multiprocessing extensions"
  notes:
    - "multiprocessing classes do not define arithmetic or comparison operators"
    - "Process, Pool, AsyncResult inherit identity-based comparison from object"
  created_at: "2026-04-12"

table multiprocessing_extra1846.arithmetic_operators:
  columns: [id, function, args, expected]
  rows:
    - ["mp1846-arith-001", "multiprocessing.Process.__dict__.__contains__", ["__add__"], false]
    - ["mp1846-arith-002", "multiprocessing.Process.__dict__.__contains__", ["__sub__"], false]
    - ["mp1846-arith-003", "multiprocessing.Process.__dict__.__contains__", ["__mul__"], false]
    - ["mp1846-arith-004", "multiprocessing.pool.Pool.__dict__.__contains__", ["__add__"], false]
    - ["mp1846-arith-005", "multiprocessing.pool.Pool.__dict__.__contains__", ["__mul__"], false]
    - ["mp1846-arith-006", "multiprocessing.pool.AsyncResult.__dict__.__contains__", ["__add__"], false]
    - ["mp1846-arith-007", "multiprocessing.managers.BaseManager.__dict__.__contains__", ["__add__"], false]
    - ["mp1846-arith-008", "multiprocessing.managers.BaseManager.__dict__.__contains__", ["__mul__"], false]

table multiprocessing_extra1846.comparison_operators:
  columns: [id, function, args, expected]
  rows:
    - ["mp1846-cmp-001", "multiprocessing.Process.__dict__.__contains__", ["__eq__"], false]
    - ["mp1846-cmp-002", "multiprocessing.Process.__dict__.__contains__", ["__lt__"], false]
    - ["mp1846-cmp-003", "multiprocessing.Process.__dict__.__contains__", ["__gt__"], false]
    - ["mp1846-cmp-004", "multiprocessing.pool.Pool.__dict__.__contains__", ["__eq__"], false]
    - ["mp1846-cmp-005", "multiprocessing.pool.AsyncResult.__dict__.__contains__", ["__eq__"], false]
    - ["mp1846-cmp-006", "multiprocessing.managers.BaseManager.__dict__.__contains__", ["__eq__"], false]
    - ["mp1846-cmp-007", "multiprocessing.Process.__dict__.__contains__", ["__hash__"], false]
    - ["mp1846-cmp-008", "multiprocessing.pool.Pool.__dict__.__contains__", ["__hash__"], false]

table multiprocessing_extra1846.mp_queue_pipe_attrs:
