spec: concurrent_futures_extra1321
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Wave 535 (_extra1321): focuses on __repr__ and __str__ method class checks for concurrent.futures classes."
    - "concurrent.futures.Future.__repr__.__qualname__ == 'Future.__repr__' — defines its own __repr__."
    - "concurrent.futures.Future.__repr__.__class__.__name__ == 'function' — Python function."
    - "concurrent.futures.ThreadPoolExecutor.__repr__.__qualname__ == 'object.__repr__' — inherits from object."
    - "concurrent.futures.ProcessPoolExecutor.__repr__.__qualname__ == 'object.__repr__' — inherits from object."
    - "concurrent.futures.Executor.__repr__.__qualname__ == 'object.__repr__' — abstract base inherits __repr__."
    - "All executor classes inherit __str__ from object — wrapper_descriptor."
    - "repr() of any class object is always a str — repr(cls).__class__.__name__ == 'str'."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table concurrent_futures_extra1321.repr_qualnames:
  description: "concurrent.futures class __repr__ qualname checks — Future defines its own, executors inherit from object"
  kind: python_call_eq
  category: identity
  id_prefix: cf1321rq
  columns: [id, function, args, expected]
  rows:
    - [cf1321rq001, concurrent.futures.Future.__repr__.__qualname__.__eq__,              ["Future.__repr__"],  true]
    - [cf1321rq002, concurrent.futures.ThreadPoolExecutor.__repr__.__qualname__.__eq__,  ["object.__repr__"],  true]
    - [cf1321rq003, concurrent.futures.ProcessPoolExecutor.__repr__.__qualname__.__eq__, ["object.__repr__"],  true]
    - [cf1321rq004, concurrent.futures.Executor.__repr__.__qualname__.__eq__,            ["object.__repr__"],  true]
    - [cf1321rq005, concurrent.futures.Future.__str__.__qualname__.__eq__,               ["object.__str__"],   true]
    - [cf1321rq006, concurrent.futures.Executor.__str__.__qualname__.__eq__,             ["object.__str__"],   true]

table concurrent_futures_extra1321.repr_class_names:
  description: "concurrent.futures __repr__ method class checks: Future is function, executors have wrapper_descriptor"
  kind: python_call_eq
  category: identity
  id_prefix: cf1321rc
  columns: [id, function, args, expected]
  rows:
    - [cf1321rc001, concurrent.futures.Future.__repr__.__class__.__name__.__eq__,              ["function"],           true]
    - [cf1321rc002, concurrent.futures.ThreadPoolExecutor.__repr__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - [cf1321rc003, concurrent.futures.ProcessPoolExecutor.__repr__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [cf1321rc004, concurrent.futures.Executor.__repr__.__class__.__name__.__eq__,            ["wrapper_descriptor"], true]
    - [cf1321rc005, concurrent.futures.Future.__str__.__class__.__name__.__eq__,               ["wrapper_descriptor"], true]
    - [cf1321rc006, concurrent.futures.Executor.__str__.__class__.__name__.__eq__,             ["wrapper_descriptor"], true]

table concurrent_futures_extra1321.repr_of_class_is_str:
  description: "repr() applied to concurrent.futures class objects always returns a str"
  kind: python_call_eq
  category: identity
  id_prefix: cf1321cs
  columns: [id, function, args, expected]
  rows:
    - [cf1321cs001, concurrent.futures.Future.__repr__.__qualname__.__class__.__name__.__eq__,             ["str"], true]
    - [cf1321cs002, concurrent.futures.ThreadPoolExecutor.__repr__.__qualname__.__class__.__name__.__eq__, ["str"], true]
    - [cf1321cs003, concurrent.futures.ProcessPoolExecutor.__repr__.__qualname__.__class__.__name__.__eq__,["str"], true]
    - [cf1321cs004, concurrent.futures.Executor.__repr__.__qualname__.__class__.__name__.__eq__,           ["str"], true]
    - [cf1321cs005, concurrent.futures.Future.__str__.__qualname__.__class__.__name__.__eq__,              ["str"], true]
    - [cf1321cs006, concurrent.futures.Executor.__str__.__qualname__.__class__.__name__.__eq__,            ["str"], true]
