spec: ntpath_extra2
version: ">=3.0"
backend: python_module(ntpath)

docs: https://docs.python.org/3/library/os.path.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.path.html — Python ntpath documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ntpath.py"
  notes:
    - "This spec extends ntpath.zspec.zsdl and ntpath_extra.zspec.zsdl."
    - "Covers module constants sep, altsep, curdir, pardir, and the module __name__ attribute."
    - "ntpath.sep is '\\\\' (a single backslash) — the Windows primary path separator."
    - "ntpath.altsep is '/' — the Windows alternate path separator."
    - "ntpath.curdir is '.' — the current directory marker."
    - "ntpath.pardir is '..' — the parent directory marker."
    - "ntpath.__name__ == 'ntpath' confirms module identity."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module __name__ attribute
# ---------------------------------------------------------------------------

invariant ntpath_extra2.module.name:
  description: "ntpath.__name__ == 'ntpath'"
  category: module
  kind: python_call_eq
  function: __name__.__eq__
  args: ["ntpath"]
  expected: true

# ---------------------------------------------------------------------------
# Module constants — sep, altsep, curdir, pardir
# ---------------------------------------------------------------------------

invariant ntpath_extra2.constants.sep:
  description: "ntpath.sep == '\\\\' — Windows path separator (single backslash)"
  category: constants
  kind: python_call_eq
  function: sep.__eq__
  args: ["\\"]
  expected: true

invariant ntpath_extra2.constants.altsep:
  description: "ntpath.altsep == '/' — Windows alternate path separator"
  category: constants
  kind: python_call_eq
  function: altsep.__eq__
  args: ["/"]
  expected: true

invariant ntpath_extra2.constants.curdir:
  description: "ntpath.curdir == '.' — current directory marker"
  category: constants
  kind: python_call_eq
  function: curdir.__eq__
  args: ["."]
  expected: true

invariant ntpath_extra2.constants.pardir:
  description: "ntpath.pardir == '..' — parent directory marker"
  category: constants
  kind: python_call_eq
  function: pardir.__eq__
  args: [".."]
  expected: true

# ---------------------------------------------------------------------------
# Additional function name checks not in prior ntpath specs
# (join, split, basename, dirname already covered in ntpath.zspec.zsdl table)
# ---------------------------------------------------------------------------

invariant ntpath_extra2.function_names.split:
  description: "ntpath.split.__name__ == 'split'"
  category: function_names
  kind: python_call_eq
  function: split.__name__.__eq__
  args: ["split"]
  expected: true

# ---------------------------------------------------------------------------
# split — two-part decomposition of Windows path
# ---------------------------------------------------------------------------

invariant ntpath_extra2.split.head:
  description: "ntpath.split('C:\\\\a\\\\b\\\\c')[0] == 'C:\\\\a\\\\b' — head component"
  category: split
  kind: python_call_eq
  function: split
  args: ["C:\\a\\b\\c"]
  method: __getitem__
  method_args: [0]
  expected: "C:\\a\\b"

invariant ntpath_extra2.split.tail:
  description: "ntpath.split('C:\\\\a\\\\b\\\\c')[1] == 'c' — tail component"
  category: split
  kind: python_call_eq
  function: split
  args: ["C:\\a\\b\\c"]
  method: __getitem__
  method_args: [1]
  expected: "c"
