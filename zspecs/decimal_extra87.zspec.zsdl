spec: decimal_extra87
version: ">=3.9"
backend: python_module(decimal)
extends: decimal_extra86

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal.zspec.zsdl and all prior decimal_extra specs through decimal_extra86."
    - "Prior specs covered: Decimal arithmetic; exception class __qualname__; getcontext/setcontext identity; Decimal/__dict__ membership; MAX_PREC/MAX_EMAX; exception hierarchy; Decimal C slot wrapper identity; Context identity; Context/__dict__ membership; exception class __name__ identity; Decimal dunders; Decimal comparison/equality/hash; Context/__dict__ class and membership; getcontext/setcontext __class__.__name__/__module__; Decimal division/power operator; Context arithmetic method __class__.__name__; Decimal arithmetic/string/conversion dunder __qualname__; Decimal comparison operator __qualname__ lengths; Decimal to_*/normalize/quantize/sqrt/compare __qualname__; Decimal.__dict__.__contains__; Decimal/__name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__(); Context/__name__/__module__/__qualname__; ROUND_* constants; Decimal method qualnames; Context class identity and __dict__ membership; signal exception __name__ and __module__; decimal_extra86 covered Decimal.__dict__ membership for math methods, dunder arithmetic, __str__/__repr__, and mappingproxy class identity."
    - "This spec covers: decimal module identity — __name__, __package__, __spec__, __loader__; plus decimal.Context method __qualname__ strings."
    - "decimal.__name__ == 'decimal' — the module name."
    - "decimal.__package__ == '' — decimal is a top-level module (not a package), so __package__ is empty string."
    - "decimal.__spec__.__class__.__name__ == 'ModuleSpec' — the module spec is a ModuleSpec instance."
    - "decimal.__spec__.name == 'decimal' — the spec's name attribute matches the module name."
    - "decimal.__loader__.__class__.__name__ == 'SourceFileLoader' — decimal is loaded from source (decimal.py)."
    - "decimal.Context.quantize.__qualname__ == 'Context.quantize' — Context method qualname follows 'Context.<method>' pattern."
    - "decimal.Context.sqrt.__qualname__ == 'Context.sqrt'."
    - "decimal.Context.compare.__qualname__ == 'Context.compare'."
    - "decimal.Context.add.__qualname__ == 'Context.add'."
    - "decimal.Context.subtract.__qualname__ == 'Context.subtract'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal module __name__, __package__, __spec__
# decimal is a top-level module (not a package): __package__ == ''.
# __spec__ is a ModuleSpec; __spec__.name == 'decimal'.
# ---------------------------------------------------------------------------

table decimal_extra87.module_name_package_spec:
  description: "decimal.__name__, __package__, __spec__.__class__.__name__, __spec__.name string equality"
  kind: python_call_eq
  category: module_identity
  id_prefix: decimalmodctxq87

  columns: [id, function, args, expected]
  rows:
    - [dec_name_eq,        __name__.__eq__,                    ["decimal"], true]
    - [dec_name_not_other, __name__.__eq__,                    ["_decimal"], false]
    - [dec_pkg_empty,      __package__.__eq__,                 [""],        true]
    - [dec_pkg_not_dec,    __package__.__eq__,                 ["decimal"], false]

# ---------------------------------------------------------------------------
# decimal module __spec__ name and __loader__ class name
# __spec__.name == 'decimal'; __loader__ is SourceFileLoader (not FrozenImporter).
# ---------------------------------------------------------------------------

table decimal_extra87.module_spec_loader:
  description: "decimal.__spec__.name and decimal.__loader__.__class__.__name__ string equality"
  kind: python_call_eq
  category: module_identity
  id_prefix: decimalmodctxq87

  columns: [id, function, args, expected]
  rows:
    - [spec_cls_name,      __spec__.__class__.__name__.__eq__, ["ModuleSpec"],       true]
    - [spec_cls_not_str,   __spec__.__class__.__name__.__eq__, ["str"],              false]
    - [spec_name_eq,       __spec__.name.__eq__,               ["decimal"],          true]
    - [loader_cls_name,    __loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true]

# ---------------------------------------------------------------------------
# decimal.Context method __qualname__ strings: quantize, sqrt, compare, add
# All Context method qualnames follow the 'Context.<method>' pattern.
# These are Python methods defined in decimal.py (SourceFileLoader module).
# ---------------------------------------------------------------------------

table decimal_extra87.Context_method_qualnames_group1:
  description: "decimal.Context.quantize/sqrt/compare/add __qualname__ string equality"
  kind: python_call_eq
  category: qualname
  id_prefix: decimalmodctxq87

  columns: [id, function, args, expected]
  rows:
    - [ctx_quantize_qn, Context.quantize.__qualname__.__eq__, ["Context.quantize"], true]
    - [ctx_sqrt_qn,     Context.sqrt.__qualname__.__eq__,     ["Context.sqrt"],     true]
    - [ctx_compare_qn,  Context.compare.__qualname__.__eq__,  ["Context.compare"],  true]
    - [ctx_add_qn,      Context.add.__qualname__.__eq__,      ["Context.add"],      true]

# ---------------------------------------------------------------------------
# decimal.Context method __qualname__ strings: subtract, multiply, divide
# Cross-checks: subtract/multiply/divide follow the same 'Context.<method>' pattern.
# ---------------------------------------------------------------------------

table decimal_extra87.Context_method_qualnames_group2:
  description: "decimal.Context.subtract/multiply/divide __qualname__ string equality; cross-checks"
  kind: python_call_eq
  category: qualname
  id_prefix: decimalmodctxq87

  columns: [id, function, args, expected]
  rows:
    - [ctx_subtract_qn,  Context.subtract.__qualname__.__eq__,  ["Context.subtract"],  true]
    - [ctx_multiply_qn,  Context.multiply.__qualname__.__eq__,  ["Context.multiply"],  true]
    - [ctx_divide_qn,    Context.divide.__qualname__.__eq__,    ["Context.divide"],    true]
    - [ctx_add_qn_neg,   Context.add.__qualname__.__eq__,       ["Context.subtract"],  false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra87.module.name_eq_decimal:
  description: "decimal.__name__ == 'decimal' (the module name)"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra87.module.package_is_empty:
  description: "decimal.__package__ == '' (decimal is a top-level module, not a package; __package__ is empty string)"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant decimal_extra87.module.spec_class_is_ModuleSpec:
  description: "decimal.__spec__.__class__.__name__ == 'ModuleSpec' (module spec is always a ModuleSpec instance)"
  category: module_identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant decimal_extra87.Context.quantize_qualname:
  description: "decimal.Context.quantize.__qualname__ == 'Context.quantize' (qualname follows 'Context.<method>' pattern)"
  category: qualname
  kind: python_call_eq
  function: Context.quantize.__qualname__.__eq__
  args: ["Context.quantize"]
  expected: true

invariant decimal_extra87.Context.subtract_qualname:
  description: "decimal.Context.subtract.__qualname__ == 'Context.subtract' (qualname follows 'Context.<method>' pattern)"
  category: qualname
  kind: python_call_eq
  function: Context.subtract.__qualname__.__eq__
  args: ["Context.subtract"]
  expected: true
