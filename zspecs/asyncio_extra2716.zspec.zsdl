spec: asyncio_extra2716
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/asyncio.html"
    - "https://docs.python.org/3/library/asyncio-task.html"
    - "https://docs.python.org/3/library/asyncio-sync.html"
    - "https://docs.python.org/3/library/asyncio-queue.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 628 (_extra2716): __neg__, __pos__, __abs__ dict-presence checks (unary arithmetic operators)."
    - "asyncio types (Queue, Task, Future, Lock, Event, Semaphore, Condition, Barrier) are concurrency primitives, not numeric types."
    - "None of these types define unary minus, unary plus, or absolute value protocols in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __neg__ dict-presence checks
#
# Wave 628 theme: asyncio concurrency types do not implement the unary minus
# operator. __neg__ does not appear in any of these classes' own __dict__.
# ---------------------------------------------------------------------------

table asyncio_extra2716.neg_protocol:
  description: "asyncio types __neg__ dict-presence checks — none define unary minus in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2716

  columns: [id, function, args, expected]
  rows:
    - ["as2716001", "asyncio.Queue.__dict__.__contains__",     ["__neg__"], false]
    - ["as2716002", "asyncio.Task.__dict__.__contains__",      ["__neg__"], false]
    - ["as2716003", "asyncio.Future.__dict__.__contains__",    ["__neg__"], false]
    - ["as2716004", "asyncio.Lock.__dict__.__contains__",      ["__neg__"], false]
    - ["as2716005", "asyncio.Event.__dict__.__contains__",     ["__neg__"], false]
    - ["as2716006", "asyncio.Semaphore.__dict__.__contains__", ["__neg__"], false]
    - ["as2716007", "asyncio.Condition.__dict__.__contains__", ["__neg__"], false]
    - ["as2716008", "asyncio.Barrier.__dict__.__contains__",   ["__neg__"], false]

