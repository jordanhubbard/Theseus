# ---------------------------------------------------------------------------
# Table 4: combined __neg__/__pos__/__abs__ checks for Task, Future, and
#          Barrier
#
# Wave 628 theme: extended cross-operator coverage for asyncio coroutine and
# synchronization types. Task wraps a coroutine; Future represents an async
# result; Barrier coordinates a group of coroutines. None define any unary
# arithmetic protocol in their own __dict__.
# ---------------------------------------------------------------------------

table asyncio_extra2716.task_future_barrier_unary:
  description: "asyncio.Task, Future, Barrier combined __neg__/__pos__/__abs__ dict-presence checks — coroutine and coordination types define no unary arithmetic"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2716

  columns: [id, function, args, expected]
  rows:
    - ["as2716025", "asyncio.Task.__dict__.__contains__",    ["__neg__"], false]
    - ["as2716026", "asyncio.Task.__dict__.__contains__",    ["__pos__"], false]
    - ["as2716027", "asyncio.Task.__dict__.__contains__",    ["__abs__"], false]
    - ["as2716028", "asyncio.Future.__dict__.__contains__",  ["__neg__"], false]
    - ["as2716029", "asyncio.Future.__dict__.__contains__",  ["__pos__"], false]
    - ["as2716030", "asyncio.Future.__dict__.__contains__",  ["__abs__"], false]
    - ["as2716031", "asyncio.Barrier.__dict__.__contains__", ["__neg__"], false]
    - ["as2716032", "asyncio.Barrier.__dict__.__contains__", ["__pos__"], false]
    - ["as2716033", "asyncio.Barrier.__dict__.__contains__", ["__abs__"], false]
