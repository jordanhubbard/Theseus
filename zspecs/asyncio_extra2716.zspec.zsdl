# __dict__.
# ---------------------------------------------------------------------------

table asyncio_extra2716.abs_protocol:
  description: "asyncio types __abs__ dict-presence checks — none define absolute value in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2716

  columns: [id, function, args, expected]
  rows:
    - ["as2716017", "asyncio.Queue.__dict__.__contains__",     ["__abs__"], false]
    - ["as2716018", "asyncio.Task.__dict__.__contains__",      ["__abs__"], false]
    - ["as2716019", "asyncio.Future.__dict__.__contains__",    ["__abs__"], false]
    - ["as2716020", "asyncio.Lock.__dict__.__contains__",      ["__abs__"], false]
