spec: abc_extra236
version: ">=3.4"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers abc.ABCMeta method identity — __subclasshook__, __instancecheck__, __subclasscheck__."
    - "ABCMeta.__subclasshook__ is a builtin_function_or_method (C extension); __module__ is None."
    - "ABCMeta.__subclasshook__.__name__ == '__subclasshook__' — 16 characters."
    - "ABCMeta.__subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__' — 24 characters."
    - "ABCMeta.__instancecheck__ is a pure Python function; __module__ == 'abc'."
    - "ABCMeta.__instancecheck__.__name__ == '__instancecheck__' — 17 characters."
    - "ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' — 25 characters."
    - "ABCMeta.__subclasscheck__ is a pure Python function; __module__ == 'abc'."
    - "ABCMeta.__subclasscheck__.__name__ == '__subclasscheck__' — 17 characters."
    - "ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' — 25 characters."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc.ABCMeta.__subclasshook__ method identity contracts
#
# __subclasshook__ is a builtin (C extension). Covers __name__ and __qualname__.
# ---------------------------------------------------------------------------

table abc_extra236.subclasshook_identity:
  description: "abc.ABCMeta.__subclasshook__ method identity: name, qualname; new to extra236"
  kind: python_call_eq
  category: subclasshook_identity
  id_prefix: abc236meta

  columns: [id, function, args, expected, description]
  rows:
    - [sh_name_eq,
       ABCMeta.__subclasshook__.__name__.__eq__,
       ["__subclasshook__"],
       true,
       "abc.ABCMeta.__subclasshook__.__name__.__eq__('__subclasshook__') == True — builtin carries its simple name; new to extra236"]
    - [sh_qualname_eq,
       ABCMeta.__subclasshook__.__qualname__.__eq__,
       ["ABCMeta.__subclasshook__"],
       true,
       "abc.ABCMeta.__subclasshook__.__qualname__.__eq__('ABCMeta.__subclasshook__') == True — qualname includes class prefix; new to extra236"]
    - [sh_class_name_eq,
       ABCMeta.__subclasshook__.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "abc.ABCMeta.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — C extension builtin; new to extra236"]
    - [sh_name_len_16,
       ABCMeta.__subclasshook__.__name__.__len__,
       [],
       16,
       "abc.ABCMeta.__subclasshook__.__name__.__len__() == 16 — '__subclasshook__' has 16 characters; new to extra236"]
    - [sh_qualname_len_24,
       ABCMeta.__subclasshook__.__qualname__.__len__,
       [],
       24,
       "abc.ABCMeta.__subclasshook__.__qualname__.__len__() == 24 — 'ABCMeta.__subclasshook__' has 24 characters; new to extra236"]

# ---------------------------------------------------------------------------
# Table 2: abc.ABCMeta.__instancecheck__ method identity contracts
#
# __instancecheck__ is a pure Python function defined in abc module.
# Covers __name__, __qualname__, and __module__.
# ---------------------------------------------------------------------------

table abc_extra236.instancecheck_identity:
  description: "abc.ABCMeta.__instancecheck__ method identity: name, qualname, module; new to extra236"
  kind: python_call_eq
  category: instancecheck_identity
  id_prefix: abc236meta

  columns: [id, function, args, expected, description]
  rows:
    - [ic_name_eq,
       ABCMeta.__instancecheck__.__name__.__eq__,
       ["__instancecheck__"],
       true,
       "abc.ABCMeta.__instancecheck__.__name__.__eq__('__instancecheck__') == True — function carries its simple name; new to extra236"]
    - [ic_qualname_eq,
       ABCMeta.__instancecheck__.__qualname__.__eq__,
       ["ABCMeta.__instancecheck__"],
       true,
       "abc.ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__') == True — qualname includes class prefix; new to extra236"]
    - [ic_module_eq,
       ABCMeta.__instancecheck__.__module__.__eq__,
       ["abc"],
       true,
       "abc.ABCMeta.__instancecheck__.__module__.__eq__('abc') == True — pure Python function defined in abc module; new to extra236"]
    - [ic_name_len_17,
       ABCMeta.__instancecheck__.__name__.__len__,
       [],
       17,
       "abc.ABCMeta.__instancecheck__.__name__.__len__() == 17 — '__instancecheck__' has 17 characters; new to extra236"]
    - [ic_qualname_len_25,
       ABCMeta.__instancecheck__.__qualname__.__len__,
       [],
       25,
       "abc.ABCMeta.__instancecheck__.__qualname__.__len__() == 25 — 'ABCMeta.__instancecheck__' has 25 characters; new to extra236"]

