# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra236
# ---------------------------------------------------------------------------

invariant abc_extra236.ABCMeta.subclasshook_name:
  description: "abc.ABCMeta.__subclasshook__.__name__ == '__subclasshook__'; new to extra236"
  category: subclasshook_identity
  kind: python_call_eq
  function: ABCMeta.__subclasshook__.__name__.__eq__
  args: ["__subclasshook__"]
  expected: true

