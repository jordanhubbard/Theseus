spec: io_extra51
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra50.zspec.zsdl — covers IOBase/RawIOBase/BufferedIOBase/TextIOBase/FileIO/BytesIO/StringIO/BufferedWriter/BufferedReader __qualname__.__len__()."
    - "io_extra49.zspec.zsdl — covers IOBase/RawIOBase/BufferedIOBase/TextIOBase/FileIO/BytesIO/StringIO/BufferedWriter/BufferedReader __qualname__.__eq__() (string equality)."
    - "io_extra48.zspec.zsdl — covers IOBase/RawIOBase/BufferedIOBase/TextIOBase __mro__.__len__() as standalone invariants; FileIO/BytesIO/StringIO __bases__[0].__name__ equality."
    - "io_extra36.zspec.zsdl — covers __mro__.__len__() for IOBase(3)/RawIOBase(5)/BufferedIOBase(5)/TextIOBase(5)/StringIO(4)/BytesIO(4) in a table."
    - "io_extra33.zspec.zsdl — covers UnsupportedOperation/__qualname__/__module__/__bases__[0].__name__ in standalone invariants."
    - "io_extra19.zspec.zsdl — covers UnsupportedOperation.__bases__[0].__name__=='OSError'."
  notes:
    - "This spec extends io_extra50.zspec.zsdl."
    - "Prior specs collectively covered: all nine main io class __qualname__.__eq__() and __qualname__.__len__() (io_extra49/io_extra50); IOBase/RawIOBase/BufferedIOBase/TextIOBase/StringIO/BytesIO __mro__.__len__() (io_extra36); IOBase/RawIOBase/BufferedIOBase/TextIOBase __mro__.__len__() also as standalones (io_extra48); UnsupportedOperation/__qualname__/__module__/__bases__[0].__name__=='OSError' (io_extra33/io_extra19). No prior io spec covers __mro__.__len__() for FileIO, BufferedWriter, BufferedReader, or BufferedRandom. No prior io spec covers io.UnsupportedOperation.__bases__.__len__()==2 (it has two bases: OSError and ValueError). No prior io spec covers io.UnsupportedOperation.__mro__.__len__()==6."
    - "This spec covers: io.FileIO.__mro__.__len__()==4 (NOVEL — io_extra36/io_extra48 do not include FileIO in the MRO depth table; no prior io spec checks FileIO.__mro__.__len__()); io.BufferedWriter.__mro__.__len__()==4 (NOVEL — no prior io spec covers BufferedWriter.__mro__.__len__()); io.BufferedReader.__mro__.__len__()==4 (NOVEL — no prior io spec covers BufferedReader.__mro__.__len__()); io.BufferedRandom.__mro__.__len__()==4 (NOVEL — no prior io spec covers BufferedRandom at all in MRO context); io.UnsupportedOperation.__mro__.__len__()==6 (NOVEL — io_extra33 covers UnsupportedOperation qualname/module/base but not mro length); io.UnsupportedOperation.__bases__.__len__()==2 (NOVEL — UnsupportedOperation has two bases: OSError and ValueError; no prior io spec checks this multiple-inheritance count)."
    - "io.FileIO.__mro__ == [FileIO, _RawIOBase, _IOBase, object] (len 4). Concrete class inheriting directly from C-level _RawIOBase. io_extra36 covers StringIO/BytesIO in the MRO table but not FileIO. No prior io spec checks FileIO.__mro__.__len__(). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedWriter.__mro__ == [BufferedWriter, _BufferedIOBase, _IOBase, object] (len 4). Concrete buffered writer inheriting from C-level _BufferedIOBase directly. No prior io spec covers BufferedWriter.__mro__.__len__(). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedReader.__mro__ == [BufferedReader, _BufferedIOBase, _IOBase, object] (len 4). Concrete buffered reader inheriting from C-level _BufferedIOBase directly. No prior io spec covers BufferedReader.__mro__.__len__(). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedRandom.__mro__ == [BufferedRandom, _BufferedIOBase, _IOBase, object] (len 4). Concrete class for read-write buffered I/O, inheriting from C-level _BufferedIOBase directly. No prior io spec covers BufferedRandom in any MRO context. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.UnsupportedOperation.__mro__ == [UnsupportedOperation, OSError, ValueError, Exception, BaseException, object] (len 6). UnsupportedOperation inherits from both OSError and ValueError via multiple inheritance, giving a 6-entry MRO. io_extra33 covers __qualname__/__module__/__bases__[0].__name__ but not MRO length. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.UnsupportedOperation.__bases__.__len__() == 2. UnsupportedOperation has two direct base classes: OSError and ValueError. No prior io spec checks __bases__.__len__() for UnsupportedOperation; io_extra33 covers only __bases__[0].__name__=='OSError'. Novel multiple-inheritance count. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io concrete class MRO depths: FileIO, BufferedWriter, BufferedReader,
# BufferedRandom
#
# The concrete C-extension io classes inherit directly from private C-level
# base classes in the _io extension module, bypassing the public abstract
# wrappers. Their MROs therefore have exactly 4 entries:
#
#   FileIO.__mro__        == [FileIO, _RawIOBase, _IOBase, object]        -> 4
#   BufferedWriter.__mro__ == [BufferedWriter, _BufferedIOBase, _IOBase, object] -> 4
#   BufferedReader.__mro__ == [BufferedReader, _BufferedIOBase, _IOBase, object] -> 4
#   BufferedRandom.__mro__ == [BufferedRandom, _BufferedIOBase, _IOBase, object] -> 4
#
# io_extra36 covers IOBase(3)/StringIO(4)/BytesIO(4)/RawIOBase(5)/
# BufferedIOBase(5)/TextIOBase(5) in a table, but NOT FileIO, BufferedWriter,
# BufferedReader, or BufferedRandom.
# io_extra48 adds standalone invariants for IOBase/RawIOBase/BufferedIOBase/
# TextIOBase but again omits the four concrete classes above.
#
# All four are novel MRO depth anchors in the io_extra51 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra51.concrete_class_mro_depths:
  description: "io concrete class __mro__.__len__() values: FileIO(4)/BufferedWriter(4)/BufferedReader(4)/BufferedRandom(4) — each inherits directly from C-level _io private bases giving a 4-entry MRO; io_extra36 covers IOBase/StringIO/BytesIO/RawIOBase/BufferedIOBase/TextIOBase MRO depths but NOT these four; all four novel MRO depth anchors in io_extra51 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_structure
  id_prefix: ccmd51

  columns: [id, function, args, expected]
  rows:
    - [FileIO_mro,         FileIO.__mro__.__len__,         [], 4]
    - [BufferedWriter_mro, BufferedWriter.__mro__.__len__,  [], 4]
    - [BufferedReader_mro, BufferedReader.__mro__.__len__,  [], 4]
    - [BufferedRandom_mro, BufferedRandom.__mro__.__len__,  [], 4]

# ---------------------------------------------------------------------------
# io.UnsupportedOperation MRO depth and base class count
#
# UnsupportedOperation is a unique class in the io module: it uses multiple
# inheritance, directly subclassing both OSError and ValueError. This gives:
#
#   UnsupportedOperation.__bases__.__len__() == 2   (two direct base classes)
#   UnsupportedOperation.__mro__.__len__()   == 6
#     MRO: [UnsupportedOperation, OSError, ValueError, Exception,
#           BaseException, object]
#
# io_extra33 covers UnsupportedOperation.__qualname__=='UnsupportedOperation',
# __module__=='io', and __bases__[0].__name__=='OSError', but NOT the MRO
# length or the number of direct base classes.
# io_extra19 covers __bases__[0].__name__=='OSError' (earliest anchor).
#
# Both invariants are novel in the io_extra51 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant io_extra51.UnsupportedOperation_bases_len:
  description: "io.UnsupportedOperation.__bases__.__len__() == 2 — UnsupportedOperation has two direct base classes (OSError and ValueError); no prior io spec checks __bases__.__len__() for UnsupportedOperation; novel multiple-inheritance count in io_extra51 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_structure
  kind: python_call_eq
  function: "UnsupportedOperation.__bases__.__len__"
  args: []
  expected: 2

invariant io_extra51.UnsupportedOperation_mro_len:
  description: "io.UnsupportedOperation.__mro__.__len__() == 6 — MRO is [UnsupportedOperation, OSError, ValueError, Exception, BaseException, object]; io_extra33 covers qualname/module/base but not MRO length; novel in io_extra51 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_structure
  kind: python_call_eq
  function: UnsupportedOperation.__mro__.__len__
  args: []
  expected: 6
