spec: theseus_contextlib_cr
version: ">=3.8"
backend: python_cleanroom(theseus_contextlib_cr)
blocks: contextlib

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/contextlib.html"
  not_derived_from:
    - "CPython source: Lib/contextlib.py (internal implementation)"
  notes:
    - "Clean-room contextlib module. Do NOT import contextlib."
    - "contextmanager: decorator to create context managers from generators."
    - "closing: context manager calling .close() on exit."
    - "suppress: context manager to suppress specified exceptions."
    - "nullcontext: context manager that does nothing."

error_model: python_exceptions

invariant theseus_contextlib_cr.contextlib2_contextmanager:
  description: "contextmanager-decorated generator works as context manager"
  category: contextmanager
  kind: python_call_eq
  function: contextlib2_contextmanager
  args: []
  expected: true

invariant theseus_contextlib_cr.contextlib2_suppress:
  description: "suppress(ValueError) swallows ValueError without reraise"
  category: suppress
  kind: python_call_eq
  function: contextlib2_suppress
  args: []
  expected: true

invariant theseus_contextlib_cr.contextlib2_closing:
  description: "closing() calls .close() on exit"
  category: closing
  kind: python_call_eq
  function: contextlib2_closing
  args: []
  expected: true
