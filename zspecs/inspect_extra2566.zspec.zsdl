spec: inspect_extra2566
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/inspect.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2566 (_extra2566): __getattr__, __setattr__, __delattr__ dict-presence checks."
    - "inspect.Parameter: pure-Python class with frozen-style semantics (attributes set via object.__setattr__ in __init__) — does NOT define its own __setattr__ or __delattr__ in __dict__; mutation is blocked via a different mechanism."
    - "inspect.Signature: similar frozen-style class — no __setattr__, __delattr__, or __getattr__ in own __dict__."
    - "inspect.BoundArguments: pure-Python class — no __setattr__, __delattr__, or __getattr__ in own __dict__."
    - "inspect.FullArgSpec, ArgInfo, Traceback, Attribute, ClosureVars: namedtuple or NamedTuple subclasses — none define attribute access hooks."
    - "inspect._ParameterKind: IntEnum subclass — no attribute access hooks in own __dict__."
    - "inspect.EndOfBlock: simple exception class — no attribute access hooks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __setattr__ dict-presence for inspect types
#
# Despite inspect.Parameter and inspect.Signature having frozen-like
# semantics (direct attribute assignment raises AttributeError at runtime),
# neither class defines __setattr__ in its own __dict__.  The immutability
# is enforced by a different mechanism (the descriptor / slot protocol or
# explicit checks inside __init__), not a custom __setattr__.
# ---------------------------------------------------------------------------

table inspect_extra2566.setattr_protocol:
  description: "inspect types __setattr__ dict-presence checks — all False — wave 2566 _extra2566"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2566

  columns: [id, function, args, expected]
  rows:
    - ["in2566001", "inspect.Parameter.__dict__.__contains__", ["__setattr__"], false]
    - ["in2566002", "inspect.Signature.__dict__.__contains__", ["__setattr__"], false]
    - ["in2566003", "inspect.BoundArguments.__dict__.__contains__", ["__setattr__"], false]
    - ["in2566004", "inspect.FullArgSpec.__dict__.__contains__", ["__setattr__"], false]
    - ["in2566005", "inspect.Attribute.__dict__.__contains__", ["__setattr__"], false]

# ---------------------------------------------------------------------------
# Table 2: __delattr__ dict-presence for inspect types
#
# No inspect class defines __delattr__ in its own __dict__.  Deletion
# semantics for frozen-like types such as Parameter and Signature are
# similarly handled without a custom __delattr__.
# ---------------------------------------------------------------------------

table inspect_extra2566.delattr_protocol:
  description: "inspect types __delattr__ dict-presence checks — all False — wave 2566 _extra2566"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2566

  columns: [id, function, args, expected]
  rows:
    - ["in2566006", "inspect.Parameter.__dict__.__contains__", ["__delattr__"], false]
    - ["in2566007", "inspect.Signature.__dict__.__contains__", ["__delattr__"], false]
    - ["in2566008", "inspect.BoundArguments.__dict__.__contains__", ["__delattr__"], false]
    - ["in2566009", "inspect.ArgInfo.__dict__.__contains__", ["__delattr__"], false]
    - ["in2566010", "inspect.Traceback.__dict__.__contains__", ["__delattr__"], false]

# ---------------------------------------------------------------------------
# Table 3: __getattr__ dict-presence for inspect types
#
# No inspect class defines __getattr__ in its own __dict__.  The inspect
# classes do not need fallback attribute lookup — all attributes are
# either declared as properties or stored as plain instance attributes.
# ---------------------------------------------------------------------------

table inspect_extra2566.getattr_protocol:
  description: "inspect types __getattr__ dict-presence checks — all False — wave 2566 _extra2566"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2566

  columns: [id, function, args, expected]
  rows:
    - ["in2566011", "inspect.Parameter.__dict__.__contains__", ["__getattr__"], false]
    - ["in2566012", "inspect.Signature.__dict__.__contains__", ["__getattr__"], false]
    - ["in2566013", "inspect.BoundArguments.__dict__.__contains__", ["__getattr__"], false]
    - ["in2566014", "inspect.FullArgSpec.__dict__.__contains__", ["__getattr__"], false]
    - ["in2566015", "inspect.ClosureVars.__dict__.__contains__", ["__getattr__"], false]

# ---------------------------------------------------------------------------
# Table 4: cross-class attribute-protocol summary for core inspect types
#
# Confirms the complete picture: inspect.Parameter and inspect.Signature
# define none of __getattr__, __setattr__, or __delattr__ in their own
# __dict__, and neither do the other core inspect introspection types.
# The pattern holds across namedtuple-based types, IntEnum subclasses,
# and pure-Python mutable containers like BoundArguments.
# ---------------------------------------------------------------------------

table inspect_extra2566.attr_protocol_summary:
  description: "inspect core types full attribute-protocol dict-presence summary — wave 2566 _extra2566"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2566

  columns: [id, function, args, expected]
  rows:
    - ["in2566016", "inspect._ParameterKind.__dict__.__contains__", ["__getattr__"], false]
    - ["in2566017", "inspect._ParameterKind.__dict__.__contains__", ["__setattr__"], false]
    - ["in2566018", "inspect.EndOfBlock.__dict__.__contains__", ["__getattr__"], false]
    - ["in2566019", "inspect.ClosureVars.__dict__.__contains__", ["__setattr__"], false]
    - ["in2566020", "inspect.Traceback.__dict__.__contains__", ["__getattr__"], false]
