spec: just_values
version: ">=2.2.0"
backend: node(just-values)

docs: https://www.npmjs.com/package/just-values

provenance:
  derived_from:
    - "just-values README — https://www.npmjs.com/package/just-values"
    - "Test vectors verified with just-values via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "just-values source"
  notes:
    - "just-values is an npm package. Install: npm install just-values"
    - "The module exports a single function that returns an array of an object's own enumerable values."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array of the object's values."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_values.values:
  kind: node_module_call_eq
  function: ~
  category: transform
  id_prefix: jvals

  columns: [id, args, expected]
  rows:
    - [two_keys, [{"a": 1, "b": 2}], [1, 2]]
    - [single,   [{"x": 42}],        [42]]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:11:19Z
  iterations: 1
  pass_count: 2
  fail_count: 0
  total_invariants: 2
  notes: Synthesis succeeded in 1 iteration(s). 2 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
