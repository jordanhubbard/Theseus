spec: execa
version: ">=9.0.0"
backend: node(execa)

docs: https://github.com/sindresorhus/execa#readme

provenance:
  derived_from:
    - "execa README — https://github.com/sindresorhus/execa#readme"
    - "Test vectors verified with execa via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "execa source"
  notes:
    - "Better child_process — auto-handles encoding, escaping, and the Windows shim layer."
    - "Install: npm install execa"
    - "v9 ESM only; named export execaSync runs synchronously and returns a result with stdout/stderr/exitCode."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws on non-zero exit unless reject:false is set; otherwise returns result with .failed=true."
  stderr: "captured into result.stderr"
  stickiness: "N/A — each call independent."
  codes: {}

invariant execa.execaSync_echo_stdout:
  description: "execaSync('echo', ['hello']).stdout is 'hello'"
  category: sync
  kind: node_chain_eq
  entry: named
  function: execaSync
  entry_args: ["echo", ["hello"]]
  chain:
    - {get: stdout}
  expected: "hello"

invariant execa.execaSync_exitCode_zero:
  description: "Successful command has exitCode 0"
  category: sync
  kind: node_chain_eq
  entry: named
  function: execaSync
  entry_args: ["echo", ["hi"]]
  chain:
    - {get: exitCode}
  expected: 0

invariant execa.execaSync_failed_false:
  description: "Successful command has failed === false"
  category: sync
  kind: node_chain_eq
  entry: named
  function: execaSync
  entry_args: ["echo", ["hi"]]
  chain:
    - {get: failed}
  expected: false

invariant execa.execaSync_command_round_trip:
  description: "result.command echoes the executed command line"
  category: sync
  kind: node_chain_eq
  entry: named
  function: execaSync
  entry_args: ["echo", ["hello"]]
  chain:
    - {get: command}
  expected: "echo hello"

invariant execa.execaSync_timedOut_false:
  description: "Command that finishes in time has timedOut === false"
  category: sync
  kind: node_chain_eq
  entry: named
  function: execaSync
  entry_args: ["echo", ["hi"]]
  chain:
    - {get: timedOut}
  expected: false

invariant execa.execaSync_isCanceled_false:
  description: "Successful execaSync has isCanceled === false"
  category: sync
  kind: node_chain_eq
  entry: named
  function: execaSync
  entry_args: ["echo", ["hi"]]
  chain:
    - {get: isCanceled}
  expected: false

invariant execa.execaSync_durationMs_is_number:
  description: "result.durationMs is a Number"
  category: sync
  kind: node_chain_eq
  entry: named
  function: execaSync
  entry_args: ["echo", ["hi"]]
  chain:
    - {get: "durationMs.constructor.name"}
  expected: "Number"
