    - [cf1201eh002, concurrent.futures.ThreadPoolExecutor.__bases__.__len__,  [], 1]
    - [cf1201eh003, concurrent.futures.ProcessPoolExecutor.__bases__.__len__, [], 1]
    - [cf1201eh004, concurrent.futures.Executor.__bases__.__class__.__name__.__eq__,            ["tuple"], true]
    - [cf1201eh005, concurrent.futures.ThreadPoolExecutor.__bases__.__class__.__name__.__eq__,  ["tuple"], true]
    - [cf1201eh006, concurrent.futures.ProcessPoolExecutor.__bases__.__class__.__name__.__eq__, ["tuple"], true]
