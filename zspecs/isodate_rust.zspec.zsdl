spec: isodate_rust
version: ">=3.9"
backend: rust_module(isodate_rust)

docs: https://isodate.readthedocs.io/en/latest/

provenance:
  derived_from:
    - "https://isodate.readthedocs.io/ — isodate documentation"
    - "ISO 8601 — Representation of dates and times"
  not_derived_from:
    - "isodate source: src/isodate/isoduration.py"
  notes:
    - "isodate.parse_duration(iso_str) parses ISO 8601 duration strings to timedelta."
    - "parse_duration('PT1H').total_seconds() == 3600.0 — 1 hour."
    - "parse_duration('PT30M').total_seconds() == 1800.0 — 30 minutes."
    - "parse_duration('PT1M30S').total_seconds() == 90.0 — 1 minute 30 seconds."
    - "parse_duration('P1D').total_seconds() == 86400.0 — 1 day."
    - "parse_duration('PT2H30M').total_seconds() == 9000.0 — 2.5 hours."
    - "isodate.duration_isoformat(timedelta(hours=2)) == 'PT2H'."
    - "Expose parse_duration_seconds(iso_str) -> float for convenience."
    - "All test vectors verified against isodate 0.6.1."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# parse_duration — ISO 8601 duration string to seconds
table isodate_rust.parse_duration.total_seconds:
  kind: python_call_eq
  category: parse_duration
  id_prefix: iso_pd
  function: parse_duration
  method: total_seconds
  method_args: []

  columns: [id, args, expected]
  rows:
    - [one_hour,    ["PT1H"],    3600.0]
    - [thirty_min,  ["PT30M"],   1800.0]
    - [ninety_sec,  ["PT1M30S"], 90.0]
    - [one_day,     ["P1D"],     86400.0]
    - [two_half_hr, ["PT2H30M"], 9000.0]
    - [zero,        ["PT0S"],    0.0]

# duration_isoformat — timedelta to ISO 8601 string (via pre-wired function)
table isodate_rust.duration_isoformat.vectors:
  kind: python_call_eq
  category: duration_isoformat
  id_prefix: iso_df
  function: timedelta_to_isoformat

  columns: [id, args, expected]
  rows:
    - [two_hours,   [7200],    "PT2H"]
    - [one_hour,    [3600],    "PT1H"]
    - [thirty_min,  [1800],    "PT30M"]
    - [one_day,     [86400],   "P1D"]

