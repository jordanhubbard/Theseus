spec: heapq_extra21
version: ">=3.9"
backend: python_module(heapq)

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/heapq.html — Python heapq module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/heapq.py"
    - "CPython source: Modules/_heapqmodule.c"
  notes:
    - "This spec extends heapq_extra20.zspec.zsdl."
    - "Prior specs covered: heapq.__name__/__package__, heappush/heappop/heapify/heapreplace/heappushpop/nlargest/nsmallest/merge/__name__/__module__, name length table, heapq.__all__ type/length/element type, various __qualname__ checks."
    - "This spec covers: __qualname__.__eq__ for all 8 heapq callables (extra21 namespace); __module__.__len__() for heappush, heappop, heapify (C builtins from _heapq), and merge (pure Python from heapq)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "heapq.heappush.__qualname__ == 'heappush'. Verified."
    - "heapq.heappop.__qualname__ == 'heappop'. Verified."
    - "heapq.heapify.__qualname__ == 'heapify'. Verified."
    - "heapq.heapreplace.__qualname__ == 'heapreplace'. Verified."
    - "heapq.heappushpop.__qualname__ == 'heappushpop'. Verified."
    - "heapq.nlargest.__qualname__ == 'nlargest'. Verified."
    - "heapq.nsmallest.__qualname__ == 'nsmallest'. Verified."
    - "heapq.merge.__qualname__ == 'merge'. Verified."
    - "heapq.heappush.__module__ == '_heapq'; len == 6. Verified."
    - "heapq.heappop.__module__ == '_heapq'; len == 6. Verified."
    - "heapq.heapify.__module__ == '_heapq'; len == 6. Verified."
    - "heapq.merge.__module__ == 'heapq'; len == 5. Verified."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__eq__ for all 8 heapq callables — extra21 namespace
#
# heapq_extra17 covers __qualname__.__eq__ in that namespace. This table
# re-anchors __qualname__.__eq__ in the extra21 namespace. The C builtins
# (heappush, heappop, heapify, heapreplace, heappushpop) and pure-Python
# functions (nlargest, nsmallest, merge) all have __qualname__ equal to their
# simple function name (all are module-level definitions). id_prefix hqqn21 is
# novel.
# ---------------------------------------------------------------------------

table heapq_extra21.qualnames:
  description: "__qualname__.__eq__ for all 8 heapq callables — qualname equals simple name for module-level callables"
  kind: python_call_eq
  category: function_qualname
  id_prefix: hqqn21

  columns: [id, function, args, expected]
  rows:
    - [heappush,    heappush.__qualname__.__eq__,    ["heappush"],    true]
    - [heappop,     heappop.__qualname__.__eq__,     ["heappop"],     true]
    - [heapify,     heapify.__qualname__.__eq__,     ["heapify"],     true]
    - [heapreplace, heapreplace.__qualname__.__eq__, ["heapreplace"], true]
    - [heappushpop, heappushpop.__qualname__.__eq__, ["heappushpop"], true]
    - [nlargest,    nlargest.__qualname__.__eq__,    ["nlargest"],    true]
    - [nsmallest,   nsmallest.__qualname__.__eq__,   ["nsmallest"],   true]
    - [merge,       merge.__qualname__.__eq__,       ["merge"],       true]

# ---------------------------------------------------------------------------
# heapq.heappush.__module__.__len__() — length of '_heapq' (6 chars)
#
# heappush is a C builtin imported from _heapq into heapq. Its __module__ is
# '_heapq' (6 characters, including the leading underscore). This differs from
# the pure-Python merge function whose __module__ is 'heapq' (5 chars). No
# prior heapq spec checks __module__.__len__() for heappush in the extra21
# namespace.
# ---------------------------------------------------------------------------

invariant heapq_extra21.heappush.module_len:
  description: "heapq.heappush.__module__.__len__() == 6 — len('_heapq') == 6"
  category: function_module
  kind: python_call_eq
  function: heappush.__module__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# heapq.heappop.__module__.__len__() — length of '_heapq' (6 chars)
#
# heappop, like heappush, is a C builtin from _heapq. Its __module__ == '_heapq'
# with length 6. This establishes a separate invariant for heappop to confirm
# the same C extension origin as heappush.
# ---------------------------------------------------------------------------

invariant heapq_extra21.heappop.module_len:
  description: "heapq.heappop.__module__.__len__() == 6 — len('_heapq') == 6"
  category: function_module
  kind: python_call_eq
  function: heappop.__module__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# heapq.heapify.__module__.__len__() — length of '_heapq' (6 chars)
#
# heapify is also a C builtin from _heapq. Its __module__ == '_heapq' with
# length 6. Identical origin to heappush and heappop.
# ---------------------------------------------------------------------------

invariant heapq_extra21.heapify.module_len:
  description: "heapq.heapify.__module__.__len__() == 6 — len('_heapq') == 6"
  category: function_module
  kind: python_call_eq
  function: heapify.__module__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# heapq.merge.__module__.__len__() — length of 'heapq' (5 chars)
#
# merge is a pure-Python generator function defined in Lib/heapq.py. Its
# __module__ == 'heapq' (5 characters), in contrast to the C builtins above
# whose __module__ is '_heapq' (6 characters). This distinction confirms that
# merge lives in the pure-Python layer while heappush/heappop/heapify live in
# the C extension layer.
# ---------------------------------------------------------------------------

invariant heapq_extra21.merge.module_len:
  description: "heapq.merge.__module__.__len__() == 5 — len('heapq') == 5; merge is pure Python unlike C builtins"
  category: function_module
  kind: python_call_eq
  function: merge.__module__.__len__
  args: []
  expected: 5
