table asyncio_extra73.Queue_qsize_empty_code:
  description: "asyncio Queue.qsize and Queue.empty code object attribute checks in asynciomore73 namespace — wave 239 theme: Queue method code attributes; Queue.qsize.__code__.co_name=='qsize'; Queue.qsize.__code__.co_argcount==1 (just self); Queue.empty.__code__.co_name=='empty'; Queue.empty.__code__.co_argcount==1 (just self); verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: asynciomore73a

  columns: [id, function, args, expected, description]
  rows:
    - [queue_qsize_co_name,     Queue.qsize.__code__.co_name.__eq__,     ["qsize"], true, "Queue.qsize.__code__.co_name == 'qsize' — asyncio.Queue.qsize is a pure Python method; verified with Python 3.14.3"]
    - [queue_qsize_co_argcount, Queue.qsize.__code__.co_argcount.__eq__, [1],       true, "Queue.qsize.__code__.co_argcount == 1 — Queue.qsize takes only self; verified with Python 3.14.3"]
    - [queue_empty_co_name,     Queue.empty.__code__.co_name.__eq__,     ["empty"], true, "Queue.empty.__code__.co_name == 'empty' — asyncio.Queue.empty is a pure Python method; verified with Python 3.14.3"]
    - [queue_empty_co_argcount, Queue.empty.__code__.co_argcount.__eq__, [1],       true, "Queue.empty.__code__.co_argcount == 1 — Queue.empty takes only self; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.run class and code object checks — extra73
#
# asyncio.run.__class__.__name__ == 'function'
# asyncio.run.__code__.co_name == 'run'
# asyncio.run.__code__.co_argcount == 1 (just coro; debug/loop_factory keyword-only)
# ---------------------------------------------------------------------------

table asyncio_extra73.run_class_code:
  description: "asyncio.run __class__.__name__ and code object attribute checks in asynciomore73 namespace — wave 239 theme: asyncio run function; run.__class__.__name__=='function' (asyncio.run is a plain Python function); run.__code__.co_name=='run'; run.__code__.co_argcount==1 (coro only; debug and loop_factory are keyword-only); verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: asynciomore73b

  columns: [id, function, args, expected, description]
  rows:
    - [run_class_name,     run.__class__.__name__.__eq__,     ["function"], true, "asyncio.run.__class__.__name__ == 'function' — asyncio.run is a plain Python function, not a method or builtin; verified with Python 3.14.3"]
    - [run_co_name,        run.__code__.co_name.__eq__,        ["run"],      true, "asyncio.run.__code__.co_name == 'run' — asyncio.run code object co_name is 'run'; verified with Python 3.14.3"]
    - [run_co_argcount,    run.__code__.co_argcount.__eq__,    [1],          true, "asyncio.run.__code__.co_argcount == 1 — coro is the sole positional-or-keyword parameter; debug and loop_factory are keyword-only; verified with Python 3.14.3"]

