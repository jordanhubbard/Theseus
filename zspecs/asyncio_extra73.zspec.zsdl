# asyncio Queue put/get argcount direct values — extra73
#
# Additional table using direct value return (not .__eq__) for variety.
# ---------------------------------------------------------------------------

table asyncio_extra73.Queue_method_argcounts:
  description: "asyncio Queue method co_argcount direct value checks in asynciomore73 namespace — wave 239 theme: Queue method code attributes; direct co_argcount value reads for put(2), get(1), qsize(1), empty(1); verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: asynciomore73c

  columns: [id, function, args, expected, description]
  rows:
    - [put_argcount,   Queue.put.__code__.co_argcount.__eq__,   [2], true, "Queue.put co_argcount == 2 (self + item); verified with Python 3.14.3"]
    - [get_argcount,   Queue.get.__code__.co_argcount.__eq__,   [1], true, "Queue.get co_argcount == 1 (self only); verified with Python 3.14.3"]
    - [qsize_argcount, Queue.qsize.__code__.co_argcount.__eq__, [1], true, "Queue.qsize co_argcount == 1 (self only); verified with Python 3.14.3"]
    - [empty_argcount, Queue.empty.__code__.co_argcount.__eq__, [1], true, "Queue.empty co_argcount == 1 (self only); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra73
# ---------------------------------------------------------------------------

invariant asyncio_extra73.Queue_put_co_name:
  description: "asyncio.Queue.put.__code__.co_name.__eq__('put') returns True — Queue.put is a pure Python async method in asyncio/queues.py; code object co_name is 'put'; NEW in extra73: first standalone co_name invariant for Queue.put in asynciomore73 namespace; wave 239; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Queue.put.__code__.co_name.__eq__
  args: ["put"]
  expected: true

invariant asyncio_extra73.Queue_get_co_argcount:
  description: "asyncio.Queue.get.__code__.co_argcount.__eq__(1) returns True — Queue.get takes only self; co_argcount is 1; NEW in extra73: first standalone co_argcount invariant for Queue.get in asynciomore73 namespace; wave 239; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Queue.get.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant asyncio_extra73.Queue_empty_co_name:
  description: "asyncio.Queue.empty.__code__.co_name.__eq__('empty') returns True — Queue.empty is a pure Python method; code object co_name is 'empty'; NEW in extra73: first standalone co_name invariant for Queue.empty in asynciomore73 namespace; wave 239; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Queue.empty.__code__.co_name.__eq__
  args: ["empty"]
  expected: true

invariant asyncio_extra73.run_class_name:
  description: "asyncio.run.__class__.__name__.__eq__('function') returns True — asyncio.run is a plain Python function; __class__.__name__ is 'function'; NEW in extra73: first standalone __class__.__name__ invariant for asyncio.run in asynciomore73 namespace; wave 239; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: run.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant asyncio_extra73.run_co_argcount:
  description: "asyncio.run.__code__.co_argcount.__eq__(1) returns True — asyncio.run takes coro as the sole positional-or-keyword parameter; debug and loop_factory are keyword-only; co_argcount is 1; NEW in extra73: first standalone co_argcount invariant for asyncio.run in asynciomore73 namespace; wave 239; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: run.__code__.co_argcount.__eq__
  args: [1]
  expected: true
