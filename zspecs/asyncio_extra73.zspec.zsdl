spec: asyncio_extra73
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queues"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks and Coroutines"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/runners.py"
  notes:
    - "This spec extends asyncio_extra72.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition __name__/__module__/__qualname__, Task/Future __name__/__module__/__qualname__/__class__.__name__, CancelledError/InvalidStateError/TimeoutError identity, QueueEmpty/QueueFull identity, gather/sleep/wait/__name__/__qualname__, class __dict__/__mro__/__all__ metadata, method qualname/name equality and length tables, __loader__/__spec__/__file__/__cached__ class names, __spec__ attributes, code object attribute chains, __defaults__/__kwdefaults__ class names, exception hierarchy, Queue/Lock/Event/Semaphore __init__ code object attributes, Condition/BoundedSemaphore __init__ code objects, TaskGroup identity, gather code object."
    - "This spec covers (asynciomore73 namespace): wave 239 theme — asyncio Queue/Task deeper code attributes + run function. NEW in extra73: Queue.put/__code__/co_name=='put'; Queue.put/__code__/co_argcount==2 (self+item); Queue.get/__code__/co_name=='get'; Queue.get/__code__/co_argcount==1 (just self); Queue.qsize/__code__/co_name=='qsize'; Queue.qsize/__code__/co_argcount==1; Queue.empty/__code__/co_name=='empty'; Queue.empty/__code__/co_argcount==1; asyncio.run.__class__.__name__=='function'; asyncio.run/__code__/co_name=='run'; asyncio.run/__code__/co_argcount==1."
    - "asyncio.Queue.put.__code__.co_name == 'put'. Queue.put is a pure Python async method in asyncio/queues.py; its code object's co_name is 'put'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.put.__code__.co_argcount == 2. Queue.put signature is async def put(self, item): — 2 positional-or-keyword parameters (self + item). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.get.__code__.co_name == 'get'. Queue.get is a pure Python async method; its code object's co_name is 'get'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.get.__code__.co_argcount == 1. Queue.get takes only self; co_argcount is 1. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.qsize.__code__.co_name == 'qsize'. Queue.qsize is a pure Python method; its code object's co_name is 'qsize'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.qsize.__code__.co_argcount == 1. Queue.qsize takes only self; co_argcount is 1. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.empty.__code__.co_name == 'empty'. Queue.empty is a pure Python method; its code object's co_name is 'empty'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.empty.__code__.co_argcount == 1. Queue.empty takes only self; co_argcount is 1. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.run.__class__.__name__ == 'function'. asyncio.run is a regular Python function (not a method or builtin); __class__.__name__ is 'function'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.run.__code__.co_name == 'run'. asyncio.run is a pure Python function in asyncio/runners.py; its code object's co_name is 'run'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.run.__code__.co_argcount == 1. asyncio.run signature is def run(coro, *, debug=None, loop_factory=None): — 1 positional-or-keyword parameter (coro); debug and loop_factory are keyword-only. co_argcount is 1. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Queue.put and Queue.get code object checks — extra73
#
# Wave 239 theme: asyncio Queue/Task deeper code attributes + run function.
#
# Queue.put.__code__.co_name == 'put'
# Queue.put.__code__.co_argcount == 2 (self + item)
# Queue.get.__code__.co_name == 'get'
# Queue.get.__code__.co_argcount == 1 (just self)
# ---------------------------------------------------------------------------

table asyncio_extra73.Queue_put_get_code:
  description: "asyncio Queue.put and Queue.get code object attribute checks in asynciomore73 namespace — wave 239 theme: Queue method code attributes; Queue.put.__code__.co_name=='put' (pure Python async method in asyncio/queues.py); Queue.put.__code__.co_argcount==2 (self+item); Queue.get.__code__.co_name=='get'; Queue.get.__code__.co_argcount==1 (just self); verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: asynciomore73

  columns: [id, function, args, expected, description]
  rows:
    - [queue_put_co_name,     Queue.put.__code__.co_name.__eq__,     ["put"], true, "Queue.put.__code__.co_name == 'put' — asyncio.Queue.put is a pure Python async method in asyncio/queues.py; verified with Python 3.14.3"]
    - [queue_put_co_argcount, Queue.put.__code__.co_argcount.__eq__, [2],     true, "Queue.put.__code__.co_argcount == 2 — Queue.put takes self + item; verified with Python 3.14.3"]
    - [queue_get_co_name,     Queue.get.__code__.co_name.__eq__,     ["get"], true, "Queue.get.__code__.co_name == 'get' — asyncio.Queue.get is a pure Python async method; verified with Python 3.14.3"]
    - [queue_get_co_argcount, Queue.get.__code__.co_argcount.__eq__, [1],     true, "Queue.get.__code__.co_argcount == 1 — Queue.get takes only self; verified with Python 3.14.3"]

