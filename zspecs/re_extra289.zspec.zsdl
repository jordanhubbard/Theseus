spec: re_extra289
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — compiled Pattern and Match method identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_sre.c, Lib/re/__init__.py"
  notes:
    - "re.Pattern and re.Match are the compiled pattern and match result types"
    - "__qualname__ attributes verified for Pattern and Match methods"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table re_extra289.pattern_method_qualnames:
  description: "re.Pattern method __qualname__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: rep289

  columns: [id, function, args, expected, description]
  rows:
    - [rep289_001, re.Pattern.match.__qualname__, [], "Pattern.match", "Pattern.match qualname"]
    - [rep289_002, re.Pattern.search.__qualname__, [], "Pattern.search", "Pattern.search qualname"]
    - [rep289_003, re.Pattern.findall.__qualname__, [], "Pattern.findall", "Pattern.findall qualname"]
    - [rep289_004, re.Pattern.finditer.__qualname__, [], "Pattern.finditer", "Pattern.finditer qualname"]
    - [rep289_005, re.Pattern.sub.__qualname__, [], "Pattern.sub", "Pattern.sub qualname"]
    - [rep289_006, re.Pattern.subn.__qualname__, [], "Pattern.subn", "Pattern.subn qualname"]
    - [rep289_007, re.Pattern.split.__qualname__, [], "Pattern.split", "Pattern.split qualname"]
    - [rep289_008, re.Pattern.fullmatch.__qualname__, [], "Pattern.fullmatch", "Pattern.fullmatch qualname"]

table re_extra289.match_method_qualnames:
  description: "re.Match method __qualname__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: rem289

  columns: [id, function, args, expected, description]
  rows:
    - [rem289_001, re.Match.group.__qualname__, [], "Match.group", "Match.group qualname"]
    - [rem289_002, re.Match.groups.__qualname__, [], "Match.groups", "Match.groups qualname"]
    - [rem289_003, re.Match.groupdict.__qualname__, [], "Match.groupdict", "Match.groupdict qualname"]
    - [rem289_004, re.Match.start.__qualname__, [], "Match.start", "Match.start qualname"]
    - [rem289_005, re.Match.end.__qualname__, [], "Match.end", "Match.end qualname"]
    - [rem289_006, re.Match.span.__qualname__, [], "Match.span", "Match.span qualname"]
    - [rem289_007, re.Match.expand.__qualname__, [], "Match.expand", "Match.expand qualname"]

invariant re_extra289.pattern_match_qualname:
  description: "Pattern.match qualname is confirmed"
  category: identity
  kind: python_call_eq
  function: re.Pattern.match.__qualname__
  args: []
  expected: "Pattern.match"

invariant re_extra289.pattern_sub_qualname:
  description: "Pattern.sub qualname is confirmed"
  category: identity
  kind: python_call_eq
  function: re.Pattern.sub.__qualname__
  args: []
  expected: "Pattern.sub"

invariant re_extra289.match_group_qualname:
  description: "Match.group qualname is confirmed"
  category: identity
  kind: python_call_eq
  function: re.Match.group.__qualname__
  args: []
  expected: "Match.group"

invariant re_extra289.match_span_qualname:
  description: "Match.span qualname is confirmed"
  category: identity
  kind: python_call_eq
  function: re.Match.span.__qualname__
  args: []
  expected: "Match.span"
