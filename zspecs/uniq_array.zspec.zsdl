spec: uniq_array
version: ">=1.0.1"
backend: node(uniq-array)

docs: https://www.npmjs.com/package/uniq-array

provenance:
  derived_from:
    - "uniq-array README — https://www.npmjs.com/package/uniq-array"
    - "Test vectors verified with uniq-array via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "uniq-array source"
  notes:
    - "uniq-array is an npm package. Install: npm install uniq-array"
    - "Returns a new array with duplicate values removed, preserving first occurrence."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table uniq_array.dedupe:
  kind: node_module_call_eq
  function: ~
  category: arrays
  id_prefix: uniqarr

  columns: [id, args, expected]
  rows:
    - [numbers, [[1, 2, 2, 3, 3, 3]], [1, 2, 3]]
    - [strings, [["a", "b", "a"]],    ["a", "b"]]
    - [already, [[1, 2, 3]],          [1, 2, 3]]

