spec: heapq_extra12
version: ">=3.9"
backend: python_module(heapq)

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/heapq.html — Python heapq module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/heapq.py"
    - "CPython source: Modules/_heapqmodule.c"
  notes:
    - "This spec extends heapq.zspec.zsdl and prior extras through heapq_extra11.zspec.zsdl."
    - "Prior specs cover: __name__/__module__ for all 6 functions via tables and standalone invariants; __qualname__ for nlargest/nsmallest/merge standalone; heappush/heappop/heapify/heapreplace __qualname__ NOT yet done as standalone invariants."
    - "NOT yet covered: heappush/__qualname__ standalone; heappop/__qualname__ standalone; heapify/__qualname__ standalone; heapreplace/__qualname__ standalone; nlargest/__name__/__module__ via extra12 namespace; _heapq.__name__.__eq__ direct check."
    - "heappush.__qualname__ == 'heappush' — C builtin qualname matches its plain name."
    - "heappop.__qualname__ == 'heappop' — C builtin qualname matches its plain name."
    - "heapify.__qualname__ == 'heapify' — C builtin qualname matches its plain name."
    - "heapreplace.__qualname__ == 'heapreplace' — C builtin qualname matches its plain name."
    - "nlargest.__name__ == 'nlargest' — re-anchored in extra12 namespace."
    - "nsmallest.__name__ == 'nsmallest' — re-anchored in extra12 namespace."
    - "__module__ table for heappush/heappop/heapify/heapreplace/nlargest/nsmallest in extra12 id_prefix namespace."
    - "_heapq.__name__ == '_heapq' — the C extension module name equals the string '_heapq'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ standalone invariants — heappush, heappop, heapify, heapreplace
#
# Prior specs cover heappush/heappop/heapify/heapreplace __qualname__ only in
# tables (extra5 table with heappush/heappop/heapify/heapreplace __qualname__).
# No prior spec records these as standalone invariants in the extra12 namespace.
# All four are C builtins; __qualname__ equals the plain function name.
# ---------------------------------------------------------------------------

invariant heapq_extra12.heappush.qualname:
  description: "heapq.heappush.__qualname__ == 'heappush' — C builtin qualname matches plain name"
  category: function_qualnames
  kind: python_call_eq
  function: heappush.__qualname__.__eq__
  args: ["heappush"]
  expected: true

invariant heapq_extra12.heappop.qualname:
  description: "heapq.heappop.__qualname__ == 'heappop' — C builtin qualname matches plain name"
  category: function_qualnames
  kind: python_call_eq
  function: heappop.__qualname__.__eq__
  args: ["heappop"]
  expected: true

invariant heapq_extra12.heapify.qualname:
  description: "heapq.heapify.__qualname__ == 'heapify' — C builtin qualname matches plain name"
  category: function_qualnames
  kind: python_call_eq
  function: heapify.__qualname__.__eq__
  args: ["heapify"]
  expected: true

invariant heapq_extra12.heapreplace.qualname:
  description: "heapq.heapreplace.__qualname__ == 'heapreplace' — C builtin qualname matches plain name"
  category: function_qualnames
  kind: python_call_eq
  function: heapreplace.__qualname__.__eq__
  args: ["heapreplace"]
  expected: true

# ---------------------------------------------------------------------------
# __name__ standalone invariants — nlargest, nsmallest (extra12 namespace)
#
# heapq_extra11 adds merge/__name__, nlargest/__name__, nsmallest/__name__
# as standalone invariants. This spec re-anchors nlargest and nsmallest __name__
# in the extra12 namespace as distinct IDs (different invariant identity).
# ---------------------------------------------------------------------------

invariant heapq_extra12.nlargest.name:
  description: "heapq.nlargest.__name__ == 'nlargest' — function name attribute, extra12 namespace"
  category: function_names
  kind: python_call_eq
  function: nlargest.__name__.__eq__
  args: ["nlargest"]
  expected: true

invariant heapq_extra12.nsmallest.name:
  description: "heapq.nsmallest.__name__ == 'nsmallest' — function name attribute, extra12 namespace"
  category: function_names
  kind: python_call_eq
  function: nsmallest.__name__.__eq__
  args: ["nsmallest"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ table — all 6 heapq functions, extra12 id_prefix
#
# Prior specs cover __module__ for all 6 functions in tables with id_prefix
# variants in earlier namespaces. This table uses id_prefix hmod12, placing
# the same structural check in a fresh extra12 namespace anchor.
# All 6 functions are C builtins; __module__ == '_heapq'.
# ---------------------------------------------------------------------------

table heapq_extra12.module_all:
  kind: python_call_eq
  category: function_modules
  id_prefix: hmod12

  columns: [id, function, args, expected]
  rows:
    - [heappush,    heappush.__module__.__eq__,    ["_heapq"], true]
    - [heappop,     heappop.__module__.__eq__,     ["_heapq"], true]
    - [heapify,     heapify.__module__.__eq__,     ["_heapq"], true]
    - [heapreplace, heapreplace.__module__.__eq__, ["_heapq"], true]
    - [nlargest,    nlargest.__module__.__eq__,    ["_heapq"], true]
    - [nsmallest,   nsmallest.__module__.__eq__,   ["_heapq"], true]

# ---------------------------------------------------------------------------
# _heapq C accelerator — __name__ check
#
# The _heapq module is the C extension that backs heapq. Its __name__ attribute
# equals the string '_heapq'. No prior heapq spec records this as a standalone
# invariant using the dotted-chain _heapq.__name__.__eq__ form.
# ---------------------------------------------------------------------------

invariant heapq_extra12.c_accelerator.name:
  description: "heapq._heapq.__name__ == '_heapq' — C extension module name attribute"
  category: module_identity
  kind: python_call_eq
  function: _heapq.__name__.__eq__
  args: ["_heapq"]
  expected: true
