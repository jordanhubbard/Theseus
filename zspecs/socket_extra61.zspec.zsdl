spec: socket_extra61
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra60.zspec.zsdl — covers socket.socket recv_into/recvfrom_into/getblocking/get_inheritable/set_inheritable __qualname__.__eq__ string values (table + invariants)."
    - "socket_extra59.zspec.zsdl — covers socket.__spec__.origin.__class__.__name__.__eq__('str') / submodule_search_locations.__class__.__name__.__eq__('NoneType') / has_location==True / __loader__.__class__.__name__.__len__()==16 (table + invariants)."
    - "socket_extra58.zspec.zsdl — covers socket.__loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__.__class__.__name__.__eq__('str') / __cached__.__class__.__name__.__eq__('str') (table + invariant)."
    - "socket_extra50.zspec.zsdl — covers socket.socket.connect/bind/listen/accept/send/recv/close __qualname__.__eq__ string values."
    - "socket_extra44.zspec.zsdl — covers socket.socket recvfrom/sendto/connect_ex/recv_into/recvfrom_into __name__.__eq__ string values (__name__ axis only)."
    - "socket_extra42.zspec.zsdl — covers socket.socket shutdown/sendall/recvfrom/sendto/connect_ex/dup/makefile/detach __qualname__.__eq__ string values."
    - "socket_extra22.zspec.zsdl — covers socket.socket connect/bind/listen/accept/close/recv/send __qualname__.__eq__ string values."
    - "socket_extra8.zspec.zsdl — covers gethostname/gethostbyname/getaddrinfo/getfqdn/create_connection __qualname__.__eq__ string values (module-level functions)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra60; it does NOT duplicate invariants present in those files."
    - "Wave 228 theme: __annotations__ class identity + __globals__ dict keys + __doc__.__contains__ content checks."
    - "socket.socket (the class) is defined in Lib/socket.py as a Python subclass of _socket.socket (a C extension). Many of its methods are pure Python functions and therefore have __annotations__ attributes. socket.socket.accept, close, detach, and makefile are Python functions (type 'function') with empty __annotations__ dicts. socket.socket.connect, bind, listen, send, recv are method_descriptors from _socket and do NOT have __annotations__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__annotations__ == {} (empty dict). accept is a Python function wrapping _socket.socket.accept; it defines no type annotations. No prior socket spec checks accept.__annotations__.__class__.__name__.__eq__('dict') or __annotations__.__len__() for any socket.socket method. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn is a module-level Python function in Lib/socket.py with empty __annotations__. socket.gethostname is a C builtin_function_or_method from _socket and does NOT have __annotations__. No prior socket spec checks getfqdn.__annotations__.__class__.__name__.__eq__('dict'). socket_extra8 covers getfqdn.__qualname__.__eq__ (__qualname__ axis); no prior spec checks the __annotations__ axis. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__doc__ is the module-level docstring, a Python str of length 2021. No prior socket spec checks socket.__doc__.__class__.__name__.__eq__('str') or socket.__doc__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__doc__ == 'A subclass of _socket.socket adding the makefile() method.' This class docstring contains both 'socket' and 'makefile'. No prior socket spec checks socket.socket.__doc__.__contains__ for any keyword. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket Python method __annotations__ class identity
#
# Wave 228 theme: __annotations__ class identity checks.
#
# socket.socket.accept, close, detach, makefile are Python functions (type
# 'function') defined in Lib/socket.py. All have __annotations__ that are
# empty dicts. socket.socket.connect, bind, listen, send, recv are
# method_descriptors from _socket and lack __annotations__.
#
# No prior socket spec checks __annotations__.__class__.__name__.__eq__('dict')
# for any socket.socket method. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra61.socket_method_annotations_class_name:
  description: "socket.socket.accept/close/detach/makefile __annotations__.__class__.__name__.__eq__('dict') — all four are pure Python functions in Lib/socket.py with empty dict annotations; connect/bind/listen are C method_descriptors excluded; socket_extra8/22/42/50 cover __qualname__ axes; no prior socket spec checks __annotations__.__class__.__name__.__eq__('dict') for any socket.socket method"
  kind: python_call_eq
  category: annotations
  id_prefix: socketann61

  columns: [id, function, args, expected]
  rows:
    - [accept_annotations_class_name_eq,  socket.accept.__annotations__.__class__.__name__.__eq__,  ["dict"], true]
    - [close_annotations_class_name_eq,   socket.close.__annotations__.__class__.__name__.__eq__,   ["dict"], true]
    - [detach_annotations_class_name_eq,  socket.detach.__annotations__.__class__.__name__.__eq__,  ["dict"], true]
    - [makefile_annotations_class_name_eq, socket.makefile.__annotations__.__class__.__name__.__eq__, ["dict"], true]

# ---------------------------------------------------------------------------
# socket.socket Python method __annotations__ emptiness
#
# All four Python functions on socket.socket have zero-entry __annotations__
# dicts — no type annotations. __len__()==0 confirms emptiness. No prior socket
# spec checks __annotations__.__len__() for any socket.socket method.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra61.socket_method_annotations_len:
  description: "socket.socket.accept/close/detach/makefile __annotations__.__len__()==0 — empty annotation dicts; Python functions in Lib/socket.py define no type annotations; no prior socket spec checks __annotations__.__len__() for any socket.socket method"
  kind: python_call_eq
  category: annotations
  id_prefix: socketann61

  columns: [id, function, args, expected]
  rows:
    - [accept_annotations_len,  socket.accept.__annotations__.__len__,  [], 0]
    - [close_annotations_len,   socket.close.__annotations__.__len__,   [], 0]
    - [detach_annotations_len,  socket.detach.__annotations__.__len__,  [], 0]
    - [makefile_annotations_len, socket.makefile.__annotations__.__len__, [], 0]

# ---------------------------------------------------------------------------
# socket.getfqdn __annotations__ class identity
#
# socket.getfqdn is a module-level Python function in Lib/socket.py.
# socket_extra8 covers getfqdn.__qualname__.__eq__('getfqdn') (qualname axis);
# no prior socket spec checks the __annotations__ axis for getfqdn.
# getfqdn.__annotations__ is an empty dict. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table socket_extra61.getfqdn_annotations_class_name:
  description: "socket.getfqdn.__annotations__.__class__.__name__.__eq__('dict') — module-level Python function in Lib/socket.py with empty dict annotations; socket_extra8 covers getfqdn.__qualname__.__eq__ (__qualname__ axis); no prior socket spec checks getfqdn.__annotations__.__class__.__name__.__eq__('dict')"
  kind: python_call_eq
  category: annotations
  id_prefix: socketann61

  columns: [id, function, args, expected]
  rows:
    - [getfqdn_annotations_class_name_eq, getfqdn.__annotations__.__class__.__name__.__eq__, ["dict"], true]

# ---------------------------------------------------------------------------
# socket module __doc__ class identity and length
#
# Wave 228 theme: module docstring type and length.
#
# socket.__doc__ is the module-level docstring, a Python str of length 2021.
# No prior socket spec checks socket.__doc__.__class__.__name__.__eq__('str')
# or socket.__doc__.__len__(). Prior specs cover the __spec__/__loader__/__file__/
# __cached__ axes only. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra61.module_doc_class_and_len:
  description: "socket.__doc__.__class__.__name__.__eq__('str') and socket.__doc__.__len__()==2021 — module docstring is a Python str of length 2021; no prior socket spec checks socket.__doc__.__class__.__name__.__eq__('str') or __doc__.__len__(); prior specs cover __spec__/__loader__/__file__/__cached__ axes"
  kind: python_call_eq
  category: docstrings
  id_prefix: socketann61

  columns: [id, function, args, expected]
    # NOTE: __doc__ here refers to the socket module's __doc__ attribute
    # accessed via the module backend; __len__ is called with no args.
  rows:
    - [module_doc_class_name_eq, __doc__.__class__.__name__.__eq__, ["str"],  true]
    - [module_doc_len,           __doc__.__len__,                   [],       2021]

# ---------------------------------------------------------------------------
# socket.socket.__doc__ content checks
#
# socket.socket.__doc__ == 'A subclass of _socket.socket adding the makefile()
# method.' The string contains 'socket' (the class name) and 'makefile' (the
# key method added by the Python wrapper). No prior socket spec checks
# socket.socket.__doc__.__contains__ for any keyword. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table socket_extra61.socket_class_doc_contains:
  description: "socket.socket.__doc__.__contains__('socket') and __contains__('makefile') — class docstring is 'A subclass of _socket.socket adding the makefile() method.'; both 'socket' and 'makefile' appear; no prior socket spec checks socket.socket.__doc__.__contains__ for any keyword; first doc content checks for socket.socket"
  kind: python_call_eq
  category: docstrings
  id_prefix: socketann61

  columns: [id, function, args, expected]
  rows:
    - [socket_class_doc_contains_socket,   "socket.__doc__.__contains__", ["socket"],   true]
    - [socket_class_doc_contains_makefile, "socket.__doc__.__contains__", ["makefile"], true]

# ---------------------------------------------------------------------------
# socket.socket.accept.__annotations__.__class__.__name__.__eq__('dict') — standalone
#
# socket.socket.accept is a Python function (not a C method_descriptor) defined
# in Lib/socket.py. Its __annotations__ attribute is an empty dict with no type
# annotations. The chain __annotations__.__class__.__name__.__eq__('dict')
# confirms the dict type identity of the annotations object. socket_extra22/50
# cover accept.__qualname__.__eq__ (qualname axis); no prior socket spec checks
# the __annotations__ axis for any socket.socket method. First annotations
# anchor for any socket.socket method. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra61.accept_annotations_class_name_dict:
  description: "socket.socket.accept.__annotations__.__class__.__name__.__eq__('dict') == True — accept is a Python function in Lib/socket.py wrapping _socket.socket.accept; __annotations__ is an empty dict; socket_extra22/50 cover accept.__qualname__.__eq__ (qualname axis); no prior socket spec checks __annotations__.__class__.__name__.__eq__('dict') for any socket.socket method; first __annotations__ class identity anchor for socket.socket"
  category: annotations
  kind: python_call_eq
  function: socket.accept.__annotations__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__doc__.__contains__('makefile') — standalone
#
# socket.socket is a Python subclass of _socket.socket defined in Lib/socket.py.
# Its class docstring highlights the makefile() method as the key addition over
# _socket.socket: 'A subclass of _socket.socket adding the makefile() method.'
# The word 'makefile' appears in the docstring. No prior socket spec checks
# socket.socket.__doc__.__contains__ for any keyword. This is the first doc
# content anchor for the socket.socket class. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra61.socket_class_doc_contains_makefile:
  description: "socket.socket.__doc__.__contains__('makefile') == True — class docstring is 'A subclass of _socket.socket adding the makefile() method.'; 'makefile' highlights the key method added by the Python wrapper class; no prior socket spec checks socket.socket.__doc__.__contains__ for any keyword; first doc content anchor for socket.socket class"
  category: docstrings
  kind: python_call_eq
  function: "socket.__doc__.__contains__"
  args: ["makefile"]
  expected: true
