spec: optparse_extra3
version: ">=3.9"
backend: python_module(optparse)

docs: https://docs.python.org/3/library/optparse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/optparse.html — Python optparse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/optparse.py"
  notes:
    - "Extends optparse.zspec.zsdl, optparse_extra.zspec.zsdl, and optparse_extra2.zspec.zsdl with new axes."
    - "optparse.zspec.zsdl covers: class_names table (__name__ for OptionParser/Option/OptionGroup/Values/OptionError/OptionConflictError/OptionValueError/BadOptionError/AmbiguousOptionError/IndentedHelpFormatter/TitledHelpFormatter); OptionParser().allow_interspersed_args; OptionParser().version; MRO checks for OptionConflictError/OptionValueError/AmbiguousOptionError."
    - "optparse_extra.zspec.zsdl covers: OptionParser/Option/OptionGroup __name__/__module__; OptParseError __name__/__bases__[0].__name__; OptionError/OptionValueError/BadOptionError/AmbiguousOptionError/OptionConflictError __name__/__bases__[0].__name__."
    - "optparse_extra2.zspec.zsdl covers: __qualname__ table for all public classes; Values/__module__; IndentedHelpFormatter/__module__/__bases__[0].__name__; TitledHelpFormatter/__module__/__bases__[0].__name__; OptionParser().description default."
    - "This spec adds: __module__ for HelpFormatter/OptionError/OptionConflictError/OptionValueError/BadOptionError/AmbiguousOptionError/OptParseError (not in extra or extra2); HelpFormatter/__bases__[0].__name__ == 'object'; OptionContainer/__name__/__module__/__qualname__ (not in any prior spec); OptionParser/__bases__[0].__name__; OptionGroup/__bases__[0].__name__; Option/__bases__[0].__name__; OptionParser().usage default."
    - "optparse.HelpFormatter.__module__ == 'optparse' — not covered by extra or extra2 (extra2 covers IndentedHelpFormatter/TitledHelpFormatter module only)."
    - "optparse.HelpFormatter.__bases__[0].__name__ == 'object' — HelpFormatter inherits directly from object; no prior spec checks this."
    - "optparse.OptionContainer.__name__ == 'OptionContainer' — OptionContainer is the shared base for OptionParser and OptionGroup; not in any prior spec's class_names table."
    - "optparse.OptionContainer.__module__ == 'optparse' — OptionContainer is defined in Lib/optparse.py."
    - "optparse.OptionContainer.__qualname__ == 'OptionContainer' — top-level class so qualname equals name."
    - "optparse.OptionParser.__bases__[0].__name__ == 'OptionContainer' — OptionParser inherits from OptionContainer, not object."
    - "optparse.OptionGroup.__bases__[0].__name__ == 'OptionContainer' — OptionGroup also inherits from OptionContainer."
    - "optparse.Option.__bases__[0].__name__ == 'object' — Option inherits directly from object."
    - "optparse.OptionParser().usage — defaults to None when not supplied; no prior spec checks this attribute."
    - "All expected values verified by running Python 3.12 optparse module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# OptionContainer class metadata — not in any prior optparse spec.
# OptionContainer is the shared base class for OptionParser and OptionGroup.
# It provides the add_option / get_option / remove_option interface.
# ---------------------------------------------------------------------------

invariant optparse_extra3.OptionContainer.name:
  description: "optparse.OptionContainer.__name__ == 'OptionContainer'"
  category: class_names
  kind: python_call_eq
  function: OptionContainer.__name__.__eq__
  args: ["OptionContainer"]
  expected: true

invariant optparse_extra3.OptionContainer.module:
  description: "optparse.OptionContainer.__module__ == 'optparse'"
  category: class_modules
  kind: python_call_eq
  function: OptionContainer.__module__.__eq__
  args: ["optparse"]
  expected: true

invariant optparse_extra3.OptionContainer.qualname:
  description: "optparse.OptionContainer.__qualname__ == 'OptionContainer'"
  category: qualnames
  kind: python_call_eq
  function: OptionContainer.__qualname__.__eq__
  args: ["OptionContainer"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ checks for exception and formatter classes.
# extra covers OptionParser/Option/OptionGroup __module__;
# extra2 covers Values/IndentedHelpFormatter/TitledHelpFormatter __module__.
# The following are not in any prior spec: HelpFormatter, OptionError,
# OptionConflictError, OptionValueError, BadOptionError, AmbiguousOptionError,
# OptParseError.
# ---------------------------------------------------------------------------

table optparse_extra3.exception_and_formatter_modules:
  kind: python_call_eq
  category: class_modules
  id_prefix: mod3

  columns: [id, function, args, expected]
  rows:
    - [HelpFormatter,        HelpFormatter.__module__.__eq__,        ["optparse"], true]
    - [OptionError,          OptionError.__module__.__eq__,          ["optparse"], true]
    - [OptionConflictError,  OptionConflictError.__module__.__eq__,  ["optparse"], true]
    - [OptionValueError,     OptionValueError.__module__.__eq__,     ["optparse"], true]
    - [BadOptionError,       BadOptionError.__module__.__eq__,       ["optparse"], true]
    - [AmbiguousOptionError, AmbiguousOptionError.__module__.__eq__, ["optparse"], true]
    - [OptParseError,        OptParseError.__module__.__eq__,        ["optparse"], true]

# ---------------------------------------------------------------------------
# Base class hierarchy — OptionParser, OptionGroup, Option, HelpFormatter.
# No prior spec checks these direct base classes.
# OptionParser and OptionGroup both inherit from OptionContainer.
# Option and HelpFormatter inherit directly from object.
# ---------------------------------------------------------------------------

invariant optparse_extra3.OptionParser.base_class:
  description: "optparse.OptionParser.__bases__[0].__name__ == 'OptionContainer'"
  category: class_hierarchy
  kind: python_call_eq
  function: OptionParser.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "OptionContainer"

invariant optparse_extra3.OptionGroup.base_class:
  description: "optparse.OptionGroup.__bases__[0].__name__ == 'OptionContainer'"
  category: class_hierarchy
  kind: python_call_eq
  function: OptionGroup.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "OptionContainer"

invariant optparse_extra3.Option.base_class:
  description: "optparse.Option.__bases__[0].__name__ == 'object' — Option inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Option.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

invariant optparse_extra3.HelpFormatter.base_class:
  description: "optparse.HelpFormatter.__bases__[0].__name__ == 'object' — HelpFormatter inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: HelpFormatter.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

# ---------------------------------------------------------------------------
# OptionParser().usage — defaults to None when not supplied.
# optparse.zspec.zsdl checks version and allow_interspersed_args defaults.
# extra2 checks description default. usage default is a new vector.
# ---------------------------------------------------------------------------

invariant optparse_extra3.OptionParser.usage_default:
  description: "optparse.OptionParser().usage == None when no usage string is supplied"
  category: defaults
  kind: python_call_eq
  function: OptionParser
  args: []
  method: usage
  method_args: []
  expected: null
