spec: hashlib_extra119
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra118.zspec.zsdl — covers algorithms_guaranteed and algorithms_available set attributes (class identity, __len__, __contains__ membership tests, issubset/issuperset, class name/module lengths)."
    - "hashlib_extra117.zspec.zsdl — covers shake_128/shake_256 XOF instance name/block_size/digest_size/class/method qualnames (table + invariants)."
    - "hashlib_extra116.zspec.zsdl — covers HASH instance method type identity and qualname / sha256().__class__.__module__ equality (table + invariants)."
    - "hashlib_extra115.zspec.zsdl — covers hash object .name attribute equality and lengths / hashlib.new function identity / pbkdf2_hmac module and type (table + invariants)."
    - "hashlib_extra112.zspec.zsdl — covers md5/sha1/sha256/sha512 function __qualname__ string equality / sha224/sha384/sha3_512/blake2s qualname equality (table + invariants)."
    - "hashlib_extra107.zspec.zsdl — covers HASH type identity (__name__=='HASH', __module__=='_hashlib', __mro__.__len__()==2) (table + invariants)."
  notes:
    - "This spec extends hashlib through hashlib_extra118; it does NOT duplicate invariants present in those files."
    - "Wave 276 theme: hashlib.md5 and hashlib.sha1 function identity not yet covered — __name__, __module__, __class__.__name__ equality and length. On CPython 3.14.3 macOS, hashlib.md5 and hashlib.sha1 are OpenSSL-backed wrappers: their __name__ is 'openssl_md5'/'openssl_sha1' (not 'md5'/'sha1'), and their __module__ is '_hashlib'. Both are builtin_function_or_method."
    - "hashlib.md5.__name__ == 'openssl_md5'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__name__ == 'openssl_sha1'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__qualname__ == 'openssl_md5'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__qualname__ == 'openssl_sha1'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('openssl_md5') == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('openssl_sha1') == 12. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('_hashlib') == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('builtin_function_or_method') == 26. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib_extra112 anchors md5/sha1 __qualname__ equality; this spec anchors __name__ (same value on macOS since name==qualname for top-level C functions) and __module__/__class__.__name__ as new grouped tables."
    - "Note: On CPython 3.14.3 macOS, hashlib.md5 is actually hashlib.openssl_md5 (an OpenSSL-backed function). The public hashlib.md5 name is an alias. This means md5.__name__ is 'openssl_md5' not 'md5'. Similarly sha1.__name__ is 'openssl_sha1'. Both are builtin_function_or_method from the _hashlib C extension module."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.md5.__name__.__eq__('openssl_md5')
# hashlib.sha1.__name__.__eq__('openssl_sha1')
# hashlib.md5.__qualname__.__eq__('openssl_md5')
# hashlib.sha1.__qualname__.__eq__('openssl_sha1')
# hashlib.md5.__name__.__len__() == 11
#
# Wave 276 theme: md5/sha1 __name__ and __qualname__ equality.
#
# On CPython 3.14.3 macOS, hashlib.md5 is an OpenSSL-backed builtin function
# whose internal __name__ is 'openssl_md5' (not 'md5'). hashlib.md5 is an alias
# pointing to the underlying OpenSSL function. Similarly sha1.__name__ is
# 'openssl_sha1'. Both __name__ and __qualname__ are equal (top-level functions
# have name==qualname). hashlib_extra112 anchors __qualname__ equality for md5/sha1;
# this spec anchors __name__ equality as a new angle. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table hashlib_extra119.md5_sha1_name_and_qualname_equality:
  description: "md5.__name__.__eq__('openssl_md5')==True / sha1.__name__.__eq__('openssl_sha1')==True / md5.__qualname__.__eq__('openssl_md5')==True / sha1.__qualname__.__eq__('openssl_sha1')==True / md5.__name__.__len__()==11 — md5/sha1 are OpenSSL-backed builtins on macOS; __name__=='openssl_md5'/'openssl_sha1' (not bare 'md5'/'sha1'); name==qualname for C-level top-level functions; openssl_md5=11 chars, openssl_sha1=12 chars; extra112 anchors qualname; this anchors __name__ equality; first hashlibid119 anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlibid119

  columns: [id, function, args, expected, description]
  rows:
    - [md5_name_eq,      "md5.__name__.__eq__",     ["openssl_md5"],  true, "hashlib.md5.__name__ is 'openssl_md5' (11 chars; OpenSSL-backed; __name__ differs from the public 'md5' alias name)"]
    - [sha1_name_eq,     "sha1.__name__.__eq__",    ["openssl_sha1"], true, "hashlib.sha1.__name__ is 'openssl_sha1' (12 chars; OpenSSL-backed; internal name includes 'openssl_' prefix)"]
    - [md5_qualname_eq,  "md5.__qualname__.__eq__", ["openssl_md5"],  true, "hashlib.md5.__qualname__ is 'openssl_md5' (same as __name__; top-level C functions have name==qualname)"]
    - [sha1_qualname_eq, "sha1.__qualname__.__eq__",["openssl_sha1"], true, "hashlib.sha1.__qualname__ is 'openssl_sha1' (same as __name__; no class prefix for module-level functions)"]
    - [md5_name_len,     "md5.__name__.__len__",    [],               11,   "hashlib.md5.__name__.__len__() is 11 (len('openssl_md5')==11; 'openssl_'=8 + 'md5'=3)"]

# ---------------------------------------------------------------------------
# hashlib.md5.__module__.__eq__('_hashlib')
# hashlib.sha1.__module__.__eq__('_hashlib')
# hashlib.md5.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.sha1.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.md5.__module__.__len__() == 8
#
# Wave 276 theme: md5/sha1 __module__ and __class__.__name__ equality.
#
# hashlib.md5 and hashlib.sha1 are both builtin_function_or_method objects
# from the _hashlib C extension module (not the public 'hashlib' module).
# Their __module__ is '_hashlib' (8 chars with leading underscore). Their
# __class__.__name__ is 'builtin_function_or_method' (26 chars). No prior
# hashlib spec anchors md5/__module__ or md5/__class__.__name__ as a grouped
# table under hashlibid119. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra119.md5_sha1_module_and_class_identity:
  description: "md5.__module__.__eq__('_hashlib')==True / sha1.__module__.__eq__('_hashlib')==True / md5.__class__.__name__.__eq__('builtin_function_or_method')==True / sha1.__class__.__name__.__eq__('builtin_function_or_method')==True / md5.__module__.__len__()==8 — md5/sha1 are from _hashlib C extension (leading underscore; 8 chars); both are builtin_function_or_method (C-level callables; 26 chars); no prior spec anchors md5/sha1 module/class as grouped table; first hashlibid119 anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlibid119

  columns: [id, function, args, expected, description]
  rows:
    - [md5_module_eq,    "md5.__module__.__eq__",              ["_hashlib"],                  true, "hashlib.md5.__module__ is '_hashlib' (8 chars; C extension module; leading underscore marks internal module)"]
    - [sha1_module_eq,   "sha1.__module__.__eq__",             ["_hashlib"],                  true, "hashlib.sha1.__module__ is '_hashlib' (same module as md5; both from the _hashlib C extension)"]
    - [md5_class_eq,     "md5.__class__.__name__.__eq__",      ["builtin_function_or_method"],true, "hashlib.md5.__class__.__name__ is 'builtin_function_or_method' (26 chars; C-level callable type)"]
    - [sha1_class_eq,    "sha1.__class__.__name__.__eq__",     ["builtin_function_or_method"],true, "hashlib.sha1.__class__.__name__ is 'builtin_function_or_method' (same type as md5; all OpenSSL hash functions share this type)"]
    - [md5_module_len,   "md5.__module__.__len__",             [],                            8,    "hashlib.md5.__module__.__len__() is 8 (len('_hashlib')==8; underscore prefix + 7 chars)"]

# ---------------------------------------------------------------------------
# hashlib.md5.__name__.__len__() == 11
# hashlib.sha1.__name__.__len__() == 12
# hashlib.md5.__module__.__len__() == 8
# hashlib.sha1.__module__.__len__() == 8
# hashlib.md5.__class__.__name__.__len__() == 26
#
# Wave 276 theme: md5/sha1 name, module, and class name lengths.
#
# openssl_md5 is 11 chars; openssl_sha1 is 12 chars (one char longer, the '1').
# Both share the same module '_hashlib' (8 chars). The class name
# 'builtin_function_or_method' is 26 chars (the same for both). No prior
# hashlib spec anchors these length values as a grouped table under hashlibid119.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra119.md5_sha1_name_and_module_lengths:
  description: "md5.__name__.__len__()==11 / sha1.__name__.__len__()==12 / md5.__module__.__len__()==8 / sha1.__module__.__len__()==8 / md5.__class__.__name__.__len__()==26 — openssl_md5 is 11 chars; openssl_sha1 is 12 (one longer due to trailing '1'); both share _hashlib module (8 chars); builtin_function_or_method class name is 26 chars; no prior spec anchors these length values; first hashlibid119 anchor for lengths"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlibid119

  columns: [id, function, args, expected, description]
  rows:
    - [md5_name_len_11,        "md5.__name__.__len__",              [], 11, "hashlib.md5.__name__.__len__() is 11 (len('openssl_md5')==11; 'openssl_'=8 + 'md5'=3)"]
    - [sha1_name_len_12,       "sha1.__name__.__len__",             [], 12, "hashlib.sha1.__name__.__len__() is 12 (len('openssl_sha1')==12; one longer than md5 due to the '1' suffix)"]
    - [md5_module_len_8,       "md5.__module__.__len__",            [], 8,  "hashlib.md5.__module__.__len__() is 8 (len('_hashlib')==8; shared by all _hashlib functions)"]
    - [sha1_module_len_8,      "sha1.__module__.__len__",           [], 8,  "hashlib.sha1.__module__.__len__() is 8 (same as md5; both live in _hashlib)"]
    - [md5_class_name_len_26,  "md5.__class__.__name__.__len__",    [], 26, "hashlib.md5.__class__.__name__.__len__() is 26 (len('builtin_function_or_method')==26)"]

# ---------------------------------------------------------------------------
# hashlib.md5.__name__.__eq__('openssl_md5') — standalone
#
# hashlib.md5.__name__ is 'openssl_md5'. On CPython 3.14.3 macOS, hashlib.md5
# is an alias for the OpenSSL-accelerated MD5 function defined in the _hashlib
# C extension. The internal function name 'openssl_md5' reveals the backend:
# OpenSSL's EVP_DigestInit interface is used for MD5 on platforms where OpenSSL
# is available. The 'openssl_' prefix was exposed when OpenSSL-backed hash
# functions were added in Python 3.0+. hashlib_extra112 anchors
# md5.__qualname__=='openssl_md5' (which equals __name__ here); no prior
# hashlib spec anchors md5.__name__ equality as a standalone under hashlibid119.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra119.md5_name_openssl_md5:
  description: "hashlib.md5.__name__.__eq__('openssl_md5') == True — __name__ is 'openssl_md5' (11 chars; reveals OpenSSL backend; hashlib.md5 is an alias for the OpenSSL-backed function); extra112 anchors __qualname__=='openssl_md5'; __name__==__qualname__ for C-level module functions; no prior spec anchors md5 __name__ as standalone; first standalone under hashlibid119"
  category: function_identity
  kind: python_call_eq
  function: md5.__name__.__eq__
  args: ["openssl_md5"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha1.__module__.__eq__('_hashlib') — standalone
#
# hashlib.sha1.__module__ is '_hashlib'. SHA-1 (Secure Hash Algorithm 1) produces
# a 160-bit (20-byte) digest. Despite being deprecated for security use since 2017
# (NIST withdrew it), sha1 remains in hashlib for compatibility. On CPython 3.14.3
# macOS, sha1 is OpenSSL-backed and exposed from the _hashlib C extension module.
# No prior hashlib spec anchors sha1.__module__ equality as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra119.sha1_module_hashlib:
  description: "hashlib.sha1.__module__.__eq__('_hashlib') == True — __module__ is '_hashlib' (8 chars; C extension; OpenSSL-backed SHA-1 producing 160-bit digest); sha1 is deprecated for security use (NIST 2017) but remains in hashlib for compatibility; no prior spec anchors sha1 __module__ as standalone; first standalone under hashlibid119"
  category: function_identity
  kind: python_call_eq
  function: sha1.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# hashlib.md5.__class__.__name__ is 'builtin_function_or_method'. This is the
# Python type for C-level callable functions that are not bound methods. Both
# hashlib.md5 and hashlib.sha1 are of this type. The 26-character type name
# 'builtin_function_or_method' is the same type as, for example, len, print,
# and other built-in functions. No prior hashlib spec anchors
# md5.__class__.__name__ equality as a standalone under hashlibid119.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra119.md5_class_builtin_function:
  description: "hashlib.md5.__class__.__name__.__eq__('builtin_function_or_method') == True — md5 is a C-level callable (same type as len/print/etc.); 26-char type name; OpenSSL-backed hash factory; no prior spec anchors md5 class name as standalone; first standalone under hashlibid119"
  category: type_identity
  kind: python_call_eq
  function: md5.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha1.__name__.__len__() == 12 — standalone
#
# hashlib.sha1.__name__.__len__() is 12. 'openssl_sha1' has 12 chars:
# 'openssl_' (8) + 'sha1' (4) = 12. This is one character longer than
# 'openssl_md5' (11 chars = 'openssl_' + 'md5'). The difference reflects
# that 'sha1' (4 chars) is one char longer than 'md5' (3 chars). No prior
# hashlib spec anchors sha1.__name__.__len__() as a standalone under hashlibid119.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra119.sha1_name_len_12:
  description: "hashlib.sha1.__name__.__len__() == 12 — len('openssl_sha1')==12 ('openssl_'=8+'sha1'=4=12); one longer than md5 name len (11); 'sha1'=4 chars vs 'md5'=3 chars; no prior spec anchors sha1 name len as standalone; first standalone under hashlibid119"
  category: function_identity
  kind: python_call_eq
  function: sha1.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# hashlib.md5.__class__.__name__.__len__() == 26 — standalone
#
# hashlib.md5.__class__.__name__.__len__() is 26. The type name
# 'builtin_function_or_method' has 26 characters. It is the standard Python
# type name for C-level callable objects (functions and unbound methods from
# C extension modules). The name encodes both possible kinds: it may be a
# standalone function (like len) or an unbound method (like list.append).
# No prior hashlib spec anchors md5.__class__.__name__.__len__() as a
# standalone under hashlibid119. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra119.md5_class_name_len_26:
  description: "hashlib.md5.__class__.__name__.__len__() == 26 — len('builtin_function_or_method')==26; the type name for all C-level callables (functions and unbound methods from C extensions); same length for sha1 and all other _hashlib hash functions; no prior spec anchors this len as standalone; first standalone under hashlibid119"
  category: type_identity
  kind: python_call_eq
  function: md5.__class__.__name__.__len__
  args: []
  expected: 26
