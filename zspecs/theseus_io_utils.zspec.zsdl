spec: theseus_io_utils
version: ">=3.9"
backend: python_cleanroom(theseus_io_utils)
blocks: io

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html"
  notes:
    - "Clean-room in-memory I/O streams. Do NOT import io."
    - "StringIO: in-memory text stream; write/read/getvalue/seek."
    - "BytesIO: in-memory bytes stream; write/read/getvalue/seek."
    - "StringIO().write('hello'); getvalue() == 'hello'."
    - "BytesIO().write(b'hello'); getvalue() == b'hello'."
    - "seek(0) then read() returns all written data."
    - "Export: StringIO, BytesIO classes."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_io_utils.stringio_write_read:
  description: "StringIO write then getvalue returns written text"
  category: stringio
  kind: python_call_eq
  function: io_stringio_write_read
  args: []
  expected: "hello"

invariant theseus_io_utils.bytesio_write_read:
  description: "BytesIO write then getvalue returns written bytes"
  category: bytesio
  kind: python_call_eq
  function: io_bytesio_write_read
  args: []
  expected: true

invariant theseus_io_utils.stringio_seek:
  description: "StringIO seek(0) then read() returns all written data"
  category: stringio
  kind: python_call_eq
  function: io_stringio_seek_read
  args: []
  expected: "world"
