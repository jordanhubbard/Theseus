spec: csv_extra27
version: ">=3.9"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html — Python csv module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
    - "CPython source: Lib/csv.py"
    - "csv_extra25.zspec.zsdl — covers __module__.__len__() for DictReader/DictWriter/Dialect/Error/reader/writer/register_dialect/field_size_limit; __name__.__len__() for DictReader/DictWriter/Dialect/Error"
    - "csv_extra26.zspec.zsdl — covers __qualname__.__len__() for Dialect/excel/excel_tab/unix_dialect/DictReader/DictWriter; __module__.__len__() for excel/excel_tab/unix_dialect; __qualname__.__len__() for DictReader.__init__/DictReader.__next__/DictWriter.writerow/DictWriter.writerows/DictWriter.writeheader"
  notes:
    - "This spec extends csv_extra26.zspec.zsdl."
    - "Prior specs covered: reader/writer/DictReader/DictWriter/Dialect/Error __name__/__module__/__qualname__, DictReader/DictWriter __init__.__name__, register_dialect/field_size_limit __module__.__len__(), various __module__.__len__() and __name__.__len__() and __qualname__.__len__() for classes and methods."
    - "This spec covers: __mro__.__len__() for DictReader, DictWriter, Dialect, excel, excel_tab; __bases__[0].__name__ for DictReader, DictWriter, Dialect; __qualname__.__len__() for DictWriter.__init__, Dialect.__init__."
    - "csv.DictReader.__mro__ == ['DictReader', 'object'] (len 2) — verified Python 3.12."
    - "csv.DictWriter.__mro__ == ['DictWriter', 'object'] (len 2) — verified Python 3.12."
    - "csv.Dialect.__mro__ == ['Dialect', 'object'] (len 2) — verified Python 3.12."
    - "csv.excel.__mro__ == ['excel', 'Dialect', 'object'] (len 3) — verified Python 3.12."
    - "csv.excel_tab.__mro__ == ['excel_tab', 'excel', 'Dialect', 'object'] (len 4) — verified Python 3.12."
    - "csv.DictReader.__bases__[0].__name__ == 'object' — verified Python 3.12."
    - "csv.DictWriter.__bases__[0].__name__ == 'object' — verified Python 3.12."
    - "csv.Dialect.__bases__[0].__name__ == 'object' — verified Python 3.12."
    - "csv.DictWriter.__init__.__qualname__ == 'DictWriter.__init__' (len 19) — verified Python 3.12."
    - "csv.Dialect.__init__.__qualname__ == 'Dialect.__init__' (len 16) — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __mro__.__len__() for DictReader, DictWriter, Dialect, excel, excel_tab
#
# The inheritance hierarchy in the csv module:
#   DictReader  -> [DictReader, object]                    -> 2
#   DictWriter  -> [DictWriter, object]                    -> 2
#   Dialect     -> [Dialect, object]                       -> 2
#   excel       -> [excel, Dialect, object]                -> 3
#   excel_tab   -> [excel_tab, excel, Dialect, object]     -> 4
# No prior csv spec checks __mro__.__len__() for any of these classes.
# ---------------------------------------------------------------------------

table csv_extra27.class_mro_depths:
  description: "__mro__.__len__() for DictReader, DictWriter, Dialect, excel, excel_tab"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: cmd27

  columns: [id, function, args, expected]
  rows:
    - [DictReader,  DictReader.__mro__.__len__,  [], 2]
    - [DictWriter,  DictWriter.__mro__.__len__,  [], 2]
    - [Dialect,     Dialect.__mro__.__len__,     [], 2]
    - [excel,       excel.__mro__.__len__,       [], 3]
    - [excel_tab,   excel_tab.__mro__.__len__,   [], 4]

# ---------------------------------------------------------------------------
# __bases__[0].__name__ for DictReader, DictWriter, Dialect
#
# All three top-level csv classes extend object directly:
#   DictReader -> object
#   DictWriter -> object
#   Dialect    -> object
# Note: __bases__[0].__name__ contains '[' in the function path, so MUST be quoted.
# No prior csv spec checks __bases__[0].__name__ for any of these three classes.
# ---------------------------------------------------------------------------

table csv_extra27.class_bases_names:
  description: "__bases__[0].__name__ for DictReader, DictWriter, Dialect — all 'object'"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: cbn27

  columns: [id, function, args, expected, method, method_args]
  rows:
    - [DictReader_base, "DictReader.__bases__[0].__name__.__eq__", ["object"], true, __len__, []]
    - [DictWriter_base, "DictWriter.__bases__[0].__name__.__eq__", ["object"], true, __len__, []]
    - [Dialect_base,    "Dialect.__bases__[0].__name__.__eq__",    ["object"], true, __len__, []]

# ---------------------------------------------------------------------------
# __qualname__.__len__() for DictWriter.__init__ and Dialect.__init__
#
# Method qualnames for __init__ follow the 'ClassName.__init__' pattern:
#   DictWriter.__init__ -> 'DictWriter.__init__' -> 19
#   Dialect.__init__    -> 'Dialect.__init__'    -> 16
# csv_extra26 covered DictReader.__init__ (len 19) but not DictWriter.__init__
# or Dialect.__init__.
# ---------------------------------------------------------------------------

invariant csv_extra27.DictWriter.__init__.qualname_len:
  description: "csv.DictWriter.__init__.__qualname__.__len__() == 19 — 'DictWriter.__init__' has 19 characters"
  category: method_identity
  kind: python_call_eq
  function: DictWriter.__init__.__qualname__.__len__
  args: []
  expected: 19

invariant csv_extra27.Dialect.__init__.qualname_len:
  description: "csv.Dialect.__init__.__qualname__.__len__() == 16 — 'Dialect.__init__' has 16 characters"
  category: method_identity
  kind: python_call_eq
  function: Dialect.__init__.__qualname__.__len__
  args: []
  expected: 16

invariant csv_extra27.excel_mro_depth:
  description: "csv.excel.__mro__.__len__() == 3 — excel -> Dialect -> object"
  category: class_hierarchy
  kind: python_call_eq
  function: excel.__mro__.__len__
  args: []
  expected: 3

invariant csv_extra27.excel_tab_mro_depth:
  description: "csv.excel_tab.__mro__.__len__() == 4 — excel_tab -> excel -> Dialect -> object"
  category: class_hierarchy
  kind: python_call_eq
  function: excel_tab.__mro__.__len__
  args: []
  expected: 4
