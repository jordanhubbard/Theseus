spec: mp3001
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/multiprocessing.html"
    - "CPython docs — https://docs.python.org/3/library/multiprocessing.managers.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Wave 647 — theme: __getitem__, __setitem__, __delitem__ dict-presence (item access/mutation protocol)."
    - "Tests operator.contains(SomeClass.__dict__, '__getitem__') etc. for multiprocessing classes."
    - "Classes covered: Process, pool.Pool, pool.AsyncResult, pool.MapResult, managers.SyncManager, managers.ListProxy, managers.SetProxy, managers.DictProxy, managers.BaseListProxy, managers.BaseProxy, managers._BaseDictProxy, managers._BaseSetProxy."
    - "Key finding: user-facing proxy classes (ListProxy, SetProxy, DictProxy) do NOT define __getitem__/__setitem__/__delitem__ in their own __dict__."
    - "BaseListProxy.__dict__ defines __getitem__ (true), __setitem__ (true), __delitem__ (true) — it is the concrete list-proxy implementation."
    - "_BaseDictProxy.__dict__ defines __getitem__ (true), __setitem__ (true), __delitem__ (true) — it is the concrete dict-proxy implementation."
    - "_BaseSetProxy.__dict__ does not define __getitem__, __setitem__, or __delitem__ (sets have no item-by-key access)."
    - "No other multiprocessing class defines __getitem__, __setitem__, or __delitem__ in its own __dict__."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __getitem__ dict-presence — operator.contains(Cls.__dict__, '__getitem__')
#
# Only BaseListProxy and _BaseDictProxy define __getitem__ (true).
# User-facing ListProxy and DictProxy do not; they delegate to their bases.
# ---------------------------------------------------------------------------

table mp3001.getitem:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: item_getitem
  id_prefix: gi

  columns: [id, function, args, expected]
  rows:
    - ["gi_Process",          operator.contains, [Process.__dict__,                                   "__getitem__"], false]
    - ["gi_Pool",             operator.contains, [multiprocessing.pool.Pool.__dict__,                 "__getitem__"], false]
    - ["gi_AsyncResult",      operator.contains, [multiprocessing.pool.AsyncResult.__dict__,          "__getitem__"], false]
    - ["gi_MapResult",        operator.contains, [multiprocessing.pool.MapResult.__dict__,            "__getitem__"], false]
    - ["gi_SyncManager",      operator.contains, [multiprocessing.managers.SyncManager.__dict__,      "__getitem__"], false]
    - ["gi_ListProxy",        operator.contains, [multiprocessing.managers.ListProxy.__dict__,        "__getitem__"], false]
    - ["gi_SetProxy",         operator.contains, [multiprocessing.managers.SetProxy.__dict__,         "__getitem__"], false]
    - ["gi_DictProxy",        operator.contains, [multiprocessing.managers.DictProxy.__dict__,        "__getitem__"], false]
    - ["gi_BaseListProxy",    operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,    "__getitem__"], true]
    - ["gi_BaseProxy",        operator.contains, [multiprocessing.managers.BaseProxy.__dict__,        "__getitem__"], false]
    - ["gi_BaseDictProxy",    operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__,   "__getitem__"], true]
    - ["gi_BaseSetProxy",     operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,    "__getitem__"], false]

# ---------------------------------------------------------------------------
# __setitem__ dict-presence — operator.contains(Cls.__dict__, '__setitem__')
#
# Only BaseListProxy and _BaseDictProxy define __setitem__ (true).
# Sets have no positional or key-based assignment, so _BaseSetProxy is false.
# ---------------------------------------------------------------------------

table mp3001.setitem:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: item_setitem
  id_prefix: si

  columns: [id, function, args, expected]
  rows:
    - ["si_Process",          operator.contains, [Process.__dict__,                                   "__setitem__"], false]
    - ["si_Pool",             operator.contains, [multiprocessing.pool.Pool.__dict__,                 "__setitem__"], false]
    - ["si_AsyncResult",      operator.contains, [multiprocessing.pool.AsyncResult.__dict__,          "__setitem__"], false]
    - ["si_MapResult",        operator.contains, [multiprocessing.pool.MapResult.__dict__,            "__setitem__"], false]
    - ["si_SyncManager",      operator.contains, [multiprocessing.managers.SyncManager.__dict__,      "__setitem__"], false]
    - ["si_ListProxy",        operator.contains, [multiprocessing.managers.ListProxy.__dict__,        "__setitem__"], false]
    - ["si_SetProxy",         operator.contains, [multiprocessing.managers.SetProxy.__dict__,         "__setitem__"], false]
    - ["si_DictProxy",        operator.contains, [multiprocessing.managers.DictProxy.__dict__,        "__setitem__"], false]
    - ["si_BaseListProxy",    operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,    "__setitem__"], true]
    - ["si_BaseProxy",        operator.contains, [multiprocessing.managers.BaseProxy.__dict__,        "__setitem__"], false]
    - ["si_BaseDictProxy",    operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__,   "__setitem__"], true]
    - ["si_BaseSetProxy",     operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,    "__setitem__"], false]

# ---------------------------------------------------------------------------
# __delitem__ dict-presence — operator.contains(Cls.__dict__, '__delitem__')
#
# Only BaseListProxy and _BaseDictProxy define __delitem__ (true).
# Sets have no key-based deletion protocol, so _BaseSetProxy is false.
# ---------------------------------------------------------------------------

table mp3001.delitem:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: item_delitem
  id_prefix: di

  columns: [id, function, args, expected]
  rows:
    - ["di_Process",          operator.contains, [Process.__dict__,                                   "__delitem__"], false]
    - ["di_Pool",             operator.contains, [multiprocessing.pool.Pool.__dict__,                 "__delitem__"], false]
    - ["di_AsyncResult",      operator.contains, [multiprocessing.pool.AsyncResult.__dict__,          "__delitem__"], false]
    - ["di_MapResult",        operator.contains, [multiprocessing.pool.MapResult.__dict__,            "__delitem__"], false]
    - ["di_SyncManager",      operator.contains, [multiprocessing.managers.SyncManager.__dict__,      "__delitem__"], false]
    - ["di_ListProxy",        operator.contains, [multiprocessing.managers.ListProxy.__dict__,        "__delitem__"], false]
    - ["di_SetProxy",         operator.contains, [multiprocessing.managers.SetProxy.__dict__,         "__delitem__"], false]
    - ["di_DictProxy",        operator.contains, [multiprocessing.managers.DictProxy.__dict__,        "__delitem__"], false]
    - ["di_BaseListProxy",    operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,    "__delitem__"], true]
    - ["di_BaseProxy",        operator.contains, [multiprocessing.managers.BaseProxy.__dict__,        "__delitem__"], false]
    - ["di_BaseDictProxy",    operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__,   "__delitem__"], true]
    - ["di_BaseSetProxy",     operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,    "__delitem__"], false]

# ---------------------------------------------------------------------------
# combined — all three item-access operators across a cross-class sample
#
# 8 subjects x 3 operators = 24 rows.
# Highlights the contrast: user-facing proxies (false) vs private base
# classes BaseListProxy (all true) and _BaseDictProxy (all true).
# _BaseSetProxy is uniformly false across all three (sets have no item protocol).
# ---------------------------------------------------------------------------

table mp3001.combined:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: item_combined
  id_prefix: comb

  columns: [id, function, args, expected]
  rows:
    - ["comb_Process_gi",           operator.contains, [Process.__dict__,                                  "__getitem__"], false]
    - ["comb_Process_si",           operator.contains, [Process.__dict__,                                  "__setitem__"], false]
    - ["comb_Process_di",           operator.contains, [Process.__dict__,                                  "__delitem__"], false]
    - ["comb_ListProxy_gi",         operator.contains, [multiprocessing.managers.ListProxy.__dict__,       "__getitem__"], false]
