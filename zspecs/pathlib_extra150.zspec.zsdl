spec: pathlib_extra150
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path class identity from new angles not covered in pathlib_extra99: __init_subclass__/__fspath__ qualnames, PurePath/__slots__ structure, and pathlib class __name__ lengths across all six public classes."
    - "pathlib.Path.__init_subclass__.__qualname__ == 'Path.__init_subclass__' (len=22)."
    - "pathlib.Path.__fspath__.__qualname__ == 'PurePath.__fspath__' (len=19) — __fspath__ is defined on PurePath, not Path."
    - "pathlib.PurePath.__init__.__qualname__ == 'PurePath.__init__' (len=17) — all pathlib classes inherit __init__ from PurePath."
    - "pathlib.PurePath.__slots__ is a tuple of length 8; Path.__slots__ is a tuple of length 1 ('_info'); PosixPath.__slots__ is an empty tuple (length 0)."
    - "pathlib class __name__ lengths: PurePath=8, PurePosixPath=13, PureWindowsPath=15, Path=4, PosixPath=9, WindowsPath=11."
    - "Path has the shortest __name__ (4 characters); PureWindowsPath has the longest (15 characters)."
    - "pathlib.PurePath.__slots__[0] == '_raw_paths' (the first slot stores the raw paths tuple passed to __new__)."
    - "pathlib.Path.__slots__[0] == '_info' (Path adds a single slot for OS-specific path info)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib class __name__ lengths
# Path=4, PurePath=8, PosixPath=9, WindowsPath=11, PurePosixPath=13, PureWindowsPath=15.
# PureWindowsPath is longest (15); Path is shortest (4).
# ---------------------------------------------------------------------------

table pathlib_extra150.class_name_lengths:
  description: "pathlib class __name__ lengths: Path=4, PurePath=8, PosixPath=9, WindowsPath=11, PurePosixPath=13, PureWindowsPath=15"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibnamelen150

  columns: [id, function, args, expected, description]
  rows:
    - [path_name_len,    Path.__name__.__len__,            [], 4,  "pathlib.Path.__name__.__len__() == 4 ('Path' has 4 characters; the shortest __name__ among all six pathlib public classes)"]
    - [purepath_name_len,PurePath.__name__.__len__,        [], 8,  "pathlib.PurePath.__name__.__len__() == 8 ('PurePath' has 8 characters)"]
    - [posixp_name_len,  PosixPath.__name__.__len__,       [], 9,  "pathlib.PosixPath.__name__.__len__() == 9 ('PosixPath' has 9 characters)"]
    - [winp_name_len,    WindowsPath.__name__.__len__,     [], 11, "pathlib.WindowsPath.__name__.__len__() == 11 ('WindowsPath' has 11 characters)"]
    - [ppp_name_len,     PurePosixPath.__name__.__len__,   [], 13, "pathlib.PurePosixPath.__name__.__len__() == 13 ('PurePosixPath' has 13 characters)"]
    - [pwp_name_len,     PureWindowsPath.__name__.__len__, [], 15, "pathlib.PureWindowsPath.__name__.__len__() == 15 ('PureWindowsPath' has 15 characters; the longest __name__ among all six pathlib public classes)"]

# ---------------------------------------------------------------------------
# pathlib.Path and PurePath special method __qualname__ values
# Path.__init_subclass__.__qualname__ == 'Path.__init_subclass__' (len=22).
# Path.__fspath__.__qualname__ == 'PurePath.__fspath__' (len=19) — defined on PurePath.
# PurePath.__init__.__qualname__ == 'PurePath.__init__' (len=17) — shared by all subclasses.
# ---------------------------------------------------------------------------

table pathlib_extra150.special_method_qualnames:
  description: "pathlib special method __qualname__ values: Path.__init_subclass__ (len=22), Path.__fspath__ (defined on PurePath, len=19), PurePath.__init__ (len=17, shared by all subclasses)"
  kind: python_call_eq
  category: qualname
  id_prefix: pathlibspecmeth150

  columns: [id, function, args, expected, description]
  rows:
    - [path_initsubcls_qeq,   Path.__init_subclass__.__qualname__.__eq__,  ["Path.__init_subclass__"],  true, "pathlib.Path.__init_subclass__.__qualname__ == 'Path.__init_subclass__' (defined on Path itself)"]
    - [path_initsubcls_qlen,  Path.__init_subclass__.__qualname__.__len__,  [],                          22,   "pathlib.Path.__init_subclass__.__qualname__.__len__() == 22 ('Path.__init_subclass__' has 22 characters)"]
    - [path_fspath_qeq,       Path.__fspath__.__qualname__.__eq__,          ["PurePath.__fspath__"],     true, "pathlib.Path.__fspath__.__qualname__ == 'PurePath.__fspath__' (defined on PurePath, not Path)"]
    - [path_fspath_qlen,      Path.__fspath__.__qualname__.__len__,         [],                          19,   "pathlib.Path.__fspath__.__qualname__.__len__() == 19 ('PurePath.__fspath__' has 19 characters)"]
    - [purepath_init_qeq,     PurePath.__init__.__qualname__.__eq__,        ["PurePath.__init__"],       true, "pathlib.PurePath.__init__.__qualname__ == 'PurePath.__init__' (all subclasses inherit __init__ from PurePath)"]
    - [purepath_init_qlen,    PurePath.__init__.__qualname__.__len__,       [],                          17,   "pathlib.PurePath.__init__.__qualname__.__len__() == 17 ('PurePath.__init__' has 17 characters)"]
    - [path_init_qeq,         Path.__init__.__qualname__.__eq__,            ["PurePath.__init__"],       true, "pathlib.Path.__init__.__qualname__ == 'PurePath.__init__' (Path does not override __init__; it inherits from PurePath)"]
    - [posixp_init_qeq,       PosixPath.__init__.__qualname__.__eq__,       ["PurePath.__init__"],       true, "pathlib.PosixPath.__init__.__qualname__ == 'PurePath.__init__' (PosixPath also inherits __init__ from PurePath)"]

# ---------------------------------------------------------------------------
# pathlib.PurePath.__slots__ and pathlib.Path.__slots__ structure
# PurePath.__slots__ is a tuple of length 8; first entry is '_raw_paths'.
# Path.__slots__ is a tuple of length 1; first (only) entry is '_info'.
# PosixPath.__slots__ is an empty tuple (length 0).
# ---------------------------------------------------------------------------

table pathlib_extra150.slots_structure:
  description: "pathlib __slots__ structure: PurePath has 8 slots (first='_raw_paths'), Path has 1 slot ('_info'), PosixPath has 0 slots"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibslots150

  columns: [id, function, args, expected, description]
  rows:
    - [purepath_slots_cls,   PurePath.__slots__.__class__.__name__.__eq__,  ["tuple"], true, "pathlib.PurePath.__slots__.__class__.__name__ == 'tuple' (__slots__ is always a tuple at the class level)"]
    - [purepath_slots_len,   PurePath.__slots__.__len__,                    [],        8,    "pathlib.PurePath.__slots__.__len__() == 8 (PurePath defines 8 slots: _raw_paths, _drv, _root, _tail_cached, _str, _str_normcase_cached, _parts_normcase_cached, _hash)"]
    - [path_slots_cls,       Path.__slots__.__class__.__name__.__eq__,      ["tuple"], true, "pathlib.Path.__slots__.__class__.__name__ == 'tuple'"]
    - [path_slots_len,       Path.__slots__.__len__,                        [],        1,    "pathlib.Path.__slots__.__len__() == 1 (Path adds exactly one slot: '_info', for OS-specific path information)"]
    - [posixpath_slots_len,  PosixPath.__slots__.__len__,                   [],        0,    "pathlib.PosixPath.__slots__.__len__() == 0 (PosixPath adds no new slots; all its state comes from PurePath and Path slots)"]
    - [purepath_slot0_eq,    "PurePath.__slots__[0].__eq__",                ["_raw_paths"], true, "pathlib.PurePath.__slots__[0] == '_raw_paths' (the first slot stores raw path arguments passed to PurePath.__new__)"]
    - [path_slot0_eq,        "Path.__slots__[0].__eq__",                    ["_info"],      true, "pathlib.Path.__slots__[0] == '_info' (Path's single slot stores OS-specific path stat/accessor info)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra150.Path.name_len_4:
  description: "pathlib.Path.__name__.__len__() == 4 ('Path' has 4 characters; the shortest __name__ among all six public pathlib classes: Path=4, PurePath=8, PosixPath=9, WindowsPath=11, PurePosixPath=13, PureWindowsPath=15)"
  category: class_identity
  kind: python_call_eq
  function: Path.__name__.__len__
  args: []
  expected: 4

invariant pathlib_extra150.PureWindowsPath.name_len_15:
  description: "pathlib.PureWindowsPath.__name__.__len__() == 15 ('PureWindowsPath' has 15 characters; the longest __name__ among all six public pathlib classes)"
  category: class_identity
  kind: python_call_eq
  function: PureWindowsPath.__name__.__len__
  args: []
  expected: 15

invariant pathlib_extra150.Path.__fspath__qualname_is_PurePath:
  description: "pathlib.Path.__fspath__.__qualname__ == 'PurePath.__fspath__' — __fspath__ is not defined on Path; it is defined on PurePath and inherited. The qualname reveals the true definition site, showing that os.fspath() support lives in PurePath."
  category: qualname
  kind: python_call_eq
  function: Path.__fspath__.__qualname__.__eq__
  args: ["PurePath.__fspath__"]
  expected: true

invariant pathlib_extra150.Path.__init__qualname_is_PurePath:
  description: "pathlib.Path.__init__.__qualname__ == 'PurePath.__init__' — Path does not define its own __init__; all pathlib classes (PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath) share the single PurePath.__init__ implementation"
  category: qualname
  kind: python_call_eq
  function: Path.__init__.__qualname__.__eq__
  args: ["PurePath.__init__"]
  expected: true

invariant pathlib_extra150.PurePath.slots_len_8:
  description: "pathlib.PurePath.__slots__.__len__() == 8 (PurePath is the root of the pathlib hierarchy and defines 8 instance slots: _raw_paths, _drv, _root, _tail_cached, _str, _str_normcase_cached, _parts_normcase_cached, _hash)"
  category: class_identity
  kind: python_call_eq
  function: PurePath.__slots__.__len__
  args: []
  expected: 8

invariant pathlib_extra150.Path.slots_len_1:
  description: "pathlib.Path.__slots__.__len__() == 1 (Path adds a single slot '_info' for OS-specific path information; all other state is inherited from PurePath's 8 slots)"
  category: class_identity
  kind: python_call_eq
  function: Path.__slots__.__len__
  args: []
  expected: 1

invariant pathlib_extra150.Path.__init_subclass__qualname_len_22:
  description: "pathlib.Path.__init_subclass__.__qualname__.__len__() == 22 ('Path.__init_subclass__' has 22 characters; the longest method qualname for Path covered in this spec)"
  category: qualname
  kind: python_call_eq
  function: Path.__init_subclass__.__qualname__.__len__
  args: []
  expected: 22

invariant pathlib_extra150.PosixPath.slots_empty:
  description: "pathlib.PosixPath.__slots__.__len__() == 0 (PosixPath adds no new instance slots; it relies entirely on the slots inherited from Path and PurePath)"
  category: class_identity
  kind: python_call_eq
  function: PosixPath.__slots__.__len__
  args: []
  expected: 0

