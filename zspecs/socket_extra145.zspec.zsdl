spec: socket_extra145
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra144.zspec.zsdl — covers socket.socket.__module__/__qualname__/__eq__('socket') and __len__()==6 / socket.socket.__dict__.__class__.__name__.__eq__('mappingproxy') / __mro__.__len__()==3 / AF_INET/AF_INET6/SOCK_STREAM/SOCK_DGRAM __class__.__name__ equality (table + invariants)."
    - "socket_extra143.zspec.zsdl — covers socket.socket method __qualname__ string equality for connect/bind/listen/accept/recv / __qualname__ length grouping / accept/__class__.__name__=='function' vs connect/bind/listen/recv/__class__.__name__=='method_descriptor' (table + invariants)."
    - "socket_extra142.zspec.zsdl — covers socket.AF_INET/AF_INET6 enum member .name values and lengths / SOCK_STREAM/SOCK_DGRAM .name values and lengths / AddressFamily/SocketKind class __name__ values and __bases__[0].__name__ == 'IntEnum' / socket.error/__name__/__len__()==7 / socket.timeout/__name__/__len__()==12."
    - "socket_extra141.zspec.zsdl — covers socket.socket/__doc__/__len__()==58 / gethostname/__doc__/__len__()==54 / gethostbyname/__doc__/__len__()==106 / getaddrinfo/__doc__/__len__()==658 / setdefaulttimeout/__doc__/__len__()==224 / getdefaulttimeout/__doc__/__len__()==232."
    - "socket_extra140.zspec.zsdl — covers socket.socket method_descriptor __doc__ lengths (recv/send/bind/connect/listen/setsockopt/getsockopt/sendall/recvfrom/accept) / socket.socket method __qualname__ lengths."
    - "socket_extra139.zspec.zsdl — covers socket.socket.__eq__/__hash__ qualnames / socket.socket.family and type as property descriptors / socket.socket class __name__/__module__/__mro__."
    - "socket_extra99.zspec.zsdl — covers socket.gethostname/gethostbyname/getaddrinfo/setdefaulttimeout/getdefaulttimeout __qualname__.__len__() / SocketIO class identity."
    - "socket_extra98.zspec.zsdl — covers socket.socket C-level and Python-level method __qualname__.__len__() values."
    - "socket_extra97.zspec.zsdl — covers socket.socket.send/sendall/fileno __qualname__.__eq__ / socket.socket.__init__/accept/makefile/close __class__.__name__=='function'."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC class names / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names / AddressFamily/SocketKind __bases__."
    - "socket_extra95.zspec.zsdl — covers AddressFamily/SocketKind enum member values and names / socket.__all__ class name and length."
    - "socket_extra94.zspec.zsdl — covers socket module-level function __qualname__ and __module__ values / byte-order function class names."
    - "socket_extra93.zspec.zsdl — covers socket.socket C-level method_descriptor class names."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra93 through socket_extra144."
    - "Wave 311 theme: socket module-level constants and module identity — socket.AF_UNSPEC.__class__.__name__.__eq__('AddressFamily') (len 13) / socket.AF_UNIX.__class__.__name__.__eq__('AddressFamily') / AF_UNSPEC.name.__eq__('AF_UNSPEC') and __len__()==9 / AF_UNIX.name.__eq__('AF_UNIX') and __len__()==7 / socket.IPPROTO_TCP.__class__.__name__.__eq__('int') (plain int, not enum on macOS) / socket.__spec__.name.__eq__('socket') / socket.__doc__.__class__.__name__.__eq__('str') / socket.__doc__.__len__()==2021."
    - "socket.AF_UNSPEC.__class__.__name__ == 'AddressFamily' (len 13). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_UNIX.__class__.__name__ == 'AddressFamily' (len 13). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_UNSPEC.name == 'AF_UNSPEC' (len 9). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_UNIX.name == 'AF_UNIX' (len 7). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_UNSPEC.value == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_UNIX.value == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_TCP.__class__.__name__ == 'int' (plain int, not an IntEnum member on macOS/Darwin). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_UDP.__class__.__name__ == 'int' (plain int). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_TCP == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_UDP == 17. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__spec__.name == 'socket' (len 6). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__doc__.__len__() == 2021. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.AF_UNSPEC and socket.AF_UNIX are both AddressFamily enum members (class name 'AddressFamily', 13 chars). AF_UNSPEC.value == 0 (address family unspecified) and AF_UNIX.value == 1 (Unix domain sockets). AF_UNSPEC.name is 'AF_UNSPEC' (9 chars) while AF_UNIX.name is 'AF_UNIX' (7 chars) — AF_UNSPEC (9) is 2 chars longer than AF_UNIX (7)."
    - "Note: socket.IPPROTO_TCP and socket.IPPROTO_UDP are plain int objects on macOS/Darwin (class name 'int', not 'AddressFamily' or 'SocketKind'). On some platforms IPPROTO constants are exposed as IntEnum members, but on macOS/Darwin they are raw ints: IPPROTO_TCP == 6, IPPROTO_UDP == 17. This is an important platform-specific difference."
    - "Note: socket.__spec__.name is 'socket' (6 chars) — the same string as socket.socket.__module__ and socket.socket.__qualname__ (both 'socket', 6 chars). Three different attributes all return the same 6-char string 'socket', but via different access paths."
    - "Note: socket.__doc__ is 2021 chars — a module-level docstring that documents socket families, types, protocol numbers, and functions. In length ordering: uuid(1948) < socket(2021) < hashlib(2098) among the four stdlib modules covered by this spec series."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.AF_UNSPEC.__class__.__name__.__eq__('AddressFamily')
# socket.AF_UNSPEC.__class__.__name__.__len__()==13
# socket.AF_UNIX.__class__.__name__.__eq__('AddressFamily')
# socket.AF_UNSPEC.value==0
# socket.AF_UNIX.value==1
#
# Wave 311 theme: AF_UNSPEC and AF_UNIX are AddressFamily enum members.
#
# AF_UNSPEC (value 0) and AF_UNIX (value 1) are both AddressFamily IntEnum members.
# Their class name is 'AddressFamily' (13 chars). extra96 anchors AF_UNSPEC/AF_UNIX
# class names via type() path; no prior socket spec anchors both together with value
# checks as a table under sockconst145. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra145.AF_UNSPEC_and_AF_UNIX_identity:
  description: "socket.AF_UNSPEC/__class__.__name__.__eq__('AddressFamily')==True / __class__.__name__.__len__()==13 / AF_UNIX/__class__.__name__.__eq__('AddressFamily')==True / AF_UNSPEC.value==0 / AF_UNIX.value==1 — both are AddressFamily IntEnum members (13 chars); AF_UNSPEC is address family 0 (unspecified); AF_UNIX is address family 1 (Unix domain sockets); extra96 anchors class names via type() path; first sockconst145 anchor for both with value checks"
  kind: python_call_eq
  category: identity
  id_prefix: sockconst145

  columns: [id, function, args, expected, description]
  rows:
    - [unspec_class_AddressFamily, AF_UNSPEC.__class__.__name__.__eq__, ["AddressFamily"], true, "socket.AF_UNSPEC.__class__.__name__ == 'AddressFamily' (13 chars; AddressFamily IntEnum member)"]
    - [unspec_class_name_len,      AF_UNSPEC.__class__.__name__.__len__, [],               13,   "socket.AF_UNSPEC.__class__.__name__.__len__() is 13 ('AddressFamily' = 13 chars)"]
    - [unix_class_AddressFamily,   AF_UNIX.__class__.__name__.__eq__,   ["AddressFamily"], true, "socket.AF_UNIX.__class__.__name__ == 'AddressFamily' (same enum class as AF_UNSPEC)"]
    - [unspec_value_0,             AF_UNSPEC.value.__eq__,              [0],               true, "socket.AF_UNSPEC.value == 0 (address family unspecified; wildcard address)"]
    - [unix_value_1,               AF_UNIX.value.__eq__,                [1],               true, "socket.AF_UNIX.value == 1 (Unix domain sockets; local IPC)"]

# ---------------------------------------------------------------------------
# socket.AF_UNSPEC.name.__eq__('AF_UNSPEC')
# socket.AF_UNSPEC.name.__len__()==9
# socket.AF_UNIX.name.__eq__('AF_UNIX')
# socket.AF_UNIX.name.__len__()==7
#
# Wave 311 theme: AF_UNSPEC and AF_UNIX enum member .name attribute values.
#
# AF_UNSPEC.name is 'AF_UNSPEC' (9 chars) and AF_UNIX.name is 'AF_UNIX' (7 chars).
# AF_UNSPEC (9) is 2 chars longer than AF_UNIX (7) because 'UNSPEC' (6 chars) is
# 2 chars longer than 'UNIX' (4 chars) with the 3-char 'AF_' prefix common to both.
# extra142 anchors AF_INET/AF_INET6/SOCK_STREAM/SOCK_DGRAM .name values; no prior
# socket spec anchors AF_UNSPEC/AF_UNIX .name values as a table under sockconst145.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra145.AF_UNSPEC_and_AF_UNIX_names:
  description: "socket.AF_UNSPEC.name.__eq__('AF_UNSPEC')==True / name.__len__()==9 / AF_UNIX.name.__eq__('AF_UNIX')==True / name.__len__()==7 — AF_UNSPEC.name (9 chars = 3-char 'AF_' + 6-char 'UNSPEC') is 2 chars longer than AF_UNIX.name (7 chars = 3-char 'AF_' + 4-char 'UNIX'); extra142 anchors AF_INET/AF_INET6 names; first sockconst145 anchor for AF_UNSPEC/AF_UNIX name equality strings"
  kind: python_call_eq
  category: identity
  id_prefix: sockconst145

  columns: [id, function, args, expected, description]
  rows:
    - [unspec_name_eq,  AF_UNSPEC.name.__eq__, ["AF_UNSPEC"], true, "socket.AF_UNSPEC.name == 'AF_UNSPEC' (9 chars = 3-char 'AF_' prefix + 6-char 'UNSPEC')"]
    - [unspec_name_len, AF_UNSPEC.name.__len__, [],           9,    "socket.AF_UNSPEC.name.__len__() is 9 (3-char 'AF_' + 6-char 'UNSPEC'; 2 chars longer than AF_UNIX)"]
    - [unix_name_eq,    AF_UNIX.name.__eq__,   ["AF_UNIX"],  true, "socket.AF_UNIX.name == 'AF_UNIX' (7 chars = 3-char 'AF_' prefix + 4-char 'UNIX')"]
    - [unix_name_len,   AF_UNIX.name.__len__,  [],           7,    "socket.AF_UNIX.name.__len__() is 7 (3-char 'AF_' + 4-char 'UNIX'; 2 chars shorter than AF_UNSPEC)"]

# ---------------------------------------------------------------------------
# socket.IPPROTO_TCP.__class__.__name__.__eq__('int')
# socket.IPPROTO_UDP.__class__.__name__.__eq__('int')
# socket.IPPROTO_TCP.__class__.__name__.__len__()==3
# socket.__spec__.name.__eq__('socket')
# socket.__doc__.__len__()==2021
#
# Wave 311 theme: IPPROTO constants are plain int on macOS; module spec and doc identity.
#
# IPPROTO_TCP and IPPROTO_UDP are plain int objects on macOS/Darwin (not enum members).
# Their class name is 'int' (3 chars), contrasting with AF_UNSPEC/AF_UNIX which are
# 'AddressFamily' (13 chars). socket.__spec__.name is 'socket' (6 chars) and
# socket.__doc__ is 2021 chars. No prior socket spec anchors IPPROTO_TCP class name
# or __spec__.name equality string as a table under sockconst145.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra145.IPPROTO_and_module_identity:
  description: "socket.IPPROTO_TCP/__class__.__name__.__eq__('int')==True / __class__.__name__.__len__()==3 / IPPROTO_UDP/__class__.__name__.__eq__('int')==True / __spec__.name.__eq__('socket')==True / __doc__/__len__()==2021 — IPPROTO_TCP and IPPROTO_UDP are plain int (not enum) on macOS/Darwin (3-char class name); __spec__.name 'socket' (6 chars); __doc__ 2021 chars; no prior socket spec anchors these together under sockconst145"
  kind: python_call_eq
  category: identity
  id_prefix: sockconst145

  columns: [id, function, args, expected, description]
  rows:
    - [tcp_class_int,    IPPROTO_TCP.__class__.__name__.__eq__, ["int"],    true, "socket.IPPROTO_TCP.__class__.__name__ == 'int' (plain int on macOS/Darwin; not IntEnum)"]
    - [tcp_class_len,    IPPROTO_TCP.__class__.__name__.__len__, [],        3,    "socket.IPPROTO_TCP.__class__.__name__.__len__() is 3 ('int' = 3 chars; shortest class name)"]
    - [udp_class_int,    IPPROTO_UDP.__class__.__name__.__eq__, ["int"],    true, "socket.IPPROTO_UDP.__class__.__name__ == 'int' (plain int on macOS/Darwin; not IntEnum)"]
    - [spec_name_eq,     __spec__.name.__eq__,                  ["socket"], true, "socket.__spec__.name == 'socket' (6 chars; same string as socket.socket.__module__ and __qualname__)"]
    - [doc_len_2021,     __doc__.__len__,                       [],         2021, "socket.__doc__.__len__() is 2021 (module docstring documenting families, types, protocols, and functions)"]

# ---------------------------------------------------------------------------
# socket.AF_UNSPEC.__class__.__name__.__eq__('AddressFamily') — standalone
#
# socket.AF_UNSPEC.__class__.__name__ is 'AddressFamily' (13 chars). AF_UNSPEC
# represents address family 0 — the unspecified or wildcard address family used
# when you want to allow any address family. It is an AddressFamily IntEnum member,
# so its __class__.__name__ is the enum class name 'AddressFamily' (not 'int' or
# 'IntEnum'). extra96 anchors AF_UNSPEC class names via a different path (type());
# no prior socket spec anchors AF_UNSPEC.__class__.__name__.__eq__('AddressFamily')
# as a standalone under sockconst145. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra145.AF_UNSPEC_class_AddressFamily:
  description: "socket.AF_UNSPEC.__class__.__name__.__eq__('AddressFamily') == True — 'AddressFamily' (13 chars); AF_UNSPEC (value 0) is the wildcard address family; IntEnum member reports enum class name not 'int'; extra96 anchors via type() path; first standalone under sockconst145"
  category: identity
  kind: python_call_eq
  function: AF_UNSPEC.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

# ---------------------------------------------------------------------------
# socket.AF_UNSPEC.name.__eq__('AF_UNSPEC') — standalone
#
# socket.AF_UNSPEC.name is 'AF_UNSPEC' (9 chars). The IntEnum .name attribute
# returns the name of the enum member as a string. 'AF_UNSPEC' consists of the
# 3-char 'AF_' prefix (Address Family) plus the 6-char 'UNSPEC' suffix (unspecified).
# At 9 chars it is 2 chars longer than AF_UNIX.name ('AF_UNIX', 7 chars) because
# 'UNSPEC' (6 chars) is 2 chars longer than 'UNIX' (4 chars). extra142 anchors
# AF_INET/AF_INET6 .name values; no prior socket spec anchors AF_UNSPEC.name
# == 'AF_UNSPEC' as a standalone under sockconst145.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra145.AF_UNSPEC_name_eq:
  description: "socket.AF_UNSPEC.name.__eq__('AF_UNSPEC') == True — 'AF_UNSPEC' (9 chars = 3-char 'AF_' + 6-char 'UNSPEC'); IntEnum .name attribute; 2 chars longer than AF_UNIX.name ('AF_UNIX', 7 chars); extra142 anchors AF_INET/AF_INET6 names; first standalone under sockconst145"
  category: identity
  kind: python_call_eq
  function: AF_UNSPEC.name.__eq__
  args: ["AF_UNSPEC"]
  expected: true

# ---------------------------------------------------------------------------
# socket.AF_UNIX.name.__eq__('AF_UNIX') — standalone
#
# socket.AF_UNIX.name is 'AF_UNIX' (7 chars). AF_UNIX is the address family for
# Unix domain sockets — the mechanism for local interprocess communication via
# filesystem paths. Its name 'AF_UNIX' consists of the 3-char 'AF_' prefix plus
# the 4-char 'UNIX' suffix. At 7 chars it is 2 chars shorter than AF_UNSPEC.name
# ('AF_UNSPEC', 9 chars). No prior socket spec anchors AF_UNIX.name == 'AF_UNIX'
# as a standalone under sockconst145. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra145.AF_UNIX_name_eq:
  description: "socket.AF_UNIX.name.__eq__('AF_UNIX') == True — 'AF_UNIX' (7 chars = 3-char 'AF_' + 4-char 'UNIX'); Unix domain sockets for local IPC via filesystem paths; 2 chars shorter than AF_UNSPEC.name (9 chars); no prior socket spec anchors this as a standalone; first standalone under sockconst145"
  category: identity
  kind: python_call_eq
  function: AF_UNIX.name.__eq__
  args: ["AF_UNIX"]
  expected: true

# ---------------------------------------------------------------------------
# socket.IPPROTO_TCP.__class__.__name__.__eq__('int') — standalone
#
# socket.IPPROTO_TCP.__class__.__name__ is 'int'. On macOS/Darwin (and some other
# platforms), IPPROTO_TCP is exposed as a plain Python int (value 6) rather than
# as an IntEnum member. This is a platform-specific behavior: on platforms where
# IPPROTO constants are wrapped in an IntEnum they would have class name 'IPPROTO'
# or similar, but on macOS/Darwin they are raw ints. IPPROTO_TCP == 6 reflects
# the TCP protocol number assigned by IANA. No prior socket spec anchors
# IPPROTO_TCP.__class__.__name__.__eq__('int') as a standalone under sockconst145.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra145.IPPROTO_TCP_class_int:
  description: "socket.IPPROTO_TCP.__class__.__name__.__eq__('int') == True — plain int on macOS/Darwin (value 6; IANA TCP protocol number); contrasts with AF_UNSPEC/AF_UNIX which are AddressFamily enum members; platform-specific: some platforms expose IPPROTO as IntEnum; no prior socket spec anchors this as a standalone; first standalone under sockconst145"
  category: identity
  kind: python_call_eq
  function: IPPROTO_TCP.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# socket.__spec__.name.__eq__('socket') — standalone
#
# socket.__spec__.name is 'socket' (6 chars). This is the same 6-char string as
# socket.socket.__module__ and socket.socket.__qualname__ (both 'socket'). Three
# different access paths — __spec__.name (ModuleSpec attribute), socket.__module__
# (class attribute), and socket.__qualname__ (class attribute) — all return the
# same string 'socket'. This triple coincidence reflects that the module name,
# the class module attribution, and the class qualname all converge on 'socket'.
# No prior socket spec anchors socket.__spec__.name.__eq__('socket') as a standalone
# under sockconst145. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra145.spec_name_eq_socket:
  description: "socket.__spec__.name.__eq__('socket') == True — 'socket' (6 chars); same string as socket.socket.__module__ and socket.socket.__qualname__ (both also 'socket', 6 chars, anchored in extra144); three different access paths all return 'socket'; no prior socket spec anchors this as a standalone; first standalone under sockconst145"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.__doc__.__len__()==2021 — standalone
#
# socket.__doc__.__len__() is 2021. The module-level docstring is 2021 chars,
# documenting socket families, types, protocol numbers, and module-level functions.
# In the length ordering among the four stdlib modules covered by this spec series:
# uuid(1948) < socket(2021) < hashlib(2098). socket (2021) sits between uuid (1948)
# and hashlib (2098), with socket being 73 chars longer than uuid and 77 chars
# shorter than hashlib. No prior socket spec anchors socket.__doc__.__len__()==2021
# as a standalone under sockconst145. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra145.doc_len_2021:
  description: "socket.__doc__.__len__() == 2021 — module docstring (str) documenting socket families, types, protocol numbers, and functions; 2021 chars; in ordering: uuid(1948) < socket(2021) < hashlib(2098); 73 chars longer than uuid, 77 chars shorter than hashlib; no prior socket spec anchors this as a standalone; first standalone under sockconst145"
  category: doc_lengths
  kind: python_call_eq
  function: __doc__.__len__
  args: []
  expected: 2021
