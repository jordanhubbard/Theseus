spec: functools_extra2716
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/functools.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 628 theme: __neg__, __pos__, and __abs__ dict-presence checks (unary minus, unary plus, absolute value)."
    - "functools.partial is a callable wrapper; it does not implement unary arithmetic protocols."
    - "functools.partialmethod is a descriptor; it similarly defines none of __neg__, __pos__, or __abs__."
    - "functools.cached_property is a data descriptor (defines __get__, __set__, __delete__) but not __neg__, __pos__, or __abs__."
    - "functools.singledispatchmethod is a descriptor wrapper; it does not define __neg__, __pos__, or __abs__."
    - "None of the functools public classes define __neg__, __pos__, or __abs__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __neg__ dict-presence — absent from all functools classes
# ---------------------------------------------------------------------------

table functools_extra2716.neg_protocol:
  description: "__neg__ is absent from all functools class __dict__s — none implement unary minus"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2716

  columns: [id, function, args, expected]
  rows:
    - ["ft2716001", "functools.partial.__dict__.__contains__",              ["__neg__"], false]
    - ["ft2716002", "functools.partialmethod.__dict__.__contains__",        ["__neg__"], false]
    - ["ft2716003", "functools.cached_property.__dict__.__contains__",      ["__neg__"], false]
    - ["ft2716004", "functools.singledispatchmethod.__dict__.__contains__",  ["__neg__"], false]

# ---------------------------------------------------------------------------
# __pos__ dict-presence — absent from all functools classes
# ---------------------------------------------------------------------------

table functools_extra2716.pos_protocol:
  description: "__pos__ is absent from all functools class __dict__s — none implement unary plus"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2716

  columns: [id, function, args, expected]
  rows:
    - ["ft2716005", "functools.partial.__dict__.__contains__",              ["__pos__"], false]
    - ["ft2716006", "functools.partialmethod.__dict__.__contains__",        ["__pos__"], false]
    - ["ft2716007", "functools.cached_property.__dict__.__contains__",      ["__pos__"], false]
    - ["ft2716008", "functools.singledispatchmethod.__dict__.__contains__",  ["__pos__"], false]

# ---------------------------------------------------------------------------
# __abs__ dict-presence — absent from all functools classes
# ---------------------------------------------------------------------------

table functools_extra2716.abs_protocol:
  description: "__abs__ is absent from all functools class __dict__s — none implement absolute value"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2716

  columns: [id, function, args, expected]
  rows:
    - ["ft2716009", "functools.partial.__dict__.__contains__",              ["__abs__"], false]
    - ["ft2716010", "functools.partialmethod.__dict__.__contains__",        ["__abs__"], false]
    - ["ft2716011", "functools.cached_property.__dict__.__contains__",      ["__abs__"], false]
    - ["ft2716012", "functools.singledispatchmethod.__dict__.__contains__",  ["__abs__"], false]

# ---------------------------------------------------------------------------
# Combined view — partial and partialmethod vs. all three protocols
# ---------------------------------------------------------------------------

table functools_extra2716.partial_unary_combined:
  description: "functools.partial and functools.partialmethod define none of __neg__, __pos__, __abs__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2716

  columns: [id, function, args, expected]
  rows:
    - ["ft2716013", "functools.partial.__dict__.__contains__",       ["__neg__"],  false]
    - ["ft2716014", "functools.partial.__dict__.__contains__",       ["__pos__"],  false]
    - ["ft2716015", "functools.partial.__dict__.__contains__",       ["__abs__"],  false]
    - ["ft2716016", "functools.partialmethod.__dict__.__contains__", ["__neg__"],  false]
    - ["ft2716017", "functools.partialmethod.__dict__.__contains__", ["__pos__"],  false]
    - ["ft2716018", "functools.partialmethod.__dict__.__contains__", ["__abs__"],  false]
