spec: th3016
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 648 (th3016): __iter__, __next__, __reversed__ dict-presence checks for threading types."
    - "threading types are synchronization primitives and thread management classes — none define iterator protocol methods in their own __dict__."
    - "Verified types: threading.Thread, threading.Condition, threading.Semaphore, threading.BoundedSemaphore, threading.Event, threading.Timer, threading.Barrier, threading.local."
    - "threading.Lock and threading.RLock are factory functions returning C-level lock objects, not checked here."
    - "threading.Timer is a Thread subclass used for delayed execution."
    - "threading.local is the thread-local storage class."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th3016.iter:
  description: "threading types __iter__ dict-presence checks; wave 648"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th3016
  columns: [id, function, args, expected]
  rows:
    - ["th3016001", operator.contains, [threading.Thread.__dict__,           "__iter__"], false]
    - ["th3016002", operator.contains, [threading.Condition.__dict__,        "__iter__"], false]
    - ["th3016003", operator.contains, [threading.Semaphore.__dict__,        "__iter__"], false]
    - ["th3016004", operator.contains, [threading.BoundedSemaphore.__dict__, "__iter__"], false]
    - ["th3016005", operator.contains, [threading.Event.__dict__,            "__iter__"], false]
    - ["th3016006", operator.contains, [threading.Barrier.__dict__,          "__iter__"], false]

