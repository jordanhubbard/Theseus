spec: pathlib_extra7
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends prior pathlib specs."
    - "Focus: Path instance methods and PurePath operations."
    - "Path('/a/b/c').parts == ('/', 'a', 'b', 'c')."
    - "Path('/a/b/c').root == '/'."
    - "Path('/a/b/c').drive == '' (POSIX — no drive letter)."
    - "Path('/a/b/c').suffix == ''."
    - "Path('/a/b/c.txt').suffix == '.txt'."
    - "Path('/a/b/c.tar.gz').suffixes == ['.tar', '.gz']."
    - "Path('/a/b/c').stem == 'c'."
    - "Path('/a/b/c.txt').stem == 'c'."
    - "Path('/a/b') / 'c' == Path('/a/b/c')."
    - "Path('/a/b/c').parent == Path('/a/b')."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

invariant pathlib_extra7.Path.root:
  description: "pathlib.Path('/a/b/c').root == '/'"
  category: Path_attributes
  kind: python_call_eq
  function: Path
  args: ["/a/b/c"]
  method: root.__eq__
  method_args: ["/"]
  expected: true

invariant pathlib_extra7.Path.drive:
  description: "pathlib.Path('/a/b/c').drive == '' on POSIX"
  category: Path_attributes
  kind: python_call_eq
  function: Path
  args: ["/a/b/c"]
  method: drive.__eq__
  method_args: [""]
  expected: true

invariant pathlib_extra7.Path.suffix_none:
  description: "pathlib.Path('/a/b/c').suffix == ''"
  category: Path_attributes
  kind: python_call_eq
  function: Path
  args: ["/a/b/c"]
  method: suffix.__eq__
  method_args: [""]
  expected: true

invariant pathlib_extra7.Path.suffix_txt:
  description: "pathlib.Path('/a/b/c.txt').suffix == '.txt'"
  category: Path_attributes
  kind: python_call_eq
  function: Path
  args: ["/a/b/c.txt"]
  method: suffix.__eq__
  method_args: [".txt"]
  expected: true

invariant pathlib_extra7.Path.stem_no_ext:
  description: "pathlib.Path('/a/b/c').stem == 'c'"
  category: Path_attributes
  kind: python_call_eq
  function: Path
  args: ["/a/b/c"]
  method: stem.__eq__
  method_args: ["c"]
  expected: true

invariant pathlib_extra7.Path.stem_with_ext:
  description: "pathlib.Path('/a/b/c.txt').stem == 'c'"
  category: Path_attributes
  kind: python_call_eq
  function: Path
  args: ["/a/b/c.txt"]
  method: stem.__eq__
  method_args: ["c"]
  expected: true

invariant pathlib_extra7.Path.parts_count:
  description: "len(pathlib.Path('/a/b/c').parts) == 4"
  category: Path_attributes
  kind: python_call_eq
  function: Path
  args: ["/a/b/c"]
  method: parts.__len__
  method_args: []
  expected: 4

invariant pathlib_extra7.Path.parts_first:
  description: "pathlib.Path('/a/b/c').parts[0] == '/'"
  category: Path_attributes
  kind: python_call_eq
  function: Path
  args: ["/a/b/c"]
  method: parts.__getitem__
  method_args: [0]
  expected: "/"

invariant pathlib_extra7.Path.parts_last:
  description: "pathlib.Path('/a/b/c').parts[-1] == 'c'"
  category: Path_attributes
  kind: python_call_eq
  function: Path
  args: ["/a/b/c"]
  method: parts.__getitem__
  method_args: [-1]
  expected: "c"

invariant pathlib_extra7.Path.suffixes_tar_gz:
  description: "pathlib.Path('/a/b/c.tar.gz').suffixes == ['.tar', '.gz']"
  category: Path_attributes
  kind: python_call_eq
  function: Path
  args: ["/a/b/c.tar.gz"]
  method: suffixes.__eq__
  method_args: [[".tar", ".gz"]]
  expected: true

invariant pathlib_extra7.PurePosixPath.class_name:
  description: "pathlib.PurePosixPath.__name__ == 'PurePosixPath'"
  category: class_names
  kind: python_call_eq
  function: PurePosixPath.__name__.__eq__
  args: ["PurePosixPath"]
  expected: true

invariant pathlib_extra7.PurePosixPath.module:
  description: "pathlib.PurePosixPath.__module__ == 'pathlib'"
  category: module
  kind: python_call_eq
  function: PurePosixPath.__module__.__eq__
  args: ["pathlib"]
  expected: true
