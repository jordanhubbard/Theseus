spec: uuid_extra116
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__/__str__/__repr__/__eq__/__hash__/__lt__ qualname equality and lengths / UUID.__init__.__code__.co_name/co_argcount equality (table + invariants)."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality for hex/bytes/bytes_le/fields/node/time/clock_seq/version/variant/clock_seq_hi_variant/clock_seq_low/time_hi_version (table + invariants)."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality and co_argcount / UUID.__module__/__eq__('uuid') / UUID.__class__.__name__.__eq__('type') / UUID.__qualname__ equality and length (table + invariants)."
    - "uuid_extra95.zspec.zsdl — covers SafeUUID.safe.value==0 / SafeUUID.unsafe.value==-1 / SafeUUID.__name__/__qualname__.__eq__ / UUID.hex/bytes/urn/fields/variant/version fget.__qualname__.__len__() (table + invariants)."
    - "uuid_extra94.zspec.zsdl — covers UUID.__slots__ class name/length/contents / UUID.__bases__[0].__name__=='object' / UUID.__mro__.__len__()==2 / UUID.__setattr__.__class__.__name__=='function' / uuid3/uuid5/getnode __qualname__.__len__() / SafeUUID metaclass/module/MRO depth (table + invariants)."
    - "uuid_extra92.zspec.zsdl — covers UUID property fget.__code__.co_name equality and co_argcount==1 and co_name lengths (table + invariants)."
    - "uuid_extra86.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in earlier uuid specs."
    - "Wave 271 theme: UUID time-related property fget co_varnames[0] and fget qualname lengths for time_low/time_mid/time_hi_version/clock_seq_hi_variant/clock_seq_low/node/time."
    - "uuid.UUID.time_low.fget.__code__.co_varnames[0] == 'self'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time_mid.fget.__code__.co_varnames[0] == 'self'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time_hi_version.fget.__code__.co_varnames[0] == 'self'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.clock_seq_hi_variant.fget.__code__.co_varnames[0] == 'self'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.clock_seq_low.fget.__code__.co_varnames[0] == 'self'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.node.fget.__code__.co_varnames[0] == 'self'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time.fget.__code__.co_varnames[0] == 'self'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time_low.fget.__qualname__ == 'UUID.time_low' (len 13). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time_mid.fget.__qualname__ == 'UUID.time_mid' (len 13). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time_hi_version.fget.__qualname__ == 'UUID.time_hi_version' (len 20). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.clock_seq_hi_variant.fget.__qualname__ == 'UUID.clock_seq_hi_variant' (len 25). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.clock_seq_low.fget.__qualname__ == 'UUID.clock_seq_low' (len 18). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.node.fget.__qualname__ == 'UUID.node' (len 9). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time.fget.__qualname__ == 'UUID.time' (len 9). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: extra92 anchors fget.__code__.co_name (the function name string) and co_argcount (1 for all properties). This spec anchors fget.__code__.co_varnames[0] (the first local variable name, which is always 'self' for instance methods). co_varnames[0] and co_name are distinct: co_varnames[0] is 'self' while co_name is the property name string (e.g., 'time_low')."
    - "Note: extra97 anchors fget qualname equality for hex/bytes/bytes_le/fields/node/time/clock_seq/version/variant/clock_seq_hi_variant/clock_seq_low/time_hi_version. This spec anchors fget qualname LENGTH (__len__()) for the time-related subset: time_low/time_mid/time_hi_version/clock_seq_hi_variant/clock_seq_low/node/time."
    - "Note: extra95 anchors fget.__qualname__.__len__() for hex/bytes/urn/fields/variant/version. This spec extends coverage to time_low/time_mid/time_hi_version/clock_seq_hi_variant/clock_seq_low/node/time."
    - "Note: uuid.UUID.time.fget.__code__.co_varnames is ('self', 'time_hi', 'time_lo') — 3 entries — but co_varnames[0] is still 'self' and co_argcount is still 1 (time_hi and time_lo are local variables, not arguments)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.time_low.fget.__code__.co_varnames[0].__eq__('self')
# uuid.UUID.time_mid.fget.__code__.co_varnames[0].__eq__('self')
# uuid.UUID.time_hi_version.fget.__code__.co_varnames[0].__eq__('self')
# uuid.UUID.time_low.fget.__code__.co_argcount.__eq__(1)
# uuid.UUID.time_mid.fget.__code__.co_argcount.__eq__(1)
#
# Wave 271 theme: time-related property fget co_varnames[0] and co_argcount.
#
# All UUID property fget functions have co_varnames[0] == 'self' because they
# are instance methods with 'self' as the first parameter. co_argcount is 1
# for all simple property getters (only 'self' argument). extra92 anchors
# co_name (function name string) and co_argcount==1 for all UUID properties;
# no prior uuid spec anchors co_varnames[0] == 'self' for these time-related
# properties under uuidcodev116. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra116.time_prop_fget_co_varnames:
  description: "UUID.time_low.fget.__code__.co_varnames[0].__eq__('self')==True / UUID.time_mid.fget.__code__.co_varnames[0].__eq__('self')==True / UUID.time_hi_version.fget.__code__.co_varnames[0].__eq__('self')==True / UUID.time_low.fget.__code__.co_argcount.__eq__(1)==True / UUID.time_mid.fget.__code__.co_argcount.__eq__(1)==True — co_varnames[0] is 'self' for all instance method property fgets; distinct from co_name which is the property name; extra92 anchors co_name and co_argcount; first uuidcodev116 anchor for co_varnames[0]"
  kind: python_call_eq
  category: code_attributes
  id_prefix: uuidcodev116

  columns: [id, function, args, expected, description]
  rows:
    - [time_low_co_varnames0,      "UUID.time_low.fget.__code__.co_varnames[0].__eq__",      ["self"], true, "UUID.time_low.fget co_varnames[0] is 'self' (first arg of instance method)"]
    - [time_mid_co_varnames0,      "UUID.time_mid.fget.__code__.co_varnames[0].__eq__",      ["self"], true, "UUID.time_mid.fget co_varnames[0] is 'self' (first arg of instance method)"]
    - [time_hi_version_co_vars0,   "UUID.time_hi_version.fget.__code__.co_varnames[0].__eq__", ["self"], true, "UUID.time_hi_version.fget co_varnames[0] is 'self' (first arg of instance method)"]
    - [time_low_co_argcount,       "UUID.time_low.fget.__code__.co_argcount.__eq__",         [1],     true, "UUID.time_low.fget co_argcount is 1 (only 'self'; simple property getter)"]
    - [time_mid_co_argcount,       "UUID.time_mid.fget.__code__.co_argcount.__eq__",         [1],     true, "UUID.time_mid.fget co_argcount is 1 (only 'self'; simple property getter)"]

# ---------------------------------------------------------------------------
# uuid.UUID.clock_seq_hi_variant.fget.__code__.co_varnames[0].__eq__('self')
# uuid.UUID.clock_seq_low.fget.__code__.co_varnames[0].__eq__('self')
# uuid.UUID.node.fget.__code__.co_varnames[0].__eq__('self')
# uuid.UUID.time.fget.__code__.co_varnames[0].__eq__('self')
# uuid.UUID.time_hi_version.fget.__code__.co_argcount.__eq__(1)
#
# Wave 271 theme: additional time-related property fget co_varnames[0].
#
# clock_seq_hi_variant, clock_seq_low, node, and time all have fget functions
# with co_varnames[0] == 'self'. Notably, uuid.UUID.time.fget.__code__.co_varnames
# is ('self', 'time_hi', 'time_lo') — it has 3 local variables — but co_varnames[0]
# is still 'self' and co_argcount is still 1 (time_hi and time_lo are computed
# local variables, not arguments). extra92 anchors co_name and co_argcount for
# all UUID properties; no prior uuid spec anchors co_varnames[0] for these
# properties as a group under uuidcodev116.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra116.clock_node_time_fget_co_varnames:
  description: "UUID.clock_seq_hi_variant.fget.__code__.co_varnames[0].__eq__('self')==True / UUID.clock_seq_low.fget.__code__.co_varnames[0].__eq__('self')==True / UUID.node.fget.__code__.co_varnames[0].__eq__('self')==True / UUID.time.fget.__code__.co_varnames[0].__eq__('self')==True / UUID.time_hi_version.fget.__code__.co_argcount.__eq__(1)==True — note UUID.time.fget has 3 co_varnames ('self','time_hi','time_lo') but co_varnames[0] is still 'self' and co_argcount is 1; extra92 anchors co_name/co_argcount; first uuidcodev116 anchor for these co_varnames[0]"
  kind: python_call_eq
  category: code_attributes
  id_prefix: uuidcodev116

  columns: [id, function, args, expected, description]
  rows:
    - [clock_seq_hi_co_vars0,  "UUID.clock_seq_hi_variant.fget.__code__.co_varnames[0].__eq__", ["self"], true, "UUID.clock_seq_hi_variant.fget co_varnames[0] is 'self'"]
    - [clock_seq_low_co_vars0, "UUID.clock_seq_low.fget.__code__.co_varnames[0].__eq__",        ["self"], true, "UUID.clock_seq_low.fget co_varnames[0] is 'self'"]
    - [node_co_vars0,          "UUID.node.fget.__code__.co_varnames[0].__eq__",                 ["self"], true, "UUID.node.fget co_varnames[0] is 'self'"]
    - [time_co_vars0,          "UUID.time.fget.__code__.co_varnames[0].__eq__",                 ["self"], true, "UUID.time.fget co_varnames[0] is 'self' (has 3 co_varnames but co_argcount==1; time_hi/time_lo are locals)"]
    - [time_hi_ver_co_argc,    "UUID.time_hi_version.fget.__code__.co_argcount.__eq__",         [1],     true, "UUID.time_hi_version.fget co_argcount is 1 (only 'self'; simple property getter)"]

# ---------------------------------------------------------------------------
# uuid.UUID.time_low.fget.__qualname__.__len__()==13
# uuid.UUID.time_mid.fget.__qualname__.__len__()==13
# uuid.UUID.time_hi_version.fget.__qualname__.__len__()==20
# uuid.UUID.clock_seq_hi_variant.fget.__qualname__.__len__()==25
# uuid.UUID.clock_seq_low.fget.__qualname__.__len__()==18
# uuid.UUID.node.fget.__qualname__.__len__()==9
# uuid.UUID.time.fget.__qualname__.__len__()==9
#
# Wave 271 theme: time-related property fget qualname lengths.
#
# Each fget qualname is 'UUID.<property_name>' with length 5 + len(property_name).
# time_low: 5+'time_low'(8)=13, time_mid: 5+'time_mid'(8)=13,
# time_hi_version: 5+'time_hi_version'(15)=20,
# clock_seq_hi_variant: 5+'clock_seq_hi_variant'(20)=25,
# clock_seq_low: 5+'clock_seq_low'(13)=18,
# node: 5+'node'(4)=9, time: 5+'time'(4)=9.
# extra95 anchors fget.__qualname__.__len__() for hex/bytes/urn/fields/variant/version;
# no prior uuid spec anchors fget.__qualname__.__len__() for time_low/time_mid/
# time_hi_version/clock_seq_hi_variant/clock_seq_low as a group under uuidcodev116.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra116.time_prop_fget_qualname_lengths:
  description: "UUID.time_low.fget.__qualname__.__len__()==13 / UUID.time_mid.fget.__qualname__.__len__()==13 / UUID.time_hi_version.fget.__qualname__.__len__()==20 / UUID.clock_seq_hi_variant.fget.__qualname__.__len__()==25 / UUID.clock_seq_low.fget.__qualname__.__len__()==18 / UUID.node.fget.__qualname__.__len__()==9 / UUID.time.fget.__qualname__.__len__()==9 — fget qualname is 'UUID.<name>'; extra95 anchors lengths for hex/bytes/fields/variant/version; first uuidcodev116 anchor for these time-related property fget qualname lengths"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: uuidcodev116

  columns: [id, function, args, expected, description]
  rows:
    - [time_low_fget_qlen,         "UUID.time_low.fget.__qualname__.__len__",         [], 13, "UUID.time_low.fget.__qualname__ is 'UUID.time_low' (5 + 8 = 13 chars)"]
    - [time_mid_fget_qlen,         "UUID.time_mid.fget.__qualname__.__len__",         [], 13, "UUID.time_mid.fget.__qualname__ is 'UUID.time_mid' (5 + 8 = 13 chars; same length as time_low)"]
    - [time_hi_version_fget_qlen,  "UUID.time_hi_version.fget.__qualname__.__len__",  [], 20, "UUID.time_hi_version.fget.__qualname__ is 'UUID.time_hi_version' (5 + 15 = 20 chars)"]
    - [clock_seq_hi_var_fget_qlen, "UUID.clock_seq_hi_variant.fget.__qualname__.__len__", [], 25, "UUID.clock_seq_hi_variant.fget.__qualname__ is 'UUID.clock_seq_hi_variant' (5 + 20 = 25 chars; longest among UUID property fget qualnames)"]
    - [clock_seq_low_fget_qlen,    "UUID.clock_seq_low.fget.__qualname__.__len__",    [], 18, "UUID.clock_seq_low.fget.__qualname__ is 'UUID.clock_seq_low' (5 + 13 = 18 chars)"]
    - [node_fget_qlen,             "UUID.node.fget.__qualname__.__len__",             [], 9,  "UUID.node.fget.__qualname__ is 'UUID.node' (5 + 4 = 9 chars)"]
    - [time_fget_qlen,             "UUID.time.fget.__qualname__.__len__",             [], 9,  "UUID.time.fget.__qualname__ is 'UUID.time' (5 + 4 = 9 chars; same length as node)"]

# ---------------------------------------------------------------------------
# uuid.UUID.time_low.fget.__code__.co_varnames[0].__eq__('self') — standalone
#
# uuid.UUID.time_low.fget.__code__.co_varnames[0] is 'self'. The co_varnames
# tuple of a code object lists all local variable names, starting with the
# function's positional arguments. For an instance method property getter, the
# first argument (co_varnames[0]) is always 'self'. This is distinct from
# co_name (which is 'time_low' — the function name as defined in the def
# statement). extra92 anchors co_name and co_argcount; no prior uuid spec
# anchors co_varnames[0] for time_low as a standalone under uuidcodev116.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra116.time_low_fget_co_varnames0_self:
  description: "uuid.UUID.time_low.fget.__code__.co_varnames[0].__eq__('self') == True — co_varnames[0] is 'self' (the first arg of the instance method); distinct from co_name which is 'time_low' (the function name); extra92 anchors co_name/co_argcount; first standalone for time_low fget co_varnames[0] under uuidcodev116"
  category: code_attributes
  kind: python_call_eq
  function: "UUID.time_low.fget.__code__.co_varnames[0].__eq__"
  args: ["self"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.time.fget.__code__.co_varnames[0].__eq__('self') — standalone
#
# uuid.UUID.time.fget.__code__.co_varnames[0] is 'self'. Unlike the simpler
# property getters (time_low, time_mid, etc.) which have only 1 co_varname,
# uuid.UUID.time.fget has co_varnames == ('self', 'time_hi', 'time_lo').
# The extra local variables time_hi and time_lo are computed within the function
# body. Despite having 3 co_varnames, co_varnames[0] is still 'self' and
# co_argcount is still 1. extra92 anchors co_name=='time' and co_argcount==1;
# no prior uuid spec anchors co_varnames[0] for time.fget as a standalone
# under uuidcodev116. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra116.time_fget_co_varnames0_self:
  description: "uuid.UUID.time.fget.__code__.co_varnames[0].__eq__('self') == True — time.fget has 3 co_varnames ('self','time_hi','time_lo') but co_varnames[0] is still 'self'; time_hi/time_lo are computed locals not arguments; co_argcount is 1; extra92 anchors co_name=='time'; first standalone for time.fget co_varnames[0] under uuidcodev116"
  category: code_attributes
  kind: python_call_eq
  function: "UUID.time.fget.__code__.co_varnames[0].__eq__"
  args: ["self"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.clock_seq_hi_variant.fget.__qualname__.__len__()==25 — standalone
#
# uuid.UUID.clock_seq_hi_variant.fget.__qualname__.__len__() is 25.
# 'UUID.clock_seq_hi_variant' = 'UUID.' (5) + 'clock_seq_hi_variant' (20) = 25.
# This is the longest fget qualname among UUID properties, because
# 'clock_seq_hi_variant' is the longest property name in the UUID class.
# extra95 anchors fget.__qualname__.__len__() for hex/bytes/urn/fields/variant/version;
# extra97 anchors fget.__qualname__.__eq__ for clock_seq_hi_variant; no prior uuid
# spec anchors clock_seq_hi_variant fget qualname length as a standalone under
# uuidcodev116. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra116.clock_seq_hi_variant_fget_qlen_25:
  description: "uuid.UUID.clock_seq_hi_variant.fget.__qualname__.__len__() == 25 — 'UUID.clock_seq_hi_variant' is 5 + 20 = 25 chars; the longest UUID property fget qualname; extra95 anchors fget qualname lengths for shorter properties; extra97 anchors qualname equality for clock_seq_hi_variant; first standalone for clock_seq_hi_variant fget qualname length under uuidcodev116"
  category: qualname_lengths
  kind: python_call_eq
  function: "UUID.clock_seq_hi_variant.fget.__qualname__.__len__"
  args: []
  expected: 25

# ---------------------------------------------------------------------------
# uuid.UUID.time_hi_version.fget.__qualname__.__len__()==20 — standalone
#
# uuid.UUID.time_hi_version.fget.__qualname__.__len__() is 20.
# 'UUID.time_hi_version' = 'UUID.' (5) + 'time_hi_version' (15) = 20.
# time_hi_version encodes the high bits of the timestamp and the UUID version
# number (bits 60-63). extra95 anchors fget qualname lengths for hex/bytes/etc.;
# extra97 anchors fget qualname equality for time_hi_version; no prior uuid
# spec anchors time_hi_version fget qualname length as a standalone under
# uuidcodev116. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra116.time_hi_version_fget_qlen_20:
  description: "uuid.UUID.time_hi_version.fget.__qualname__.__len__() == 20 — 'UUID.time_hi_version' is 5 + 15 = 20 chars; encodes high timestamp bits and version field; extra95 anchors shorter property fget qualname lengths; extra97 anchors qualname equality for time_hi_version; first standalone for time_hi_version fget qualname length under uuidcodev116"
  category: qualname_lengths
  kind: python_call_eq
  function: "UUID.time_hi_version.fget.__qualname__.__len__"
  args: []
  expected: 20
