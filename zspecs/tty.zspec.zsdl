spec: tty
version: ">=3.0"
backend: python_module(tty)

docs: https://docs.python.org/3/library/tty.html

provenance:
  derived_from:
    - "Python tty documentation — https://docs.python.org/3/library/tty.html"
    - "Test vectors verified by running Python 3.14.3 tty module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tty.py"
  notes:
    - "tty is a POSIX-only module (available on macOS and Linux; not available on Windows)."
    - "setraw(fd) puts the terminal referenced by fd into raw mode; setcbreak(fd) puts it into cbreak mode."
    - "Both functions wrap termios.tcgetattr / termios.tcsetattr internally."
    - "The integer constants IFLAG, OFLAG, CFLAG, LFLAG, ISPEED, OSPEED, CC index into the termios attribute list."
    - "These indices match the POSIX termios structure: [0]=c_iflag, [1]=c_oflag, [2]=c_cflag, [3]=c_lflag, [4]=c_ispeed, [5]=c_ospeed, [6]=c_cc."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

table tty.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [setraw,    setraw.__name__.__eq__,    ["setraw"],    true]
    - [setcbreak, setcbreak.__name__.__eq__, ["setcbreak"], true]

# ---------------------------------------------------------------------------
# Module identity
# ---------------------------------------------------------------------------

table tty.module_checks:
  kind: python_call_eq
  category: module
  id_prefix: mod

  columns: [id, function, args, expected]
  rows:
    - [setraw_module,    setraw.__module__.__eq__,    ["tty"], true]
    - [setcbreak_module, setcbreak.__module__.__eq__, ["tty"], true]

# ---------------------------------------------------------------------------
# Integer constants — termios attribute list indices
# ---------------------------------------------------------------------------

table tty.constants:
  kind: python_call_eq
  category: constants
  id_prefix: const

  columns: [id, function, args, expected]
  rows:
    - [iflag,  IFLAG.__eq__,  [0], true]
    - [oflag,  OFLAG.__eq__,  [1], true]
    - [cflag,  CFLAG.__eq__,  [2], true]
    - [lflag,  LFLAG.__eq__,  [3], true]
    - [ispeed, ISPEED.__eq__, [4], true]
    - [ospeed, OSPEED.__eq__, [5], true]
    - [cc,     CC.__eq__,     [6], true]
