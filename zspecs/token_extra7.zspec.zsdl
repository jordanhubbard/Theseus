spec: token_extra7
version: ">=3.12"
backend: python_module(token)

docs: https://docs.python.org/3/library/token.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/token.html — Python token module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/token.py"
    - "token.zspec.zsdl — covers ENDMARKER=0, NAME=1, NUMBER=2, STRING=3, NEWLINE=4, INDENT=5, DEDENT=6, OP=55, TYPE_COMMENT=57, SOFT_KEYWORD=58, COMMENT=65, NL=66, ERRORTOKEN=67, ENCODING=68 exact values; NT_OFFSET=256; tok_name lookups [0-6]; ISEOF/ISTERMINAL/ISNONTERMINAL predicates"
    - "token_extra.zspec.zsdl — covers int type checks for all major constants, tok_name/EXACT_TOKEN_TYPES is_dict, NAME/NUMBER/STRING/NEWLINE/ENDMARKER exact values"
    - "token_extra2.zspec.zsdl — covers EXACT_TYPE/ERRORTOKEN/ENCODING/TYPE_COMMENT is_int, tok_name is_dict, tok_name min_length>=50, tok_name[0-4], ENDMARKER==0"
    - "token_extra3.zspec.zsdl — covers int type checks via tables, tok_name/EXACT_TOKEN_TYPES is_dict, NAME>0/NUMBER>0/ENDMARKER==0, tok_name[1]=='NAME'"
    - "token_extra4.zspec.zsdl — covers INDENT==5, DEDENT==6, tok_name[2-6], EXACT_TOKEN_TYPES membership '='/'+'/':',, tok_name[4]=='NEWLINE', INDENT>NEWLINE/DEDENT>INDENT ordering"
    - "token_extra5.zspec.zsdl — covers SOFT_KEYWORD==58/is_int, FSTRING_START==59/is_int, FSTRING_END==61/is_int, tok_name[58]=='SOFT_KEYWORD', tok_name[59]=='FSTRING_START', tok_name len>=60, EXACT_TOKEN_TYPES len>=40 and membership for '('/')'/'.'"
    - "token_extra6.zspec.zsdl — covers ISEOF(2)/ISEOF(255) false; ISTERMINAL(0)/ISTERMINAL(255) true, ISTERMINAL(256) false; ISNONTERMINAL(256) true, ISNONTERMINAL(255) false; tok_name.__contains__(0/1/65/66); EXACT_TOKEN_TYPES.__contains__('-'/'*'); EXACT_TOKEN_TYPES['='] is int"
  notes:
    - "This spec adds new axes for the token module not covered in any prior token spec."
    - "ISEOF, ISTERMINAL, ISNONTERMINAL are functions in the token module; their __module__ is 'token'."
    - "token.ISEOF.__module__ == 'token' — not tested in any prior spec."
    - "token.ISTERMINAL.__module__ == 'token' — not tested in any prior spec."
    - "token.ISNONTERMINAL.__module__ == 'token' — not tested in any prior spec."
    - "token.tok_name.__getitem__(65) == 'COMMENT' — COMMENT maps to 65 on Python 3.14; prior specs check __contains__(65) but not the value."
    - "token.tok_name.__getitem__(66) == 'NL' — NL maps to 66 on Python 3.14; prior specs check __contains__(66) but not the value."
    - "token.tok_name.__getitem__(67) == 'ERRORTOKEN' — ERRORTOKEN maps to 67 on Python 3.14; not tested in any prior spec."
    - "token.tok_name.__getitem__(68) == 'ENCODING' — ENCODING maps to 68 on Python 3.14; not tested in any prior spec."
    - "token.COMMENT == 65 on Python 3.14 (was different in older CPython). The base spec verifies COMMENT=65."
    - "token.EXACT_TOKEN_TYPES.__contains__('/') == True — forward slash is an operator token."
    - "token.EXACT_TOKEN_TYPES.__contains__('%') == True — percent operator is an exact token type."
    - "token.EXACT_TOKEN_TYPES.__contains__('**') == True — power operator is an exact token type."
    - "token.EXACT_TOKEN_TYPES.__contains__('//') == True — floor division is an exact token type."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ISEOF, ISTERMINAL, ISNONTERMINAL __module__ attributes
# All three are functions defined in Lib/token.py. No prior spec checks
# their __module__ attribute.
# ---------------------------------------------------------------------------

table token_extra7.predicate_modules:
  kind: python_call_eq
  category: module_attrs
  id_prefix: pred_mod

  columns: [id, function, args, expected]
  rows:
    - [ISEOF,         ISEOF.__module__.__eq__,         ["token"], true]
    - [ISTERMINAL,    ISTERMINAL.__module__.__eq__,    ["token"], true]
    - [ISNONTERMINAL, ISNONTERMINAL.__module__.__eq__, ["token"], true]

# ---------------------------------------------------------------------------
# tok_name lookups for extended constants (Python 3.14 values)
# token.zspec covers indices 0-6; token_extra5 adds 58 and 59.
# New here: 65 (COMMENT), 66 (NL), 67 (ERRORTOKEN), 68 (ENCODING).
# token_extra6 checked __contains__(65) and __contains__(66) but not __getitem__.
# ---------------------------------------------------------------------------

table token_extra7.tok_name_extended_lookups:
  kind: python_call_eq
  category: tok_name
  id_prefix: tok_name_ext

  columns: [id, function, args, expected]
  rows:
    - [comment,    tok_name.__getitem__, [65], "COMMENT"]
    - [nl,         tok_name.__getitem__, [66], "NL"]
    - [errortoken, tok_name.__getitem__, [67], "ERRORTOKEN"]
    - [encoding,   tok_name.__getitem__, [68], "ENCODING"]

# ---------------------------------------------------------------------------
# EXACT_TOKEN_TYPES — additional operator membership checks
# token_extra4 covers '=', '+', ':'; token_extra5 covers '(', ')', '.';
# token_extra6 covers '-', '*'. New here: '/', '%', '**', '//'.
# ---------------------------------------------------------------------------

table token_extra7.exact_token_types_operators:
  kind: python_call_eq
  category: dict_contents
  id_prefix: ett_op

  columns: [id, function, args, expected]
  rows:
    - [slash,       EXACT_TOKEN_TYPES.__contains__, ["/"],  true]
    - [percent,     EXACT_TOKEN_TYPES.__contains__, ["%"],  true]
    - [power,       EXACT_TOKEN_TYPES.__contains__, ["**"], true]
    - [floordiv,    EXACT_TOKEN_TYPES.__contains__, ["//"], true]

# ---------------------------------------------------------------------------
# ISEOF predicate for token constants 3, 4, 5, 6
# token.zspec covers ISEOF(0)==True and ISEOF(1)==False.
# token_extra6 adds ISEOF(2) and ISEOF(255).
# New here: ISEOF applied to STRING(3), NEWLINE(4), INDENT(5), DEDENT(6)
# — all are terminal tokens and none is EOF.
# ---------------------------------------------------------------------------

table token_extra7.ISEOF_additional_false:
  kind: python_call_eq
  category: predicates
  id_prefix: iseof_false

  columns: [id, function, args, expected]
  rows:
    - [string,  ISEOF, [3], false]
    - [newline, ISEOF, [4], false]
    - [indent,  ISEOF, [5], false]
    - [dedent,  ISEOF, [6], false]

# ---------------------------------------------------------------------------
# ISTERMINAL for additional values
# token.zspec covers ISTERMINAL(1)==True and ISTERMINAL(300)==False.
# token_extra6 covers ISTERMINAL(0)/ISTERMINAL(255)/ISTERMINAL(256).
# New here: ISTERMINAL(3)==True (STRING), ISTERMINAL(500)==False (above NT_OFFSET).
# ---------------------------------------------------------------------------

invariant token_extra7.ISTERMINAL.string_is_terminal:
  description: "token.ISTERMINAL(3) == True — STRING is a terminal token"
  category: predicates
  kind: python_call_eq
  function: ISTERMINAL
  args: [3]
  expected: true

invariant token_extra7.ISTERMINAL.above_nt_offset_false:
  description: "token.ISTERMINAL(500) == False — 500 > NT_OFFSET(256) so not terminal"
  category: predicates
  kind: python_call_eq
  function: ISTERMINAL
  args: [500]
  expected: false
