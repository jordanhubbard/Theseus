spec: concurrent_futures_extra153
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: concurrent.futures._base.Future method qualnames. concurrent.futures._base.Future.result.__qualname__=='Future.result' (len=13); concurrent.futures._base.Future.cancel.__qualname__=='Future.cancel' (len=13); concurrent.futures._base.Future.done.__qualname__=='Future.done' (len=11); concurrent.futures._base.Future.cancelled.__qualname__=='Future.cancelled' (len=16); concurrent.futures._base.Future.running.__qualname__=='Future.running' (len=14); concurrent.futures._base.Future.add_done_callback.__qualname__=='Future.add_done_callback' (len=24). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures._base.Future method qualname length ordering — Future.done(11) < Future.cancel(13) == Future.result(13) < Future.running(14) < Future.cancelled(16) < Future.add_done_callback(24); Future.cancel and Future.result have the same qualname length (13: 'Future'=6+'.'=1+'cancel'=6=13 and 'Future'=6+'.'=1+'result'=6=13); Future.add_done_callback is the longest at 24 ('Future'=6+'.'=1+'add_done_callback'=17=24); Future.done is the shortest at 11 ('Future'=6+'.'=1+'done'=4=11). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures._base.Future is defined in Lib/concurrent/futures/_base.py — it is the thread-safe future class used by ThreadPoolExecutor and ProcessPoolExecutor; Future.result() blocks until the future is complete and returns the result (or raises the exception); Future.cancel() attempts to cancel execution; Future.done() and Future.cancelled() and Future.running() are state-inspection predicates; Future.add_done_callback() registers a callback to be called when the future completes. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures._base.Future state predicate method qualnames — extra153
#
# concurrent.futures._base.Future.done.__qualname__.__eq__('Future.done')           == True
# concurrent.futures._base.Future.cancelled.__qualname__.__eq__('Future.cancelled') == True
# concurrent.futures._base.Future.running.__qualname__.__eq__('Future.running')     == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra153.cf_future_predicate_qualnames:
  description: "concurrent.futures._base.Future state predicate method qualname checks in cffutpred153 namespace — concurrent.futures._base.Future.done.__qualname__=='Future.done' (len=11: 'Future'=6+'.'=1+'done'=4=11; done() returns True if the future is cancelled or finished executing); concurrent.futures._base.Future.cancelled.__qualname__=='Future.cancelled' (len=16: 'Future'=6+'.'=1+'cancelled'=9=16; cancelled() returns True if cancel() was called and the call was successfully cancelled); concurrent.futures._base.Future.running.__qualname__=='Future.running' (len=14: 'Future'=6+'.'=1+'running'=7=14; running() returns True if the call is currently being executed); predicate qualname length ordering: Future.done(11) < Future.running(14) < Future.cancelled(16); all three are state-inspection predicates with no side effects; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffutpred153

  columns: [id, function, args, expected, description]
  rows:
    - [done_qn_eq,      concurrent.futures._base.Future.done.__qualname__.__eq__,      ["Future.done"],      true,  "concurrent.futures._base.Future.done.__qualname__ == 'Future.done' (len=11); verified with Python 3.14.3"]
    - [cancelled_qn_eq, concurrent.futures._base.Future.cancelled.__qualname__.__eq__, ["Future.cancelled"], true,  "concurrent.futures._base.Future.cancelled.__qualname__ == 'Future.cancelled' (len=16); verified with Python 3.14.3"]
    - [running_qn_eq,   concurrent.futures._base.Future.running.__qualname__.__eq__,   ["Future.running"],   true,  "concurrent.futures._base.Future.running.__qualname__ == 'Future.running' (len=14); verified with Python 3.14.3"]
    - [done_qn_len,     concurrent.futures._base.Future.done.__qualname__.__len__,     [],                   11,    "concurrent.futures._base.Future.done.__qualname__.__len__() == 11 ('Future.done'; shortest predicate qualname); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures._base.Future action method qualnames — extra153
#
# concurrent.futures._base.Future.result.__qualname__.__eq__('Future.result')       == True
# concurrent.futures._base.Future.cancel.__qualname__.__eq__('Future.cancel')       == True
# concurrent.futures._base.Future.add_done_callback.__qualname__.__eq__('Future.add_done_callback') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra153.cf_future_action_qualnames:
  description: "concurrent.futures._base.Future action method qualname checks in cffutact153 namespace — concurrent.futures._base.Future.result.__qualname__=='Future.result' (len=13: 'Future'=6+'.'=1+'result'=6=13; result() blocks until the future is done and returns the computed value or raises the stored exception); concurrent.futures._base.Future.cancel.__qualname__=='Future.cancel' (len=13: 'Future'=6+'.'=1+'cancel'=6=13; cancel() attempts to prevent the future from running — same qualname length as result); concurrent.futures._base.Future.add_done_callback.__qualname__=='Future.add_done_callback' (len=24: 'Future'=6+'.'=1+'add_done_callback'=17=24; add_done_callback(fn) registers fn to be called with the future as its only argument when the future completes or is cancelled; longest qualname in this spec); action qualname length: cancel(13) == result(13) < add_done_callback(24); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffutact153

  columns: [id, function, args, expected, description]
  rows:
    - [result_qn_eq,  concurrent.futures._base.Future.result.__qualname__.__eq__,           ["Future.result"],           true,  "concurrent.futures._base.Future.result.__qualname__ == 'Future.result' (len=13); verified with Python 3.14.3"]
    - [cancel_qn_eq,  concurrent.futures._base.Future.cancel.__qualname__.__eq__,           ["Future.cancel"],           true,  "concurrent.futures._base.Future.cancel.__qualname__ == 'Future.cancel' (len=13; same length as Future.result); verified with Python 3.14.3"]
    - [adc_qn_eq,     concurrent.futures._base.Future.add_done_callback.__qualname__.__eq__, ["Future.add_done_callback"], true, "concurrent.futures._base.Future.add_done_callback.__qualname__ == 'Future.add_done_callback' (len=24; longest qualname in this spec); verified with Python 3.14.3"]
    - [adc_qn_len,    concurrent.futures._base.Future.add_done_callback.__qualname__.__len__, [],                          24,   "concurrent.futures._base.Future.add_done_callback.__qualname__.__len__() == 24 ('Future.add_done_callback'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra153
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra153.cf_Future_result_qualname_eq:
  description: "concurrent.futures._base.Future.result.__qualname__.__eq__('Future.result') returns True — concurrent.futures._base.Future.result is an instance method with qualname 'Future.result' (len=13: 'Future'=6+'.'=1+'result'=6=13); result() is the primary method for retrieving the value computed by the future: it blocks until the future is done (or until timeout expires), then returns the value or re-raises the stored exception; Future.result.__qualname__=='Future.result' confirms it is defined directly on the Future class; cancel and result have the same qualname length (13) because 'cancel'=6 and 'result'=6 are the same length; NEW in extra153: first standalone Future.result.__qualname__ identity invariant in cffutact153 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures._base.Future.result.__qualname__.__eq__
  args: ["Future.result"]
  expected: true

invariant concurrent_futures_extra153.cf_Future_cancel_qualname_eq:
  description: "concurrent.futures._base.Future.cancel.__qualname__.__eq__('Future.cancel') returns True — concurrent.futures._base.Future.cancel is an instance method with qualname 'Future.cancel' (len=13: 'Future'=6+'.'=1+'cancel'=6=13; same length as 'Future.result'=13 because 'cancel'=6=='result'=6); cancel() attempts to cancel the future: if the associated call has not started it will be cancelled and return True; if it has already started or is done, cancel() returns False; Future.cancel.__qualname__=='Future.cancel' confirms it is defined on Future (not inherited); NEW in extra153: first standalone Future.cancel.__qualname__ identity invariant in cffutact153 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures._base.Future.cancel.__qualname__.__eq__
  args: ["Future.cancel"]
  expected: true

invariant concurrent_futures_extra153.cf_Future_done_qualname_eq:
  description: "concurrent.futures._base.Future.done.__qualname__.__eq__('Future.done') returns True — concurrent.futures._base.Future.done is a state predicate with qualname 'Future.done' (len=11: 'Future'=6+'.'=1+'done'=4=11; the shortest qualname among all Future methods in this spec); done() returns True if the future is cancelled or has finished executing; the qualname 'Future.done' confirms it is defined directly on Future; length ordering: Future.done(11) < Future.running(14) < Future.cancelled(16) < Future.add_done_callback(24); NEW in extra153: first standalone Future.done.__qualname__ identity invariant in cffutpred153 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures._base.Future.done.__qualname__.__eq__
  args: ["Future.done"]
  expected: true

invariant concurrent_futures_extra153.cf_Future_add_done_callback_qualname_eq:
  description: "concurrent.futures._base.Future.add_done_callback.__qualname__.__eq__('Future.add_done_callback') returns True — concurrent.futures._base.Future.add_done_callback is an instance method with qualname 'Future.add_done_callback' (len=24: 'Future'=6+'.'=1+'add_done_callback'=17=24; the longest qualname in this spec; 'add_done_callback'=17 because 'add'=3+'_'=1+'done'=4+'_'=1+'callback'=8=17); add_done_callback(fn) attaches a callback function that will be called — with the future as its only argument — when the future completes or is cancelled; callbacks are called in the thread that calls set_result or set_exception (or in the executor thread); qualname length: add_done_callback(24) is 13 chars longer than the next longest method (cancelled=16... wait: Future.cancelled.__qualname__='Future.cancelled'(16); add_done_callback(24)>cancelled(16)); NEW in extra153: first standalone Future.add_done_callback.__qualname__ identity invariant in cffutact153 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures._base.Future.add_done_callback.__qualname__.__eq__
  args: ["Future.add_done_callback"]
  expected: true

invariant concurrent_futures_extra153.cf_Future_cancelled_qualname_eq:
  description: "concurrent.futures._base.Future.cancelled.__qualname__.__eq__('Future.cancelled') returns True — concurrent.futures._base.Future.cancelled is a state predicate with qualname 'Future.cancelled' (len=16: 'Future'=6+'.'=1+'cancelled'=9=16); cancelled() returns True if cancel() was successfully called on this future; 'cancelled'=9 is the same length as 'completed'=9 (the string in the concurrent.futures constants FIRST_COMPLETED, ALL_COMPLETED established in extra152); Future.cancelled.__qualname__=='Future.cancelled' (len=16) sits between Future.running (len=14) and Future.add_done_callback (len=24) in length ordering; NEW in extra153: first standalone Future.cancelled.__qualname__ identity invariant in cffutpred153 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures._base.Future.cancelled.__qualname__.__eq__
  args: ["Future.cancelled"]
  expected: true
