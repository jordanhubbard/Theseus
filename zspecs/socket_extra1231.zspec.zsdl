spec: socket_extra1231
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks socket.__dict__.__contains__ for top-level module attributes: socket, error, timeout, herror, gaierror, AF_INET, AF_INET6, SOCK_STREAM, SOCK_DGRAM, gethostname, getaddrinfo, create_connection, setdefaulttimeout; also module name/package attrs"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra1231.module_dict_contains_exceptions_and_classes:
  description: "socket.__dict__.__contains__ checks for socket class and exception type names"
  kind: python_call_eq
  category: module_dict_contains_exceptions_and_classes
  id_prefix: sk1231ec
  columns: [id, function, args, expected]
  rows:
    - [sk1231ec001, socket.__dict__.__contains__,                    ["socket"],                    true]
    - [sk1231ec002, socket.__dict__.__contains__,                    ["error"],                     true]
    - [sk1231ec003, socket.__dict__.__contains__,                    ["timeout"],                   true]
    - [sk1231ec004, socket.__dict__.__contains__,                    ["herror"],                    true]
    - [sk1231ec005, socket.__dict__.__contains__,                    ["gaierror"],                  true]
    - [sk1231ec006, socket.__dict__.__class__.__name__.__eq__,       ["dict"],                      true]
    - [sk1231ec007, socket.__dict__.__class__.__qualname__.__eq__,   ["dict"],                      true]
    - [sk1231ec008, socket.__dict__.__class__.__module__.__eq__,     ["builtins"],                  true]
    - [sk1231ec009, socket.__dict__.__class__.__name__.__class__.__name__.__eq__, ["str"],          true]

table socket_extra1231.module_dict_contains_constants_and_functions:
  description: "socket.__dict__.__contains__ checks for AF_INET, AF_INET6, SOCK_STREAM, SOCK_DGRAM, gethostname, getaddrinfo, create_connection, setdefaulttimeout"
  kind: python_call_eq
  category: module_dict_contains_constants_and_functions
  id_prefix: sk1231cf
  columns: [id, function, args, expected]
  rows:
    - [sk1231cf001, socket.__dict__.__contains__,                    ["AF_INET"],                   true]
    - [sk1231cf002, socket.__dict__.__contains__,                    ["AF_INET6"],                  true]
    - [sk1231cf003, socket.__dict__.__contains__,                    ["SOCK_STREAM"],               true]
    - [sk1231cf004, socket.__dict__.__contains__,                    ["SOCK_DGRAM"],                true]
    - [sk1231cf005, socket.__dict__.__contains__,                    ["gethostname"],               true]
    - [sk1231cf006, socket.__dict__.__contains__,                    ["getaddrinfo"],               true]
    - [sk1231cf007, socket.__dict__.__contains__,                    ["create_connection"],         true]
    - [sk1231cf008, socket.__dict__.__contains__,                    ["setdefaulttimeout"],         true]
    - [sk1231cf009, socket.__dict__.__class__.__module__.__class__.__name__.__eq__, ["str"],        true]

table socket_extra1231.module_name_and_package_attrs:
  description: "socket module __name__, __package__, and standard dunder attrs via __dict__.__contains__ and direct attribute access"
  kind: python_call_eq
  category: module_name_and_package_attrs
  id_prefix: sk1231np
  columns: [id, function, args, expected]
  rows:
    - [sk1231np001, socket.__dict__.__contains__,                    ["__name__"],                  true]
    - [sk1231np002, socket.__dict__.__contains__,                    ["__doc__"],                   true]
    - [sk1231np003, socket.__dict__.__contains__,                    ["__package__"],               true]
    - [sk1231np004, socket.__dict__.__contains__,                    ["__spec__"],                  true]
    - [sk1231np005, socket.__name__.__eq__,                          ["socket"],                    true]
    - [sk1231np006, socket.__name__.__class__.__name__.__eq__,       ["str"],                       true]
    - [sk1231np007, socket.__package__.__eq__,                       [""],                          true]
    - [sk1231np008, socket.__package__.__class__.__name__.__eq__,    ["str"],                       true]
    - [sk1231np009, socket.__dict__.__class__.__qualname__.__class__.__name__.__eq__, ["str"],      true]
