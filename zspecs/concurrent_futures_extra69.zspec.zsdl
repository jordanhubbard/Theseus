    - [invstate_name,     InvalidStateError.__name__.__eq__,     ["InvalidStateError"],         true, "InvalidStateError.__name__ == 'InvalidStateError' — concurrent.futures.InvalidStateError is defined in concurrent/futures/_base.py; its __name__ is 'InvalidStateError'; NEW in extra69: first __name__.__eq__('InvalidStateError') check for InvalidStateError in the cfann69 namespace; verified with Python 3.14.3"]
    - [invstate_module,   InvalidStateError.__module__.__eq__,   ["concurrent.futures._base"],  true, "InvalidStateError.__module__ == 'concurrent.futures._base' — InvalidStateError is defined in concurrent/futures/_base.py; its __module__ is 'concurrent.futures._base'; NEW in extra69: first __module__.__eq__('concurrent.futures._base') check for InvalidStateError in the cfann69 namespace; verified with Python 3.14.3"]
    - [invstate_qualname, InvalidStateError.__qualname__.__eq__, ["InvalidStateError"],         true, "InvalidStateError.__qualname__ == 'InvalidStateError' — InvalidStateError is a top-level class in its module; its __qualname__ is 'InvalidStateError'; NEW in extra69: first __qualname__.__eq__('InvalidStateError') check for InvalidStateError in the cfann69 namespace; verified with Python 3.14.3"]

