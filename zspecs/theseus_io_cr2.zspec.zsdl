spec: theseus_io_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_io_cr2)
blocks: io

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html"
  notes:
    - "Clean-room extended I/O streams. Do NOT import io."
    - "StringIO: in-memory text stream with read/write/seek/tell/getvalue."
    - "BytesIO: in-memory binary stream with read/write/seek/tell/getvalue."
    - "BufferedReader-like: wrap a raw stream, provide buffered read."
    - "io_cr2_stringio_seek(): write 'hello'; seek(0); read() == 'hello'."
    - "io_cr2_bytesio_tell(): write b'abc'; tell() == 3."
    - "io_cr2_stringio_readline(): write 'a\\nb'; seek(0); readline() == 'a\\n'."
    - "Export: StringIO, BytesIO classes."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_io_cr2.stringio_seek:
  description: "StringIO: write 'hello'; seek(0); read() == 'hello'"
  category: stringio
  kind: python_call_eq
  function: io_cr2_stringio_seek
  args: []
  expected: "hello"

invariant theseus_io_cr2.bytesio_tell:
  description: "BytesIO: write b'abc'; tell() == 3"
  category: bytesio
  kind: python_call_eq
  function: io_cr2_bytesio_tell
  args: []
  expected: 3

invariant theseus_io_cr2.stringio_readline:
  description: "StringIO: write 'a\\nb'; seek(0); readline() == 'a\\n'"
  category: stringio
  kind: python_call_eq
  function: io_cr2_stringio_readline
  args: []
  expected: "a\n"
