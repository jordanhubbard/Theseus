spec: struct_extra21
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct.zspec.zsdl — pack/unpack/calcsize core vectors."
    - "struct_extra.zspec.zsdl through struct_extra20.zspec.zsdl — prior extras."
  notes:
    - "This spec extends struct.zspec.zsdl through struct_extra20.zspec.zsdl."
    - "struct_extra4 covers module-level function __qualname__: pack/unpack/pack_into/unpack_from/calcsize/iter_unpack."
    - "struct_extra9 covers Struct class method __qualname__: Struct.pack/unpack/pack_into/unpack_from/iter_unpack."
    - "No prior struct spec checks __qualname__ for Struct.__init__ or Struct.__repr__."
    - "This spec adds NEW axes:"
    - "  (1) struct.Struct.__init__.__qualname__ == 'Struct.__init__' — dunder method qualname includes class prefix."
    - "  (2) struct.Struct.__repr__.__qualname__ == 'Struct.__repr__' — dunder method qualname includes class prefix."
    - "  (3) struct.Struct.pack.__qualname__.__len__() == 11 — len('Struct.pack') == 11."
    - "  (4) struct.Struct.unpack.__qualname__.__len__() == 13 — len('Struct.unpack') == 13."
    - "  (5) struct.Struct.pack_into.__qualname__.__len__() == 16 — len('Struct.pack_into') == 16."
    - "  (6) struct.Struct.unpack_from.__qualname__.__len__() == 18 — len('Struct.unpack_from') == 18."
    - "  (7) struct.Struct.iter_unpack.__qualname__.__len__() == 18 — len('Struct.iter_unpack') == 18."
    - "  (8) struct.Struct.__init__.__qualname__.__len__() == 15 — len('Struct.__init__') == 15."
    - "  (9) struct.Struct.__repr__.__qualname__.__len__() == 15 — len('Struct.__repr__') == 15."
    - "struct.Struct.__init__.__qualname__ == 'Struct.__init__' — Verified Python 3.12 macOS."
    - "struct.Struct.__repr__.__qualname__ == 'Struct.__repr__' — Verified."
    - "len('Struct.pack') == 11 — Verified."
    - "len('Struct.unpack') == 13 — Verified."
    - "len('Struct.pack_into') == 16 — Verified."
    - "len('Struct.unpack_from') == 18 — Verified."
    - "len('Struct.iter_unpack') == 18 — Verified."
    - "len('Struct.__init__') == 15 — Verified."
    - "len('Struct.__repr__') == 15 — Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Struct.__init__ and Struct.__repr__ __qualname__ — dunder methods not yet covered
#
# struct_extra9 covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __qualname__.
# No prior spec checks __qualname__ for the __init__ or __repr__ dunder methods
# on the Struct class. Under python_module(struct), 'Struct.__init__.__qualname__.__eq__'
# resolves as struct_module.Struct.__init__.__qualname__.__eq__.
# For class-level methods, __qualname__ includes the class prefix 'Struct.'.
# ---------------------------------------------------------------------------

invariant struct_extra21.Struct.init_qualname:
  description: "struct.Struct.__init__.__qualname__ == 'Struct.__init__' — dunder method qualname includes class prefix"
  category: method_qualnames
  kind: python_call_eq
  function: Struct.__init__.__qualname__.__eq__
  args: ["Struct.__init__"]
  expected: true

invariant struct_extra21.Struct.repr_qualname:
  description: "struct.Struct.__repr__.__qualname__ == 'Struct.__repr__' — dunder method qualname includes class prefix"
  category: method_qualnames
  kind: python_call_eq
  function: Struct.__repr__.__qualname__.__eq__
  args: ["Struct.__repr__"]
  expected: true

# ---------------------------------------------------------------------------
# Struct class method __qualname__ string lengths — length axis cross-checks
#
# struct_extra9 verifies Struct method __qualname__ equality.
# struct_extra20 checks __len__() for module-level function qualnames.
# No prior spec checks __len__() for Struct class method qualnames.
# These provide an independent axis: length validation without string equality.
# ---------------------------------------------------------------------------

table struct_extra21.Struct_method_qualname_lengths:
  description: "struct.Struct method __qualname__ string lengths for methods covered by struct_extra9"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: smqlen21

  columns: [id, function, args, expected]
  rows:
    - [pack,        Struct.pack.__qualname__.__len__,        [], 11]
    - [unpack,      Struct.unpack.__qualname__.__len__,      [], 13]
    - [pack_into,   Struct.pack_into.__qualname__.__len__,   [], 16]
    - [unpack_from, Struct.unpack_from.__qualname__.__len__, [], 18]
    - [iter_unpack, Struct.iter_unpack.__qualname__.__len__, [], 18]
    - [dunder_init, Struct.__init__.__qualname__.__len__,    [], 15]
    - [dunder_repr, Struct.__repr__.__qualname__.__len__,    [], 15]
