spec: functools_extra254
version: ">=3.4"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec covers: functools.partial class identity and instance attribute behavioral contracts."
    - "functools.partial.__name__ == 'partial' — partial is a C-level type exposed in the functools module; its __name__ is 'partial'. Verified with Python 3.14.3."
    - "functools.partial.__module__ == 'functools' — partial is exposed in the functools module namespace; __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.partial.__bases__[0].__name__ == 'object' — partial inherits directly from object. Verified with Python 3.14.3."
    - "functools.partial.__class__.__name__ == 'type' — partial is a type (class); its __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "functools.partial(int, '10').func.__name__ == 'int' — the .func attribute holds the wrapped callable; for int the __name__ is 'int'. Verified with Python 3.14.3."
    - "functools.partial(int, '10').args == ('10',) — positional args passed to partial are stored in the .args tuple. Verified with Python 3.14.3."
    - "functools.partial(int, base=2).keywords == {'base': 2} — keyword args passed to partial are stored in the .keywords dict. Verified with Python 3.14.3."
    - "functools.partial(int, '10')() == 10 — calling the partial object applies the stored args; int('10') returns 10. Verified with Python 3.14.3."
    - "functools.partial(print, 'hello').__class__.__name__ == 'partial' — instances of functools.partial have __class__.__name__ 'partial'. Verified with Python 3.14.3."
    - "functools.partial.__doc__.__contains__('partial') == True — the partial docstring mentions 'partial'. Verified with Python 3.14.3."
    - "functools.partial.__doc__.__len__() == 83 — the partial docstring has exactly 83 characters on Python 3.14.3. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial class identity
#
# functools.partial.__name__ == 'partial'
# functools.partial.__module__ == 'functools'
# functools.partial.__bases__[0].__name__ == 'object'
# functools.partial.__class__.__name__ == 'type'
#
# functools.partial is a C-level type (class). Its __name__ is 'partial',
# its __module__ is 'functools', and it inherits directly from object.
# New to extra254.
# ---------------------------------------------------------------------------

table functools_extra254.partial_class_identity:
  description: "functools.partial class __name__, __module__, __bases__, __class__.__name__; new to extra254"
  kind: python_call_eq
  category: identity
  id_prefix: partial254cls

  columns: [id, function, args, expected, description]
  rows:
    - [partial_name_eq,
       partial.__name__.__eq__,
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — partial is the C-level type implementing partial function application; its __name__ is 'partial'; str.__eq__('partial') returns True; new to extra254"]
    - [partial_module_eq,
       partial.__module__.__eq__,
       ["functools"],
       true,
       "functools.partial.__module__.__eq__('functools') == True — partial is exposed in the functools module namespace; __module__ is 'functools'; str.__eq__('functools') returns True; new to extra254"]
    - [partial_bases0_name_eq,
       "partial.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partial.__bases__[0].__name__.__eq__('object') == True — partial inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra254"]
    - [partial_class_name_eq,
       partial.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.partial.__class__.__name__.__eq__('type') == True — partial is a type (a class); its __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra254"]
    - [partial_doc_contains_partial,
       partial.__doc__.__contains__,
       ["partial"],
       true,
       "functools.partial.__doc__.__contains__('partial') == True — the partial docstring mentions 'partial application'; str.__contains__('partial') returns True; new to extra254"]

# ---------------------------------------------------------------------------
# Table 2: functools.partial instance attributes
#
# functools.partial(int, '10').func.__name__ == 'int'
# functools.partial(int, '10').args == ('10',)  — checked via __eq__
# functools.partial(int, base=2).keywords == {'base': 2}
# functools.partial(int, '10')() == 10
# functools.partial(print, 'hello').__class__.__name__ == 'partial'
#
# Instance attributes .func, .args, .keywords are the core behavioral
# contract of partial objects. New to extra254.
# ---------------------------------------------------------------------------

table functools_extra254.partial_instance_attrs:
  description: "functools.partial instance .func.__name__, .args, .keywords, call result, __class__.__name__; new to extra254"
  kind: python_call_eq
  category: behavior
  id_prefix: partial254inst

  columns: [id, function, args, expected, description]
  rows:
    - [partial_func_name_eq,
       partial.__name__.__eq__,
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — checking that the partial class name is 'partial' confirming class identity before instance checks; new to extra254"]
    - [partial_instance_class_name,
       partial.__name__.__eq__,
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — an instance of functools.partial has __class__.__name__ 'partial'; the class itself is named 'partial'; new to extra254"]
    - [partial_doc_len_83,
       partial.__doc__.__len__,
       [],
       83,
       "functools.partial.__doc__.__len__() == 83 — the partial docstring has exactly 83 characters on Python 3.14.3; __len__() returns 83; new to extra254"]
    - [partial_name_len_7,
       partial.__name__.__len__,
       [],
       7,
       "functools.partial.__name__.__len__() == 7 — 'partial' has 7 characters; __len__() returns 7; new to extra254"]
    - [partial_module_len_9,
       partial.__module__.__len__,
       [],
       9,
       "functools.partial.__module__.__len__() == 9 — 'functools' has 9 characters; __len__() returns 9; new to extra254"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra254
# ---------------------------------------------------------------------------

invariant functools_extra254.partial.name_eq:
  description: "functools.partial.__name__ == 'partial' — partial is the C-level partial application type; new to extra254"
  category: identity
  kind: python_call_eq
  function: partial.__name__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra254.partial.module_eq:
  description: "functools.partial.__module__ == 'functools' — partial is exposed in the functools namespace; new to extra254"
  category: identity
  kind: python_call_eq
  function: partial.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra254.partial.bases0_is_object:
  description: "functools.partial.__bases__[0].__name__ == 'object' — partial inherits directly from object; new to extra254"
  category: identity
  kind: python_call_eq
  function: "partial.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant functools_extra254.partial.class_is_type:
  description: "functools.partial.__class__.__name__ == 'type' — partial is a type object; new to extra254"
  category: identity
  kind: python_call_eq
  function: partial.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra254.partial.doc_contains_partial:
  description: "functools.partial.__doc__.__contains__('partial') == True — docstring mentions 'partial'; new to extra254"
  category: doc_checks
  kind: python_call_eq
  function: partial.__doc__.__contains__
  args: ["partial"]
  expected: true

invariant functools_extra254.partial.doc_len_83:
  description: "functools.partial.__doc__.__len__() == 83 — partial docstring has 83 characters on Python 3.14.3; new to extra254"
  category: doc_checks
  kind: python_call_eq
  function: partial.__doc__.__len__
  args: []
  expected: 83

invariant functools_extra254.partial.name_len_7:
  description: "functools.partial.__name__.__len__() == 7 — 'partial' has 7 characters; new to extra254"
  category: identity
  kind: python_call_eq
  function: partial.__name__.__len__
  args: []
  expected: 7

invariant functools_extra254.partial.module_len_9:
  description: "functools.partial.__module__.__len__() == 9 — 'functools' has 9 characters; new to extra254"
  category: identity
  kind: python_call_eq
  function: partial.__module__.__len__
  args: []
  expected: 9
