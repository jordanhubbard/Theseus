spec: io_extra2656
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 io documentation — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bytesio.c"
    - "CPython source: Modules/_io/stringio.c"
    - "io_extra.zspec.zsdl — covers existing io invariants"
    - "io_extra2641.zspec.zsdl — covers __copy__/__deepcopy__/__sizeof__ dict-presence"
  notes:
    - "Wave 624 (io_extra2656) theme: __contains__, __add__, and __mul__ dict-presence checks."
    - "None of the io classes define __contains__, __add__, or __mul__ in their own __dict__."
    - "__contains__ is the membership-test protocol; io stream classes do not implement container semantics."
    - "__add__ and __mul__ are arithmetic operators; io stream classes do not implement concatenation or repetition via these hooks."
    - "Covers io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.BytesIO, io.StringIO, io.FileIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, and io.TextIOWrapper."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __contains__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2656.no_contains_in_io_classes:
  description: "__contains__ is absent from all io class __dict__s — io stream classes do not implement the container membership protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2656

  columns: [id, function, args, expected]
  rows:
    - ["io2656001", "io.IOBase.__dict__.__contains__",         ["__contains__"], false]
    - ["io2656002", "io.RawIOBase.__dict__.__contains__",      ["__contains__"], false]
    - ["io2656003", "io.BufferedIOBase.__dict__.__contains__", ["__contains__"], false]
    - ["io2656004", "io.TextIOBase.__dict__.__contains__",     ["__contains__"], false]
    - ["io2656005", "io.BytesIO.__dict__.__contains__",        ["__contains__"], false]
    - ["io2656006", "io.StringIO.__dict__.__contains__",       ["__contains__"], false]

# ---------------------------------------------------------------------------
# __add__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2656.no_add_in_io_classes:
  description: "__add__ is absent from all io class __dict__s — io stream classes do not implement the arithmetic addition protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2656

  columns: [id, function, args, expected]
  rows:
    - ["io2656007", "io.IOBase.__dict__.__contains__",          ["__add__"], false]
    - ["io2656008", "io.FileIO.__dict__.__contains__",          ["__add__"], false]
    - ["io2656009", "io.BufferedReader.__dict__.__contains__",  ["__add__"], false]
    - ["io2656010", "io.BufferedWriter.__dict__.__contains__",  ["__add__"], false]
    - ["io2656011", "io.BufferedRandom.__dict__.__contains__",  ["__add__"], false]
    - ["io2656012", "io.TextIOWrapper.__dict__.__contains__",   ["__add__"], false]

# ---------------------------------------------------------------------------
# __mul__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2656.no_mul_in_io_classes:
  description: "__mul__ is absent from all io class __dict__s — io stream classes do not implement the arithmetic multiplication protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2656

  columns: [id, function, args, expected]
  rows:
    - ["io2656013", "io.IOBase.__dict__.__contains__",         ["__mul__"], false]
    - ["io2656014", "io.BytesIO.__dict__.__contains__",        ["__mul__"], false]
    - ["io2656015", "io.StringIO.__dict__.__contains__",       ["__mul__"], false]
    - ["io2656016", "io.FileIO.__dict__.__contains__",         ["__mul__"], false]
    - ["io2656017", "io.BufferedReader.__dict__.__contains__", ["__mul__"], false]
    - ["io2656018", "io.BufferedWriter.__dict__.__contains__", ["__mul__"], false]

# ---------------------------------------------------------------------------
# Complementary: io stream classes have I/O methods but not arithmetic/container hooks
# Confirms that io classes are sequential I/O objects, not arithmetic or container types
# ---------------------------------------------------------------------------

table io_extra2656.io_has_stream_methods_not_arithmetic_hooks:
  description: "io.BytesIO defines read/write/seek/tell but NOT __contains__/__add__/__mul__; io.StringIO similarly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2656

  columns: [id, function, args, expected]
  rows:
    - ["io2656019", "io.BytesIO.__dict__.__contains__",  ["read"],         true]
    - ["io2656020", "io.BytesIO.__dict__.__contains__",  ["write"],        true]
    - ["io2656021", "io.BytesIO.__dict__.__contains__",  ["seek"],         true]
    - ["io2656022", "io.BytesIO.__dict__.__contains__",  ["tell"],         true]
    - ["io2656023", "io.BytesIO.__dict__.__contains__",  ["__contains__"], false]
    - ["io2656024", "io.BytesIO.__dict__.__contains__",  ["__add__"],      false]
    - ["io2656025", "io.BytesIO.__dict__.__contains__",  ["__mul__"],      false]
    - ["io2656026", "io.StringIO.__dict__.__contains__", ["read"],         true]
    - ["io2656027", "io.StringIO.__dict__.__contains__", ["write"],        true]
    - ["io2656028", "io.StringIO.__dict__.__contains__", ["seek"],         true]
    - ["io2656029", "io.StringIO.__dict__.__contains__", ["tell"],         true]
    - ["io2656030", "io.StringIO.__dict__.__contains__", ["__contains__"], false]
    - ["io2656031", "io.StringIO.__dict__.__contains__", ["__add__"],      false]
    - ["io2656032", "io.StringIO.__dict__.__contains__", ["__mul__"],      false]
