spec: io3016
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module class hierarchy"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 648 (io3016): __iter__, __next__, __reversed__ dict-presence checks for io types."
    - "io.BytesIO is the only io class that defines __iter__ in its own __dict__; it also defines __next__."
    - "io.StringIO, io.BufferedReader, io.BufferedRandom, and io.TextIOWrapper define __next__ but NOT __iter__ in their own __dict__; __iter__ is inherited."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.FileIO, and io.BufferedWriter define neither __iter__ nor __next__ in their own __dict__."
    - "No io class defines __reversed__ in its own __dict__; io streams are forward-only iterators."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __iter__ dict-presence — operator.contains(Cls.__dict__, '__iter__')
#
# Only BytesIO defines __iter__ in its own __dict__; all others inherit or omit.
# ---------------------------------------------------------------------------

table io3016.iter:
  description: "io types __iter__ dict-presence checks; wave 648"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io3016
  columns: [id, function, args, expected]
  rows:
    - ["io3016001", operator.contains, [io.IOBase.__dict__,          "__iter__"], false]
    - ["io3016002", operator.contains, [io.RawIOBase.__dict__,       "__iter__"], false]
    - ["io3016003", operator.contains, [io.BufferedIOBase.__dict__,  "__iter__"], false]
    - ["io3016004", operator.contains, [io.TextIOBase.__dict__,      "__iter__"], false]
    - ["io3016005", operator.contains, [io.FileIO.__dict__,          "__iter__"], false]
    - ["io3016006", operator.contains, [io.BytesIO.__dict__,         "__iter__"], true]
    - ["io3016007", operator.contains, [io.StringIO.__dict__,        "__iter__"], false]
    - ["io3016008", operator.contains, [io.BufferedReader.__dict__,  "__iter__"], false]
    - ["io3016009", operator.contains, [io.BufferedWriter.__dict__,  "__iter__"], false]
    - ["io3016010", operator.contains, [io.BufferedRandom.__dict__,  "__iter__"], false]
    - ["io3016011", operator.contains, [io.TextIOWrapper.__dict__,   "__iter__"], false]

# ---------------------------------------------------------------------------
# __next__ dict-presence — operator.contains(Cls.__dict__, '__next__')
#
# BytesIO, StringIO, BufferedReader, BufferedRandom, and TextIOWrapper define
# __next__ directly. IOBase, RawIOBase, BufferedIOBase, TextIOBase, FileIO,
# and BufferedWriter do not.
# ---------------------------------------------------------------------------

table io3016.next:
  description: "io types __next__ dict-presence checks; wave 648"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io3016
  columns: [id, function, args, expected]
  rows:
    - ["io3016012", operator.contains, [io.IOBase.__dict__,          "__next__"], false]
    - ["io3016013", operator.contains, [io.RawIOBase.__dict__,       "__next__"], false]
    - ["io3016014", operator.contains, [io.BufferedIOBase.__dict__,  "__next__"], false]
    - ["io3016015", operator.contains, [io.TextIOBase.__dict__,      "__next__"], false]
    - ["io3016016", operator.contains, [io.FileIO.__dict__,          "__next__"], false]
    - ["io3016017", operator.contains, [io.BytesIO.__dict__,         "__next__"], true]
    - ["io3016018", operator.contains, [io.StringIO.__dict__,        "__next__"], true]
    - ["io3016019", operator.contains, [io.BufferedReader.__dict__,  "__next__"], true]
    - ["io3016020", operator.contains, [io.BufferedWriter.__dict__,  "__next__"], false]
    - ["io3016021", operator.contains, [io.BufferedRandom.__dict__,  "__next__"], true]
    - ["io3016022", operator.contains, [io.TextIOWrapper.__dict__,   "__next__"], true]

# ---------------------------------------------------------------------------
# __reversed__ dict-presence — operator.contains(Cls.__dict__, '__reversed__')
#
# No io class defines __reversed__; io streams are forward-only iterators.
# All false.
# ---------------------------------------------------------------------------

table io3016.reversed:
  description: "io types __reversed__ dict-presence checks; wave 648"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io3016
  columns: [id, function, args, expected]
  rows:
    - ["io3016023", operator.contains, [io.IOBase.__dict__,          "__reversed__"], false]
    - ["io3016024", operator.contains, [io.RawIOBase.__dict__,       "__reversed__"], false]
    - ["io3016025", operator.contains, [io.BufferedIOBase.__dict__,  "__reversed__"], false]
    - ["io3016026", operator.contains, [io.TextIOBase.__dict__,      "__reversed__"], false]
    - ["io3016027", operator.contains, [io.FileIO.__dict__,          "__reversed__"], false]
    - ["io3016028", operator.contains, [io.BytesIO.__dict__,         "__reversed__"], false]
    - ["io3016029", operator.contains, [io.StringIO.__dict__,        "__reversed__"], false]
    - ["io3016030", operator.contains, [io.BufferedReader.__dict__,  "__reversed__"], false]
    - ["io3016031", operator.contains, [io.BufferedWriter.__dict__,  "__reversed__"], false]
    - ["io3016032", operator.contains, [io.BufferedRandom.__dict__,  "__reversed__"], false]
    - ["io3016033", operator.contains, [io.TextIOWrapper.__dict__,   "__reversed__"], false]

# ---------------------------------------------------------------------------
# combined — all three iterator-protocol operators across the full set of io types
#
# 11 types x 3 operators cross-product, sampled to ~24 rows with full variety.
# Highlights: BytesIO has both __iter__ and __next__; StringIO/BufferedReader/
# BufferedRandom/TextIOWrapper have __next__ only; __reversed__ is always false.
# ---------------------------------------------------------------------------

table io3016.combined:
  description: "io types __iter__/__next__/__reversed__ combined dict-presence checks; wave 648"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io3016
  columns: [id, function, args, expected]
  rows:
    - ["io3016034", operator.contains, [io.BytesIO.__dict__,         "__iter__"],     true]
    - ["io3016035", operator.contains, [io.BytesIO.__dict__,         "__next__"],     true]
    - ["io3016036", operator.contains, [io.BytesIO.__dict__,         "__reversed__"], false]
    - ["io3016037", operator.contains, [io.StringIO.__dict__,        "__iter__"],     false]
    - ["io3016038", operator.contains, [io.StringIO.__dict__,        "__next__"],     true]
    - ["io3016039", operator.contains, [io.StringIO.__dict__,        "__reversed__"], false]
    - ["io3016040", operator.contains, [io.BufferedReader.__dict__,  "__iter__"],     false]
    - ["io3016041", operator.contains, [io.BufferedReader.__dict__,  "__next__"],     true]
    - ["io3016042", operator.contains, [io.BufferedReader.__dict__,  "__reversed__"], false]
    - ["io3016043", operator.contains, [io.TextIOWrapper.__dict__,   "__iter__"],     false]
    - ["io3016044", operator.contains, [io.TextIOWrapper.__dict__,   "__next__"],     true]
    - ["io3016045", operator.contains, [io.TextIOWrapper.__dict__,   "__reversed__"], false]
    - ["io3016046", operator.contains, [io.IOBase.__dict__,          "__iter__"],     false]
    - ["io3016047", operator.contains, [io.IOBase.__dict__,          "__next__"],     false]
    - ["io3016048", operator.contains, [io.IOBase.__dict__,          "__reversed__"], false]
    - ["io3016049", operator.contains, [io.BufferedRandom.__dict__,  "__iter__"],     false]
    - ["io3016050", operator.contains, [io.BufferedRandom.__dict__,  "__next__"],     true]
    - ["io3016051", operator.contains, [io.BufferedRandom.__dict__,  "__reversed__"], false]
    - ["io3016052", operator.contains, [io.BufferedWriter.__dict__,  "__iter__"],     false]
    - ["io3016053", operator.contains, [io.BufferedWriter.__dict__,  "__next__"],     false]
    - ["io3016054", operator.contains, [io.BufferedWriter.__dict__,  "__reversed__"], false]
    - ["io3016055", operator.contains, [io.FileIO.__dict__,          "__iter__"],     false]
    - ["io3016056", operator.contains, [io.FileIO.__dict__,          "__next__"],     false]
    - ["io3016057", operator.contains, [io.TextIOBase.__dict__,      "__reversed__"], false]
