spec: functools_extra58
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra57.zspec.zsdl."
    - "Prior specs covered for singledispatchmethod: __name__.__eq__('singledispatchmethod') (extra3); __module__.__eq__('functools') (extra3/extra12); __qualname__.__eq__('singledispatchmethod') (extra3); __bases__[0].__name__=='object' via __getitem__ (extra10); __bases__.__len__()==1 (extra10); __mro__.__len__()==2 (extra36); __class__.__name__=='type' (extra51); __name__.__len__()==20 (extra14); __qualname__.__len__()==20 (extra14); __module__.__len__()==9 (extra20/extra34/extra37); __dict__.__class__.__name__.__len__()==12 (extra36)."
    - "Prior specs covered for cmp_to_key: __name__.__eq__('cmp_to_key') (extra3/extra4); __module__.__eq__('_functools') (extra12/extra48); __qualname__.__len__()==10 (extra14); __name__.__len__()==10 (extra14); __module__.__len__()==10 (extra20/extra34/extra43); __class__.__name__=='builtin_function_or_method' (extra51)."
    - "This spec covers: functools.singledispatchmethod.__module__.__class__.__name__.__eq__('str')==true; functools.singledispatchmethod.__name__.__class__.__name__.__eq__('str')==true; functools.singledispatchmethod.__qualname__.__class__.__name__.__eq__('str')==true; functools.cmp_to_key.__module__.__class__.__name__.__eq__('str')==true; functools.cmp_to_key.__name__.__class__.__name__.__eq__('str')==true; functools.cmp_to_key.__doc__.__class__.__name__.__eq__('str')==true; functools.singledispatchmethod.__module__.__class__.__qualname__.__eq__('str')==true; functools.cmp_to_key.__module__.__class__.__qualname__.__eq__('str')==true."
    - "Key findings: functools.singledispatchmethod is a pure-Python class in Lib/functools.py; its string attributes (__module__=='functools', __name__=='singledispatchmethod', __qualname__=='singledispatchmethod') are all Python str objects, so their __class__.__name__ == 'str' (3 chars). functools.cmp_to_key is a C-extension function in Modules/_functoolsmodule.c; its __module__ == '_functools' (10 chars, a str object), its __name__ == 'cmp_to_key' (10 chars, a str object), and its __doc__ is a str object. The str built-in type is a top-level type so __class__.__qualname__ == __class__.__name__ == 'str' for all str attributes. No prior functools spec records __module__.__class__.__name__.__eq__('str') for singledispatchmethod or cmp_to_key. All eight invariants are new to extra58."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.singledispatchmethod string attribute __class__.__name__ == 'str'
# — extra58 namespace
#
# functools.singledispatchmethod is a pure-Python class defined at module level
# in Lib/functools.py (added in Python 3.8). Its string attributes:
#   __module__  == 'functools'           (9 chars, a Python str)
#   __name__    == 'singledispatchmethod' (20 chars, a Python str)
#   __qualname__ == 'singledispatchmethod' (20 chars, a Python str)
# Since each of these is a Python str object, its __class__ is the str built-in
# type, and str.__name__ == 'str' (3 chars). Prior specs confirmed the string
# values and lengths (extra3/extra12/extra14/extra20) but no prior spec records
# __module__/__name__/__qualname__.__class__.__name__.__eq__('str') for
# singledispatchmethod. All three checks are new to extra58.
# ---------------------------------------------------------------------------

table functools_extra58.sdm_string_attrs_class_name:
  description: "functools.singledispatchmethod __module__/__name__/__qualname__ are Python str objects — __class__.__name__ == 'str' (3 chars) for each; no prior functools spec records this class-of-string check for singledispatchmethod"
  kind: python_call_eq
  category: identity
  id_prefix: functoolssdm58

  columns: [id, function, args, expected, description]
  rows:
    - [sdm_module_class_name,
       singledispatchmethod.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.singledispatchmethod.__module__.__class__.__name__ == 'str' — singledispatchmethod is a pure-Python class in Lib/functools.py (Python 3.8+); __module__ is the Python string 'functools' (9 chars); Python str objects have __class__ == str; str.__name__ == 'str' (3 chars); prior extra12/extra20 confirmed singledispatchmethod.__module__.__eq__('functools') and __module__.__len__()==9; this is the first __module__.__class__.__name__ check for singledispatchmethod; new to extra58"]
    - [sdm_name_class_name,
       singledispatchmethod.__name__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.singledispatchmethod.__name__.__class__.__name__ == 'str' — singledispatchmethod.__name__ is the Python string 'singledispatchmethod' (20 chars); Python str objects have __class__ == str; str.__name__ == 'str' (3 chars); prior extra3/extra14 confirmed singledispatchmethod.__name__.__eq__('singledispatchmethod') and __name__.__len__()==20; this is the first __name__.__class__.__name__ check for singledispatchmethod; new to extra58"]
    - [sdm_qualname_class_name,
       singledispatchmethod.__qualname__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.singledispatchmethod.__qualname__.__class__.__name__ == 'str' — singledispatchmethod.__qualname__ is the Python string 'singledispatchmethod' (20 chars; top-level class, no enclosing scope); Python str objects have __class__ == str; str.__name__ == 'str' (3 chars); prior extra3/extra14 confirmed singledispatchmethod.__qualname__.__eq__('singledispatchmethod') and __qualname__.__len__()==20; this is the first __qualname__.__class__.__name__ check for singledispatchmethod; new to extra58"]

# ---------------------------------------------------------------------------
# functools.singledispatchmethod __module__.__class__.__qualname__ == 'str'
# — extra58 namespace
#
# The str built-in type is a top-level type in the builtins module with no
# enclosing class scope, so __qualname__ == __name__ == 'str' (3 chars).
# Therefore singledispatchmethod.__module__.__class__.__qualname__ == 'str'.
# No prior functools spec records this qualname form for singledispatchmethod.
# ---------------------------------------------------------------------------

table functools_extra58.sdm_module_class_qualname:
  description: "functools.singledispatchmethod.__module__.__class__.__qualname__ == 'str' — str built-in type has __qualname__ == __name__ == 'str' (3 chars); qualname form not recorded in any prior functools spec for singledispatchmethod"
  kind: python_call_eq
  category: identity
  id_prefix: functoolssdm58

  columns: [id, function, args, expected, description]
  rows:
    - [sdm_module_class_qualname,
       singledispatchmethod.__module__.__class__.__qualname__.__eq__,
       ["str"],
       true,
       "functools.singledispatchmethod.__module__.__class__.__qualname__ == 'str' — singledispatchmethod.__module__ is a Python str object ('functools', 9 chars); the str built-in type is a top-level type with __qualname__ == __name__ == 'str' (3 chars); consistent with extra58's singledispatchmethod.__module__.__class__.__name__.__eq__('str'); no prior functools spec records __module__.__class__.__qualname__ for singledispatchmethod; new to extra58"]

# ---------------------------------------------------------------------------
# functools.cmp_to_key string attribute __class__.__name__ == 'str'
# — extra58 namespace
#
# functools.cmp_to_key is a C-extension function in Modules/_functoolsmodule.c.
# Its string attributes:
#   __module__ == '_functools'  (10 chars, a Python str)
#   __name__   == 'cmp_to_key' (10 chars, a Python str)
#   __doc__    is a Python str (the C-level docstring is exposed as a Python str)
# Since each of these is a Python str object, its __class__ is the str built-in
# type, and str.__name__ == 'str' (3 chars). Prior specs confirmed string values
# and lengths (extra4/extra12/extra14/extra20/extra48) but no prior spec records
# __module__/__name__/__doc__.__class__.__name__.__eq__('str') for cmp_to_key.
# All three checks are new to extra58.
# ---------------------------------------------------------------------------

table functools_extra58.cmp_to_key_string_attrs_class_name:
  description: "functools.cmp_to_key __module__/__name__/__doc__ are Python str objects — __class__.__name__ == 'str' (3 chars) for each; cmp_to_key is a C-extension builtin_function_or_method; no prior functools spec records class-of-string checks for cmp_to_key attributes"
  kind: python_call_eq
  category: identity
  id_prefix: functoolssdm58

  columns: [id, function, args, expected, description]
  rows:
    - [cmp_to_key_module_class_name,
       cmp_to_key.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.cmp_to_key.__module__.__class__.__name__ == 'str' — cmp_to_key is a C-extension function in Modules/_functoolsmodule.c; __module__ is the Python string '_functools' (10 chars); Python str objects have __class__ == str; str.__name__ == 'str' (3 chars); prior extra12/extra48 confirmed cmp_to_key.__module__.__eq__('_functools') and extra20/extra43 confirmed __module__.__len__()==10; this is the first __module__.__class__.__name__ check for cmp_to_key; new to extra58"]
    - [cmp_to_key_name_class_name,
       cmp_to_key.__name__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.cmp_to_key.__name__.__class__.__name__ == 'str' — cmp_to_key.__name__ is the Python string 'cmp_to_key' (10 chars); C-extension functions expose their __name__ as a Python str object; str.__name__ == 'str' (3 chars); prior extra3/extra4/extra14 confirmed cmp_to_key.__name__.__eq__('cmp_to_key') and __name__.__len__()==10; this is the first __name__.__class__.__name__ check for cmp_to_key; new to extra58"]
    - [cmp_to_key_doc_class_name,
       cmp_to_key.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.cmp_to_key.__doc__.__class__.__name__ == 'str' — cmp_to_key is a C-extension function whose docstring is stored as a Python str object at the C level; all C-extension docstrings that are non-None are Python str objects; __class__.__name__ of any str object is 'str' (3 chars); no prior functools spec records cmp_to_key.__doc__.__class__.__name__; new to extra58"]

