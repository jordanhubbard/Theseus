spec: decimal_extra205
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html
rfcs:
  - "IBM General Decimal Arithmetic Specification, Version 1.72"
  - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"

provenance:
  derived_from:
    - "Python 3 decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "IBM General Decimal Arithmetic Specification 1.72 — http://speleotrove.com/decimal/decarith.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra.zspec.zsdl — covers predicate methods, to_eng_string, rounding mode constants, DefaultContext"
  notes:
    - "decimal.Decimal.__dict__ contains sqrt, ln, log10, exp as concrete transcendental math methods."
    - "decimal.Context.__dict__ contains sqrt, ln, log10, exp as context-dispatch transcendental math methods."
    - "decimal.Decimal.sqrt() computes the square root in the current context; an IBM GDA operation."
    - "decimal.Decimal.ln() computes the natural logarithm; decimal.Decimal.log10() computes log base 10."
    - "decimal.Decimal.exp() computes e raised to the given power; all confirmed Python 3.14.3 macOS."
    - "decimal.Context.sqrt(), Context.ln(), Context.log10() are the context-method equivalents."
    - "decimal.Decimal.__dict__.__contains__('sqrt') == True; confirmed Python 3.14.3 macOS."
    - "decimal.Context.__dict__.__contains__('sqrt') == True; confirmed Python 3.14.3 macOS."
    - "decimal.Context.__dict__.__contains__('ln') == True; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal.Decimal.__dict__ membership — transcendental math methods
# sqrt, ln, log10, exp are concrete methods defined on Decimal (IBM GDA ops)
# ---------------------------------------------------------------------------

table decimal_extra205.decimal_dict_transcendental:
  description: "decimal.Decimal.__dict__ contains the transcendental math method implementations"
  kind: python_call_eq
  category: dict_membership
  id_prefix: decimalannotations205

  columns: [id, function, args, expected, description]
  rows:
    - [decimal_has_sqrt,   "decimal.Decimal.__dict__.__contains__",  ["sqrt"],   true,  "decimal.Decimal.__dict__.__contains__('sqrt') == True; sqrt is an IBM GDA transcendental method on Decimal; confirmed Python 3.14.3 macOS"]
    - [decimal_has_ln,     "decimal.Decimal.__dict__.__contains__",  ["ln"],     true,  "decimal.Decimal.__dict__.__contains__('ln') == True; ln computes natural log on Decimal; confirmed Python 3.14.3 macOS"]
    - [decimal_has_log10,  "decimal.Decimal.__dict__.__contains__",  ["log10"],  true,  "decimal.Decimal.__dict__.__contains__('log10') == True; log10 computes log base 10 on Decimal; confirmed Python 3.14.3 macOS"]
    - [decimal_has_exp,    "decimal.Decimal.__dict__.__contains__",  ["exp"],    true,  "decimal.Decimal.__dict__.__contains__('exp') == True; exp computes e**n on Decimal; confirmed Python 3.14.3 macOS"]
    - [decimal_has_quantize, "decimal.Decimal.__dict__.__contains__", ["quantize"], true, "decimal.Decimal.__dict__.__contains__('quantize') == True; quantize adjusts the exponent of a Decimal; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: decimal.Context.__dict__ membership — context transcendental methods
# sqrt, ln, log10, exp are context-dispatch methods on Context
# ---------------------------------------------------------------------------

table decimal_extra205.context_dict_transcendental:
  description: "decimal.Context.__dict__ contains the context-dispatch transcendental math methods"
  kind: python_call_eq
  category: dict_membership
  id_prefix: decimalannotations205

  columns: [id, function, args, expected, description]
  rows:
    - [context_has_sqrt,   "decimal.Context.__dict__.__contains__",  ["sqrt"],   true,  "decimal.Context.__dict__.__contains__('sqrt') == True; Context.sqrt dispatches sqrt to the context; confirmed Python 3.14.3 macOS"]
    - [context_has_ln,     "decimal.Context.__dict__.__contains__",  ["ln"],     true,  "decimal.Context.__dict__.__contains__('ln') == True; Context.ln dispatches natural log to the context; confirmed Python 3.14.3 macOS"]
    - [context_has_log10,  "decimal.Context.__dict__.__contains__",  ["log10"],  true,  "decimal.Context.__dict__.__contains__('log10') == True; Context.log10 dispatches log base 10 to the context; confirmed Python 3.14.3 macOS"]
    - [context_has_exp,    "decimal.Context.__dict__.__contains__",  ["exp"],    true,  "decimal.Context.__dict__.__contains__('exp') == True; Context.exp dispatches e**n to the context; confirmed Python 3.14.3 macOS"]
    - [context_has_add,    "decimal.Context.__dict__.__contains__",  ["add"],    true,  "decimal.Context.__dict__.__contains__('add') == True; Context.add dispatches addition to the context; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: decimal.Context.__dict__ membership — arithmetic dispatch methods
# add, multiply, subtract, divide are context-dispatch arithmetic methods
# ---------------------------------------------------------------------------

table decimal_extra205.context_dict_arithmetic:
  description: "decimal.Context.__dict__ contains arithmetic context-dispatch methods"
  kind: python_call_eq
  category: dict_membership
  id_prefix: decimalannotations205

  columns: [id, function, args, expected, description]
  rows:
    - [context_has_multiply,   "decimal.Context.__dict__.__contains__",  ["multiply"],   true,  "decimal.Context.__dict__.__contains__('multiply') == True; Context.multiply dispatches multiplication to the context; confirmed Python 3.14.3 macOS"]
    - [context_has_subtract,   "decimal.Context.__dict__.__contains__",  ["subtract"],   true,  "decimal.Context.__dict__.__contains__('subtract') == True; Context.subtract dispatches subtraction to the context; confirmed Python 3.14.3 macOS"]
    - [context_has_divide,     "decimal.Context.__dict__.__contains__",  ["divide"],     true,  "decimal.Context.__dict__.__contains__('divide') == True; Context.divide dispatches division to the context; confirmed Python 3.14.3 macOS"]
    - [decimal_has_normalize,  "decimal.Decimal.__dict__.__contains__",  ["normalize"],  true,  "decimal.Decimal.__dict__.__contains__('normalize') == True; normalize reduces trailing zeros on Decimal; confirmed Python 3.14.3 macOS"]

