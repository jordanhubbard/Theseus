# ===
# Table 4: Contrast — sync iteration presence vs async iteration absence for BytesIO
# ===

table io_extra2431.bytesio_sync_vs_async:
  description: "io.BytesIO has sync __iter__ and __next__ but no async __aiter__ or __anext__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2431
  columns: [id, function, args, expected]
  rows:
    - ["io2431020", "io.BytesIO.__dict__.__contains__", ["__iter__"], true]
    - ["io2431021", "io.BytesIO.__dict__.__contains__", ["__next__"], true]
    - ["io2431022", "io.BytesIO.__dict__.__contains__", ["__aiter__"], false]
    - ["io2431023", "io.BytesIO.__dict__.__contains__", ["__anext__"], false]
    - ["io2431024", "io.StringIO.__dict__.__contains__", ["__next__"], true]
    - ["io2431025", "io.StringIO.__dict__.__contains__", ["__anext__"], false]
    - ["io2431026", "io.BufferedReader.__dict__.__contains__", ["__next__"], true]
    - ["io2431027", "io.BufferedReader.__dict__.__contains__", ["__anext__"], false]
    - ["io2431028", "io.TextIOWrapper.__dict__.__contains__", ["__next__"], true]
    - ["io2431029", "io.TextIOWrapper.__dict__.__contains__", ["__anext__"], false]
