  columns: [id, function, args, expected]
  rows:
    - ["io2431005", "io.BytesIO.__dict__.__contains__", ["__aiter__"], false]
    - ["io2431006", "io.StringIO.__dict__.__contains__", ["__aiter__"], false]
    - ["io2431007", "io.FileIO.__dict__.__contains__", ["__aiter__"], false]
    - ["io2431008", "io.BufferedReader.__dict__.__contains__", ["__aiter__"], false]
    - ["io2431009", "io.BufferedRandom.__dict__.__contains__", ["__aiter__"], false]
    - ["io2431010", "io.TextIOWrapper.__dict__.__contains__", ["__aiter__"], false]

