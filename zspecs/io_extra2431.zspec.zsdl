spec: io_extra2431
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/io.html"
    - "CPython source — Modules/_io/_iomodule.c"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2431: __aiter__ and __anext__ async iteration protocol dict-presence for io classes."
    - "None of the io class hierarchy defines __aiter__ or __anext__ in their own class __dict__."
    - "io.BytesIO defines __iter__ and __next__ (sync iteration) but NOT async equivalents."
    - "io.StringIO, io.BufferedReader, io.BufferedRandom, and io.TextIOWrapper define __next__ but NOT __aiter__ or __anext__."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase, and io.FileIO define none of the four iteration protocol methods."
    - "The async iteration protocol (__aiter__/__anext__) belongs to async generators and async context managers, not sync I/O classes."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ===
# Table 1: __aiter__ in class __dict__ — abstract base classes
# ===

table io_extra2431.aiter_in_dict_abstract:
  description: "__aiter__ dict-presence for io abstract base classes — none define async iteration"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2431
  columns: [id, function, args, expected]
  rows:
    - ["io2431001", "io.IOBase.__dict__.__contains__", ["__aiter__"], false]
    - ["io2431002", "io.RawIOBase.__dict__.__contains__", ["__aiter__"], false]
    - ["io2431003", "io.BufferedIOBase.__dict__.__contains__", ["__aiter__"], false]
    - ["io2431004", "io.TextIOBase.__dict__.__contains__", ["__aiter__"], false]

