spec: re_extra210
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra204.zspec.zsdl — covers re module-level dunder attributes: __name__, __package__, __spec__.name, __loader__, __doc__"
  notes:
    - "re.compile.__code__.co_varnames == ('pattern', 'flags') — compile takes exactly 2 parameters; confirmed Python 3.14.3 macOS."
    - "re.compile.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple; confirmed Python 3.14.3 macOS."
    - "re.compile.__code__.co_varnames.__len__() == 2; confirmed Python 3.14.3 macOS."
    - "re.sub.__code__.co_varnames == ('pattern', 'repl', 'string', 'count', 'flags', 'args', 'warnings') — 7 entries; confirmed Python 3.14.3 macOS."
    - "re.sub.__code__.co_varnames.__len__() == 7; confirmed Python 3.14.3 macOS."
    - "re.compile.__code__.__class__.__name__ == 'code'; confirmed Python 3.14.3 macOS."
    - "re.Pattern.__dict__.__contains__('match') == True; confirmed Python 3.14.3 macOS."
    - "re.Pattern.__dict__.__contains__('search') == True; confirmed Python 3.14.3 macOS."
    - "re.Pattern.__dict__.__contains__('findall') == True; confirmed Python 3.14.3 macOS."
    - "re.Pattern.__dict__.__contains__('compile') == False; 'compile' is a module-level function, not a Pattern method; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re.compile.__code__.co_varnames type and contents
# co_varnames is a tuple of length 2: ('pattern', 'flags')
# ---------------------------------------------------------------------------

table re_extra210.compile_co_varnames:
  description: "re.compile.__code__.co_varnames type identity, length, and parameter membership"
  kind: python_call_eq
  category: co_varnames_identity
  id_prefix: recovarnames210

  columns: [id, function, args, expected, description]
  rows:
    - [compile_varnames_class,           re.compile.__code__.co_varnames.__class__.__name__.__eq__,  ["tuple"],   true,  "re.compile.__code__.co_varnames.__class__.__name__ == 'tuple'; co_varnames is always a tuple; confirmed Python 3.14.3 macOS"]
    - [compile_varnames_len,             re.compile.__code__.co_varnames.__len__,                   [],          2,     "re.compile.__code__.co_varnames.__len__() == 2; compile takes exactly 2 parameters: pattern and flags; confirmed Python 3.14.3 macOS"]
    - [compile_varnames_has_pattern,     re.compile.__code__.co_varnames.__contains__,              ["pattern"], true,  "re.compile.__code__.co_varnames.__contains__('pattern') == True; 'pattern' is the first parameter of re.compile; confirmed Python 3.14.3 macOS"]
    - [compile_code_class_name,          re.compile.__code__.__class__.__name__.__eq__,             ["code"],    true,  "re.compile.__code__.__class__.__name__ == 'code'; the code object is always of type 'code'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re.sub.__code__.co_varnames type and contents
# co_varnames is a tuple of length 7: ('pattern', 'repl', 'string', 'count', 'flags', 'args', 'warnings')
# ---------------------------------------------------------------------------

table re_extra210.sub_co_varnames:
  description: "re.sub.__code__.co_varnames length and parameter membership"
  kind: python_call_eq
  category: co_varnames_identity
  id_prefix: recovarnames210

  columns: [id, function, args, expected, description]
  rows:
    - [sub_varnames_len,         re.sub.__code__.co_varnames.__len__,      [],          7,     "re.sub.__code__.co_varnames.__len__() == 7; sub takes 7 entries including pattern, repl, string, count, flags, args, warnings; confirmed Python 3.14.3 macOS"]
    - [sub_varnames_has_repl,    re.sub.__code__.co_varnames.__contains__,  ["repl"],    true,  "re.sub.__code__.co_varnames.__contains__('repl') == True; 'repl' is the replacement parameter of re.sub; confirmed Python 3.14.3 macOS"]
    - [sub_varnames_has_pattern, re.sub.__code__.co_varnames.__contains__,  ["pattern"], true,  "re.sub.__code__.co_varnames.__contains__('pattern') == True; 'pattern' is the first parameter of re.sub; confirmed Python 3.14.3 macOS"]
    - [sub_varnames_has_string,  re.sub.__code__.co_varnames.__contains__,  ["string"],  true,  "re.sub.__code__.co_varnames.__contains__('string') == True; 'string' is the input string parameter of re.sub; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re.Pattern.__dict__ membership — method names present and absent
# match, search, findall are present; 'compile' is absent
# ---------------------------------------------------------------------------

table re_extra210.pattern_dict_methods:
  description: "re.Pattern.__dict__ method membership — match, search, findall present; compile absent"
  kind: python_call_eq
  category: dict_membership
  id_prefix: recovarnames210

  columns: [id, function, args, expected, description]
  rows:
    - [pattern_has_match,    re.Pattern.__dict__.__contains__,  ["match"],   true,   "re.Pattern.__dict__.__contains__('match') == True; match() is a method on compiled Pattern objects; confirmed Python 3.14.3 macOS"]
    - [pattern_has_search,   re.Pattern.__dict__.__contains__,  ["search"],  true,   "re.Pattern.__dict__.__contains__('search') == True; search() is a method on compiled Pattern objects; confirmed Python 3.14.3 macOS"]
    - [pattern_has_findall,  re.Pattern.__dict__.__contains__,  ["findall"], true,   "re.Pattern.__dict__.__contains__('findall') == True; findall() is a method on compiled Pattern objects; confirmed Python 3.14.3 macOS"]
    - [pattern_no_compile,   re.Pattern.__dict__.__contains__,  ["compile"], false,  "re.Pattern.__dict__.__contains__('compile') == False; 'compile' is a module-level function, not a Pattern method; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra210.compile_varnames_class_name:
  description: "re.compile.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple; confirmed Python 3.14.3 macOS"
  category: co_varnames_identity
  kind: python_call_eq
  function: re.compile.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant re_extra210.compile_varnames_has_pattern:
  description: "re.compile.__code__.co_varnames.__contains__('pattern') == True — 'pattern' is the first parameter of re.compile; confirmed Python 3.14.3 macOS"
  category: co_varnames_identity
  kind: python_call_eq
  function: re.compile.__code__.co_varnames.__contains__
  args: ["pattern"]
  expected: true

invariant re_extra210.compile_varnames_len:
  description: "re.compile.__code__.co_varnames.__len__() == 2 — compile takes exactly 2 parameters: pattern and flags; confirmed Python 3.14.3 macOS"
  category: co_varnames_identity
  kind: python_call_eq
  function: re.compile.__code__.co_varnames.__len__
  args: []
  expected: 2

invariant re_extra210.sub_varnames_has_repl:
  description: "re.sub.__code__.co_varnames.__contains__('repl') == True — 'repl' is the replacement parameter of re.sub; confirmed Python 3.14.3 macOS"
  category: co_varnames_identity
  kind: python_call_eq
  function: re.sub.__code__.co_varnames.__contains__
  args: ["repl"]
  expected: true

invariant re_extra210.sub_varnames_len:
  description: "re.sub.__code__.co_varnames.__len__() == 7 — sub has 7 co_varnames entries: pattern, repl, string, count, flags, args, warnings; confirmed Python 3.14.3 macOS"
  category: co_varnames_identity
  kind: python_call_eq
  function: re.sub.__code__.co_varnames.__len__
  args: []
  expected: 7

invariant re_extra210.pattern_has_match:
  description: "re.Pattern.__dict__.__contains__('match') == True — match() is a method on compiled Pattern objects; confirmed Python 3.14.3 macOS"
  category: dict_membership
  kind: python_call_eq
  function: re.Pattern.__dict__.__contains__
  args: ["match"]
  expected: true

invariant re_extra210.pattern_has_search:
  description: "re.Pattern.__dict__.__contains__('search') == True — search() is a method on compiled Pattern objects; confirmed Python 3.14.3 macOS"
  category: dict_membership
  kind: python_call_eq
  function: re.Pattern.__dict__.__contains__
  args: ["search"]
  expected: true

invariant re_extra210.pattern_has_findall:
  description: "re.Pattern.__dict__.__contains__('findall') == True — findall() is a method on compiled Pattern objects; confirmed Python 3.14.3 macOS"
  category: dict_membership
  kind: python_call_eq
  function: re.Pattern.__dict__.__contains__
  args: ["findall"]
  expected: true
