spec: wrap_ansi
version: ">=10.0.0"
backend: node(wrap-ansi)

docs: https://www.npmjs.com/package/wrap-ansi

provenance:
  derived_from:
    - "wrap-ansi README — https://www.npmjs.com/package/wrap-ansi"
    - "Test vectors verified with wrap-ansi via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "wrap-ansi source"
  notes:
    - "wrap-ansi is an npm package. Install: npm install wrap-ansi"
    - "Wraps text at a given column width, inserting newlines. ESM package; use function: default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the wrapped string with newlines inserted."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table wrap_ansi.wrap:
  kind: node_module_call_eq
  function: "default"
  category: transform
  id_prefix: wrapansi

  columns: [id, args, expected]
  rows:
    - [two_words, ["hi there", 5],    "hi\nthere"]
    - [long,      ["hello world", 7], "hello\nworld"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T01:28:41Z
  iterations: 1
  pass_count: 2
  fail_count: 0
  total_invariants: 2
  notes: Synthesis succeeded in 1 iteration(s). 2 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
