spec: inspect_extra2116
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/inspect.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2116 (_extra2116): __or__/__ror__/__ior__, __and__/__rand__/__iand__, __xor__/__rxor__/__ixor__ dict-presence checks for inspect module types."
    - "Theme: set/dict merge operators (union, intersection, symmetric-difference) — NOT numeric bitwise ops."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "inspect.BufferFlags defines __or__, __ror__, __and__, __rand__, __xor__, __rxor__ in its own __dict__ (all True) — it is an IntFlag subclass; Flag.__or__ etc. implement flag-combination (a form of set-union semantics)."
    - "inspect.BufferFlags does NOT define __ior__, __iand__, __ixor__ in its own __dict__ (all False) — the in-place flag operators are not overridden in the BufferFlags class itself; IntFlag inherits them from higher in the MRO."
    - "inspect.ForwardRef defines __or__ and __ror__ in its own __dict__ (both True) — ForwardRef implements the X | Y type-union syntax introduced in Python 3.10 (PEP 604)."
    - "inspect.ForwardRef does NOT define __ior__, __and__, __rand__, __iand__, __xor__, __rxor__, __ixor__ in its own __dict__ (all False) — only the type-union operators are overridden."
    - "inspect.Parameter does NOT define any of the nine operators — it is a plain Python class with no set/dict semantics."
    - "inspect.Signature does NOT define any of the nine operators — it is a plain Python class with no set/dict semantics."
    - "inspect.BoundArguments does NOT define any of the nine operators — it is a plain Python class with no set/dict semantics."
    - "inspect.Format (IntEnum) does NOT define any of the nine operators in its own __dict__ — IntEnum does not add union/intersection operators the way IntFlag does."
    - "inspect._ParameterKind (IntEnum) does NOT define any of the nine operators — same rationale as Format."
    - "Named-tuple types FullArgSpec, FrameInfo do NOT define any of the nine operators."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __or__ / __ror__ / __ior__ dict-presence (dict-merge / set-union)
#
# inspect.BufferFlags: __or__ True, __ror__ True, __ior__ False
# inspect.ForwardRef: __or__ True, __ror__ True, __ior__ False
# All others: False
# ---------------------------------------------------------------------------

table inspect_extra2116.or_operator:
  description: "inspect types __or__/__ror__/__ior__ dict-presence — BufferFlags and ForwardRef True for __or__/__ror__, all others False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2116

  columns: [id, function, args, expected]
  rows:
    - ["in2116001", "inspect.BufferFlags.__dict__.__contains__", ["__or__"], true]
    - ["in2116002", "inspect.BufferFlags.__dict__.__contains__", ["__ror__"], true]
    - ["in2116003", "inspect.BufferFlags.__dict__.__contains__", ["__ior__"], false]
    - ["in2116004", "inspect.ForwardRef.__dict__.__contains__", ["__or__"], true]
    - ["in2116005", "inspect.ForwardRef.__dict__.__contains__", ["__ror__"], true]
    - ["in2116006", "inspect.ForwardRef.__dict__.__contains__", ["__ior__"], false]
    - ["in2116007", "inspect.Parameter.__dict__.__contains__", ["__or__"], false]
    - ["in2116008", "inspect.Parameter.__dict__.__contains__", ["__ror__"], false]
    - ["in2116009", "inspect.Parameter.__dict__.__contains__", ["__ior__"], false]
    - ["in2116010", "inspect.Signature.__dict__.__contains__", ["__or__"], false]
    - ["in2116011", "inspect.Signature.__dict__.__contains__", ["__ror__"], false]
    - ["in2116012", "inspect.Signature.__dict__.__contains__", ["__ior__"], false]
    - ["in2116013", "inspect.BoundArguments.__dict__.__contains__", ["__or__"], false]
    - ["in2116014", "inspect.BoundArguments.__dict__.__contains__", ["__ror__"], false]
    - ["in2116015", "inspect.BoundArguments.__dict__.__contains__", ["__ior__"], false]
    - ["in2116016", "inspect.Format.__dict__.__contains__", ["__or__"], false]
    - ["in2116017", "inspect.Format.__dict__.__contains__", ["__ror__"], false]
    - ["in2116018", "inspect.Format.__dict__.__contains__", ["__ior__"], false]
    - ["in2116019", "inspect._ParameterKind.__dict__.__contains__", ["__or__"], false]
    - ["in2116020", "inspect._ParameterKind.__dict__.__contains__", ["__ror__"], false]
    - ["in2116021", "inspect._ParameterKind.__dict__.__contains__", ["__ior__"], false]

