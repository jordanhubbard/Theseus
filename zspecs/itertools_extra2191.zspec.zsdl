spec: itertools_extra2191
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2191: context manager protocol dict-presence checks — __enter__, __exit__, __aenter__, __aexit__, acquire, release, __wrapped__, __closure__."
    - "All itertools types are C extension iterator classes; none implement the context manager, lock, or wrapper protocols in their own __dict__."
    - "itertools.accumulate, batched, chain, combinations, combinations_with_replacement, compress, count, cycle, dropwhile, filterfalse, groupby, islice, pairwise, permutations, product, repeat, starmap, takewhile, zip_longest all return false for all theme keys."
    - "itertools._tee, _grouper, and _tee_dataobject are internal helper types and also return false for all theme keys."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table itertools_extra2191.accumulate_context_protocol:
  description: "itertools.accumulate dict-presence checks for context manager, lock, and wrapper protocol keys"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2191

  columns: [id, function, args, expected]
  rows:
    - ["it2191001", "itertools.accumulate.__dict__.__contains__", ["__enter__"], false]
    - ["it2191002", "itertools.accumulate.__dict__.__contains__", ["__exit__"], false]
    - ["it2191003", "itertools.accumulate.__dict__.__contains__", ["__aenter__"], false]
    - ["it2191004", "itertools.accumulate.__dict__.__contains__", ["__aexit__"], false]
    - ["it2191005", "itertools.accumulate.__dict__.__contains__", ["acquire"], false]
    - ["it2191006", "itertools.accumulate.__dict__.__contains__", ["release"], false]
    - ["it2191007", "itertools.accumulate.__dict__.__contains__", ["__wrapped__"], false]
    - ["it2191008", "itertools.accumulate.__dict__.__contains__", ["__closure__"], false]

