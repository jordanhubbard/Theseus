spec: itertools_extra238
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers itertools.chain and itertools.repeat class identity contracts."
    - "itertools.chain.__name__ == 'chain' (len=5) — the C-level type name. Verified with Python 3.14.3."
    - "itertools.chain.__module__ == 'itertools' (len=9) — chain is defined in Modules/itertoolsmodule.c. Verified with Python 3.14.3."
    - "itertools.chain.__bases__[0].__name__ == 'object' — chain inherits directly from object. Verified with Python 3.14.3."
    - "itertools.repeat.__name__ == 'repeat' (len=6) — the C-level type name. Verified with Python 3.14.3."
    - "itertools.repeat.__module__ == 'itertools' (len=9) — repeat is defined in Modules/itertoolsmodule.c. Verified with Python 3.14.3."
    - "itertools.repeat.__bases__[0].__name__ == 'object' — repeat inherits directly from object. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.chain class identity contracts
#
# itertools.chain.__name__ == 'chain' (len=5)
# itertools.chain.__module__ == 'itertools' (len=9)
# itertools.chain.__class__.__name__ == 'type'
# itertools.chain.__bases__[0].__name__ == 'object'
# itertools.chain.__doc__.__contains__('chain') == True
#
# chain is a C-level type in Modules/itertoolsmodule.c. New to extra238.
# ---------------------------------------------------------------------------

table itertools_extra238.chain_identity:
  description: "itertools.chain class identity: name, module, class, bases, doc; new to extra238"
  kind: python_call_eq
  category: identity
  id_prefix: chain238

  columns: [id, function, args, expected, description]
  rows:
    - [chain_name_eq,
       chain.__name__.__eq__,
       ["chain"],
       true,
       "itertools.chain.__name__.__eq__('chain') == True — chain is a C-level type in Modules/itertoolsmodule.c; __name__ is 'chain' (len=5); new to extra238"]
    - [chain_name_len_5,
       chain.__name__.__len__,
       [],
       5,
       "itertools.chain.__name__.__len__() == 5 — 'chain' has exactly 5 characters; str.__len__() returns 5; new to extra238"]
    - [chain_module_eq,
       chain.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.chain.__module__.__eq__('itertools') == True — chain is defined in Modules/itertoolsmodule.c; __module__ is 'itertools' (len=9); new to extra238"]
    - [chain_class_is_type,
       chain.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.chain.__class__.__name__.__eq__('type') == True — chain is a C-level type; its metaclass is the built-in type type; new to extra238"]
    - [chain_bases_0_is_object,
       "chain.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.chain.__bases__[0].__name__.__eq__('object') == True — chain inherits directly from object; __bases__[0] is object; new to extra238"]

# ---------------------------------------------------------------------------
# Table 2: itertools.chain doc and length contracts
#
# itertools.chain.__doc__.__contains__('chain') == True
# itertools.chain.__doc__.__contains__('iterable') == True
# itertools.chain.__doc__.__class__.__name__ == 'str'
# itertools.chain.__module__.__len__() == 9
# itertools.chain.__name__.__contains__('chain') == True
#
# chain docstring describes chaining iterables. New to extra238.
# ---------------------------------------------------------------------------

table itertools_extra238.chain238_doc_and_lengths:
  description: "itertools.chain doc contains 'chain' and 'iterable'; module len 9; doc class is str; new to extra238"
  kind: python_call_eq
  category: identity
  id_prefix: chain238doc

  columns: [id, function, args, expected, description]
  rows:
    - [chain_doc_contains_chain,
       chain.__doc__.__contains__,
       ["chain"],
       true,
       "itertools.chain.__doc__.__contains__('chain') == True — docstring describes the chain type and its __next__() method; str.__contains__('chain') returns True; new to extra238"]
    - [chain_doc_contains_iterable,
       chain.__doc__.__contains__,
       ["iterable"],
       true,
       "itertools.chain.__doc__.__contains__('iterable') == True — docstring describes consuming iterables until exhausted; str.__contains__('iterable') returns True; new to extra238"]
    - [chain_doc_class_is_str,
       chain.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.chain.__doc__.__class__.__name__.__eq__('str') == True — the chain docstring is a plain Python str object; new to extra238"]
    - [chain_module_len_9,
       chain.__module__.__len__,
       [],
       9,
       "itertools.chain.__module__.__len__() == 9 — 'itertools' has exactly 9 characters (i-t-e-r-t-o-o-l-s); str.__len__() returns 9; new to extra238"]
    - [chain_name_contains_chain,
       chain.__name__.__contains__,
       ["chain"],
       true,
       "itertools.chain.__name__.__contains__('chain') == True — __name__ is 'chain'; str.__contains__('chain') returns True; new to extra238"]

# ---------------------------------------------------------------------------
# Table 3: itertools.repeat class identity contracts
#
# itertools.repeat.__name__ == 'repeat' (len=6)
# itertools.repeat.__module__ == 'itertools' (len=9)
# itertools.repeat.__class__.__name__ == 'type'
# itertools.repeat.__bases__[0].__name__ == 'object'
# itertools.repeat.__doc__.__contains__('repeat') == True
#
# repeat is a C-level type in Modules/itertoolsmodule.c. New to extra238.
# ---------------------------------------------------------------------------

table itertools_extra238.repeat_identity:
  description: "itertools.repeat class identity: name, module, class, bases, doc; new to extra238"
  kind: python_call_eq
  category: identity
  id_prefix: repeat238

  columns: [id, function, args, expected, description]
  rows:
    - [repeat_name_eq,
       repeat.__name__.__eq__,
       ["repeat"],
       true,
       "itertools.repeat.__name__.__eq__('repeat') == True — repeat is a C-level type in Modules/itertoolsmodule.c; __name__ is 'repeat' (len=6); new to extra238"]
    - [repeat_name_len_6,
       repeat.__name__.__len__,
       [],
       6,
       "itertools.repeat.__name__.__len__() == 6 — 'repeat' has exactly 6 characters; str.__len__() returns 6; new to extra238"]
    - [repeat_module_eq,
       repeat.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.repeat.__module__.__eq__('itertools') == True — repeat is defined in Modules/itertoolsmodule.c; __module__ is 'itertools' (len=9); new to extra238"]
    - [repeat_bases_0_is_object,
       "repeat.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.repeat.__bases__[0].__name__.__eq__('object') == True — repeat inherits directly from object; __bases__[0] is object; new to extra238"]
    - [repeat_doc_contains_repeat,
       repeat.__doc__.__contains__,
       ["repeat"],
       true,
       "itertools.repeat.__doc__.__contains__('repeat') == True — docstring describes the repeat type; str.__contains__('repeat') returns True; new to extra238"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra238
# ---------------------------------------------------------------------------

invariant itertools_extra238.chain_name_eq:
  description: "itertools.chain.__name__ == 'chain' (len=5); new to extra238"
  kind: python_call_eq
  function: chain.__name__.__eq__
  args: ["chain"]
  expected: true

invariant itertools_extra238.chain_name_len_5:
  description: "itertools.chain.__name__.__len__() == 5 — 'chain' has 5 characters; new to extra238"
  kind: python_call_eq
  function: chain.__name__.__len__
  args: []
  expected: 5

invariant itertools_extra238.chain_module_eq:
  description: "itertools.chain.__module__ == 'itertools'; new to extra238"
  kind: python_call_eq
  function: chain.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra238.chain_module_len_9:
  description: "itertools.chain.__module__.__len__() == 9 — 'itertools' has 9 characters; new to extra238"
  kind: python_call_eq
  function: chain.__module__.__len__
  args: []
  expected: 9

invariant itertools_extra238.chain_class_is_type:
  description: "itertools.chain.__class__.__name__ == 'type'; new to extra238"
  kind: python_call_eq
  function: chain.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra238.chain_bases_0_is_object:
  description: "itertools.chain.__bases__[0].__name__ == 'object'; new to extra238"
  kind: python_call_eq
  function: "chain.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra238.chain_doc_contains_chain:
  description: "itertools.chain.__doc__.__contains__('chain') == True; new to extra238"
  kind: python_call_eq
  function: chain.__doc__.__contains__
  args: ["chain"]
  expected: true

invariant itertools_extra238.repeat_name_eq:
  description: "itertools.repeat.__name__ == 'repeat' (len=6); new to extra238"
  kind: python_call_eq
  function: repeat.__name__.__eq__
  args: ["repeat"]
  expected: true

invariant itertools_extra238.repeat_name_len_6:
  description: "itertools.repeat.__name__.__len__() == 6 — 'repeat' has 6 characters; new to extra238"
  kind: python_call_eq
  function: repeat.__name__.__len__
  args: []
  expected: 6

invariant itertools_extra238.repeat_module_eq:
  description: "itertools.repeat.__module__ == 'itertools'; new to extra238"
  kind: python_call_eq
  function: repeat.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra238.repeat_bases_0_is_object:
  description: "itertools.repeat.__bases__[0].__name__ == 'object'; new to extra238"
  kind: python_call_eq
  function: "repeat.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra238.repeat_doc_contains_repeat:
  description: "itertools.repeat.__doc__.__contains__('repeat') == True; new to extra238"
  kind: python_call_eq
  function: repeat.__doc__.__contains__
  args: ["repeat"]
  expected: true

invariant itertools_extra238.repeat_doc_contains_times:
  description: "itertools.repeat.__doc__.__contains__('times') == True; new to extra238"
  kind: python_call_eq
  function: repeat.__doc__.__contains__
  args: ["times"]
  expected: true
