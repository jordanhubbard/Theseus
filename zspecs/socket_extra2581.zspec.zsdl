spec: socket_extra2581
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "Wave 2581 theme: __call__ dict-presence — checking whether socket classes define __call__ in their own __dict__ (making instances callable functors)."
    - "socket.socket is a Python class (defined in Lib/socket.py) wrapping a C-level socket file descriptor. Instances are context managers and I/O endpoints, not callable functors."
    - "socket.socket.__dict__.__contains__('__call__') == False — socket objects cannot be invoked with (). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.AddressFamily is an IntEnum subclass. Despite IntEnum types having __call__ on the metaclass, AddressFamily does NOT define __call__ in its own class __dict__. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.SocketKind is an IntEnum subclass. Same as AddressFamily: __call__ is absent from its own __dict__. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.socket.__dict__ contains: accept, close, sendfile, detach, dup, makefile, get_inheritable, set_inheritable, family, type, __enter__, __exit__, __repr__, __init__ — the full Python-level socket API."
    - "socket.AddressFamily.__dict__ contains AF_INET, AF_INET6, AF_UNIX, AF_UNSPEC, AF_ROUTE, AF_SNA and other address family constants, plus __new__ and __format__."
    - "socket.SocketKind.__dict__ contains SOCK_STREAM, SOCK_DGRAM, SOCK_RAW, SOCK_RDM, SOCK_SEQPACKET, plus __new__ and __format__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __call__ absence across all three socket types
#
# socket.socket, socket.AddressFamily, and socket.SocketKind all lack
# __call__ in their own __dict__. None of these types are callable functors.
# ---------------------------------------------------------------------------

table socket_extra2581.call_absent:
  description: "__call__ is absent from socket.socket, AddressFamily, and SocketKind __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2581

  columns: [id, function, args, expected]
  rows:
    - ["sk2581001", "socket.socket.__dict__.__contains__",        ["__call__"], false]
    - ["sk2581002", "socket.AddressFamily.__dict__.__contains__", ["__call__"], false]
    - ["sk2581003", "socket.SocketKind.__dict__.__contains__",    ["__call__"], false]

# ---------------------------------------------------------------------------
# socket.socket I/O API present in __dict__
#
# socket.socket defines its I/O and lifecycle methods directly in its
# __dict__. These True entries confirm the dict lookup works and that
# socket objects have a real API despite not being callable.
# ---------------------------------------------------------------------------

table socket_extra2581.socket_io_api_present:
  description: "I/O and lifecycle methods are present in socket.socket.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2581

  columns: [id, function, args, expected]
  rows:
    - ["sk2581004", "socket.socket.__dict__.__contains__", ["accept"],          true]
    - ["sk2581005", "socket.socket.__dict__.__contains__", ["close"],           true]
    - ["sk2581006", "socket.socket.__dict__.__contains__", ["sendfile"],        true]
    - ["sk2581007", "socket.socket.__dict__.__contains__", ["detach"],          true]
    - ["sk2581008", "socket.socket.__dict__.__contains__", ["dup"],             true]
    - ["sk2581009", "socket.socket.__dict__.__contains__", ["makefile"],        true]
    - ["sk2581010", "socket.socket.__dict__.__contains__", ["get_inheritable"], true]
    - ["sk2581011", "socket.socket.__dict__.__contains__", ["set_inheritable"], true]

# ---------------------------------------------------------------------------
# socket.socket context manager and repr dunders present
#
# socket.socket is a context manager; __enter__ and __exit__ are defined
# in its __dict__. It also defines __repr__ and __init__.
# ---------------------------------------------------------------------------

table socket_extra2581.socket_dunders_present:
  description: "Context manager and representation dunders are present in socket.socket.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2581

  columns: [id, function, args, expected]
  rows:
    - ["sk2581012", "socket.socket.__dict__.__contains__", ["__enter__"], true]
    - ["sk2581013", "socket.socket.__dict__.__contains__", ["__exit__"],  true]
    - ["sk2581014", "socket.socket.__dict__.__contains__", ["__repr__"],  true]
    - ["sk2581015", "socket.socket.__dict__.__contains__", ["__init__"],  true]
    - ["sk2581016", "socket.socket.__dict__.__contains__", ["family"],    true]
    - ["sk2581017", "socket.socket.__dict__.__contains__", ["type"],      true]

# ---------------------------------------------------------------------------
# socket.AddressFamily constants and lifecycle dunders present
#
# socket.AddressFamily is an IntEnum with address family constants
# defined directly in its __dict__, plus __new__ and __format__.
# ---------------------------------------------------------------------------

table socket_extra2581.address_family_members_present:
  description: "Address family constants and lifecycle dunders are present in socket.AddressFamily.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2581

  columns: [id, function, args, expected]
  rows:
    - ["sk2581018", "socket.AddressFamily.__dict__.__contains__", ["AF_INET"],   true]
    - ["sk2581019", "socket.AddressFamily.__dict__.__contains__", ["AF_INET6"],  true]
    - ["sk2581020", "socket.AddressFamily.__dict__.__contains__", ["AF_UNIX"],   true]
    - ["sk2581021", "socket.AddressFamily.__dict__.__contains__", ["AF_UNSPEC"], true]
    - ["sk2581022", "socket.AddressFamily.__dict__.__contains__", ["AF_ROUTE"],  true]
    - ["sk2581023", "socket.AddressFamily.__dict__.__contains__", ["__new__"],   true]
    - ["sk2581024", "socket.AddressFamily.__dict__.__contains__", ["__format__"], true]

# ---------------------------------------------------------------------------
# socket.SocketKind constants present in __dict__
#
# socket.SocketKind is an IntEnum with socket kind constants defined
# directly in its __dict__, plus __new__ and __format__.
# ---------------------------------------------------------------------------

table socket_extra2581.socket_kind_members_present:
  description: "Socket kind constants and lifecycle dunders are present in socket.SocketKind.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2581

  columns: [id, function, args, expected]
  rows:
    - ["sk2581025", "socket.SocketKind.__dict__.__contains__", ["SOCK_STREAM"],    true]
    - ["sk2581026", "socket.SocketKind.__dict__.__contains__", ["SOCK_DGRAM"],     true]
    - ["sk2581027", "socket.SocketKind.__dict__.__contains__", ["SOCK_RAW"],       true]
    - ["sk2581028", "socket.SocketKind.__dict__.__contains__", ["SOCK_RDM"],       true]
    - ["sk2581029", "socket.SocketKind.__dict__.__contains__", ["SOCK_SEQPACKET"], true]
    - ["sk2581030", "socket.SocketKind.__dict__.__contains__", ["__new__"],        true]
    - ["sk2581031", "socket.SocketKind.__dict__.__contains__", ["__format__"],     true]
