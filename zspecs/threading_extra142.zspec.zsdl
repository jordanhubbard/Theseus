spec: threading_extra142
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.Condition (Python class) — doc len 338, method qualnames (__init__, wait, notify, notify_all) and co_argcount; threading.Semaphore (Python class) — doc len 307, method qualnames (__init__, acquire, release); threading.Event (Python class) — doc len 226, method qualnames (__init__, set, clear, wait, is_set) (Wave 269)."
    - "threading.Condition.__doc__ len == 338. Verified with Python 3.14.3."
    - "threading.Condition.__init__.__qualname__ == 'Condition.__init__' (len 18); co_argcount == 2 (self, lock). Verified with Python 3.14.3."
    - "threading.Condition.wait.__qualname__ == 'Condition.wait' (len 14); co_argcount == 2 (self, timeout). Verified with Python 3.14.3."
    - "threading.Condition.notify.__qualname__ == 'Condition.notify' (len 16); co_argcount == 2 (self, n). Verified with Python 3.14.3."
    - "threading.Condition.notify_all.__qualname__ == 'Condition.notify_all' (len 20); co_argcount == 1 (self). Verified with Python 3.14.3."
    - "threading.Semaphore.__doc__ len == 307. Verified with Python 3.14.3."
    - "threading.Semaphore.__init__.__qualname__ == 'Semaphore.__init__' (len 18); co_argcount == 2 (self, value). Verified with Python 3.14.3."
    - "threading.Semaphore.acquire.__qualname__ == 'Semaphore.acquire' (len 17); co_argcount == 3 (self, blocking, timeout). Verified with Python 3.14.3."
    - "threading.Semaphore.release.__qualname__ == 'Semaphore.release' (len 17); co_argcount == 2 (self, n). Verified with Python 3.14.3."
    - "threading.Event.__doc__ len == 226. Verified with Python 3.14.3."
    - "threading.Event.__init__.__qualname__ == 'Event.__init__' (len 14); co_argcount == 1 (self). Verified with Python 3.14.3."
    - "threading.Event.set.__qualname__ == 'Event.set' (len 9); co_argcount == 1 (self). Verified with Python 3.14.3."
    - "threading.Event.wait.__qualname__ == 'Event.wait' (len 10); co_argcount == 2 (self, timeout). Verified with Python 3.14.3."
    - "threading.Event.is_set.__qualname__ == 'Event.is_set' (len 12); co_argcount == 1 (self). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

