spec: hashlib_extra148
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra147.zspec.zsdl — covers hashlib.sha3_256/sha3_512/sha3_224/sha3_384 __name__ equality strings (all 'openssl_sha3_NNN', len 16) / sha3_256/__class__.__name__.__eq__('builtin_function_or_method') / sha3_256/__module__.__eq__('_hashlib') / shake_128/shake_256 __name__ equality (len 17) (table + invariants)."
    - "hashlib_extra146.zspec.zsdl — covers hashlib.pbkdf2_hmac and hashlib.scrypt function identity / pbkdf2_hmac/__qualname__/__len__()==11 / pbkdf2_hmac/__module__.__eq__('_hashlib') / scrypt/__module__.__eq__('_hashlib') / blake2b/__module__.__eq__('_blake2') / blake2s/__module__.__eq__('_blake2') (table + invariants)."
    - "hashlib_extra145.zspec.zsdl — covers hashlib.algorithms_guaranteed/__class__.__name__.__eq__('set') / algorithms_available/__class__.__name__.__eq__('set') / membership checks / sha256/__name__.__eq__('openssl_sha256') / md5/__name__.__eq__('openssl_md5') (table + invariants)."
    - "hashlib_extra144.zspec.zsdl — covers hashlib._hashlib.HASH/__doc__/__len__()==442 / HASH method qualname lengths / sha256 vs sha512/sha224 __doc__ inequality."
    - "hashlib_extra143.zspec.zsdl — covers hashlib.md5/sha1/sha224/sha256/sha384/sha512 __doc__ lengths and qualname lengths / pbkdf2_hmac/scrypt __doc__ lengths / __module__ equality."
    - "hashlib_extra142.zspec.zsdl — covers hashlib.blake2b and blake2s class constants / blake2b/blake2s __doc__ identity and length / sha3/shake constructor __doc__ lengths."
    - "hashlib_extra141.zspec.zsdl — covers hashlib SHA constructor __doc__.__class__.__name__ / __spec__ attribute identity / new.__doc__.__len__()==147 / file_digest.__doc__.__len__()==417."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 constructor __class__.__name__ and __name__ equality / blake2b/blake2s class identity / new/__class__.__name__=='function' / algorithms_guaranteed.__len__()==14."
    - "hashlib_extra98.zspec.zsdl — covers hashlib.sha3_*/shake_* constructor __qualname__ and __module__ equality."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra147."
    - "Wave 308 theme: hashlib.file_digest function identity — file_digest/__qualname__.__eq__('file_digest') (len 11) / file_digest/__module__.__eq__('hashlib') (not '_hashlib'; file_digest is a Python function) / file_digest/__class__.__name__.__eq__('function') / file_digest/__code__.co_argcount==2 / file_digest/__code__.co_name.__eq__('file_digest') / hashlib.__spec__.name.__eq__('hashlib') / hashlib.__doc__.__class__.__name__.__eq__('str') / hashlib.__doc__.__len__()==2098."
    - "hashlib.file_digest.__qualname__ == 'file_digest' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__module__ == 'hashlib' (len 7, WITHOUT underscore prefix). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__class__.__name__ == 'function' (Python-level function in Lib/hashlib.py; contrasts with sha256/md5/pbkdf2_hmac which are builtin_function_or_method). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__code__.co_argcount == 2 (parameters: fileobj, digest). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__code__.co_name == 'file_digest' (len 11, same as __qualname__). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.name == 'hashlib' (len 7). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__doc__.__len__() == 2098. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.file_digest is a Python-level function (class 'function', __module__ == 'hashlib') rather than a C-level builtin_function_or_method (which would have __module__ == '_hashlib'). This makes it unique among the hashlib API: sha256, md5, sha512, pbkdf2_hmac, and scrypt are all C-level builtins from _hashlib or _blake2, while file_digest is implemented in pure Python in Lib/hashlib.py. The function was added in Python 3.11."
    - "Note: hashlib.file_digest.__qualname__ == 'file_digest' (11 chars) and __module__ == 'hashlib' (7 chars). The qualname is a simple (non-class-qualified) name because file_digest is a module-level Python function. The __code__.co_name also equals 'file_digest' (11 chars), consistent with module-level function convention."
    - "Note: hashlib.file_digest.__code__.co_argcount == 2 means the function takes exactly 2 positional arguments: fileobj (a file-like object) and digest (a hash name or constructor). An additional keyword-only argument (_bufsize) exists for internal buffer control, giving co_kwonlyargcount == 1."
    - "Note: hashlib.__doc__ is 2098 chars (a 'str'). This module-level docstring is one of the longest in the hashlib spec series, documenting the module's purpose, algorithm names, and usage. hashlib_extra141 anchors file_digest.__doc__.__len__()==417; this spec anchors the module __doc__ length and the file_digest code object attributes."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.file_digest.__qualname__.__eq__('file_digest')
# hashlib.file_digest.__qualname__.__len__()==11
# hashlib.file_digest.__module__.__eq__('hashlib')
# hashlib.file_digest.__class__.__name__.__eq__('function')
#
# Wave 308 theme: hashlib.file_digest qualname, module, and class identity.
#
# file_digest is a Python-level function (__class__.__name__ == 'function') in
# Lib/hashlib.py with __module__ == 'hashlib' (not '_hashlib'). This distinguishes
# it from all other hashlib callables (sha256/md5/pbkdf2_hmac/scrypt) which are
# C-level builtin_function_or_method objects from _hashlib or _blake2.
# extra141 anchors file_digest.__doc__.__len__()==417; no prior hashlib spec
# anchors file_digest qualname/module/class as a table under hashdoc148.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra148.file_digest_identity:
  description: "hashlib.file_digest/__qualname__.__eq__('file_digest')==True / __qualname__.__len__()==11 / __module__.__eq__('hashlib')==True / __class__.__name__.__eq__('function')==True — file_digest is a Python-level function in Lib/hashlib.py (not a C builtin); __module__ is 'hashlib' (without underscore), distinguishing it from C-level callables whose __module__ is '_hashlib'; extra141 anchors __doc__ length; first hashdoc148 anchor for file_digest identity"
  kind: python_call_eq
  category: identity
  id_prefix: hashdoc148

  columns: [id, function, args, expected, description]
  rows:
    - [fd_qualname_eq,   file_digest.__qualname__.__eq__,         ["file_digest"], true, "hashlib.file_digest.__qualname__ == 'file_digest' (11 chars; simple non-class-qualified qualname)"]
    - [fd_qualname_len,  file_digest.__qualname__.__len__,         [],             11,   "hashlib.file_digest.__qualname__.__len__() is 11 ('file_digest' = 11 chars)"]
    - [fd_module_eq,     file_digest.__module__.__eq__,            ["hashlib"],    true, "hashlib.file_digest.__module__ == 'hashlib' (7 chars; public module without underscore; Python function)"]
    - [fd_class_function, file_digest.__class__.__name__.__eq__,  ["function"],   true, "hashlib.file_digest.__class__.__name__ == 'function' (Python-level; not builtin_function_or_method)"]

# ---------------------------------------------------------------------------
# hashlib.file_digest.__code__.co_argcount==2
# hashlib.file_digest.__code__.co_name.__eq__('file_digest')
# hashlib.file_digest.__code__.co_name.__len__()==11
# hashlib.file_digest.__module__.__len__()==7
#
# Wave 308 theme: file_digest code object attributes.
#
# file_digest takes 2 positional arguments (fileobj, digest) per co_argcount.
# co_name is 'file_digest' (11 chars), matching __qualname__. The module name
# 'hashlib' (7 chars) without underscore equals '__name__.__len__()' for the module.
# No prior hashlib spec anchors file_digest.__code__.co_argcount or co_name
# as a table under hashdoc148. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra148.file_digest_code_attributes:
  description: "hashlib.file_digest/__code__.co_argcount==2 / __code__.co_name.__eq__('file_digest')==True / __code__.co_name.__len__()==11 / __module__.__len__()==7 — co_argcount 2 reflects fileobj and digest positional parameters; co_name 'file_digest' (11 chars) matches __qualname__; __module__ 'hashlib' (7 chars) is length of the public module name; no prior hashlib spec anchors these under hashdoc148"
  kind: python_call_eq
  category: identity
  id_prefix: hashdoc148

  columns: [id, function, args, expected, description]
  rows:
    - [fd_co_argcount,    file_digest.__code__.co_argcount,       [], 2,  "hashlib.file_digest.__code__.co_argcount is 2 (positional params: fileobj and digest)"]
    - [fd_co_name_eq,     file_digest.__code__.co_name.__eq__,    ["file_digest"], true, "hashlib.file_digest.__code__.co_name == 'file_digest' (11 chars; matches __qualname__)"]
    - [fd_co_name_len,    file_digest.__code__.co_name.__len__,   [], 11, "hashlib.file_digest.__code__.co_name.__len__() is 11 ('file_digest' = 11 chars)"]
    - [fd_module_len,     file_digest.__module__.__len__,         [], 7,  "hashlib.file_digest.__module__.__len__() is 7 ('hashlib' = 7 chars; public module name)"]

# ---------------------------------------------------------------------------
# hashlib.__spec__.name.__eq__('hashlib')
# hashlib.__spec__.name.__len__()==7
# hashlib.__doc__.__class__.__name__.__eq__('str')
# hashlib.__doc__.__len__()==2098
#
# Wave 308 theme: hashlib module-level attributes (__spec__.name, __doc__ identity).
#
# hashlib.__spec__.name is 'hashlib' (7 chars), matching the public module name.
# hashlib.__doc__ is a 'str' of length 2098, documenting the module's purpose,
# algorithm names, and usage. extra96 anchors hashlib.__name__/__package__/__spec__;
# no prior hashlib spec anchors __spec__.name equality string or __doc__.__len__()==2098
# as a table under hashdoc148. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra148.module_spec_and_doc_identity:
  description: "hashlib.__spec__.name.__eq__('hashlib')==True / __spec__.name.__len__()==7 / hashlib.__doc__.__class__.__name__.__eq__('str')==True / __doc__.__len__()==2098 — __spec__.name 'hashlib' (7 chars) matches __name__; module docstring is a 2098-char str documenting algorithms, names, and usage; extra96 anchors __spec__ attribute identity; first hashdoc148 anchor for __spec__.name equality string and __doc__.__len__()==2098"
  kind: python_call_eq
  category: identity
  id_prefix: hashdoc148

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,      __spec__.name.__eq__,              ["hashlib"], true, "hashlib.__spec__.name == 'hashlib' (7 chars; public module name in __spec__)"]
    - [spec_name_len,     __spec__.name.__len__,             [],          7,    "hashlib.__spec__.name.__len__() is 7 ('hashlib' = 7 chars)"]
    - [doc_class_str,     __doc__.__class__.__name__.__eq__, ["str"],     true, "hashlib.__doc__.__class__.__name__ == 'str' (module docstring is a regular Python string)"]
    - [doc_len_2098,      __doc__.__len__,                   [],          2098, "hashlib.__doc__.__len__() is 2098 (comprehensive module docstring; 2098 chars)"]

# ---------------------------------------------------------------------------
# hashlib.file_digest.__qualname__.__eq__('file_digest') — standalone
#
# hashlib.file_digest.__qualname__ is 'file_digest' (11 chars). This is a simple
# (non-class-qualified) qualname because file_digest is a module-level function.
# The name 'file_digest' encodes the function's purpose: computing a digest of
# a file-like object's contents. At 11 chars it is the same length as
# hashlib.pbkdf2_hmac.__qualname__ ('pbkdf2_hmac', also 11 chars). extra141
# anchors file_digest.__doc__.__len__()==417; no prior hashlib spec anchors
# file_digest.__qualname__ == 'file_digest' as a standalone under hashdoc148.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra148.file_digest_qualname_eq:
  description: "hashlib.file_digest.__qualname__.__eq__('file_digest') == True — 'file_digest' (11 chars); simple non-class-qualified qualname; module-level Python function added in 3.11; 11 chars matches pbkdf2_hmac qualname length (also 11); extra141 anchors __doc__ length; first standalone under hashdoc148"
  category: identity
  kind: python_call_eq
  function: file_digest.__qualname__.__eq__
  args: ["file_digest"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.file_digest.__module__.__eq__('hashlib') — standalone
#
# hashlib.file_digest.__module__ is 'hashlib' (7 chars), the public module name
# without underscore prefix. This distinguishes file_digest from all C-level hashlib
# callables: sha256, md5, sha512, sha3_256, pbkdf2_hmac, scrypt all have
# __module__ == '_hashlib' (8 chars, with underscore). blake2b/blake2s have
# __module__ == '_blake2' (7 chars, with underscore). file_digest is the only
# hashlib callable with __module__ == 'hashlib' (no underscore).
# No prior hashlib spec anchors this distinction as a standalone under hashdoc148.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra148.file_digest_module_eq:
  description: "hashlib.file_digest.__module__.__eq__('hashlib') == True — 'hashlib' (7 chars, no underscore); only hashlib callable with module == 'hashlib'; all C-level callables have '_hashlib' (8 chars) or '_blake2' (7 chars, with underscore); file_digest is Python-level in Lib/hashlib.py; no prior hashlib spec anchors this as a standalone; first standalone under hashdoc148"
  category: identity
  kind: python_call_eq
  function: file_digest.__module__.__eq__
  args: ["hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.file_digest.__class__.__name__.__eq__('function') — standalone
#
# hashlib.file_digest.__class__.__name__ is 'function'. file_digest is implemented
# as a Python function in Lib/hashlib.py (added in Python 3.11). This makes it
# the only hashlib callable visible at the module level whose class is 'function'
# rather than 'builtin_function_or_method'. The distinction matters for introspection:
# 'function' objects have a __code__ attribute, while builtin_function_or_method
# objects do not. extra99 anchors new/__class__.__name__=='function' (hashlib.new is
# also a Python function); no prior hashlib spec anchors file_digest class name
# as a standalone under hashdoc148. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra148.file_digest_class_function:
  description: "hashlib.file_digest.__class__.__name__.__eq__('function') == True — Python-level function in Lib/hashlib.py (added Python 3.11); only hashlib function-class callable with __code__ attribute; contrasts with sha256/md5/pbkdf2_hmac/scrypt (builtin_function_or_method) and blake2b/blake2s (type); extra99 anchors new/__class__.__name__=='function'; first standalone under hashdoc148"
  category: identity
  kind: python_call_eq
  function: file_digest.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.file_digest.__code__.co_argcount==2 — standalone
#
# hashlib.file_digest.__code__.co_argcount is 2. The two positional parameters are
# fileobj (a file-like object supporting read()) and digest (a hash constructor or
# algorithm name string). An additional keyword-only argument _bufsize (co_kwonlyargcount
# == 1) controls the internal read buffer size but is not included in co_argcount
# (which counts only positional and positional-or-keyword arguments). No prior hashlib
# spec anchors file_digest.__code__.co_argcount==2 as a standalone under hashdoc148.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra148.file_digest_co_argcount_2:
  description: "hashlib.file_digest.__code__.co_argcount == 2 — two positional args: fileobj (file-like object supporting read()) and digest (hash constructor or name string); keyword-only _bufsize (co_kwonlyargcount==1) not counted; file_digest is Python-level so __code__ is accessible; no prior hashlib spec anchors this as a standalone; first standalone under hashdoc148"
  category: identity
  kind: python_call_eq
  function: file_digest.__code__.co_argcount
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# hashlib.__spec__.name.__eq__('hashlib') — standalone
#
# hashlib.__spec__.name is 'hashlib' (7 chars). The __spec__ attribute is a
# ModuleSpec object describing the module's import metadata. Its name attribute
# equals the public module name 'hashlib' — the same as hashlib.__name__. The
# __spec__.name is set by the import system and remains stable across all
# environments where hashlib is importable. extra96 anchors hashlib.__spec__
# attribute identity at a higher level; no prior hashlib spec anchors
# __spec__.name.__eq__('hashlib') as a standalone under hashdoc148.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra148.spec_name_eq_hashlib:
  description: "hashlib.__spec__.name.__eq__('hashlib') == True — 'hashlib' (7 chars); ModuleSpec.name equals __name__ for the public hashlib module; stable across environments; extra96 anchors __spec__ attribute identity; first standalone under hashdoc148"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__doc__.__len__()==2098 — standalone
#
# hashlib.__doc__.__len__() is 2098. The module-level docstring is 2098 chars,
# making it the longest documentation string examined in the hashlib series so far.
# It documents the module's general purpose, the meaning of algorithm names, security
# considerations, and usage examples. The 2098-char length substantially exceeds
# Struct.__doc__ (40 chars), uuid.UUID.__doc__ (2787 chars, however that belongs to
# uuid, not hashlib). No prior hashlib spec anchors hashlib.__doc__.__len__()==2098
# as a standalone under hashdoc148. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra148.doc_len_2098:
  description: "hashlib.__doc__.__len__() == 2098 — module docstring (str) documents the module's purpose, algorithm names, security notes, and usage; 2098 chars; longest hashlib doc string anchored in the series so far; no prior hashlib spec anchors this as a standalone; first standalone under hashdoc148"
  category: doc_lengths
  kind: python_call_eq
  function: __doc__.__len__
  args: []
  expected: 2098

