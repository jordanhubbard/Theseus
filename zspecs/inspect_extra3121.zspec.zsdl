    - ["in3121011", operator.contains, [inspect.Signature.__dict__,           "__repr__"], true]
    - ["in3121012", operator.contains, [inspect.BoundArguments.__dict__,      "__repr__"], true]
    - ["in3121013", operator.contains, [inspect.FrameInfo.__dict__,           "__repr__"], true]
    - ["in3121014", operator.contains, [inspect.ArgInfo.__dict__,             "__repr__"], true]
    - ["in3121015", operator.contains, [inspect.FullArgSpec.__dict__,         "__repr__"], true]
    - ["in3121016", operator.contains, [inspect.Attribute.__dict__,           "__repr__"], true]
    - ["in3121017", operator.contains, [inspect.ClassFoundException.__dict__, "__repr__"], false]
    - ["in3121018", operator.contains, [inspect.EndOfBlock.__dict__,          "__repr__"], false]

