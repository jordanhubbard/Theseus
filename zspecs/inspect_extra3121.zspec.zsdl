spec: in3121
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 655 (in3121): __ge__, __repr__, __str__ dict-presence checks for inspect types."
    - "No inspect type defines __ge__ in its own __dict__."
    - "inspect.Parameter and inspect.Signature define both __repr__ and __str__."
    - "inspect.BoundArguments, inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, and inspect.Attribute define __repr__ but not __str__."
    - "inspect.ClassFoundException and inspect.EndOfBlock define neither __repr__ nor __str__ in their own __dict__."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses; __repr__ is inherited from namedtuple and appears in their own __dict__."
    - "inspect.Parameter.__str__ delegates to __repr__; inspect.Signature.__str__ renders the full signature string."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3121.ge:
  description: "inspect types __ge__ dict-presence checks; wave 655"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in3121
  columns: [id, function, args, expected]
  rows:
    - ["in3121001", operator.contains, [inspect.Parameter.__dict__,           "__ge__"], false]
    - ["in3121002", operator.contains, [inspect.Signature.__dict__,           "__ge__"], false]
    - ["in3121003", operator.contains, [inspect.BoundArguments.__dict__,      "__ge__"], false]
    - ["in3121004", operator.contains, [inspect.FrameInfo.__dict__,           "__ge__"], false]
    - ["in3121005", operator.contains, [inspect.ArgInfo.__dict__,             "__ge__"], false]
    - ["in3121006", operator.contains, [inspect.FullArgSpec.__dict__,         "__ge__"], false]
    - ["in3121007", operator.contains, [inspect.Attribute.__dict__,           "__ge__"], false]
    - ["in3121008", operator.contains, [inspect.ClassFoundException.__dict__, "__ge__"], false]
    - ["in3121009", operator.contains, [inspect.EndOfBlock.__dict__,          "__ge__"], false]

