spec: concurrent_futures_extra109
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec extends concurrent_futures_extra108.zspec.zsdl."
    - "This spec covers: wave 254 theme — concurrent.futures exception __qualname__ string equality and __module__ values. NEW in extra109: concurrent.futures.CancelledError.__qualname__=='CancelledError' (len=14); concurrent.futures.TimeoutError.__qualname__=='TimeoutError' (len=12); concurrent.futures.BrokenExecutor.__qualname__=='BrokenExecutor' (len=14, tied with CancelledError); concurrent.futures.InvalidStateError.__qualname__=='InvalidStateError' (len=17, longest class qualname in this spec); concurrent.futures.CancelledError.__module__=='concurrent.futures._base' (len=24); concurrent.futures.TimeoutError.__module__=='builtins' (len=8, shortest module name — TimeoutError is a builtin alias); concurrent.futures.BrokenExecutor.__module__=='concurrent.futures._base' (len=24, tied with CancelledError); concurrent.futures.InvalidStateError.__module__=='concurrent.futures._base' (len=24); all four exceptions have MRO length=5. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.CancelledError.__qualname__ == 'CancelledError' (len=14). concurrent.futures.TimeoutError.__qualname__ == 'TimeoutError' (len=12, shortest qualname in spec). concurrent.futures.BrokenExecutor.__qualname__ == 'BrokenExecutor' (len=14, tied with CancelledError). concurrent.futures.InvalidStateError.__qualname__ == 'InvalidStateError' (len=17, longest qualname in spec). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.TimeoutError.__module__ == 'builtins' (len=8) — TimeoutError is an alias to the built-in TimeoutError exception; it is NOT defined in concurrent.futures but imported from builtins. The other three exceptions (CancelledError, BrokenExecutor, InvalidStateError) all have __module__=='concurrent.futures._base' (len=24). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures exception __qualname__ string equality — extra109
#
# Wave 254 theme: exception class __qualname__ values and lengths.
#
# CancelledError.__qualname__    == 'CancelledError'    (len=14)
# TimeoutError.__qualname__      == 'TimeoutError'      (len=12, shortest)
# BrokenExecutor.__qualname__    == 'BrokenExecutor'    (len=14, tied with CancelledError)
# InvalidStateError.__qualname__ == 'InvalidStateError' (len=17, longest)
# ---------------------------------------------------------------------------

table concurrent_futures_extra109.cf_exception_qualnames:
  description: "concurrent.futures exception __qualname__ checks in cfexc109 namespace — wave 254 theme: concurrent.futures.CancelledError.__qualname__.__eq__('CancelledError')==True (len=14: 'CancelledError'=14; tied longest with BrokenExecutor=14 among the first three); concurrent.futures.CancelledError.__qualname__.__len__()==14; concurrent.futures.TimeoutError.__qualname__.__eq__('TimeoutError')==True (len=12: 'TimeoutError'=12; shortest exception qualname in spec — 2 chars shorter than CancelledError=14); concurrent.futures.TimeoutError.__qualname__.__len__()==12; concurrent.futures.BrokenExecutor.__qualname__.__eq__('BrokenExecutor')==True (len=14: 'BrokenExecutor'=14; tied with CancelledError=14); concurrent.futures.BrokenExecutor.__qualname__.__len__()==14; concurrent.futures.InvalidStateError.__qualname__.__eq__('InvalidStateError')==True (len=17: 'InvalidStateError'=17; longest exception qualname in spec); concurrent.futures.InvalidStateError.__qualname__.__len__()==17; compare qualname lengths: TimeoutError=12 (shortest) < CancelledError=BrokenExecutor=14 (tied) < InvalidStateError=17 (longest); InvalidStateError=17 > BrokenExecutor=14 by 3 chars; all four exception qualnames contain 'Error': the word 'Error' contributes 5 chars to each name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexc109

  columns: [id, function, args, expected, description]
  rows:
    - [ce_qn_eq,           concurrent.futures.CancelledError.__qualname__.__eq__,        ["CancelledError"],     true, "CancelledError.__qualname__ == 'CancelledError' (len=14); verified with Python 3.14.3"]
    - [ce_qn_len,          concurrent.futures.CancelledError.__qualname__.__len__,        [],                     14,   "CancelledError.__qualname__.__len__() == 14 ('CancelledError'=14); verified with Python 3.14.3"]
    - [te_qn_eq,           concurrent.futures.TimeoutError.__qualname__.__eq__,           ["TimeoutError"],       true, "TimeoutError.__qualname__ == 'TimeoutError' (len=12, shortest in spec); verified with Python 3.14.3"]
    - [te_qn_len,          concurrent.futures.TimeoutError.__qualname__.__len__,           [],                     12,   "TimeoutError.__qualname__.__len__() == 12 ('TimeoutError'=12, shortest exception qualname in spec); verified with Python 3.14.3"]
    - [be_qn_eq,           concurrent.futures.BrokenExecutor.__qualname__.__eq__,         ["BrokenExecutor"],     true, "BrokenExecutor.__qualname__ == 'BrokenExecutor' (len=14, tied with CancelledError=14); verified with Python 3.14.3"]
    - [be_qn_len,          concurrent.futures.BrokenExecutor.__qualname__.__len__,         [],                     14,   "BrokenExecutor.__qualname__.__len__() == 14 ('BrokenExecutor'=14, tied with CancelledError=14); verified with Python 3.14.3"]
    - [ise_qn_eq,          concurrent.futures.InvalidStateError.__qualname__.__eq__,       ["InvalidStateError"],  true, "InvalidStateError.__qualname__ == 'InvalidStateError' (len=17, longest in spec); verified with Python 3.14.3"]
    - [ise_qn_len,         concurrent.futures.InvalidStateError.__qualname__.__len__,      [],                     17,   "InvalidStateError.__qualname__.__len__() == 17 ('InvalidStateError'=17, longest exception qualname in spec); verified with Python 3.14.3"]
    - [ce_vs_te_len,       concurrent.futures.CancelledError.__qualname__.__len__,         [],                     14,   "CancelledError len=14 > TimeoutError len=12 (CancelledError is 2 chars longer); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures exception __module__ values — extra109
#
# Wave 254 theme: exception class __module__ values and lengths.
#
# CancelledError.__module__    == 'concurrent.futures._base' (len=24)
# TimeoutError.__module__      == 'builtins'                 (len=8, shortest — builtin alias)
# BrokenExecutor.__module__    == 'concurrent.futures._base' (len=24)
# InvalidStateError.__module__ == 'concurrent.futures._base' (len=24)
# ---------------------------------------------------------------------------

table concurrent_futures_extra109.cf_exception_modules:
  description: "concurrent.futures exception __module__ checks in cfexc109 namespace — wave 254 theme: concurrent.futures.CancelledError.__module__.__eq__('concurrent.futures._base')==True (len=24: 'concurrent.futures._base'=24; CancelledError is defined in the private _base submodule); concurrent.futures.CancelledError.__module__.__len__()==24; concurrent.futures.TimeoutError.__module__.__eq__('builtins')==True (len=8: 'builtins'=8; shortest module name in spec — TimeoutError is NOT defined in concurrent.futures but is the built-in OSError subclass re-exported); concurrent.futures.TimeoutError.__module__.__len__()==8; concurrent.futures.BrokenExecutor.__module__.__eq__('concurrent.futures._base')==True (len=24; tied with CancelledError and InvalidStateError); concurrent.futures.BrokenExecutor.__module__.__len__()==24; concurrent.futures.InvalidStateError.__module__.__eq__('concurrent.futures._base')==True (len=24; also in _base); concurrent.futures.InvalidStateError.__module__.__len__()==24; compare module name lengths: 'builtins'=8 (shortest, TimeoutError) vs 'concurrent.futures._base'=24 (all others, 3x longer); TimeoutError.__module__=='builtins' reveals that concurrent.futures.TimeoutError is simply the built-in TimeoutError (an OSError subclass) re-exported under the concurrent.futures namespace; CancelledError, BrokenExecutor, and InvalidStateError are all custom exception classes defined in concurrent.futures._base; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexc109a

  columns: [id, function, args, expected, description]
  rows:
    - [ce_module_eq,       concurrent.futures.CancelledError.__module__.__eq__,          ["concurrent.futures._base"], true, "CancelledError.__module__ == 'concurrent.futures._base' (len=24); verified with Python 3.14.3"]
    - [ce_module_len,      concurrent.futures.CancelledError.__module__.__len__,          [],                     24,   "CancelledError.__module__.__len__() == 24 ('concurrent.futures._base'=24); verified with Python 3.14.3"]
    - [te_module_eq,       concurrent.futures.TimeoutError.__module__.__eq__,             ["builtins"],           true, "TimeoutError.__module__ == 'builtins' (len=8, shortest — TimeoutError is a builtin alias); verified with Python 3.14.3"]
    - [te_module_len,      concurrent.futures.TimeoutError.__module__.__len__,             [],                     8,    "TimeoutError.__module__.__len__() == 8 ('builtins'=8, shortest module name in spec); verified with Python 3.14.3"]
    - [be_module_eq,       concurrent.futures.BrokenExecutor.__module__.__eq__,           ["concurrent.futures._base"], true, "BrokenExecutor.__module__ == 'concurrent.futures._base' (len=24); verified with Python 3.14.3"]
    - [be_module_len,      concurrent.futures.BrokenExecutor.__module__.__len__,           [],                     24,   "BrokenExecutor.__module__.__len__() == 24 ('concurrent.futures._base'=24); verified with Python 3.14.3"]
    - [ise_module_eq,      concurrent.futures.InvalidStateError.__module__.__eq__,         ["concurrent.futures._base"], true, "InvalidStateError.__module__ == 'concurrent.futures._base' (len=24); verified with Python 3.14.3"]
    - [ise_module_len,     concurrent.futures.InvalidStateError.__module__.__len__,         [],                     24,   "InvalidStateError.__module__.__len__() == 24 ('concurrent.futures._base'=24); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures exception MRO and base class hierarchy — extra109
#
# Wave 254 theme: exception class MRO lengths and base class names.
#
# CancelledError.__mro__ == [CancelledError, Error, Exception, BaseException, object] (len=5)
# TimeoutError.__mro__   == [TimeoutError, OSError, Exception, BaseException, object]  (len=5)
# BrokenExecutor.__mro__ == [BrokenExecutor, RuntimeError, Exception, BaseException, object] (len=5)
# InvalidStateError.__mro__ == [InvalidStateError, Error, Exception, BaseException, object] (len=5)
# ---------------------------------------------------------------------------

table concurrent_futures_extra109.cf_exception_hierarchy:
  description: "concurrent.futures exception MRO and base class hierarchy checks in cfexc109 namespace — wave 254 theme: all four exceptions have MRO length=5; concurrent.futures.CancelledError.__mro__.__len__()==5 (MRO=[CancelledError, Error, Exception, BaseException, object]); concurrent.futures.CancelledError.__bases__[0].__name__.__eq__('Error')==True (CancelledError inherits from concurrent.futures._base.Error, a custom base exception class); concurrent.futures.TimeoutError.__mro__.__len__()==5 (MRO=[TimeoutError, OSError, Exception, BaseException, object]); concurrent.futures.TimeoutError.__bases__[0].__name__.__eq__('OSError')==True (TimeoutError is the built-in OSError subclass; it does NOT inherit from concurrent.futures.Error); concurrent.futures.BrokenExecutor.__mro__.__len__()==5 (MRO=[BrokenExecutor, RuntimeError, Exception, BaseException, object]); concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__('RuntimeError')==True (BrokenExecutor inherits from RuntimeError — raised when executor is broken and can no longer process tasks); concurrent.futures.InvalidStateError.__mro__.__len__()==5 (MRO=[InvalidStateError, Error, Exception, BaseException, object]); concurrent.futures.InvalidStateError.__bases__[0].__name__.__eq__('Error')==True (InvalidStateError inherits from concurrent.futures._base.Error, same as CancelledError); compare: CancelledError and InvalidStateError both inherit from Error (same base); TimeoutError inherits from OSError (stdlib); BrokenExecutor inherits from RuntimeError (stdlib); all four have MRO len=5; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: cfexc109b

  columns: [id, function, args, expected, description]
  rows:
    - [ce_mro_len,         concurrent.futures.CancelledError.__mro__.__len__,             [],                     5,    "CancelledError.__mro__.__len__() == 5 ([CancelledError, Error, Exception, BaseException, object]); verified with Python 3.14.3"]
    - [ce_base_eq,         "concurrent.futures.CancelledError.__bases__[0].__name__.__eq__", ["Error"],            true, "CancelledError.__bases__[0].__name__ == 'Error' (inherits from concurrent.futures._base.Error); verified with Python 3.14.3"]
    - [te_mro_len,         concurrent.futures.TimeoutError.__mro__.__len__,               [],                     5,    "TimeoutError.__mro__.__len__() == 5 ([TimeoutError, OSError, Exception, BaseException, object]); verified with Python 3.14.3"]
    - [te_base_eq,         "concurrent.futures.TimeoutError.__bases__[0].__name__.__eq__", ["OSError"],           true, "TimeoutError.__bases__[0].__name__ == 'OSError' (built-in TimeoutError inherits from OSError); verified with Python 3.14.3"]
    - [be_mro_len,         concurrent.futures.BrokenExecutor.__mro__.__len__,              [],                     5,    "BrokenExecutor.__mro__.__len__() == 5 ([BrokenExecutor, RuntimeError, Exception, BaseException, object]); verified with Python 3.14.3"]
    - [be_base_eq,         "concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__", ["RuntimeError"],    true, "BrokenExecutor.__bases__[0].__name__ == 'RuntimeError' (raised when executor is broken); verified with Python 3.14.3"]
    - [ise_mro_len,        concurrent.futures.InvalidStateError.__mro__.__len__,            [],                     5,    "InvalidStateError.__mro__.__len__() == 5 ([InvalidStateError, Error, Exception, BaseException, object]); verified with Python 3.14.3"]
    - [ise_base_eq,        "concurrent.futures.InvalidStateError.__bases__[0].__name__.__eq__", ["Error"],         true, "InvalidStateError.__bases__[0].__name__ == 'Error' (same base as CancelledError); verified with Python 3.14.3"]
    - [all_mro_same_len,   concurrent.futures.BrokenExecutor.__mro__.__len__,              [],                     5,    "BrokenExecutor.__mro__ len=5 — all four cf exceptions have MRO length=5; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra109
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra109.InvalidStateError_qualname_len_17:
  description: "concurrent.futures.InvalidStateError.__qualname__.__len__() == 17 — 'InvalidStateError'=17 chars; this is the longest exception qualname in this spec; compare exception qualname lengths: TimeoutError=12 (shortest) < CancelledError=BrokenExecutor=14 (tied) < InvalidStateError=17 (longest); InvalidStateError=17 > BrokenExecutor=14 by 3 chars; concurrent.futures.InvalidStateError.__module__=='concurrent.futures._base' (len=24); concurrent.futures.InvalidStateError.__bases__[0].__name__=='Error' (same base as CancelledError — both inherit from concurrent.futures._base.Error); InvalidStateError.__mro__.__len__()==5 ([InvalidStateError, Error, Exception, BaseException, object]); InvalidStateError is raised when an operation is performed on a Future in an invalid state (e.g., setting the result on an already-completed Future); NEW in extra109: first standalone InvalidStateError qualname length invariant in cfexc109 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.InvalidStateError.__qualname__.__len__
  args: []
  expected: 17

invariant concurrent_futures_extra109.TimeoutError_qualname_len_12:
  description: "concurrent.futures.TimeoutError.__qualname__.__len__() == 12 — 'TimeoutError'=12 chars; this is the shortest exception qualname in this spec; compare: TimeoutError=12 (shortest) < CancelledError=BrokenExecutor=14 (tied) < InvalidStateError=17 (longest); concurrent.futures.TimeoutError.__module__=='builtins' (len=8) — the shortest __module__ value in this spec and a key distinguishing fact: TimeoutError is NOT defined in concurrent.futures._base but is simply the built-in TimeoutError (subclass of OSError) re-exported; CancelledError, BrokenExecutor, InvalidStateError all have __module__=='concurrent.futures._base' (len=24); TimeoutError.__bases__[0].__name__=='OSError' (only exception in spec that inherits from an OS-level error); NEW in extra109: first standalone TimeoutError qualname length invariant in cfexc109 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.TimeoutError.__qualname__.__len__
  args: []
  expected: 12

invariant concurrent_futures_extra109.TimeoutError_module_is_builtins:
  description: "concurrent.futures.TimeoutError.__module__.__eq__('builtins') returns True — TimeoutError.__module__=='builtins' (len=8); this is the unique distinguishing fact about concurrent.futures.TimeoutError: it is the built-in Python TimeoutError (an OSError subclass) re-exported under the concurrent.futures namespace; all other three exceptions in this spec have __module__=='concurrent.futures._base' (len=24 — three times as long as 'builtins'=8); concurrent.futures.TimeoutError.__bases__[0].__name__=='OSError' (unlike CancelledError and InvalidStateError which inherit from concurrent.futures._base.Error, and BrokenExecutor which inherits from RuntimeError); TimeoutError.__qualname__=='TimeoutError' (len=12, shortest in spec); TimeoutError.__mro__.__len__()==5 ([TimeoutError, OSError, Exception, BaseException, object]); concurrent.futures.TimeoutError is provided for backward compatibility; NEW in extra109: first standalone TimeoutError __module__ invariant in cfexc109 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.TimeoutError.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant concurrent_futures_extra109.CancelledError_module_len_24:
  description: "concurrent.futures.CancelledError.__module__.__len__() == 24 — 'concurrent.futures._base'=24 chars; this is the module name shared by CancelledError, BrokenExecutor, and InvalidStateError (all three defined in concurrent.futures._base); compare module lengths: 'builtins'=8 (TimeoutError, shortest) vs 'concurrent.futures._base'=24 (all others, longest — 3x longer than 'builtins'); concurrent.futures.CancelledError.__qualname__=='CancelledError' (len=14); concurrent.futures.CancelledError.__bases__[0].__name__=='Error' (inherits from concurrent.futures._base.Error); CancelledError.__mro__.__len__()==5 ([CancelledError, Error, Exception, BaseException, object]); CancelledError is raised when a Future is cancelled; in Python 3.8+, CancelledError is a subclass of BaseException (via Error) in the asyncio/concurrent.futures ecosystem; the module string 'concurrent.futures._base' contains the private '_base' submodule marker; NEW in extra109: first standalone CancelledError module length invariant in cfexc109 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.CancelledError.__module__.__len__
  args: []
  expected: 24

invariant concurrent_futures_extra109.BrokenExecutor_base_is_RuntimeError:
  description: "concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__('RuntimeError') returns True — BrokenExecutor inherits from RuntimeError (not from concurrent.futures._base.Error like CancelledError and InvalidStateError); BrokenExecutor.__qualname__=='BrokenExecutor' (len=14, tied with CancelledError=14); BrokenExecutor.__module__=='concurrent.futures._base' (len=24); BrokenExecutor.__mro__.__len__()==5 ([BrokenExecutor, RuntimeError, Exception, BaseException, object]); BrokenExecutor is raised when a ThreadPoolExecutor or ProcessPoolExecutor is broken and can no longer be used to submit new tasks; compare bases: BrokenExecutor.__bases__[0].__name__=='RuntimeError' vs CancelledError.__bases__[0].__name__=='Error' vs TimeoutError.__bases__[0].__name__=='OSError' vs InvalidStateError.__bases__[0].__name__=='Error'; BrokenExecutor is the only exception in this spec that inherits from RuntimeError; NEW in extra109: first standalone BrokenExecutor base name invariant in cfexc109 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__"
  args: ["RuntimeError"]
  expected: true
