spec: decimal_extra93
version: ">=3.9"
backend: python_module(decimal)
extends: decimal_extra92

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal_extra92.zspec.zsdl."
    - "This spec covers: decimal ROUND_* constants and decimal.Context.__init__ descriptor attrs."
    - "All ROUND_* constants are plain str objects; their values equal their own names (e.g. ROUND_UP == 'ROUND_UP')."
    - "ROUND_UP len=8, ROUND_DOWN len=10, ROUND_CEILING len=13, ROUND_FLOOR len=11."
    - "ROUND_HALF_UP len=13, ROUND_HALF_DOWN len=15, ROUND_HALF_EVEN len=15, ROUND_05UP len=10."
    - "decimal.Context.__init__ is a 'wrapper_descriptor' (C extension slot); it has no __code__ attribute."
    - "Context.__init__.__qualname__ = 'Context.__init__' (length 16)."
    - "Context.__init__.__name__ = '__init__' (length 8)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal ROUND_* constant values and class names
# ROUND_UP through ROUND_HALF_DOWN — all str with value == name
# ---------------------------------------------------------------------------

table decimal_extra93.rounding_constants_values_and_classnames:
  description: "decimal ROUND_UP through ROUND_HALF_DOWN: values (str) and __class__.__name__ == 'str'"
  kind: python_call_eq
  category: rounding_constants
  id_prefix: decimalrounding93

  columns: [id, function, args, expected]
  rows:
    - [round_up_val,      ROUND_UP.__eq__,                     ["ROUND_UP"],       true]
    - [round_up_cls,      ROUND_UP.__class__.__name__.__eq__,  ["str"],            true]
    - [round_dn_val,      ROUND_DOWN.__eq__,                   ["ROUND_DOWN"],     true]
    - [round_dn_cls,      ROUND_DOWN.__class__.__name__.__eq__, ["str"],           true]
    - [round_ceil_val,    ROUND_CEILING.__eq__,                ["ROUND_CEILING"],  true]
    - [round_ceil_cls,    ROUND_CEILING.__class__.__name__.__eq__, ["str"],        true]
    - [round_floor_val,   ROUND_FLOOR.__eq__,                  ["ROUND_FLOOR"],   true]
    - [round_floor_cls,   ROUND_FLOOR.__class__.__name__.__eq__, ["str"],          true]
    - [round_halfup_val,  ROUND_HALF_UP.__eq__,                ["ROUND_HALF_UP"], true]
    - [round_halfup_cls,  ROUND_HALF_UP.__class__.__name__.__eq__, ["str"],        true]
    - [round_halfdn_val,  ROUND_HALF_DOWN.__eq__,              ["ROUND_HALF_DOWN"], true]
    - [round_halfdn_cls,  ROUND_HALF_DOWN.__class__.__name__.__eq__, ["str"],      true]
    - [round_up_not_int,  ROUND_UP.__class__.__name__.__eq__,  ["int"],            false]

# ---------------------------------------------------------------------------
# decimal ROUND_HALF_EVEN, ROUND_05UP values and __len__() measurements
# ROUND_HALF_EVEN len=15, ROUND_05UP len=10
# ---------------------------------------------------------------------------

table decimal_extra93.rounding_halfe_and_05up:
  description: "decimal.ROUND_HALF_EVEN and ROUND_05UP: string values and __len__() measurements"
  kind: python_call_eq
  category: rounding_constants
  id_prefix: decimalrounding93

  columns: [id, function, args, expected]
  rows:
    - [round_halfe_val,  ROUND_HALF_EVEN.__eq__,              ["ROUND_HALF_EVEN"], true]
    - [round_halfe_cls,  ROUND_HALF_EVEN.__class__.__name__.__eq__, ["str"],       true]
    - [round_halfe_len,  ROUND_HALF_EVEN.__len__,             [],                  15]
    - [round_05up_val,   ROUND_05UP.__eq__,                   ["ROUND_05UP"],      true]
    - [round_05up_cls,   ROUND_05UP.__class__.__name__.__eq__, ["str"],             true]
    - [round_05up_len,   ROUND_05UP.__len__,                  [],                  10]
    - [round_halfdn_len, ROUND_HALF_DOWN.__len__,             [],                  15]
    - [round_halfup_len, ROUND_HALF_UP.__len__,               [],                  13]
    - [round_up_len,     ROUND_UP.__len__,                    [],                  8]
    - [round_dn_len,     ROUND_DOWN.__len__,                  [],                  10]
    - [round_ceil_len,   ROUND_CEILING.__len__,               [],                  13]
    - [round_floor_len,  ROUND_FLOOR.__len__,                 [],                  11]

# ---------------------------------------------------------------------------
# ROUND_* string self-equality (value == its own constant name as a string)
# ---------------------------------------------------------------------------

table decimal_extra93.rounding_string_self_equality:
  description: "decimal ROUND_* constants are strings equal to their own constant names: ROUND_UP == 'ROUND_UP', etc."
  kind: python_call_eq
  category: rounding_constants
  id_prefix: decimalrounding93

  columns: [id, function, args, expected]
  rows:
    - [rup_self_eq,    ROUND_UP.__eq__,        ["ROUND_UP"],        true]
    - [rdn_self_eq,    ROUND_DOWN.__eq__,      ["ROUND_DOWN"],      true]
    - [rceil_self_eq,  ROUND_CEILING.__eq__,   ["ROUND_CEILING"],   true]
    - [rfloor_self_eq, ROUND_FLOOR.__eq__,     ["ROUND_FLOOR"],     true]
    - [rhup_self_eq,   ROUND_HALF_UP.__eq__,   ["ROUND_HALF_UP"],   true]
    - [rhdn_self_eq,   ROUND_HALF_DOWN.__eq__, ["ROUND_HALF_DOWN"], true]
    - [rhe_self_eq,    ROUND_HALF_EVEN.__eq__, ["ROUND_HALF_EVEN"], true]
    - [r05_self_eq,    ROUND_05UP.__eq__,      ["ROUND_05UP"],      true]
    - [rup_not_rdn,    ROUND_UP.__eq__,        ["ROUND_DOWN"],      false]

# ---------------------------------------------------------------------------
# decimal.Context.__init__ descriptor attrs
# __class__.__name__ = 'wrapper_descriptor'
# __qualname__ = 'Context.__init__' (len 16)
# __name__ = '__init__' (len 8)
# ---------------------------------------------------------------------------

table decimal_extra93.Context_init_descriptor_attrs:
  description: "decimal.Context.__init__ is a 'wrapper_descriptor'; its __qualname__ is 'Context.__init__' (len 16) and __name__ is '__init__' (len 8)"
  kind: python_call_eq
  category: code_attrs
  id_prefix: decimalrounding93

  columns: [id, function, args, expected]
  rows:
    - [ctx_init_cls,        Context.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"],  true]
    - [ctx_init_qn_eq,      Context.__init__.__qualname__.__eq__,       ["Context.__init__"],    true]
    - [ctx_init_qn_len,     Context.__init__.__qualname__.__len__,      [],                      16]
    - [ctx_init_name_eq,    Context.__init__.__name__.__eq__,           ["__init__"],            true]
    - [ctx_init_name_len,   Context.__init__.__name__.__len__,          [],                      8]
    - [ctx_init_not_meth,   Context.__init__.__class__.__name__.__eq__, ["method_descriptor"],   false]
    - [ctx_init_not_fn,     Context.__init__.__class__.__name__.__eq__, ["function"],            false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra93.ROUND_UP.value_equals_name:
  description: "decimal.ROUND_UP == 'ROUND_UP' (ROUND_* constants are plain strings equal to their own names, not integer constants or enum members)"
  category: rounding_constants
  kind: python_call_eq
  function: ROUND_UP.__eq__
  args: ["ROUND_UP"]
  expected: true

invariant decimal_extra93.ROUND_UP.class_is_str:
  description: "decimal.ROUND_UP.__class__.__name__ == 'str' (all ROUND_* rounding mode constants are ordinary Python str objects)"
  category: rounding_constants
  kind: python_call_eq
  function: ROUND_UP.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant decimal_extra93.ROUND_HALF_EVEN.len_is_15:
  description: "decimal.ROUND_HALF_EVEN.__len__() == 15 (the string 'ROUND_HALF_EVEN' has 15 characters)"
  category: rounding_constants
  kind: python_call_eq
  function: ROUND_HALF_EVEN.__len__
  args: []
  expected: 15

invariant decimal_extra93.Context.init_is_wrapper_descriptor:
  description: "decimal.Context.__init__.__class__.__name__ == 'wrapper_descriptor' (Context is a C extension type; its __init__ slot is exposed as a wrapper_descriptor with no __code__ attribute)"
  category: code_attrs
  kind: python_call_eq
  function: Context.__init__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra93.Context.init_qualname_eq:
  description: "decimal.Context.__init__.__qualname__ == 'Context.__init__' (wrapper_descriptor objects on C extension types carry a dotted __qualname__ including the class name)"
  category: code_attrs
  kind: python_call_eq
  function: Context.__init__.__qualname__.__eq__
  args: ["Context.__init__"]
  expected: true
