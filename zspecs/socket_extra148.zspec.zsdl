# ---------------------------------------------------------------------------
# socket.__dict__.__contains__('error') — standalone
#
# socket.__dict__.__contains__('error') is True. The 'error' key in socket.__dict__
# maps to socket.error, which is an alias for the built-in OSError. socket.error is
# OSError evaluates to True. The name 'error' (5 chars) is kept for backward
# compatibility — code written before Python 3.3 (when socket.error became an alias
# for OSError) continues to work. extra146 anchors __all__.__contains__('error');
# no prior socket spec anchors socket.__dict__.__contains__('error') as a standalone
# under sockmod148. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra148.module_dict_contains_error:
  description: "socket.__dict__.__contains__('error') == True — 'error' maps to OSError (socket.error is OSError == True); kept for backward compatibility; socket.error.__name__ is 'OSError' (not 'error'); extra146 anchors __all__.__contains__('error'); no prior socket spec anchors this as a standalone; first standalone under sockmod148"
  category: identity
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["error"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('family') — standalone
#
# socket.socket.__dict__.__contains__('family') is True. 'family' is a property
# descriptor in socket.socket.__dict__ that returns the socket's address family as
# an AddressFamily IntEnum member (e.g., AF_INET for IPv4). The property is defined
# in Lib/socket.py and provides enum-typed access to the underlying _socket.socket
# family attribute. extra144 anchors socket.socket.__dict__.__class__.__name__
# == 'mappingproxy'; no prior socket spec anchors socket.socket.__dict__.__contains__
# ('family') as a standalone under sockmod148.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra148.socket_dict_contains_family:
  description: "socket.socket.__dict__.__contains__('family') == True — 'family' is a property descriptor in socket.socket; returns socket address family as AddressFamily IntEnum; Python-level override of C-level attribute; extra144 anchors socket.socket.__dict__ class name 'mappingproxy'; no prior socket spec anchors this as a standalone; first standalone under sockmod148"
  category: identity
  kind: python_call_eq
  function: socket.__dict__.__contains__
  args: ["family"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('__enter__') — standalone
#
# socket.socket.__dict__.__contains__('__enter__') is True. socket.socket.__enter__
# is a Python-level function defined in Lib/socket.py that returns self, enabling
# socket objects to be used as context managers with the 'with' statement. Together
# with __exit__ (which calls self.close()), this ensures sockets are properly closed
# when the 'with' block exits, even if an exception occurs. Both __enter__ and __exit__
# are present in socket.socket.__dict__ (verified True). extra147 anchors other
# Python-level method entries; no prior socket spec anchors socket.socket.__dict__
# .__contains__('__enter__') as a standalone under sockmod148.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra148.socket_dict_contains_enter:
  description: "socket.socket.__dict__.__contains__('__enter__') == True — Python-level function in Lib/socket.py; returns self for 'with socket.socket() as s:' context manager; __exit__ (also present) calls self.close() on exit; extra147 anchors other Python-level method entries (accept/makefile/close/etc.); no prior socket spec anchors this as a standalone; first standalone under sockmod148"
  category: identity
  kind: python_call_eq
  function: socket.__dict__.__contains__
  args: ["__enter__"]
  expected: true

