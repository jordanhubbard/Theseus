spec: socket_extra148
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra147.zspec.zsdl — covers socket.socket.__dict__.__contains__('accept'/'makefile'/'close'/'__init__'/'__slots__'/'sendfile'/'detach'/'dup'/'__repr__') / socket.__dict__.__len__()==28 / socket.__package__.__eq__('') / socket.__loader__.__class__.__name__.__eq__('SourceFileLoader') (table + invariants)."
    - "socket_extra146.zspec.zsdl — covers socket.__all__.__contains__('socket'/'AF_INET'/'SOCK_STREAM'/'gethostname'/'error'/'AF_INET6') / __all__.__len__()==238 / socket.socket.__init__.__qualname__.__eq__('socket.__init__') / __init__.__class__.__name__.__eq__('function') (table + invariants)."
    - "socket_extra145.zspec.zsdl — covers socket.AF_UNSPEC/__class__.__name__.__eq__('AddressFamily') / AF_UNIX.name.__eq__('AF_UNIX') / IPPROTO_TCP/__class__.__name__.__eq__('int') / __spec__.name.__eq__('socket') / __doc__.__len__()==2021 (table + invariants)."
    - "socket_extra144.zspec.zsdl — covers socket.socket.__module__/__qualname__/__eq__('socket') / socket.socket.__dict__.__class__.__name__.__eq__('mappingproxy') / __mro__.__len__()==3 (table + invariants)."
    - "socket_extra143.zspec.zsdl — covers socket.socket method __qualname__ string equality for connect/bind/listen/accept/recv / accept/__class__.__name__=='function' (table + invariants)."
    - "socket_extra142.zspec.zsdl — covers socket.AF_INET/AF_INET6 enum member .name values / SOCK_STREAM/SOCK_DGRAM .name values / AddressFamily/SocketKind class __name__ values (table + invariants)."
    - "socket_extra99.zspec.zsdl — covers socket.gethostname/gethostbyname/getaddrinfo/setdefaulttimeout/getdefaulttimeout __qualname__.__len__() / SocketIO class identity."
    - "socket_extra97.zspec.zsdl — covers socket.socket.send/sendall/fileno __qualname__.__eq__ / socket.socket.__init__/accept/makefile/close __class__.__name__=='function'."
    - "socket_extra95.zspec.zsdl — covers AddressFamily/SocketKind enum member values and names / socket.__all__ class name and length."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra93 through socket_extra147."
    - "Wave 323 theme: socket module-level __dict__.__contains__ checks — socket.__dict__.__contains__('socket')==True / __dict__.__contains__('AF_INET')==True / __dict__.__contains__('gethostname')==True / __dict__.__contains__('error')==True. Also socket.socket.__dict__.__contains__('family')==True / __dict__.__contains__('type')==True / __dict__.__contains__('__enter__')==True / __dict__.__contains__('__exit__')==True."
    - "socket.__dict__.__contains__('socket') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__dict__.__contains__('AF_INET') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__dict__.__contains__('gethostname') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__dict__.__contains__('error') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('family') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('type') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('__enter__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('__exit__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.__dict__ is a plain 'dict' (not a mappingproxy). Module __dict__ objects are always mutable plain dicts. This contrasts with socket.socket.__dict__ which is a 'mappingproxy' (anchored in extra144). socket.__dict__.__len__() == 267 (verified Python 3.14.3), much larger than the 18-entry struct.__dict__ or the 37-entry uuid.UUID.__dict__ — the 267 module-level entries include all AF_*/SOCK_*/IPPROTO_*/SO_* constants plus all functions, the socket class, and exception aliases."
    - "Note: socket.__dict__.__contains__('socket') refers to the socket.socket class at the module level (not the module itself). The socket module exports the socket class under the same name as the module, creating the overloaded name 'socket' (6 chars) that refers to both the module and the class. extra146 anchors __all__.__contains__('socket'); this spec is the first to anchor socket.__dict__.__contains__('socket')."
    - "Note: socket.__dict__.__contains__('error') is True, but socket.error is an alias for OSError — it is the same object as the built-in OSError (socket.error is OSError evaluates to True). socket.error.__name__ is 'OSError' (not 'error'), and its __module__ is 'builtins'. The 'error' key in socket.__dict__ maps to the OSError class re-exported under the name 'error' for backward compatibility."
    - "Note: socket.socket.__dict__.__contains__('family') and __dict__.__contains__('type') are both True. 'family' and 'type' are property descriptors defined in Lib/socket.py on the socket.socket class. They return the socket's address family and socket type, respectively, as IntEnum members. C-level equivalents are inherited from _socket.socket but the Python-level properties override them for enum-typed access."
    - "Note: socket.socket.__dict__.__contains__('__enter__') and __dict__.__contains__('__exit__') are both True. These are Python-level functions defined in Lib/socket.py to support the context manager protocol ('with socket.socket() as s:'). __enter__ returns self; __exit__ calls self.close(). These are among the Python-level entries in socket.socket.__dict__ (28 entries total, anchored in extra147)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.__dict__.__contains__('socket')
# socket.__dict__.__contains__('AF_INET')
# socket.__dict__.__contains__('gethostname')
# socket.__dict__.__contains__('error')
#
# Wave 323 theme: socket module-level __dict__ contains key public names.
#
# The module-level dict contains the socket class (under the same name as the module),
# the AF_INET constant, the gethostname function, and the error exception alias.
# extra146 anchors __all__.__contains__ for these same names; no prior socket spec
# anchors socket.__dict__.__contains__ for any name as a table under sockmod148.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra148.module_dict_contains_key_names:
  description: "socket.__dict__.__contains__('socket')==True / __dict__.__contains__('AF_INET')==True / __dict__.__contains__('gethostname')==True / __dict__.__contains__('error')==True — module-level plain dict (267 entries); 'socket' is the socket class (same name as module); AF_INET is the IPv4 address family constant; gethostname is a builtin_function_or_method; error is an alias for OSError; extra146 covers __all__.__contains__ for these names; first sockmod148 anchor for socket.__dict__.__contains__ membership checks"
  kind: python_call_eq
  category: identity
  id_prefix: sockmod148

  columns: [id, function, args, expected, description]
  rows:
    - [module_dict_socket,     __dict__.__contains__, ["socket"],      true, "socket.__dict__.__contains__('socket') == True (socket.socket class exported under module name)"]
    - [module_dict_AF_INET,    __dict__.__contains__, ["AF_INET"],     true, "socket.__dict__.__contains__('AF_INET') == True (IPv4 address family constant; AddressFamily IntEnum member)"]
    - [module_dict_gethostname, __dict__.__contains__, ["gethostname"], true, "socket.__dict__.__contains__('gethostname') == True (builtin_function_or_method returning machine host name)"]
    - [module_dict_error,      __dict__.__contains__, ["error"],       true, "socket.__dict__.__contains__('error') == True (alias for OSError; error.__name__ is 'OSError', not 'error')"]

