    - [module_dict_timeout,     __dict__.__contains__, ["timeout"],     true, "socket.__dict__.__contains__('timeout') == True (alias for TimeoutError; a subclass of OSError)"]
    - [module_dict_getaddrinfo, __dict__.__contains__, ["getaddrinfo"], true, "socket.__dict__.__contains__('getaddrinfo') == True (builtin_function_or_method; main name-resolution function)"]
    - [module_dict_AF_INET6,    __dict__.__contains__, ["AF_INET6"],    true, "socket.__dict__.__contains__('AF_INET6') == True (IPv6 address family constant; AddressFamily IntEnum member)"]
    - [module_dict_SOCK_STREAM, __dict__.__contains__, ["SOCK_STREAM"], true, "socket.__dict__.__contains__('SOCK_STREAM') == True (TCP stream socket type; SocketKind IntEnum member)"]

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('family')
# socket.socket.__dict__.__contains__('type')
# socket.socket.__dict__.__contains__('__enter__')
# socket.socket.__dict__.__contains__('__exit__')
#
# Wave 323 theme: socket.socket class __dict__ contains property and context manager entries.
#
# family and type are property descriptors in socket.socket.__dict__ that return the
# socket's address family and type as IntEnum values. __enter__ and __exit__ are
# Python-level functions implementing the context manager protocol. extra147 covers
# other socket.socket.__dict__ entries (accept/makefile/close/__init__/__slots__/etc.);
# no prior socket spec anchors __dict__.__contains__ for family/type/__enter__/__exit__
# as a table under sockmod148. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra148.socket_dict_contains_property_and_ctxmgr:
  description: "socket.socket.__dict__.__contains__('family')==True / __dict__.__contains__('type')==True / __dict__.__contains__('__enter__')==True / __dict__.__contains__('__exit__')==True — family/type are property descriptors returning IntEnum-typed address family and socket type; __enter__/__exit__ implement 'with socket() as s:' context manager protocol; extra147 covers other Python-level method entries; first sockmod148 anchor for family/type/__enter__/__exit__ dict membership"
  kind: python_call_eq
  category: identity
  id_prefix: sockmod148

  columns: [id, function, args, expected, description]
  rows:
    - [socket_dict_family,   socket.__dict__.__contains__, ["family"],    true, "socket.socket.__dict__.__contains__('family') == True (property returning address family as AddressFamily IntEnum)"]
    - [socket_dict_type,     socket.__dict__.__contains__, ["type"],      true, "socket.socket.__dict__.__contains__('type') == True (property returning socket type as SocketKind IntEnum)"]
    - [socket_dict_enter,    socket.__dict__.__contains__, ["__enter__"], true, "socket.socket.__dict__.__contains__('__enter__') == True (Python-level function; returns self for 'with' statement)"]
    - [socket_dict_exit,     socket.__dict__.__contains__, ["__exit__"],  true, "socket.socket.__dict__.__contains__('__exit__') == True (Python-level function; calls self.close() on context exit)"]

# ---------------------------------------------------------------------------
# socket.__dict__.__contains__('socket') — standalone
#
# socket.__dict__.__contains__('socket') is True. The key 'socket' in socket.__dict__
# refers to the socket.socket class — the same 6-char name as the module itself.
# This creates the familiar pattern where 'import socket; socket.socket(...)' uses
# 'socket' for both the module name and the class name. extra144 anchors
# socket.socket.__qualname__.__eq__('socket') (6 chars) and __module__.__eq__('socket');
# extra146 anchors __all__.__contains__('socket'); no prior socket spec anchors
# socket.__dict__.__contains__('socket') as a standalone under sockmod148.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra148.module_dict_contains_socket:
  description: "socket.__dict__.__contains__('socket') == True — 'socket' key maps to the socket.socket class; same 6-char name as the module; creates 'socket.socket(...)' pattern; extra144 anchors socket.socket qualname and module; extra146 anchors __all__.__contains__('socket'); no prior socket spec anchors this as a standalone; first standalone under sockmod148"
  category: identity
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["socket"]
  expected: true

