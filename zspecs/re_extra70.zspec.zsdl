spec: re_extra70
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra69.zspec.zsdl — covers search/compile/match/fullmatch __defaults__.__class__.__name__=='tuple'; search/compile/match __defaults__.__len__()==1; sub/__defaults__.__class__.__name__=='NoneType'; Pattern/__class__.__name__=='type'; Pattern/__name__=='Pattern'; Match/__class__.__name__=='type'; Match/__name__=='Match'; Pattern/__module__.__contains__('re'); Match/__module__.__contains__('re')."
    - "re_extra68.zspec.zsdl — covers re.search/compile/match co_consts/co_nlocals/co_stacksize class name checks; re.error/__bases__[0].__name__=='Exception'; re.error/__mro__.__len__()==4; re.error/__module__=='re'; re.error/__qualname__=='error'."
    - "re_extra67.zspec.zsdl — covers co_varnames/__class__.__name__=='tuple'; co_varnames[0].__eq__('pattern'); co_filename/__contains__('.py'); co_flags/__class__.__name__=='int'."
  notes:
    - "This spec extends re_extra69.zspec.zsdl."
    - "Theme: __kwdefaults__ for re functions and re.Pattern/re.Match extended class identity — __qualname__, __bases__[0].__name__, __mro__.__len__(), __doc__.__class__.__name__."
    - "re.search, re.compile, re.match, re.sub, re.fullmatch are pure Python wrappers (Lib/re/__init__.py). None define keyword-only defaults so __kwdefaults__ is None for all. No prior re spec checks __kwdefaults__ for any re function in rekw70 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.Pattern.__qualname__ == 'Pattern' — Pattern is a top-level C extension type; __qualname__ equals __name__ for non-nested types. No prior re spec checks Pattern.__qualname__ in rekw70 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.Pattern.__bases__[0].__name__ == 'object' — Pattern is a C extension type that inherits directly from object. No prior re spec checks Pattern.__bases__[0].__name__ in rekw70 namespace. Function value contains '[' so it is double-quoted. Novel hierarchy anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.Pattern.__mro__.__len__() == 2 — MRO is [Pattern, object]; 2 entries (C type with direct object inheritance). No prior re spec checks Pattern.__mro__.__len__() in rekw70 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.Match.__qualname__ == 'Match' — Match is a top-level C extension type; __qualname__ equals __name__. No prior re spec checks Match.__qualname__ in rekw70 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.Match.__bases__[0].__name__ == 'object' — Match is a C extension type that inherits directly from object. No prior re spec checks Match.__bases__[0].__name__ in rekw70 namespace. Function value contains '[' so it is double-quoted. Novel hierarchy anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.Match.__mro__.__len__() == 2 — MRO is [Match, object]; 2 entries. No prior re spec checks Match.__mro__.__len__() in rekw70 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.Pattern.__doc__.__class__.__name__ == 'str' — Pattern has a docstring; its type is str. No prior re spec checks Pattern.__doc__.__class__.__name__ in rekw70 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.Match.__doc__.__class__.__name__ == 'str' — Match has a docstring; its type is str. No prior re spec checks Match.__doc__.__class__.__name__ in rekw70 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Table row function values containing '[' must be double-quoted per ZSDL rules."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re functions: __kwdefaults__.__class__.__name__ == 'NoneType'
#
# re.search, re.compile, re.match, re.sub, and re.fullmatch are pure Python
# wrapper functions defined in Lib/re/__init__.py. None of them define
# keyword-only arguments with defaults, so __kwdefaults__ is None for all:
#   search.__kwdefaults__.__class__.__name__    == 'NoneType'
#   compile.__kwdefaults__.__class__.__name__   == 'NoneType'
#   match.__kwdefaults__.__class__.__name__     == 'NoneType'
#   sub.__kwdefaults__.__class__.__name__       == 'NoneType'
#   fullmatch.__kwdefaults__.__class__.__name__ == 'NoneType'
#
# No prior re spec checks __kwdefaults__ for any re function in rekw70
# namespace. Novel __kwdefaults__ anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra70.none_kwdefaults:
  description: "search/compile/match/sub/fullmatch __kwdefaults__.__class__.__name__=='NoneType' — none of the re wrapper functions define keyword-only defaults; __kwdefaults__ is None; None.__class__.__name__ is 'NoneType'; no prior re spec checks __kwdefaults__ for any re function in rekw70 namespace; novel __kwdefaults__ anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_kwdefaults
  id_prefix: rekw70none

  columns: [id, function, args, expected]
  rows:
    - [search_kwdefaults,    search.__kwdefaults__.__class__.__name__.__eq__,    ["NoneType"], true]
    - [compile_kwdefaults,   compile.__kwdefaults__.__class__.__name__.__eq__,   ["NoneType"], true]
    - [match_kwdefaults,     match.__kwdefaults__.__class__.__name__.__eq__,     ["NoneType"], true]
    - [sub_kwdefaults,       sub.__kwdefaults__.__class__.__name__.__eq__,       ["NoneType"], true]
    - [fullmatch_kwdefaults, fullmatch.__kwdefaults__.__class__.__name__.__eq__, ["NoneType"], true]

# ---------------------------------------------------------------------------
# re.Pattern extended identity: __qualname__, __bases__[0].__name__, __mro__.__len__()
#
# re.Pattern is a C extension type. It inherits directly from object:
#   Pattern.__qualname__           == 'Pattern'
#   Pattern.__bases__[0].__name__  == 'object'
#   Pattern.__mro__.__len__()      == 2   ([Pattern, object])
#
# Function value for __bases__[0].__name__ contains '[' — must be double-quoted.
# No prior re spec checks Pattern.__qualname__, __bases__[0].__name__, or
# __mro__.__len__() in rekw70 namespace. Novel extended identity anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra70.Pattern_extended_identity:
  description: "Pattern/__qualname__=='Pattern'; Pattern/__bases__[0].__name__=='object'; Pattern/__mro__.__len__()==2 — re.Pattern is a C extension type that inherits directly from object; __qualname__ equals __name__ for non-nested types; MRO is [Pattern, object] with 2 entries; no prior re spec checks these in rekw70 namespace; function value with '[' is double-quoted; novel extended identity anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: rekw70pattern

  columns: [id, function, args, expected]
  rows:
    - [pattern_qualname,       Pattern.__qualname__.__eq__,                    ["Pattern"], true]
    - [pattern_bases_object,   "Pattern.__bases__[0].__name__.__eq__",         ["object"],  true]
    - [pattern_mro_len_2,      Pattern.__mro__.__len__,                        [],          2]

# ---------------------------------------------------------------------------
# re.Match extended identity: __qualname__, __bases__[0].__name__, __mro__.__len__()
#
# re.Match is a C extension type. It inherits directly from object:
#   Match.__qualname__           == 'Match'
#   Match.__bases__[0].__name__  == 'object'
#   Match.__mro__.__len__()      == 2   ([Match, object])
#
# Function value for __bases__[0].__name__ contains '[' — must be double-quoted.
# No prior re spec checks Match.__qualname__, __bases__[0].__name__, or
# __mro__.__len__() in rekw70 namespace. Novel extended identity anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra70.Match_extended_identity:
  description: "Match/__qualname__=='Match'; Match/__bases__[0].__name__=='object'; Match/__mro__.__len__()==2 — re.Match is a C extension type that inherits directly from object; __qualname__ equals __name__ for non-nested types; MRO is [Match, object] with 2 entries; no prior re spec checks these in rekw70 namespace; function value with '[' is double-quoted; novel extended identity anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: rekw70match

  columns: [id, function, args, expected]
  rows:
    - [match_qualname,       Match.__qualname__.__eq__,                    ["Match"],  true]
    - [match_bases_object,   "Match.__bases__[0].__name__.__eq__",         ["object"], true]
    - [match_mro_len_2,      Match.__mro__.__len__,                        [],         2]

# ---------------------------------------------------------------------------
# re.Pattern and re.Match doc class: __doc__.__class__.__name__ == 'str'
#
# Both Pattern and Match are C extension types that have docstrings. The
# docstring type is always str:
#   Pattern.__doc__.__class__.__name__ == 'str'
#   Match.__doc__.__class__.__name__   == 'str'
#
# No prior re spec checks Pattern.__doc__.__class__.__name__ or
# Match.__doc__.__class__.__name__ in rekw70 namespace.
# Novel doc class anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra70.Pattern_Match_doc_class:
  description: "Pattern/__doc__.__class__.__name__=='str'; Match/__doc__.__class__.__name__=='str' — re.Pattern and re.Match are C extension types that both have string docstrings; __doc__.__class__.__name__ is 'str' for both; no prior re spec checks Pattern/__doc__ or Match/__doc__ class name in rekw70 namespace; novel doc class anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: rekw70doc

  columns: [id, function, args, expected]
  rows:
    - [pattern_doc_str,  Pattern.__doc__.__class__.__name__.__eq__,  ["str"], true]
    - [match_doc_str,    Match.__doc__.__class__.__name__.__eq__,    ["str"], true]

invariant re_extra70.search_kwdefaults_NoneType:
  description: "search.__kwdefaults__.__class__.__name__.__eq__('NoneType') == True — re.search is a pure Python wrapper function with no keyword-only defaults; __kwdefaults__ is None; None.__class__.__name__ is 'NoneType'; no prior re spec checks search.__kwdefaults__.__class__.__name__ in rekw70 namespace; novel __kwdefaults__ class-name anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_kwdefaults
  kind: python_call_eq
  function: search.__kwdefaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant re_extra70.Pattern_qualname_Pattern:
  description: "Pattern.__qualname__.__eq__('Pattern') == True — re.Pattern is a top-level C extension type; __qualname__ equals __name__ for non-nested types; __qualname__ is 'Pattern'; no prior re spec checks Pattern.__qualname__ in rekw70 namespace; novel qualname anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__qualname__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra70.Pattern_bases_object:
  description: "Pattern.__bases__[0].__name__.__eq__('object') == True — re.Pattern is a C extension type that inherits directly from object; __bases__[0] is object; object.__name__ is 'object'; no prior re spec checks Pattern.__bases__[0].__name__ in rekw70 namespace; novel hierarchy anchor; function value contains '[' so it is double-quoted; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: "Pattern.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant re_extra70.Pattern_mro_2:
  description: "Pattern.__mro__.__len__() == 2 — re.Pattern is a C extension type that inherits directly from object; its MRO is [Pattern, object] with exactly 2 entries; no prior re spec checks Pattern.__mro__.__len__() in rekw70 namespace; novel MRO length anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__mro__.__len__
  args: []
  expected: 2

invariant re_extra70.Match_mro_2:
  description: "Match.__mro__.__len__() == 2 — re.Match is a C extension type that inherits directly from object; its MRO is [Match, object] with exactly 2 entries; no prior re spec checks Match.__mro__.__len__() in rekw70 namespace; novel MRO length anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Match.__mro__.__len__
  args: []
  expected: 2
