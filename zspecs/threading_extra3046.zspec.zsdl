spec: th3046
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 650 (th3046): __enter__, __exit__, __aenter__ dict-presence checks for threading types."
    - "type(threading.Lock()) defines __enter__ and __exit__ (context manager protocol); __aenter__ is absent."
    - "type(threading.RLock()) defines __enter__ and __exit__ (context manager protocol); __aenter__ is absent."
    - "threading.Condition defines __enter__ and __exit__ (context manager protocol); __aenter__ is absent."
    - "threading.Semaphore defines __enter__ and __exit__ (context manager protocol); __aenter__ is absent."
    - "threading.Thread, threading.Event, threading.BoundedSemaphore, threading.Timer, threading.Barrier, threading.local do not define __enter__, __exit__, or __aenter__ in their own __dict__."
    - "threading.Lock() returns a _thread.lock instance; type(threading.Lock()) is used to access its __dict__."
    - "threading.RLock() returns a _thread.RLock instance; type(threading.RLock()) is used to access its __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th3046.enter:
  description: "threading types __enter__ dict-presence checks; wave 650"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th3046
  columns: [id, function, args, expected]
  rows:
    - ["th3046001", operator.contains, [threading.Thread.__dict__,            "__enter__"], false]
    - ["th3046002", operator.contains, [type(threading.Lock()).__dict__,      "__enter__"], true]
    - ["th3046003", operator.contains, [type(threading.RLock()).__dict__,     "__enter__"], true]
    - ["th3046004", operator.contains, [threading.Event.__dict__,             "__enter__"], false]
    - ["th3046005", operator.contains, [threading.Condition.__dict__,         "__enter__"], true]
    - ["th3046006", operator.contains, [threading.Semaphore.__dict__,         "__enter__"], true]
    - ["th3046007", operator.contains, [threading.BoundedSemaphore.__dict__,  "__enter__"], false]
    - ["th3046008", operator.contains, [threading.Timer.__dict__,             "__enter__"], false]
    - ["th3046009", operator.contains, [threading.Barrier.__dict__,           "__enter__"], false]
    - ["th3046010", operator.contains, [threading.local.__dict__,             "__enter__"], false]

