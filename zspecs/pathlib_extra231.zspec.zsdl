spec: pathlib_extra231
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path and PurePath class __doc__ string contains checks, and Path method __doc__ string contains checks."
    - "pathlib.Path.__doc__.__contains__('path') == True — Path doc contains 'path' (lowercase) in 'Path represents a filesystem path'; verified with Python 3.14.3."
    - "pathlib.PurePath.__doc__.__contains__('path') == True — PurePath doc contains 'path' (lowercase) in 'PurePath represents a filesystem path'; verified with Python 3.14.3."
    - "pathlib.Path.is_absolute.__doc__.__contains__('absolute') == True — is_absolute doc is 'True if the path is absolute (has both a root and, if applicable, a drive).'; verified with Python 3.14.3."
    - "pathlib.Path.is_file.__doc__.__contains__('file') == True — is_file doc contains 'regular file'; verified with Python 3.14.3."
    - "pathlib.Path.is_dir.__doc__.__contains__('director') == True — is_dir doc is 'Whether this path is a directory.'; 'director' is a substring of 'directory'; verified with Python 3.14.3."
    - "pathlib.Path.exists.__doc__.__contains__('exist') == True — exists doc starts 'Whether this path exists.'; verified with Python 3.14.3."
    - "pathlib.Path.stat.__doc__.__contains__('stat') == True — stat doc starts 'Return the result of the stat() system call on this path'; verified with Python 3.14.3."
    - "pathlib.Path.resolve.__doc__.__contains__('resolv') == True — resolve doc starts 'Make the path absolute, resolving all symlinks'; 'resolv' is a substring of 'resolving'; verified with Python 3.14.3."
    - "pathlib.Path.mkdir.__doc__.__contains__('director') == True — mkdir doc is 'Create a new directory at this given path.'; 'director' is a substring of 'directory'; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib class-level __doc__ contains checks
# Path.__doc__ and PurePath.__doc__ both contain 'path'.
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table pathlib_extra231.class_doc_contains:
  description: "pathlib.Path and PurePath __doc__ string contains 'path'; verified with Python 3.14.3"
  kind: python_call_eq
  category: docstring
  id_prefix: pldoccontains231a

  columns: [id, function, args, expected]
  rows:
    - [path_doc_path,      "Path.__doc__.__contains__",      ["path"], true]
    - [purepath_doc_path,  "PurePath.__doc__.__contains__",  ["path"], true]

# ---------------------------------------------------------------------------
# pathlib.Path method __doc__ contains checks
# is_absolute->absolute, is_file->file, is_dir->director, exists->exist,
# stat->stat, resolve->resolv, mkdir->director
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table pathlib_extra231.method_doc_contains:
  description: "pathlib.Path method __doc__ string contains checks for is_absolute, is_file, is_dir, exists, stat, resolve, mkdir; verified with Python 3.14.3"
  kind: python_call_eq
  category: docstring
  id_prefix: pldoccontains231b

  columns: [id, function, args, expected]
  rows:
    - [is_absolute_doc_absolute, "Path.is_absolute.__doc__.__contains__", ["absolute"],  true]
    - [is_file_doc_file,         "Path.is_file.__doc__.__contains__",     ["file"],      true]
    - [is_dir_doc_director,      "Path.is_dir.__doc__.__contains__",      ["director"],  true]
    - [exists_doc_exist,         "Path.exists.__doc__.__contains__",      ["exist"],     true]
    - [stat_doc_stat,            "Path.stat.__doc__.__contains__",        ["stat"],      true]
    - [resolve_doc_resolv,       "Path.resolve.__doc__.__contains__",     ["resolv"],    true]
    - [mkdir_doc_director,       "Path.mkdir.__doc__.__contains__",       ["director"],  true]

# ---------------------------------------------------------------------------
# Standalone invariants
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

invariant pathlib_extra231.Path.doc_contains_path:
  description: "pathlib.Path.__doc__.__contains__('path') == True — Path doc is 'PurePath subclass that can make system calls. Path represents a filesystem path...'; 'path' appears in second sentence; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: Path.__doc__.__contains__
  args: ["path"]
  expected: true

invariant pathlib_extra231.PurePath.doc_contains_path:
  description: "pathlib.PurePath.__doc__.__contains__('path') == True — PurePath doc is 'Base class for manipulating paths without I/O. PurePath represents a filesystem path...'; 'path' appears in 'paths' and 'path'; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: PurePath.__doc__.__contains__
  args: ["path"]
  expected: true

invariant pathlib_extra231.Path.is_absolute_doc_contains_absolute:
  description: "pathlib.Path.is_absolute.__doc__.__contains__('absolute') == True — is_absolute doc is 'True if the path is absolute (has both a root and, if applicable, a drive).'; 'absolute' appears immediately; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: Path.is_absolute.__doc__.__contains__
  args: ["absolute"]
  expected: true

invariant pathlib_extra231.Path.is_file_doc_contains_file:
  description: "pathlib.Path.is_file.__doc__.__contains__('file') == True — is_file doc contains 'regular file'; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: Path.is_file.__doc__.__contains__
  args: ["file"]
  expected: true

invariant pathlib_extra231.Path.is_dir_doc_contains_director:
  description: "pathlib.Path.is_dir.__doc__.__contains__('director') == True — is_dir doc is 'Whether this path is a directory.'; 'director' is a substring of 'directory'; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: Path.is_dir.__doc__.__contains__
  args: ["director"]
  expected: true

invariant pathlib_extra231.Path.exists_doc_contains_exist:
  description: "pathlib.Path.exists.__doc__.__contains__('exist') == True — exists doc starts 'Whether this path exists.'; 'exist' is a substring of 'exists'; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: Path.exists.__doc__.__contains__
  args: ["exist"]
  expected: true

invariant pathlib_extra231.Path.stat_doc_contains_stat:
  description: "pathlib.Path.stat.__doc__.__contains__('stat') == True — stat doc starts 'Return the result of the stat() system call on this path, like os.stat() does.'; 'stat' appears in 'stat()'; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: Path.stat.__doc__.__contains__
  args: ["stat"]
  expected: true

invariant pathlib_extra231.Path.resolve_doc_contains_resolv:
  description: "pathlib.Path.resolve.__doc__.__contains__('resolv') == True — resolve doc starts 'Make the path absolute, resolving all symlinks on the way and also normalizing it.'; 'resolv' is a substring of 'resolving'; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: Path.resolve.__doc__.__contains__
  args: ["resolv"]
  expected: true

invariant pathlib_extra231.Path.mkdir_doc_contains_director:
  description: "pathlib.Path.mkdir.__doc__.__contains__('director') == True — mkdir doc is 'Create a new directory at this given path.'; 'director' is a substring of 'directory'; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: Path.mkdir.__doc__.__contains__
  args: ["director"]
  expected: true
