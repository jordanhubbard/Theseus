spec: abc_extra1411
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc: Abstract Base Classes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py, Modules/_abc.c"
  notes:
    - "Wave 541 (_extra1411): focuses on __sizeof__ method type and presence, plus __reduce_ex__ checks for abc module classes."
    - "abc.ABCMeta and abc.ABC have __sizeof__ with type 'method_descriptor' (inherited from object/type hierarchy)."
    - "abc.abstractmethod (a function decorator class) has __sizeof__ with type 'builtin_function_or_method'."
    - "abc.ABCMeta and abc.ABC have __reduce_ex__ with type 'method_descriptor'."
    - "abc.abstractmethod has __reduce_ex__ with type 'builtin_function_or_method'."
    - "None of ABCMeta, ABC, or abstractmethod define __sizeof__ or __reduce_ex__ in their own __dict__."
    - "abc.ABCMeta.__sizeof__.__class__.__name__ == 'method_descriptor'; '__sizeof__' not in abc.ABCMeta.__dict__."
    - "abc.ABC.__sizeof__.__class__.__name__ == 'method_descriptor'; '__sizeof__' not in abc.ABC.__dict__."
    - "abc.abstractmethod.__sizeof__.__class__.__name__ == 'builtin_function_or_method'; '__sizeof__' not in abc.abstractmethod.__dict__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table abc_extra1411.sizeof_class_name:
  description: "abc class __sizeof__.__class__.__name__ identity checks — ABCMeta and ABC have 'method_descriptor' (inherited via type/object); abstractmethod has 'builtin_function_or_method' (it is implemented in C as a type); none define __sizeof__ in their own __dict__; verified with Python 3.14.3"
  kind: python_call_eq
  category: sizeof_class_name
  id_prefix: ab1411sz
  columns: [id, function, args, expected]
  rows:
    - [ab1411sz001, abc.ABCMeta.__sizeof__.__class__.__name__.__eq__,       ["method_descriptor"],       true]
    - [ab1411sz002, abc.ABC.__sizeof__.__class__.__name__.__eq__,            ["method_descriptor"],       true]
    - [ab1411sz003, abc.abstractmethod.__sizeof__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [ab1411sz004, abc.ABCMeta.__sizeof__.__class__.__name__.__eq__,       ["method_descriptor"],       true]
    - [ab1411sz005, abc.ABC.__sizeof__.__class__.__name__.__eq__,            ["method_descriptor"],       true]
    - [ab1411sz006, abc.abstractmethod.__sizeof__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

table abc_extra1411.sizeof_not_in_dict:
  description: "abc class __sizeof__ absence from own __dict__ — ABCMeta, ABC, and abstractmethod do not define __sizeof__ in their own __dict__; all inherit it; __dict__.__contains__('__sizeof__') is False for each; verified with Python 3.14.3"
  kind: python_call_eq
  category: sizeof_dict_membership
  id_prefix: ab1411sd
  columns: [id, function, args, expected]
  rows:
    - [ab1411sd001, abc.ABCMeta.__dict__.__contains__,       ["__sizeof__"],    false]
    - [ab1411sd002, abc.ABC.__dict__.__contains__,            ["__sizeof__"],    false]
    - [ab1411sd003, abc.abstractmethod.__dict__.__contains__, ["__sizeof__"],    false]
    - [ab1411sd004, abc.ABCMeta.__dict__.__contains__,       ["__reduce_ex__"], false]
    - [ab1411sd005, abc.ABC.__dict__.__contains__,            ["__reduce_ex__"], false]
    - [ab1411sd006, abc.abstractmethod.__dict__.__contains__, ["__reduce_ex__"], false]

table abc_extra1411.reduce_ex_class_name:
  description: "abc class __reduce_ex__.__class__.__name__ identity checks — ABCMeta and ABC have 'method_descriptor'; abstractmethod has 'builtin_function_or_method'; none define __reduce_ex__ in their own __dict__; verified with Python 3.14.3"
  kind: python_call_eq
  category: reduce_ex_class_name
  id_prefix: ab1411rx
  columns: [id, function, args, expected]
  rows:
    - [ab1411rx001, abc.ABCMeta.__reduce_ex__.__class__.__name__.__eq__,       ["method_descriptor"],       true]
    - [ab1411rx002, abc.ABC.__reduce_ex__.__class__.__name__.__eq__,            ["method_descriptor"],       true]
    - [ab1411rx003, abc.abstractmethod.__reduce_ex__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [ab1411rx004, abc.ABCMeta.__reduce_ex__.__class__.__name__.__eq__,       ["method_descriptor"],       true]
    - [ab1411rx005, abc.ABC.__reduce_ex__.__class__.__name__.__eq__,            ["method_descriptor"],       true]
    - [ab1411rx006, abc.abstractmethod.__reduce_ex__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
