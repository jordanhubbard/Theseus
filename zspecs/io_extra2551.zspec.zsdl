    - ["io2551006", "io.StringIO.__dict__.__contains__",       ["__reduce__"], false]
    - ["io2551007", "io.FileIO.__dict__.__contains__",         ["__reduce__"], false]
    - ["io2551008", "io.BufferedReader.__dict__.__contains__", ["__reduce__"], false]
    - ["io2551009", "io.BufferedWriter.__dict__.__contains__", ["__reduce__"], false]
    - ["io2551010", "io.BufferedRandom.__dict__.__contains__", ["__reduce__"], false]

