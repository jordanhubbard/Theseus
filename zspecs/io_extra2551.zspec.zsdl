spec: io_extra2551
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2551 (_extra2551): __reduce__, __reduce_ex__, __getnewargs__ dict-presence checks for io classes."
    - "io.BytesIO and io.StringIO define __getstate__/__setstate__ but NOT __reduce__, __reduce_ex__, or __getnewargs__."
    - "io.FileIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom define __getstate__ but not __reduce__/__reduce_ex__/__getnewargs__."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase define none of these pickling methods."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

table io_extra2551.reduce_protocol:
  description: "io stream classes __reduce__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2551

  columns: [id, function, args, expected]
  rows:
    - ["io2551001", "io.IOBase.__dict__.__contains__",         ["__reduce__"], false]
