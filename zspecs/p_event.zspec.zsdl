spec: p_event
version: ">=6.0.0"
backend: node(p-event)
esm: true

docs: https://github.com/sindresorhus/p-event#readme

provenance:
  derived_from:
    - "p-event README — https://github.com/sindresorhus/p-event#readme"
    - "Test vectors verified with p-event via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "p-event source"
  notes:
    - "Promise-ify EventEmitter events — await the next emit, an iterator over emits, or N emits."
    - "Install: npm install p-event"
    - "v6 ESM only; named exports pEvent / pEventIterator / pEventMultiple / TimeoutError."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws TimeoutError when timeout option fires; rejects on 'error' events unless filtered out."
  stderr: "null"
  stickiness: "Each call subscribes a listener for the lifetime of the wait."
  codes:
    TimeoutError: "Promise timeout exceeded"

invariant p_event.has_pEvent:
  description: "pEvent() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "pEvent.constructor.name"}
  expected: "Function"

invariant p_event.has_pEventIterator:
  description: "pEventIterator() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "pEventIterator.constructor.name"}
  expected: "Function"

invariant p_event.has_pEventMultiple:
  description: "pEventMultiple() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "pEventMultiple.constructor.name"}
  expected: "Function"

invariant p_event.has_TimeoutError:
  description: "TimeoutError class exposed"
  category: errors
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "TimeoutError.constructor.name"}
  expected: "Function"

invariant p_event.TimeoutError_name:
  description: "TimeoutError.name is 'TimeoutError'"
  category: errors
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "TimeoutError.name"}
  expected: "TimeoutError"

invariant p_event.pEvent_name:
  description: "pEvent function name is 'pEvent'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "pEvent.name"}
  expected: "pEvent"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:19:20Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
