spec: prime_number
version: ">=2.0.0"
backend: node(prime-number)

docs: https://www.npmjs.com/package/prime-number

provenance:
  derived_from:
    - "prime-number README — https://www.npmjs.com/package/prime-number"
    - "Test vectors verified with prime-number via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "prime-number source"
  notes:
    - "prime-number is an npm package. Install: npm install prime-number"
    - "Returns true if the number is prime."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table prime_number.isPrime:
  kind: node_module_call_eq
  function: ~
  category: predicate
  id_prefix: primnum

  columns: [id, args, expected]
  rows:
    - [prime_7,     [7],   true]
    - [prime_13,    [13],  true]
    - [not_prime_4, [4],   false]
    - [not_prime_9, [9],   false]
