spec: scipy_linalg_rust
version: ">=3.9"
backend: rust_module(scipy_linalg_rust)

docs: https://docs.scipy.org/doc/scipy/reference/linalg.html

provenance:
  derived_from:
    - "https://docs.scipy.org/doc/scipy/reference/linalg.html — SciPy linear algebra"
  not_derived_from:
    - "scipy source: scipy/linalg/_basic.py"
  notes:
    - "SciPy provides linear algebra routines."
    - "scipy.linalg.det([[1,2],[3,4]]) == -2.0."
    - "scipy.linalg.det([[1,0],[0,1]]) == 1.0 — identity matrix."
    - "scipy.linalg.norm([3,4]) == 5.0 — Euclidean norm."
    - "scipy.linalg.norm([0,0]) == 0.0."
    - "scipy.linalg.norm([1,0]) == 1.0."
    - "scipy.linalg.inv([[2,0],[0,2]])[0][0] == 0.5."
    - "Expose linalg_det(matrix) -> float: scipy.linalg.det(matrix)."
    - "Expose linalg_norm(vec) -> float: scipy.linalg.norm(vec)."
    - "Expose linalg_inv_elem(matrix, i, j) -> float: scipy.linalg.inv(matrix)[i][j]."
    - "All test vectors verified against scipy 1.15.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# linalg_det — matrix determinant
table scipy_linalg_rust.det.vectors:
  kind: python_call_eq
  category: det
  id_prefix: sl_det
  function: linalg_det

  columns: [id, args, expected]
  rows:
    - [identity,   [[[1, 0], [0, 1]]],   1.0]
    - [simple,     [[[1, 2], [3, 4]]],  -2.0]
    - [two_by_two, [[[2, 0], [0, 3]]],   6.0]

# linalg_norm — Euclidean norm
table scipy_linalg_rust.norm.vectors:
  kind: python_call_eq
  category: norm
  id_prefix: sl_norm
  function: linalg_norm

  columns: [id, args, expected]
  rows:
    - [zero,      [[0, 0]],  0.0]
    - [unit,      [[1, 0]],  1.0]
    - [three_four, [[3, 4]], 5.0]

# linalg_inv_elem — matrix inverse element
invariant scipy_linalg_rust.inv.diag_half:
  description: "inv([[2,0],[0,2]])[0][0] == 0.5"
  category: inv
  kind: python_call_eq
  function: linalg_inv_elem
  args: [[[2, 0], [0, 2]], 0, 0]
  expected: 0.5

invariant scipy_linalg_rust.inv.identity:
  description: "inv([[1,0],[0,1]])[0][0] == 1.0"
  category: inv
  kind: python_call_eq
  function: linalg_inv_elem
  args: [[[1, 0], [0, 1]], 0, 0]
  expected: 1.0

