spec: theseus_tempfile_cr
version: ">=3.8"
backend: python_cleanroom(theseus_tempfile_cr)
blocks: tempfile

docs: https://docs.python.org/3/library/tempfile.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/tempfile.html"
  not_derived_from:
    - "CPython source: Lib/tempfile.py"
  notes:
    - "Clean-room tempfile module. Do NOT import tempfile."

error_model: python_exceptions

invariant theseus_tempfile_cr.tempfile2_mkstemp:
  description: "mkstemp creates a temporary file"
  category: behavior
  kind: python_call_eq
  function: tempfile2_mkstemp
  args: []
  expected: true

invariant theseus_tempfile_cr.tempfile2_mkdtemp:
  description: "mkdtemp creates a temporary directory"
  category: behavior
  kind: python_call_eq
  function: tempfile2_mkdtemp
  args: []
  expected: true

invariant theseus_tempfile_cr.tempfile2_named:
  description: "NamedTemporaryFile creates and auto-deletes a temp file"
  category: behavior
  kind: python_call_eq
  function: tempfile2_named
  args: []
  expected: true
