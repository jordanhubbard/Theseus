spec: html_entities_rust
version: ">=3.9"
backend: rust_module(html_entities_rust)

docs: https://docs.python.org/3/library/html.entities.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/html.entities.html — Python html.entities documentation"
    - "HTML 5 specification — named character references"
  not_derived_from:
    - "CPython source: Lib/html/entities.py"
  notes:
    - "Clean-room Rust reimplementation of Python html.entities module, exposed via PyO3."
    - "name2codepoint is a dict mapping HTML entity names (str) to Unicode codepoints (int)."
    - "name2codepoint['amp'] == 38 (U+0026 AMPERSAND)."
    - "name2codepoint['lt'] == 60 (U+003C LESS-THAN SIGN)."
    - "name2codepoint['gt'] == 62 (U+003E GREATER-THAN SIGN)."
    - "name2codepoint['quot'] == 34 (U+0022 QUOTATION MARK)."
    - "name2codepoint['nbsp'] == 160 (U+00A0 NO-BREAK SPACE)."
    - "codepoint2name is the inverse dict mapping codepoints (int) to entity names (str)."
    - "codepoint2name[38] == 'amp', codepoint2name[60] == 'lt'."
    - "'apos' is NOT in name2codepoint (it is in html5 but not name2codepoint)."
    - "All test vectors verified against Python 3.14.3 html.entities module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# name2codepoint — entity name to codepoint integer
table html_entities_rust.name2codepoint.lookup:
  kind: python_call_eq
  category: name2codepoint
  id_prefix: n2cp
  function: name2codepoint.__getitem__

  columns: [id, args, expected]
  rows:
    - [amp,   ["amp"],   38]
    - [lt,    ["lt"],    60]
    - [gt,    ["gt"],    62]
    - [quot,  ["quot"],  34]
    - [nbsp,  ["nbsp"],  160]
    - [copy,  ["copy"],  169]
    - [reg,   ["reg"],   174]

# name2codepoint — __contains__ checks
table html_entities_rust.name2codepoint.contains:
  kind: python_call_eq
  category: name2codepoint
  id_prefix: n2cp_has
  function: name2codepoint.__contains__

  columns: [id, args, expected]
  rows:
    - [has_amp,    ["amp"],   true]
    - [has_lt,     ["lt"],    true]
    - [miss_apos,  ["apos"],  false]
    - [miss_bogus, ["bogus"], false]

# codepoint2name — codepoint integer to entity name
table html_entities_rust.codepoint2name.lookup:
  kind: python_call_eq
  category: codepoint2name
  id_prefix: cp2n
  function: codepoint2name.__getitem__

  columns: [id, args, expected]
  rows:
    - [amp,  [38],  "amp"]
    - [lt,   [60],  "lt"]
    - [gt,   [62],  "gt"]
    - [quot, [34],  "quot"]
    - [nbsp, [160], "nbsp"]

# codepoint2name — __contains__ checks
table html_entities_rust.codepoint2name.contains:
  kind: python_call_eq
  category: codepoint2name
  id_prefix: cp2n_has
  function: codepoint2name.__contains__

  columns: [id, args, expected]
  rows:
    - [has_amp,  [38],  true]
    - [has_lt,   [60],  true]
    - [miss_999, [999], false]

