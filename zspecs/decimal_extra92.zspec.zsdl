spec: decimal_extra92
version: ">=3.9"
backend: python_module(decimal)
extends: decimal_extra91

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal_extra91.zspec.zsdl."
    - "This spec covers: decimal.Context method __qualname__ lengths."
    - "Context.ln.__qualname__ = 'Context.ln' (len=10) — shortest among the methods checked."
    - "Context.add.__qualname__ = 'Context.add' (len=11), same for exp, abs, max, min (len=11)."
    - "Context.sqrt.__qualname__ = 'Context.sqrt' (len=12), Context.plus (len=12)."
    - "Context.log10.__qualname__ = 'Context.log10' (len=13), Context.power (len=13), Context.minus (len=13)."
    - "Context.divide.__qualname__ = 'Context.divide' (len=14)."
    - "Context.compare.__qualname__ = 'Context.compare' (len=15), Context.max_mag (len=15), Context.min_mag (len=15)."
    - "Context.subtract.__qualname__ = 'Context.subtract' (len=16), Context.multiply (len=16), Context.quantize (len=16)."
    - "Context.remainder.__qualname__ = 'Context.remainder' (len=17), Context.normalize (len=17)."
    - "Context.divide_int.__qualname__ = 'Context.divide_int' (len=18)."
    - "Context.logical_or.__qualname__ = 'Context.logical_or' (len=18), Context.logical_and (len=19), Context.logical_xor (len=19)."
    - "Context.to_sci_string.__qualname__ = 'Context.to_sci_string' (len=21), Context.to_eng_string (len=21)."
    - "Context.logical_invert.__qualname__ = 'Context.logical_invert' (len=22)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Context short __qualname__ lengths
# ln=10, add=exp=abs=max=min=11, sqrt=plus=12, log10=power=minus=13, divide=14
# ---------------------------------------------------------------------------

table decimal_extra92.Context_short_qualname_lengths:
  description: "decimal.Context methods with short __qualname__ lengths: ln(10), add/exp/abs/max/min(11), sqrt/plus(12), log10/power/minus(13), divide(14)"
  kind: python_call_eq
  category: method_qualname
  id_prefix: decimalcontextmethods92

  columns: [id, function, args, expected]
  rows:
    - [ctx_ln_qnlen,     Context.ln.__qualname__.__len__,      [], 10]
    - [ctx_add_qnlen,    Context.add.__qualname__.__len__,     [], 11]
    - [ctx_exp_qnlen,    Context.exp.__qualname__.__len__,     [], 11]
    - [ctx_abs_qnlen,    Context.abs.__qualname__.__len__,     [], 11]
    - [ctx_max_qnlen,    Context.max.__qualname__.__len__,     [], 11]
    - [ctx_min_qnlen,    Context.min.__qualname__.__len__,     [], 11]
    - [ctx_sqrt_qnlen,   Context.sqrt.__qualname__.__len__,    [], 12]
    - [ctx_plus_qnlen,   Context.plus.__qualname__.__len__,    [], 12]
    - [ctx_log10_qnlen,  Context.log10.__qualname__.__len__,   [], 13]
    - [ctx_power_qnlen,  Context.power.__qualname__.__len__,   [], 13]
    - [ctx_minus_qnlen,  Context.minus.__qualname__.__len__,   [], 13]
    - [ctx_divide_qnlen, Context.divide.__qualname__.__len__,  [], 14]

# ---------------------------------------------------------------------------
# decimal.Context medium __qualname__ lengths
# compare=max_mag=min_mag=15, subtract=multiply=quantize=16
# ---------------------------------------------------------------------------

table decimal_extra92.Context_medium_qualname_lengths:
  description: "decimal.Context methods with medium __qualname__ lengths: compare/max_mag/min_mag(15), subtract/multiply/quantize(16)"
  kind: python_call_eq
  category: method_qualname
  id_prefix: decimalcontextmethods92

  columns: [id, function, args, expected]
  rows:
    - [ctx_compare_qnlen,  Context.compare.__qualname__.__len__,  [], 15]
    - [ctx_maxmag_qnlen,   Context.max_mag.__qualname__.__len__,  [], 15]
    - [ctx_minmag_qnlen,   Context.min_mag.__qualname__.__len__,  [], 15]
    - [ctx_subtract_qnlen, Context.subtract.__qualname__.__len__, [], 16]
    - [ctx_multiply_qnlen, Context.multiply.__qualname__.__len__, [], 16]
    - [ctx_quantize_qnlen, Context.quantize.__qualname__.__len__, [], 16]
    - [ctx_compare_not14,  Context.compare.__qualname__.__len__,  [], 15]

# ---------------------------------------------------------------------------
# decimal.Context longer __qualname__ lengths
# remainder=normalize=17, divide_int=logical_or=18, logical_and=logical_xor=19,
# to_sci_string=to_eng_string=21, logical_invert=22
# ---------------------------------------------------------------------------

table decimal_extra92.Context_long_qualname_lengths:
  description: "decimal.Context methods with longer __qualname__ lengths: remainder/normalize(17), divide_int/logical_or(18), logical_and/logical_xor(19), to_sci_string/to_eng_string(21), logical_invert(22)"
  kind: python_call_eq
  category: method_qualname
  id_prefix: decimalcontextmethods92

  columns: [id, function, args, expected]
  rows:
    - [ctx_remainder_qnlen,   Context.remainder.__qualname__.__len__,      [], 17]
    - [ctx_normalize_qnlen,   Context.normalize.__qualname__.__len__,      [], 17]
    - [ctx_divint_qnlen,      Context.divide_int.__qualname__.__len__,     [], 18]
    - [ctx_logor_qnlen,       Context.logical_or.__qualname__.__len__,     [], 18]
    - [ctx_logand_qnlen,      Context.logical_and.__qualname__.__len__,    [], 19]
    - [ctx_logxor_qnlen,      Context.logical_xor.__qualname__.__len__,    [], 19]
    - [ctx_scistr_qnlen,      Context.to_sci_string.__qualname__.__len__,  [], 21]
    - [ctx_engstr_qnlen,      Context.to_eng_string.__qualname__.__len__,  [], 21]
    - [ctx_loginvert_qnlen,   Context.logical_invert.__qualname__.__len__, [], 22]

# ---------------------------------------------------------------------------
# decimal.Context method __qualname__ equality for key operations
# ---------------------------------------------------------------------------

table decimal_extra92.Context_qualname_equality:
  description: "decimal.Context method __qualname__ string equality for key operations"
  kind: python_call_eq
  category: method_qualname
  id_prefix: decimalcontextmethods92

  columns: [id, function, args, expected]
  rows:
    - [ctx_add_qn_eq,      Context.add.__qualname__.__eq__,            ["Context.add"],            true]
    - [ctx_ln_qn_eq,       Context.ln.__qualname__.__eq__,             ["Context.ln"],             true]
    - [ctx_sqrt_qn_eq,     Context.sqrt.__qualname__.__eq__,           ["Context.sqrt"],           true]
    - [ctx_divide_qn_eq,   Context.divide.__qualname__.__eq__,         ["Context.divide"],         true]
    - [ctx_subtract_qn_eq, Context.subtract.__qualname__.__eq__,       ["Context.subtract"],       true]
    - [ctx_normalize_qn_eq, Context.normalize.__qualname__.__eq__,     ["Context.normalize"],      true]
    - [ctx_loginvert_qn_eq, Context.logical_invert.__qualname__.__eq__, ["Context.logical_invert"], true]
    - [ctx_add_not_bare,   Context.add.__qualname__.__eq__,            ["add"],                    false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra92.Context.ln_qualname_len_10:
  description: "decimal.Context.ln.__qualname__.__len__() == 10 (qualname is 'Context.ln', the shortest among the Context methods checked)"
  category: method_qualname
  kind: python_call_eq
  function: Context.ln.__qualname__.__len__
  args: []
  expected: 10

invariant decimal_extra92.Context.add_qualname_len_11:
  description: "decimal.Context.add.__qualname__.__len__() == 11 (qualname is 'Context.add', length 11)"
  category: method_qualname
  kind: python_call_eq
  function: Context.add.__qualname__.__len__
  args: []
  expected: 11

invariant decimal_extra92.Context.logical_invert_qualname_len_22:
  description: "decimal.Context.logical_invert.__qualname__.__len__() == 22 (qualname is 'Context.logical_invert', the longest among the Context methods checked)"
  category: method_qualname
  kind: python_call_eq
  function: Context.logical_invert.__qualname__.__len__
  args: []
  expected: 22

invariant decimal_extra92.Context.to_sci_string_qualname_len_21:
  description: "decimal.Context.to_sci_string.__qualname__.__len__() == 21 (qualname is 'Context.to_sci_string', length 21)"
  category: method_qualname
  kind: python_call_eq
  function: Context.to_sci_string.__qualname__.__len__
  args: []
  expected: 21

invariant decimal_extra92.Context.normalize_qualname_eq:
  description: "decimal.Context.normalize.__qualname__ == 'Context.normalize' (Context methods have dotted qualnames of the form 'Context.method_name')"
  category: method_qualname
  kind: python_call_eq
  function: Context.normalize.__qualname__.__eq__
  args: ["Context.normalize"]
  expected: true
