spec: abc_extra435
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module class and function identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers ABC, ABCMeta, abstractmethod, and abstractproperty identity"
    - "__bases__[0] function fields are double-quoted per ZSDL rules"
    - "abstractproperty is deprecated since 3.3 but still present in the module"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra435.class_name:
  description: "abc class and decorator __name__ checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: ABCN

  columns: [id, function, args, expected]
  rows:
    - [id001, abc.ABC.__name__.__eq__,              ["ABC"],              true]
    - [id002, abc.ABCMeta.__name__.__eq__,           ["ABCMeta"],          true]
    - [id003, abc.abstractmethod.__name__.__eq__,    ["abstractmethod"],   true]
    - [id004, abc.abstractproperty.__name__.__eq__,  ["abstractproperty"], true]

table abc_extra435.class_module:
  description: "abc class and decorator __module__ checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: ABCM

  columns: [id, function, args, expected]
  rows:
    - [id001, abc.ABC.__module__.__eq__,             ["abc"], true]
    - [id002, abc.ABCMeta.__module__.__eq__,          ["abc"], true]
    - [id003, abc.abstractmethod.__module__.__eq__,   ["abc"], true]
    - [id004, abc.abstractproperty.__module__.__eq__, ["abc"], true]

table abc_extra435.class_bases:
  description: "abc class __bases__[0].__name__ checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: ABCB

  columns: [id, function, args, expected]
  rows:
    - [id001, "abc.ABC.__bases__[0].__name__.__eq__",             ["object"], true]
    - [id002, "abc.ABCMeta.__bases__[0].__name__.__eq__",          ["type"],   true]
    - [id003, "abc.abstractmethod.__bases__[0].__name__.__eq__",   ["object"], true]
