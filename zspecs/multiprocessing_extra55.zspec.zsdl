spec: multiprocessing_extra55
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Process — Process documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#exceptions — multiprocessing exceptions documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/__init__.py"
  notes:
    - "This spec extends multiprocessing_extra54.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() tables, Process method __qualname__.__len__() tables, Pool method tables, Process/Pool __mro__.__len__() tables, __all__ metadata, class __dict__.__class__.__name__/__qualname__ tables (extra52), Process/__class__.__name__=='type', cpu_count/__class__.__name__=='method', current_process/__class__.__name__=='function', ProcessError/AuthenticationError/__class__.__name__=='type' (extra45), Process/__class__.__module__=='builtins', current_process/__class__.__module__=='builtins', cpu_count/__class__.__module__=='builtins' (extra46), Pool/__doc__/__class__/__module__=='builtins' (extra50), Pool/__class__.__name__=='type' (multiprocessing_extra), Pool/active_children/ProcessError/AuthenticationError __class__.__module__.__eq__('builtins') (extra53), Process/__init__.__class__.__name__.__eq__('function') (extra53), Process/Pool __repr__.__class__.__name__ (extra54), Process __weakref__.__class__.__name__ (extra54), ProcessError/AuthenticationError exception __repr__.__class__.__name__ (extra54)."
    - "This spec covers (mpall55 namespace): multiprocessing.__all__.__class__.__name__.__eq__('list') — mp.__all__ is a plain Python list of 37 exported names; __class__.__name__ == 'list'; __eq__('list') returns True. multiprocessing.__all__.__len__()==37 cross-check. Process.__eq__.__class__.__name__.__eq__('wrapper_descriptor') — Process is a pure-Python class inheriting from BaseProcess; it defines no custom __eq__; it inherits object.__eq__ which is a C-level slot wrapper. ProcessError/AuthenticationError __eq__.__class__.__name__.__eq__('wrapper_descriptor') — exception classes inherit object.__eq__ via BaseException chain (C-level slot wrapper). No prior multiprocessing spec has captured __all__.__class__.__name__ equality, __all__.__len__() equality, or __eq__.__class__.__name__ as string equality checks."
    - "multiprocessing.__all__.__class__.__name__ == 'list'. The multiprocessing module exposes __all__ as a plain Python list of 37 exported names. list is a built-in type; __class__.__name__ == 'list'. No prior multiprocessing spec captured __all__.__class__.__name__ as a string equality check (prior specs captured __all__ length as a numeric fact). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.__all__.__len__() == 37. The __all__ list contains 37 entries covering process management, synchronization, communication, and utility functions. This cross-check verifies the cardinality against a known expected value. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__eq__.__class__.__name__ == 'wrapper_descriptor'. Process is a pure-Python class defined in Lib/multiprocessing/process.py (inheriting from BaseProcess). Neither Process nor BaseProcess defines a custom __eq__ method. They inherit object.__eq__, which is a C-level slot wrapper (wrapper_descriptor). No prior multiprocessing spec captured __eq__.__class__.__name__ as a string equality check. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__eq__.__class__.__name__ == 'wrapper_descriptor'. ProcessError is a subclass of Exception → BaseException (C type). It does not define a custom __eq__ method. It inherits object.__eq__ via the BaseException chain, which is a C-level slot wrapper (wrapper_descriptor). No prior multiprocessing spec captured exception __eq__.__class__.__name__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.AuthenticationError.__eq__.__class__.__name__ == 'wrapper_descriptor'. AuthenticationError subclasses ProcessError → Exception → BaseException. It inherits object.__eq__ (C-level slot wrapper); __eq__.__class__.__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.__all__ container type and length — extra55
#
# multiprocessing.__all__ is a plain Python list of 37 exported names.
# The list type is a built-in type; __class__.__name__ == 'list'.
# __all__.__len__() == 37.
#
# No prior multiprocessing spec has captured __all__.__class__.__name__
# as a string equality check. Extra55 introduces this in the mpall55 namespace.
# ---------------------------------------------------------------------------

table multiprocessing_extra55.all_metadata_eq:
  description: "multiprocessing.__all__ type and length in mpall55 namespace — __all__ is a plain Python list (37 items); __class__.__name__.__eq__('list') returns True; __len__() == 37; no prior mp spec captured __all__.__class__.__name__ equality"
  kind: python_call_eq
  category: class_names
  id_prefix: mpall55allmeta

  columns: [id, function, args, expected, description]
  rows:
    - [all_is_list, __all__.__class__.__name__.__eq__, ["list"], true, "multiprocessing.__all__.__class__.__name__ == 'list' — mp.__all__ is a plain Python list of 37 exported names; list is a built-in type; __class__.__name__ == 'list'; first __all__.__class__.__name__ equality check in any multiprocessing spec"]
    - [all_len,     __all__.__len__,                   [],       37,   "multiprocessing.__all__.__len__() == 37 — __all__ contains 37 entries covering process management, synchronization, communication, and utility functions"]

# ---------------------------------------------------------------------------
# multiprocessing.Process __eq__.__class__.__name__ — extra55
#
# Process is defined in Lib/multiprocessing/process.py as a subclass of
# BaseProcess. Neither Process nor BaseProcess defines a custom __eq__ method.
# They inherit object.__eq__, which is a C-level slot wrapper:
#   Process.__eq__.__class__.__name__ == 'wrapper_descriptor'
#
# No prior multiprocessing spec has captured Process.__eq__.__class__.__name__
# as a string equality check. Extra55 introduces this in the mpall55 namespace.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra55.Process_eq_class_name_eq:
  description: "multiprocessing.Process.__eq__.__class__.__name__ == 'wrapper_descriptor' — Process is a pure-Python class inheriting from BaseProcess; neither defines custom __eq__; inherits object.__eq__ (C-level slot wrapper); __eq__.__class__.__name__ == 'wrapper_descriptor'; first __eq__.__class__.__name__ check in any multiprocessing spec"
  category: class_names
  kind: python_call_eq
  function: Process.__eq__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# multiprocessing ProcessError/AuthenticationError __eq__.__class__.__name__
# — extra55
#
# ProcessError and AuthenticationError are exception classes in the
# multiprocessing module. Both inherit (directly or indirectly) from
# BaseException (C type). Neither defines a custom __eq__ method. They inherit
# object.__eq__ via the exception chain, which is a C-level slot wrapper:
#   ProcessError.__eq__.__class__.__name__        == 'wrapper_descriptor'
#   AuthenticationError.__eq__.__class__.__name__ == 'wrapper_descriptor'
#
# No prior multiprocessing spec has captured exception __eq__.__class__.__name__.
# ---------------------------------------------------------------------------

table multiprocessing_extra55.exception_eq_class_name_eq:
  description: "multiprocessing ProcessError/AuthenticationError __eq__.__class__.__name__ in mpall55 namespace — exception classes inherit object.__eq__ via BaseException chain (C-level slot wrapper); __eq__.__class__.__name__ == 'wrapper_descriptor'; no prior mp spec captured exception __eq__.__class__.__name__"
  kind: python_call_eq
  category: class_names
  id_prefix: mpall55exceqname

  columns: [id, function, args, expected, description]
  rows:
    - [ProcessError,        ProcessError.__eq__.__class__.__name__.__eq__,        ["wrapper_descriptor"], true, "ProcessError.__eq__.__class__.__name__ == 'wrapper_descriptor' — ProcessError subclasses Exception → BaseException (C type); inherits object.__eq__ (C-level slot wrapper); defines no custom __eq__; first exception __eq__.__class__.__name__ check in any multiprocessing spec"]
    - [AuthenticationError, AuthenticationError.__eq__.__class__.__name__.__eq__, ["wrapper_descriptor"], true, "AuthenticationError.__eq__.__class__.__name__ == 'wrapper_descriptor' — AuthenticationError subclasses ProcessError → Exception → BaseException; inherits object.__eq__ (C-level slot wrapper); defines no custom __eq__"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra55
# ---------------------------------------------------------------------------

invariant multiprocessing_extra55.all_class_name_list_eq:
  description: "multiprocessing.__all__.__class__.__name__ == 'list' — mp.__all__ is a plain Python list of 37 exported names; list is a built-in type; __class__.__name__ == 'list'; first __all__.__class__.__name__ equality check in any multiprocessing spec"
  category: class_names
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant multiprocessing_extra55.ProcessError_eq_class_name_eq:
  description: "multiprocessing.ProcessError.__eq__.__class__.__name__ == 'wrapper_descriptor' — ProcessError subclasses Exception → BaseException (C type); inherits object.__eq__ which is a C-level slot wrapper (wrapper_descriptor); defines no custom __eq__; first exception __eq__.__class__.__name__ check in any multiprocessing spec"
  category: class_names
  kind: python_call_eq
  function: ProcessError.__eq__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant multiprocessing_extra55.AuthenticationError_eq_class_name_eq:
  description: "multiprocessing.AuthenticationError.__eq__.__class__.__name__ == 'wrapper_descriptor' — AuthenticationError subclasses ProcessError → Exception → BaseException; inherits object.__eq__ (C-level slot wrapper); defines no custom __eq__"
  category: class_names
  kind: python_call_eq
  function: AuthenticationError.__eq__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true
