spec: functools_extra378
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "functools.singledispatch.__name__ == 'singledispatch' — singledispatch is a pure-Python decorator in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.singledispatch.__module__ == 'functools' — defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.partial.__name__ == 'partial' — partial is a C type implemented in Modules/_functoolsmodule.c and re-exported from functools. Verified with Python 3.14.3."
    - "functools.partial.__module__ == 'functools' — __module__ is 'functools' (the re-exporting module). Verified with Python 3.14.3."
    - "functools.partial.__bases__[0].__name__ == 'object' — partial inherits directly from object. Verified with Python 3.14.3."
    - "functools.partial.__doc__.__class__.__name__ == 'str' — partial has a string docstring. Verified with Python 3.14.3."
    - "functools.reduce.__doc__.__class__.__name__ == 'str' — reduce has a string docstring. Verified with Python 3.14.3."
    - "functools.update_wrapper.__name__ == 'update_wrapper' — update_wrapper is a pure-Python function in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.update_wrapper.__module__ == 'functools' — defined in Lib/functools.py. Verified with Python 3.14.3."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.singledispatch and functools.partial function/class identity
#
# functools.singledispatch.__name__ == 'singledispatch'
# functools.singledispatch.__module__ == 'functools'
# functools.partial.__name__ == 'partial'
# functools.partial.__module__ == 'functools'
# functools.partial.__bases__[0].__name__ == 'object'
#
# singledispatch is a pure-Python decorator that transforms a function into a
# single-dispatch generic function. partial is a C type that creates new callable
# objects with pre-filled arguments; it re-exports from functools and its
# __bases__[0] is object.
# ---------------------------------------------------------------------------

table functools_extra378.singledispatch_and_partial_identity:
  description: "functools.singledispatch decorator and functools.partial class identity: __name__, __module__, and base class; new to extra378"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolssp378

  columns: [id, function, args, expected, description]
  rows:
    - [singledispatch_name_eq,
       "singledispatch.__name__.__eq__",
       ["singledispatch"],
       true,
       "functools.singledispatch.__name__.__eq__('singledispatch') == True — singledispatch is a pure-Python decorator in Lib/functools.py that transforms a function into a single-dispatch generic function dispatching on the type of its first argument; its __name__ is 'singledispatch'; str.__eq__('singledispatch') returns True; new to extra378"]
    - [singledispatch_module_eq,
       "singledispatch.__module__.__eq__",
       ["functools"],
       true,
       "functools.singledispatch.__module__.__eq__('functools') == True — singledispatch is defined in Lib/functools.py; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra378"]
    - [partial_name_eq,
       "partial.__name__.__eq__",
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — partial is a C type implemented in Modules/_functoolsmodule.c that creates new callables with pre-filled arguments and keywords; its __name__ is 'partial'; str.__eq__('partial') returns True; new to extra378"]
    - [partial_module_eq,
       "partial.__module__.__eq__",
       ["functools"],
       true,
       "functools.partial.__module__.__eq__('functools') == True — partial is re-exported from functools; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra378"]
    - [partial_bases_first_eq_object,
       "partial.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partial.__bases__[0].__name__.__eq__('object') == True — partial inherits directly from object with no intermediate base class; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra378"]

# ---------------------------------------------------------------------------
# Table 2: functools.partial and functools.reduce docstring class, plus
#          functools.update_wrapper identity
#
# functools.partial.__doc__.__class__.__name__ == 'str'
# functools.reduce.__doc__.__class__.__name__ == 'str'
# functools.update_wrapper.__name__ == 'update_wrapper'
# functools.update_wrapper.__module__ == 'functools'
#
# Both partial and reduce carry plain string docstrings (__doc__.__class__.__name__
# == 'str'). update_wrapper is a pure-Python helper in Lib/functools.py that
# updates a wrapper function to look like the wrapped function.
# ---------------------------------------------------------------------------

table functools_extra378.doc_class_and_update_wrapper_identity:
  description: "functools.partial and functools.reduce docstring class name (both 'str'), and functools.update_wrapper __name__ and __module__; new to extra378"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsduw378

  columns: [id, function, args, expected, description]
  rows:
    - [partial_doc_class_name_eq,
       "partial.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.partial.__doc__.__class__.__name__.__eq__('str') == True — partial carries a plain string docstring; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra378"]
    - [reduce_doc_class_name_eq,
       "reduce.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.reduce.__doc__.__class__.__name__.__eq__('str') == True — reduce is a C builtin with a plain string docstring; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra378"]
    - [update_wrapper_name_eq,
       "update_wrapper.__name__.__eq__",
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__name__.__eq__('update_wrapper') == True — update_wrapper is a pure-Python function in Lib/functools.py that updates a wrapper function to look like the wrapped function by copying attributes; its __name__ is 'update_wrapper'; str.__eq__('update_wrapper') returns True; new to extra378"]
    - [update_wrapper_module_eq,
       "update_wrapper.__module__.__eq__",
       ["functools"],
       true,
       "functools.update_wrapper.__module__.__eq__('functools') == True — update_wrapper is defined in Lib/functools.py; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra378"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra378
# ---------------------------------------------------------------------------

invariant functools_extra378.singledispatch_name:
  description: "functools.singledispatch.__name__ == 'singledispatch' — pure-Python decorator in Lib/functools.py; new to extra378"
  kind: python_call_eq
  function: singledispatch.__name__.__eq__
  args: ["singledispatch"]
  expected: true

invariant functools_extra378.singledispatch_module:
  description: "functools.singledispatch.__module__ == 'functools' — defined in Lib/functools.py; new to extra378"
  kind: python_call_eq
  function: singledispatch.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra378.partial_name:
  description: "functools.partial.__name__ == 'partial' — C type re-exported from functools; new to extra378"
  kind: python_call_eq
  function: partial.__name__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra378.partial_module:
  description: "functools.partial.__module__ == 'functools' — C type whose __module__ is the re-exporting functools package; new to extra378"
  kind: python_call_eq
  function: partial.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra378.partial_bases_object:
  description: "functools.partial.__bases__[0].__name__ == 'object' — partial inherits directly from object; new to extra378"
  kind: python_call_eq
  function: partial.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

invariant functools_extra378.partial_doc_class_name:
  description: "functools.partial.__doc__.__class__.__name__ == 'str' — partial carries a plain string docstring; new to extra378"
  kind: python_call_eq
  function: partial.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra378.reduce_doc_class_name:
  description: "functools.reduce.__doc__.__class__.__name__ == 'str' — reduce is a C builtin with a plain string docstring; new to extra378"
  kind: python_call_eq
  function: reduce.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra378.update_wrapper_name:
  description: "functools.update_wrapper.__name__ == 'update_wrapper' — pure-Python helper in Lib/functools.py; new to extra378"
  kind: python_call_eq
  function: update_wrapper.__name__.__eq__
  args: ["update_wrapper"]
  expected: true

invariant functools_extra378.update_wrapper_module:
  description: "functools.update_wrapper.__module__ == 'functools' — defined in Lib/functools.py; new to extra378"
  kind: python_call_eq
  function: update_wrapper.__module__.__eq__
  args: ["functools"]
  expected: true
