spec: itertools_extra20
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools.zspec.zsdl and prior extras through itertools_extra19.zspec.zsdl."
    - "itertools_extra19 covers: __name__.__eq__ for chain/cycle/repeat/count/zip_longest/takewhile/dropwhile/filterfalse; instance class names for chain/repeat/takewhile/filterfalse."
    - "itertools_extra18 covers: accumulate/product/combinations/permutations instance class names and __name__.__eq__ table."
    - "No prior itertools spec records __bases__[0].__name__.__eq__ for all ten classes together in the extra20 namespace."
    - "All itertools iterator classes are C-level types that inherit directly from 'object'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__eq__ table — ten itertools classes
#
# Verifies that each class's direct base class is 'object'.
# All itertools iterator types are implemented in C and inherit directly from
# object with no intermediate Python base class.
# No prior itertools spec records all ten base names in one table in
# the extra20 namespace.
# ---------------------------------------------------------------------------

table itertools_extra20.base_names:
  kind: python_call_eq
  category: class_attrs
  columns: [id, function, args, expected, description]
  rows:
    - [itertools_extra20.base_names.chain,
       "chain.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.chain.__bases__[0].__name__ == 'object'"]
    - [itertools_extra20.base_names.count,
       "count.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.count.__bases__[0].__name__ == 'object'"]
    - [itertools_extra20.base_names.cycle,
       "cycle.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.cycle.__bases__[0].__name__ == 'object'"]
    - [itertools_extra20.base_names.repeat,
       "repeat.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.repeat.__bases__[0].__name__ == 'object'"]
    - [itertools_extra20.base_names.islice,
       "islice.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.islice.__bases__[0].__name__ == 'object'"]
    - [itertools_extra20.base_names.product,
       "product.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.product.__bases__[0].__name__ == 'object'"]
    - [itertools_extra20.base_names.permutations,
       "permutations.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.permutations.__bases__[0].__name__ == 'object'"]
    - [itertools_extra20.base_names.combinations,
       "combinations.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.combinations.__bases__[0].__name__ == 'object'"]
    - [itertools_extra20.base_names.starmap,
       "starmap.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.starmap.__bases__[0].__name__ == 'object'"]
    - [itertools_extra20.base_names.compress,
       "compress.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.compress.__bases__[0].__name__ == 'object'"]

# ---------------------------------------------------------------------------
# chain.__module__.__eq__ — module anchor
#
# Verifies that chain is defined in the 'itertools' module.
# No prior itertools spec records this in the extra20 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra20.chain.module:
  description: "itertools.chain.__module__ == 'itertools' — chain is defined in itertools"
  category: class_attrs
  kind: python_call_eq
  function: chain.__module__.__eq__
  args: ["itertools"]
  expected: true

