spec: as3046
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 650 (as3046): __enter__, __exit__, __aenter__ dict-presence for asyncio types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Key findings: asyncio.Timeout and asyncio.TaskGroup define __aenter__ (true) — they are async context managers using the async-with protocol directly."
    - "asyncio.Lock, asyncio.Semaphore, asyncio.Condition, asyncio.BoundedSemaphore implement __aenter__/__aexit__ via inheritance from a mixin, NOT in their own __dict__ — hence false for all three methods."
    - "No asyncio class defines __enter__ or __exit__ in its own __dict__ — none are synchronous context managers."
    - "asyncio.Task, asyncio.Future, asyncio.Queue, asyncio.Event do not define any context manager protocol methods."
    - "asyncio.Handle, asyncio.TimerHandle, asyncio.StreamReader, asyncio.StreamWriter also define none of these methods in their own __dict__."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __enter__ dict-presence — operator.contains(Cls.__dict__, '__enter__')
#
# No asyncio class defines __enter__ in its own __dict__; all results are false.
# asyncio primitives (Lock, Semaphore, Condition) are async context managers
# using __aenter__/__aexit__, not the synchronous __enter__/__exit__ protocol.
# Timeout and TaskGroup also use the async protocol exclusively.
# ---------------------------------------------------------------------------

table as3046.enter:
  description: "asyncio types __enter__ dict-presence checks; wave 650"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: as3046

  columns: [id, function, args, expected]
  rows:
    - ["as3046001", operator.contains, [asyncio.Task.__dict__,             "__enter__"], false]
    - ["as3046002", operator.contains, [asyncio.Future.__dict__,           "__enter__"], false]
    - ["as3046003", operator.contains, [asyncio.Queue.__dict__,            "__enter__"], false]
    - ["as3046004", operator.contains, [asyncio.Event.__dict__,            "__enter__"], false]
    - ["as3046005", operator.contains, [asyncio.Semaphore.__dict__,        "__enter__"], false]
    - ["as3046006", operator.contains, [asyncio.Lock.__dict__,             "__enter__"], false]
    - ["as3046007", operator.contains, [asyncio.Condition.__dict__,        "__enter__"], false]
    - ["as3046008", operator.contains, [asyncio.BoundedSemaphore.__dict__, "__enter__"], false]
    - ["as3046009", operator.contains, [asyncio.Handle.__dict__,           "__enter__"], false]
    - ["as3046010", operator.contains, [asyncio.TimerHandle.__dict__,      "__enter__"], false]
    - ["as3046011", operator.contains, [asyncio.Timeout.__dict__,          "__enter__"], false]
    - ["as3046012", operator.contains, [asyncio.TaskGroup.__dict__,        "__enter__"], false]
    - ["as3046013", operator.contains, [asyncio.StreamReader.__dict__,     "__enter__"], false]
    - ["as3046014", operator.contains, [asyncio.StreamWriter.__dict__,     "__enter__"], false]

