# ---------------------------------------------------------------------------
# __aenter__ dict-presence — operator.contains(Cls.__dict__, '__aenter__')
#
# asyncio.Timeout and asyncio.TaskGroup define __aenter__ in their own __dict__
# (true) — they are native async context managers.
# Lock, Semaphore, Condition, BoundedSemaphore inherit __aenter__ from a shared
# mixin and do NOT define it directly in their own __dict__ (false).
# Task, Future, Queue, Event, Handle, TimerHandle, StreamReader, StreamWriter
# define no async context manager protocol at all (false).
# ---------------------------------------------------------------------------

table as3046.aenter:
  description: "asyncio types __aenter__ dict-presence checks; wave 650"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
