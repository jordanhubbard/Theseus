    - ["as3046030", operator.contains, [asyncio.Future.__dict__,           "__aenter__"], false]
    - ["as3046031", operator.contains, [asyncio.Queue.__dict__,            "__aenter__"], false]
    - ["as3046032", operator.contains, [asyncio.Event.__dict__,            "__aenter__"], false]
    - ["as3046033", operator.contains, [asyncio.Semaphore.__dict__,        "__aenter__"], false]
    - ["as3046034", operator.contains, [asyncio.Lock.__dict__,             "__aenter__"], false]
    - ["as3046035", operator.contains, [asyncio.Condition.__dict__,        "__aenter__"], false]
    - ["as3046036", operator.contains, [asyncio.BoundedSemaphore.__dict__, "__aenter__"], false]
    - ["as3046037", operator.contains, [asyncio.Handle.__dict__,           "__aenter__"], false]
    - ["as3046038", operator.contains, [asyncio.TimerHandle.__dict__,      "__aenter__"], false]
    - ["as3046039", operator.contains, [asyncio.Timeout.__dict__,          "__aenter__"], true]
    - ["as3046040", operator.contains, [asyncio.TaskGroup.__dict__,        "__aenter__"], true]
    - ["as3046041", operator.contains, [asyncio.StreamReader.__dict__,     "__aenter__"], false]
    - ["as3046042", operator.contains, [asyncio.StreamWriter.__dict__,     "__aenter__"], false]

# ---------------------------------------------------------------------------
# combined — __enter__, __exit__, __aenter__ across all 14 asyncio subjects
#
# Covers the full matrix: 14 classes x 3 methods = 42 rows.
# __enter__: all false — no synchronous context manager protocol defined.
# __exit__:  all false — mirrors __enter__ findings.
# __aenter__: true only for Timeout and TaskGroup; all others false.
# The async primitives (Lock, Semaphore, Condition, BoundedSemaphore) inherit
# __aenter__ from a base class mixin rather than defining it directly.
# ---------------------------------------------------------------------------

