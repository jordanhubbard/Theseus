spec: re_extra2311
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/re.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 601 (_extra2311): __abstractmethods__ content checks."
    - "re module types (Pattern, Match, error, RegexFlag) are all concrete — none are abstract."
    - "re.Pattern and re.Match are C extension types; re.error is a Python Exception subclass; re.RegexFlag is an IntFlag enum."
    - "None of these types set __abstractmethods__ in their own __dict__."
    - "Accessing .__abstractmethods__ on any re type raises AttributeError."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __abstractmethods__ dict-presence for re types
#
# None of the re public types set __abstractmethods__ in their own __dict__.
# Expected: False for all.
# ---------------------------------------------------------------------------

table re_extra2311.abstract_absence:
  description: "re types have no __abstractmethods__ in class __dict__ — all False — wave 601 _extra2311"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2311

  columns: [id, function, args, expected]
  rows:
    - ["re2311001", "re.Pattern.__dict__.__contains__",   ["__abstractmethods__"], false]
    - ["re2311002", "re.Match.__dict__.__contains__",     ["__abstractmethods__"], false]
    - ["re2311003", "re.error.__dict__.__contains__",     ["__abstractmethods__"], false]
    - ["re2311004", "re.RegexFlag.__dict__.__contains__", ["__abstractmethods__"], false]

# ---------------------------------------------------------------------------
# Table 2: __abstractmethods__.__len__ raises AttributeError
#
# Since __abstractmethods__ is absent from each type's __dict__ and none of
# the MRO bases provide it, .__abstractmethods__.__len__ raises AttributeError.
# ---------------------------------------------------------------------------

table re_extra2311.abstract_len_error:
  description: "re types raise AttributeError on __abstractmethods__.__len__ — wave 601 _extra2311"
  kind: python_call_raises
  category: attribute_access
  id_prefix: re2311

  columns: [id, function, args, expected]
  rows:
    - ["re2311005", "re.Pattern.__abstractmethods__.__len__",   [], "AttributeError"]
    - ["re2311006", "re.Match.__abstractmethods__.__len__",     [], "AttributeError"]
    - ["re2311007", "re.error.__abstractmethods__.__len__",     [], "AttributeError"]
    - ["re2311008", "re.RegexFlag.__abstractmethods__.__len__", [], "AttributeError"]

# ---------------------------------------------------------------------------
# Table 3: __abstractmethods__.__contains__ raises AttributeError — re.Pattern
#
# Chained .__abstractmethods__.__contains__ access raises AttributeError because
# the intermediate attribute does not exist on the Pattern C type.
# Representative method names: match, search, fullmatch, findall, sub.
# ---------------------------------------------------------------------------

table re_extra2311.pattern_contains_error:
  description: "re.Pattern __abstractmethods__.__contains__ raises AttributeError — wave 601 _extra2311"
  kind: python_call_raises
  category: attribute_access
  id_prefix: re2311

  columns: [id, function, args, expected]
  rows:
    - ["re2311009", "re.Pattern.__abstractmethods__.__contains__", ["match"],    "AttributeError"]
    - ["re2311010", "re.Pattern.__abstractmethods__.__contains__", ["search"],   "AttributeError"]
    - ["re2311011", "re.Pattern.__abstractmethods__.__contains__", ["fullmatch"], "AttributeError"]
    - ["re2311012", "re.Pattern.__abstractmethods__.__contains__", ["findall"],  "AttributeError"]
    - ["re2311013", "re.Pattern.__abstractmethods__.__contains__", ["sub"],      "AttributeError"]

# ---------------------------------------------------------------------------
# Table 4: __abstractmethods__.__contains__ raises AttributeError — re.Match
#
# Representative method names: group, groups, start, end, span.
# ---------------------------------------------------------------------------

table re_extra2311.match_contains_error:
  description: "re.Match __abstractmethods__.__contains__ raises AttributeError — wave 601 _extra2311"
  kind: python_call_raises
  category: attribute_access
  id_prefix: re2311

  columns: [id, function, args, expected]
  rows:
    - ["re2311014", "re.Match.__abstractmethods__.__contains__", ["group"],  "AttributeError"]
    - ["re2311015", "re.Match.__abstractmethods__.__contains__", ["groups"], "AttributeError"]
    - ["re2311016", "re.Match.__abstractmethods__.__contains__", ["start"],  "AttributeError"]
    - ["re2311017", "re.Match.__abstractmethods__.__contains__", ["end"],    "AttributeError"]
    - ["re2311018", "re.Match.__abstractmethods__.__contains__", ["span"],   "AttributeError"]

# ---------------------------------------------------------------------------
# Table 5: __abstractmethods__.__contains__ raises AttributeError — re.error / re.RegexFlag
#
# re.error is a pure-Python exception subclass; re.RegexFlag is an IntFlag enum.
# Neither has __abstractmethods__ in __dict__.
# ---------------------------------------------------------------------------

table re_extra2311.error_regexflag_contains_error:
  description: "re.error and re.RegexFlag __abstractmethods__.__contains__ raises AttributeError — wave 601 _extra2311"
  kind: python_call_raises
  category: attribute_access
  id_prefix: re2311

  columns: [id, function, args, expected]
  rows:
    - ["re2311019", "re.error.__abstractmethods__.__contains__",     ["__str__"],   "AttributeError"]
    - ["re2311020", "re.RegexFlag.__abstractmethods__.__contains__", ["__or__"],    "AttributeError"]
    - ["re2311021", "re.error.__abstractmethods__.__contains__",     ["__init__"],  "AttributeError"]
    - ["re2311022", "re.RegexFlag.__abstractmethods__.__contains__", ["__and__"],   "AttributeError"]
