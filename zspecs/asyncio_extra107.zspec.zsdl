table asyncio_extra107.asyncio_transport_bases:
  description: "asyncio transport abstract class __bases__[0].__name__ checks in asyncioproto107 namespace — wave 254 theme: asyncio.BaseTransport.__bases__[0].__name__.__eq__('object')==True (inherits directly from object, MRO=[BaseTransport, object], length=2 — tied with BaseProtocol for shortest); asyncio.Transport.__bases__[0].__name__.__eq__('ReadTransport')==True (Transport uses multiple inheritance: bases=[ReadTransport, WriteTransport]; MRO=[Transport, ReadTransport, WriteTransport, BaseTransport, object], length=5 — deepest in spec); asyncio.DatagramTransport.__bases__[0].__name__.__eq__('BaseTransport')==True (MRO=[DatagramTransport, BaseTransport, object], length=3); BaseTransport.__module__.__eq__('asyncio.transports')==True; Transport.__module__.__eq__('asyncio.transports')==True; DatagramTransport.__module__.__eq__('asyncio.transports')==True; BaseTransport.__mro__.__len__()==2; Transport.__mro__.__len__()==5; DatagramTransport.__mro__.__len__()==3; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: asyncioproto107a

  columns: [id, function, args, expected, description]
  rows:
    - [bt_base_eq,   "asyncio.BaseTransport.__bases__[0].__name__.__eq__",     ["object"],         true, "asyncio.BaseTransport.__bases__[0].__name__ == 'object' (inherits directly from object); verified with Python 3.14.3"]
    - [bt_mro_len,   asyncio.BaseTransport.__mro__.__len__,                    [],                 2,    "asyncio.BaseTransport.__mro__.__len__() == 2 ([BaseTransport, object]); tied for shortest MRO in spec; verified with Python 3.14.3"]
    - [bt_module,    asyncio.BaseTransport.__module__.__eq__,                  ["asyncio.transports"], true, "asyncio.BaseTransport.__module__ == 'asyncio.transports'; verified with Python 3.14.3"]
    - [t_base_eq,    "asyncio.Transport.__bases__[0].__name__.__eq__",         ["ReadTransport"],  true, "asyncio.Transport.__bases__[0].__name__ == 'ReadTransport' (Transport inherits from ReadTransport and WriteTransport via multiple inheritance); verified with Python 3.14.3"]
    - [t_mro_len,    asyncio.Transport.__mro__.__len__,                        [],                 5,    "asyncio.Transport.__mro__.__len__() == 5 ([Transport, ReadTransport, WriteTransport, BaseTransport, object]); deepest MRO in spec; verified with Python 3.14.3"]
    - [t_module,     asyncio.Transport.__module__.__eq__,                      ["asyncio.transports"], true, "asyncio.Transport.__module__ == 'asyncio.transports'; verified with Python 3.14.3"]
    - [dgt_base_eq,  "asyncio.DatagramTransport.__bases__[0].__name__.__eq__", ["BaseTransport"],  true, "asyncio.DatagramTransport.__bases__[0].__name__ == 'BaseTransport' (inherits directly from BaseTransport); verified with Python 3.14.3"]
    - [dgt_mro_len,  asyncio.DatagramTransport.__mro__.__len__,                [],                 3,    "asyncio.DatagramTransport.__mro__.__len__() == 3 ([DatagramTransport, BaseTransport, object]); verified with Python 3.14.3"]
