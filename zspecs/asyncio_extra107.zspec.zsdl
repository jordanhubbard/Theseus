spec: asyncio_extra107
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/protocols.py"
    - "CPython source: Lib/asyncio/transports.py"
  notes:
    - "This spec extends asyncio_extra106.zspec.zsdl."
    - "This spec covers: wave 254 theme — asyncio protocol/transport abstract class identity. NEW in extra107: asyncio.BaseProtocol.__name__=='BaseProtocol', __module__=='asyncio.protocols', __bases__[0].__name__=='object', __mro__.__len__()==2 (inherits directly from object); asyncio.Protocol.__bases__[0].__name__=='BaseProtocol' (mro len=3); asyncio.DatagramProtocol.__bases__[0].__name__=='BaseProtocol' (mro len=3); asyncio.SubprocessProtocol.__bases__[0].__name__=='BaseProtocol' (mro len=3); asyncio.BaseTransport.__bases__[0].__name__=='object' (mro len=2); asyncio.Transport.__bases__[0].__name__=='ReadTransport' (mro len=5, most complex — Transport inherits from both ReadTransport and WriteTransport via multiple inheritance); asyncio.DatagramTransport.__bases__[0].__name__=='BaseTransport' (mro len=3); all protocol classes have __module__=='asyncio.protocols'; all transport classes have __module__=='asyncio.transports'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.BaseProtocol.__bases__[0].__name__ == 'object'. BaseProtocol is the root of the protocol hierarchy; it inherits directly from object with MRO [BaseProtocol, object] (length=2). Protocol, DatagramProtocol, and SubprocessProtocol all inherit from BaseProtocol (MRO length=3). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Transport.__bases__[0].__name__ == 'ReadTransport'. Transport uses multiple inheritance from ReadTransport and WriteTransport; its MRO is [Transport, ReadTransport, WriteTransport, BaseTransport, object] (length=5), making it the deepest class in this spec. BaseTransport is the shared base of both ReadTransport and WriteTransport. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.DatagramTransport.__bases__[0].__name__ == 'BaseTransport'. DatagramTransport inherits directly from BaseTransport (bypassing ReadTransport/WriteTransport) with MRO [DatagramTransport, BaseTransport, object] (length=3). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Protocol hierarchy __bases__[0].__name__ — extra107
#
# Wave 254 theme: asyncio protocol abstract class identity.
#
# asyncio.BaseProtocol.__bases__[0].__name__      == 'object'       (mro len=2, shortest)
# asyncio.Protocol.__bases__[0].__name__          == 'BaseProtocol' (mro len=3)
# asyncio.DatagramProtocol.__bases__[0].__name__  == 'BaseProtocol' (mro len=3)
# asyncio.SubprocessProtocol.__bases__[0].__name__ == 'BaseProtocol' (mro len=3)
# ---------------------------------------------------------------------------

table asyncio_extra107.asyncio_protocol_bases:
  description: "asyncio protocol abstract class __bases__[0].__name__ checks in asyncioproto107 namespace — wave 254 theme: asyncio.BaseProtocol.__bases__[0].__name__.__eq__('object')==True (BaseProtocol inherits directly from object, MRO=[BaseProtocol, object], length=2 — shortest in spec); asyncio.Protocol.__bases__[0].__name__.__eq__('BaseProtocol')==True (MRO=[Protocol, BaseProtocol, object], length=3); asyncio.DatagramProtocol.__bases__[0].__name__.__eq__('BaseProtocol')==True (MRO=[DatagramProtocol, BaseProtocol, object], length=3); asyncio.SubprocessProtocol.__bases__[0].__name__.__eq__('BaseProtocol')==True (MRO=[SubprocessProtocol, BaseProtocol, object], length=3); all four protocol classes have __module__=='asyncio.protocols'; BaseProtocol.__mro__.__len__()==2; Protocol.__mro__.__len__()==3; DatagramProtocol.__mro__.__len__()==3; SubprocessProtocol.__mro__.__len__()==3; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: asyncioproto107

  columns: [id, function, args, expected, description]
  rows:
    - [bp_base_eq,   "asyncio.BaseProtocol.__bases__[0].__name__.__eq__",      ["object"],        true, "asyncio.BaseProtocol.__bases__[0].__name__ == 'object' (inherits directly from object); verified with Python 3.14.3"]
    - [bp_mro_len,   asyncio.BaseProtocol.__mro__.__len__,                     [],                2,    "asyncio.BaseProtocol.__mro__.__len__() == 2 ([BaseProtocol, object]); shortest MRO in spec; verified with Python 3.14.3"]
    - [bp_module,    asyncio.BaseProtocol.__module__.__eq__,                   ["asyncio.protocols"], true, "asyncio.BaseProtocol.__module__ == 'asyncio.protocols'; verified with Python 3.14.3"]
    - [p_base_eq,    "asyncio.Protocol.__bases__[0].__name__.__eq__",          ["BaseProtocol"],  true, "asyncio.Protocol.__bases__[0].__name__ == 'BaseProtocol'; verified with Python 3.14.3"]
    - [p_mro_len,    asyncio.Protocol.__mro__.__len__,                         [],                3,    "asyncio.Protocol.__mro__.__len__() == 3 ([Protocol, BaseProtocol, object]); verified with Python 3.14.3"]
    - [dp_base_eq,   "asyncio.DatagramProtocol.__bases__[0].__name__.__eq__",  ["BaseProtocol"],  true, "asyncio.DatagramProtocol.__bases__[0].__name__ == 'BaseProtocol'; verified with Python 3.14.3"]
    - [dp_mro_len,   asyncio.DatagramProtocol.__mro__.__len__,                 [],                3,    "asyncio.DatagramProtocol.__mro__.__len__() == 3 ([DatagramProtocol, BaseProtocol, object]); verified with Python 3.14.3"]
    - [sp_base_eq,   "asyncio.SubprocessProtocol.__bases__[0].__name__.__eq__", ["BaseProtocol"], true, "asyncio.SubprocessProtocol.__bases__[0].__name__ == 'BaseProtocol'; verified with Python 3.14.3"]
    - [sp_mro_len,   asyncio.SubprocessProtocol.__mro__.__len__,               [],                3,    "asyncio.SubprocessProtocol.__mro__.__len__() == 3 ([SubprocessProtocol, BaseProtocol, object]); verified with Python 3.14.3"]

