# ---------------------------------------------------------------------------
# asyncio protocol/transport __name__ and __qualname__ lengths — extra107
#
# Wave 254 theme: class name lengths for protocol and transport classes.
#
# asyncio.BaseProtocol.__qualname__      == 'BaseProtocol'       (len=12)
# asyncio.SubprocessProtocol.__qualname__ == 'SubprocessProtocol' (len=18, longest protocol)
# asyncio.DatagramTransport.__qualname__ == 'DatagramTransport'  (len=17)
# ---------------------------------------------------------------------------

table asyncio_extra107.asyncio_proto_transport_qualname_lengths:
  description: "asyncio protocol/transport class __name__ and __qualname__ length checks in asyncioproto107 namespace — wave 254 theme: comparing qualname lengths of protocol and transport classes; BaseProtocol.__name__.__eq__('BaseProtocol')==True (len=12); Protocol.__name__.__eq__('Protocol')==True (len=8, shortest protocol); DatagramProtocol.__name__.__eq__('DatagramProtocol')==True (len=16); SubprocessProtocol.__name__.__eq__('SubprocessProtocol')==True (len=18, longest class name in spec); BaseTransport.__name__.__eq__('BaseTransport')==True (len=13); Transport.__name__.__eq__('Transport')==True (len=9); DatagramTransport.__name__.__eq__('DatagramTransport')==True (len=17); qualname lengths mirror name lengths since all are top-level classes; Protocol.__qualname__.__len__()==8; SubprocessProtocol.__qualname__.__len__()==18; DatagramTransport.__qualname__.__len__()==17; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioproto107b

  columns: [id, function, args, expected, description]
  rows:
    - [bp_name_eq,   asyncio.BaseProtocol.__name__.__eq__,        ["BaseProtocol"],       true, "asyncio.BaseProtocol.__name__ == 'BaseProtocol' (len=12); verified with Python 3.14.3"]
    - [p_name_eq,    asyncio.Protocol.__name__.__eq__,            ["Protocol"],           true, "asyncio.Protocol.__name__ == 'Protocol' (len=8, shortest protocol name); verified with Python 3.14.3"]
    - [dp_name_eq,   asyncio.DatagramProtocol.__name__.__eq__,    ["DatagramProtocol"],   true, "asyncio.DatagramProtocol.__name__ == 'DatagramProtocol' (len=16); verified with Python 3.14.3"]
    - [sp_name_eq,   asyncio.SubprocessProtocol.__name__.__eq__,  ["SubprocessProtocol"], true, "asyncio.SubprocessProtocol.__name__ == 'SubprocessProtocol' (len=18, longest name in spec); verified with Python 3.14.3"]
    - [sp_qn_len,    asyncio.SubprocessProtocol.__qualname__.__len__, [],                 18,   "asyncio.SubprocessProtocol.__qualname__.__len__() == 18 ('SubprocessProtocol'=18, longest qualname in spec); verified with Python 3.14.3"]
    - [bt_name_eq,   asyncio.BaseTransport.__name__.__eq__,       ["BaseTransport"],      true, "asyncio.BaseTransport.__name__ == 'BaseTransport' (len=13); verified with Python 3.14.3"]
    - [t_name_eq,    asyncio.Transport.__name__.__eq__,           ["Transport"],          true, "asyncio.Transport.__name__ == 'Transport' (len=9, shortest transport name); verified with Python 3.14.3"]
    - [dgt_name_eq,  asyncio.DatagramTransport.__name__.__eq__,   ["DatagramTransport"],  true, "asyncio.DatagramTransport.__name__ == 'DatagramTransport' (len=17); verified with Python 3.14.3"]
    - [p_qn_len,     asyncio.Protocol.__qualname__.__len__,       [],                     8,    "asyncio.Protocol.__qualname__.__len__() == 8 ('Protocol'=8, shortest protocol qualname); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra107
# ---------------------------------------------------------------------------

invariant asyncio_extra107.BaseProtocol_base_is_object:
  description: "asyncio.BaseProtocol.__bases__[0].__name__.__eq__('object') returns True — BaseProtocol is the root of the asyncio protocol hierarchy; it inherits directly from object with MRO [BaseProtocol, object] (length=2 — tied with BaseTransport for shortest in spec); Protocol, DatagramProtocol, and SubprocessProtocol all inherit from BaseProtocol (each with MRO length=3); BaseProtocol.__module__=='asyncio.protocols'; BaseProtocol.__qualname__=='BaseProtocol' (len=12); BaseProtocol defines the connection_made, connection_lost, and pause_writing/resume_writing abstract interface; NEW in extra107: first standalone BaseProtocol base invariant in asyncioproto107 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "asyncio.BaseProtocol.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant asyncio_extra107.Transport_mro_len_5:
  description: "asyncio.Transport.__mro__.__len__() == 5 — Transport has the deepest MRO in this spec: [Transport, ReadTransport, WriteTransport, BaseTransport, object] (5 elements); Transport uses multiple inheritance from ReadTransport and WriteTransport, which both inherit from BaseTransport; asyncio.Transport.__bases__[0].__name__=='ReadTransport' (first base in MRO); asyncio.Transport.__module__=='asyncio.transports'; compare MRO lengths: BaseProtocol=2, BaseTransport=2 (shortest), Protocol=3, DatagramProtocol=3, SubprocessProtocol=3, DatagramTransport=3, Transport=5 (longest); NEW in extra107: first standalone Transport MRO length invariant in asyncioproto107 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: asyncio.Transport.__mro__.__len__
  args: []
  expected: 5

invariant asyncio_extra107.DatagramTransport_base_is_BaseTransport:
  description: "asyncio.DatagramTransport.__bases__[0].__name__.__eq__('BaseTransport') returns True — DatagramTransport inherits directly from BaseTransport (not from ReadTransport or WriteTransport), giving MRO [DatagramTransport, BaseTransport, object] (length=3); this distinguishes DatagramTransport from Transport: Transport uses multiple inheritance (ReadTransport + WriteTransport) while DatagramTransport inherits only from BaseTransport; DatagramTransport.__module__=='asyncio.transports'; DatagramTransport.__qualname__=='DatagramTransport' (len=17); DatagramTransport is used for UDP-based transports; NEW in extra107: first standalone DatagramTransport base invariant in asyncioproto107 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "asyncio.DatagramTransport.__bases__[0].__name__.__eq__"
  args: ["BaseTransport"]
  expected: true

invariant asyncio_extra107.SubprocessProtocol_qualname_len_18:
  description: "asyncio.SubprocessProtocol.__qualname__.__len__() == 18 — 'SubprocessProtocol' = 18 chars: 'Subprocess'=10 + 'Protocol'=8 = 18; this is the longest class qualname in this spec; compare qualname lengths: Protocol=8 (shortest), Transport=9, BaseProtocol=12, BaseTransport=13, DatagramProtocol=16, DatagramTransport=17, SubprocessProtocol=18 (longest); asyncio.SubprocessProtocol.__bases__[0].__name__=='BaseProtocol'; asyncio.SubprocessProtocol.__module__=='asyncio.protocols'; SubprocessProtocol defines the interface for subprocess stdin/stdout/stderr transports; NEW in extra107: first standalone SubprocessProtocol qualname length invariant in asyncioproto107 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.SubprocessProtocol.__qualname__.__len__
  args: []
  expected: 18

invariant asyncio_extra107.Protocol_base_is_BaseProtocol:
  description: "asyncio.Protocol.__bases__[0].__name__.__eq__('BaseProtocol') returns True — Protocol inherits from BaseProtocol giving MRO [Protocol, BaseProtocol, object] (length=3); asyncio.DatagramProtocol and asyncio.SubprocessProtocol also each inherit directly from BaseProtocol (all three have MRO length=3); Protocol.__module__=='asyncio.protocols'; Protocol.__qualname__=='Protocol' (len=8, shortest protocol qualname in spec); Protocol adds data_received and eof_received to the BaseProtocol interface; all three direct BaseProtocol subclasses (Protocol, DatagramProtocol, SubprocessProtocol) have the same MRO length; NEW in extra107: first standalone Protocol base invariant in asyncioproto107 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "asyncio.Protocol.__bases__[0].__name__.__eq__"
  args: ["BaseProtocol"]
  expected: true

