invariant multiprocessing_extra115.Pool_co_varnames_len_6:
  description: "multiprocessing.Pool.__code__.co_varnames.__len__() == 6 — co_varnames==('self','processes','initializer','initargs','maxtasksperchild','Pool'): 5 parameters (self, processes, initializer, initargs, maxtasksperchild) plus 1 local variable 'Pool' for the class to instantiate; this is the most co_varnames of any factory method in this spec; multiprocessing.Pool.__code__.co_argcount==5 (the most positional args in spec); multiprocessing.Pool.__code__.co_qualname=='BaseContext.Pool' (len=16); multiprocessing.Pool.__module__=='multiprocessing.context' (len=23); compare co_varnames: Lock==RLock==2 (fewest) < Queue==Pipe==Semaphore==BoundedSemaphore==3 < Value==Array==5 < Pool==6 (most; the extra parameter maxtasksperchild is what pushes it to 6; it limits the number of tasks each worker process executes before being replaced); first standalone Pool co_varnames length invariant in mpnew115 namespace; wave 257; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: Pool.__code__.co_varnames.__len__
  args: []
  expected: 6

invariant multiprocessing_extra115.Lock_co_qualname_len_16:
