    - [bsem_coq_eq,   BoundedSemaphore.__code__.co_qualname.__eq__, ["BaseContext.BoundedSemaphore"], true, "BoundedSemaphore.__code__.co_qualname == 'BaseContext.BoundedSemaphore' (len=28, longest in spec); verified with Python 3.14.3"]
    - [bsem_coq_len,  BoundedSemaphore.__code__.co_qualname.__len__, [],                             28,   "BoundedSemaphore.__code__.co_qualname.__len__() == 28 (longest in spec; 'BaseContext.BoundedSemaphore'=28); verified with Python 3.14.3"]
    - [bsem_co_name,  BoundedSemaphore.__code__.co_name.__eq__,     ["BoundedSemaphore"],            true, "BoundedSemaphore.__code__.co_name == 'BoundedSemaphore' (unqualified, len=16; longest method name); verified with Python 3.14.3"]
