    - [sem_coq_len,   Semaphore.__code__.co_qualname.__len__,       [],                              21,   "Semaphore.__code__.co_qualname.__len__() == 21 ('BaseContext.Semaphore'=21); verified with Python 3.14.3"]
    - [sem_co_name,   Semaphore.__code__.co_name.__eq__,            ["Semaphore"],                   true, "Semaphore.__code__.co_name == 'Semaphore' (unqualified, len=9); verified with Python 3.14.3"]
