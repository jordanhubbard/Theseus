spec: multiprocessing_extra115
version: ">=3.11"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec extends multiprocessing_extra114.zspec.zsdl."
    - "This spec covers: wave 257 theme — multiprocessing.Pool, Lock, RLock, Semaphore, BoundedSemaphore, Value, Array factory method co_qualname and co_varnames.__len__() not covered in extra114. Prior specs covered: extra114 covered Queue/Pipe/Barrier/Event co_qualname and co_varnames; extra112 covered multiprocessing.pool.Pool class method co_qualname (Pool.imap, imap_unordered, map_async, starmap_async). NOT previously covered: Pool/Lock/RLock/Semaphore/BoundedSemaphore/Value/Array as factory method (BaseContext bound methods) co_qualname and co_varnames. NEW in extra115: Pool.__code__.co_qualname=='BaseContext.Pool' (len=16); Lock.__code__.co_qualname=='BaseContext.Lock' (len=16, tied with Pool); RLock.__code__.co_qualname=='BaseContext.RLock' (len=17); Semaphore.__code__.co_qualname=='BaseContext.Semaphore' (len=21); BoundedSemaphore.__code__.co_qualname=='BaseContext.BoundedSemaphore' (len=28, longest); Value.__code__.co_varnames.__len__()==5; Array.__code__.co_varnames.__len__()==5 (tied with Value); Pool.__code__.co_varnames.__len__()==6 (most in spec). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.Pool, Lock, RLock, Semaphore, BoundedSemaphore, Value, Array are bound methods of the default BaseContext instance. Their co_qualname includes the 'BaseContext.' prefix (len=12). Pool co_qualname len=16 ('BaseContext.'=12+'Pool'=4=16). Lock co_qualname len=16 (tied: 'BaseContext.'=12+'Lock'=4=16). RLock co_qualname len=17 ('BaseContext.'=12+'RLock'=5=17). Semaphore co_qualname len=21 ('BaseContext.'=12+'Semaphore'=9=21). BoundedSemaphore co_qualname len=28 ('BaseContext.'=12+'BoundedSemaphore'=16=28, longest). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.Pool.__code__.co_varnames == ('self','processes','initializer','initargs','maxtasksperchild','Pool') — len=6: 5 parameters plus 1 local 'Pool' class variable (most co_varnames in spec). Value.__code__.co_varnames == ('self','typecode_or_type','lock','args','Value') — len=5. Array.__code__.co_varnames == ('self','typecode_or_type','size_or_initializer','lock','Array') — len=5, tied with Value. Lock.__code__.co_varnames == ('self','Lock') — len=2 (tied with RLock: fewest in spec). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing Pool and Lock/RLock factory co_qualname — extra115
#
# Wave 257 theme: Pool, Lock, RLock co_qualname values (not previously covered as factory methods).
#
# multiprocessing.Pool.__code__.co_qualname   == 'BaseContext.Pool'   (len=16, tied with Lock)
# multiprocessing.Lock.__code__.co_qualname   == 'BaseContext.Lock'   (len=16, tied with Pool)
# multiprocessing.RLock.__code__.co_qualname  == 'BaseContext.RLock'  (len=17)
# ---------------------------------------------------------------------------

table multiprocessing_extra115.mp_pool_lock_coqualname:
  description: "multiprocessing Pool, Lock, RLock factory method co_qualname checks in mpnew115 namespace — wave 257 theme: multiprocessing.Pool.__code__.co_qualname.__eq__('BaseContext.Pool')==True (len=16: 'BaseContext.'=12+'Pool'=4=16; Pool is a factory method of BaseContext that creates a multiprocessing.pool.Pool worker pool; co_argcount=5: self, processes, initializer, initargs, maxtasksperchild; co_varnames has 6 entries); multiprocessing.Pool.__code__.co_qualname.__len__()==16; multiprocessing.Pool.__code__.co_name.__eq__('Pool')==True; multiprocessing.Pool.__code__.co_argcount.__eq__(5)==True; multiprocessing.Pool.__code__.co_varnames.__len__()==6 (most co_varnames in spec: 5 params plus 1 local 'Pool' class); multiprocessing.Lock.__code__.co_qualname.__eq__('BaseContext.Lock')==True (len=16: tied with Pool; 'Lock'=4 chars same as 'Pool'=4; Lock creates a non-reentrant process lock); multiprocessing.Lock.__code__.co_qualname.__len__()==16; multiprocessing.Lock.__code__.co_name.__eq__('Lock')==True; multiprocessing.Lock.__code__.co_argcount.__eq__(1)==True (self only; Lock takes no factory arguments); multiprocessing.Lock.__code__.co_varnames.__len__()==2 (fewest in spec: 'self' and 'Lock'; tied with RLock); multiprocessing.RLock.__code__.co_qualname.__eq__('BaseContext.RLock')==True (len=17: 'BaseContext.'=12+'RLock'=5=17; RLock is the reentrant lock; 'RLock'=5 is 1 char longer than 'Lock'=4, hence co_qualname len=17 vs Lock=16); multiprocessing.RLock.__code__.co_qualname.__len__()==17; multiprocessing.RLock.__code__.co_varnames.__len__()==2 (tied with Lock: fewest in spec); compare co_qualname lengths: Pool==Lock==16 (tied, shortest) < RLock=17 < Queue==Event==17 (from extra114) < Barrier=19 (from extra114) < Semaphore=21 < BoundedSemaphore=28 (longest); compare co_varnames: Lock==RLock==2 (fewest) < Queue==Pipe==Semaphore==3 < Value==Array==5 < Pool==6 (most); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: mpnew115

  columns: [id, function, args, expected, description]
  rows:
    - [pool_coq_eq,    Pool.__code__.co_qualname.__eq__,   ["BaseContext.Pool"],  true, "Pool.__code__.co_qualname == 'BaseContext.Pool' (len=16, tied with Lock); verified with Python 3.14.3"]
    - [pool_coq_len,   Pool.__code__.co_qualname.__len__,  [],                   16,   "Pool.__code__.co_qualname.__len__() == 16 ('BaseContext.Pool'=16); verified with Python 3.14.3"]
    - [pool_co_name,   Pool.__code__.co_name.__eq__,       ["Pool"],             true, "Pool.__code__.co_name == 'Pool' (unqualified name, len=4); verified with Python 3.14.3"]
    - [pool_argc,      Pool.__code__.co_argcount.__eq__,   [5],                  true, "Pool.__code__.co_argcount == 5 (self, processes, initializer, initargs, maxtasksperchild; most in spec); verified with Python 3.14.3"]
    - [pool_var_len,   Pool.__code__.co_varnames.__len__,  [],                   6,    "Pool.__code__.co_varnames.__len__() == 6 (5 params + 1 local 'Pool' class; most in spec); verified with Python 3.14.3"]
    - [lock_coq_eq,    Lock.__code__.co_qualname.__eq__,   ["BaseContext.Lock"],  true, "Lock.__code__.co_qualname == 'BaseContext.Lock' (len=16, tied with Pool); verified with Python 3.14.3"]
    - [lock_coq_len,   Lock.__code__.co_qualname.__len__,  [],                   16,   "Lock.__code__.co_qualname.__len__() == 16 (tied with Pool; 'Lock'=4=='Pool'=4); verified with Python 3.14.3"]
    - [lock_co_name,   Lock.__code__.co_name.__eq__,       ["Lock"],             true, "Lock.__code__.co_name == 'Lock' (unqualified, len=4); verified with Python 3.14.3"]
    - [lock_argc,      Lock.__code__.co_argcount.__eq__,   [1],                  true, "Lock.__code__.co_argcount == 1 (self only; Lock takes no factory arguments); verified with Python 3.14.3"]
    - [lock_var_len,   Lock.__code__.co_varnames.__len__,  [],                   2,    "Lock.__code__.co_varnames.__len__() == 2 (fewest in spec: 'self','Lock'; tied with RLock); verified with Python 3.14.3"]
    - [rlock_coq_eq,   RLock.__code__.co_qualname.__eq__,  ["BaseContext.RLock"], true, "RLock.__code__.co_qualname == 'BaseContext.RLock' (len=17, 1 more than Lock=16); verified with Python 3.14.3"]
    - [rlock_coq_len,  RLock.__code__.co_qualname.__len__, [],                   17,   "RLock.__code__.co_qualname.__len__() == 17 ('BaseContext.RLock'=17, 1 more than Pool==Lock=16); verified with Python 3.14.3"]
    - [rlock_var_len,  RLock.__code__.co_varnames.__len__, [],                   2,    "RLock.__code__.co_varnames.__len__() == 2 (fewest in spec: tied with Lock); verified with Python 3.14.3"]

