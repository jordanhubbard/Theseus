spec: hl2911
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib: Secure hashes and message digests"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 641 (hl2911): __ilshift__, __irshift__, __ipow__ dict-presence checks for hashlib types."
    - "hashlib hash classes are cryptographic digest objects, not numeric types — none define in-place left-shift, right-shift, or power operators."
    - "Verified types: type(hashlib.md5()), type(hashlib.sha256()), hashlib.blake2b, hashlib.blake2s."
    - "type(hashlib.md5()) and type(hashlib.sha256()) both yield the C-level HASH type from _hashlib."
    - "hashlib.blake2b and hashlib.blake2s are C extension types exposed directly."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl2911.ilshift:
  description: "hashlib types __ilshift__ dict-presence checks; wave 641"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2911
  columns: [id, function, args, expected]
  rows:
    - ["hl2911001", operator.contains, [type(hashlib.md5()).__dict__,     "__ilshift__"], false]
    - ["hl2911002", operator.contains, [type(hashlib.sha256()).__dict__,  "__ilshift__"], false]
    - ["hl2911003", operator.contains, [hashlib.blake2b.__dict__,         "__ilshift__"], false]
    - ["hl2911004", operator.contains, [hashlib.blake2s.__dict__,         "__ilshift__"], false]

