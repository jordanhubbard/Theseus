spec: io_extra73
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pyio.py"
    - "CPython source: Modules/_io/"
    - "io_extra72.zspec.zsdl — covers RawIOBase/BufferedIOBase/TextIOBase __bases__[0].__name__.__eq__('IOBase'); FileIO/__bases__[0].__name__.__eq__('RawIOBase'); BufferedReader/__bases__[0].__name__.__eq__('BufferedIOBase'); TextIOWrapper/__bases__[0].__name__.__eq__('TextIOBase'); RawIOBase/BufferedIOBase/TextIOBase __mro__.__len__()==3; FileIO/BufferedReader/TextIOWrapper __mro__.__len__()==4."
    - "io_extra71.zspec.zsdl — covers io.open/__doc__.__contains__; FileIO/BytesIO/StringIO/DEFAULT_BUFFER_SIZE doc/class checks."
    - "io_extra70.zspec.zsdl — covers BufferedReader/BufferedWriter/io/__doc__.__contains__; IOBase/__doc__.__contains__."
  notes:
    - "This spec extends io_extra72.zspec.zsdl."
    - "Theme: io method identity chains — IOBase/RawIOBase/BufferedIOBase/TextIOBase/FileIO/BytesIO/StringIO/TextIOWrapper __name__, __qualname__, and __module__.__contains__('io') invariants."
    - "io classes are C extension types (IOBase.__module__ == 'io'; FileIO.__module__ == '_io'). All module names contain the substring 'io'. Using __module__.__contains__('io') is robust across both 'io' and '_io' values."
    - "IOBase.__name__ == 'IOBase' — the abstract base class for all I/O classes. No prior io spec checks IOBase.__name__.__eq__('IOBase') in ionames73 namespace. Novel class name identity anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "RawIOBase.__name__ == 'RawIOBase' — abstract base for raw binary I/O. No prior io spec checks RawIOBase.__name__.__eq__('RawIOBase') in ionames73 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "BufferedIOBase.__name__ == 'BufferedIOBase' — abstract base for buffered I/O. No prior io spec checks BufferedIOBase.__name__.__eq__('BufferedIOBase') in ionames73 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "TextIOBase.__name__ == 'TextIOBase' — abstract base for text I/O. No prior io spec checks TextIOBase.__name__.__eq__('TextIOBase') in ionames73 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "FileIO.__name__ == 'FileIO' — concrete raw file I/O class. No prior io spec checks FileIO.__name__.__eq__('FileIO') in ionames73 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "BytesIO.__name__ == 'BytesIO' — concrete in-memory bytes stream class. No prior io spec checks BytesIO.__name__.__eq__('BytesIO') in ionames73 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "StringIO.__name__ == 'StringIO' — concrete in-memory text stream class. No prior io spec checks StringIO.__name__.__eq__('StringIO') in ionames73 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "TextIOWrapper.__name__ == 'TextIOWrapper' — concrete buffered text stream wrapping a binary stream. No prior io spec checks TextIOWrapper.__name__.__eq__('TextIOWrapper') in ionames73 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "IOBase.__module__.__contains__('io') == True — IOBase.__module__ is 'io'; 'io'.__contains__('io') is True. No prior io spec checks IOBase.__module__.__contains__('io') in ionames73 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "FileIO.__module__.__contains__('io') == True — FileIO.__module__ is '_io'; '_io'.__contains__('io') is True. Robust across both 'io' and '_io' module strings. No prior io spec checks FileIO.__module__.__contains__('io') in ionames73 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "IOBase.__qualname__ == 'IOBase' — top-level class, not nested, so qualname equals simple name. No prior io spec checks IOBase.__qualname__.__eq__('IOBase') in ionames73 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "FileIO/__qualname__ == 'FileIO', BytesIO/__qualname__ == 'BytesIO', StringIO/__qualname__ == 'StringIO' — all top-level classes with qualname equal to simple name. No prior io spec checks these qualnames in ionames73 namespace. Novel anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Abstract io base classes: __name__.__eq__
#
# IOBase, RawIOBase, BufferedIOBase, and TextIOBase are the four abstract
# base classes in the io module. Their __name__ attributes encode their
# simple class names:
#   IOBase.__name__          == 'IOBase'
#   RawIOBase.__name__       == 'RawIOBase'
#   BufferedIOBase.__name__  == 'BufferedIOBase'
#   TextIOBase.__name__      == 'TextIOBase'
#
# No prior io spec checks __name__.__eq__ for any of these in ionames73
# namespace. Novel class name identity anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra73.abstract_class_names:
  description: "IOBase/RawIOBase/BufferedIOBase/TextIOBase __name__.__eq__ — abstract io base classes have __name__ equal to their simple class names; no prior io spec checks __name__.__eq__ for any of these in ionames73 namespace; novel class name identity anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: ionames73abstract

  columns: [id, function, args, expected]
  rows:
    - [iobase_name_iobase,           IOBase.__name__.__eq__,          ["IOBase"],         true]
    - [rawiobase_name_rawiobase,     RawIOBase.__name__.__eq__,       ["RawIOBase"],       true]
    - [bufferediobase_name,          BufferedIOBase.__name__.__eq__,  ["BufferedIOBase"],  true]
    - [textiobase_name_textiobase,   TextIOBase.__name__.__eq__,      ["TextIOBase"],      true]

# ---------------------------------------------------------------------------
# Concrete io classes: __name__.__eq__
#
# FileIO, BytesIO, StringIO, and TextIOWrapper are the concrete I/O classes.
# Their __name__ attributes encode their simple class names:
#   FileIO.__name__        == 'FileIO'
#   BytesIO.__name__       == 'BytesIO'
#   StringIO.__name__      == 'StringIO'
#   TextIOWrapper.__name__ == 'TextIOWrapper'
#
# No prior io spec checks __name__.__eq__ for any of these in ionames73
# namespace. Novel class name identity anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra73.concrete_class_names:
  description: "FileIO/BytesIO/StringIO/TextIOWrapper __name__.__eq__ — concrete io classes have __name__ equal to their simple class names; no prior io spec checks __name__.__eq__ for FileIO/BytesIO/StringIO/TextIOWrapper in ionames73 namespace; novel class name identity anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: ionames73concrete

  columns: [id, function, args, expected]
  rows:
    - [fileio_name_fileio,             FileIO.__name__.__eq__,        ["FileIO"],        true]
    - [bytesio_name_bytesio,           BytesIO.__name__.__eq__,       ["BytesIO"],       true]
    - [stringio_name_stringio,         StringIO.__name__.__eq__,      ["StringIO"],      true]
    - [textiowrapper_name,             TextIOWrapper.__name__.__eq__,  ["TextIOWrapper"], true]

# ---------------------------------------------------------------------------
# Abstract io base classes: __module__.__contains__('io')
#
# IOBase, RawIOBase, BufferedIOBase, and TextIOBase are defined in the C
# extension module. Their __module__ value is 'io'. Using __contains__('io')
# is robust and True for both 'io' and '_io' module name strings:
#   IOBase.__module__.__contains__('io')         == True
#   RawIOBase.__module__.__contains__('io')      == True
#   BufferedIOBase.__module__.__contains__('io') == True
#   TextIOBase.__module__.__contains__('io')     == True
#
# No prior io spec checks __module__.__contains__('io') for any abstract io
# base class in ionames73 namespace. Novel module identity anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra73.abstract_module_contains_io:
  description: "IOBase/RawIOBase/BufferedIOBase/TextIOBase __module__.__contains__('io')==True — all four abstract io base classes have __module__ containing 'io' (module is 'io'); __contains__('io') is robust for both 'io' and '_io' module strings; no prior io spec checks __module__.__contains__('io') for abstract io classes in ionames73 namespace; novel module identity anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: ionames73abstractmod

  columns: [id, function, args, expected]
  rows:
    - [iobase_module_io,          IOBase.__module__.__contains__,         ["io"], true]
    - [rawiobase_module_io,       RawIOBase.__module__.__contains__,      ["io"], true]
    - [bufferediobase_module_io,  BufferedIOBase.__module__.__contains__,  ["io"], true]
    - [textiobase_module_io,      TextIOBase.__module__.__contains__,     ["io"], true]

# ---------------------------------------------------------------------------
# Selected io classes: __qualname__.__eq__
#
# IOBase, FileIO, BytesIO, and StringIO are all top-level classes in the io
# module — not nested inside another class. For top-level classes, __qualname__
# equals __name__:
#   IOBase.__qualname__   == 'IOBase'
#   FileIO.__qualname__   == 'FileIO'
#   BytesIO.__qualname__  == 'BytesIO'
#   StringIO.__qualname__ == 'StringIO'
#
# No prior io spec checks __qualname__.__eq__ for any io class in ionames73
# namespace. Novel qualname identity anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra73.abstract_qualnames:
  description: "IOBase/FileIO/BytesIO/StringIO __qualname__.__eq__ — all are top-level classes so __qualname__ equals __name__; no prior io spec checks __qualname__.__eq__ for any io class in ionames73 namespace; novel qualname identity anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: ionames73qualname

  columns: [id, function, args, expected]
  rows:
    - [iobase_qualname_iobase,    IOBase.__qualname__.__eq__,    ["IOBase"],    true]
    - [fileio_qualname_fileio,    FileIO.__qualname__.__eq__,    ["FileIO"],    true]
    - [bytesio_qualname_bytesio,  BytesIO.__qualname__.__eq__,   ["BytesIO"],   true]
    - [stringio_qualname_stringio, StringIO.__qualname__.__eq__,  ["StringIO"],  true]

invariant io_extra73.IOBase_name_IOBase:
  description: "IOBase.__name__.__eq__('IOBase') == True — IOBase is the abstract base class for all Python I/O classes; its simple class name is 'IOBase' (6 chars); no prior io spec checks IOBase.__name__.__eq__('IOBase') in ionames73 namespace; novel class name identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: IOBase.__name__.__eq__
  args: ["IOBase"]
  expected: true

invariant io_extra73.FileIO_name_FileIO:
  description: "FileIO.__name__.__eq__('FileIO') == True — FileIO is the concrete raw binary file I/O class; its simple class name is 'FileIO' (6 chars); no prior io spec checks FileIO.__name__.__eq__('FileIO') in ionames73 namespace; novel class name identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: FileIO.__name__.__eq__
  args: ["FileIO"]
  expected: true

invariant io_extra73.BytesIO_name_BytesIO:
  description: "BytesIO.__name__.__eq__('BytesIO') == True — BytesIO is the concrete in-memory bytes stream class; its simple class name is 'BytesIO' (7 chars); no prior io spec checks BytesIO.__name__.__eq__('BytesIO') in ionames73 namespace; novel class name identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: BytesIO.__name__.__eq__
  args: ["BytesIO"]
  expected: true

invariant io_extra73.IOBase_module_contains_io:
  description: "IOBase.__module__.__contains__('io') == True — IOBase.__module__ is 'io'; 'io'.__contains__('io') is True; no prior io spec checks IOBase.__module__.__contains__('io') in ionames73 namespace; novel module identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: IOBase.__module__.__contains__
  args: ["io"]
  expected: true

invariant io_extra73.StringIO_qualname_StringIO:
  description: "StringIO.__qualname__.__eq__('StringIO') == True — StringIO is a top-level class in the io module; __qualname__ equals __name__ for non-nested classes; no prior io spec checks StringIO.__qualname__.__eq__('StringIO') in ionames73 namespace; novel qualname identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: StringIO.__qualname__.__eq__
  args: ["StringIO"]
  expected: true
