spec: concurrent_futures_extra22
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures.zspec.zsdl and prior extras through concurrent_futures_extra21.zspec.zsdl."
    - "concurrent_futures_extra20 covers: Future.result/exception/done/cancel/cancelled method qualnames; Executor.submit/map/shutdown."
    - "concurrent_futures_extra21 covers: ThreadPoolExecutor/ProcessPoolExecutor method qualnames; Future.add_done_callback qualname."
    - "NOT yet covered in any prior spec: Future.__repr__.__qualname__ in extra22 namespace."
    - "NOT yet covered: Future.__str__.__qualname__ (inherits object.__str__) in extra22 namespace."
    - "NOT yet covered: Future.running.__qualname__ in extra22 namespace."
    - "NOT yet covered: as_completed/__qualname__ and __module__ in extra22 namespace."
    - "NOT yet covered: wait/__qualname__ and __module__ in extra22 namespace."
    - "NOT yet covered: FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED __class__.__name__ in extra22 namespace."
    - "NOT yet covered: ThreadPoolExecutor.__module__ and ProcessPoolExecutor.__module__ in extra22 namespace."
    - "Future.__repr__.__qualname__ == 'Future.__repr__' — Future defines its own __repr__ (length 15)."
    - "Future.__str__.__qualname__ == 'object.__str__' — inherited from object (length 14)."
    - "Future.running.__qualname__ == 'Future.running' — method on Future class (length 14)."
    - "as_completed.__qualname__ == 'as_completed' — module-level generator function (length 12)."
    - "as_completed.__module__ == 'concurrent.futures._base' — defined in _base (length 24)."
    - "wait.__qualname__ == 'wait' — module-level function (length 4)."
    - "wait.__module__ == 'concurrent.futures._base' — defined in _base (length 24)."
    - "FIRST_COMPLETED.__class__.__name__ == 'str' — the constant is a plain string."
    - "FIRST_EXCEPTION.__class__.__name__ == 'str' — the constant is a plain string."
    - "ALL_COMPLETED.__class__.__name__ == 'str' — the constant is a plain string."
    - "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' — length 25."
    - "ProcessPoolExecutor.__module__ == 'concurrent.futures.process' — length 26."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Future dunder method __qualname__ table — extra22 namespace
#
# Future defines its own __repr__ (qualname 'Future.__repr__', length 15).
# Future.__str__ is inherited from object (qualname 'object.__str__', length 14).
# No prior spec covers Future's dunder method qualnames.
# ---------------------------------------------------------------------------

table concurrent_futures_extra22.future_dunder_qualnames:
  description: "concurrent.futures.Future dunder method __qualname__ values in extra22 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: futdmqn22

  columns: [id, function, args, expected]
  rows:
    - [repr, Future.__repr__.__qualname__.__eq__, ["Future.__repr__"], true]
    - [str,  Future.__str__.__qualname__.__eq__,  ["object.__str__"],  true]

# ---------------------------------------------------------------------------
# Future dunder method __qualname__ length table — extra22 namespace
#
# Lengths: Future.__repr__(15), object.__str__(14).
# ---------------------------------------------------------------------------

table concurrent_futures_extra22.future_dunder_qualname_lengths:
  description: "concurrent.futures.Future dunder method __qualname__ lengths in extra22 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: futdmqnlen22

  columns: [id, function, args, expected]
  rows:
    - [repr, Future.__repr__.__qualname__.__len__, [], 15]
    - [str,  Future.__str__.__qualname__.__len__,  [], 14]

# ---------------------------------------------------------------------------
# Module-level function __qualname__ and __module__ table — extra22 namespace
#
# as_completed and wait are module-level functions in concurrent.futures.
# Both are defined in the private _base submodule. No prior spec checks
# their __qualname__ or __module__ values.
# as_completed.__qualname__ == 'as_completed' (length 12).
# wait.__qualname__ == 'wait' (length 4).
# Both have __module__ == 'concurrent.futures._base' (length 24).
# ---------------------------------------------------------------------------

table concurrent_futures_extra22.module_function_qualnames:
  description: "concurrent.futures module-level function __qualname__ values in extra22 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: mfqn22

  columns: [id, function, args, expected]
  rows:
    - [as_completed_qn, as_completed.__qualname__.__eq__, ["as_completed"], true]
    - [wait_qn,         wait.__qualname__.__eq__,         ["wait"],         true]

# ---------------------------------------------------------------------------
# Module-level function __module__ table — extra22 namespace
#
# Both as_completed and wait have __module__ == 'concurrent.futures._base'.
# ---------------------------------------------------------------------------

table concurrent_futures_extra22.module_function_modules:
  description: "concurrent.futures module-level function __module__ values in extra22 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: mfmod22

  columns: [id, function, args, expected]
  rows:
    - [as_completed, as_completed.__module__.__eq__, ["concurrent.futures._base"], true]
    - [wait,         wait.__module__.__eq__,         ["concurrent.futures._base"], true]

# ---------------------------------------------------------------------------
# FIRST_COMPLETED / FIRST_EXCEPTION / ALL_COMPLETED class name table — extra22
#
# These three constants are plain Python strings (not enums or special types).
# Their __class__.__name__ == 'str'. No prior spec checks this.
# ---------------------------------------------------------------------------

table concurrent_futures_extra22.wait_constant_class_names:
  description: "concurrent.futures wait constant __class__.__name__ values in extra22 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: wcn22

  columns: [id, function, args, expected]
  rows:
    - [FIRST_COMPLETED, FIRST_COMPLETED.__class__.__name__.__eq__, ["str"], true]
    - [FIRST_EXCEPTION, FIRST_EXCEPTION.__class__.__name__.__eq__, ["str"], true]
    - [ALL_COMPLETED,   ALL_COMPLETED.__class__.__name__.__eq__,   ["str"], true]

# ---------------------------------------------------------------------------
# Executor subclass __module__ table — extra22 namespace
#
# No prior spec checks ThreadPoolExecutor.__module__ or
# ProcessPoolExecutor.__module__. They are defined in separate private
# submodules. ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'
# (length 25). ProcessPoolExecutor.__module__ == 'concurrent.futures.process'
# (length 26).
# ---------------------------------------------------------------------------

table concurrent_futures_extra22.executor_modules:
  description: "concurrent.futures Executor subclass __module__ values in extra22 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: execmod22

  columns: [id, function, args, expected]
  rows:
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__module__.__eq__,  ["concurrent.futures.thread"],  true]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__module__.__eq__, ["concurrent.futures.process"], true]

# ---------------------------------------------------------------------------
# Future.running.__qualname__ — standalone extra22 invariant
#
# concurrent_futures_extra20 covers Future.result/exception/done/cancel/
# cancelled qualnames. No prior spec checks Future.running.__qualname__.
# Its value is 'Future.running' (length 14).
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra22.Future.running.qualname_eq:
  description: "concurrent.futures.Future.running.__qualname__ == 'Future.running'"
  category: method_names
  kind: python_call_eq
  function: Future.running.__qualname__.__eq__
  args: ["Future.running"]
  expected: true
