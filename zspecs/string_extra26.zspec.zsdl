spec: string_extra26
version: ">=3.9"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/string.py"
  notes:
    - "This spec extends string_extra25.zspec.zsdl."
    - "Prior specs covered: Template/__name__/__module__/__qualname__, Formatter/__name__/__module__/__qualname__, Template/Formatter __bases__[0].__name__, capwords/__name__, Template.substitute/safe_substitute/__name__, Template.flags==None, Formatter method names and qualnames (format/vformat/parse/get_field/get_value/check_unused_args/format_field/convert_field), Template.__init__.__name__/__qualname__."
    - "This spec covers: string.Template.__module__.__len__(), string.Formatter.__module__.__len__(), string.Template.__name__.__len__(), string.Formatter.__name__.__len__(), string.Template.__qualname__.__len__(), string.Formatter.__qualname__.__len__(), string.capwords.__module__, string.capwords.__qualname__, string.capwords.__module__.__len__(), string.capwords.__name__.__len__(), string.Template.substitute.__qualname__, string.Template.safe_substitute.__qualname__."
    - "string.Template.__module__ == 'string' — length 6. Verified at runtime."
    - "string.Formatter.__module__ == 'string' — length 6. Verified at runtime."
    - "string.Template.__name__ == 'Template' — length 8. Verified at runtime."
    - "string.Formatter.__name__ == 'Formatter' — length 9. Verified at runtime."
    - "string.Template.__qualname__ == 'Template' — length 8. Verified at runtime."
    - "string.Formatter.__qualname__ == 'Formatter' — length 9. Verified at runtime."
    - "string.capwords.__module__ == 'string' — capwords is a module-level function defined in the string module. Verified at runtime."
    - "string.capwords.__qualname__ == 'capwords' — module-level function with simple unqualified qualname. Verified at runtime."
    - "string.capwords.__module__.__len__() == 6 — 'string' has 6 characters. Verified at runtime."
    - "string.capwords.__name__.__len__() == 8 — 'capwords' has 8 characters. Verified at runtime."
    - "string.Template.substitute.__qualname__ == 'Template.substitute' — compound dotted qualname, length 19. Verified at runtime."
    - "string.Template.safe_substitute.__qualname__ == 'Template.safe_substitute' — compound dotted qualname, length 24. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# string.Template.__module__ — __len__()
#
# Prior specs verify Template.__module__ == 'string'. No prior spec verifies
# the length of Template.__module__ as a standalone invariant.
# len('string') == 6. Verified at runtime: 6.
# ---------------------------------------------------------------------------

invariant string_extra26.Template.module_len:
  description: "len(string.Template.__module__) == 6 — 'string' has 6 characters"
  category: class_identity
  kind: python_call_eq
  function: Template.__module__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# string.Formatter.__module__ — __len__()
#
# Prior specs verify Formatter.__module__ == 'string'. No prior spec verifies
# the length of Formatter.__module__ as a standalone invariant.
# len('string') == 6. Verified at runtime: 6.
# ---------------------------------------------------------------------------

invariant string_extra26.Formatter.module_len:
  description: "len(string.Formatter.__module__) == 6 — 'string' has 6 characters"
  category: class_identity
  kind: python_call_eq
  function: Formatter.__module__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# string.Template.__name__ — __len__()
#
# Prior specs verify Template.__name__ == 'Template'. No prior spec verifies
# the length of Template.__name__ as a standalone invariant.
# len('Template') == 8. Verified at runtime: 8.
# ---------------------------------------------------------------------------

invariant string_extra26.Template.name_len:
  description: "len(string.Template.__name__) == 8 — 'Template' has 8 characters"
  category: class_identity
  kind: python_call_eq
  function: Template.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# string.Formatter.__name__ — __len__()
#
# Prior specs verify Formatter.__name__ == 'Formatter'. No prior spec verifies
# the length of Formatter.__name__ as a standalone invariant.
# len('Formatter') == 9. Verified at runtime: 9.
# ---------------------------------------------------------------------------

invariant string_extra26.Formatter.name_len:
  description: "len(string.Formatter.__name__) == 9 — 'Formatter' has 9 characters"
  category: class_identity
  kind: python_call_eq
  function: Formatter.__name__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# string.Template.__qualname__ — __len__()
#
# Prior specs verify Template.__qualname__ == 'Template'. No prior spec verifies
# the length of Template.__qualname__ as a standalone invariant.
# len('Template') == 8. Verified at runtime: 8.
# ---------------------------------------------------------------------------

invariant string_extra26.Template.qualname_len:
  description: "len(string.Template.__qualname__) == 8 — 'Template' has 8 characters"
  category: class_identity
  kind: python_call_eq
  function: Template.__qualname__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# string.Formatter.__qualname__ — __len__()
#
# Prior specs verify Formatter.__qualname__ == 'Formatter'. No prior spec verifies
# the length of Formatter.__qualname__ as a standalone invariant.
# len('Formatter') == 9. Verified at runtime: 9.
# ---------------------------------------------------------------------------

invariant string_extra26.Formatter.qualname_len:
  description: "len(string.Formatter.__qualname__) == 9 — 'Formatter' has 9 characters"
  category: class_identity
  kind: python_call_eq
  function: Formatter.__qualname__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# string.capwords — __module__
#
# Prior specs verify capwords.__name__ == 'capwords'. No prior spec verifies
# capwords.__module__ as a standalone invariant.
# __module__ == 'string'. Verified at runtime: 'string'.
# ---------------------------------------------------------------------------

invariant string_extra26.capwords.module:
  description: "string.capwords.__module__ == 'string' — capwords is defined in the string module"
  category: function_identity
  kind: python_call_eq
  function: capwords.__module__.__eq__
  args: ["string"]
  expected: true

# ---------------------------------------------------------------------------
# string.capwords — __qualname__
#
# No prior spec verifies capwords.__qualname__ as a standalone invariant.
# capwords is a module-level function, so __qualname__ == 'capwords'.
# Verified at runtime: 'capwords'.
# ---------------------------------------------------------------------------

invariant string_extra26.capwords.qualname:
  description: "string.capwords.__qualname__ == 'capwords' — module-level function with simple unqualified qualname"
  category: function_identity
  kind: python_call_eq
  function: capwords.__qualname__.__eq__
  args: ["capwords"]
  expected: true

# ---------------------------------------------------------------------------
# string.capwords.__module__ — __len__()
#
# No prior spec verifies the length of capwords.__module__ as a standalone
# invariant. len('string') == 6. Verified at runtime: 6.
# ---------------------------------------------------------------------------

invariant string_extra26.capwords.module_len:
  description: "len(string.capwords.__module__) == 6 — 'string' has 6 characters"
  category: function_identity
  kind: python_call_eq
  function: capwords.__module__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# string.capwords.__name__ — __len__()
#
# No prior spec verifies the length of capwords.__name__ as a standalone
# invariant. len('capwords') == 8. Verified at runtime: 8.
# ---------------------------------------------------------------------------

invariant string_extra26.capwords.name_len:
  description: "len(string.capwords.__name__) == 8 — 'capwords' has 8 characters"
  category: function_identity
  kind: python_call_eq
  function: capwords.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# string.Template.substitute — __qualname__
#
# Prior specs verify Template.substitute.__name__ == 'substitute'. No prior spec
# verifies Template.substitute.__qualname__ as a standalone invariant.
# __qualname__ == 'Template.substitute' (compound dotted form), length 19.
# Verified at runtime: 'Template.substitute'.
# ---------------------------------------------------------------------------

invariant string_extra26.Template.substitute_qualname:
  description: "string.Template.substitute.__qualname__ == 'Template.substitute' — compound dotted qualname, length 19"
  category: function_identity
  kind: python_call_eq
  function: Template.substitute.__qualname__.__eq__
  args: ["Template.substitute"]
  expected: true

# ---------------------------------------------------------------------------
# string.Template.safe_substitute — __qualname__
#
# Prior specs verify Template.safe_substitute.__name__ == 'safe_substitute'. No
# prior spec verifies Template.safe_substitute.__qualname__ as a standalone
# invariant. __qualname__ == 'Template.safe_substitute' (compound dotted form),
# length 24. Verified at runtime: 'Template.safe_substitute'.
# ---------------------------------------------------------------------------

invariant string_extra26.Template.safe_substitute_qualname:
  description: "string.Template.safe_substitute.__qualname__ == 'Template.safe_substitute' — compound dotted qualname, length 24"
  category: function_identity
  kind: python_call_eq
  function: Template.safe_substitute.__qualname__.__eq__
  args: ["Template.safe_substitute"]
  expected: true

# ---------------------------------------------------------------------------
# Table: Template and Formatter class identifier __len__() values
#
# No prior spec groups the __module__.__len__, __name__.__len__, and
# __qualname__.__len__ checks for Template and Formatter into a single table.
# All values verified at runtime.
# ---------------------------------------------------------------------------

table string_extra26.class_identifier_lengths:
  description: "string.Template and Formatter __module__, __name__, __qualname__ lengths"
  kind: python_call_eq
  category: class_identity
  columns: [id, function, args, expected, description]
  rows:
    - [Template_module_len,
       Template.__module__.__len__,
       [],
       6,
       "len(Template.__module__) == 6"]
    - [Formatter_module_len,
       Formatter.__module__.__len__,
       [],
       6,
       "len(Formatter.__module__) == 6"]
    - [Template_name_len,
       Template.__name__.__len__,
       [],
       8,
       "len(Template.__name__) == 8"]
    - [Formatter_name_len,
       Formatter.__name__.__len__,
       [],
       9,
       "len(Formatter.__name__) == 9"]
    - [Template_qualname_len,
       Template.__qualname__.__len__,
       [],
       8,
       "len(Template.__qualname__) == 8"]
    - [Formatter_qualname_len,
       Formatter.__qualname__.__len__,
       [],
       9,
       "len(Formatter.__qualname__) == 9"]

# ---------------------------------------------------------------------------
# Table: capwords attributes and Template method qualnames
#
# No prior spec groups capwords.__module__, capwords.__qualname__,
# capwords.__module__.__len__, capwords.__name__.__len__, and the qualnames
# of Template.substitute and Template.safe_substitute into a single table.
# All values verified at runtime.
# ---------------------------------------------------------------------------

table string_extra26.capwords_and_method_qualnames:
  description: "string.capwords module/qualname attributes and Template method qualnames"
  kind: python_call_eq
  category: function_identity
  columns: [id, function, args, expected, description]
  rows:
    - [capwords_module,
       capwords.__module__.__eq__,
       ["string"],
       true,
       "capwords.__module__ == 'string'"]
    - [capwords_qualname,
       capwords.__qualname__.__eq__,
       ["capwords"],
       true,
       "capwords.__qualname__ == 'capwords'"]
    - [capwords_module_len,
       capwords.__module__.__len__,
       [],
       6,
       "len(capwords.__module__) == 6"]
    - [capwords_name_len,
       capwords.__name__.__len__,
       [],
       8,
       "len(capwords.__name__) == 8"]
    - [substitute_qualname,
       Template.substitute.__qualname__.__eq__,
       ["Template.substitute"],
       true,
       "Template.substitute.__qualname__ == 'Template.substitute'"]
    - [safe_substitute_qualname,
       Template.safe_substitute.__qualname__.__eq__,
       ["Template.safe_substitute"],
       true,
       "Template.safe_substitute.__qualname__ == 'Template.safe_substitute'"]
