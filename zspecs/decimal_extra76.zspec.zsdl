spec: decimal_extra76
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal.zspec.zsdl and all prior decimal_extra specs through decimal_extra75."
    - "Prior specs covered: Decimal arithmetic; exception class __qualname__; getcontext/setcontext identity; Decimal/__dict__ membership; MAX_PREC/MAX_EMAX; exception hierarchy __bases__ and MRO; Decimal C slot wrapper identity; Context identity; Context/__dict__ membership; exception class __name__ identity; Decimal.__dict__.__contains__ for arithmetic/conversion/comparison dunders; Decimal comparison/equality/hash wrapper_descriptor identity; Context.__dict__ class and membership; getcontext/setcontext __class__.__name__ and __module__; Decimal division/power operator wrapper_descriptor identity and __dict__ membership; Context.__init__/__class__.__name__; Context.sqrt/exp/ln/log10/power __class__.__name__; Context.__dict__.__class__.__name__ and membership; Context.__bases__[0].__name__; Context.__mro__.__len__()."
    - "This spec covers: Decimal.__add__/__qualname__ full string and __len__(); Decimal.__sub__/__qualname__.__len__(); Decimal.__mul__/__qualname__.__len__(); Decimal.__neg__/__qualname__.__len__(); Decimal.__pos__/__qualname__.__len__(); Decimal.__abs__/__qualname__.__len__(); Decimal.__str__/__qualname__.__len__(); Decimal.__repr__/__qualname__.__len__(); Decimal.__hash__/__qualname__.__len__(); Decimal.__bool__/__qualname__.__len__(); Decimal.__int__/__qualname__.__len__(); Decimal.__float__/__qualname__.__len__(); Decimal.__format__/__qualname__.__len__()."
    - "decimal.Decimal.__add__.__qualname__ == 'Decimal.__add__' — full qualname string for the C wrapper_descriptor."
    - "decimal.Decimal.__add__.__qualname__.__len__() == 15 — 'Decimal.__add__' is 15 characters."
    - "decimal.Decimal.__sub__.__qualname__.__len__() == 15 — 'Decimal.__sub__' is 15 characters."
    - "decimal.Decimal.__mul__.__qualname__.__len__() == 15 — 'Decimal.__mul__' is 15 characters."
    - "decimal.Decimal.__neg__.__qualname__.__len__() == 15 — 'Decimal.__neg__' is 15 characters."
    - "decimal.Decimal.__pos__.__qualname__.__len__() == 15 — 'Decimal.__pos__' is 15 characters."
    - "decimal.Decimal.__abs__.__qualname__.__len__() == 15 — 'Decimal.__abs__' is 15 characters."
    - "decimal.Decimal.__str__.__qualname__.__len__() == 15 — 'Decimal.__str__' is 15 characters."
    - "decimal.Decimal.__repr__.__qualname__.__len__() == 16 — 'Decimal.__repr__' is 16 characters."
    - "decimal.Decimal.__hash__.__qualname__.__len__() == 16 — 'Decimal.__hash__' is 16 characters."
    - "decimal.Decimal.__bool__.__qualname__.__len__() == 16 — 'Decimal.__bool__' is 16 characters."
    - "decimal.Decimal.__int__.__qualname__.__len__() == 15 — 'Decimal.__int__' is 15 characters."
    - "decimal.Decimal.__float__.__qualname__.__len__() == 17 — 'Decimal.__float__' is 17 characters."
    - "decimal.Decimal.__format__.__qualname__.__len__() == 18 — 'Decimal.__format__' is 18 characters."
    - "All Decimal dunder methods tested here are wrapper_descriptor instances (C slot wrappers)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal.__add__ __qualname__ full string and length
# Decimal is a C type; __add__ is a wrapper_descriptor (C slot).
# __qualname__ == 'Decimal.__add__' — length 15.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra76.Decimal_add_qualname:
  description: "Decimal.__add__.__qualname__ full string and length"
  kind: python_call_eq
  category: qualname
  id_prefix: decimalextra76

  columns: [id, function, args, expected]
  rows:
    - [add_qualname,     Decimal.__add__.__qualname__.__eq__, ["Decimal.__add__"], true]
    - [add_qualname_len, Decimal.__add__.__qualname__.__len__, [],                 15]

# ---------------------------------------------------------------------------
# Decimal arithmetic dunder __qualname__ lengths: __sub__, __mul__, __neg__, __pos__, __abs__
# All have __qualname__ of the form 'Decimal.__xxx__'; all are wrapper_descriptors.
# __sub__, __mul__, __neg__, __pos__, __abs__ all have length 15.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra76.Decimal_arith_qualname_lens:
  description: "Decimal.__sub__, __mul__, __neg__, __pos__, __abs__ __qualname__ lengths"
  kind: python_call_eq
  category: qualname
  id_prefix: decimalextra76

  columns: [id, function, args, expected]
  rows:
    - [sub_qualname_len, Decimal.__sub__.__qualname__.__len__, [], 15]
    - [mul_qualname_len, Decimal.__mul__.__qualname__.__len__, [], 15]
    - [neg_qualname_len, Decimal.__neg__.__qualname__.__len__, [], 15]
    - [pos_qualname_len, Decimal.__pos__.__qualname__.__len__, [], 15]
    - [abs_qualname_len, Decimal.__abs__.__qualname__.__len__, [], 15]

# ---------------------------------------------------------------------------
# Decimal string/repr/hash/bool dunder __qualname__ lengths
# __str__: length 15 ('Decimal.__str__')
# __repr__: length 16 ('Decimal.__repr__')
# __hash__: length 16 ('Decimal.__hash__')
# __bool__: length 16 ('Decimal.__bool__')
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra76.Decimal_str_repr_hash_bool_qualname_lens:
  description: "Decimal.__str__, __repr__, __hash__, __bool__ __qualname__ lengths"
  kind: python_call_eq
  category: qualname
  id_prefix: decimalextra76

  columns: [id, function, args, expected]
  rows:
    - [str_qualname_len,  Decimal.__str__.__qualname__.__len__,  [], 15]
    - [repr_qualname_len, Decimal.__repr__.__qualname__.__len__, [], 16]
    - [hash_qualname_len, Decimal.__hash__.__qualname__.__len__, [], 16]
    - [bool_qualname_len, Decimal.__bool__.__qualname__.__len__, [], 16]

# ---------------------------------------------------------------------------
# Decimal numeric conversion dunder __qualname__ lengths
# __int__: length 15 ('Decimal.__int__')
# __float__: length 17 ('Decimal.__float__')
# __format__: length 18 ('Decimal.__format__')
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra76.Decimal_int_float_format_qualname_lens:
  description: "Decimal.__int__, __float__, __format__ __qualname__ lengths"
  kind: python_call_eq
  category: qualname
  id_prefix: decimalextra76

  columns: [id, function, args, expected]
  rows:
    - [int_qualname_len,    Decimal.__int__.__qualname__.__len__,    [], 15]
    - [float_qualname_len,  Decimal.__float__.__qualname__.__len__,  [], 17]
    - [format_qualname_len, Decimal.__format__.__qualname__.__len__, [], 18]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra76.Decimal_add.qualname:
  description: "decimal.Decimal.__add__.__qualname__ == 'Decimal.__add__' (C wrapper_descriptor qualname)"
  category: qualname
  kind: python_call_eq
  function: Decimal.__add__.__qualname__.__eq__
  args: ["Decimal.__add__"]
  expected: true

invariant decimal_extra76.Decimal_add.qualname_len:
  description: "decimal.Decimal.__add__.__qualname__.__len__() == 15 ('Decimal.__add__' has 15 chars)"
  category: qualname
  kind: python_call_eq
  function: Decimal.__add__.__qualname__.__len__
  args: []
  expected: 15

invariant decimal_extra76.Decimal_repr.qualname_len:
  description: "decimal.Decimal.__repr__.__qualname__.__len__() == 16 ('Decimal.__repr__' has 16 chars)"
  category: qualname
  kind: python_call_eq
  function: Decimal.__repr__.__qualname__.__len__
  args: []
  expected: 16

invariant decimal_extra76.Decimal_float.qualname_len:
  description: "decimal.Decimal.__float__.__qualname__.__len__() == 17 ('Decimal.__float__' has 17 chars)"
  category: qualname
  kind: python_call_eq
  function: Decimal.__float__.__qualname__.__len__
  args: []
  expected: 17

invariant decimal_extra76.Decimal_format.qualname_len:
  description: "decimal.Decimal.__format__.__qualname__.__len__() == 18 ('Decimal.__format__' has 18 chars)"
  category: qualname
  kind: python_call_eq
  function: Decimal.__format__.__qualname__.__len__
  args: []
  expected: 18
