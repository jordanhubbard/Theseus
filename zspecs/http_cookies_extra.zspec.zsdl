spec: http_cookies_extra
version: ">=3.0"
backend: python_module(http.cookies)

docs: https://docs.python.org/3/library/http.cookies.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/http.cookies.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/cookies.py"
  notes:
    - "This spec extends http_cookies.zspec.zsdl."
    - "http_cookies.zspec.zsdl already covers: BaseCookie/SimpleCookie/Morsel/CookieError __name__ (table), SimpleCookie().__len__(), Morsel default attributes (key/value/coded_value), Morsel._reserved checks, _LegalKeyChars/_LegalChars type, CookieError issubclass/issubclass."
    - "This spec adds: __qualname__ checks for all four public classes, __module__ checks for SimpleCookie and CookieError, CookieError.__bases__[0].__name__, and a SimpleCookie class-name behavioral invariant via method_chain."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — all four public http.cookies classes
# (http_cookies.zspec.zsdl covers __name__ but NOT __qualname__)
# ---------------------------------------------------------------------------

table http_cookies_extra.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [SimpleCookie, SimpleCookie.__qualname__.__eq__, ["SimpleCookie"], true]
    - [Morsel,       Morsel.__qualname__.__eq__,       ["Morsel"],       true]
    - [CookieError,  CookieError.__qualname__.__eq__,  ["CookieError"],  true]
    - [BaseCookie,   BaseCookie.__qualname__.__eq__,   ["BaseCookie"],   true]

# ---------------------------------------------------------------------------
# __module__ checks — verify classes are defined in http.cookies
# ---------------------------------------------------------------------------

invariant http_cookies_extra.SimpleCookie.module:
  description: "http.cookies.SimpleCookie.__module__ == 'http.cookies'"
  category: modules
  kind: python_call_eq
  function: SimpleCookie.__module__.__eq__
  args: ["http.cookies"]
  expected: true

invariant http_cookies_extra.CookieError.module:
  description: "http.cookies.CookieError.__module__ == 'http.cookies'"
  category: modules
  kind: python_call_eq
  function: CookieError.__module__.__eq__
  args: ["http.cookies"]
  expected: true

# ---------------------------------------------------------------------------
# CookieError hierarchy — direct base is Exception
# (http_cookies.zspec.zsdl checks issubclass(CookieError, Exception) == True
#  but does NOT check __bases__[0].__name__ directly)
# ---------------------------------------------------------------------------

invariant http_cookies_extra.CookieError.base_is_Exception:
  description: "http.cookies.CookieError.__bases__[0].__name__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: CookieError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# Behavioral — SimpleCookie().__class__.__name__ == 'SimpleCookie'
# Uses method_chain in an invariant block (allowed here; NOT in table rows)
# ---------------------------------------------------------------------------

invariant http_cookies_extra.SimpleCookie.class_name_via_chain:
  description: "http.cookies.SimpleCookie().__class__.__name__ == 'SimpleCookie'"
  category: SimpleCookie
  kind: python_call_eq
  function: SimpleCookie
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["SimpleCookie"]
  expected: true
