spec: io_extra520
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Checks __name__ identity for RawIOBase, BufferedIOBase, and TextIOBase methods"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra520.rawiobase_method_names:
  description: "io.RawIOBase method __name__ identity"
  kind: python_call_eq
  category: method_names
  id_prefix: io520rn

  columns: [id, function, args, expected]
  rows:
    - [io520rn001, io.RawIOBase.read.__name__.__eq__,     ["read"],     true]
    - [io520rn002, io.RawIOBase.readall.__name__.__eq__,  ["readall"],  true]
    - [io520rn003, io.RawIOBase.readinto.__name__.__eq__, ["readinto"], true]
    - [io520rn004, io.RawIOBase.write.__name__.__eq__,    ["write"],    true]

table io_extra520.bufferediobase_method_names:
  description: "io.BufferedIOBase method __name__ identity"
  kind: python_call_eq
  category: method_names
  id_prefix: io520bn

  columns: [id, function, args, expected]
  rows:
    - [io520bn001, io.BufferedIOBase.read.__name__.__eq__,       ["read"],       true]
    - [io520bn002, io.BufferedIOBase.read1.__name__.__eq__,      ["read1"],      true]
    - [io520bn003, io.BufferedIOBase.readinto.__name__.__eq__,   ["readinto"],   true]
    - [io520bn004, io.BufferedIOBase.readinto1.__name__.__eq__,  ["readinto1"],  true]
    - [io520bn005, io.BufferedIOBase.write.__name__.__eq__,      ["write"],      true]
    - [io520bn006, io.BufferedIOBase.detach.__name__.__eq__,     ["detach"],     true]

table io_extra520.textiobase_method_names:
  description: "io.TextIOBase method __name__ identity"
  kind: python_call_eq
  category: method_names
  id_prefix: io520tn

  columns: [id, function, args, expected]
  rows:
    - [io520tn001, io.TextIOBase.read.__name__.__eq__,     ["read"],     true]
    - [io520tn002, io.TextIOBase.readline.__name__.__eq__, ["readline"], true]
    - [io520tn003, io.TextIOBase.write.__name__.__eq__,    ["write"],    true]
    - [io520tn004, io.TextIOBase.seek.__name__.__eq__,     ["seek"],     true]
    - [io520tn005, io.TextIOBase.tell.__name__.__eq__,     ["tell"],     true]
