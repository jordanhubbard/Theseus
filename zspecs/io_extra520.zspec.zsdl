spec: io_extra520
backend: python_module(io)

---

table:
  id: rawiobase_method_names
  description: io.RawIOBase method name identity
  columns: [id, function, expected]
  rows:
    - [rawiobase_read_name,     io.RawIOBase.read.__name__.__eq__,    read]
    - [rawiobase_readall_name,  io.RawIOBase.readall.__name__.__eq__,  readall]
    - [rawiobase_readinto_name, io.RawIOBase.readinto.__name__.__eq__, readinto]
    - [rawiobase_write_name,    io.RawIOBase.write.__name__.__eq__,    write]
  kind: python_call_eq

