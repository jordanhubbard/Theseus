spec: inspect_extra1606
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __slots__ and slot descriptor protocol"
    - "inspect.Parameter defines __slots__ = ('_name', '_kind', '_default', '_annotation'); each slot creates a member_descriptor in Parameter.__dict__"
    - "inspect.BoundArguments defines __slots__ = ('arguments', '_signature', '__weakref__'); slot descriptors appear in BoundArguments.__dict__"
    - "inspect.Signature defines __slots__ = ('_return_annotation', '_parameters'); slot descriptors appear in Signature.__dict__"
    - "Public attribute access (name, kind, default, annotation) for Parameter is via property descriptors, not slot descriptors directly"
    - "inspect._ParameterKind is an IntEnum subclass; it does NOT define __slots__ and has no per-instance __dict__ (enum restriction)"
  created_at: "2026-04-12"
error_model: python_exceptions

table inspect_extra1606.parameter_slots:
  description: "inspect.Parameter defines __slots__ with four private slot names; each appears as member_descriptor in Parameter.__dict__; public names are properties"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1606pa

  columns: [id, function, args, expected]
  rows:
    - ["in1606pa001", "inspect.Parameter.__dict__.__contains__", ["__slots__"],     true]
    - ["in1606pa002", "inspect.Parameter.__dict__.__contains__", ["_name"],         true]
    - ["in1606pa003", "inspect.Parameter.__dict__.__contains__", ["_kind"],         true]
    - ["in1606pa004", "inspect.Parameter.__dict__.__contains__", ["_default"],      true]
    - ["in1606pa005", "inspect.Parameter.__dict__.__contains__", ["_annotation"],   true]
    - ["in1606pa006", "inspect.Parameter.__dict__.__contains__", ["__dict__"],      false]
    - ["in1606pa007", "inspect.Parameter.__dict__.__contains__", ["__weakref__"],   false]
    - ["in1606pa008", "inspect.Parameter.__dict__.__contains__", ["name"],          true]
    - ["in1606pa009", "inspect.Parameter.__dict__.__contains__", ["kind"],          true]
    - ["in1606pa010", "inspect.Parameter.__dict__.__contains__", ["default"],       true]
    - ["in1606pa011", "inspect.Parameter.__dict__.__contains__", ["annotation"],    true]
    - ["in1606pa012", "inspect.Parameter.__dict__.__contains__", ["POSITIONAL_ONLY"],     true]
    - ["in1606pa013", "inspect.Parameter.__dict__.__contains__", ["POSITIONAL_OR_KEYWORD"], true]
    - ["in1606pa014", "inspect.Parameter.__dict__.__contains__", ["VAR_POSITIONAL"],      true]
    - ["in1606pa015", "inspect.Parameter.__dict__.__contains__", ["KEYWORD_ONLY"],        true]
    - ["in1606pa016", "inspect.Parameter.__dict__.__contains__", ["VAR_KEYWORD"],         true]
    - ["in1606pa017", "inspect.Parameter.__dict__.__contains__", ["empty"],         true]
    - ["in1606pa018", "inspect.Parameter.__dict__.__contains__", ["replace"],       true]
    - ["in1606pa019", "inspect.Parameter.__dict__.__contains__", ["__init__"],      true]
    - ["in1606pa020", "inspect.Parameter.__dict__.__contains__", ["__repr__"],      true]
    - ["in1606pa021", "inspect.Parameter.__dict__.__contains__", ["__str__"],       true]
    - ["in1606pa022", "inspect.Parameter.__dict__.__contains__", ["__eq__"],        true]
    - ["in1606pa023", "inspect.Parameter.__dict__.__contains__", ["__hash__"],      true]
    - ["in1606pa024", "inspect.Parameter.__dict__.__contains__", ["__reduce__"],    true]
    - ["in1606pa025", "inspect.Parameter.__dict__.__contains__", ["__setstate__"],  true]
    - ["in1606pa026", "inspect.Parameter.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
    - ["in1606pa027", "inspect.Parameter.__name__.__eq__",   ["Parameter"],  true]
    - ["in1606pa028", "inspect.Parameter.__module__.__eq__", ["inspect"],    true]
    - ["in1606pa029", "inspect.Parameter.__class__.__name__.__eq__", ["type"], true]
    - ["in1606pa030", "inspect.Parameter.__bases__.__len__", [], 1]

