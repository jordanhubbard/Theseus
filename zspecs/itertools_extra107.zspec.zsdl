spec: itertools_extra107
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra106.zspec.zsdl."
    - "This spec covers: itertools type __module__ equality (all C-extension types report __module__ == 'itertools', not '_itertools'); and __qualname__ string equality for all 18 itertools types (__qualname__ equals __name__ for all top-level C types); wave 260."
    - "itertools.count.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.cycle.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.repeat.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.chain.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.compress.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.dropwhile.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.takewhile.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.islice.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.starmap.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.product.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.permutations.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.combinations.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.accumulate.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.groupby.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.zip_longest.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.filterfalse.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.pairwise.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "All 18 itertools C-extension type __qualname__ values equal their __name__ (top-level types have __qualname__ == __name__). Verified with Python 3.14.3."
    - "Note: itertools C-extension types report __module__ == 'itertools' (the public module name), not '_itertools' (the underlying C extension module). This is different from _functools where e.g. functools.reduce.__module__ == '_functools'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools type __module__ equality (group 1)
#
# Wave 260 theme: all itertools C-extension types report __module__ as
# 'itertools' (the public module name), not '_itertools'. This is an
# important distinction from some other modules where C-extension types
# report the private underlying C module name. This table covers the first
# 10 types: count, cycle, repeat, chain, compress, dropwhile, takewhile,
# islice, starmap, product.
#
# itertools.count.__module__ == 'itertools'
# itertools.cycle.__module__ == 'itertools'
# itertools.repeat.__module__ == 'itertools'
# itertools.chain.__module__ == 'itertools'
# itertools.compress.__module__ == 'itertools'
# itertools.dropwhile.__module__ == 'itertools'
# itertools.takewhile.__module__ == 'itertools'
# itertools.islice.__module__ == 'itertools'
# itertools.starmap.__module__ == 'itertools'
# itertools.product.__module__ == 'itertools'
#
# New to extra107.
# ---------------------------------------------------------------------------

table itertools_extra107.module_group1:
  description: "itertools C-extension type __module__ equality for count/cycle/repeat/chain/compress/dropwhile/takewhile/islice/starmap/product; all __module__ == 'itertools' (not '_itertools'); wave 260; new to extra107"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsmod107

  columns: [id, function, args, expected, description]
  rows:
    - [count_module_eq,
       "count.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.count.__module__.__eq__('itertools') == True — itertools.count is a C extension type; its __module__ is 'itertools' (the public module name, not '_itertools'); str.__eq__('itertools') returns True; new to extra107"]
    - [cycle_module_eq,
       "cycle.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.cycle.__module__.__eq__('itertools') == True — itertools.cycle is a C extension type; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra107"]
    - [repeat_module_eq,
       "repeat.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.repeat.__module__.__eq__('itertools') == True — itertools.repeat is a C extension type; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra107"]
    - [chain_module_eq,
       "chain.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.chain.__module__.__eq__('itertools') == True — itertools.chain is a C extension type; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra107"]
    - [compress_module_eq,
       "compress.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.compress.__module__.__eq__('itertools') == True — itertools.compress is a C extension type; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra107"]
    - [dropwhile_module_eq,
       "dropwhile.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.dropwhile.__module__.__eq__('itertools') == True — itertools.dropwhile is a C extension type; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra107"]
    - [takewhile_module_eq,
       "takewhile.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.takewhile.__module__.__eq__('itertools') == True — itertools.takewhile is a C extension type; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra107"]
    - [islice_module_eq,
       "islice.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.islice.__module__.__eq__('itertools') == True — itertools.islice is a C extension type; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra107"]
    - [starmap_module_eq,
       "starmap.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.starmap.__module__.__eq__('itertools') == True — itertools.starmap is a C extension type; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra107"]
    - [product_module_eq,
       "product.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.product.__module__.__eq__('itertools') == True — itertools.product is a C extension type; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra107"]

# ---------------------------------------------------------------------------
# Table 2: itertools type __module__ equality (group 2)
#
# Wave 260 theme: remaining 8 itertools C-extension types, all reporting
# __module__ == 'itertools'. This includes combinations_with_replacement
# which has the longest name in the module.
#
# itertools.permutations.__module__ == 'itertools'
# itertools.combinations.__module__ == 'itertools'
# itertools.combinations_with_replacement.__module__ == 'itertools'
# itertools.accumulate.__module__ == 'itertools'
# itertools.groupby.__module__ == 'itertools'
# itertools.zip_longest.__module__ == 'itertools'
# itertools.filterfalse.__module__ == 'itertools'
# itertools.pairwise.__module__ == 'itertools'
#
# New to extra107.
# ---------------------------------------------------------------------------

table itertools_extra107.module_group2:
  description: "itertools C-extension type __module__ equality for permutations/combinations/combinations_with_replacement/accumulate/groupby/zip_longest/filterfalse/pairwise; all __module__ == 'itertools'; wave 260; new to extra107"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsmod2107

  columns: [id, function, args, expected, description]
  rows:
    - [permutations_module_eq,
       "permutations.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.permutations.__module__.__eq__('itertools') == True — itertools.permutations is a C extension type; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra107"]
    - [combinations_module_eq,
       "combinations.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.combinations.__module__.__eq__('itertools') == True — itertools.combinations is a C extension type; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra107"]
    - ["combinations_with_replacement_module_eq",
       "combinations_with_replacement.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.combinations_with_replacement.__module__.__eq__('itertools') == True — itertools.combinations_with_replacement is a C extension type; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra107"]
    - [accumulate_module_eq,
       "accumulate.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.accumulate.__module__.__eq__('itertools') == True — itertools.accumulate is a C extension type; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra107"]
    - [groupby_module_eq,
       "groupby.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.groupby.__module__.__eq__('itertools') == True — itertools.groupby is a C extension type; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra107"]
    - [zip_longest_module_eq,
       "zip_longest.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.zip_longest.__module__.__eq__('itertools') == True — itertools.zip_longest is a C extension type; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra107"]
    - [filterfalse_module_eq,
       "filterfalse.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.filterfalse.__module__.__eq__('itertools') == True — itertools.filterfalse is a C extension type; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra107"]
    - [pairwise_module_eq,
       "pairwise.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.pairwise.__module__.__eq__('itertools') == True — itertools.pairwise is a C extension type added in Python 3.10; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra107"]

# ---------------------------------------------------------------------------
# Table 3: itertools type __qualname__ equality for selected types
#
# Wave 260 theme: for all itertools C-extension types, __qualname__ equals
# __name__ because they are all top-level types (not nested inside another
# class). This table verifies __qualname__ directly for 8 selected types
# covering the full spread of the module.
#
# itertools.count.__qualname__ == 'count'
# itertools.repeat.__qualname__ == 'repeat'
# itertools.islice.__qualname__ == 'islice'
# itertools.product.__qualname__ == 'product'
# itertools.permutations.__qualname__ == 'permutations'
# itertools.combinations_with_replacement.__qualname__ == 'combinations_with_replacement'
# itertools.groupby.__qualname__ == 'groupby'
# itertools.zip_longest.__qualname__ == 'zip_longest'
#
# New to extra107.
# ---------------------------------------------------------------------------

table itertools_extra107.qualname_group:
  description: "itertools C-extension type __qualname__ string equality for count/repeat/islice/product/permutations/combinations_with_replacement/groupby/zip_longest; __qualname__ equals __name__ for all top-level types; wave 260; new to extra107"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsqn107

  columns: [id, function, args, expected, description]
  rows:
    - [count_qualname_eq,
       "count.__qualname__.__eq__",
       ["count"],
       true,
       "itertools.count.__qualname__.__eq__('count') == True — itertools.count is a top-level C extension type; __qualname__ equals __name__ equals 'count' for top-level types (not nested inside another class); str.__eq__('count') returns True; new to extra107"]
    - [repeat_qualname_eq,
       "repeat.__qualname__.__eq__",
       ["repeat"],
       true,
       "itertools.repeat.__qualname__.__eq__('repeat') == True — itertools.repeat is a top-level C extension type; __qualname__ equals __name__ equals 'repeat'; str.__eq__('repeat') returns True; new to extra107"]
    - [islice_qualname_eq,
       "islice.__qualname__.__eq__",
       ["islice"],
       true,
       "itertools.islice.__qualname__.__eq__('islice') == True — itertools.islice is a top-level C extension type; __qualname__ equals __name__ equals 'islice'; str.__eq__('islice') returns True; new to extra107"]
    - [product_qualname_eq,
       "product.__qualname__.__eq__",
       ["product"],
       true,
       "itertools.product.__qualname__.__eq__('product') == True — itertools.product is a top-level C extension type; __qualname__ equals __name__ equals 'product'; str.__eq__('product') returns True; new to extra107"]
    - [permutations_qualname_eq,
       "permutations.__qualname__.__eq__",
       ["permutations"],
       true,
       "itertools.permutations.__qualname__.__eq__('permutations') == True — itertools.permutations is a top-level C extension type; __qualname__ equals __name__ equals 'permutations'; str.__eq__('permutations') returns True; new to extra107"]
    - ["combinations_with_replacement_qualname_eq",
       "combinations_with_replacement.__qualname__.__eq__",
       ["combinations_with_replacement"],
       true,
       "itertools.combinations_with_replacement.__qualname__.__eq__('combinations_with_replacement') == True — itertools.combinations_with_replacement is a top-level C extension type; __qualname__ equals __name__ equals 'combinations_with_replacement'; str.__eq__('combinations_with_replacement') returns True; new to extra107"]
    - [groupby_qualname_eq,
       "groupby.__qualname__.__eq__",
       ["groupby"],
       true,
       "itertools.groupby.__qualname__.__eq__('groupby') == True — itertools.groupby is a top-level C extension type; __qualname__ equals __name__ equals 'groupby'; str.__eq__('groupby') returns True; new to extra107"]
    - [zip_longest_qualname_eq,
       "zip_longest.__qualname__.__eq__",
       ["zip_longest"],
       true,
       "itertools.zip_longest.__qualname__.__eq__('zip_longest') == True — itertools.zip_longest is a top-level C extension type; __qualname__ equals __name__ equals 'zip_longest' (with underscore); str.__eq__('zip_longest') returns True; new to extra107"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra107
# ---------------------------------------------------------------------------

invariant itertools_extra107.count_module:
  description: "itertools.count.__module__ == 'itertools' — C-extension type module is 'itertools' (not '_itertools'); wave 260; new to extra107"
  kind: python_call_eq
  function: count.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra107.combinations_with_replacement_module:
  description: "itertools.combinations_with_replacement.__module__ == 'itertools' — longest type name; module is 'itertools'; wave 260; new to extra107"
  kind: python_call_eq
  function: combinations_with_replacement.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra107.pairwise_module:
  description: "itertools.pairwise.__module__ == 'itertools' — added in Python 3.10; module is 'itertools'; wave 260; new to extra107"
  kind: python_call_eq
  function: pairwise.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra107.product_qualname:
  description: "itertools.product.__qualname__ == 'product' — top-level type so __qualname__ equals __name__; wave 260; new to extra107"
  kind: python_call_eq
  function: product.__qualname__.__eq__
  args: ["product"]
  expected: true

invariant itertools_extra107.groupby_qualname:
  description: "itertools.groupby.__qualname__ == 'groupby' — top-level type so __qualname__ equals __name__; wave 260; new to extra107"
  kind: python_call_eq
  function: groupby.__qualname__.__eq__
  args: ["groupby"]
  expected: true
