spec: threading_extra2701
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/threading.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 627 theme: __lshift__, __rshift__, and __invert__ dict-presence checks (bit-shift left/right and bitwise NOT)."
    - "threading.Thread is a runnable object; it does not define bit-shift or bitwise NOT protocols."
    - "threading.Lock (accessed as threading.Lock, actual type is _thread.lock) is a synchronization primitive; it defines acquire/release but not __lshift__, __rshift__, or __invert__."
    - "threading.Event, threading.Condition, threading.Semaphore, threading.BoundedSemaphore are synchronization primitives; none define __lshift__, __rshift__, or __invert__."
    - "threading.Timer is a Thread subclass for deferred execution; it defines none of these bit-shift or bitwise NOT protocols."
    - "threading.Barrier is a synchronization barrier; it does not define __lshift__, __rshift__, or __invert__."
    - "threading.local is a thread-local storage object; it does not define bit-shift or bitwise NOT protocols."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __lshift__ dict-presence — absent from all threading synchronization types
# ---------------------------------------------------------------------------

table threading_extra2701.lshift_protocol:
  description: "__lshift__ is absent from all threading type __dict__s — synchronization primitives do not implement bit-shift left"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2701

  columns: [id, function, args, expected]
  rows:
    - ["th2701001", "threading.Thread.__dict__.__contains__",           ["__lshift__"], false]
    - ["th2701002", "threading.Lock.__dict__.__contains__",             ["__lshift__"], false]
    - ["th2701003", "threading.Event.__dict__.__contains__",            ["__lshift__"], false]
    - ["th2701004", "threading.Condition.__dict__.__contains__",        ["__lshift__"], false]
    - ["th2701005", "threading.Semaphore.__dict__.__contains__",        ["__lshift__"], false]
    - ["th2701006", "threading.BoundedSemaphore.__dict__.__contains__", ["__lshift__"], false]
    - ["th2701007", "threading.Timer.__dict__.__contains__",            ["__lshift__"], false]
    - ["th2701008", "threading.Barrier.__dict__.__contains__",          ["__lshift__"], false]
    - ["th2701009", "threading.local.__dict__.__contains__",            ["__lshift__"], false]

