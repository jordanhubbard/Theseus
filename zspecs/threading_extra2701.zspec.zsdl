# ---------------------------------------------------------------------------
# Combined per-type view — Thread, Barrier, and Timer vs. all three protocols
# ---------------------------------------------------------------------------

table threading_extra2701.thread_barrier_combined:
  description: "threading.Thread, threading.Barrier, and threading.Timer define none of __lshift__, __rshift__, __invert__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2701

  columns: [id, function, args, expected]
  rows:
    - ["th2701028", "threading.Thread.__dict__.__contains__",  ["__lshift__"],  false]
    - ["th2701029", "threading.Thread.__dict__.__contains__",  ["__rshift__"],  false]
