spec: re_extra1816
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "re module CPython source"
    - "Python data model documentation"
  not_derived_from:
    - "any third-party regex library"
  notes:
    - "Tests __format__, __repr__, __str__, __reduce__, __copy__, __deepcopy__ presence in class __dict__"
    - "Tests re.error exception attrs"
  created_at: "2026-04-12"

table re_extra1816.format_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["re1816-fp-001", "re.Pattern.__dict__.__contains__", ["__format__"], false]
    - ["re1816-fp-002", "re.Pattern.__dict__.__contains__", ["__repr__"], true]
    - ["re1816-fp-003", "re.Pattern.__dict__.__contains__", ["__str__"], false]
    - ["re1816-fp-004", "re.Match.__dict__.__contains__", ["__format__"], false]
    - ["re1816-fp-005", "re.Match.__dict__.__contains__", ["__repr__"], true]
    - ["re1816-fp-006", "re.Match.__dict__.__contains__", ["__str__"], false]
    - ["re1816-fp-007", "re.error.__dict__.__contains__", ["__format__"], false]
    - ["re1816-fp-008", "re.error.__dict__.__contains__", ["__repr__"], false]

table re_extra1816.copy_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["re1816-cp-001", "re.Pattern.__dict__.__contains__", ["__reduce__"], true]
    - ["re1816-cp-002", "re.Pattern.__dict__.__contains__", ["__copy__"], true]
    - ["re1816-cp-003", "re.Pattern.__dict__.__contains__", ["__deepcopy__"], true]
    - ["re1816-cp-004", "re.Match.__dict__.__contains__", ["__reduce__"], false]
    - ["re1816-cp-005", "re.Match.__dict__.__contains__", ["__copy__"], true]
    - ["re1816-cp-006", "re.Match.__dict__.__contains__", ["__deepcopy__"], true]
    - ["re1816-cp-007", "re.error.__dict__.__contains__", ["__reduce__"], false]
    - ["re1816-cp-008", "re.error.__dict__.__contains__", ["__copy__"], false]

table re_extra1816.error_attrs:
  columns: [id, function, args, expected]
  rows:
    - ["re1816-ea-001", "re.error.__dict__.__contains__", ["__init__"], true]
    - ["re1816-ea-002", "re.error.__dict__.__contains__", ["msg"], false]
    - ["re1816-ea-003", "re.error.__dict__.__contains__", ["pattern"], false]
    - ["re1816-ea-004", "re.error.__dict__.__contains__", ["pos"], false]
    - ["re1816-ea-005", "re.error.__dict__.__contains__", ["lineno"], false]
    - ["re1816-ea-006", "re.error.__dict__.__contains__", ["colno"], false]
    - ["re1816-ea-007", "re.error.__dict__.__contains__", ["__doc__"], true]
    - ["re1816-ea-008", "re.error.__dict__.__contains__", ["__module__"], true]
    - ["re1816-ea-009", "re.error.__dict__.__contains__", ["__weakref__"], true]
    - ["re1816-ea-010", "re.Pattern.__dict__.__contains__", ["__reduce__"], true]
