    - [it916ac002, itertools.accumulate.__name__.__eq__,      ["accumulate"],  true]
    - [it916ac003, itertools.accumulate.__module__.__eq__,    ["itertools"],   true]
    - [it916ac004, itertools.compress.__qualname__.__eq__,    ["compress"],    true]
    - [it916ac005, itertools.compress.__name__.__eq__,        ["compress"],    true]
    - [it916ac006, itertools.compress.__module__.__eq__,      ["itertools"],   true]

