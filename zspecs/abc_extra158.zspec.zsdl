spec: abc_extra158
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: abc.ABC.__dict__ membership and abc.ABCMeta.__dict__ membership via __dict__.__contains__ calls. CRITICAL FINDING: abc.ABC.__dict__ does NOT contain '__subclasshook__' or '__init_subclass__' in Python 3.14.3 — those methods are inherited from object via the metaclass protocol, NOT directly defined in ABC.__dict__; abc.ABC.__dict__ DOES contain: '__module__', '__firstlineno__', '__doc__', '__slots__', '__static_attributes__', '__abstractmethods__', '_abc_impl'. abc.ABCMeta.__dict__ DOES contain: '__module__', '__firstlineno__', '__doc__', '__new__', 'register', '__instancecheck__', '__subclasscheck__', '_dump_registry', '_abc_registry_clear', '_abc_caches_clear', '__static_attributes__'. abc.ABC.__dict__.__contains__('_abc_impl')==True (the C-level ABC implementation object); abc.ABC.__dict__.__contains__('__abstractmethods__')==True (frozenset tracking abstract methods); abc.ABC.__dict__.__contains__('__slots__')==True (ABC defines __slots__=()); abc.ABCMeta.__dict__.__contains__('register')==True; abc.ABCMeta.__dict__.__contains__('__new__')==True. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__dict__ membership: The actual keys in abc.ABC.__dict__ are ['__module__', '__firstlineno__', '__doc__', '__slots__', '__static_attributes__', '__abstractmethods__', '_abc_impl']; abc.ABC.__dict__.__contains__('__subclasshook__')==False (NOT in ABC.__dict__ — __subclasshook__ is inherited via the MRO, not defined directly on ABC); abc.ABC.__dict__.__contains__('__init_subclass__')==False (also NOT in ABC.__dict__); the task description for this spec mentioned these as True but verification shows they are False; this spec uses the ACTUAL verified values: '_abc_impl'==True, '__abstractmethods__'==True, '__slots__'==True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__dict__ membership: The actual keys are ['__module__', '__firstlineno__', '__doc__', '__new__', 'register', '__instancecheck__', '__subclasscheck__', '_dump_registry', '_abc_registry_clear', '_abc_caches_clear', '__static_attributes__']; ABCMeta.__dict__.__contains__('register')==True; ABCMeta.__dict__.__contains__('__new__')==True; ABCMeta.__dict__.__contains__('_dump_registry')==True; ABCMeta.__dict__.__contains__('__static_attributes__')==True; ABCMeta.__dict__.__contains__('__prepare__')==False (NOT in ABCMeta.__dict__ — __prepare__ is inherited from type, not defined on ABCMeta). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC identity: ABC.__name__=='ABC' (len=3); ABC.__module__=='abc' (len=3); ABC.__bases__[0].__name__=='object' (len=6); abc.ABCMeta identity: ABCMeta.__name__=='ABCMeta' (len=7); ABCMeta.__module__=='abc' (len=3); ABCMeta.__bases__[0].__name__=='type' (len=4). Both established in prior specs (extra156, extra157). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABC.__dict__ membership — extra158
#
# abc.ABC.__dict__.__contains__('_abc_impl')          == True
# abc.ABC.__dict__.__contains__('__abstractmethods__') == True
# abc.ABC.__dict__.__contains__('__slots__')           == True
# abc.ABC.__dict__.__contains__('__doc__')             == True
# abc.ABC.__dict__.__contains__('__subclasshook__')    == False  (NOT in ABC.__dict__)
# ---------------------------------------------------------------------------

table abc_extra158.abc_ABC_dict_contains:
  description: "abc.ABC.__dict__ membership checks in abcabcdict158 namespace — abc.ABC.__dict__.__contains__('_abc_impl')==True ('_abc_impl' is the C-level ABC implementation object stored directly in ABC.__dict__; it is a _abc_data object from the _abc C extension that tracks registered virtual subclasses and caches; this is a new discovery not covered in prior specs); abc.ABC.__dict__.__contains__('__abstractmethods__')==True ('__abstractmethods__' is a frozenset stored in ABC.__dict__ listing the abstract methods that must be overridden; for ABC itself it is frozenset() — empty since ABC has no @abstractmethod); abc.ABC.__dict__.__contains__('__slots__')==True (ABC defines __slots__=() to prevent instance dict creation, making ABC more efficient as a base class); abc.ABC.__dict__.__contains__('__doc__')==True (ABC has a docstring stored in __dict__); CRITICAL: abc.ABC.__dict__.__contains__('__subclasshook__')==False (NOT in ABC.__dict__ — __subclasshook__ is NOT directly defined on ABC; it is inherited via the MRO); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabcdict158

  columns: [id, function, args, expected, description]
  rows:
    - [abc_has_abc_impl,       abc.ABC.__dict__.__contains__,  ["_abc_impl"],          true,   "ABC.__dict__.__contains__('_abc_impl') == True (C-level ABC implementation object in ABC.__dict__); verified with Python 3.14.3"]
    - [abc_has_abstractmeth,   abc.ABC.__dict__.__contains__,  ["__abstractmethods__"], true,   "ABC.__dict__.__contains__('__abstractmethods__') == True (frozenset of abstract methods; empty for ABC itself); verified with Python 3.14.3"]
    - [abc_has_slots,          abc.ABC.__dict__.__contains__,  ["__slots__"],           true,   "ABC.__dict__.__contains__('__slots__') == True (ABC defines __slots__=() for efficiency); verified with Python 3.14.3"]
    - [abc_no_subclasshook,    abc.ABC.__dict__.__contains__,  ["__subclasshook__"],    false,  "ABC.__dict__.__contains__('__subclasshook__') == False (NOT in ABC.__dict__; inherited via MRO, not directly defined); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta.__dict__ membership — extra158
#
# abc.ABCMeta.__dict__.__contains__('register')           == True
# abc.ABCMeta.__dict__.__contains__('__new__')            == True
# abc.ABCMeta.__dict__.__contains__('_dump_registry')     == True
# abc.ABCMeta.__dict__.__contains__('__prepare__')        == False  (NOT in ABCMeta.__dict__)
# ---------------------------------------------------------------------------

table abc_extra158.abc_ABCMeta_dict_contains:
  description: "abc.ABCMeta.__dict__ membership checks in abcmetadict158 namespace — abc.ABCMeta.__dict__.__contains__('register')==True (register() is defined directly on ABCMeta; established in extra157 as a key method; register(subclass) adds subclass as a virtual subclass of the ABC); abc.ABCMeta.__dict__.__contains__('__new__')==True (__new__ is defined directly on ABCMeta; ABCMeta.__new__ is responsible for setting up the ABC tracking machinery when a new class is created with ABCMeta as its metaclass); abc.ABCMeta.__dict__.__contains__('_dump_registry')==True (_dump_registry is a debugging method defined directly on ABCMeta that prints the ABC virtual subclass registry to the provided file; '_dump_registry' is in ABCMeta.__dict__ as a directly-defined method); abc.ABCMeta.__dict__.__contains__('__prepare__')==False (CRITICAL: '__prepare__' is NOT in ABCMeta.__dict__; __prepare__ is inherited from type, not defined on ABCMeta itself; established in extra156 as a qualname but actually inherited from type); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetadict158

  columns: [id, function, args, expected, description]
  rows:
    - [meta_has_register,     abc.ABCMeta.__dict__.__contains__,  ["register"],        true,   "ABCMeta.__dict__.__contains__('register') == True (directly defined; established in extra157); verified with Python 3.14.3"]
    - [meta_has_new,          abc.ABCMeta.__dict__.__contains__,  ["__new__"],         true,   "ABCMeta.__dict__.__contains__('__new__') == True (ABCMeta defines __new__ for class creation setup); verified with Python 3.14.3"]
    - [meta_has_dump_reg,     abc.ABCMeta.__dict__.__contains__,  ["_dump_registry"],  true,   "ABCMeta.__dict__.__contains__('_dump_registry') == True (debugging method for ABC registry); verified with Python 3.14.3"]
    - [meta_no_prepare,       abc.ABCMeta.__dict__.__contains__,  ["__prepare__"],     false,  "ABCMeta.__dict__.__contains__('__prepare__') == False (NOT in ABCMeta.__dict__; inherited from type); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABC identity cross-reference and dict size — extra158
#
# abc.ABC.__name__.__eq__('ABC')           == True
# abc.ABCMeta.__name__.__eq__('ABCMeta')   == True
# ---------------------------------------------------------------------------

table abc_extra158.abc_identity_cross_reference:
  description: "abc.ABC and abc.ABCMeta identity cross-reference checks in abcidref158 namespace — abc.ABC.__name__.__eq__('ABC')==True (len=3: 'A'+'B'+'C'=3; established in prior specs; ABC is the helper class that uses ABCMeta as its metaclass); abc.ABCMeta.__name__.__eq__('ABCMeta')==True (len=7: 'ABC'=3+'Meta'=4=7; established in extra157; ABCMeta is the metaclass implementing the ABC protocol); abc.ABC.__module__.__eq__('abc')==True (len=3; same top-level module as ABCMeta — both ABC and ABCMeta live in 'abc', the shortest module path in these spec series); abc.ABC.__dict__.__contains__('__slots__')==True (direct dict membership confirmed — ABC.__slots__==() prevents instance __dict__ creation); qualname cross-reference: ABC.__name__.__len__()==3 vs ABCMeta.__name__.__len__()==7 (ABCMeta is 4 chars longer: 'Meta'=4 suffix added); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcidref158

  columns: [id, function, args, expected, description]
  rows:
    - [abc_name_eq,   abc.ABC.__name__.__eq__,     ["ABC"],     true,  "abc.ABC.__name__ == 'ABC' (len=3; established in prior specs); verified with Python 3.14.3"]
    - [meta_name_eq,  abc.ABCMeta.__name__.__eq__,  ["ABCMeta"], true,  "abc.ABCMeta.__name__ == 'ABCMeta' (len=7; established in extra157); verified with Python 3.14.3"]
    - [abc_mod_eq,    abc.ABC.__module__.__eq__,    ["abc"],     true,  "abc.ABC.__module__ == 'abc' (len=3; same top-level module as ABCMeta); verified with Python 3.14.3"]
    - [abc_has_slots, abc.ABC.__dict__.__contains__, ["__slots__"],  true, "ABC.__dict__.__contains__('__slots__') == True (ABC defines __slots__=() for efficiency); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra158
# ---------------------------------------------------------------------------

invariant abc_extra158.abc_ABC_dict_has_abc_impl:
  description: "abc.ABC.__dict__.__contains__('_abc_impl') returns True — '_abc_impl' is stored directly in abc.ABC.__dict__; _abc_impl is the C-level ABC implementation object (a _abc_data instance from the _abc C extension); it holds the internal state for ABC virtual subclass tracking — including the registered virtual subclasses, their caches, and weak references; the presence of '_abc_impl' directly in ABC.__dict__ (not in ABCMeta.__dict__) means each ABC class gets its own _abc_impl instance to track its own virtual subclasses independently; compare: ABCMeta.__dict__.__contains__('_abc_caches_clear')==True (established in extra157; the cache-clearing method is on ABCMeta while the actual cache data _abc_impl is on ABC itself); abc.ABC.__dict__.__contains__('__subclasshook__')==False (NOT in ABC.__dict__ — __subclasshook__ is inherited, not directly defined); NEW in extra158: first standalone ABC.__dict__.__contains__('_abc_impl') invariant in abcabcdict158 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__dict__.__contains__
  args: ["_abc_impl"]
  expected: true

invariant abc_extra158.abc_ABC_dict_has_abstractmethods:
  description: "abc.ABC.__dict__.__contains__('__abstractmethods__') returns True — '__abstractmethods__' is stored directly in abc.ABC.__dict__; __abstractmethods__ is a frozenset containing the names of all abstract methods that a concrete subclass of ABC must implement; for ABC itself, __abstractmethods__ is an empty frozenset() since ABC defines no @abstractmethod methods; when a class inherits from ABC and defines @abstractmethod methods, its __abstractmethods__ frozenset contains those method names; Python's type machinery checks __abstractmethods__ at class instantiation time and raises TypeError if it is non-empty; abc.ABC.__dict__.__contains__('__abstractmethods__')==True confirms __abstractmethods__ is directly on ABC (not inherited from object); compare: ABC.__dict__.__contains__('_abc_impl')==True (both are stored in ABC.__dict__ directly); ABC.__dict__.__contains__('__slots__')==True (ABC also defines __slots__); NEW in extra158: first standalone ABC.__dict__.__contains__('__abstractmethods__') invariant in abcabcdict158 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__dict__.__contains__
  args: ["__abstractmethods__"]
  expected: true

invariant abc_extra158.abc_ABCMeta_dict_has_new:
  description: "abc.ABCMeta.__dict__.__contains__('__new__') returns True — '__new__' is defined directly in abc.ABCMeta.__dict__; ABCMeta.__new__ is the metaclass constructor that initializes new ABC classes; when a class is created with ABCMeta as its metaclass (either via 'class Foo(metaclass=ABCMeta)' or by inheriting from abc.ABC), ABCMeta.__new__ is called; ABCMeta.__new__ sets up the ABC infrastructure including computing __abstractmethods__ (collecting all @abstractmethod decorated methods from the MRO) and initializing the _abc_impl object; ABCMeta.__new__.__qualname__=='ABCMeta.__new__' (len=15: 'ABCMeta'=7+'.'=1+'__new__'=7=15; established in extra157 tables); compare: abc.ABC.__dict__.__contains__('__new__')==False (ABC does not define __new__ — it is not in ABC.__dict__; __new__ is inherited from object via ABCMeta); NEW in extra158: first standalone ABCMeta.__dict__.__contains__('__new__') invariant in abcmetadict158 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__contains__
  args: ["__new__"]
  expected: true

invariant abc_extra158.abc_ABCMeta_dict_has_dump_registry:
  description: "abc.ABCMeta.__dict__.__contains__('_dump_registry') returns True — '_dump_registry' is defined directly in abc.ABCMeta.__dict__; ABCMeta._dump_registry(file) is a debugging method that prints the ABC virtual subclass registry to the specified file object; it shows which classes have been registered as virtual subclasses of a given ABC and their cached issubclass results; '_dump_registry' in ABCMeta.__dict__ confirms it is directly defined on ABCMeta (not inherited from type); ABCMeta._dump_registry.__qualname__=='ABCMeta._dump_registry' (len=22: 'ABCMeta'=7+'.'=1+'_dump_registry'=14=22; '_dump_registry'='_'=1+'dump'=4+'_'=1+'registry'=8=14); compare qualname lengths: __new__(15) < register(16) < _dump_registry(22) < _abc_caches_clear(25) < _abc_registry_clear(27); _dump_registry(22) is between register(16) and _abc_caches_clear(25); NEW in extra158: first standalone ABCMeta.__dict__.__contains__('_dump_registry') invariant in abcmetadict158 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__contains__
  args: ["_dump_registry"]
  expected: true

invariant abc_extra158.abc_ABC_dict_no_subclasshook:
  description: "abc.ABC.__dict__.__contains__('__subclasshook__') returns False — '__subclasshook__' is NOT in abc.ABC.__dict__ in Python 3.14.3; this is a KEY FINDING: despite abc.ABC.__subclasshook__ being accessible as an attribute of ABC (established in extra156 where its qualname=='ABC.__subclasshook__' was verified), '__subclasshook__' is NOT directly stored in ABC.__dict__; it is accessible via attribute lookup through the MRO or metaclass protocol but not directly in the instance dict; this means ABC.__dict__.__contains__('__subclasshook__')==False while ABC.__subclasshook__.__qualname__=='ABC.__subclasshook__'==True — a subtle distinction between attribute accessibility and direct dict membership; compare: abc.ABC.__dict__.__contains__('_abc_impl')==True (present in __dict__); abc.ABC.__dict__.__contains__('__abstractmethods__')==True (present in __dict__); NEW in extra158: first standalone ABC.__dict__.__contains__('__subclasshook__') false-membership invariant in abcabcdict158 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__dict__.__contains__
  args: ["__subclasshook__"]
  expected: false
