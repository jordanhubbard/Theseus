spec: struct_extra41
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra40.zspec.zsdl — covers Struct.__init__/__repr__ __name__.__eq__ and __name__.__len__()==8."
    - "struct_extra39.zspec.zsdl — covers Struct/__mro__[1]/__name__.__eq__('object') and error/__mro__[3]/__name__.__eq__('object'); Struct.size.__qualname__.__eq__('Struct.size') and Struct.size.__qualname__.__len__()==11."
    - "struct_extra38.zspec.zsdl — covers Struct/error __bases__[0].__qualname__.__eq__; error mro[1]/mro[2] __name__.__eq__."
    - "struct_extra37.zspec.zsdl — covers pack_into/unpack_from/iter_unpack __qualname__.__eq__; Struct.__bases__[0].__name__.__eq__('object'); calcsize('P')==8."
    - "struct_extra29.zspec.zsdl — covers Struct.__dict__['size'].__class__.__name__.__len__()==17 and Struct.__dict__['format'].__class__.__name__.__len__()==17 (descriptor class name length only, via __dict__ access, NOT __name__.__eq__ string value, NOT via Struct.size/Struct.format direct access)."
    - "struct_extra18.zspec.zsdl — covers Struct/__module__.__eq__('_struct') and all six module-level functions __module__.__eq__('_struct') and error/__module__.__eq__('struct')."
    - "struct_extra9.zspec.zsdl — covers Struct METHOD pack/unpack/pack_into/unpack_from/iter_unpack __name__.__eq__ and __qualname__.__eq__."
  notes:
    - "This spec extends struct through struct_extra40; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: struct_extra39 covers Struct.size.__qualname__.__eq__('Struct.size') and __qualname__.__len__()==11. struct_extra29 covers Struct.__dict__['size'].__class__.__name__.__len__()==17 (length only, via __dict__ access). But NO prior spec checks Struct.size.__name__.__eq__('size') or Struct.size.__name__.__len__()==4. These use the __name__ attribute chain accessed directly on the descriptor (Struct.size, not Struct.__dict__['size']), which is a distinct axis from __qualname__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__name__ == 'size'. The getset_descriptor for the Struct.size attribute has __name__ == 'size' (4 chars). extra39 covers __qualname__.__eq__('Struct.size') and __qualname__.__len__()==11; extra29 covers __class__.__name__.__len__()==17 via __dict__. No prior spec checks Struct.size.__name__.__eq__('size'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__name__.__len__() == 4. len('size') == 4. No prior spec checks Struct.size.__name__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: struct_extra29 covers Struct.__dict__['size'].__class__.__name__.__len__()==17 and Struct.__dict__['format'].__class__.__name__.__len__()==17 (length checks only, accessed via __dict__). But NO prior spec checks the string eq value for Struct.size.__class__.__name__ or Struct.format.__class__.__name__ as 'getset_descriptor'. The __class__.__name__.__eq__ axis is distinct from __class__.__name__.__len__ and provides an independent regression vector. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__class__.__name__ == 'getset_descriptor'. The descriptor type name is 'getset_descriptor'. extra29 covers __class__.__name__.__len__()==17 (length only). No prior spec checks __class__.__name__.__eq__('getset_descriptor') for Struct.size. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__class__.__name__ == 'getset_descriptor'. Same descriptor type as Struct.size — both are C-level getset_descriptor objects. extra29 covers __class__.__name__.__len__()==17 (length only). No prior spec checks __class__.__name__.__eq__('getset_descriptor') for Struct.format. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 3: No prior spec checks Struct.format.__name__.__eq__('format') or Struct.format.__qualname__.__eq__('Struct.format'). struct_extra39 covers Struct.size.__qualname__.__eq__ (not format). struct_extra29 covers both size and format descriptor class name lengths via __dict__, but does not check __name__.__eq__ or __qualname__.__eq__ for either via direct access. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__name__ == 'format'. The getset_descriptor for the Struct.format attribute has __name__ == 'format' (6 chars). No prior spec checks Struct.format.__name__.__eq__('format'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__qualname__ == 'Struct.format'. The getset_descriptor qualname includes the class prefix. extra39 covers Struct.size.__qualname__.__eq__('Struct.size') but NOT Struct.format.__qualname__. No prior spec checks Struct.format.__qualname__.__eq__('Struct.format'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.size __name__ string eq and length
#
# struct_extra39 covers Struct.size.__qualname__.__eq__('Struct.size') and
#   Struct.size.__qualname__.__len__()==11 (__qualname__ axis).
# struct_extra29 covers Struct.__dict__['size'].__class__.__name__.__len__()==17
#   (descriptor class name length via __dict__ access).
# No prior spec checks Struct.size.__name__.__eq__('size') or
#   Struct.size.__name__.__len__()==4 (__name__ axis via direct attribute access).
# Struct.size is a getset_descriptor; its __name__ == 'size' (the bare name).
# ---------------------------------------------------------------------------

table struct_extra41.Struct_size_name:
  description: "struct.Struct.size.__name__.__eq__('size') and __name__.__len__()==4 — novel __name__ axis; extra39 covers __qualname__.__eq__/'Struct.size'; extra29 covers __class__.__name__.__len__ via __dict__; no prior spec checks Struct.size.__name__.__eq__ or __name__.__len__"
  kind: python_call_eq
  category: type_structure
  id_prefix: ssn41

  columns: [id, function, args, expected]
  rows:
    - [size_name_eq,  Struct.size.__name__.__eq__,  ["size"], true]
    - [size_name_len, Struct.size.__name__.__len__,  [],       4]

# ---------------------------------------------------------------------------
# struct.Struct.size and Struct.format __class__.__name__.__eq__ string values
#
# struct_extra29 covers Struct.__dict__['size'].__class__.__name__.__len__()==17 and
#   Struct.__dict__['format'].__class__.__name__.__len__()==17 (length only,
#   via __dict__ access).
# No prior spec checks the string eq value 'getset_descriptor' for either
# Struct.size.__class__.__name__ or Struct.format.__class__.__name__
# (accessed directly on the descriptor, not via __dict__).
# ---------------------------------------------------------------------------

table struct_extra41.Struct_descriptor_class_name_eq:
  description: "struct.Struct.size/__class__/__name__.__eq__('getset_descriptor') and Struct.format/__class__/__name__.__eq__('getset_descriptor') — novel string eq axis; extra29 covers __class__.__name__.__len__()==17 via __dict__ only; no prior spec checks __class__.__name__.__eq__ for Struct.size or Struct.format"
  kind: python_call_eq
  category: type_structure
  id_prefix: sdcne41

  columns: [id, function, args, expected]
  rows:
    - [size_class_name_eq,   Struct.size.__class__.__name__.__eq__,   ["getset_descriptor"], true]
    - [format_class_name_eq, Struct.format.__class__.__name__.__eq__, ["getset_descriptor"], true]

# ---------------------------------------------------------------------------
# struct.Struct.format __name__ and __qualname__ string eq values
#
# struct_extra39 covers Struct.size.__qualname__.__eq__('Struct.size') (__qualname__ axis).
# struct_extra29 covers both size/format descriptor class name lengths via __dict__.
# No prior spec checks Struct.format.__name__.__eq__('format') or
#   Struct.format.__qualname__.__eq__('Struct.format').
# Struct.format is a getset_descriptor; __name__ == 'format', __qualname__ == 'Struct.format'.
# These are the format descriptor's __name__ and __qualname__ axes, analogous to
# Struct.size's coverage in extra39 and extra41.
# ---------------------------------------------------------------------------

table struct_extra41.Struct_format_name_qualname_eq:
  description: "struct.Struct.format.__name__.__eq__('format') and __qualname__.__eq__('Struct.format') — novel: extra39 covers Struct.size.__qualname__.__eq__ but NOT Struct.format; extra29 covers format descriptor class name len via __dict__; no prior spec checks Struct.format __name__ or __qualname__ string eq values"
  kind: python_call_eq
  category: type_structure
  id_prefix: sfnqe41

  columns: [id, function, args, expected]
  rows:
    - [format_name_eq,    "Struct.format.__name__.__eq__",    ["format"],        true]
    - [format_qualname_eq, "Struct.format.__qualname__.__eq__", ["Struct.format"], true]
