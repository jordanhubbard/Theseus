spec: it3376
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 672 (it3376): __trunc__, __round__, __index__ dict-presence checks for itertools types."
    - "Theme: __trunc__/__round__/__index__ dict-presence (math.trunc(x), round(x), operator.index(x))."
    - "All values False — itertools iterator types implement the iterator protocol only, not numeric protocols."
    - "No itertools iterator type defines __trunc__, __round__, or __index__ in its own __dict__."
    - "All 18 itertools iterator types are C-level types; they implement iterator protocol (__iter__/__next__), not truncation, rounding, or integer-conversion protocols."
    - "itertools.pairwise requires Python >= 3.10."
    - "All 18 itertools iterator types are checked."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

