spec: asyncio_extra2836
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronisation primitives documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio task and future documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
    - "asyncio_extra.zspec.zsdl — covers __name__ and __module__ checks for Queue, Task, Future, Lock, Event, Semaphore, Condition"
    - "asyncio_extra2.zspec.zsdl — covers module checks for event loop classes and exception classes"
    - "asyncio_extra2806.zspec.zsdl — covers __ilshift__, __irshift__, __ipow__ dict-presence checks"
    - "asyncio_extra2821.zspec.zsdl — covers __radd__, __rsub__, __rmul__ dict-presence checks"
  notes:
    - "Wave 636 theme: __rtruediv__, __rfloordiv__, and __rmod__ dict-presence checks (reflected true division, floor division, modulo operators)."
    - "None of the asyncio synchronisation or task primitives define __rtruediv__, __rfloordiv__, or __rmod__ in their __dict__."
    - "Queue, Task, Future, Lock, Event, Semaphore, Condition, Barrier are async coordination primitives, not numeric types."
    - "asyncio.Barrier was added in Python 3.11; version constraint >=3.9 applies to all other types."
    - "All eight types checked: Queue, Task, Future, Lock, Event, Semaphore, Condition, Barrier."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Queue, asyncio.Task, asyncio.Future — __rtruediv__/__rfloordiv__/__rmod__
# dict-presence checks
#
# Queue is an async FIFO queue; Task wraps a coroutine; Future is a low-level
# awaitable. None of them define reflected division or modulo operator dunders.
# ---------------------------------------------------------------------------

table asyncio_extra2836.queue_task_future_operator_dict:
  description: "asyncio.Queue, Task, Future __rtruediv__, __rfloordiv__, __rmod__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: as2836qtf

  columns: [id, function, args, expected]
  rows:
    - ["as2836qtf_q_rtd",  Queue.__dict__.__contains__,  ["__rtruediv__"],   false]
    - ["as2836qtf_q_rfd",  Queue.__dict__.__contains__,  ["__rfloordiv__"],  false]
    - ["as2836qtf_q_rmd",  Queue.__dict__.__contains__,  ["__rmod__"],       false]
    - ["as2836qtf_t_rtd",  Task.__dict__.__contains__,   ["__rtruediv__"],   false]
    - ["as2836qtf_t_rfd",  Task.__dict__.__contains__,   ["__rfloordiv__"],  false]
    - ["as2836qtf_t_rmd",  Task.__dict__.__contains__,   ["__rmod__"],       false]
    - ["as2836qtf_f_rtd",  Future.__dict__.__contains__, ["__rtruediv__"],   false]
    - ["as2836qtf_f_rfd",  Future.__dict__.__contains__, ["__rfloordiv__"],  false]
    - ["as2836qtf_f_rmd",  Future.__dict__.__contains__, ["__rmod__"],       false]

# ---------------------------------------------------------------------------
# asyncio.Lock, asyncio.Event, asyncio.Semaphore — __rtruediv__/__rfloordiv__/__rmod__
# dict-presence checks
#
# Lock, Event, and Semaphore are async synchronisation primitives defined in
# asyncio.locks. They do not implement reflected division or modulo operator dunders.
# ---------------------------------------------------------------------------

table asyncio_extra2836.lock_event_semaphore_operator_dict:
  description: "asyncio.Lock, Event, Semaphore __rtruediv__, __rfloordiv__, __rmod__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: as2836les

  columns: [id, function, args, expected]
  rows:
    - ["as2836les_l_rtd",  Lock.__dict__.__contains__,      ["__rtruediv__"],   false]
    - ["as2836les_l_rfd",  Lock.__dict__.__contains__,      ["__rfloordiv__"],  false]
    - ["as2836les_l_rmd",  Lock.__dict__.__contains__,      ["__rmod__"],       false]
    - ["as2836les_e_rtd",  Event.__dict__.__contains__,     ["__rtruediv__"],   false]
    - ["as2836les_e_rfd",  Event.__dict__.__contains__,     ["__rfloordiv__"],  false]
    - ["as2836les_e_rmd",  Event.__dict__.__contains__,     ["__rmod__"],       false]
    - ["as2836les_s_rtd",  Semaphore.__dict__.__contains__, ["__rtruediv__"],   false]
    - ["as2836les_s_rfd",  Semaphore.__dict__.__contains__, ["__rfloordiv__"],  false]
    - ["as2836les_s_rmd",  Semaphore.__dict__.__contains__, ["__rmod__"],       false]

# ---------------------------------------------------------------------------
# asyncio.Condition and asyncio.Barrier — __rtruediv__/__rfloordiv__/__rmod__
# dict-presence checks
#
# Condition is a combination lock/condition variable. Barrier (added in 3.11)
# is a synchronisation barrier. Neither defines reflected division or modulo operator dunders.
# ---------------------------------------------------------------------------

table asyncio_extra2836.condition_barrier_operator_dict:
  description: "asyncio.Condition and Barrier __rtruediv__, __rfloordiv__, __rmod__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: as2836cb

  columns: [id, function, args, expected]
  rows:
    - ["as2836cb_c_rtd",  Condition.__dict__.__contains__, ["__rtruediv__"],   false]
    - ["as2836cb_c_rfd",  Condition.__dict__.__contains__, ["__rfloordiv__"],  false]
    - ["as2836cb_c_rmd",  Condition.__dict__.__contains__, ["__rmod__"],       false]
    - ["as2836cb_b_rtd",  Barrier.__dict__.__contains__,   ["__rtruediv__"],   false]
    - ["as2836cb_b_rfd",  Barrier.__dict__.__contains__,   ["__rfloordiv__"],  false]
    - ["as2836cb_b_rmd",  Barrier.__dict__.__contains__,   ["__rmod__"],       false]

# ---------------------------------------------------------------------------
# Full 8×3 cross-type matrix — all asyncio types, all three reflected division/modulo operator dunders
#
# Consolidates the full 8×3 dict-presence check in one table.
# Every cell is False: Queue, Task, Future, Lock, Event, Semaphore, Condition,
# and Barrier do not define /, //, or % reflected operator dunders.
# ---------------------------------------------------------------------------

