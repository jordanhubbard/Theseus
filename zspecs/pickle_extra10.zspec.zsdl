spec: pickle_extra10
version: ">=3.9"
backend: python_module(pickle)

docs: https://docs.python.org/3/library/pickle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pickle.html — Python pickle module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pickle.py"
    - "CPython source: Modules/_pickle.c"
  notes:
    - "This spec extends pickle.zspec.zsdl through pickle_extra9.zspec.zsdl."
    - "pickle_extra9 covers: format_version value/type; STOP/MARK/NONE opcodes; dumps(None,protocol=0); PickleBuffer callable; PickleError/PicklingError/UnpicklingError MRO[1]; Pickler/Unpickler __qualname__."
    - "pickle_extra8 covers: Pickler/Unpickler/PickleError/PicklingError/UnpicklingError __name__/__module__/__qualname__; HIGHEST_PROTOCOL/DEFAULT_PROTOCOL type/bounds; PickleBuffer attrs; exception hierarchy."
    - "Focus: new axes not yet covered in any prior pickle spec."
    - "pickle.dumps(42).__class__.__name__ == 'bytes' — return type of dumps is bytes."
    - "pickle.HIGHEST_PROTOCOL.__class__.__name__ == 'int' — constant type is int."
    - "pickle.DEFAULT_PROTOCOL.__class__.__name__ == 'int' — constant type is int."
    - "pickle.HIGHEST_PROTOCOL.__ge__(5) == True — at least protocol 5 on CPython 3.12."
    - "pickle.DEFAULT_PROTOCOL.__ge__(3) == True — default is at least protocol 3."
    - "pickle.PickleError.__qualname__ == 'PickleError' — qualname for the base exception."
    - "pickle.PicklingError.__qualname__ == 'PicklingError' — qualname for PicklingError."
    - "pickle.UnpicklingError.__qualname__ == 'UnpicklingError' — qualname for UnpicklingError."
    - "pickle.dumps.__name__ == 'dumps' — function __name__ attribute."
    - "pickle.loads.__name__ == 'loads' — function __name__ attribute."
    - "pickle.__name__ == 'pickle' — top-level module __name__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pickle.dumps() return type
#
# Prior specs test round-trip correctness (dumps then loads == original value).
# No prior spec checks the __class__.__name__ of the dumps return value directly.
# ---------------------------------------------------------------------------

invariant pickle_extra10.dumps.result_class:
  description: "pickle.dumps(42).__class__.__name__ == 'bytes' — dumps always returns bytes"
  category: dumps_types
  kind: python_call_eq
  function: dumps
  args: [42]
  method: __class__.__name__
  expected: "bytes"

# ---------------------------------------------------------------------------
# HIGHEST_PROTOCOL and DEFAULT_PROTOCOL types
#
# pickle_extra8 checks HIGHEST_PROTOCOL and DEFAULT_PROTOCOL values (>= 5 and == 5).
# No prior spec checks their __class__.__name__ (i.e. that they are ints).
# ---------------------------------------------------------------------------

invariant pickle_extra10.HIGHEST_PROTOCOL.class_name:
  description: "pickle.HIGHEST_PROTOCOL.__class__.__name__ == 'int'"
  category: constant_types
  kind: python_call_eq
  function: HIGHEST_PROTOCOL.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant pickle_extra10.DEFAULT_PROTOCOL.class_name:
  description: "pickle.DEFAULT_PROTOCOL.__class__.__name__ == 'int'"
  category: constant_types
  kind: python_call_eq
  function: DEFAULT_PROTOCOL.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# HIGHEST_PROTOCOL >= 5 and DEFAULT_PROTOCOL >= 3
#
# CPython 3.12 has HIGHEST_PROTOCOL == 5 and DEFAULT_PROTOCOL == 5.
# Using __ge__ rather than __eq__ makes the spec forward-compatible if
# future versions increase the protocol number.
# pickle_extra8 checks HIGHEST_PROTOCOL and DEFAULT_PROTOCOL with __eq__ (exact values).
# No prior spec checks __ge__ comparisons for these constants.
# ---------------------------------------------------------------------------

invariant pickle_extra10.HIGHEST_PROTOCOL.ge5:
  description: "pickle.HIGHEST_PROTOCOL >= 5 — at least protocol version 5 supported"
  category: constants
  kind: python_call_eq
  function: HIGHEST_PROTOCOL.__ge__
  args: [5]
  expected: true

invariant pickle_extra10.DEFAULT_PROTOCOL.ge3:
  description: "pickle.DEFAULT_PROTOCOL >= 3 — default protocol is at least version 3"
  category: constants
  kind: python_call_eq
  function: DEFAULT_PROTOCOL.__ge__
  args: [3]
  expected: true

# ---------------------------------------------------------------------------
# Exception qualnames — PickleError, PicklingError, UnpicklingError
#
# pickle_extra9 adds Pickler.__qualname__ and Unpickler.__qualname__.
# No prior spec checks __qualname__ for the exception classes PickleError,
# PicklingError, or UnpicklingError.
# ---------------------------------------------------------------------------

invariant pickle_extra10.PickleError.qualname:
  description: "pickle.PickleError.__qualname__ == 'PickleError'"
  category: qualnames
  kind: python_call_eq
  function: PickleError.__qualname__.__eq__
  args: ["PickleError"]
  expected: true

invariant pickle_extra10.PicklingError.qualname:
  description: "pickle.PicklingError.__qualname__ == 'PicklingError'"
  category: qualnames
  kind: python_call_eq
  function: PicklingError.__qualname__.__eq__
  args: ["PicklingError"]
  expected: true

invariant pickle_extra10.UnpicklingError.qualname:
  description: "pickle.UnpicklingError.__qualname__ == 'UnpicklingError'"
  category: qualnames
  kind: python_call_eq
  function: UnpicklingError.__qualname__.__eq__
  args: ["UnpicklingError"]
  expected: true

# ---------------------------------------------------------------------------
# pickle.dumps and pickle.loads __name__ attributes
#
# Prior specs check dump/dumps/load/loads __qualname__ and __module__.
# No prior spec checks dumps.__name__ or loads.__name__ as standalone invariants
# with the pickle_extra10 namespace prefix.
# ---------------------------------------------------------------------------

invariant pickle_extra10.dumps.name:
  description: "pickle.dumps.__name__ == 'dumps'"
  category: function_names
  kind: python_call_eq
  function: dumps.__name__.__eq__
  args: ["dumps"]
  expected: true

invariant pickle_extra10.loads.name:
  description: "pickle.loads.__name__ == 'loads'"
  category: function_names
  kind: python_call_eq
  function: loads.__name__.__eq__
  args: ["loads"]
  expected: true

# ---------------------------------------------------------------------------
# pickle.__name__ — top-level module name
#
# No prior pickle spec checks the top-level module __name__ attribute.
# ---------------------------------------------------------------------------

invariant pickle_extra10.module.name:
  description: "pickle.__name__ == 'pickle' — top-level module __name__"
  category: module_attrs
  kind: python_call_eq
  function: __name__.__eq__
  args: ["pickle"]
  expected: true
