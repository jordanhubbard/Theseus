table io_extra1276.iobase_inheritance_types:
  description: "io.IOBase __subclasses__, __mro__, and __bases__ type name checks"
  kind: python_call_eq
  category: iobase_inheritance_types
  id_prefix: io1276ib
  columns: [id, function, args, expected]
  rows:
    - [io1276ib001, io.IOBase.__subclasses__().__class__.__name__.__eq__, ["list"],  true]
    - [io1276ib002, io.IOBase.__mro__.__class__.__name__.__eq__,         ["tuple"], true]
    - [io1276ib003, io.IOBase.__bases__.__class__.__name__.__eq__,       ["tuple"], true]
    - [io1276ib004, io.RawIOBase.__subclasses__().__class__.__name__.__eq__, ["list"],  true]
    - [io1276ib005, io.RawIOBase.__mro__.__class__.__name__.__eq__,         ["tuple"], true]
    - [io1276ib006, io.RawIOBase.__bases__.__class__.__name__.__eq__,       ["tuple"], true]
    - [io1276ib007, io.BufferedIOBase.__subclasses__().__class__.__name__.__eq__, ["list"],  true]
    - [io1276ib008, io.BufferedIOBase.__mro__.__class__.__name__.__eq__,         ["tuple"], true]

