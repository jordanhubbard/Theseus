spec: hashlib_extra2746
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/hashlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 630 theme: __round__, __divmod__, and __pow__ dict-presence checks."
    - "hashlib.HASH (the internal _hashlib.HASH type) is a hash object; it does not implement __round__, __divmod__, or __pow__ in its own __dict__."
    - "hashlib.blake2b is a hash constructor class; it similarly defines none of __round__, __divmod__, or __pow__ in its own __dict__."
    - "hashlib.blake2s is a hash constructor class; it similarly defines none of __round__, __divmod__, or __pow__ in its own __dict__."
    - "None of the hashlib public classes define __round__, __divmod__, or __pow__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __round__ dict-presence — absent from all hashlib classes
# ---------------------------------------------------------------------------

table hashlib_extra2746.round_protocol:
  description: "__round__ is absent from all hashlib class __dict__s — none implement numeric rounding"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2746

  columns: [id, function, args, expected]
  rows:
    - ["hl2746001", "type(hashlib.new('sha256')).__dict__.__contains__", ["__round__"], false]
    - ["hl2746002", "hashlib.blake2b.__dict__.__contains__",             ["__round__"], false]
    - ["hl2746003", "hashlib.blake2s.__dict__.__contains__",             ["__round__"], false]

# ---------------------------------------------------------------------------
# __divmod__ dict-presence — absent from all hashlib classes
# ---------------------------------------------------------------------------

table hashlib_extra2746.divmod_protocol:
  description: "__divmod__ is absent from all hashlib class __dict__s — none implement divmod"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2746

  columns: [id, function, args, expected]
  rows:
    - ["hl2746004", "type(hashlib.new('sha256')).__dict__.__contains__", ["__divmod__"], false]
    - ["hl2746005", "hashlib.blake2b.__dict__.__contains__",             ["__divmod__"], false]
    - ["hl2746006", "hashlib.blake2s.__dict__.__contains__",             ["__divmod__"], false]

# ---------------------------------------------------------------------------
# __pow__ dict-presence — absent from all hashlib classes
# ---------------------------------------------------------------------------

table hashlib_extra2746.pow_protocol:
  description: "__pow__ is absent from all hashlib class __dict__s — none implement exponentiation"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2746

  columns: [id, function, args, expected]
  rows:
    - ["hl2746007", "type(hashlib.new('sha256')).__dict__.__contains__", ["__pow__"], false]
    - ["hl2746008", "hashlib.blake2b.__dict__.__contains__",             ["__pow__"], false]
    - ["hl2746009", "hashlib.blake2s.__dict__.__contains__",             ["__pow__"], false]

# ---------------------------------------------------------------------------
# Combined view — blake2b and blake2s vs. all three arithmetic protocols
# ---------------------------------------------------------------------------

table hashlib_extra2746.blake_arithmetic_combined:
  description: "hashlib.blake2b and hashlib.blake2s define none of __round__, __divmod__, __pow__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2746

  columns: [id, function, args, expected]
  rows:
    - ["hl2746010", "hashlib.blake2b.__dict__.__contains__", ["__round__"],  false]
    - ["hl2746011", "hashlib.blake2b.__dict__.__contains__", ["__divmod__"], false]
    - ["hl2746012", "hashlib.blake2b.__dict__.__contains__", ["__pow__"],    false]
    - ["hl2746013", "hashlib.blake2s.__dict__.__contains__", ["__round__"],  false]
    - ["hl2746014", "hashlib.blake2s.__dict__.__contains__", ["__divmod__"], false]
    - ["hl2746015", "hashlib.blake2s.__dict__.__contains__", ["__pow__"],    false]
