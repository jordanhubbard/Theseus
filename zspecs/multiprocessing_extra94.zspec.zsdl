table multiprocessing_extra94.baseprocess_property_dict_membership:
  description: "BaseProcess.__dict__ property membership checks in mpbaseprocess94 namespace — wave 254 theme: multiprocessing BaseProcess property __dict__ membership; all process properties are defined on BaseProcess; BaseProcess.__dict__.__contains__('name')==True; BaseProcess.__dict__.__contains__('daemon')==True; BaseProcess.__dict__.__contains__('pid')==True; BaseProcess.__dict__.__contains__('exitcode')==True; BaseProcess.__dict__.__contains__('authkey')==True; BaseProcess.__dict__.__contains__('sentinel')==True; these are Python property descriptors defined in BaseProcess's class body; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpbaseprocess94b

  columns: [id, function, args, expected, description]
  rows:
    - [bp_has_name,     "BaseProcess.__dict__.__contains__", ["name"],     true, "BaseProcess.__dict__.__contains__('name') == True — name property defined on BaseProcess; verified with Python 3.14.3"]
    - [bp_has_daemon,   "BaseProcess.__dict__.__contains__", ["daemon"],   true, "BaseProcess.__dict__.__contains__('daemon') == True — daemon property defined on BaseProcess; verified with Python 3.14.3"]
    - [bp_has_pid,      "BaseProcess.__dict__.__contains__", ["pid"],      true, "BaseProcess.__dict__.__contains__('pid') == True — pid property defined on BaseProcess; verified with Python 3.14.3"]
    - [bp_has_exitcode, "BaseProcess.__dict__.__contains__", ["exitcode"], true, "BaseProcess.__dict__.__contains__('exitcode') == True — exitcode property defined on BaseProcess; verified with Python 3.14.3"]
    - [bp_has_authkey,  "BaseProcess.__dict__.__contains__", ["authkey"],  true, "BaseProcess.__dict__.__contains__('authkey') == True — authkey property defined on BaseProcess; verified with Python 3.14.3"]
    - [bp_has_sentinel, "BaseProcess.__dict__.__contains__", ["sentinel"], true, "BaseProcess.__dict__.__contains__('sentinel') == True — sentinel property defined on BaseProcess; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# BaseProcess dunder methods + multiprocessing.__all__ class name — extra94
#
# BaseProcess.__dict__.__contains__('__init__') == True
# BaseProcess.__dict__.__contains__('__repr__') == True
# multiprocessing.__all__.__class__.__name__ == 'list'
# multiprocessing.__all__.__len__() == 37
# ---------------------------------------------------------------------------

table multiprocessing_extra94.baseprocess_dunder_and_all:
  description: "BaseProcess dunder method membership and multiprocessing.__all__ checks in mpbaseprocess94 namespace — wave 254 theme: multiprocessing BaseProcess __dict__ membership and module __all__; BaseProcess.__dict__.__contains__('__init__')==True (BaseProcess defines its own __init__); BaseProcess.__dict__.__contains__('__repr__')==True (BaseProcess defines __repr__); multiprocessing.__all__.__class__.__name__.__eq__('list')==True (module __all__ is a list, not tuple); multiprocessing.__all__.__len__()==37 (37 public names exported from multiprocessing); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpbaseprocess94c

  columns: [id, function, args, expected, description]
  rows:
    - [bp_has_init,   "BaseProcess.__dict__.__contains__",    ["__init__"], true, "BaseProcess.__dict__.__contains__('__init__') == True — BaseProcess defines __init__; verified with Python 3.14.3"]
    - [bp_has_repr,   "BaseProcess.__dict__.__contains__",    ["__repr__"], true, "BaseProcess.__dict__.__contains__('__repr__') == True — BaseProcess defines __repr__; verified with Python 3.14.3"]
    - [mp_all_class,  "__all__.__class__.__name__.__eq__",    ["list"],     true, "multiprocessing.__all__.__class__.__name__ == 'list' — __all__ is a list; verified with Python 3.14.3"]
    - [mp_all_len,    "__all__.__len__",                      [],           37,   "multiprocessing.__all__.__len__() == 37 — 37 public names; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra94
# ---------------------------------------------------------------------------

invariant multiprocessing_extra94.BaseProcess_name_eq:
  description: "multiprocessing.process.BaseProcess.__name__.__eq__('BaseProcess') returns True — BaseProcess is the private base class for multiprocessing.Process; its __name__ is 'BaseProcess'; it is defined in Lib/multiprocessing/process.py and re-exported; BaseProcess.__mro__.__len__() is 2, indicating it inherits only from object; the public Process class subclasses BaseProcess and has MRO length 3; NEW in extra94: first standalone __name__ invariant for BaseProcess in mpbaseprocess94 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "BaseProcess.__name__.__eq__"
  args: ["BaseProcess"]
  expected: true

invariant multiprocessing_extra94.BaseProcess_module_eq:
  description: "multiprocessing.process.BaseProcess.__module__.__eq__('multiprocessing.process') returns True — BaseProcess is defined in the multiprocessing.process submodule (Lib/multiprocessing/process.py); it is not directly importable from multiprocessing (only Process is in multiprocessing.__all__); __module__ being 'multiprocessing.process' confirms the source location; NEW in extra94: first standalone __module__ invariant for BaseProcess in mpbaseprocess94 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "BaseProcess.__module__.__eq__"
  args: ["multiprocessing.process"]
  expected: true

invariant multiprocessing_extra94.BaseProcess_dict_has_sentinel:
  description: "multiprocessing.process.BaseProcess.__dict__.__contains__('sentinel') returns True — sentinel is a property defined on BaseProcess that exposes the OS-level file descriptor used to detect process completion; it is used internally by join() and can be passed to os.waitpid or select; its presence in BaseProcess.__dict__ confirms it is not inherited; NEW in extra94: first standalone sentinel membership invariant for BaseProcess in mpbaseprocess94 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "BaseProcess.__dict__.__contains__"
  args: ["sentinel"]
  expected: true

invariant multiprocessing_extra94.BaseProcess_mro_len_two:
  description: "multiprocessing.process.BaseProcess.__mro__.__len__() == 2 — BaseProcess's MRO is [BaseProcess, object]; it inherits directly from object with no intermediate base; the concrete Process class subclasses BaseProcess giving it MRO length 3 ([Process, BaseProcess, object]); this contrasts with Pool whose MRO is also length 2 ([Pool, object]) but with completely different functionality; NEW in extra94: first standalone __mro__.__len__ invariant for BaseProcess in mpbaseprocess94 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "BaseProcess.__mro__.__len__"
  args: []
  expected: 2

invariant multiprocessing_extra94.mp_all_len_37:
  description: "multiprocessing.__all__.__len__() == 37 — the multiprocessing module exports 37 public names including synchronization primitives (Lock, RLock, Semaphore, BoundedSemaphore, Event, Condition, Barrier), communication (Pipe, Queue, JoinableQueue, SimpleQueue), pool management (Pool, Manager), process-related (Process, active_children, current_process, parent_process), and configuration functions (get_context, get_start_method, set_start_method, etc.); NEW in extra94: first standalone __all__ length invariant for multiprocessing in mpbaseprocess94 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 37
