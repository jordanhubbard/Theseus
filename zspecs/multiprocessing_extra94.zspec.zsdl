spec: multiprocessing_extra94
version: ">=3.9"
backend: python_module(multiprocessing)
extends: multiprocessing_extra93

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra93.zspec.zsdl."
    - "This spec covers: wave 254 theme — multiprocessing BaseProcess class identity and __dict__ membership. NEW in extra94: BaseProcess.__name__=='BaseProcess'; BaseProcess.__module__=='multiprocessing.process'; BaseProcess.__qualname__=='BaseProcess'; BaseProcess.__bases__[0].__name__=='object'; BaseProcess.__mro__.__len__()==2; BaseProcess.__dict__.__contains__('start')==True; BaseProcess.__dict__.__contains__('run')==True; BaseProcess.__dict__.__contains__('join')==True; BaseProcess.__dict__.__contains__('is_alive')==True; BaseProcess.__dict__.__contains__('terminate')==True; BaseProcess.__dict__.__contains__('kill')==True; BaseProcess.__dict__.__contains__('close')==True; BaseProcess.__dict__.__contains__('name')==True; BaseProcess.__dict__.__contains__('daemon')==True; BaseProcess.__dict__.__contains__('pid')==True; BaseProcess.__dict__.__contains__('exitcode')==True; BaseProcess.__dict__.__contains__('authkey')==True; BaseProcess.__dict__.__contains__('sentinel')==True; BaseProcess.__dict__.__contains__('__init__')==True; BaseProcess.__dict__.__contains__('__repr__')==True; multiprocessing.__all__.__len__()==37; multiprocessing.__all__.__class__.__name__=='list'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "BaseProcess.__name__ == 'BaseProcess'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "BaseProcess.__module__ == 'multiprocessing.process'. Defined in Lib/multiprocessing/process.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "BaseProcess.__qualname__ == 'BaseProcess'. Module-level class; qualname equals name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "BaseProcess.__bases__[0].__name__ == 'object'. BaseProcess inherits directly from object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "BaseProcess.__mro__.__len__() == 2. MRO is [BaseProcess, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All 15 BaseProcess.__dict__ membership checks return True. start, run, join, is_alive, terminate, kill, close, name, daemon, pid, exitcode, authkey, sentinel, __init__, __repr__ are all defined in BaseProcess.__dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.__all__.__len__() == 37. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BaseProcess class identity — extra94
#
# Wave 254 theme: multiprocessing BaseProcess class identity.
#
# BaseProcess.__name__ == 'BaseProcess'
# BaseProcess.__module__ == 'multiprocessing.process'
# BaseProcess.__qualname__ == 'BaseProcess'
# BaseProcess.__bases__[0].__name__ == 'object'
# BaseProcess.__mro__.__len__() == 2
# ---------------------------------------------------------------------------

table multiprocessing_extra94.baseprocess_class_identity:
  description: "BaseProcess class identity checks in mpbaseprocess94 namespace — wave 254 theme: multiprocessing BaseProcess class identity; BaseProcess is defined in multiprocessing.process (Lib/multiprocessing/process.py); BaseProcess.__name__.__eq__('BaseProcess')==True; BaseProcess.__module__.__eq__('multiprocessing.process')==True; BaseProcess.__qualname__.__eq__('BaseProcess')==True (module-level class, qualname equals name); BaseProcess.__bases__[0].__name__.__eq__('object')==True (inherits directly from object); BaseProcess.__mro__.__len__()==2 (MRO is [BaseProcess, object]); the concrete Process class subclasses BaseProcess and has MRO length 3; backend uses multiprocessing.process.BaseProcess; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpbaseprocess94

  columns: [id, function, args, expected, description]
  rows:
    - [bp_name,    "BaseProcess.__name__.__eq__",           ["BaseProcess"],               true, "BaseProcess.__name__ == 'BaseProcess' — class name; verified with Python 3.14.3"]
    - [bp_module,  "BaseProcess.__module__.__eq__",         ["multiprocessing.process"],   true, "BaseProcess.__module__ == 'multiprocessing.process' — defined in process.py; verified with Python 3.14.3"]
    - [bp_qualname,"BaseProcess.__qualname__.__eq__",       ["BaseProcess"],               true, "BaseProcess.__qualname__ == 'BaseProcess' — module-level class; verified with Python 3.14.3"]
    - [bp_base0,   "BaseProcess.__bases__[0].__name__.__eq__", ["object"],                 true, "BaseProcess.__bases__[0].__name__ == 'object' — inherits from object; verified with Python 3.14.3"]
    - [bp_mro_len, "BaseProcess.__mro__.__len__",           [],                            2,    "BaseProcess.__mro__.__len__() == 2 — MRO is [BaseProcess, object]; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# BaseProcess.__dict__ lifecycle method membership — extra94
#
# start, run, join, is_alive, terminate, kill, close — all True
# ---------------------------------------------------------------------------

table multiprocessing_extra94.baseprocess_lifecycle_dict_membership:
  description: "BaseProcess.__dict__ lifecycle method membership checks in mpbaseprocess94 namespace — wave 254 theme: multiprocessing BaseProcess __dict__ membership; all lifecycle methods are defined directly on BaseProcess (not inherited); BaseProcess.__dict__.__contains__('start')==True; BaseProcess.__dict__.__contains__('run')==True; BaseProcess.__dict__.__contains__('join')==True; BaseProcess.__dict__.__contains__('is_alive')==True; BaseProcess.__dict__.__contains__('terminate')==True; BaseProcess.__dict__.__contains__('kill')==True; BaseProcess.__dict__.__contains__('close')==True; the concrete Process subclass must override run() but inherits all others; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpbaseprocess94a

  columns: [id, function, args, expected, description]
  rows:
    - [bp_has_start,     "BaseProcess.__dict__.__contains__", ["start"],     true, "BaseProcess.__dict__.__contains__('start') == True — start() defined on BaseProcess; verified with Python 3.14.3"]
    - [bp_has_run,       "BaseProcess.__dict__.__contains__", ["run"],       true, "BaseProcess.__dict__.__contains__('run') == True — run() defined on BaseProcess; subclasses override it; verified with Python 3.14.3"]
    - [bp_has_join,      "BaseProcess.__dict__.__contains__", ["join"],      true, "BaseProcess.__dict__.__contains__('join') == True — join() defined on BaseProcess; verified with Python 3.14.3"]
    - [bp_has_is_alive,  "BaseProcess.__dict__.__contains__", ["is_alive"],  true, "BaseProcess.__dict__.__contains__('is_alive') == True — is_alive() defined on BaseProcess; verified with Python 3.14.3"]
    - [bp_has_terminate, "BaseProcess.__dict__.__contains__", ["terminate"], true, "BaseProcess.__dict__.__contains__('terminate') == True — terminate() defined on BaseProcess; verified with Python 3.14.3"]
    - [bp_has_kill,      "BaseProcess.__dict__.__contains__", ["kill"],      true, "BaseProcess.__dict__.__contains__('kill') == True — kill() defined on BaseProcess; verified with Python 3.14.3"]
    - [bp_has_close,     "BaseProcess.__dict__.__contains__", ["close"],     true, "BaseProcess.__dict__.__contains__('close') == True — close() defined on BaseProcess; verified with Python 3.14.3"]

