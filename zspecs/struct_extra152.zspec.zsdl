spec: struct_extra152
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra151.zspec.zsdl — covers struct.__all__.__class__.__name__.__eq__('list') / __all__.__contains__('pack'/'error') / __all__.__len__()==8 / error.__name__/__module__/__qualname__ / pack/__unpack/__calcsize qualnames (table + invariants)."
    - "struct_extra150.zspec.zsdl — covers struct.__spec__.__class__.__name__.__eq__('ModuleSpec') / __spec__.name.__eq__('struct') / pack.__module__.__eq__('_struct') / pack/__unpack/__calcsize __class__.__name__.__eq__('builtin_function_or_method') (table + invariants)."
    - "struct_extra149.zspec.zsdl — covers struct.Struct.pack_into/__unpack_from/__iter_unpack qualnames / Struct.size/__format/__class__.__name__.__eq__('getset_descriptor') (table + invariants)."
    - "struct_extra148.zspec.zsdl — covers struct.Struct.__name__/__module__/__bases__[0].__name__ / Struct.pack/__qualname__ / Struct.unpack/__qualname__ / struct.error.__name__/__module__/__bases__[0].__name__ (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra151."
    - "Wave 338 theme: struct.iter_unpack identity and module-level function __name__ values — iter_unpack.__class__.__name__ / iter_unpack.__module__ / iter_unpack.__name__ / Struct.__name__.__len__()==6 / pack.__name__.__eq__('pack') / unpack.__name__.__eq__('unpack') / calcsize.__name__.__eq__('calcsize') / pack_into.__name__.__eq__('pack_into')."
    - "struct.iter_unpack.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__name__ == 'iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__name__.__len__() == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__name__ == 'pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__name__ == 'unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__name__ == 'calcsize'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__name__ == 'pack_into'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.iter_unpack.__class__.__name__ == 'builtin_function_or_method' and __module__ == '_struct'. iter_unpack() returns an iterator yielding successive tuples from a buffer according to a format string. Like pack, unpack, and calcsize, iter_unpack is a C extension callable from _struct (builtin_function_or_method, 26 chars). Its __name__ is 'iter_unpack' (11 chars; the longest module-level function __name__ in the struct module)."
    - "Note: struct.pack.__name__ == 'pack' (4 chars). struct.unpack.__name__ == 'unpack' (6 chars). struct.calcsize.__name__ == 'calcsize' (8 chars). struct.pack_into.__name__ == 'pack_into' (9 chars with underscore). For module-level C extension callables, __name__ equals __qualname__ (bare function name, no module prefix). extra151 anchors these qualname values; this spec anchors the __name__ values. For these functions, __name__ == __qualname__."
    - "Note: struct.Struct.__name__.__len__() == 6. 'Struct' is 6 chars. struct.Struct is the compiled struct object class. __name__ == 'Struct' (6 chars; matches class name in the C extension). extra148 anchors Struct.__name__=='Struct'; this spec anchors the length of 6."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.iter_unpack.__class__.__name__.__eq__('builtin_function_or_method')
# struct.iter_unpack.__module__.__eq__('_struct')
# struct.iter_unpack.__name__.__eq__('iter_unpack')
# struct.Struct.__name__.__len__()==6
#
# Wave 338 theme: iter_unpack identity and Struct.__name__ length.
#
# iter_unpack.__class__.__name__ == 'builtin_function_or_method' (26 chars; C extension callable).
# iter_unpack.__module__ == '_struct' (7 chars; same as pack/unpack/calcsize).
# iter_unpack.__name__ == 'iter_unpack' (11 chars; longest module-level function __name__).
# Struct.__name__.__len__() == 6 ('Struct' = 6 chars; extra148 anchors Struct.__name__=='Struct').
# No prior struct spec anchors iter_unpack identity as a table under structiu152.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra152.iter_unpack_identity_and_struct_name_len:
  description: "struct.iter_unpack.__class__.__name__.__eq__('builtin_function_or_method')==True / iter_unpack.__module__.__eq__('_struct')==True / iter_unpack.__name__.__eq__('iter_unpack')==True / Struct.__name__.__len__()==6 — iter_unpack is a 'builtin_function_or_method' (26 chars; C extension callable; same class as pack/unpack/calcsize); iter_unpack.__module__ is '_struct' (7 chars; all module-level struct functions share this); iter_unpack.__name__ is 'iter_unpack' (11 chars; longest module-level function name with underscore); Struct.__name__ is 6 chars ('Struct'; extra148 anchors the string value); first structiu152 anchor for iter_unpack identity and Struct name length"
  kind: python_call_eq
  category: identity
  id_prefix: structiu152

  columns: [id, function, args, expected, description]
  rows:
    - [iter_unpack_class_builtin, "iter_unpack.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "struct.iter_unpack.__class__.__name__ == 'builtin_function_or_method' (26 chars; C extension callable from _struct)"]
    - [iter_unpack_module,        "iter_unpack.__module__.__eq__",         ["_struct"],                    true, "struct.iter_unpack.__module__ == '_struct' (7 chars; C extension; same as pack/unpack/calcsize/pack_into)"]
    - [iter_unpack_name,          "iter_unpack.__name__.__eq__",           ["iter_unpack"],                true, "struct.iter_unpack.__name__ == 'iter_unpack' (11 chars; longest module-level struct function __name__; underscore in name)"]
    - [Struct_name_len_6,         "Struct.__name__.__len__",               [],                            6,    "struct.Struct.__name__.__len__() is 6 ('Struct' = 6 chars; extra148 anchors Struct.__name__=='Struct'; length check here)"]

# ---------------------------------------------------------------------------
# struct.pack.__name__.__eq__('pack')
# struct.unpack.__name__.__eq__('unpack')
# struct.calcsize.__name__.__eq__('calcsize')
# struct.pack_into.__name__.__eq__('pack_into')
#
# Wave 338 theme: module-level function __name__ values are bare function names.
#
# pack.__name__ == 'pack' (4 chars). unpack.__name__ == 'unpack' (6 chars).
# calcsize.__name__ == 'calcsize' (8 chars). pack_into.__name__ == 'pack_into' (9 chars).
# For C extension callables, __name__ == __qualname__ (bare name, no module prefix).
# extra151 anchors these qualname values; no prior struct spec anchors these as a
# __name__ table under structiu152. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra152.module_function_names:
  description: "struct.pack.__name__.__eq__('pack')==True / unpack.__name__.__eq__('unpack')==True / calcsize.__name__.__eq__('calcsize')==True / pack_into.__name__.__eq__('pack_into')==True — all four module-level functions have __name__==__qualname__ (bare names; no 'struct.' or '_struct.' prefix); pack(4 chars) < unpack(6 chars) < calcsize(8 chars) < pack_into(9 chars, with underscore) < iter_unpack(11 chars, with underscore); extra151 anchors qualname values for pack/unpack/calcsize; first structiu152 anchor for pack_into.__name__ and the combined __name__ table"
  kind: python_call_eq
  category: identity
  id_prefix: structiu152

  columns: [id, function, args, expected, description]
  rows:
    - [pack_name_pack,          "pack.__name__.__eq__",       ["pack"],       true, "struct.pack.__name__ == 'pack' (4 chars; __name__==__qualname__ for C extension callable; no module prefix)"]
    - [unpack_name_unpack,      "unpack.__name__.__eq__",     ["unpack"],     true, "struct.unpack.__name__ == 'unpack' (6 chars; __name__==__qualname__ for C extension callable from _struct)"]
    - [calcsize_name_calcsize,  "calcsize.__name__.__eq__",   ["calcsize"],   true, "struct.calcsize.__name__ == 'calcsize' (8 chars; __name__==__qualname__; returns size in bytes for format string)"]
    - [pack_into_name,          "pack_into.__name__.__eq__",  ["pack_into"],  true, "struct.pack_into.__name__ == 'pack_into' (9 chars; underscore in name; packs values into a writable buffer at offset)"]

# ---------------------------------------------------------------------------
# struct.iter_unpack.__name__.__len__()==11
# struct.pack_into.__name__.__len__()==9
# struct.calcsize.__name__.__len__()==8
# struct.unpack.__name__.__len__()==6
#
# Wave 338 theme: module-level function __name__ length ordering.
#
# Length ordering: pack(4) < unpack(6) < calcsize(8) < pack_into(9) < iter_unpack(11).
# No prior struct spec anchors these __name__ lengths as a combined table under structiu152.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra152.function_name_lengths:
  description: "struct.iter_unpack.__name__.__len__()==11 / pack_into.__name__.__len__()==9 / calcsize.__name__.__len__()==8 / unpack.__name__.__len__()==6 — __name__ length ordering for struct module-level functions: pack(4) < unpack(6) < calcsize(8) < pack_into(9) < iter_unpack(11); pack_into and iter_unpack have underscores in their names (hence longer lengths); pack is shortest at 4 chars; all five functions are builtin_function_or_method from _struct; first structiu152 anchor for these __name__ length values"
  kind: python_call_eq
  category: identity
  id_prefix: structiu152

  columns: [id, function, args, expected, description]
  rows:
    - [iter_unpack_name_len_11, "iter_unpack.__name__.__len__", [], 11, "struct.iter_unpack.__name__.__len__() is 11 ('iter_unpack' = 11 chars; longest module-level function name; underscore separates iter and unpack)"]
    - [pack_into_name_len_9,    "pack_into.__name__.__len__",   [], 9,  "struct.pack_into.__name__.__len__() is 9 ('pack_into' = 9 chars; underscore in name; packs into buffer at offset)"]
    - [calcsize_name_len_8,     "calcsize.__name__.__len__",    [], 8,  "struct.calcsize.__name__.__len__() is 8 ('calcsize' = 8 chars; second longest among simple-name functions)"]
    - [unpack_name_len_6,       "unpack.__name__.__len__",      [], 6,  "struct.unpack.__name__.__len__() is 6 ('unpack' = 6 chars; 2 more than pack=4; returns tuple of values from packed bytes)"]

# ---------------------------------------------------------------------------
# struct.iter_unpack.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# struct.iter_unpack.__class__.__name__ is 'builtin_function_or_method' (26 chars).
# iter_unpack() returns an iterator that yields successive (size)-byte chunks from a
# buffer and unpacks each according to the format string. It is implemented in the
# _struct C extension module, making it a builtin_function_or_method like pack, unpack,
# calcsize, and pack_into. iter_unpack is useful for processing a buffer containing
# multiple packed records of the same format. iter_unpack.__module__ == '_struct' (7 chars).
# iter_unpack.__name__ == 'iter_unpack' (11 chars; longest module-level function name).
# No prior struct spec anchors iter_unpack.__class__.__name__ as a standalone under
# structiu152. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra152.iter_unpack_class_builtin:
  description: "struct.iter_unpack.__class__.__name__.__eq__('builtin_function_or_method') == True — 26 chars; C extension callable from _struct; returns iterator yielding successive unpacked tuples from a buffer; __module__=='_struct' (7 chars); __name__=='iter_unpack' (11 chars; longest module-level function name); same class as pack/unpack/calcsize/pack_into; no prior struct spec anchors this as a standalone; first standalone under structiu152"
  category: identity
  kind: python_call_eq
  function: iter_unpack.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack_into.__name__.__eq__('pack_into') — standalone
#
# struct.pack_into.__name__ is 'pack_into' (9 chars). pack_into() is the variant of
# struct.pack() that writes packed bytes into a writable buffer (such as a bytearray
# or a memoryview) at a specified byte offset. Like pack(), pack_into() is a
# builtin_function_or_method from the _struct C extension with __module__ == '_struct'.
# Its __name__ is 'pack_into' (9 chars; underscore joins 'pack'=4 chars and 'into'=4 chars
# plus the separator). This contrasts with pack.__name__ == 'pack' (4 chars, no underscore).
# extra151 anchors pack.__qualname__=='pack' and pack.__name__ equivalence via qualname table;
# no prior struct spec anchors pack_into.__name__ as a standalone under structiu152.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra152.pack_into_name_eq:
  description: "struct.pack_into.__name__.__eq__('pack_into') == True — 9 chars ('pack'=4 + '_'=1 + 'into'=4); packs values into writable buffer at offset; builtin_function_or_method from _struct; __module__=='_struct' (7 chars); length ordering: pack(4) < unpack(6) < calcsize(8) < pack_into(9) < iter_unpack(11); extra151 anchors pack/__qualname__=='pack'; no prior struct spec anchors pack_into.__name__ as a standalone; first standalone under structiu152"
  category: identity
  kind: python_call_eq
  function: pack_into.__name__.__eq__
  args: ["pack_into"]
  expected: true

# ---------------------------------------------------------------------------
# struct.iter_unpack.__module__.__eq__('_struct') — standalone
#
# struct.iter_unpack.__module__ is '_struct' (7 chars). Like all module-level struct
# functions (pack, unpack, calcsize, pack_into), iter_unpack is implemented in the
# _struct C extension module and has __module__ == '_struct'. The underscore prefix
# distinguishes the C implementation module from the public 'struct' wrapper module.
# All five module-level functions share __module__ == '_struct' (7 chars).
# extra150 anchors pack/__module__=='_struct' and unpack/__module__=='_struct' and
# calcsize/__module__=='_struct' as table rows; no prior struct spec anchors
# iter_unpack.__module__ as a standalone under structiu152.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra152.iter_unpack_module_struct:
  description: "struct.iter_unpack.__module__.__eq__('_struct') == True — '_struct' (7 chars); C extension module; same as pack/unpack/calcsize/pack_into (extra150 anchors those); all five module-level functions share __module__=='_struct'; underscore prefix distinguishes C implementation from public 'struct' wrapper (6 chars); iter_unpack.__name__=='iter_unpack' (11 chars); returns iterator for successive unpacking; no prior struct spec anchors iter_unpack.__module__ as a standalone; first standalone under structiu152"
  category: identity
  kind: python_call_eq
  function: iter_unpack.__module__.__eq__
  args: ["_struct"]
  expected: true

