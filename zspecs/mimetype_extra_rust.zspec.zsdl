spec: mimetype_extra_rust
version: ">=3.9"
backend: rust_module(mimetype_extra_rust)

docs: https://docs.python.org/3/library/mimetypes.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/mimetypes.html — Python mimetypes documentation"
  not_derived_from:
    - "CPython source: Lib/mimetypes.py"
  notes:
    - "Additional mimetypes operations not in mimetypes_rust."
    - "mimetypes.guess_extension('text/html') returns a file extension like '.html'."
    - "mimetypes.guess_extension('image/png') returns '.png'."
    - "mimetypes.guess_type('file.html')[0] == 'text/html'."
    - "mimetypes.guess_type('image.jpg')[0] == 'image/jpeg'."
    - "mimetypes.guess_type('archive.gz')[0] == 'application/gzip'."
    - "Expose guess_type_html() -> str: mimetypes.guess_type('file.html')[0]."
    - "Expose guess_type_png() -> str: mimetypes.guess_type('image.png')[0]."
    - "Expose guess_type_json() -> str: mimetypes.guess_type('data.json')[0]."
    - "Expose guess_ext_html() -> str: mimetypes.guess_extension('text/html')."
    - "All test vectors verified against Python 3.14.3 mimetypes module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# guess_type — guess MIME type from filename
table mimetype_extra_rust.guess_type.vectors:
  kind: python_call_eq
  category: guess_type
  id_prefix: mt2_gt
  function: guess_type_for

  columns: [id, args, expected]
  rows:
    - [html,  ["file.html"],   "text/html"]
    - [png,   ["image.png"],   "image/png"]
    - [json,  ["data.json"],   "application/json"]
    - [css,   ["style.css"],   "text/css"]
    - [js,    ["script.js"],   "text/javascript"]

# guess_extension — guess file extension from MIME type
invariant mimetype_extra_rust.guess_ext.html:
  description: "guess_extension('text/html') ends with 'html' or 'htm'"
  category: guess_ext
  kind: python_call_eq
  function: guess_ext_contains
  args: ["text/html", "htm"]
  expected: true

invariant mimetype_extra_rust.guess_ext.png:
  description: "guess_extension('image/png') == '.png'"
  category: guess_ext
  kind: python_call_eq
  function: guess_extension_for
  args: ["image/png"]
  expected: ".png"

