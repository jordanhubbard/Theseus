spec: inspect_extra1006
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __module__ attribute of inspect predicate functions for all major is* functions"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra1006.method_function_module:
  description: "inspect.ismethod, isfunction, isgeneratorfunction __module__ checks"
  kind: python_call_eq
  category: method_function_module
  id_prefix: ip1006mf
  columns: [id, function, args, expected]
  rows:
    - [ip1006mf001, inspect.ismethod.__module__.__eq__,            ["inspect"], true]
    - [ip1006mf002, inspect.isfunction.__module__.__eq__,          ["inspect"], true]
    - [ip1006mf003, inspect.isgeneratorfunction.__module__.__eq__, ["inspect"], true]
    - [ip1006mf004, inspect.isgenerator.__module__.__eq__,         ["inspect"], true]
    - [ip1006mf005, inspect.ismethod.__qualname__.__eq__,          ["ismethod"], true]
    - [ip1006mf006, inspect.isfunction.__qualname__.__eq__,        ["isfunction"], true]

table inspect_extra1006.coroutine_module:
  description: "inspect.iscoroutinefunction, iscoroutine, isawaitable __module__ checks"
  kind: python_call_eq
  category: coroutine_module
  id_prefix: ip1006co
  columns: [id, function, args, expected]
  rows:
    - [ip1006co001, inspect.iscoroutinefunction.__module__.__eq__, ["inspect"], true]
    - [ip1006co002, inspect.iscoroutine.__module__.__eq__,         ["inspect"], true]
    - [ip1006co003, inspect.isawaitable.__module__.__eq__,         ["inspect"], true]
    - [ip1006co004, inspect.iscoroutinefunction.__qualname__.__eq__, ["iscoroutinefunction"], true]
    - [ip1006co005, inspect.iscoroutine.__qualname__.__eq__,         ["iscoroutine"],         true]
    - [ip1006co006, inspect.isawaitable.__qualname__.__eq__,         ["isawaitable"],         true]

table inspect_extra1006.asyncgen_traceback_module:
  description: "inspect.isasyncgenfunction, isasyncgen, istraceback __module__ checks"
  kind: python_call_eq
  category: asyncgen_traceback_module
  id_prefix: ip1006at
  columns: [id, function, args, expected]
  rows:
    - [ip1006at001, inspect.isasyncgenfunction.__module__.__eq__, ["inspect"], true]
    - [ip1006at002, inspect.isasyncgen.__module__.__eq__,         ["inspect"], true]
    - [ip1006at003, inspect.istraceback.__module__.__eq__,        ["inspect"], true]
    - [ip1006at004, inspect.isasyncgenfunction.__qualname__.__eq__, ["isasyncgenfunction"], true]
    - [ip1006at005, inspect.isasyncgen.__qualname__.__eq__,         ["isasyncgen"],         true]
    - [ip1006at006, inspect.istraceback.__qualname__.__eq__,        ["istraceback"],         true]
