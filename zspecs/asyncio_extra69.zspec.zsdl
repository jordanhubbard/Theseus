spec: asyncio_extra69
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-exceptions.html — Python asyncio exceptions documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/exceptions.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Modules/_asynciomodule.c"
  notes:
    - "This spec extends asyncio_extra68.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__()==13, Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__() tables, InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__/__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, Queue/Lock method qualname string equality, asyncio class __module__ string equality (extra52), Queue/Lock __doc__/__class__/__name__=='str' (extra50), asyncio.__all__.__class__.__name__=='list' (extra51), gather/sleep/__qualname__.__eq__ (extra3/extra22/extra26/extra28/extra43), Queue/__name__.__eq__ and Lock/__name__.__eq__ (extra/extra2/extra5), run/__qualname__.__eq__('run') (extra6/extra22/extra43), Condition/__name__/__qualname__/__len__() (extra53), BoundedSemaphore/__name__/__qualname__/__len__() (extra53), run/__name__.__eq__('run') (extra53), class __dict__.__class__.__name__/__qualname__ == 'mappingproxy' (extra54), class __class__.__module__.__eq__('builtins') (extra55), gather/sleep/wait __class__.__module__.__eq__('builtins') (extra55), Queue/Lock/Event/Semaphore/Condition __init__.__class__.__name__.__eq__('function') (extra55), class __repr__.__class__.__name__ (extra56), class __weakref__.__class__.__name__ (extra56), gather/sleep/wait function __repr__.__class__.__name__ (extra56), asyncio.__all__.__class__.__name__.__eq__('tuple') (extra57), class __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra57), class __subclasshook__.__class__.__name__ (extra57), asyncio.__all__.__contains__ membership checks (extra58), asyncio.__package__.__eq__('asyncio') (extra58), Queue/Lock __doc__.__class__.__name__.__eq__('str') (extra58), __loader__/__spec__/__file__/__cached__ __class__.__name__ (extra59), __spec__ attributes (extra60), Queue/Lock __init__ and put/get/empty/full/qsize/acquire/release __qualname__.__eq__ (extra61), gather/sleep/Queue.__init__/Lock.__init__ __annotations__/__globals__ class identity, gather __globals__.__contains__('gather'), Queue.__doc__.__contains__('Queue') (extra62), gather/sleep/Queue.__init__/Lock.__init__ __defaults__/__code__/__class__.__name__ checks (extra63), gather/sleep/Queue.__init__/Lock.__init__ __code__.co_name equality and co_argcount values (extra64), gather/sleep/Queue.__init__ co_varnames/co_filename/co_flags attribute chains (extra65), gather/sleep/Queue.__init__ co_consts/co_nlocals/co_stacksize type identity (extra66), sleep/__defaults__/__len__()==1, Queue.__init__/__defaults__.__class__.__name__=='tuple', gather/__defaults__.__class__.__name__=='NoneType', Lock.__init__/__defaults__.__class__.__name__=='NoneType', Event class identity, Semaphore class identity (extra67), gather/__kwdefaults__.__class__.__name__=='dict', gather/__kwdefaults__.__len__()==1, sleep/__kwdefaults__.__class__.__name__=='NoneType', Queue.__init__/__kwdefaults__.__class__.__name__=='NoneType', Lock.__init__/__kwdefaults__.__class__.__name__=='NoneType', Condition/__class__/__name__/__module__/__qualname__, BoundedSemaphore/__class__/__name__/__module__/__qualname__ (extra68)."
    - "This spec covers (asyncioid69 namespace): wave 235 theme — asyncio exception hierarchy and Task/Future class identity. NEW in extra69: InvalidStateError.__name__.__eq__('InvalidStateError'); InvalidStateError.__qualname__.__eq__('InvalidStateError'); InvalidStateError.__module__.__contains__('asyncio')==True; CancelledError.__name__.__eq__('CancelledError'); CancelledError.__module__.__contains__('asyncio')==True; TimeoutError.__name__.__eq__('TimeoutError'); Task.__class__.__name__.__eq__('type'); Task.__name__.__eq__('Task'); Task.__qualname__.__eq__('Task'); Task.__module__.__contains__('asyncio')==True; Future.__class__.__name__.__eq__('type'); Future.__name__.__eq__('Future'); Future.__qualname__.__eq__('Future'); Future.__module__.__contains__('asyncio')==True."
    - "asyncio.InvalidStateError.__name__ == 'InvalidStateError'. InvalidStateError is defined in asyncio.exceptions as a subclass of Exception. Its __name__ is the simple class name 'InvalidStateError'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.InvalidStateError.__qualname__ == 'InvalidStateError'. InvalidStateError is a top-level class in asyncio.exceptions; its qualified name is simply 'InvalidStateError'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.InvalidStateError.__module__.__contains__('asyncio') == True. InvalidStateError is defined in asyncio.exceptions; its __module__ is 'asyncio.exceptions'. 'asyncio.exceptions'.__contains__('asyncio') is True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.CancelledError.__name__ == 'CancelledError'. CancelledError is defined in asyncio.exceptions as a subclass of BaseException. Its __name__ is the simple class name 'CancelledError'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.CancelledError.__module__.__contains__('asyncio') == True. CancelledError is defined in asyncio.exceptions; its __module__ is 'asyncio.exceptions'. 'asyncio.exceptions'.__contains__('asyncio') is True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.TimeoutError.__name__ == 'TimeoutError'. In Python 3.11+, asyncio.TimeoutError is builtins.TimeoutError. Its __name__ is 'TimeoutError'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__class__.__name__ == 'type'. Task is an ordinary Python class (or C extension type); its metaclass is 'type'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__name__ == 'Task'. Task is a top-level class; its __name__ attribute is the simple class name 'Task'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__qualname__ == 'Task'. Task is a top-level class; its qualified name is simply 'Task'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__module__.__contains__('asyncio') == True. Task is implemented in asyncio (either Lib/asyncio/tasks.py or _asyncio C module); its __module__ contains 'asyncio'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Future.__class__.__name__ == 'type'. Future is an ordinary Python class (or C extension type); its metaclass is 'type'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Future.__name__ == 'Future'. Future is a top-level class; its __name__ attribute is the simple class name 'Future'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Future.__qualname__ == 'Future'. Future is a top-level class; its qualified name is simply 'Future'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Future.__module__.__contains__('asyncio') == True. Future is implemented in asyncio (either Lib/asyncio/futures.py or _asyncio C module); its __module__ contains 'asyncio'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio exception names and qualnames — extra69
#
# Wave 235 theme: exception hierarchy identity.
#
# InvalidStateError.__name__ == 'InvalidStateError'
# InvalidStateError.__qualname__ == 'InvalidStateError'
# CancelledError.__name__ == 'CancelledError'
# TimeoutError.__name__ == 'TimeoutError'
# ---------------------------------------------------------------------------

table asyncio_extra69.exception_names:
  description: "asyncio exception __name__.__eq__ checks in asyncioid69 namespace — wave 235 theme: exception hierarchy identity; InvalidStateError.__name__=='InvalidStateError'; InvalidStateError.__qualname__=='InvalidStateError'; CancelledError.__name__=='CancelledError'; TimeoutError.__name__=='TimeoutError'; NEW in extra69: first __name__/__qualname__ string equality checks for asyncio exceptions in the asyncioid69 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioid69

  columns: [id, function, args, expected, description]
  rows:
    - [invalidstate_name,     InvalidStateError.__name__.__eq__,     ["InvalidStateError"], true, "InvalidStateError.__name__ == 'InvalidStateError' — asyncio.InvalidStateError is defined in asyncio.exceptions as a subclass of Exception; its __name__ is the simple class name 'InvalidStateError'; NEW in extra69: first __name__.__eq__('InvalidStateError') check in the asyncioid69 namespace; verified with Python 3.14.3"]
    - [invalidstate_qualname, InvalidStateError.__qualname__.__eq__, ["InvalidStateError"], true, "InvalidStateError.__qualname__ == 'InvalidStateError' — InvalidStateError is a top-level class in asyncio.exceptions; its qualified name is simply 'InvalidStateError'; __qualname__.__eq__('InvalidStateError') returns True; NEW in extra69: first __qualname__.__eq__ check for InvalidStateError in the asyncioid69 namespace; verified with Python 3.14.3"]
    - [cancelled_name,        CancelledError.__name__.__eq__,        ["CancelledError"],    true, "CancelledError.__name__ == 'CancelledError' — asyncio.CancelledError is defined in asyncio.exceptions as a subclass of BaseException; its __name__ is the simple class name 'CancelledError'; NEW in extra69: first __name__.__eq__('CancelledError') check in the asyncioid69 namespace; verified with Python 3.14.3"]
    - [timeout_name,          TimeoutError.__name__.__eq__,          ["TimeoutError"],      true, "TimeoutError.__name__ == 'TimeoutError' — asyncio.TimeoutError (builtins.TimeoutError in Python 3.11+) has __name__ 'TimeoutError'; __name__.__eq__('TimeoutError') returns True; NEW in extra69: first __name__.__eq__('TimeoutError') check in the asyncioid69 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio exception __module__ contains 'asyncio' — extra69
#
# Wave 235 theme: exception module membership.
#
# InvalidStateError.__module__.__contains__('asyncio') == True
# CancelledError.__module__.__contains__('asyncio') == True
#
# Note: asyncio.TimeoutError is builtins.TimeoutError in Python 3.11+, so its
# __module__ is 'builtins' — not included here.
# ---------------------------------------------------------------------------

table asyncio_extra69.exception_module_asyncio:
  description: "asyncio InvalidStateError/__module__.__contains__('asyncio') and CancelledError/__module__.__contains__('asyncio') checks in asyncioid69 namespace — wave 235 theme: exception module membership; both are defined in asyncio.exceptions whose __name__ is 'asyncio.exceptions'; __module__.__contains__('asyncio') is True for both; NEW in extra69: first __module__.__contains__('asyncio') checks for InvalidStateError and CancelledError in the asyncioid69 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioid69a

  columns: [id, function, args, expected, description]
  rows:
    - [invalidstate_module_asyncio, InvalidStateError.__module__.__contains__, ["asyncio"], true, "InvalidStateError.__module__.__contains__('asyncio') == True — InvalidStateError is defined in asyncio.exceptions; its __module__ is 'asyncio.exceptions'; 'asyncio.exceptions'.__contains__('asyncio') is True; NEW in extra69: first __module__.__contains__('asyncio') check for InvalidStateError in the asyncioid69 namespace; verified with Python 3.14.3"]
    - [cancelled_module_asyncio,    CancelledError.__module__.__contains__,    ["asyncio"], true, "CancelledError.__module__.__contains__('asyncio') == True — CancelledError is defined in asyncio.exceptions; its __module__ is 'asyncio.exceptions'; 'asyncio.exceptions'.__contains__('asyncio') is True; NEW in extra69: first __module__.__contains__('asyncio') check for CancelledError in the asyncioid69 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio Task class identity checks — extra69
#
# Wave 235 theme: Task class identity.
#
# Task.__class__.__name__ == 'type'   (ordinary class / C type)
# Task.__name__ == 'Task'
# Task.__qualname__ == 'Task'
# Task.__module__.__contains__('asyncio') == True
# ---------------------------------------------------------------------------

table asyncio_extra69.Task_identity:
  description: "asyncio Task class identity checks in asyncioid69 namespace — wave 235 theme: Task class identity; Task.__class__.__name__=='type' (Task is an ordinary class or C type with metaclass type); Task.__name__=='Task'; Task.__qualname__=='Task'; Task.__module__.__contains__('asyncio')==True (Task is implemented in asyncio); NEW in extra69: first identity checks for Task in the asyncioid69 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioid69b

  columns: [id, function, args, expected, description]
  rows:
    - [task_class_name,     Task.__class__.__name__.__eq__,    ["type"],    true, "Task.__class__.__name__ == 'type' — asyncio.Task is an ordinary Python class (or C extension type); its metaclass is the built-in 'type'; Task.__class__.__name__ is 'type'; NEW in extra69: first __class__.__name__.__eq__('type') check for Task in the asyncioid69 namespace; verified with Python 3.14.3"]
    - [task_name,           Task.__name__.__eq__,              ["Task"],    true, "Task.__name__ == 'Task' — Task is a top-level class; its __name__ attribute is the simple class name 'Task'; NEW in extra69: first __name__.__eq__('Task') check in the asyncioid69 namespace; verified with Python 3.14.3"]
    - [task_qualname,       Task.__qualname__.__eq__,          ["Task"],    true, "Task.__qualname__ == 'Task' — Task is a top-level class; its qualified name is simply 'Task'; __qualname__.__eq__('Task') returns True; NEW in extra69: first __qualname__.__eq__('Task') check in the asyncioid69 namespace; verified with Python 3.14.3"]
    - [task_module_asyncio, Task.__module__.__contains__,      ["asyncio"], true, "Task.__module__.__contains__('asyncio') == True — Task is implemented in asyncio (either asyncio.tasks or the _asyncio C module); its __module__ contains 'asyncio'; NEW in extra69: first __module__.__contains__('asyncio') check for Task in the asyncioid69 namespace; verified with Python 3.14.3"]

