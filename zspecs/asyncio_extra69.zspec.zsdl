table asyncio_extra69.Future_identity:
  description: "asyncio Future class identity checks in asyncioid69 namespace — wave 235 theme: Future class identity; Future.__class__.__name__=='type' (Future is an ordinary class or C type with metaclass type); Future.__name__=='Future'; Future.__qualname__=='Future'; Future.__module__.__contains__('asyncio')==True (Future is implemented in asyncio); NEW in extra69: first identity checks for Future in the asyncioid69 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioid69c

  columns: [id, function, args, expected, description]
  rows:
    - [future_class_name,     Future.__class__.__name__.__eq__,    ["type"],    true, "Future.__class__.__name__ == 'type' — asyncio.Future is an ordinary Python class (or C extension type); its metaclass is the built-in 'type'; Future.__class__.__name__ is 'type'; NEW in extra69: first __class__.__name__.__eq__('type') check for Future in the asyncioid69 namespace; verified with Python 3.14.3"]
    - [future_name,           Future.__name__.__eq__,              ["Future"],  true, "Future.__name__ == 'Future' — Future is a top-level class; its __name__ attribute is the simple class name 'Future'; NEW in extra69: first __name__.__eq__('Future') check in the asyncioid69 namespace; verified with Python 3.14.3"]
    - [future_qualname,       Future.__qualname__.__eq__,          ["Future"],  true, "Future.__qualname__ == 'Future' — Future is a top-level class; its qualified name is simply 'Future'; __qualname__.__eq__('Future') returns True; NEW in extra69: first __qualname__.__eq__('Future') check in the asyncioid69 namespace; verified with Python 3.14.3"]
    - [future_module_asyncio, Future.__module__.__contains__,      ["asyncio"], true, "Future.__module__.__contains__('asyncio') == True — Future is implemented in asyncio (either asyncio.futures or the _asyncio C module); its __module__ contains 'asyncio'; NEW in extra69: first __module__.__contains__('asyncio') check for Future in the asyncioid69 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra69
# ---------------------------------------------------------------------------

invariant asyncio_extra69.InvalidStateError_name:
  description: "asyncio.InvalidStateError.__name__.__eq__('InvalidStateError') returns True — asyncio.InvalidStateError is defined in asyncio.exceptions as a subclass of Exception; its __name__ is the simple class name 'InvalidStateError'; NEW in extra69: first standalone __name__.__eq__('InvalidStateError') invariant for InvalidStateError in the asyncioid69 namespace; wave 235 first exception name identity invariant for InvalidStateError; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: InvalidStateError.__name__.__eq__
  args: ["InvalidStateError"]
  expected: true

invariant asyncio_extra69.CancelledError_module_asyncio:
  description: "asyncio.CancelledError.__module__.__contains__('asyncio') returns True — CancelledError is defined in asyncio.exceptions; its __module__ is 'asyncio.exceptions'; 'asyncio.exceptions'.__contains__('asyncio') is True; NEW in extra69: first standalone __module__.__contains__('asyncio') invariant for CancelledError in the asyncioid69 namespace; wave 235 first exception module identity invariant for CancelledError; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: CancelledError.__module__.__contains__
  args: ["asyncio"]
  expected: true

invariant asyncio_extra69.Task_class_type:
  description: "asyncio.Task.__class__.__name__.__eq__('type') returns True — asyncio.Task is an ordinary Python class or C extension type whose metaclass is the built-in 'type'; Task.__class__.__name__ is 'type'; NEW in extra69: first standalone __class__.__name__.__eq__('type') invariant for Task in the asyncioid69 namespace; wave 235 first class metaclass identity invariant for Task; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Task.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant asyncio_extra69.Task_name_Task:
  description: "asyncio.Task.__name__.__eq__('Task') returns True — Task is a top-level class; its __name__ attribute is the simple class name 'Task'; NEW in extra69: first standalone __name__.__eq__('Task') invariant in the asyncioid69 namespace; wave 235 first __name__ identity invariant for Task; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Task.__name__.__eq__
  args: ["Task"]
  expected: true

invariant asyncio_extra69.Future_class_type:
  description: "asyncio.Future.__class__.__name__.__eq__('type') returns True — asyncio.Future is an ordinary Python class or C extension type whose metaclass is the built-in 'type'; Future.__class__.__name__ is 'type'; NEW in extra69: first standalone __class__.__name__.__eq__('type') invariant for Future in the asyncioid69 namespace; wave 235 first class metaclass identity invariant for Future; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Future.__class__.__name__.__eq__
  args: ["type"]
  expected: true
