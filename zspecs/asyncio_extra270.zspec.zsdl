spec: asyncio_extra270
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-eventloop.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-eventloop.html — asyncio event loop documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/events.py"
  notes:
    - "asyncio.AbstractEventLoop is defined in asyncio.events, so __module__ == 'asyncio.events'."
    - "asyncio.AbstractEventLoop.__bases__[0].__name__ == 'object' — it inherits directly from object."
    - "All abstract methods (run_forever, run_until_complete, stop, is_running, is_closed, close, create_task) carry __qualname__ prefixed with 'AbstractEventLoop.'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# AbstractEventLoop class identity — table
#
# Class name, module, and base class name for asyncio.AbstractEventLoop.
# Includes method __name__ checks for the seven key abstract methods.
# ---------------------------------------------------------------------------

table asyncio_extra270.abstract_event_loop_identity:
  description: "asyncio.AbstractEventLoop class identity and method __name__ values"
  kind: python_call_eq
  category: identity
  id_prefix: aelid

  columns: [id, function, args, expected, description]
  rows:
    - [cls_name,              AbstractEventLoop.__name__.__eq__,                    ["AbstractEventLoop"],  true, "asyncio.AbstractEventLoop.__name__ == 'AbstractEventLoop'"]
    - [cls_module,            AbstractEventLoop.__module__.__eq__,                  ["asyncio.events"],     true, "asyncio.AbstractEventLoop.__module__ == 'asyncio.events'"]
    - [run_forever_name,      AbstractEventLoop.run_forever.__name__.__eq__,        ["run_forever"],        true, "asyncio.AbstractEventLoop.run_forever.__name__ == 'run_forever'"]
    - [run_until_complete_name, AbstractEventLoop.run_until_complete.__name__.__eq__, ["run_until_complete"], true, "asyncio.AbstractEventLoop.run_until_complete.__name__ == 'run_until_complete'"]
    - [stop_name,             AbstractEventLoop.stop.__name__.__eq__,               ["stop"],               true, "asyncio.AbstractEventLoop.stop.__name__ == 'stop'"]

# ---------------------------------------------------------------------------
# AbstractEventLoop method __qualname__ — table
#
# Abstract methods: is_running, is_closed, close, create_task carry the
# 'AbstractEventLoop.' prefix in __qualname__.
# ---------------------------------------------------------------------------

table asyncio_extra270.abstract_event_loop_qualnames:
  description: "asyncio.AbstractEventLoop methods report __qualname__ with AbstractEventLoop prefix"
  kind: python_call_eq
  category: identity
  id_prefix: aelqn

  columns: [id, function, args, expected, description]
  rows:
    - [run_forever_qn,        AbstractEventLoop.run_forever.__qualname__.__eq__,        ["AbstractEventLoop.run_forever"],        true, "run_forever.__qualname__ == 'AbstractEventLoop.run_forever'"]
    - [run_until_complete_qn, AbstractEventLoop.run_until_complete.__qualname__.__eq__, ["AbstractEventLoop.run_until_complete"], true, "run_until_complete.__qualname__ == 'AbstractEventLoop.run_until_complete'"]
    - [stop_qn,               AbstractEventLoop.stop.__qualname__.__eq__,               ["AbstractEventLoop.stop"],               true, "stop.__qualname__ == 'AbstractEventLoop.stop'"]
    - [close_qn,              AbstractEventLoop.close.__qualname__.__eq__,              ["AbstractEventLoop.close"],              true, "close.__qualname__ == 'AbstractEventLoop.close'"]
    - [create_task_qn,        AbstractEventLoop.create_task.__qualname__.__eq__,        ["AbstractEventLoop.create_task"],        true, "create_task.__qualname__ == 'AbstractEventLoop.create_task'"]

# ---------------------------------------------------------------------------
# AbstractEventLoop.__bases__[0] is object — standalone invariant
# ---------------------------------------------------------------------------

invariant asyncio_extra270.AbstractEventLoop.bases0_name:
  description: "asyncio.AbstractEventLoop.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: "AbstractEventLoop.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# is_running, is_closed method __name__ — standalone invariants
# ---------------------------------------------------------------------------

invariant asyncio_extra270.AbstractEventLoop.is_running_name:
  description: "asyncio.AbstractEventLoop.is_running.__name__ == 'is_running'"
  category: identity
  kind: python_call_eq
  function: AbstractEventLoop.is_running.__name__.__eq__
  args: ["is_running"]
  expected: true

invariant asyncio_extra270.AbstractEventLoop.is_closed_name:
  description: "asyncio.AbstractEventLoop.is_closed.__name__ == 'is_closed'"
  category: identity
  kind: python_call_eq
  function: AbstractEventLoop.is_closed.__name__.__eq__
  args: ["is_closed"]
  expected: true

invariant asyncio_extra270.AbstractEventLoop.close_name:
  description: "asyncio.AbstractEventLoop.close.__name__ == 'close'"
  category: identity
  kind: python_call_eq
  function: AbstractEventLoop.close.__name__.__eq__
  args: ["close"]
  expected: true

invariant asyncio_extra270.AbstractEventLoop.create_task_name:
  description: "asyncio.AbstractEventLoop.create_task.__name__ == 'create_task'"
  category: identity
  kind: python_call_eq
  function: AbstractEventLoop.create_task.__name__.__eq__
  args: ["create_task"]
  expected: true

invariant asyncio_extra270.AbstractEventLoop.is_running_qualname:
  description: "asyncio.AbstractEventLoop.is_running.__qualname__ == 'AbstractEventLoop.is_running'"
  category: identity
  kind: python_call_eq
  function: AbstractEventLoop.is_running.__qualname__.__eq__
  args: ["AbstractEventLoop.is_running"]
  expected: true

invariant asyncio_extra270.AbstractEventLoop.is_closed_qualname:
  description: "asyncio.AbstractEventLoop.is_closed.__qualname__ == 'AbstractEventLoop.is_closed'"
  category: identity
  kind: python_call_eq
  function: AbstractEventLoop.is_closed.__qualname__.__eq__
  args: ["AbstractEventLoop.is_closed"]
  expected: true
