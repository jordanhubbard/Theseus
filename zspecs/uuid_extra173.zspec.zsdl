spec: uuid_extra173
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "uuid.uuid3.__name__ == 'uuid3' — len 5; uuid3 generates deterministic UUID from MD5 of namespace+name."
    - "uuid.uuid3.__module__ == 'uuid' — uuid3 is defined in the pure-Python uuid module."
    - "uuid.uuid5.__name__ == 'uuid5' — len 5; uuid5 generates deterministic UUID from SHA-1 of namespace+name."
    - "uuid.uuid5.__module__ == 'uuid' — uuid5 is defined in the pure-Python uuid module."
    - "uuid.uuid1.__name__ == 'uuid1' — len 5; uuid1 generates time-based UUID."
    - "uuid.uuid4.__name__ == 'uuid4' — len 5; uuid4 generates random UUID."
    - "uuid.uuid3.__qualname__ == 'uuid3' — simple function, qualname matches name."
    - "uuid.uuid5.__qualname__ == 'uuid5' — simple function, qualname matches name."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: uuid3 and uuid5 — function name identity
#
# uuid.uuid3.__name__ == 'uuid3'
# uuid.uuid5.__name__ == 'uuid5'
#
# uuid3 and uuid5 produce deterministic (name-based) UUIDs using MD5 and
# SHA-1 respectively. Their __name__ attributes reflect the function names
# as defined in Lib/uuid.py. New to extra173.
# ---------------------------------------------------------------------------

table uuid_extra173.uuid3_uuid5_name_identity:
  description: "uuid3.__name__=='uuid3' and uuid5.__name__=='uuid5'; new to extra173"
  kind: python_call_eq
  category: identity
  id_prefix: uuidfuncs173

  columns: [id, function, args, expected, description]
  rows:
    - [uuid3_name_eq,
       "uuid3.__name__.__eq__",
       ["uuid3"],
       true,
       "uuid.uuid3.__name__.__eq__('uuid3') == True — the function's __name__ is 'uuid3'; len=5; new to extra173"]
    - [uuid5_name_eq,
       "uuid5.__name__.__eq__",
       ["uuid5"],
       true,
       "uuid.uuid5.__name__.__eq__('uuid5') == True — the function's __name__ is 'uuid5'; len=5; new to extra173"]
    - [uuid3_name_len,
       "uuid3.__name__.__len__",
       [],
       5,
       "uuid.uuid3.__name__.__len__() == 5 — 'uuid3' has 5 characters; new to extra173"]
    - [uuid5_name_len,
       "uuid5.__name__.__len__",
       [],
       5,
       "uuid.uuid5.__name__.__len__() == 5 — 'uuid5' has 5 characters; new to extra173"]

# ---------------------------------------------------------------------------
# Table 2: uuid3 and uuid5 — module and qualname identity
#
# uuid.uuid3.__module__ == 'uuid'
# uuid.uuid5.__module__ == 'uuid'
# uuid.uuid3.__qualname__ == 'uuid3'
# uuid.uuid5.__qualname__ == 'uuid5'
#
# Both functions are defined at module level in Lib/uuid.py (the pure-Python
# uuid module). Their __qualname__ matches __name__ because they are simple
# module-level functions, not nested or class-bound. New to extra173.
# ---------------------------------------------------------------------------

table uuid_extra173.uuid3_uuid5_module_qualname:
  description: "uuid3 and uuid5 __module__=='uuid' and __qualname__ matches __name__; new to extra173"
  kind: python_call_eq
  category: identity
  id_prefix: uuidfuncs173

  columns: [id, function, args, expected, description]
  rows:
    - [uuid3_module_eq,
       "uuid3.__module__.__eq__",
       ["uuid"],
       true,
       "uuid.uuid3.__module__.__eq__('uuid') == True — uuid3 is defined in the pure-Python uuid module; new to extra173"]
    - [uuid5_module_eq,
       "uuid5.__module__.__eq__",
       ["uuid"],
       true,
       "uuid.uuid5.__module__.__eq__('uuid') == True — uuid5 is defined in the pure-Python uuid module; new to extra173"]
    - [uuid3_qualname_eq,
       "uuid3.__qualname__.__eq__",
       ["uuid3"],
       true,
       "uuid.uuid3.__qualname__.__eq__('uuid3') == True — uuid3 is a simple module-level function; qualname equals name; new to extra173"]
    - [uuid5_qualname_eq,
       "uuid5.__qualname__.__eq__",
       ["uuid5"],
       true,
       "uuid.uuid5.__qualname__.__eq__('uuid5') == True — uuid5 is a simple module-level function; qualname equals name; new to extra173"]

# ---------------------------------------------------------------------------
# Table 3: uuid1 and uuid4 — function name identity
#
# uuid.uuid1.__name__ == 'uuid1'
# uuid.uuid4.__name__ == 'uuid4'
#
# uuid1 generates time-based UUIDs (non-deterministic). uuid4 generates
# random UUIDs (non-deterministic). Their __name__ attributes are verified
# for completeness alongside uuid3 and uuid5. New to extra173.
# ---------------------------------------------------------------------------

table uuid_extra173.uuid1_uuid4_name_identity:
  description: "uuid1.__name__=='uuid1' and uuid4.__name__=='uuid4'; new to extra173"
  kind: python_call_eq
  category: identity
  id_prefix: uuidfuncs173

  columns: [id, function, args, expected, description]
  rows:
    - [uuid1_name_eq,
       "uuid1.__name__.__eq__",
       ["uuid1"],
       true,
       "uuid.uuid1.__name__.__eq__('uuid1') == True — the function's __name__ is 'uuid1'; len=5; new to extra173"]
    - [uuid4_name_eq,
       "uuid4.__name__.__eq__",
       ["uuid4"],
       true,
       "uuid.uuid4.__name__.__eq__('uuid4') == True — the function's __name__ is 'uuid4'; len=5; new to extra173"]
    - [uuid1_name_len,
       "uuid1.__name__.__len__",
       [],
       5,
       "uuid.uuid1.__name__.__len__() == 5 — 'uuid1' has 5 characters; new to extra173"]
    - [uuid4_name_len,
       "uuid4.__name__.__len__",
       [],
       5,
       "uuid.uuid4.__name__.__len__() == 5 — 'uuid4' has 5 characters; new to extra173"]

