spec: inspect_extra257
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.Parameter class identity and kind constant contracts."
    - "inspect.Parameter.__name__ == 'Parameter' — class name. Verified with Python 3.14.3."
    - "inspect.Parameter.__module__ == 'inspect' — defined in inspect. Verified with Python 3.14.3."
    - "inspect.Parameter.__bases__[0].__name__ == 'object' — inherits directly from object. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind' — kind constants are _ParameterKind enum members. Verified with Python 3.14.3."
    - "int(inspect.Parameter.POSITIONAL_ONLY) == 0 — POSITIONAL_ONLY has integer value 0. Verified with Python 3.14.3."
    - "int(inspect.Parameter.POSITIONAL_OR_KEYWORD) == 1 — POSITIONAL_OR_KEYWORD has integer value 1. Verified with Python 3.14.3."
    - "int(inspect.Parameter.VAR_POSITIONAL) == 2 — VAR_POSITIONAL has integer value 2. Verified with Python 3.14.3."
    - "int(inspect.Parameter.KEYWORD_ONLY) == 3 — KEYWORD_ONLY has integer value 3. Verified with Python 3.14.3."
    - "int(inspect.Parameter.VAR_KEYWORD) == 4 — VAR_KEYWORD has integer value 4. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter class identity contracts
#
# inspect.Parameter.__name__              == 'Parameter'
# inspect.Parameter.__module__            == 'inspect'
# inspect.Parameter.__bases__[0].__name__ == 'object'
# inspect.Parameter.__class__.__name__    == 'type'
# inspect.Parameter.__qualname__          == 'Parameter'
#
# Parameter is a pure-Python class in inspect. New to extra257.
# ---------------------------------------------------------------------------

table inspect_extra257.parameter_identity:
  description: "inspect.Parameter name, module, base, class, qualname contracts; new to extra257"
  kind: python_call_eq
  category: identity
  id_prefix: ipar257

  columns: [id, function, args, expected, description]
  rows:
    - [par_name_eq,
       Parameter.__name__.__eq__,
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — class name; new to extra257"]
    - [par_module_eq,
       Parameter.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — defined in inspect module; new to extra257"]
    - [par_base_name_eq,
       "Parameter.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Parameter.__bases__[0].__name__.__eq__('object') == True — inherits directly from object; new to extra257"]
    - [par_class_name_eq,
       Parameter.__class__.__name__.__eq__,
       ["type"],
       true,
       "inspect.Parameter.__class__.__name__.__eq__('type') == True — it is a class; metaclass is type; new to extra257"]
    - [par_qualname_eq,
       Parameter.__qualname__.__eq__,
       ["Parameter"],
       true,
       "inspect.Parameter.__qualname__.__eq__('Parameter') == True — top-level class; qualname equals name; new to extra257"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Parameter kind constant class name contracts
#
# inspect.Parameter.POSITIONAL_ONLY.__class__.__name__       == '_ParameterKind'
# inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind'
# inspect.Parameter.VAR_POSITIONAL.__class__.__name__        == '_ParameterKind'
# inspect.Parameter.KEYWORD_ONLY.__class__.__name__          == '_ParameterKind'
# inspect.Parameter.VAR_KEYWORD.__class__.__name__           == '_ParameterKind'
#
# All five kind constants are _ParameterKind enum members. New to extra257.
# ---------------------------------------------------------------------------

table inspect_extra257.parameter_kind_class:
  description: "inspect.Parameter kind constants all have __class__.__name__ == '_ParameterKind'; new to extra257"
  kind: python_call_eq
  category: identity
  id_prefix: ipkc257

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_class_eq,
       Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_ONLY is a _ParameterKind enum member; new to extra257"]
    - [positional_or_keyword_class_eq,
       Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_OR_KEYWORD is a _ParameterKind enum member; new to extra257"]
    - [var_positional_class_eq,
       Parameter.VAR_POSITIONAL.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_POSITIONAL.__class__.__name__.__eq__('_ParameterKind') == True — VAR_POSITIONAL is a _ParameterKind enum member; new to extra257"]
    - [keyword_only_class_eq,
       Parameter.KEYWORD_ONLY.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — KEYWORD_ONLY is a _ParameterKind enum member; new to extra257"]
    - [var_keyword_class_eq,
       Parameter.VAR_KEYWORD.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — VAR_KEYWORD is a _ParameterKind enum member; new to extra257"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter kind constant integer values (POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD, VAR_POSITIONAL)
#
# int(inspect.Parameter.POSITIONAL_ONLY)       == 0
# int(inspect.Parameter.POSITIONAL_OR_KEYWORD) == 1
# int(inspect.Parameter.VAR_POSITIONAL)        == 2
#
# _ParameterKind is an IntEnum; these are the canonical integer values. New to extra257.
# ---------------------------------------------------------------------------

table inspect_extra257.parameter_kind_int_low:
  description: "inspect.Parameter POSITIONAL_ONLY==0, POSITIONAL_OR_KEYWORD==1, VAR_POSITIONAL==2 integer value contracts; new to extra257"
  kind: python_call_eq
  category: identity
  id_prefix: ipkil257

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_int_eq,
       Parameter.POSITIONAL_ONLY.__int__,
       [],
       0,
       "inspect.Parameter.POSITIONAL_ONLY.__int__() == 0 — POSITIONAL_ONLY has integer value 0; new to extra257"]
    - [positional_or_keyword_int_eq,
       Parameter.POSITIONAL_OR_KEYWORD.__int__,
       [],
       1,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.__int__() == 1 — POSITIONAL_OR_KEYWORD has integer value 1; new to extra257"]
    - [var_positional_int_eq,
       Parameter.VAR_POSITIONAL.__int__,
       [],
       2,
       "inspect.Parameter.VAR_POSITIONAL.__int__() == 2 — VAR_POSITIONAL has integer value 2; new to extra257"]
    - [positional_only_eq_zero,
       Parameter.POSITIONAL_ONLY.__eq__,
       [0],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__eq__(0) == True — POSITIONAL_ONLY equals integer 0; new to extra257"]
    - [positional_or_keyword_eq_one,
       Parameter.POSITIONAL_OR_KEYWORD.__eq__,
       [1],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.__eq__(1) == True — POSITIONAL_OR_KEYWORD equals integer 1; new to extra257"]

# ---------------------------------------------------------------------------
# Table 4: inspect.Parameter kind constant integer values (VAR_POSITIONAL, KEYWORD_ONLY, VAR_KEYWORD)
#
# int(inspect.Parameter.VAR_POSITIONAL) == 2
# int(inspect.Parameter.KEYWORD_ONLY)   == 3
# int(inspect.Parameter.VAR_KEYWORD)    == 4
#
# New to extra257.
# ---------------------------------------------------------------------------

table inspect_extra257.parameter_kind_int_high:
  description: "inspect.Parameter VAR_POSITIONAL==2, KEYWORD_ONLY==3, VAR_KEYWORD==4 integer value contracts; new to extra257"
  kind: python_call_eq
  category: identity
  id_prefix: ipkih257

  columns: [id, function, args, expected, description]
  rows:
    - [var_positional_eq_two,
       Parameter.VAR_POSITIONAL.__eq__,
       [2],
       true,
       "inspect.Parameter.VAR_POSITIONAL.__eq__(2) == True — VAR_POSITIONAL equals integer 2; new to extra257"]
    - [keyword_only_int_eq,
       Parameter.KEYWORD_ONLY.__int__,
       [],
       3,
       "inspect.Parameter.KEYWORD_ONLY.__int__() == 3 — KEYWORD_ONLY has integer value 3; new to extra257"]
    - [keyword_only_eq_three,
       Parameter.KEYWORD_ONLY.__eq__,
       [3],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__eq__(3) == True — KEYWORD_ONLY equals integer 3; new to extra257"]
    - [var_keyword_int_eq,
       Parameter.VAR_KEYWORD.__int__,
       [],
       4,
       "inspect.Parameter.VAR_KEYWORD.__int__() == 4 — VAR_KEYWORD has integer value 4; new to extra257"]
    - [var_keyword_eq_four,
       Parameter.VAR_KEYWORD.__eq__,
       [4],
       true,
       "inspect.Parameter.VAR_KEYWORD.__eq__(4) == True — VAR_KEYWORD equals integer 4; new to extra257"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra257
# ---------------------------------------------------------------------------

invariant inspect_extra257.Parameter.name_eq:
  description: "inspect.Parameter.__name__ == 'Parameter' — class name; new to extra257"
  category: identity
  kind: python_call_eq
  function: Parameter.__name__.__eq__
  args: ["Parameter"]
  expected: true

invariant inspect_extra257.Parameter.module_eq:
  description: "inspect.Parameter.__module__ == 'inspect' — defined in inspect; new to extra257"
  category: identity
  kind: python_call_eq
  function: Parameter.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra257.Parameter.base_is_object:
  description: "inspect.Parameter.__bases__[0].__name__ == 'object' — inherits directly from object; new to extra257"
  category: identity
  kind: python_call_eq
  function: "Parameter.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant inspect_extra257.Parameter.class_is_type:
  description: "inspect.Parameter.__class__.__name__ == 'type' — it is a class; metaclass is type; new to extra257"
  category: identity
  kind: python_call_eq
  function: Parameter.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra257.Parameter.POSITIONAL_ONLY.class_name:
  description: "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind' — enum member type; new to extra257"
  category: identity
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra257.Parameter.POSITIONAL_ONLY.int_value:
  description: "inspect.Parameter.POSITIONAL_ONLY.__int__() == 0 — integer value 0; new to extra257"
  category: identity
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__int__
  args: []
  expected: 0

invariant inspect_extra257.Parameter.POSITIONAL_OR_KEYWORD.int_value:
  description: "inspect.Parameter.POSITIONAL_OR_KEYWORD.__int__() == 1 — integer value 1; new to extra257"
  category: identity
  kind: python_call_eq
  function: Parameter.POSITIONAL_OR_KEYWORD.__int__
  args: []
  expected: 1

invariant inspect_extra257.Parameter.VAR_POSITIONAL.int_value:
  description: "inspect.Parameter.VAR_POSITIONAL.__int__() == 2 — integer value 2; new to extra257"
  category: identity
  kind: python_call_eq
  function: Parameter.VAR_POSITIONAL.__int__
  args: []
  expected: 2

invariant inspect_extra257.Parameter.KEYWORD_ONLY.int_value:
  description: "inspect.Parameter.KEYWORD_ONLY.__int__() == 3 — integer value 3; new to extra257"
  category: identity
  kind: python_call_eq
  function: Parameter.KEYWORD_ONLY.__int__
  args: []
  expected: 3

invariant inspect_extra257.Parameter.VAR_KEYWORD.int_value:
  description: "inspect.Parameter.VAR_KEYWORD.__int__() == 4 — integer value 4; new to extra257"
  category: identity
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.__int__
  args: []
  expected: 4

invariant inspect_extra257.Parameter.KEYWORD_ONLY.class_name:
  description: "inspect.Parameter.KEYWORD_ONLY.__class__.__name__ == '_ParameterKind' — enum member type; new to extra257"
  category: identity
  kind: python_call_eq
  function: Parameter.KEYWORD_ONLY.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra257.Parameter.VAR_KEYWORD.class_name:
  description: "inspect.Parameter.VAR_KEYWORD.__class__.__name__ == '_ParameterKind' — enum member type; new to extra257"
  category: identity
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true
