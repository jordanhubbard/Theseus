spec: sk3196
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 660 (sk3196): __pow__, __lshift__, __rshift__ dict-presence checks for socket types."
    - "socket.socket is a Python class; it does not define __pow__, __lshift__, or __rshift__ in its __dict__."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses (EnumType metaclass)."
    - "Neither socket.AddressFamily nor socket.SocketKind defines __pow__, __lshift__, or __rshift__ in its own __dict__; arithmetic and bitwise dunder methods are not part of the enum or int protocol at the class level."
    - "All values are False — none of these types are numeric types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table sk3196.pow:
  description: "socket types __pow__ dict-presence checks; wave 660"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: sk3196
  columns: [id, function, args, expected]
  rows:
    - ["sk3196001", operator.contains, [socket.socket.__dict__,        "__pow__"], false]
    - ["sk3196002", operator.contains, [socket.AddressFamily.__dict__, "__pow__"], false]
    - ["sk3196003", operator.contains, [socket.SocketKind.__dict__,    "__pow__"], false]

