spec: multiprocessing_extra151
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/sharedctypes.py"
  notes:
    - "This spec covers: multiprocessing.Value and multiprocessing.Array class/function identity, and multiprocessing.Lock/Event/Semaphore/Manager type identity. multiprocessing.Value.__module__=='multiprocessing.context' (len=23; Value is a bound method of the default context object, defined in context.py); multiprocessing.Value.__qualname__=='BaseContext.Value' (len=17); multiprocessing.Array.__module__=='multiprocessing.context' (len=23; same as Value); multiprocessing.Array.__qualname__=='BaseContext.Array' (len=17); multiprocessing.Lock.__class__.__name__=='method' (len=6; Lock is a bound method on the default context, NOT a class); multiprocessing.Event.__class__.__name__=='method' (same); multiprocessing.Semaphore.__class__.__name__=='method' (same); multiprocessing.Manager.__class__.__name__=='method' (same); multiprocessing.Manager.__qualname__=='BaseContext.Manager' (len=19). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.Value.__module__=='multiprocessing.context' — multiprocessing.Value is a bound method of the default context object (not a class or function in the traditional sense); its __module__ is 'multiprocessing.context' (len=23) because the method is defined as BaseContext.Value in context.py; the underlying factory function creates a multiprocessing.sharedctypes.Value object; similarly, multiprocessing.Array.__module__=='multiprocessing.context'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.Lock.__class__.__name__=='method' — multiprocessing.Lock (and Event, Semaphore, Manager) are all bound methods of the default context object (a BaseContext subclass); they are factory functions, not classes; calling multiprocessing.Lock() returns a Lock object; their __class__.__name__=='method' (a Python method object, len=6); this is a context-based dispatch design: the actual implementation depends on the context start method (spawn/fork/forkserver). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.Manager.__qualname__=='BaseContext.Manager' (len=19) — Manager has a longer qualname than Value (len=17) and Array (len=17) because 'Manager' has 7 chars while 'Value' and 'Array' have 5 chars each; all three are methods on BaseContext. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Value and multiprocessing.Array identity — extra151
#
# multiprocessing.Value.__module__.__eq__('multiprocessing.context')     == True
# multiprocessing.Value.__qualname__.__eq__('BaseContext.Value')         == True
# multiprocessing.Array.__module__.__eq__('multiprocessing.context')     == True
# multiprocessing.Array.__qualname__.__eq__('BaseContext.Array')         == True
# ---------------------------------------------------------------------------

table multiprocessing_extra151.mp_value_array_identity:
  description: "multiprocessing.Value and multiprocessing.Array identity checks in mpvalarray151 namespace — multiprocessing.Value.__module__=='multiprocessing.context' (len=23; Value is a bound method on the default context object defined as BaseContext.Value in Lib/multiprocessing/context.py — it is a factory function, not a class definition); multiprocessing.Value.__qualname__=='BaseContext.Value' (len=17: 'BaseContext'=11+'.'=1+'Value'=5=17; confirms Value is a method on BaseContext); multiprocessing.Array.__module__=='multiprocessing.context' (len=23; same module as Value — both are defined in context.py as bound methods of the default context); multiprocessing.Array.__qualname__=='BaseContext.Array' (len=17: 'BaseContext'=11+'.'=1+'Array'=5=17; same length as BaseContext.Value because 'Value' and 'Array' are both 5-char names); Value and Array are factory functions: calling multiprocessing.Value('i', 0) creates a shared memory integer Value; the underlying class is multiprocessing.sharedctypes.Value; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpvalarray151

  columns: [id, function, args, expected, description]
  rows:
    - [value_mod_eq,       multiprocessing.Value.__module__.__eq__,     ["multiprocessing.context"],  true,  "multiprocessing.Value.__module__ == 'multiprocessing.context' (len=23; bound method on default context); verified with Python 3.14.3"]
    - [value_qualname_eq,  multiprocessing.Value.__qualname__.__eq__,   ["BaseContext.Value"],         true,  "multiprocessing.Value.__qualname__ == 'BaseContext.Value' (len=17; method on BaseContext); verified with Python 3.14.3"]
    - [array_mod_eq,       multiprocessing.Array.__module__.__eq__,     ["multiprocessing.context"],  true,  "multiprocessing.Array.__module__ == 'multiprocessing.context' (len=23; same module as Value); verified with Python 3.14.3"]
    - [array_qualname_eq,  multiprocessing.Array.__qualname__.__eq__,   ["BaseContext.Array"],         true,  "multiprocessing.Array.__qualname__ == 'BaseContext.Array' (len=17; same qualname length as BaseContext.Value); verified with Python 3.14.3"]
    - [value_mod_len,      multiprocessing.Value.__module__.__len__,    [],                            23,    "multiprocessing.Value.__module__.__len__() == 23 ('multiprocessing.context'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.Lock, Event, Semaphore class identity — extra151
#
# multiprocessing.Lock.__class__.__name__.__eq__('method')       == True
# multiprocessing.Event.__class__.__name__.__eq__('method')      == True
# multiprocessing.Semaphore.__class__.__name__.__eq__('method')  == True
# ---------------------------------------------------------------------------

table multiprocessing_extra151.mp_lock_event_semaphore_class:
  description: "multiprocessing.Lock/Event/Semaphore type identity checks in mpcontext151 namespace — multiprocessing.Lock.__class__.__name__=='method' (len=6; Lock is a bound method on the default context object, not a class; calling type(multiprocessing.Lock) returns method; the actual Lock implementation is in Lib/multiprocessing/synchronize.py); multiprocessing.Event.__class__.__name__=='method' (len=6; same — Event is also a bound context method, factory for multiprocessing.synchronize.Event); multiprocessing.Semaphore.__class__.__name__=='method' (len=6; same — Semaphore is a bound context method, factory for multiprocessing.synchronize.Semaphore); all three have __class__.__name__=='method' (same 6-char value); their qualnames are BaseContext.Lock (len=16), BaseContext.Event (len=17), BaseContext.Semaphore (len=21); the context dispatch design means the concrete synchronization class depends on the start method (spawn/fork/forkserver); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpcontext151

  columns: [id, function, args, expected, description]
  rows:
    - [lock_class_eq,   multiprocessing.Lock.__class__.__name__.__eq__,       ["method"],  true,  "multiprocessing.Lock.__class__.__name__ == 'method' (len=6; bound context method, not a class); verified with Python 3.14.3"]
    - [event_class_eq,  multiprocessing.Event.__class__.__name__.__eq__,      ["method"],  true,  "multiprocessing.Event.__class__.__name__ == 'method' (len=6; bound context method); verified with Python 3.14.3"]
    - [sema_class_eq,   multiprocessing.Semaphore.__class__.__name__.__eq__,  ["method"],  true,  "multiprocessing.Semaphore.__class__.__name__ == 'method' (len=6; bound context method); verified with Python 3.14.3"]
    - [lock_cls_len,    multiprocessing.Lock.__class__.__name__.__len__,       [],          6,     "multiprocessing.Lock.__class__.__name__.__len__() == 6 ('method'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.Manager identity — extra151
#
# multiprocessing.Manager.__class__.__name__.__eq__('method')   == True
# multiprocessing.Manager.__qualname__.__eq__('BaseContext.Manager') == True
# ---------------------------------------------------------------------------

table multiprocessing_extra151.mp_manager_identity:
  description: "multiprocessing.Manager identity checks in mpmanager151 namespace — multiprocessing.Manager.__class__.__name__=='method' (len=6; Manager is a bound method on the default context object, factory for creating a multiprocessing.managers.SyncManager; same 'method' class as Lock, Event, Semaphore, Value, Array); multiprocessing.Manager.__qualname__=='BaseContext.Manager' (len=19: 'BaseContext'=11+'.'=1+'Manager'=7=19; len=19 because 'Manager' has 7 chars, 2 more than 'Value'/'Array'=5 chars, making qualname len=17 vs 19); multiprocessing.Manager.__qualname__.__len__()==19 (the longest qualname in this spec: Manager=19 > Semaphore=21... wait: BaseContext.Semaphore len=21 > BaseContext.Manager=19 > BaseContext.Event=17 = BaseContext.Value=17 = BaseContext.Array=17 > BaseContext.Lock=16); Manager provides a server process with a SyncManager that can create shared data structures accessible across processes; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmanager151

  columns: [id, function, args, expected, description]
  rows:
    - [mgr_class_eq,    multiprocessing.Manager.__class__.__name__.__eq__,  ["method"],              true,  "multiprocessing.Manager.__class__.__name__ == 'method' (len=6; bound context method like Lock/Event/Semaphore); verified with Python 3.14.3"]
    - [mgr_qualname_eq, multiprocessing.Manager.__qualname__.__eq__,        ["BaseContext.Manager"], true,  "multiprocessing.Manager.__qualname__ == 'BaseContext.Manager' (len=19; 'Manager' has 7 chars); verified with Python 3.14.3"]
    - [mgr_qualname_len, multiprocessing.Manager.__qualname__.__len__,       [],                      19,    "multiprocessing.Manager.__qualname__.__len__() == 19 ('BaseContext.Manager'); verified with Python 3.14.3"]
    - [mgr_cls_name_len, multiprocessing.Manager.__class__.__name__.__len__, [],                      6,     "multiprocessing.Manager.__class__.__name__.__len__() == 6 ('method'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra151
# ---------------------------------------------------------------------------

invariant multiprocessing_extra151.mp_Value_module_is_context:
  description: "multiprocessing.Value.__module__.__eq__('multiprocessing.context') returns True — multiprocessing.Value is a bound method of the default context object (a DefaultContext instance, which subclasses BaseContext defined in Lib/multiprocessing/context.py); its __module__ is 'multiprocessing.context' (len=23); Value.__qualname__=='BaseContext.Value' (len=17); this means multiprocessing.Value is NOT a class — it is a factory method; calling multiprocessing.Value('i', 42) creates a shared ctypes integer by delegating to multiprocessing.sharedctypes.Value; the context design allows different start methods (spawn/fork/forkserver) to use appropriate implementations; NEW in extra151: first standalone multiprocessing.Value.__module__ identity invariant in mpvalarray151 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Value.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra151.mp_Array_module_is_context:
  description: "multiprocessing.Array.__module__.__eq__('multiprocessing.context') returns True — multiprocessing.Array is also a bound method of the default context object (same pattern as Value); Array.__module__=='multiprocessing.context' (len=23); Array.__qualname__=='BaseContext.Array' (len=17; same length as BaseContext.Value since 'Array'='Value'=5 chars); calling multiprocessing.Array('i', [1,2,3]) creates a shared ctypes array by delegating to multiprocessing.sharedctypes.Array; both Value and Array are context-bound factory methods; their __module__ (context) differs from the underlying sharedctypes module (multiprocessing.sharedctypes, len=28) where the actual class definitions live; NEW in extra151: first standalone multiprocessing.Array.__module__ identity invariant in mpvalarray151 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Array.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra151.mp_Lock_class_is_method:
  description: "multiprocessing.Lock.__class__.__name__.__eq__('method') returns True — multiprocessing.Lock is a bound method on the default context object, NOT a class; type(multiprocessing.Lock).__name__=='method' (len=6); the actual Lock implementation is in multiprocessing.synchronize (SemLock-based); calling multiprocessing.Lock() invokes BaseContext.Lock() which dispatches to the appropriate synchronize.Lock class for the current start method; Lock.__class__.__name__=='method' is shared with Event.__class__.__name__=='method', Semaphore.__class__.__name__=='method', Manager.__class__.__name__=='method', Value.__class__.__name__=='method', and Array.__class__.__name__=='method' — all context-dispatched factories have the same type; NEW in extra151: first standalone multiprocessing.Lock.__class__.__name__ identity invariant in mpcontext151 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Lock.__class__.__name__.__eq__
  args: ["method"]
  expected: true

invariant multiprocessing_extra151.mp_Manager_qualname_eq:
  description: "multiprocessing.Manager.__qualname__.__eq__('BaseContext.Manager') returns True — multiprocessing.Manager is a bound method of BaseContext with qualname 'BaseContext.Manager' (len=19); compare qualname lengths: BaseContext.Semaphore(21) > BaseContext.Manager(19) > BaseContext.Event(17) = BaseContext.Value(17) = BaseContext.Array(17) > BaseContext.Lock(16); Manager is the longest of the common names (Lock=4, Value=Array=5, Event=5, Manager=7, Semaphore=9); calling multiprocessing.Manager() starts a server process running a SyncManager and returns a proxy manager object with proxy factory methods (list(), dict(), Namespace(), Queue(), etc.); Manager.__class__.__name__=='method' (same as all other context-bound factories); NEW in extra151: first standalone multiprocessing.Manager.__qualname__ identity invariant in mpmanager151 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Manager.__qualname__.__eq__
  args: ["BaseContext.Manager"]
  expected: true

invariant multiprocessing_extra151.mp_Value_qualname_len:
  description: "multiprocessing.Value.__qualname__.__len__() == 17 — multiprocessing.Value.__qualname__ is 'BaseContext.Value' (17 chars: 'BaseContext'=11+'.'=1+'Value'=5=17); the qualname reflects that Value is a method on BaseContext; same length as BaseContext.Array (also 17) and BaseContext.Event (also 17); shorter than BaseContext.Manager (19) and BaseContext.Semaphore (21); longer than BaseContext.Lock (16); multiprocessing.Value.__module__.__len__()==23 ('multiprocessing.context'); the qualname pattern 'BaseContext.X' is shared by all context-dispatched factory methods: Lock, Event, Semaphore, Value, Array, Manager; NEW in extra151: first standalone multiprocessing.Value.__qualname__ length invariant in mpvalarray151 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Value.__qualname__.__len__
  args: []
  expected: 17
