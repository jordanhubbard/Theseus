spec: multiprocessing_extra151
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
  notes:
    - "This spec covers multiprocessing module-level dunder attributes: __name__, __package__, __spec__.name, __loader__.__class__.__name__, __doc__.__class__.__name__."
    - "multiprocessing.__name__ == 'multiprocessing' — the module's own __name__ attribute. Verified with Python 3.14.3."
    - "multiprocessing.__package__ == 'multiprocessing' — multiprocessing is a package; __package__ equals __name__. Verified with Python 3.14.3."
    - "multiprocessing.__spec__.name == 'multiprocessing' — the ModuleSpec's name attribute matches the module name. Verified with Python 3.14.3."
    - "multiprocessing.__loader__.__class__.__name__ == 'SourceFileLoader' — multiprocessing is loaded from source files on disk. Verified with Python 3.14.3."
    - "multiprocessing.__doc__.__class__.__name__ == 'NoneType' — multiprocessing.__doc__ is None; the __init__.py has no module-level docstring. Verified with Python 3.14.3."
    - "multiprocessing.__spec__.__class__.__name__ == 'ModuleSpec' — the spec object is an importlib.machinery.ModuleSpec instance. Verified with Python 3.14.3."
    - "multiprocessing.__path__.__class__.__name__ == 'list' — multiprocessing is a package; __path__ is a list. Verified with Python 3.14.3."
    - "multiprocessing.__loader__.name == 'multiprocessing' — SourceFileLoader.name attribute matches the module name. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.__name__ and multiprocessing.__package__ identity
#
# multiprocessing.__name__ == 'multiprocessing'
# multiprocessing.__package__ == 'multiprocessing'
#
# multiprocessing is a package; its __name__ and __package__ are both
# 'multiprocessing'. New to multiprocessing_extra151.
# ---------------------------------------------------------------------------

table multiprocessing_extra151.module_name_package:
  description: "multiprocessing.__name__ and __package__ both equal 'multiprocessing'; it is a package so name equals package; new to multiprocessing_extra151"
  kind: python_call_eq
  category: module_identity
  id_prefix: mpmod151

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_eq,
       "__name__.__eq__",
       ["multiprocessing"],
       true,
       "multiprocessing.__name__.__eq__('multiprocessing') == True — the module's __name__ attribute equals 'multiprocessing'; new to multiprocessing_extra151"]
    - [module_name_len_eq_15,
       "__name__.__len__",
       [],
       15,
       "multiprocessing.__name__.__len__() == 15 — 'multiprocessing' has 15 characters; new to multiprocessing_extra151"]
    - [module_package_eq,
       "__package__.__eq__",
       ["multiprocessing"],
       true,
       "multiprocessing.__package__.__eq__('multiprocessing') == True — multiprocessing is a package so __package__ equals __name__; new to multiprocessing_extra151"]
    - [module_package_class_eq,
       "__package__.__class__.__name__.__eq__",
       ["str"],
       true,
       "multiprocessing.__package__.__class__.__name__.__eq__('str') == True — __package__ is a str instance; new to multiprocessing_extra151"]

# ---------------------------------------------------------------------------
# Table 2: multiprocessing.__spec__.name and __spec__.__class__.__name__
#
# multiprocessing.__spec__.name == 'multiprocessing'
# multiprocessing.__spec__.__class__.__name__ == 'ModuleSpec'
#
# The ModuleSpec for multiprocessing carries the canonical module name.
# New to multiprocessing_extra151.
# ---------------------------------------------------------------------------

table multiprocessing_extra151.module_spec_identity:
  description: "multiprocessing.__spec__.name == 'multiprocessing' and __spec__.__class__.__name__ == 'ModuleSpec'; new to multiprocessing_extra151"
  kind: python_call_eq
  category: module_identity
  id_prefix: mpmod151

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,
       "__spec__.name.__eq__",
       ["multiprocessing"],
       true,
       "multiprocessing.__spec__.name.__eq__('multiprocessing') == True — the ModuleSpec's name attribute equals 'multiprocessing'; new to multiprocessing_extra151"]
    - [spec_name_len_eq_15,
       "__spec__.name.__len__",
       [],
       15,
       "multiprocessing.__spec__.name.__len__() == 15 — 'multiprocessing' has 15 characters; new to multiprocessing_extra151"]
    - [spec_class_name_eq,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "multiprocessing.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — the spec object is a ModuleSpec instance; new to multiprocessing_extra151"]
    - [spec_class_name_len_eq_10,
       "__spec__.__class__.__name__.__len__",
       [],
       10,
       "multiprocessing.__spec__.__class__.__name__.__len__() == 10 — 'ModuleSpec' has 10 characters; new to multiprocessing_extra151"]

# ---------------------------------------------------------------------------
# Table 3: multiprocessing.__loader__, __doc__, __path__
#
# multiprocessing.__loader__.__class__.__name__ == 'SourceFileLoader'
# multiprocessing.__doc__.__class__.__name__ == 'NoneType'
# multiprocessing.__path__.__class__.__name__ == 'list'
# multiprocessing.__loader__.name == 'multiprocessing'
#
# multiprocessing is loaded via SourceFileLoader; __doc__ is None (no module
# docstring in __init__.py); __path__ is a list since it is a package.
# New to multiprocessing_extra151.
# ---------------------------------------------------------------------------

table multiprocessing_extra151.loader_doc_path:
  description: "multiprocessing.__loader__.__class__.__name__ == 'SourceFileLoader'; __doc__.__class__.__name__ == 'NoneType' (no module docstring); __path__.__class__.__name__ == 'list'; new to multiprocessing_extra151"
  kind: python_call_eq
  category: module_identity
  id_prefix: mpmod151

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_name_eq,
       "__loader__.__class__.__name__.__eq__",
       ["SourceFileLoader"],
       true,
       "multiprocessing.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — loaded from source; loader is a SourceFileLoader; new to multiprocessing_extra151"]
    - [loader_class_name_len_eq_16,
       "__loader__.__class__.__name__.__len__",
       [],
       16,
       "multiprocessing.__loader__.__class__.__name__.__len__() == 16 — 'SourceFileLoader' has 16 characters; new to multiprocessing_extra151"]
    - [doc_class_name_eq_nonetype,
       "__doc__.__class__.__name__.__eq__",
       ["NoneType"],
       true,
       "multiprocessing.__doc__.__class__.__name__.__eq__('NoneType') == True — multiprocessing.__doc__ is None; the __init__.py has no module docstring; new to multiprocessing_extra151"]
    - [path_class_name_eq,
       "__path__.__class__.__name__.__eq__",
       ["list"],
       true,
       "multiprocessing.__path__.__class__.__name__.__eq__('list') == True — multiprocessing is a package so __path__ is a list; new to multiprocessing_extra151"]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra151
# ---------------------------------------------------------------------------

invariant multiprocessing_extra151.module_name:
  description: "multiprocessing.__name__ == 'multiprocessing' — the module's __name__ attribute equals its canonical name; new to multiprocessing_extra151; verified Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["multiprocessing"]
  expected: true

invariant multiprocessing_extra151.module_package:
  description: "multiprocessing.__package__ == 'multiprocessing' — it is a package; __package__ equals __name__; new to multiprocessing_extra151; verified Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["multiprocessing"]
  expected: true

invariant multiprocessing_extra151.spec_name:
  description: "multiprocessing.__spec__.name == 'multiprocessing' — ModuleSpec.name matches the module name; new to multiprocessing_extra151; verified Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["multiprocessing"]
  expected: true

invariant multiprocessing_extra151.spec_class_name:
  description: "multiprocessing.__spec__.__class__.__name__ == 'ModuleSpec' — the spec object is an importlib.machinery.ModuleSpec instance; new to multiprocessing_extra151; verified Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant multiprocessing_extra151.loader_class_name:
  description: "multiprocessing.__loader__.__class__.__name__ == 'SourceFileLoader' — loaded from source files; loader is a SourceFileLoader; new to multiprocessing_extra151; verified Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant multiprocessing_extra151.doc_class_name:
  description: "multiprocessing.__doc__.__class__.__name__ == 'NoneType' — multiprocessing.__doc__ is None; the package __init__.py has no module docstring; new to multiprocessing_extra151; verified Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant multiprocessing_extra151.path_class_name:
  description: "multiprocessing.__path__.__class__.__name__ == 'list' — it is a package; __path__ is a list; new to multiprocessing_extra151; verified Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: __path__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant multiprocessing_extra151.loader_name:
  description: "multiprocessing.__loader__.name == 'multiprocessing' — SourceFileLoader.name attribute matches the module name; new to multiprocessing_extra151; verified Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: __loader__.name.__eq__
  args: ["multiprocessing"]
  expected: true
