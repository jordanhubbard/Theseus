spec: re_extra66
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra65.zspec.zsdl — covers re.search/__defaults__.__class__.__name__.__eq__('tuple') and __len__()==1; re.compile/__defaults__.__class__.__name__.__eq__('tuple') and __len__()==1; re.search/__code__.__class__.__name__.__eq__('code'); re.compile/__code__.__class__.__name__.__eq__('code'); re.Match/__doc__.__contains__('match') and __contains__('boolean'); re.Pattern/__doc__.__contains__('regular') and __contains__('Compiled')."
    - "re_extra64.zspec.zsdl — covers re.search/__annotations__/__globals__ class identity; re.error.__doc__.__contains__('pattern') and __contains__('Exception')."
    - "re_extra56.zspec.zsdl — covers search/compile __qualname__.__eq__() as namespace re-anchors."
    - "re_extra55.zspec.zsdl — covers search/compile/match/fullmatch/sub/findall/subn/split/escape/purge __qualname__.__eq__()."
  notes:
    - "This spec extends re_extra65.zspec.zsdl."
    - "Wave 230 theme: __code__ deep chains for Python functions + docstring content for C extension classes."
    - "re module is pure Python (Lib/re/__init__.py). re.search, re.compile, re.match, and re.sub are Python functions with __code__ objects."
    - "re.search.__code__.co_name == 'search' — co_name records the function name. re_extra65 covered __code__.__class__.__name__.__eq__('code') but NOT co_name equality. Novel co_name anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.compile.__code__.co_name == 'compile' — same pattern. Novel co_name anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.search.__code__.co_argcount == 3 — search(pattern, string, flags=0) has 3 positional parameters. co_argcount is 3. No prior re spec checks search.__code__.co_argcount. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.compile.__code__.co_argcount == 2 — compile(pattern, flags=0) has 2 positional parameters. co_argcount is 2. No prior re spec checks compile.__code__.co_argcount. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.match.__code__.co_name == 'match' — same pattern for match function. Novel co_name anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.sub.__code__.co_name == 'sub' — same pattern for sub function. Novel co_name anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.search and re.compile __code__.co_name
#
# re module is pure Python. re.search and re.compile are Python functions.
# Their __code__ code objects have co_name recording the function name.
#
#   re.search.__code__.co_name  == 'search'
#   re.compile.__code__.co_name == 'compile'
#
# re_extra65 covered __code__.__class__.__name__.__eq__('code') but NOT
# co_name equality. Novel co_name anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra66.func_code_coname:
  description: "re.search.__code__.co_name.__eq__('search') and re.compile.__code__.co_name.__eq__('compile') — re module is pure Python; search and compile are Python functions; co_name records the function name; re_extra65 covered __code__.__class__.__name__.__eq__('code') but not co_name equality; novel co_name anchors in recode2_66 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_code_coname
  id_prefix: recode2_66coname

  columns: [id, function, args, expected]
  rows:
    - [search_co_name_eq,  search.__code__.co_name.__eq__,  ["search"],  true]
    - [compile_co_name_eq, compile.__code__.co_name.__eq__, ["compile"], true]

# ---------------------------------------------------------------------------
# re.search and re.compile __code__.co_argcount
#
# re.search(pattern, string, flags=0) has 3 positional parameters.
# re.compile(pattern, flags=0) has 2 positional parameters.
# co_argcount counts all positional-or-keyword arguments.
#
#   re.search.__code__.co_argcount  == 3
#   re.compile.__code__.co_argcount == 2
#
# No prior re spec checks search.__code__.co_argcount or
# compile.__code__.co_argcount. Novel co_argcount anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra66.func_code_co_argcount:
  description: "re.search.__code__.co_argcount==3 and re.compile.__code__.co_argcount==2 — search(pattern,string,flags=0) has 3 positional params; compile(pattern,flags=0) has 2 positional params; co_argcount counts positional-or-keyword args; no prior re spec checks __code__.co_argcount for any re function; novel co_argcount anchors in recode2_66 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_code_argcount
  id_prefix: recode2_66argc

  columns: [id, function, args, expected]
  rows:
    - [search_co_argcount_eq,  search.__code__.co_argcount.__eq__,  [3], true]
    - [compile_co_argcount_eq, compile.__code__.co_argcount.__eq__, [2], true]

# ---------------------------------------------------------------------------
# re.match and re.sub __code__.co_name
#
# re.match and re.sub are pure Python functions with __code__ objects.
# Their co_name attributes record the function names.
#
#   re.match.__code__.co_name == 'match'
#   re.sub.__code__.co_name   == 'sub'
#
# No prior re spec checks re.match.__code__.co_name.__eq__('match') or
# re.sub.__code__.co_name.__eq__('sub') in the recode2_66 namespace.
# Novel co_name anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra66.match_sub_code_coname:
  description: "re.match.__code__.co_name.__eq__('match') and re.sub.__code__.co_name.__eq__('sub') — re.match and re.sub are pure Python functions; co_name records the function name; no prior re spec checks __code__.co_name for match or sub in recode2_66 namespace; novel co_name anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_code_coname
  id_prefix: recode2_66matchsub

  columns: [id, function, args, expected]
  rows:
    - [match_co_name_eq, match.__code__.co_name.__eq__, ["match"], true]
    - [sub_co_name_eq,   sub.__code__.co_name.__eq__,   ["sub"],   true]

invariant re_extra66.search_co_name:
  description: "re.search.__code__.co_name.__eq__('search') == True — re.search is a pure Python function; __code__ is a code object; co_name is 'search' (the function name); re_extra65 covered __code__.__class__.__name__.__eq__('code') but not co_name; novel co_name anchor in recode2_66 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_coname
  kind: python_call_eq
  function: search.__code__.co_name.__eq__
  args: ["search"]
  expected: true

invariant re_extra66.compile_co_name:
  description: "re.compile.__code__.co_name.__eq__('compile') == True — re.compile is a pure Python function; __code__ is a code object; co_name is 'compile' (the function name); re_extra65 covered __code__.__class__.__name__.__eq__('code') but not co_name; novel co_name anchor in recode2_66 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_coname
  kind: python_call_eq
  function: compile.__code__.co_name.__eq__
  args: ["compile"]
  expected: true

invariant re_extra66.search_co_argcount:
  description: "re.search.__code__.co_argcount.__eq__(3) == True — search(pattern, string, flags=0) has 3 positional-or-keyword parameters; co_argcount is 3; no prior re spec checks search.__code__.co_argcount; novel co_argcount anchor in recode2_66 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_argcount
  kind: python_call_eq
  function: search.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant re_extra66.compile_co_argcount:
  description: "re.compile.__code__.co_argcount.__eq__(2) == True — compile(pattern, flags=0) has 2 positional-or-keyword parameters; co_argcount is 2; no prior re spec checks compile.__code__.co_argcount; novel co_argcount anchor in recode2_66 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_argcount
  kind: python_call_eq
  function: compile.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant re_extra66.match_co_name:
  description: "re.match.__code__.co_name.__eq__('match') == True — re.match is a pure Python function; __code__ is a code object; co_name is 'match' (the function name); no prior re spec checks match.__code__.co_name in recode2_66 namespace; novel co_name anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_coname
  kind: python_call_eq
  function: match.__code__.co_name.__eq__
  args: ["match"]
  expected: true

invariant re_extra66.sub_co_name:
  description: "re.sub.__code__.co_name.__eq__('sub') == True — re.sub is a pure Python function; __code__ is a code object; co_name is 'sub' (the function name); no prior re spec checks sub.__code__.co_name in recode2_66 namespace; novel co_name anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_coname
  kind: python_call_eq
  function: sub.__code__.co_name.__eq__
  args: ["sub"]
  expected: true
