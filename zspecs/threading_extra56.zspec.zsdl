spec: threading_extra56
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra55.zspec.zsdl."
    - "Prior specs covered: Thread/Event/Semaphore/Condition/Barrier/Timer __dict__.__class__.__name__.__eq__('mappingproxy') (extra55); function __qualname__.__len__ for main_thread/current_thread/active_count (extra55). No prior threading spec records __init__.__class__.__name__/__module__ for any threading class. No prior threading spec records __class__.__module__.__eq__('builtins') for module-level functions main_thread/current_thread/active_count."
    - "Thread/Event/Semaphore/Condition are pure-Python classes; their __init__ is a function object. Barrier and Timer are also pure-Python classes with function __init__. BoundedSemaphore.__init__ is also a function. Lock.__init__ is a wrapper_descriptor (C type); RLock.__init__ is a method-wrapper; these are excluded from the 'function' table."
    - "This spec covers: threading.Thread/__init__.__class__.__name__.__eq__('function')==true; threading.Event/__init__.__class__.__name__.__eq__('function')==true; threading.Semaphore/__init__.__class__.__name__.__eq__('function')==true; threading.Condition/__init__.__class__.__name__.__eq__('function')==true; threading.Thread/__init__.__class__.__module__.__eq__('builtins')==true; threading.Event/__init__.__class__.__module__.__eq__('builtins')==true; threading.main_thread/__class__.__module__.__eq__('builtins')==true; threading.current_thread/__class__.__module__.__eq__('builtins')==true; threading.active_count/__class__.__module__.__eq__('builtins')==true; threading.enumerate/__class__.__module__.__eq__('builtins')==true."
    - "Key findings: Thread, Event, Semaphore, Condition, Barrier, and Timer are all pure-Python classes in Lib/threading.py. Their __init__ methods, accessed on the class (not an instance), are function objects — the underlying unbound function. The 'function' built-in type is defined in the C runtime builtins module, so function.__module__ == 'builtins'. This is consistent with inspect_extra55's finding for Parameter/Signature.__init__. Lock.__init__ is a C-level wrapper_descriptor and RLock.__init__ is a C-level method-wrapper, so they are intentionally excluded. Module-level functions main_thread/current_thread/active_count/enumerate are also pure-Python functions, so their __class__.__module__ == 'builtins'. All ten invariants are new to extra56."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading class __init__.__class__.__name__ == 'function' — extra56
#
# Thread, Event, Semaphore, and Condition are pure-Python classes in
# Lib/threading.py. When __init__ is accessed on the class (not on an instance),
# Python returns the underlying function object (the unbound __init__ function).
# This function object's __class__ is the built-in 'function' type. Therefore
# __init__.__class__.__name__ == 'function' (8 chars) for these four classes.
#
# Note: Lock.__init__ is a C-level 'wrapper_descriptor' and RLock.__init__ is
# a C-level 'method-wrapper'; these are intentionally excluded from this table
# because their __class__.__name__ is not 'function'.
#
# No prior threading spec records __init__.__class__.__name__ for any threading
# class. All four checks below are new to extra56.
# ---------------------------------------------------------------------------

table threading_extra56.class_init_class_name:
  description: "threading class __init__.__class__.__name__ == 'function' — pure-Python class __init__ is a function object; 'function' type __name__ == 'function' (8 chars); excludes Lock/RLock (C-level init); not recorded in any prior threading spec; new to extra56"
  kind: python_call_eq
  category: class_identity
  id_prefix: thrdmod56

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_init_class_name,
       Thread.__init__.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.Thread.__init__.__class__.__name__ == 'function' — Thread is a pure-Python class in Lib/threading.py; accessed on the class, __init__ is the underlying function object (the unbound initializer); its __class__ is the built-in 'function' type; function.__name__ == 'function' (8 chars); no prior threading spec records __init__.__class__.__name__ for Thread; new to extra56"]
    - [Event_init_class_name,
       Event.__init__.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.Event.__init__.__class__.__name__ == 'function' — Event is a pure-Python class in Lib/threading.py implementing a flag-based thread synchronization primitive; accessed on the class, __init__ is the underlying function object; its __class__ is the built-in 'function' type; function.__name__ == 'function' (8 chars); no prior threading spec records __init__.__class__.__name__ for Event; new to extra56"]
    - [Semaphore_init_class_name,
       Semaphore.__init__.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.Semaphore.__init__.__class__.__name__ == 'function' — Semaphore is a pure-Python class in Lib/threading.py implementing a counting semaphore; accessed on the class, __init__ is the underlying function object; its __class__ is the built-in 'function' type; function.__name__ == 'function' (8 chars); no prior threading spec records __init__.__class__.__name__ for Semaphore; new to extra56"]
    - [Condition_init_class_name,
       Condition.__init__.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.Condition.__init__.__class__.__name__ == 'function' — Condition is a pure-Python class in Lib/threading.py implementing a condition variable for thread synchronization; accessed on the class, __init__ is the underlying function object; its __class__ is the built-in 'function' type; function.__name__ == 'function' (8 chars); no prior threading spec records __init__.__class__.__name__ for Condition; new to extra56"]

# ---------------------------------------------------------------------------
# threading class __init__.__class__.__module__ == 'builtins' — extra56
#
# The 'function' built-in type is defined in Objects/funcobject.c and exposed
# via the C runtime builtins module. Therefore function.__module__ == 'builtins'
# (8 chars). For Thread and Event (both pure-Python classes with function-type
# __init__), Thread.__init__.__class__.__module__ == 'builtins' and
# Event.__init__.__class__.__module__ == 'builtins'. This is consistent with
# the finding for Parameter/Signature in inspect_extra55. No prior threading
# spec records __init__.__class__.__module__ for any threading class. New to extra56.
# ---------------------------------------------------------------------------

table threading_extra56.class_init_class_module:
  description: "threading.Thread/Event __init__.__class__.__module__ == 'builtins' — function type is a C runtime built-in with __module__=='builtins' (8 chars); not recorded in any prior threading spec; new to extra56"
  kind: python_call_eq
  category: class_identity
  id_prefix: thrdmod56

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_init_class_module,
       Thread.__init__.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "threading.Thread.__init__.__class__.__module__ == 'builtins' — Thread.__init__ is a function object; the 'function' built-in type is defined in the C runtime 'builtins' module; function.__module__ == 'builtins' (8 chars); consistent with extra56's Thread.__init__.__class__.__name__.__eq__('function'); no prior threading spec records __init__.__class__.__module__ for Thread; new to extra56"]
    - [Event_init_class_module,
       Event.__init__.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "threading.Event.__init__.__class__.__module__ == 'builtins' — Event.__init__ is a function object; the 'function' built-in type is defined in the C runtime 'builtins' module; function.__module__ == 'builtins' (8 chars); consistent with extra56's Event.__init__.__class__.__name__.__eq__('function'); no prior threading spec records __init__.__class__.__module__ for Event; new to extra56"]

# ---------------------------------------------------------------------------
# threading module-level function __class__.__module__ == 'builtins' — extra56
#
# threading module-level functions (main_thread, current_thread, active_count,
# enumerate) are pure-Python functions at the top level of Lib/threading.py.
# Each is a 'function' type object. The 'function' type is defined in the C
# runtime builtins module, so function.__module__ == 'builtins' (8 chars), and
# therefore each function's __class__.__module__ == 'builtins'.
#
# Prior extra55 confirmed __qualname__.__len__() for main_thread/current_thread/
# active_count. Prior extra15/extra22/extra47 confirmed __qualname__.__eq__ for
# these same functions. But no prior threading spec records __class__.__module__
# for any threading module-level function. All four checks below are new to extra56.
# ---------------------------------------------------------------------------

table threading_extra56.function_class_module_builtins:
  description: "threading module-level function __class__.__module__ == 'builtins' — pure-Python functions; 'function' type is a C runtime built-in with __module__=='builtins' (8 chars); not recorded in any prior threading spec; new to extra56"
  kind: python_call_eq
  category: class_identity
  id_prefix: thrdmod56

  columns: [id, function, args, expected, description]
  rows:
    - [main_thread_class_module,
       main_thread.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "threading.main_thread.__class__.__module__ == 'builtins' — main_thread is a pure-Python function in Lib/threading.py that returns the Thread object for the main thread; its __class__ is the 'function' built-in type; function.__module__ == 'builtins' (8 chars); prior extra15/extra22/extra47/extra55 confirmed __qualname__/__qualname__.__len__ for main_thread but not __class__.__module__; new to extra56"]
    - [current_thread_class_module,
       current_thread.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "threading.current_thread.__class__.__module__ == 'builtins' — current_thread is a pure-Python function in Lib/threading.py that returns the Thread object for the calling thread; its __class__ is the 'function' built-in type; function.__module__ == 'builtins' (8 chars); prior extra15/extra22/extra47/extra55 confirmed __qualname__/__qualname__.__len__ for current_thread but not __class__.__module__; new to extra56"]
    - [active_count_class_module,
       active_count.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "threading.active_count.__class__.__module__ == 'builtins' — active_count is a pure-Python function in Lib/threading.py that returns the number of Thread objects currently alive; its __class__ is the 'function' built-in type; function.__module__ == 'builtins' (8 chars); prior extra15/extra22/extra47/extra55 confirmed __qualname__/__qualname__.__len__ for active_count but not __class__.__module__; new to extra56"]
    - [enumerate_class_module,
       enumerate.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "threading.enumerate.__class__.__module__ == 'builtins' — enumerate is a pure-Python function in Lib/threading.py (not the built-in enumerate) that returns a list of all Thread objects currently alive; its __class__ is the 'function' built-in type; function.__module__ == 'builtins' (8 chars); no prior threading spec records __class__.__module__ for threading.enumerate; new to extra56"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra56
# ---------------------------------------------------------------------------

invariant threading_extra56.Thread_init_is_function:
  description: "Thread.__init__.__class__.__name__ == 'function' — class-level __init__ of a pure-Python class is the underlying function object; the function type is from builtins; contrasts with Lock/RLock which have C-level init types"
  kind: python_call_eq
  function: Thread.__init__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra56.Event_init_module_builtins:
  description: "Event.__init__.__class__.__module__ == 'builtins' — function type is a C runtime built-in; __module__ == 'builtins' for all pure-Python class __init__ methods"
  kind: python_call_eq
  function: Event.__init__.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant threading_extra56.main_thread_function_type_builtins:
  description: "main_thread.__class__.__module__ == 'builtins' — module-level pure-Python functions have function type from builtins; new dimension not covered by prior __qualname__ checks"
  kind: python_call_eq
  function: main_thread.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true
