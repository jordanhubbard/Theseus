spec: re_extra228
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec covers: re module __dict__ membership for all public functions, classes, and flags."
    - "re.__dict__.__contains__('PatternError') == True — PatternError added in Python 3.13 as alias for re.error."
    - "re.__dict__.__contains__('I') == True — I is the shorthand alias for IGNORECASE."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module __dict__ membership — functions
# ---------------------------------------------------------------------------

table re_extra228.dict_membership_functions:
  description: "re.__dict__ contains the expected public functions"
  kind: python_call_eq
  category: module_membership
  id_prefix: redictfunc228

  columns: [id, function, args, expected]
  rows:
    - [compile_present,   "__dict__.__contains__", ["compile"],   true]
    - [match_present,     "__dict__.__contains__", ["match"],     true]
    - [search_present,    "__dict__.__contains__", ["search"],    true]
    - [fullmatch_present, "__dict__.__contains__", ["fullmatch"], true]
    - [findall_present,   "__dict__.__contains__", ["findall"],   true]
    - [finditer_present,  "__dict__.__contains__", ["finditer"],  true]
    - [sub_present,       "__dict__.__contains__", ["sub"],       true]
    - [subn_present,      "__dict__.__contains__", ["subn"],      true]
    - [split_present,     "__dict__.__contains__", ["split"],     true]
    - [escape_present,    "__dict__.__contains__", ["escape"],    true]
    - [purge_present,     "__dict__.__contains__", ["purge"],     true]

# ---------------------------------------------------------------------------
# re module __dict__ membership — exceptions and flags
# ---------------------------------------------------------------------------

table re_extra228.dict_membership_exceptions_flags:
  description: "re.__dict__ contains the expected exception classes and flags"
  kind: python_call_eq
  category: module_membership
  id_prefix: redictflags228

  columns: [id, function, args, expected]
  rows:
    - [error_present,        "__dict__.__contains__", ["error"],        true]
    - [patternerror_present, "__dict__.__contains__", ["PatternError"], true]
    - [ignorecase_present,   "__dict__.__contains__", ["IGNORECASE"],   true]
    - [multiline_present,    "__dict__.__contains__", ["MULTILINE"],    true]
    - [dotall_present,       "__dict__.__contains__", ["DOTALL"],       true]
    - [verbose_present,      "__dict__.__contains__", ["VERBOSE"],      true]
    - [i_alias_present,      "__dict__.__contains__", ["I"],            true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra228.dict_contains_compile:
  description: "re.__dict__.__contains__('compile') == True"
  category: module_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["compile"]
  expected: true

invariant re_extra228.dict_contains_PatternError:
  description: "re.__dict__.__contains__('PatternError') == True — added in Python 3.13 as alias for re.error"
  category: module_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["PatternError"]
  expected: true

invariant re_extra228.dict_contains_IGNORECASE:
  description: "re.__dict__.__contains__('IGNORECASE') == True"
  category: module_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["IGNORECASE"]
  expected: true

invariant re_extra228.dict_contains_I_alias:
  description: "re.__dict__.__contains__('I') == True — I is the shorthand alias for IGNORECASE"
  category: module_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["I"]
  expected: true
