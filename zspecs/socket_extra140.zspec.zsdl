spec: socket_extra140
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra139.zspec.zsdl — covers socket.socket.__eq__/__hash__ qualnames (inherited from object) / socket.socket.family and type as property descriptors / socket.socket class __name__/__module__/__mro__ / socket.getfqdn and create_connection __doc__ lengths (table + invariants)."
    - "socket_extra138.zspec.zsdl — covers socket.socket.__doc__ identity and content / socket.__spec__ and __loader__ attribute identity / socket.herror and socket.gaierror exception class identity / socket.getfqdn and create_connection qualnames."
    - "socket_extra99.zspec.zsdl — covers socket.gethostname/gethostbyname/getaddrinfo/setdefaulttimeout/getdefaulttimeout __qualname__.__len__() / SocketIO class identity."
    - "socket_extra98.zspec.zsdl — covers socket.socket C-level and Python-level method __qualname__.__len__() values."
    - "socket_extra97.zspec.zsdl — covers socket.socket.__init__/accept/makefile/close __class__.__name__=='function' and __module__=='socket' / socket.socket.send/sendall/fileno __qualname__.__eq__."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC class names / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names / AddressFamily/SocketKind __bases__ / gethostname/gethostbyname/setdefaulttimeout/getdefaulttimeout __class__.__name__=='builtin_function_or_method'."
    - "socket_extra95.zspec.zsdl — covers AddressFamily/SocketKind enum member values and names / socket.__all__ class name and length."
    - "socket_extra94.zspec.zsdl — covers socket module-level function __qualname__ and __module__ values / byte-order function class names."
    - "socket_extra93.zspec.zsdl — covers socket.socket C-level method_descriptor class names."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra93 through socket_extra139."
    - "Wave 295 theme: socket.socket method_descriptor __doc__ lengths (recv/send/bind/connect/listen/setsockopt/getsockopt/sendall/recvfrom) / socket.socket.accept __doc__ length / method __qualname__ lengths."
    - "socket.socket.recv.__doc__.__len__() == 321. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.send.__doc__.__len__() == 208. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.bind.__doc__.__len__() == 233. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.connect.__doc__.__len__() == 110. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.listen.__doc__.__len__() == 305. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.setsockopt.__doc__.__len__() == 267. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getsockopt.__doc__.__len__() == 229. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.sendall.__doc__.__len__() == 240. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recvfrom.__doc__.__len__() == 126. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__doc__.__len__() == 218. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recv.__qualname__ == 'socket.recv' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.send.__qualname__ == 'socket.send' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.bind.__qualname__ == 'socket.bind' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.connect.__qualname__ == 'socket.connect' (len 14). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.listen.__qualname__ == 'socket.listen' (len 13). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.setsockopt.__qualname__ == 'socket.setsockopt' (len 17). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getsockopt.__qualname__ == 'socket.getsockopt' (len 17). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.socket.recv (321) is the longest method_descriptor docstring among the socket methods examined — it describes blocking behavior, the flags argument, and end-of-connection semantics. socket.socket.connect (110) is the shortest."
    - "Note: socket.socket.accept.__class__.__name__ == 'function' (Python-level function in Lib/socket.py), while recv/send/bind/connect/listen/setsockopt/getsockopt/sendall/recvfrom are all 'method_descriptor' (C-level from socketmodule.c)."
    - "Note: socket.socket.recv/__qualname__ == 'socket.recv' — the C-level method_descriptors use the _socket.socket class name 'socket' as qualifier (not the module-level name)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.recv.__doc__.__len__()==321
# socket.socket.send.__doc__.__len__()==208
# socket.socket.bind.__doc__.__len__()==233
# socket.socket.connect.__doc__.__len__()==110
# socket.socket.listen.__doc__.__len__()==305
#
# Wave 295 theme: socket.socket method_descriptor __doc__ lengths (group 1).
#
# socket.socket.recv (321) is the longest: it describes blocking behavior,
# the flags argument, and end-of-connection semantics (returns empty string
# when remote end is closed). socket.socket.connect (110) is the shortest.
# socket.socket.listen (305) documents the optional backlog parameter with
# default behavior and the minimum-of-zero clamping. No prior socket spec
# anchors these __doc__ lengths under sockmethod140.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra140.socket_method_doc_lengths_group1:
  description: "socket.socket.recv/__doc__/__len__()==321 / send/__doc__/__len__()==208 / bind/__doc__/__len__()==233 / connect/__doc__/__len__()==110 / listen/__doc__/__len__()==305 — recv (321) is the longest method_descriptor doc, describing blocking/flags/end-of-connection; connect (110) is the shortest; listen (305) documents optional backlog and zero-clamping; all are method_descriptors from socketmodule.c; no prior socket spec anchors these; first sockmethod140 anchor"
  kind: python_call_eq
  category: doc_lengths
  id_prefix: sockmethod140

  columns: [id, function, args, expected, description]
  rows:
    - [recv_doc_len,    socket.recv.__doc__.__len__,    [], 321, "socket.socket.recv.__doc__.__len__() is 321 (describes blocking, flags argument, and end-of-connection empty string behavior)"]
    - [send_doc_len,    socket.send.__doc__.__len__,    [], 208, "socket.socket.send.__doc__.__len__() is 208 (describes flags argument and partial-send semantics)"]
    - [bind_doc_len,    socket.bind.__doc__.__len__,    [], 233, "socket.socket.bind.__doc__.__len__() is 233 (describes IP and raw packet socket address formats)"]
    - [connect_doc_len, socket.connect.__doc__.__len__, [], 110, "socket.socket.connect.__doc__.__len__() is 110 (shortest of the group; describes IP address pair format)"]
    - [listen_doc_len,  socket.listen.__doc__.__len__,  [], 305, "socket.socket.listen.__doc__.__len__() is 305 (documents optional backlog, zero-clamping, and default behavior)"]

# ---------------------------------------------------------------------------
# socket.socket.setsockopt.__doc__.__len__()==267
# socket.socket.getsockopt.__doc__.__len__()==229
# socket.socket.sendall.__doc__.__len__()==240
# socket.socket.recvfrom.__doc__.__len__()==126
# socket.socket.accept.__doc__.__len__()==218
#
# Wave 295 theme: socket.socket method __doc__ lengths (group 2).
#
# setsockopt (267) documents three overloads (int value, buffer value, None with
# optlen). getsockopt (229) documents the optional buffersize argument.
# sendall (240) notes the repeated-send behavior and error semantics.
# recvfrom (126) is very short — it references recv() semantics plus sender address.
# accept (218) is a Python-level function (not method_descriptor). No prior
# socket spec anchors these lengths under sockmethod140.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra140.socket_method_doc_lengths_group2:
  description: "socket.socket.setsockopt/__doc__/__len__()==267 / getsockopt/__doc__/__len__()==229 / sendall/__doc__/__len__()==240 / recvfrom/__doc__/__len__()==126 / accept/__doc__/__len__()==218 — setsockopt (267) documents three overloads; getsockopt (229) documents optional buffersize; sendall (240) notes repeated-send behavior; recvfrom (126) is very short (references recv semantics); accept (218) is a Python-level function (class 'function', not method_descriptor); no prior socket spec anchors these; first sockmethod140 anchor"
  kind: python_call_eq
  category: doc_lengths
  id_prefix: sockmethod140

  columns: [id, function, args, expected, description]
  rows:
    - [setsockopt_doc_len, socket.setsockopt.__doc__.__len__, [], 267, "socket.socket.setsockopt.__doc__.__len__() is 267 (documents three overloads: int/buffer/None+optlen)"]
    - [getsockopt_doc_len, socket.getsockopt.__doc__.__len__, [], 229, "socket.socket.getsockopt.__doc__.__len__() is 229 (documents optional buffersize; returns int or string)"]
    - [sendall_doc_len,    socket.sendall.__doc__.__len__,    [], 240, "socket.socket.sendall.__doc__.__len__() is 240 (notes repeated-send behavior and partial-error semantics)"]
    - [recvfrom_doc_len,   socket.recvfrom.__doc__.__len__,   [], 126, "socket.socket.recvfrom.__doc__.__len__() is 126 (very short; references recv() semantics plus sender address)"]
    - [accept_doc_len,     socket.accept.__doc__.__len__,     [], 218, "socket.socket.accept.__doc__.__len__() is 218 (Python-level function in Lib/socket.py; documents return value as (socket, address) pair)"]

# ---------------------------------------------------------------------------
# socket.socket.recv.__qualname__.__len__()==11 ('socket.recv')
# socket.socket.send.__qualname__.__len__()==11 ('socket.send')
# socket.socket.bind.__qualname__.__len__()==11 ('socket.bind')
# socket.socket.connect.__qualname__.__len__()==14 ('socket.connect')
# socket.socket.listen.__qualname__.__len__()==13 ('socket.listen')
# socket.socket.setsockopt.__qualname__.__len__()==17 ('socket.setsockopt')
# socket.socket.getsockopt.__qualname__.__len__()==17 ('socket.getsockopt')
#
# Wave 295 theme: socket.socket method __qualname__ lengths.
#
# All method_descriptor qualnames follow the pattern 'socket.<method>' where
# 'socket' is the _socket.socket class name. recv/send/bind (4-char method
# names) give 11-char qualnames. setsockopt and getsockopt (10-char method
# names) give 17-char qualnames. No prior socket spec anchors these qualname
# lengths under sockmethod140. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra140.socket_method_qualname_lengths:
  description: "socket.socket.recv/__qualname__/__len__()==11 / send/__qualname__/__len__()==11 / bind/__qualname__/__len__()==11 / connect/__qualname__/__len__()==14 / listen/__qualname__/__len__()==13 / setsockopt/__qualname__/__len__()==17 / getsockopt/__qualname__/__len__()==17 — qualnames follow 'socket.<method>' pattern (7 chars for 'socket.' prefix + method name length); recv/send/bind share 11-char qualnames; setsockopt/getsockopt share 17-char qualnames; no prior socket spec anchors these; first sockmethod140 anchor"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: sockmethod140

  columns: [id, function, args, expected, description]
  rows:
    - [recv_qualname_len,      socket.recv.__qualname__.__len__,      [], 11, "socket.socket.recv.__qualname__.__len__() is 11 ('socket.recv' = 7 + 4 chars)"]
    - [send_qualname_len,      socket.send.__qualname__.__len__,      [], 11, "socket.socket.send.__qualname__.__len__() is 11 ('socket.send' = 7 + 4 chars)"]
    - [bind_qualname_len,      socket.bind.__qualname__.__len__,      [], 11, "socket.socket.bind.__qualname__.__len__() is 11 ('socket.bind' = 7 + 4 chars)"]
    - [connect_qualname_len,   socket.connect.__qualname__.__len__,   [], 14, "socket.socket.connect.__qualname__.__len__() is 14 ('socket.connect' = 7 + 7 chars)"]
    - [listen_qualname_len,    socket.listen.__qualname__.__len__,    [], 13, "socket.socket.listen.__qualname__.__len__() is 13 ('socket.listen' = 7 + 6 chars)"]
    - [setsockopt_qualname_len, socket.setsockopt.__qualname__.__len__, [], 17, "socket.socket.setsockopt.__qualname__.__len__() is 17 ('socket.setsockopt' = 7 + 10 chars)"]
    - [getsockopt_qualname_len, socket.getsockopt.__qualname__.__len__, [], 17, "socket.socket.getsockopt.__qualname__.__len__() is 17 ('socket.getsockopt' = 7 + 10 chars, same as setsockopt)"]

# ---------------------------------------------------------------------------
# socket.socket.recv.__doc__.__len__()==321 — standalone
#
# socket.socket.recv.__doc__.__len__() is 321. The recv docstring is the longest
# among the socket.socket method_descriptor docstrings examined in this spec.
# It describes: the buffersize argument, the optional flags argument (referring
# to Unix manual), the blocking behavior (blocks when no data is available),
# and the end-of-connection semantics (returns empty string when remote end
# is closed and all data is read). No prior socket spec anchors
# socket.socket.recv.__doc__.__len__() as a standalone under sockmethod140.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra140.socket_recv_doc_len_321:
  description: "socket.socket.recv.__doc__.__len__() == 321 — longest socket.socket method_descriptor docstring in this spec (321 chars); describes buffersize/flags arguments, blocking behavior, and end-of-connection semantics (empty string return); C-level method_descriptor from socketmodule.c; no prior socket spec anchors this as a standalone; first standalone under sockmethod140"
  category: doc_lengths
  kind: python_call_eq
  function: socket.recv.__doc__.__len__
  args: []
  expected: 321

# ---------------------------------------------------------------------------
# socket.socket.connect.__doc__.__len__()==110 — standalone
#
# socket.socket.connect.__doc__.__len__() is 110. The connect docstring is the
# shortest of the socket.socket method_descriptor docstrings examined: it simply
# states 'Connect the socket to a remote address. For IP sockets, the address
# is a pair (host, port).' The brevity reflects that connect has a single
# required argument and the semantics are well-understood. No prior socket spec
# anchors socket.socket.connect.__doc__.__len__() as a standalone under
# sockmethod140. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra140.socket_connect_doc_len_110:
  description: "socket.socket.connect.__doc__.__len__() == 110 — shortest socket.socket method_descriptor docstring in this spec (110 chars); single required argument, well-understood semantics; C-level method_descriptor from socketmodule.c; no prior socket spec anchors this as a standalone; first standalone under sockmethod140"
  category: doc_lengths
  kind: python_call_eq
  function: socket.connect.__doc__.__len__
  args: []
  expected: 110

# ---------------------------------------------------------------------------
# socket.socket.listen.__doc__.__len__()==305 — standalone
#
# socket.socket.listen.__doc__.__len__() is 305. The listen docstring is the
# second-longest method_descriptor docstring in this spec. It documents the
# optional backlog parameter, the minimum-of-zero clamping behavior (backlog
# values lower than 0 are set to 0), and the default-reasonable-value behavior
# when backlog is not specified. No prior socket spec anchors
# socket.socket.listen.__doc__.__len__() as a standalone under sockmethod140.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra140.socket_listen_doc_len_305:
  description: "socket.socket.listen.__doc__.__len__() == 305 — second-longest socket.socket method_descriptor docstring (305 chars); documents optional backlog parameter, zero-clamping, and default behavior; C-level method_descriptor from socketmodule.c; no prior socket spec anchors this as a standalone; first standalone under sockmethod140"
  category: doc_lengths
  kind: python_call_eq
  function: socket.listen.__doc__.__len__
  args: []
  expected: 305

# ---------------------------------------------------------------------------
# socket.socket.recvfrom.__doc__.__len__()==126 — standalone
#
# socket.socket.recvfrom.__doc__.__len__() is 126. The recvfrom docstring is
# very short — it simply says 'Like recv(buffersize, flags) but also return
# the sender's address info.' This brevity comes from its reliance on the recv
# docstring for the main semantics, with only the address return value being
# additional. No prior socket spec anchors socket.socket.recvfrom.__doc__.__len__()
# as a standalone under sockmethod140. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra140.socket_recvfrom_doc_len_126:
  description: "socket.socket.recvfrom.__doc__.__len__() == 126 — very short docstring (126 chars); delegates to recv() semantics with only the sender address return as addendum; C-level method_descriptor from socketmodule.c; no prior socket spec anchors this as a standalone; first standalone under sockmethod140"
  category: doc_lengths
  kind: python_call_eq
  function: socket.recvfrom.__doc__.__len__
  args: []
  expected: 126

