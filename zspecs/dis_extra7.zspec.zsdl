spec: dis_extra7
version: ">=3.9"
backend: python_module(dis)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dis.html — Python dis module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dis.py"
    - "CPython source: Python/compile.c"
    - "dis.zspec.zsdl — covers __name__ for Instruction/Bytecode/dis/disassemble/code_info/show_code/get_instructions/stack_effect; opname class/length; opmap contains/values; stack_effect values; haslocal/hasname"
    - "dis_extra.zspec.zsdl — covers dis.__name__ (module name), distb/__name__, findlinestarts/__name__, findlabels/__name__, disassemble/__name__, code_info/__name__, show_code/__name__, get_instructions/__name__, stack_effect/__name__, Instruction/__name__/__module__, opname/__class__/__name__, opmap/__class__/__name__, HAVE_ARGUMENT/__class__/__name__"
    - "dis_extra2.zspec.zsdl — covers __module__ for dis/disassemble/get_instructions/findlinestarts/findlabels/code_info; Instruction/__name__/__module__/__bases__[0]; Bytecode/__name__/__module__/__bases__[0]; opname/opmap class checks; HAVE_ARGUMENT class check"
    - "dis_extra3.zspec.zsdl — covers __name__/__module__ for Instruction/Bytecode (table); __name__ for findlinestarts/findlabels/get_instructions/stack_effect (table); opname class/length; opmap class/contains; HAVE_ARGUMENT value; Bytecode.__module__"
    - "dis_extra4.zspec.zsdl — covers Instruction.__qualname__; Instruction._fields class/contains-opname/contains-opcode; opname.__len__ >= 100; dis/disassemble/get_instructions/findlinestarts __qualname__ (table)"
    - "dis_extra5.zspec.zsdl — covers __qualname__ for code_info/show_code/stack_effect/findlabels/distb; Bytecode.__qualname__; Instruction._fields[0] == 'opname'; show_code/__module__; distb/__module__"
    - "dis_extra6.zspec.zsdl — covers hasjabs empty list; hasjrel/hasconst/hascompare/hasfree class+len; Instruction._fields[1]/'opcode' and _fields[2]/'arg'; opmap LOAD_CONST/LOAD_GLOBAL/RETURN_VALUE/STORE_NAME values; opname[82] == 'LOAD_CONST'"
  notes:
    - "This spec adds new axes: Instruction._fields[3]/'argval' and _fields[4]/'argrepr' (not yet verified); hasexc class and nonempty check (Python 3.12+); hasarg class and nonempty check; Bytecode.__bases__[0].__name__ == 'object'; opmap additional entries BINARY_OP/CALL/RESUME; opname indexed access for POP_TOP/STORE_NAME/RETURN_VALUE; HAVE_ARGUMENT class check via __class__.__name__."
    - "dis.Instruction._fields[3] == 'argval' — fourth field, not checked in any prior spec."
    - "dis.Instruction._fields[4] == 'argrepr' — fifth field, not checked in any prior spec."
    - "dis.hasexc is a list (Python 3.12+) with 3 entries — exception-related opcodes."
    - "dis.hasarg is a list with 101 entries in Python 3.12 — opcodes that take an argument."
    - "dis.Bytecode.__bases__[0].__name__ == 'object' — Bytecode is a top-level class."
    - "dis.opmap['BINARY_OP'] == 44 in Python 3.12."
    - "dis.opmap['CALL'] == 52 in Python 3.12."
    - "dis.opmap['RESUME'] == 128 in Python 3.12."
    - "dis.opname[31] == 'POP_TOP' — indexed access not previously tested for this opcode."
    - "dis.opname[116] == 'STORE_NAME' — indexed access not previously tested for this opcode."
    - "dis.opname[35] == 'RETURN_VALUE' — indexed access not previously tested for this opcode."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Instruction._fields[3] == 'argval', _fields[4] == 'argrepr'
# dis_extra5 confirmed _fields[0] == 'opname'.
# dis_extra6 confirmed _fields[1] == 'opcode' and _fields[2] == 'arg'.
# The next two fields have not been verified in any prior spec.
# ---------------------------------------------------------------------------

invariant dis_extra7.Instruction.fields_index3:
  description: "dis.Instruction._fields[3] == 'argval' — fourth field of Instruction namedtuple"
  category: instruction_fields
  kind: python_call_eq
  function: Instruction._fields.__getitem__
  args: [3]
  expected: "argval"

invariant dis_extra7.Instruction.fields_index4:
  description: "dis.Instruction._fields[4] == 'argrepr' — fifth field of Instruction namedtuple"
  category: instruction_fields
  kind: python_call_eq
  function: Instruction._fields.__getitem__
  args: [4]
  expected: "argrepr"

# ---------------------------------------------------------------------------
# hasexc — class and nonempty check (Python 3.12+)
# No prior spec covers dis.hasexc. In Python 3.12 it has 3 entries for
# exception-related opcodes (SETUP_CLEANUP, SETUP_WITH, SETUP_FINALLY equiv.).
# ---------------------------------------------------------------------------

invariant dis_extra7.hasexc.is_list:
  description: "dis.hasexc is a list"
  category: opcode_sets
  kind: python_call_eq
  function: hasexc.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant dis_extra7.hasexc.nonempty:
  description: "dis.hasexc has at least one entry (Python 3.12+)"
  category: opcode_sets
  kind: python_call_eq
  function: hasexc.__len__
  args: []
  method: __ge__
  method_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# hasarg — class and nonempty check
# No prior spec covers dis.hasarg. In Python 3.12 it has 101 entries.
# ---------------------------------------------------------------------------

invariant dis_extra7.hasarg.is_list:
  description: "dis.hasarg is a list"
  category: opcode_sets
  kind: python_call_eq
  function: hasarg.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant dis_extra7.hasarg.nonempty:
  description: "dis.hasarg has many entries — opcodes that take an argument"
  category: opcode_sets
  kind: python_call_eq
  function: hasarg.__len__
  args: []
  method: __ge__
  method_args: [10]
  expected: true

# ---------------------------------------------------------------------------
# Bytecode.__bases__[0].__name__ == 'object'
# dis_extra2 covers Bytecode/__name__/__module__/__bases__[0] but the note
# says bases[0] only; no spec verifies it is 'object' via __name__.__eq__.
# ---------------------------------------------------------------------------

invariant dis_extra7.Bytecode.base_is_object:
  description: "dis.Bytecode.__bases__[0].__name__ == 'object' — Bytecode is a top-level class"
  category: hierarchy
  kind: python_call_eq
  function: Bytecode.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# opmap additional entries not in prior specs
# dis.zspec covers LOAD_FAST (84) and POP_TOP (31).
# dis_extra6 covers LOAD_CONST (82), LOAD_GLOBAL (92), RETURN_VALUE (35), STORE_NAME (116).
# New here: BINARY_OP (44), CALL (52), RESUME (128).
# ---------------------------------------------------------------------------

table dis_extra7.opmap_values:
  kind: python_call_eq
  category: opmap
  id_prefix: opmap

  columns: [id, function, args, expected]
  rows:
    - [BINARY_OP,  opmap.__getitem__, ["BINARY_OP"],  44]
    - [CALL,       opmap.__getitem__, ["CALL"],        52]
    - [RESUME,     opmap.__getitem__, ["RESUME"],     128]

# ---------------------------------------------------------------------------
# opname indexed access for opcodes not previously spot-checked
# dis_extra6 checks opname[82] == 'LOAD_CONST'.
# New here: opname[31]/'POP_TOP', opname[116]/'STORE_NAME', opname[35]/'RETURN_VALUE'.
# ---------------------------------------------------------------------------

table dis_extra7.opname_index:
  kind: python_call_eq
  category: opname
  id_prefix: opname

  columns: [id, function, args, expected]
  rows:
    - [idx31,   opname.__getitem__, [31],  "POP_TOP"]
    - [idx116,  opname.__getitem__, [116], "STORE_NAME"]
    - [idx35,   opname.__getitem__, [35],  "RETURN_VALUE"]
