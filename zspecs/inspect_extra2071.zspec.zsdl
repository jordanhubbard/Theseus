spec: inspect_extra2071
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/inspect.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 585 (_extra2071): __pos__/__neg__, __getattribute__, __reduce__/__reduce_ex__, __copy__/__deepcopy__ dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "inspect.Parameter defines __reduce__ (True) in its __dict__ — it is an immutable frozen-like class that implements custom pickling for its enum-valued kind attribute."
    - "inspect.Signature defines __reduce__ (True) in its __dict__ — it implements custom pickling to preserve its parameters mapping and return_annotation."
    - "inspect.BoundArguments does NOT define __reduce__ in its __dict__."
    - "None of Parameter, Signature, or BoundArguments define __pos__, __neg__, __getattribute__, __reduce_ex__, __copy__, or __deepcopy__ in their own __dict__."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __pos__ / __neg__ dict-presence for inspect classes
#
# inspect.Parameter, Signature, and BoundArguments are introspection classes,
# not numeric types. None define __pos__ or __neg__ in their own __dict__.
# ---------------------------------------------------------------------------

table inspect_extra2071.unary_sign_protocol:
  description: "inspect classes __pos__/__neg__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2071

  columns: [id, function, args, expected]
  rows:
    - ["in2071001", "inspect.Parameter.__dict__.__contains__", ["__pos__"], false]
    - ["in2071002", "inspect.Parameter.__dict__.__contains__", ["__neg__"], false]
    - ["in2071003", "inspect.Signature.__dict__.__contains__", ["__pos__"], false]
    - ["in2071004", "inspect.Signature.__dict__.__contains__", ["__neg__"], false]
    - ["in2071005", "inspect.BoundArguments.__dict__.__contains__", ["__pos__"], false]
    - ["in2071006", "inspect.BoundArguments.__dict__.__contains__", ["__neg__"], false]

# ---------------------------------------------------------------------------
# Table 2: __getattribute__ dict-presence for inspect classes
#
# None of Parameter, Signature, or BoundArguments override __getattribute__
# in their own __dict__. They rely on the default object.__getattribute__.
# ---------------------------------------------------------------------------

table inspect_extra2071.getattribute_protocol:
  description: "inspect classes __getattribute__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2071

  columns: [id, function, args, expected]
  rows:
    - ["in2071007", "inspect.Parameter.__dict__.__contains__", ["__getattribute__"], false]
    - ["in2071008", "inspect.Signature.__dict__.__contains__", ["__getattribute__"], false]
    - ["in2071009", "inspect.BoundArguments.__dict__.__contains__", ["__getattribute__"], false]

# ---------------------------------------------------------------------------
# Table 3: __reduce__ / __reduce_ex__ dict-presence for inspect classes
#
# inspect.Parameter defines __reduce__ (True) in its __dict__ — custom pickle
# support is needed because Parameter.kind is an IntEnum and Parameter is
# intended to be reconstructable.
# inspect.Signature also defines __reduce__ (True) — it custom-pickles its
# parameters OrderedDict and return_annotation.
# inspect.BoundArguments does NOT define __reduce__.
# None of the three define __reduce_ex__.
# ---------------------------------------------------------------------------

table inspect_extra2071.pickle_protocol:
  description: "inspect classes __reduce__/__reduce_ex__ dict-presence — Parameter and Signature True for __reduce__, BoundArguments False, all False for __reduce_ex__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2071

  columns: [id, function, args, expected]
  rows:
    - ["in2071010", "inspect.Parameter.__dict__.__contains__", ["__reduce__"], true]
    - ["in2071011", "inspect.Parameter.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["in2071012", "inspect.Signature.__dict__.__contains__", ["__reduce__"], true]
    - ["in2071013", "inspect.Signature.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["in2071014", "inspect.BoundArguments.__dict__.__contains__", ["__reduce__"], false]
    - ["in2071015", "inspect.BoundArguments.__dict__.__contains__", ["__reduce_ex__"], false]

# ---------------------------------------------------------------------------
# Table 4: __copy__ / __deepcopy__ dict-presence for inspect classes
#
# None of Parameter, Signature, or BoundArguments define __copy__ or
# __deepcopy__ in their own __dict__. The copy module falls back to the
# generic protocol (using __reduce__ where available).
# ---------------------------------------------------------------------------

table inspect_extra2071.copy_protocol:
  description: "inspect classes __copy__/__deepcopy__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2071

  columns: [id, function, args, expected]
  rows:
    - ["in2071016", "inspect.Parameter.__dict__.__contains__", ["__copy__"], false]
    - ["in2071017", "inspect.Parameter.__dict__.__contains__", ["__deepcopy__"], false]
    - ["in2071018", "inspect.Signature.__dict__.__contains__", ["__copy__"], false]
    - ["in2071019", "inspect.Signature.__dict__.__contains__", ["__deepcopy__"], false]
    - ["in2071020", "inspect.BoundArguments.__dict__.__contains__", ["__copy__"], false]
    - ["in2071021", "inspect.BoundArguments.__dict__.__contains__", ["__deepcopy__"], false]

# ---------------------------------------------------------------------------
# Table 5: Cross-check — Parameter and Signature have __reduce__; BoundArguments does not
#
# Confirms the asymmetry: Parameter and Signature pickle themselves, but
# BoundArguments (which holds live argument bindings) does not.
# ---------------------------------------------------------------------------

table inspect_extra2071.reduce_cross_check:
  description: "inspect classes __reduce__ asymmetry cross-check — Parameter and Signature True, BoundArguments False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2071

  columns: [id, function, args, expected]
  rows:
    - ["in2071022", "inspect.Parameter.__dict__.__contains__", ["__reduce__"], true]
    - ["in2071023", "inspect.Signature.__dict__.__contains__", ["__reduce__"], true]
    - ["in2071024", "inspect.BoundArguments.__dict__.__contains__", ["__reduce__"], false]
    - ["in2071025", "inspect.Parameter.__dict__.__contains__", ["__pos__"], false]
    - ["in2071026", "inspect.Signature.__dict__.__contains__", ["__neg__"], false]
    - ["in2071027", "inspect.BoundArguments.__dict__.__contains__", ["__copy__"], false]
    - ["in2071028", "inspect.Parameter.__dict__.__contains__", ["__deepcopy__"], false]
    - ["in2071029", "inspect.Signature.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["in2071030", "inspect.BoundArguments.__dict__.__contains__", ["__getattribute__"], false]
