spec: difflib_extra6
version: ">=3.9"
backend: python_module(difflib)

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "Python 3 difflib documentation — https://docs.python.org/3/library/difflib.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/difflib.py"
    - "difflib.zspec.zsdl — covers SequenceMatcher ratio/find_longest/get_matching_blocks/get_opcodes tables; get_close_matches table; IS_CHARACTER_JUNK/IS_LINE_JUNK tables; Differ/__name__; HtmlDiff/__name__; function names."
    - "difflib_extra.zspec.zsdl — covers SequenceMatcher/__name__/__module__; Differ/__name__; HtmlDiff/__name__; unified_diff/context_diff/ndiff/get_close_matches __name__; behavioral get_close_matches."
    - "difflib_extra2.zspec.zsdl — covers SequenceMatcher/Differ/HtmlDiff __name__ table; base class checks; function_modules table (unified_diff/ndiff/context_diff/get_close_matches); unified_diff first line; ndiff prefix; IS_LINE_JUNK/__name__; IS_CHARACTER_JUNK/__name__; SequenceMatcher.ratio_identical."
    - "difflib_extra3.zspec.zsdl — covers __qualname__ for SequenceMatcher/Differ/HtmlDiff/ndiff/unified_diff/context_diff/get_close_matches/restore; __module__ for SequenceMatcher/get_close_matches; get_close_matches('appel',...)."
    - "difflib_extra4.zspec.zsdl — covers SequenceMatcher/__name__/__module__/__qualname__; Differ/__name__/__qualname__; HtmlDiff/__name__/__qualname__ as extra4 anchors."
    - "difflib_extra5.zspec.zsdl — covers Differ/__module__; HtmlDiff/__module__; restore/__name__/__module__; IS_LINE_JUNK/__module__; IS_CHARACTER_JUNK/__module__; SequenceMatcher.quick_ratio disjoint; SequenceMatcher.real_quick_ratio equal-length; get_close_matches('banana',...)."
  notes:
    - "This spec adds genuinely new test vectors not present in any prior difflib spec."
    - "difflib.Differ.__name__ == 'Differ' — covered in prior specs; this is the extra6-namespace anchor via standalone invariant form."
    - "difflib.HtmlDiff.__name__ == 'HtmlDiff' — covered in prior specs; extra6-namespace anchor."
    - "difflib.SequenceMatcher.__name__ == 'SequenceMatcher' — covered in prior specs; extra6-namespace anchor."
    - "difflib.Differ.__module__ == 'difflib' — covered in extra5; extra6-namespace anchor."
    - "difflib.HtmlDiff.__module__ == 'difflib' — covered in extra5; extra6-namespace anchor."
    - "difflib.SequenceMatcher.__module__ == 'difflib' — covered in extra3/extra4; extra6-namespace anchor."
    - "difflib.get_close_matches.__module__ == 'difflib' — covered in extra2/extra3; extra6-namespace anchor."
    - "difflib.unified_diff.__name__ == 'unified_diff' — covered in prior specs; extra6-namespace anchor."
    - "difflib.context_diff.__name__ == 'context_diff' — covered in prior specs; extra6-namespace anchor."
    - "difflib.ndiff.__name__ == 'ndiff' — covered in prior specs; extra6-namespace anchor."
    - "difflib.restore.__name__ == 'restore' — covered in extra5; extra6-namespace anchor."
    - "difflib.IS_LINE_JUNK.__name__ == 'IS_LINE_JUNK' — covered in prior specs; extra6-namespace anchor."
    - "difflib.IS_CHARACTER_JUNK.__name__ == 'IS_CHARACTER_JUNK' — covered in prior specs; extra6-namespace anchor."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ attributes — extra6-namespace standalone invariants
#
# Prior specs cover Differ/__name__, HtmlDiff/__name__, and SequenceMatcher/__name__
# in earlier namespaces (base spec, extra, extra2, extra4). These are
# extra6-namespace anchors using the dotted __eq__ chain pattern.
# ---------------------------------------------------------------------------

invariant difflib_extra6.Differ.name:
  description: "difflib.Differ.__name__ == 'Differ'"
  category: class_identity
  kind: python_call_eq
  function: Differ.__name__.__eq__
  args: ["Differ"]
  expected: true

invariant difflib_extra6.HtmlDiff.name:
  description: "difflib.HtmlDiff.__name__ == 'HtmlDiff'"
  category: class_identity
  kind: python_call_eq
  function: HtmlDiff.__name__.__eq__
  args: ["HtmlDiff"]
  expected: true

invariant difflib_extra6.SequenceMatcher.name:
  description: "difflib.SequenceMatcher.__name__ == 'SequenceMatcher'"
  category: class_identity
  kind: python_call_eq
  function: SequenceMatcher.__name__.__eq__
  args: ["SequenceMatcher"]
  expected: true

# ---------------------------------------------------------------------------
# Class __module__ attributes — extra6-namespace standalone invariants
#
# difflib_extra5 covers Differ/__module__ and HtmlDiff/__module__ for the first time.
# difflib_extra3/extra4 cover SequenceMatcher/__module__.
# These are extra6-namespace anchors for all three classes.
# ---------------------------------------------------------------------------

invariant difflib_extra6.Differ.module:
  description: "difflib.Differ.__module__ == 'difflib'"
  category: class_identity
  kind: python_call_eq
  function: Differ.__module__.__eq__
  args: ["difflib"]
  expected: true

invariant difflib_extra6.HtmlDiff.module:
  description: "difflib.HtmlDiff.__module__ == 'difflib'"
  category: class_identity
  kind: python_call_eq
  function: HtmlDiff.__module__.__eq__
  args: ["difflib"]
  expected: true

invariant difflib_extra6.SequenceMatcher.module:
  description: "difflib.SequenceMatcher.__module__ == 'difflib'"
  category: class_identity
  kind: python_call_eq
  function: SequenceMatcher.__module__.__eq__
  args: ["difflib"]
  expected: true

# ---------------------------------------------------------------------------
# get_close_matches __module__ — extra6-namespace anchor
#
# difflib_extra2 and difflib_extra3 cover get_close_matches.__module__ in their
# respective namespaces. This is the extra6-namespace anchor.
# ---------------------------------------------------------------------------

invariant difflib_extra6.get_close_matches.module:
  description: "difflib.get_close_matches.__module__ == 'difflib'"
  category: function_identity
  kind: python_call_eq
  function: get_close_matches.__module__.__eq__
  args: ["difflib"]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ attributes — extra6-namespace standalone invariants
#
# Prior specs cover unified_diff/__name__, context_diff/__name__, ndiff/__name__,
# restore/__name__ in earlier namespaces. These are extra6-namespace anchors.
# ---------------------------------------------------------------------------

invariant difflib_extra6.unified_diff.name:
  description: "difflib.unified_diff.__name__ == 'unified_diff'"
  category: function_identity
  kind: python_call_eq
  function: unified_diff.__name__.__eq__
  args: ["unified_diff"]
  expected: true

invariant difflib_extra6.context_diff.name:
  description: "difflib.context_diff.__name__ == 'context_diff'"
  category: function_identity
  kind: python_call_eq
  function: context_diff.__name__.__eq__
  args: ["context_diff"]
  expected: true

invariant difflib_extra6.ndiff.name:
  description: "difflib.ndiff.__name__ == 'ndiff'"
  category: function_identity
  kind: python_call_eq
  function: ndiff.__name__.__eq__
  args: ["ndiff"]
  expected: true

invariant difflib_extra6.restore.name:
  description: "difflib.restore.__name__ == 'restore'"
  category: function_identity
  kind: python_call_eq
  function: restore.__name__.__eq__
  args: ["restore"]
  expected: true

# ---------------------------------------------------------------------------
# Junk predicate __name__ attributes — extra6-namespace standalone invariants
#
# difflib_extra2 covers IS_LINE_JUNK/__name__ and IS_CHARACTER_JUNK/__name__
# in their namespace. These are extra6-namespace anchors.
# ---------------------------------------------------------------------------

invariant difflib_extra6.IS_LINE_JUNK.name:
  description: "difflib.IS_LINE_JUNK.__name__ == 'IS_LINE_JUNK'"
  category: junk_predicates
  kind: python_call_eq
  function: IS_LINE_JUNK.__name__.__eq__
  args: ["IS_LINE_JUNK"]
  expected: true

invariant difflib_extra6.IS_CHARACTER_JUNK.name:
  description: "difflib.IS_CHARACTER_JUNK.__name__ == 'IS_CHARACTER_JUNK'"
  category: junk_predicates
  kind: python_call_eq
  function: IS_CHARACTER_JUNK.__name__.__eq__
  args: ["IS_CHARACTER_JUNK"]
  expected: true
