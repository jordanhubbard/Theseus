spec: lodash_find
version: ">=4.0.0"
backend: node(lodash.find)

docs: https://lodash.com/docs/#find

provenance:
  derived_from:
    - "lodash.find README — https://www.npmjs.com/package/lodash.find"
    - "Test vectors verified with lodash.find@4.6.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.find exports the _.find function directly as module.exports."
    - "find(collection, predicate) returns the first element matching the predicate."
    - "Object predicate uses match shorthand: finds first element where all given properties match."
    - "Returns undefined if not found (omitted from test vectors)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the matching element or undefined."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_find.find:
  kind: node_module_call_eq
  function: ~
  category: find
  id_prefix: lfind

  columns: [id, args, expected]
  rows:
    - [by_id,     [[{"id": 1, "n": "a"}, {"id": 2, "n": "b"}], {"id": 2}],
       {"id": 2, "n": "b"}]
    - [first_match, [[{"x": 1}, {"x": 2}, {"x": 1}], {"x": 1}],
       {"x": 1}]
    - [by_prop,   [[{"active": false, "n": "a"}, {"active": true, "n": "b"}], "active"],
       {"active": true, "n": "b"}]

