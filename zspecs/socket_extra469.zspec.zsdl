spec: socket_extra469
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module public API"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Checks __name__ identity for socket.socket class methods and module-level functions"
    - "socket.socket methods are C-level implementations; __name__ is stable across CPython versions"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra469.socket_class_method_names:
  description: "socket.socket class method __name__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: SKM

  columns: [id, function, args, expected]
  rows:
    - [SKM001, socket.socket.connect.__name__.__eq__, ["connect"], true]
    - [SKM002, socket.socket.bind.__name__.__eq__, ["bind"], true]
    - [SKM003, socket.socket.listen.__name__.__eq__, ["listen"], true]
    - [SKM004, socket.socket.accept.__name__.__eq__, ["accept"], true]
    - [SKM005, socket.socket.send.__name__.__eq__, ["send"], true]
    - [SKM006, socket.socket.recv.__name__.__eq__, ["recv"], true]
    - [SKM007, socket.socket.close.__name__.__eq__, ["close"], true]
    - [SKM008, socket.socket.setsockopt.__name__.__eq__, ["setsockopt"], true]
    - [SKM009, socket.socket.getsockopt.__name__.__eq__, ["getsockopt"], true]
    - [SKM010, socket.socket.settimeout.__name__.__eq__, ["settimeout"], true]
    - [SKM011, socket.socket.gettimeout.__name__.__eq__, ["gettimeout"], true]
    - [SKM012, socket.socket.fileno.__name__.__eq__, ["fileno"], true]

table socket_extra469.socket_module_function_names:
  description: "socket module-level function __name__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: SKF

  columns: [id, function, args, expected]
  rows:
    - [SKF001, socket.getfqdn.__name__.__eq__, ["getfqdn"], true]
    - [SKF002, socket.gethostname.__name__.__eq__, ["gethostname"], true]
    - [SKF003, socket.gethostbyname.__name__.__eq__, ["gethostbyname"], true]
