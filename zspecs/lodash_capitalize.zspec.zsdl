spec: lodash_capitalize
version: ">=4.0.0"
backend: node(lodash.capitalize)

docs: https://lodash.com/docs/#capitalize

provenance:
  derived_from:
    - "lodash.capitalize README — https://www.npmjs.com/package/lodash.capitalize"
    - "Test vectors verified with lodash.capitalize@4.2.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.capitalize exports the _.capitalize function directly as module.exports."
    - "Capitalizes the first character and lowercases the rest."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns capitalized string. No errors for string inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_capitalize.convert:
  kind: node_module_call_eq
  function: ~
  category: convert
  id_prefix: lcap

  columns: [id, args, expected]
  rows:
    - [lower,  ["hello"],  "Hello"]
    - [upper,  ["WORLD"],  "World"]
    - [mixed,  ["fOO"],    "Foo"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:19:19Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
