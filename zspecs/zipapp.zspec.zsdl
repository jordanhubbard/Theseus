spec: zipapp
version: ">=3.5"
backend: python_module(zipapp)

docs: https://docs.python.org/3/library/zipapp.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/zipapp.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/zipapp.py"
  notes:
    - "zipapp was added in Python 3.5 to manage executable Python zip archives."
    - "ZipAppError inherits from ValueError, not Exception directly."
    - "create_archive and get_interpreter are plain Python functions (type == 'function')."
    - "ZipAppError.__module__ == 'zipapp' because it is defined at module top-level."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "zipapp.create_archive raises ZipAppError (a ValueError subclass) when the source is invalid or lacks a __main__.py; get_interpreter raises BadZipFile if the archive is not valid."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Function name attributes
# ---------------------------------------------------------------------------

table zipapp.func_names:
  kind: python_call_eq
  category: functions
  id_prefix: func_name

  columns: [id, function, args, expected]
  rows:
    - [create_archive,   "create_archive.__name__.__eq__",   ["create_archive"],   true]
    - [get_interpreter,  "get_interpreter.__name__.__eq__",  ["get_interpreter"],  true]

# ---------------------------------------------------------------------------
# Function type checks
# ---------------------------------------------------------------------------

table zipapp.func_types:
  kind: python_call_eq
  category: types
  id_prefix: func_type

  columns: [id, function, args, expected]
  rows:
    - [create_archive,  "create_archive.__class__.__name__.__eq__",  ["function"], true]
    - [get_interpreter, "get_interpreter.__class__.__name__.__eq__", ["function"], true]

# ---------------------------------------------------------------------------
# ZipAppError class name and module
# ---------------------------------------------------------------------------

invariant zipapp.ZipAppError.class_name:
  description: "zipapp.ZipAppError.__name__ == 'ZipAppError'"
  category: classnames
  kind: python_call_eq
  function: "ZipAppError.__name__.__eq__"
  args: ["ZipAppError"]
  expected: true

invariant zipapp.ZipAppError.module:
  description: "zipapp.ZipAppError.__module__ == 'zipapp'"
  category: classnames
  kind: python_call_eq
  function: "ZipAppError.__module__.__eq__"
  args: ["zipapp"]
  expected: true

# ---------------------------------------------------------------------------
# ZipAppError hierarchy — inherits from ValueError
# ---------------------------------------------------------------------------

invariant zipapp.ZipAppError.base_class:
  description: "zipapp.ZipAppError.__bases__[0].__name__ == 'ValueError'"
  category: hierarchy
  kind: python_call_eq
  function: "ZipAppError.__bases__.__getitem__"
  args: [0]
  method: __name__
  method_args: []
  expected: "ValueError"

# ---------------------------------------------------------------------------
# ZipAppError is a class (type object)
# ---------------------------------------------------------------------------

invariant zipapp.ZipAppError.is_type:
  description: "type(zipapp.ZipAppError).__name__ == 'type' — ZipAppError is a class"
  category: types
  kind: python_call_eq
  function: "ZipAppError.__class__.__name__.__eq__"
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# ZipAppError is a subclass of Exception (via ValueError)
# ---------------------------------------------------------------------------

invariant zipapp.ZipAppError.is_exception:
  description: "issubclass(ZipAppError, ValueError) — ZipAppError IS-A ValueError"
  category: hierarchy
  kind: python_call_eq
  function: "issubclass"
  args: ["ZipAppError", "ValueError"]
  expected: true
