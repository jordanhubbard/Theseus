spec: pp2986
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module class hierarchy"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 646 (pp2986): __len__, __length_hint__, __contains__ dict-presence checks for pathlib types."
    - "pathlib path objects represent filesystem paths and are not containers or sequences."
    - "None of PurePath, PurePosixPath, PureWindowsPath, or Path define __len__, __length_hint__, or __contains__ in their own __dict__."
    - "Path iteration (for p in path.iterdir()) works via separate methods, not via container protocol slots."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __len__ dict-presence — operator.contains(Cls.__dict__, '__len__')
#
# pathlib path types are not sequences; none define __len__; all false.
# ---------------------------------------------------------------------------

table pp2986.len:
  description: "pathlib types __len__ dict-presence checks; wave 646"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2986
  columns: [id, function, args, expected]
  rows:
    - ["pp2986001", operator.contains, [pathlib.PurePath.__dict__,        "__len__"], false]
    - ["pp2986002", operator.contains, [pathlib.PurePosixPath.__dict__,   "__len__"], false]
    - ["pp2986003", operator.contains, [pathlib.PureWindowsPath.__dict__, "__len__"], false]
    - ["pp2986004", operator.contains, [pathlib.Path.__dict__,            "__len__"], false]
    - ["pp2986005", operator.contains, [pathlib.PurePath.__dict__,        "__len__"], false]
    - ["pp2986006", operator.contains, [pathlib.Path.__dict__,            "__len__"], false]

