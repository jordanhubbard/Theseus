spec: multiprocessing_extra27
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra26.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__, Process.__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, Lock/Event/Semaphore/Value/Array __module__=='multiprocessing.context', managers/shared_memory __name__, Pool.__qualname__=='BaseContext.Pool', cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, Process.__module__.__len__()==23, Process.__name__.__len__()==7, exception __module__ equality and __len__(), function __qualname__ equality for cpu_count/get_start_method/set_start_method/get_context/active_children."
    - "This spec covers: Pool/Queue/Lock/Event/Semaphore/Barrier __qualname__.__len__(); Process method __qualname__.__len__() for start/run/join/terminate/is_alive; Pool/Queue/Semaphore/Barrier/Manager __name__.__len__(); current_process.__name__.__len__() and __module__.__len__()."
    - "Pool.__qualname__ == 'BaseContext.Pool' — length 16."
    - "Queue.__qualname__ == 'BaseContext.Queue' — length 17."
    - "Lock.__qualname__ == 'BaseContext.Lock' — length 16."
    - "Event.__qualname__ == 'BaseContext.Event' — length 17."
    - "Semaphore.__qualname__ == 'BaseContext.Semaphore' — length 21."
    - "Barrier.__qualname__ == 'BaseContext.Barrier' — length 19."
    - "Process.start.__qualname__ == 'BaseProcess.start' — length 17 (from BaseProcess)."
    - "Process.run.__qualname__ == 'BaseProcess.run' — length 15."
    - "Process.join.__qualname__ == 'BaseProcess.join' — length 16."
    - "Process.terminate.__qualname__ == 'BaseProcess.terminate' — length 21."
    - "Process.is_alive.__qualname__ == 'BaseProcess.is_alive' — length 20."
    - "current_process.__module__ == 'multiprocessing.process' — length 23."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Context-bound class __qualname__ length table — extra27 namespace
#
# multiprocessing exposes Pool, Queue, Lock, Event, Semaphore, and Barrier
# through the default context (a DefaultContext/BaseContext instance). These
# are bound methods of the context object whose __qualname__ includes the
# 'BaseContext.' prefix. Prior specs check __qualname__ equality for Pool;
# this table adds __qualname__.__len__() for the full set:
#   Pool.__qualname__ == 'BaseContext.Pool' (16)
#   Queue.__qualname__ == 'BaseContext.Queue' (17)
#   Lock.__qualname__ == 'BaseContext.Lock' (16)
#   Event.__qualname__ == 'BaseContext.Event' (17)
#   Semaphore.__qualname__ == 'BaseContext.Semaphore' (21)
#   Barrier.__qualname__ == 'BaseContext.Barrier' (19)
# ---------------------------------------------------------------------------

table multiprocessing_extra27.context_class_qualname_lengths:
  description: "multiprocessing context-bound class __qualname__ lengths in extra27 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: ctxqualnamelen27

  columns: [id, function, args, expected]
  rows:
    - [Pool,      Pool.__qualname__.__len__,      [], 16]
    - [Queue,     Queue.__qualname__.__len__,     [], 17]
    - [Lock,      Lock.__qualname__.__len__,      [], 16]
    - [Event,     Event.__qualname__.__len__,     [], 17]
    - [Semaphore, Semaphore.__qualname__.__len__, [], 21]
    - [Barrier,   Barrier.__qualname__.__len__,   [], 19]

# ---------------------------------------------------------------------------
# Process method __qualname__ length table — extra27 namespace
#
# multiprocessing.Process inherits its core methods from BaseProcess
# (defined in multiprocessing.process). The inherited methods carry the
# 'BaseProcess.' prefix in their __qualname__:
#   Process.start.__qualname__ == 'BaseProcess.start' (17)
#   Process.run.__qualname__ == 'BaseProcess.run' (15)
#   Process.join.__qualname__ == 'BaseProcess.join' (16)
#   Process.terminate.__qualname__ == 'BaseProcess.terminate' (21)
#   Process.is_alive.__qualname__ == 'BaseProcess.is_alive' (20)
# No prior spec has measured __qualname__.__len__() for Process instance
# methods.
# ---------------------------------------------------------------------------

table multiprocessing_extra27.process_method_qualname_lengths:
  description: "multiprocessing Process method __qualname__ lengths in extra27 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: procmqualnamelen27

  columns: [id, function, args, expected]
  rows:
    - [start,     Process.start.__qualname__.__len__,     [], 17]
    - [run,       Process.run.__qualname__.__len__,       [], 15]
    - [join,      Process.join.__qualname__.__len__,      [], 16]
    - [terminate, Process.terminate.__qualname__.__len__, [], 21]
    - [is_alive,  Process.is_alive.__qualname__.__len__,  [], 20]

# ---------------------------------------------------------------------------
# current_process __module__ length — extra27 standalone invariant
#
# multiprocessing.current_process is a pure module-level function defined
# in multiprocessing.process (not multiprocessing.context). Its __module__
# == 'multiprocessing.process' (length 23). This is consistent with the
# same 23-character length as 'multiprocessing.context', but refers to a
# different submodule. Prior specs confirm the __qualname__ for
# current_process; this invariant adds the __module__.__len__() axis.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra27.current_process.module_len:
  description: "multiprocessing.current_process.__module__.__len__() == 23 — defined in multiprocessing.process"
  category: class_modules
  kind: python_call_eq
  function: current_process.__module__.__len__
  args: []
  expected: 23

# ---------------------------------------------------------------------------
# Process.start qualname string equality — extra27 standalone invariant
#
# Confirms the full __qualname__ string 'BaseProcess.start' for the start
# method, complementing the length check in the table above. This documents
# that Process inherits start from BaseProcess and does not override it.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra27.process_start_qualname_eq:
  description: "multiprocessing.Process.start.__qualname__ == 'BaseProcess.start' — method inherited from BaseProcess"
  category: method_names
  kind: python_call_eq
  function: Process.start.__qualname__.__eq__
  args: ["BaseProcess.start"]
  expected: true
