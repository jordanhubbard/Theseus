spec: multiprocessing_extra263
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "https://docs.python.org/3/library/multiprocessing.managers.html — multiprocessing.managers documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/managers.py"
  notes:
    - "multiprocessing.Value.__module__ == 'multiprocessing.context' — Value is a bound method factory on the context object."
    - "multiprocessing.Array.__module__ == 'multiprocessing.context' — same as Value."
    - "multiprocessing.Manager.__module__ == 'multiprocessing.context' — Manager is a bound method factory, not the SyncManager class."
    - "multiprocessing.managers.SyncManager.__module__ == 'multiprocessing.managers'; inherits from BaseManager."
    - "multiprocessing.managers.BaseManager.__module__ == 'multiprocessing.managers'; inherits from object."
    - "BaseManager.start.__qualname__ == 'BaseManager.start'; BaseManager.connect.__qualname__ == 'BaseManager.connect'."
    - "SyncManager.dict, SyncManager.list, and SyncManager.Queue are registered proxy-factory functions with simple __name__ values."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Value and Array factory identity — table
#
# Value and Array are bound-method factories; __module__ == 'multiprocessing.context'.
# ---------------------------------------------------------------------------

table multiprocessing_extra263.value_array_identity:
  description: "multiprocessing.Value and Array factory __name__ and __module__ values"
  kind: python_call_eq
  category: identity
  id_prefix: vaid

  columns: [id, function, args, expected, description]
  rows:
    - [val_name,    Value.__name__.__eq__,    ["Value"],                     true, "multiprocessing.Value.__name__ == 'Value'"]
    - [val_module,  Value.__module__.__eq__,  ["multiprocessing.context"],   true, "multiprocessing.Value.__module__ == 'multiprocessing.context'"]
    - [arr_name,    Array.__name__.__eq__,    ["Array"],                     true, "multiprocessing.Array.__name__ == 'Array'"]
    - [arr_module,  Array.__module__.__eq__,  ["multiprocessing.context"],   true, "multiprocessing.Array.__module__ == 'multiprocessing.context'"]

# ---------------------------------------------------------------------------
# multiprocessing.managers.BaseManager class identity — table
#
# BaseManager is defined in multiprocessing.managers and inherits from object.
# ---------------------------------------------------------------------------

table multiprocessing_extra263.basemanager_identity:
  description: "multiprocessing.managers.BaseManager class identity and method __name__ values"
  kind: python_call_eq
  category: identity
  id_prefix: bmid

  columns: [id, function, args, expected, description]
  rows:
    - [bm_name,       managers.BaseManager.__name__.__eq__,              ["BaseManager"],             true, "multiprocessing.managers.BaseManager.__name__ == 'BaseManager'"]
    - [bm_module,     managers.BaseManager.__module__.__eq__,            ["multiprocessing.managers"], true, "multiprocessing.managers.BaseManager.__module__ == 'multiprocessing.managers'"]
    - [bm_base,       "managers.BaseManager.__bases__[0].__name__.__eq__", ["object"],                true, "multiprocessing.managers.BaseManager inherits from object"]
    - [bm_start,      managers.BaseManager.start.__name__.__eq__,        ["start"],                   true, "multiprocessing.managers.BaseManager.start.__name__ == 'start'"]
    - [bm_connect,    managers.BaseManager.connect.__name__.__eq__,      ["connect"],                 true, "multiprocessing.managers.BaseManager.connect.__name__ == 'connect'"]
    - [bm_join,       managers.BaseManager.join.__name__.__eq__,         ["join"],                    true, "multiprocessing.managers.BaseManager.join.__name__ == 'join'"]
    - [bm_register,   managers.BaseManager.register.__name__.__eq__,     ["register"],                true, "multiprocessing.managers.BaseManager.register.__name__ == 'register'"]

# ---------------------------------------------------------------------------
# multiprocessing.Manager factory — standalone invariants
#
# multiprocessing.Manager is a bound-method factory (not the class itself);
# its __module__ is 'multiprocessing.context'.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra263.Manager.name:
  description: "multiprocessing.Manager.__name__ == 'Manager'"
  category: identity
  kind: python_call_eq
  function: Manager.__name__.__eq__
  args: ["Manager"]
  expected: true

invariant multiprocessing_extra263.Manager.module:
  description: "multiprocessing.Manager.__module__ == 'multiprocessing.context'"
  category: identity
  kind: python_call_eq
  function: Manager.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

# ---------------------------------------------------------------------------
# multiprocessing.managers.SyncManager class identity — standalone invariants
#
# SyncManager inherits from BaseManager and lives in multiprocessing.managers.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra263.SyncManager.name:
  description: "multiprocessing.managers.SyncManager.__name__ == 'SyncManager'"
  category: identity
  kind: python_call_eq
  function: managers.SyncManager.__name__.__eq__
  args: ["SyncManager"]
  expected: true

invariant multiprocessing_extra263.SyncManager.module:
  description: "multiprocessing.managers.SyncManager.__module__ == 'multiprocessing.managers'"
  category: identity
  kind: python_call_eq
  function: managers.SyncManager.__module__.__eq__
  args: ["multiprocessing.managers"]
  expected: true

invariant multiprocessing_extra263.SyncManager.bases0_name:
  description: "multiprocessing.managers.SyncManager.__bases__[0].__name__ == 'BaseManager'"
  category: identity
  kind: python_call_eq
  function: "managers.SyncManager.__bases__[0].__name__.__eq__"
  args: ["BaseManager"]
  expected: true

invariant multiprocessing_extra263.SyncManager.dict_name:
  description: "multiprocessing.managers.SyncManager.dict.__name__ == 'dict'"
  category: identity
  kind: python_call_eq
  function: managers.SyncManager.dict.__name__.__eq__
  args: ["dict"]
  expected: true

invariant multiprocessing_extra263.SyncManager.list_name:
  description: "multiprocessing.managers.SyncManager.list.__name__ == 'list'"
  category: identity
  kind: python_call_eq
  function: managers.SyncManager.list.__name__.__eq__
  args: ["list"]
  expected: true

invariant multiprocessing_extra263.SyncManager.Queue_name:
  description: "multiprocessing.managers.SyncManager.Queue.__name__ == 'Queue'"
  category: identity
  kind: python_call_eq
  function: managers.SyncManager.Queue.__name__.__eq__
  args: ["Queue"]
  expected: true

# ---------------------------------------------------------------------------
# multiprocessing.managers.BaseManager method __qualname__ — standalone invariants
# ---------------------------------------------------------------------------

invariant multiprocessing_extra263.BaseManager.start_qualname:
  description: "multiprocessing.managers.BaseManager.start.__qualname__ == 'BaseManager.start'"
  category: identity
  kind: python_call_eq
  function: managers.BaseManager.start.__qualname__.__eq__
  args: ["BaseManager.start"]
  expected: true

invariant multiprocessing_extra263.BaseManager.connect_qualname:
  description: "multiprocessing.managers.BaseManager.connect.__qualname__ == 'BaseManager.connect'"
  category: identity
  kind: python_call_eq
  function: managers.BaseManager.connect.__qualname__.__eq__
  args: ["BaseManager.connect"]
  expected: true
