spec: struct_extra469
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module public API"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Checks __name__ identity for struct.Struct class methods and module-level functions"
    - "struct.Struct methods are C-level slot wrappers; __name__ is stable across CPython versions"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra469.struct_class_method_names:
  description: "struct.Struct class method __name__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: STM

  columns: [id, function, args, expected]
  rows:
    - [STM001, struct.Struct.pack.__name__.__eq__, ["pack"], true]
    - [STM002, struct.Struct.unpack.__name__.__eq__, ["unpack"], true]
    - [STM003, struct.Struct.pack_into.__name__.__eq__, ["pack_into"], true]
    - [STM004, struct.Struct.unpack_from.__name__.__eq__, ["unpack_from"], true]
    - [STM005, struct.Struct.iter_unpack.__name__.__eq__, ["iter_unpack"], true]

table struct_extra469.struct_module_function_names:
  description: "struct module-level function __name__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: STF

  columns: [id, function, args, expected]
  rows:
    - [STF001, struct.pack.__name__.__eq__, ["pack"], true]
    - [STF002, struct.unpack.__name__.__eq__, ["unpack"], true]
    - [STF003, struct.calcsize.__name__.__eq__, ["calcsize"], true]
    - [STF004, struct.error.__name__.__eq__, ["error"], true]
