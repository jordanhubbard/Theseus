spec: io_extra148
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: io.IOBase, io.RawIOBase, io.BufferedIOBase, and io.TextIOBase class-level identity from angles not covered in io_extra147: __name__ lengths, __module__ string, metaclass (ABCMeta), __qualname__ lengths, MRO lengths and MRO entry names, and __bases__ first-entry names."
    - "All four ABC classes have __class__.__name__ == 'ABCMeta' (not 'type'); they are abstract base classes registered via abc.ABCMeta."
    - "IOBase.__name__ == 'IOBase' (6 chars); RawIOBase.__name__ == 'RawIOBase' (9 chars); BufferedIOBase.__name__ == 'BufferedIOBase' (14 chars); TextIOBase.__name__ == 'TextIOBase' (10 chars)."
    - "All four ABCs have __module__ == 'io' (2 chars)."
    - "IOBase MRO length == 3 (IOBase, _IOBase, object). RawIOBase, BufferedIOBase, TextIOBase each have MRO length 5."
    - "IOBase.__bases__[0].__name__ == '_IOBase' (the private C extension base class)."
    - "RawIOBase.__bases__[0].__name__ == '_RawIOBase'; RawIOBase.__bases__[1].__name__ == 'IOBase' (multiple inheritance from both C and Python layers)."
    - "io.IOBase.__doc__.__len__() == 1235; io.RawIOBase.__doc__.__len__() == 30; io.BufferedIOBase.__doc__.__len__() == 496; io.TextIOBase.__doc__.__len__() == 176."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io ABC class __doc__ lengths and doc type identity
# IOBase.__doc__ == 1235 chars (str); RawIOBase.__doc__ == 30 chars (str).
# BufferedIOBase.__doc__ == 496 chars (str); TextIOBase.__doc__ == 176 chars (str).
# All four have non-None __doc__ values of type str.
# ---------------------------------------------------------------------------

table io_extra148.abc_doc_lengths:
  description: "io ABC class __doc__ lengths: IOBase=1235, RawIOBase=30, BufferedIOBase=496, TextIOBase=176; all are str"
  kind: python_call_eq
  category: doc_identity
  id_prefix: ioabc148

  columns: [id, function, args, expected, description]
  rows:
    - [iobase_doc_cls,   IOBase.__doc__.__class__.__name__.__eq__,        ["str"], true,  "io.IOBase.__doc__.__class__.__name__ == 'str' (not None; all four io ABCs have non-None docstrings)"]
    - [iobase_doc_len,   IOBase.__doc__.__len__,                           [],     1235,  "io.IOBase.__doc__.__len__() == 1235 (longest of the four ABC docstrings; covers the full IO contract)"]
    - [rawio_doc_cls,    RawIOBase.__doc__.__class__.__name__.__eq__,      ["str"], true,  "io.RawIOBase.__doc__ is a str (single-sentence doc: 'Base class for raw binary I/O.')"]
    - [rawio_doc_len,    RawIOBase.__doc__.__len__,                        [],     30,    "io.RawIOBase.__doc__.__len__() == 30 (shortest of the four ABC docstrings)"]
    - [bufio_doc_cls,    BufferedIOBase.__doc__.__class__.__name__.__eq__, ["str"], true,  "io.BufferedIOBase.__doc__ is a str (multi-sentence doc covering buffering semantics)"]
    - [bufio_doc_len,    BufferedIOBase.__doc__.__len__,                   [],     496,   "io.BufferedIOBase.__doc__.__len__() == 496 (second longest; explains BlockingIOError semantics)"]
    - [textio_doc_cls,   TextIOBase.__doc__.__class__.__name__.__eq__,     ["str"], true,  "io.TextIOBase.__doc__ is a str (covers character-stream interface over bytes streams)"]
    - [textio_doc_len,   TextIOBase.__doc__.__len__,                       [],     176,   "io.TextIOBase.__doc__.__len__() == 176 (second shortest; longer than RawIOBase by 146 chars)"]

# ---------------------------------------------------------------------------
# io ABC metaclass identity: all four ABCs use ABCMeta, not 'type'.
# IOBase.__class__.__name__ == 'ABCMeta'; same for the three subclasses.
# __name__ lengths: IOBase=6, RawIOBase=9, BufferedIOBase=14, TextIOBase=10.
# __module__ == 'io' (len=2) for all four.
# ---------------------------------------------------------------------------

table io_extra148.abc_metaclass_and_name:
  description: "io ABC metaclass is ABCMeta for all four; __name__ lengths: IOBase=6, RawIOBase=9, BufferedIOBase=14, TextIOBase=10; __module__='io' (len=2)"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioabc148

  columns: [id, function, args, expected, description]
  rows:
    - [iobase_meta_eq,    IOBase.__class__.__name__.__eq__,        ["ABCMeta"], true, "io.IOBase.__class__.__name__ == 'ABCMeta' (IOBase is an abstract base class, metaclass is abc.ABCMeta)"]
    - [iobase_name_len,   IOBase.__name__.__len__,                  [],         6,    "io.IOBase.__name__.__len__() == 6 ('IOBase' has 6 characters)"]
    - [iobase_module_eq,  IOBase.__module__.__eq__,                 ["io"],     true, "io.IOBase.__module__ == 'io' (defined in the public io namespace, not '_io')"]
    - [iobase_module_len, IOBase.__module__.__len__,                [],         2,    "io.IOBase.__module__.__len__() == 2 ('io' is a 2-character module name)"]
    - [rawio_meta_eq,     RawIOBase.__class__.__name__.__eq__,      ["ABCMeta"], true, "io.RawIOBase.__class__.__name__ == 'ABCMeta' (same metaclass as IOBase; the whole io ABC hierarchy uses ABCMeta)"]
    - [rawio_name_len,    RawIOBase.__name__.__len__,               [],         9,    "io.RawIOBase.__name__.__len__() == 9 ('RawIOBase' has 9 characters; 3 more than IOBase)"]
    - [bufio_meta_eq,     BufferedIOBase.__class__.__name__.__eq__, ["ABCMeta"], true, "io.BufferedIOBase.__class__.__name__ == 'ABCMeta'"]
    - [bufio_name_len,    BufferedIOBase.__name__.__len__,          [],         14,   "io.BufferedIOBase.__name__.__len__() == 14 ('BufferedIOBase' is the longest of the four ABC names)"]
    - [textio_meta_eq,    TextIOBase.__class__.__name__.__eq__,     ["ABCMeta"], true, "io.TextIOBase.__class__.__name__ == 'ABCMeta'"]
    - [textio_name_len,   TextIOBase.__name__.__len__,              [],         10,   "io.TextIOBase.__name__.__len__() == 10 ('TextIOBase' has 10 characters)"]

# ---------------------------------------------------------------------------
# io ABC MRO structure
# IOBase MRO: [IOBase, _IOBase, object] (length 3).
# RawIOBase MRO: [RawIOBase, _RawIOBase, IOBase, _IOBase, object] (length 5).
# BufferedIOBase MRO: [BufferedIOBase, _BufferedIOBase, IOBase, _IOBase, object] (length 5).
# TextIOBase MRO: [TextIOBase, _TextIOBase, IOBase, _IOBase, object] (length 5).
# The C extension private classes (_IOBase, _RawIOBase, etc.) are interleaved.
# ---------------------------------------------------------------------------

table io_extra148.abc_mro_structure:
  description: "io ABC MRO lengths: IOBase=3, RawIOBase=5, BufferedIOBase=5, TextIOBase=5; MRO entry names for IOBase and RawIOBase"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioabc148

  columns: [id, function, args, expected, description]
  rows:
    - [iobase_mro_len,    "IOBase.__mro__.__len__",                      [], 3, "io.IOBase.__mro__.__len__() == 3 ([IOBase, _IOBase, object]; shortest MRO among the four ABCs)"]
    - [iobase_mro0_eq,    "IOBase.__mro__[0].__name__.__eq__",    ["IOBase"],    true, "io.IOBase.__mro__[0].__name__ == 'IOBase' (class is its own first MRO entry)"]
    - [iobase_mro1_eq,    "IOBase.__mro__[1].__name__.__eq__",    ["_IOBase"],   true, "io.IOBase.__mro__[1].__name__ == '_IOBase' (the private C extension implementation base)"]
    - [iobase_mro2_eq,    "IOBase.__mro__[2].__name__.__eq__",    ["object"],    true, "io.IOBase.__mro__[2].__name__ == 'object' (the universal base class)"]
    - [rawio_mro_len,     "RawIOBase.__mro__.__len__",                   [], 5, "io.RawIOBase.__mro__.__len__() == 5 ([RawIOBase, _RawIOBase, IOBase, _IOBase, object])"]
    - [rawio_mro2_eq,     "RawIOBase.__mro__[2].__name__.__eq__",  ["IOBase"],   true, "io.RawIOBase.__mro__[2].__name__ == 'IOBase' (RawIOBase extends IOBase at MRO position 2)"]
    - [bufio_mro_len,     "BufferedIOBase.__mro__.__len__",              [], 5, "io.BufferedIOBase.__mro__.__len__() == 5 ([BufferedIOBase, _BufferedIOBase, IOBase, _IOBase, object])"]
    - [bufio_mro2_eq,     "BufferedIOBase.__mro__[2].__name__.__eq__", ["IOBase"], true, "io.BufferedIOBase.__mro__[2].__name__ == 'IOBase' (BufferedIOBase extends IOBase at MRO position 2)"]
    - [textio_mro_len,    "TextIOBase.__mro__.__len__",                  [], 5, "io.TextIOBase.__mro__.__len__() == 5 ([TextIOBase, _TextIOBase, IOBase, _IOBase, object])"]
    - [textio_mro2_eq,    "TextIOBase.__mro__[2].__name__.__eq__",  ["IOBase"],  true, "io.TextIOBase.__mro__[2].__name__ == 'IOBase' (TextIOBase extends IOBase at MRO position 2)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra148.IOBase.metaclass_is_ABCMeta:
  description: "io.IOBase.__class__.__name__ == 'ABCMeta' (all four io abstract base classes — IOBase, RawIOBase, BufferedIOBase, TextIOBase — use abc.ABCMeta as their metaclass, distinguishing them from concrete classes like BufferedReader whose __class__.__name__ is 'type')"
  category: class_identity
  kind: python_call_eq
  function: IOBase.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant io_extra148.BufferedIOBase.name_len_14:
  description: "io.BufferedIOBase.__name__.__len__() == 14 ('BufferedIOBase' is the longest __name__ among the four io ABC classes: IOBase=6, RawIOBase=9, TextIOBase=10, BufferedIOBase=14; this reflects the 8-character prefix 'Buffered' plus 6-character suffix 'IOBase')"
  category: class_identity
  kind: python_call_eq
  function: BufferedIOBase.__name__.__len__
  args: []
  expected: 14

invariant io_extra148.IOBase.mro_len_3:
  description: "io.IOBase.__mro__.__len__() == 3 (IOBase's MRO is [IOBase, _IOBase, object]; the shortest MRO among the four ABCs because IOBase is the root of the io class hierarchy and directly subclasses _IOBase which subclasses object)"
  category: class_identity
  kind: python_call_eq
  function: "IOBase.__mro__.__len__"
  args: []
  expected: 3

invariant io_extra148.RawIOBase.mro_len_5:
  description: "io.RawIOBase.__mro__.__len__() == 5 (MRO is [RawIOBase, _RawIOBase, IOBase, _IOBase, object]; one level deeper than IOBase because RawIOBase inherits from both _RawIOBase (C layer) and IOBase (Python ABC layer))"
  category: class_identity
  kind: python_call_eq
  function: "RawIOBase.__mro__.__len__"
  args: []
  expected: 5

invariant io_extra148.TextIOBase.doc_len_176:
  description: "io.TextIOBase.__doc__.__len__() == 176 (TextIOBase's docstring is the second shortest ABC doc at 176 chars; it describes the character-stream interface layered over an underlying bytes stream; longer than RawIOBase (30) but shorter than BufferedIOBase (496) and IOBase (1235))"
  category: doc_identity
  kind: python_call_eq
  function: TextIOBase.__doc__.__len__
  args: []
  expected: 176

invariant io_extra148.IOBase.module_eq_io:
  description: "io.IOBase.__module__ == 'io' (the public module name; although the C implementation lives in _io, the Python wrapper in Lib/io.py re-exports the ABCs under the 'io' module namespace so __module__ records 'io', not '_io')"
  category: class_identity
  kind: python_call_eq
  function: IOBase.__module__.__eq__
  args: ["io"]
  expected: true
