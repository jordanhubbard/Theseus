spec: dill_rust
version: ">=3.9"
backend: rust_module(dill_rust)

docs: https://dill.readthedocs.io/

provenance:
  derived_from:
    - "https://dill.readthedocs.io/ — dill library documentation"
  not_derived_from:
    - "dill source: dill/_dill.py"
  notes:
    - "dill extends Python's pickle module for serializing Python objects."
    - "dill.dumps(obj) -> bytes — serializes object to bytes."
    - "dill.loads(bytes) -> obj — deserializes from bytes."
    - "dill.copy(obj) — deep copy via serialization."
    - "Expose dill_roundtrip_int(n) -> int: dill.loads(dill.dumps(n)) == n."
    - "Expose dill_roundtrip_str(s) -> str: dill.loads(dill.dumps(s)) == s."
    - "Expose dill_roundtrip_list(lst) -> list: dill.loads(dill.dumps(lst)) == lst."
    - "Expose dill_copy_int(n) -> int: dill.copy(n) == n."
    - "dill.loads(dill.dumps(42)) == 42."
    - "dill.loads(dill.dumps('hello')) == 'hello'."
    - "dill.loads(dill.dumps([1,2,3])) == [1,2,3]."
    - "All test vectors verified against dill 0.3.9."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# dill_roundtrip_int — int serialization roundtrip
table dill_rust.roundtrip.int:
  kind: python_call_eq
  category: roundtrip
  id_prefix: dill_int
  function: dill_roundtrip_int

  columns: [id, args, expected]
  rows:
    - [zero,     [0],    0]
    - [positive, [42],   42]
    - [negative, [-1],  -1]
    - [large,    [1000], 1000]

# dill_roundtrip_str — string serialization roundtrip
table dill_rust.roundtrip.str:
  kind: python_call_eq
  category: roundtrip
  id_prefix: dill_str
  function: dill_roundtrip_str

  columns: [id, args, expected]
  rows:
    - [hello,  ["hello"],  "hello"]
    - [empty,  [""],       ""]
    - [spaces, ["a b c"],  "a b c"]

# dill_roundtrip_list — list serialization roundtrip
invariant dill_rust.roundtrip.list_123:
  description: "dill.loads(dill.dumps([1,2,3])) == [1,2,3]"
  category: roundtrip
  kind: python_call_eq
  function: dill_roundtrip_list
  args: [[1, 2, 3]]
  expected: [1, 2, 3]

invariant dill_rust.roundtrip.list_empty:
  description: "dill roundtrip of [] == []"
  category: roundtrip
  kind: python_call_eq
  function: dill_roundtrip_list
  args: [[]]
  expected: []

