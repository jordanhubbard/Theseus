spec: pathlib_extra2686
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 pathlib documentation — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
    - "pathlib_extra.zspec.zsdl — covers existing pathlib invariants"
    - "pathlib_extra2671.zspec.zsdl — covers __sub__/__floordiv__/__mod__ dict-presence"
  notes:
    - "Wave 626 (pathlib_extra2686) theme: __and__, __or__, and __xor__ dict-presence checks."
    - "None of the pathlib classes define __and__, __or__, or __xor__ in their own __dict__."
    - "__and__ is the bitwise AND operator; pathlib path objects are filesystem path types, not integers or sets."
    - "__or__ is the bitwise OR operator; pathlib path objects do not implement bitwise OR semantics."
    - "__xor__ is the bitwise XOR operator; pathlib path objects do not implement bitwise XOR semantics."
    - "pathlib uses __truediv__ (the / operator) for path joining — none of __and__, __or__, or __xor__ are used."
    - "Covers pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, and pathlib.Path."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __and__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2686.no_and_in_pathlib_classes:
  description: "__and__ is absent from all pathlib class __dict__s — pathlib path objects do not implement the bitwise AND protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2686

  columns: [id, function, args, expected]
  rows:
    - ["pp2686001", "pathlib.PurePath.__dict__.__contains__",        ["__and__"], false]
    - ["pp2686002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__and__"], false]
    - ["pp2686003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__and__"], false]
    - ["pp2686004", "pathlib.Path.__dict__.__contains__",            ["__and__"], false]

# ---------------------------------------------------------------------------
# __or__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2686.no_or_in_pathlib_classes:
  description: "__or__ is absent from all pathlib class __dict__s — pathlib path objects do not implement the bitwise OR protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2686

  columns: [id, function, args, expected]
  rows:
    - ["pp2686005", "pathlib.PurePath.__dict__.__contains__",        ["__or__"], false]
    - ["pp2686006", "pathlib.PurePosixPath.__dict__.__contains__",   ["__or__"], false]
    - ["pp2686007", "pathlib.PureWindowsPath.__dict__.__contains__", ["__or__"], false]
    - ["pp2686008", "pathlib.Path.__dict__.__contains__",            ["__or__"], false]

# ---------------------------------------------------------------------------
# __xor__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2686.no_xor_in_pathlib_classes:
  description: "__xor__ is absent from all pathlib class __dict__s — pathlib path objects do not implement the bitwise XOR protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2686

  columns: [id, function, args, expected]
  rows:
    - ["pp2686009", "pathlib.PurePath.__dict__.__contains__",        ["__xor__"], false]
    - ["pp2686010", "pathlib.PurePosixPath.__dict__.__contains__",   ["__xor__"], false]
    - ["pp2686011", "pathlib.PureWindowsPath.__dict__.__contains__", ["__xor__"], false]
    - ["pp2686012", "pathlib.Path.__dict__.__contains__",            ["__xor__"], false]

# ---------------------------------------------------------------------------
# Complementary: pathlib classes have path-manipulation methods but not bitwise operator hooks
# Confirms that path objects use __truediv__ for joining and have no __and__/__or__/__xor__ semantics
# ---------------------------------------------------------------------------

table pathlib_extra2686.pathlib_has_path_methods_not_bitwise_hooks:
  description: "pathlib.PurePath defines __str__/__truediv__/__fspath__ but NOT __and__/__or__/__xor__; pathlib.Path defines stat/exists/open but NOT __and__/__or__/__xor__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2686

  columns: [id, function, args, expected]
  rows:
    - ["pp2686013", "pathlib.PurePath.__dict__.__contains__", ["__str__"],     true]
    - ["pp2686014", "pathlib.PurePath.__dict__.__contains__", ["__truediv__"], true]
    - ["pp2686015", "pathlib.PurePath.__dict__.__contains__", ["__fspath__"],  true]
    - ["pp2686016", "pathlib.PurePath.__dict__.__contains__", ["__and__"],     false]
    - ["pp2686017", "pathlib.PurePath.__dict__.__contains__", ["__or__"],      false]
    - ["pp2686018", "pathlib.PurePath.__dict__.__contains__", ["__xor__"],     false]
    - ["pp2686019", "pathlib.Path.__dict__.__contains__",     ["stat"],        true]
    - ["pp2686020", "pathlib.Path.__dict__.__contains__",     ["exists"],      true]
    - ["pp2686021", "pathlib.Path.__dict__.__contains__",     ["open"],        true]
    - ["pp2686022", "pathlib.Path.__dict__.__contains__",     ["__and__"],     false]
    - ["pp2686023", "pathlib.Path.__dict__.__contains__",     ["__or__"],      false]
    - ["pp2686024", "pathlib.Path.__dict__.__contains__",     ["__xor__"],     false]
