spec: traceback_extra23
version: ">=3.9"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/traceback.html — Python traceback module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
  notes:
    - "This spec extends traceback_extra22.zspec.zsdl."
    - "Prior specs covered: TracebackException/StackSummary/FrameSummary __name__/__module__/__qualname__, print_exc/format_exc/print_tb/format_tb/extract_tb/extract_stack/__name__/__module__, TracebackException.__init__.__name__, format_list/__name__/__module__, various __qualname__ checks."
    - "This spec covers: TracebackException.__module__.__len__() == 9, StackSummary.__module__.__len__() == 9, FrameSummary.__module__.__len__() == 9, TracebackException.__name__.__len__() == 18, StackSummary.__name__.__len__() == 12, FrameSummary.__name__.__len__() == 12, print_exc.__module__.__len__() == 9, format_exc.__module__.__len__() == 9, print_tb.__module__.__len__() == 9, format_tb.__module__.__len__() == 9, TracebackException.__qualname__.__len__() == 18, StackSummary.__qualname__.__len__() == 12."
    - "traceback.TracebackException.__module__ == 'traceback' (len 9). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.StackSummary.__module__ == 'traceback' (len 9). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.FrameSummary.__module__ == 'traceback' (len 9). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.TracebackException.__name__ == 'TracebackException' (len 18). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.StackSummary.__name__ == 'StackSummary' (len 12). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.FrameSummary.__name__ == 'FrameSummary' (len 12). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.print_exc.__module__ == 'traceback' (len 9). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.format_exc.__module__ == 'traceback' (len 9). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.print_tb.__module__ == 'traceback' (len 9). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.format_tb.__module__ == 'traceback' (len 9). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.TracebackException.__qualname__ == 'TracebackException' (len 18). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.StackSummary.__qualname__ == 'StackSummary' (len 12). Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# traceback.TracebackException.__module__.__len__()
#
# TracebackException.__module__ == 'traceback', which has length 9.
# Prior specs record the __module__ string value; this spec records its length
# via the __len__ method as a fresh extra23-namespace invariant.
# ---------------------------------------------------------------------------

invariant traceback_extra23.TracebackException.module.len:
  description: "traceback.TracebackException.__module__.__len__() == 9 — 'traceback' has 9 characters"
  category: string_length
  kind: python_call_eq
  function: TracebackException.__module__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# traceback.StackSummary.__module__.__len__()
#
# StackSummary.__module__ == 'traceback', which has length 9.
# ---------------------------------------------------------------------------

invariant traceback_extra23.StackSummary.module.len:
  description: "traceback.StackSummary.__module__.__len__() == 9 — 'traceback' has 9 characters"
  category: string_length
  kind: python_call_eq
  function: StackSummary.__module__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# traceback.FrameSummary.__module__.__len__()
#
# FrameSummary.__module__ == 'traceback', which has length 9.
# ---------------------------------------------------------------------------

invariant traceback_extra23.FrameSummary.module.len:
  description: "traceback.FrameSummary.__module__.__len__() == 9 — 'traceback' has 9 characters"
  category: string_length
  kind: python_call_eq
  function: FrameSummary.__module__.__len__
  args: []
  expected: 9

