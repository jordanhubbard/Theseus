# ---------------------------------------------------------------------------
# Consolidated table — all twelve __len__ invariants
#
# Covers __module__.__len__() for TracebackException/StackSummary/FrameSummary
# (3), __name__.__len__() for TracebackException/StackSummary/FrameSummary (3),
# __module__.__len__() for print_exc/format_exc/print_tb/format_tb (4), and
# __qualname__.__len__() for TracebackException/StackSummary (2).
# ---------------------------------------------------------------------------

table traceback_extra23.string_lengths:
  description: "String lengths of __module__, __name__, and __qualname__ attributes for traceback classes and functions"
  kind: python_call_eq
  category: string_length

  columns: [id, function, args, expected]
  rows:
    - [TracebackException_module_len,   TracebackException.__module__.__len__,   [], 9]
    - [StackSummary_module_len,         StackSummary.__module__.__len__,         [], 9]
    - [FrameSummary_module_len,         FrameSummary.__module__.__len__,         [], 9]
    - [TracebackException_name_len,     TracebackException.__name__.__len__,     [], 18]
    - [StackSummary_name_len,           StackSummary.__name__.__len__,           [], 12]
    - [FrameSummary_name_len,           FrameSummary.__name__.__len__,           [], 12]
    - [print_exc_module_len,            print_exc.__module__.__len__,            [], 9]
    - [format_exc_module_len,           format_exc.__module__.__len__,           [], 9]
    - [print_tb_module_len,             print_tb.__module__.__len__,             [], 9]
    - [format_tb_module_len,            format_tb.__module__.__len__,            [], 9]
    - [TracebackException_qualname_len, TracebackException.__qualname__.__len__, [], 18]
    - [StackSummary_qualname_len,       StackSummary.__qualname__.__len__,       [], 12]
