spec: structlog_rust
version: ">=3.9"
backend: rust_module(structlog_rust)

docs: https://www.structlog.org/en/stable/

provenance:
  derived_from:
    - "https://www.structlog.org/en/stable/ — structlog documentation"
  not_derived_from:
    - "structlog source: src/structlog/__init__.py"
  notes:
    - "structlog provides structured logging for Python."
    - "structlog.get_logger() returns a BoundLogger."
    - "structlog.__version__ is a non-empty string."
    - "structlog.is_configured() returns a bool."
    - "structlog.BoundLogger is available."
    - "Expose structlog_version_nonempty() -> bool: len(structlog.__version__) > 0."
    - "Expose structlog_has_get_logger() -> bool: hasattr(structlog, 'get_logger')."
    - "Expose structlog_is_configured() -> bool: isinstance(structlog.is_configured(), bool)."
    - "All test vectors verified against structlog 25.1.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# structlog_version_nonempty — version non-empty
invariant structlog_rust.version.nonempty:
  description: "structlog.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: structlog_version_nonempty
  args: []
  expected: true

# structlog_has_get_logger — get_logger present
invariant structlog_rust.module.has_get_logger:
  description: "structlog.get_logger is available"
  category: module
  kind: python_call_eq
  function: structlog_has_get_logger
  args: []
  expected: true

# structlog_is_configured — is_configured returns bool
invariant structlog_rust.config.is_configured_bool:
  description: "structlog.is_configured() returns a bool"
  category: config
  kind: python_call_eq
  function: structlog_is_configured
  args: []
  expected: true

