spec: pathlib_extra249
version: ">=3.10"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
    - "pathlib_extra248.zspec.zsdl — covers Path.iterdir, mkdir, rmdir, unlink method identity"
  notes:
    - "This spec covers: pathlib.Path rename, replace, symlink_to, hardlink_to method identity."
    - "pathlib.Path.rename.__name__ == 'rename' — length 6; verified Python 3.14.3 macOS."
    - "pathlib.Path.rename.__qualname__ == 'Path.rename' — length 11; verified Python 3.14.3 macOS."
    - "pathlib.Path.rename.__module__ == 'pathlib' — length 7; verified Python 3.14.3 macOS."
    - "pathlib.Path.replace.__name__ == 'replace' — length 7; verified Python 3.14.3 macOS."
    - "pathlib.Path.replace.__qualname__ == 'Path.replace' — length 12; verified Python 3.14.3 macOS."
    - "pathlib.Path.replace.__module__ == 'pathlib' — length 7; verified Python 3.14.3 macOS."
    - "pathlib.Path.symlink_to.__name__ == 'symlink_to' — length 10; verified Python 3.14.3 macOS."
    - "pathlib.Path.symlink_to.__qualname__ == 'Path.symlink_to' — length 15; verified Python 3.14.3 macOS."
    - "pathlib.Path.symlink_to.__module__ == 'pathlib' — length 7; verified Python 3.14.3 macOS."
    - "pathlib.Path.hardlink_to.__name__ == 'hardlink_to' — length 11; hardlink_to was added in Python 3.10; verified Python 3.14.3 macOS."
    - "pathlib.Path.hardlink_to.__qualname__ == 'Path.hardlink_to' — length 16; verified Python 3.14.3 macOS."
    - "pathlib.Path.hardlink_to.__module__ == 'pathlib' — length 7; verified Python 3.14.3 macOS."
    - "All these methods are regular Python instance methods defined in pathlib, so __module__ == 'pathlib'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path.rename method identity contracts
# rename.__name__ == 'rename' (len=6), __qualname__ == 'Path.rename' (len=11),
# __module__ == 'pathlib'. All verified with Python 3.14.3 macOS.
# ---------------------------------------------------------------------------

table pathlib_extra249.rename_identity:
  description: "pathlib.Path.rename method identity: __name__, __qualname__, __module__ equality; verified Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathlibrename249

  columns: [id, function, args, expected]
  rows:
    - [rename_name_eq,      Path.rename.__name__.__eq__,      ["rename"],      true]
    - [rename_name_not,     Path.rename.__name__.__eq__,      ["replace"],     false]
    - [rename_qualname_eq,  Path.rename.__qualname__.__eq__,  ["Path.rename"], true]
    - [rename_module_eq,    Path.rename.__module__.__eq__,    ["pathlib"],     true]
    - [rename_name_len,     Path.rename.__name__.__len__,     [],              6]

# ---------------------------------------------------------------------------
# pathlib.Path.replace method identity contracts
# replace.__name__ == 'replace' (len=7), __qualname__ == 'Path.replace' (len=12),
# __module__ == 'pathlib'. All verified with Python 3.14.3 macOS.
# ---------------------------------------------------------------------------

table pathlib_extra249.replace_identity:
  description: "pathlib.Path.replace method identity: __name__, __qualname__, __module__ equality; verified Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathlibrename249

  columns: [id, function, args, expected]
  rows:
    - [replace_name_eq,      Path.replace.__name__.__eq__,      ["replace"],      true]
    - [replace_name_not,     Path.replace.__name__.__eq__,      ["rename"],       false]
    - [replace_qualname_eq,  Path.replace.__qualname__.__eq__,  ["Path.replace"], true]
    - [replace_module_eq,    Path.replace.__module__.__eq__,    ["pathlib"],      true]
    - [replace_name_len,     Path.replace.__name__.__len__,     [],               7]

# ---------------------------------------------------------------------------
# pathlib.Path.symlink_to method identity contracts
# symlink_to.__name__ == 'symlink_to' (len=10),
# __qualname__ == 'Path.symlink_to' (len=15), __module__ == 'pathlib'.
# All verified with Python 3.14.3 macOS.
# ---------------------------------------------------------------------------

table pathlib_extra249.symlink_to_identity:
  description: "pathlib.Path.symlink_to method identity: __name__, __qualname__, __module__ equality; verified Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathlibrename249

  columns: [id, function, args, expected]
  rows:
    - [symlink_name_eq,      Path.symlink_to.__name__.__eq__,      ["symlink_to"],      true]
    - [symlink_name_not,     Path.symlink_to.__name__.__eq__,      ["hardlink_to"],     false]
    - [symlink_qualname_eq,  Path.symlink_to.__qualname__.__eq__,  ["Path.symlink_to"], true]
    - [symlink_module_eq,    Path.symlink_to.__module__.__eq__,    ["pathlib"],         true]
    - [symlink_name_len,     Path.symlink_to.__name__.__len__,     [],                  10]

# ---------------------------------------------------------------------------
# pathlib.Path.hardlink_to method identity contracts
# hardlink_to was added in Python 3.10.
# hardlink_to.__name__ == 'hardlink_to' (len=11),
# __qualname__ == 'Path.hardlink_to' (len=16), __module__ == 'pathlib'.
# All verified with Python 3.14.3 macOS.
# ---------------------------------------------------------------------------

table pathlib_extra249.hardlink_to_identity:
  description: "pathlib.Path.hardlink_to method identity: __name__, __qualname__, __module__ equality; verified Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathlibrename249

  columns: [id, function, args, expected]
  rows:
    - [hardlink_name_eq,      Path.hardlink_to.__name__.__eq__,      ["hardlink_to"],      true]
    - [hardlink_name_not,     Path.hardlink_to.__name__.__eq__,      ["symlink_to"],       false]
    - [hardlink_qualname_eq,  Path.hardlink_to.__qualname__.__eq__,  ["Path.hardlink_to"], true]
    - [hardlink_module_eq,    Path.hardlink_to.__module__.__eq__,    ["pathlib"],          true]
    - [hardlink_name_len,     Path.hardlink_to.__name__.__len__,     [],                   11]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra249.rename.name_eq:
  description: "pathlib.Path.rename.__name__ == 'rename' — the unbound method's __name__ attribute; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Path.rename.__name__.__eq__
  args: ["rename"]
  expected: true

invariant pathlib_extra249.rename.qualname_eq:
  description: "pathlib.Path.rename.__qualname__ == 'Path.rename' — the class-qualified name for the method; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Path.rename.__qualname__.__eq__
  args: ["Path.rename"]
  expected: true

invariant pathlib_extra249.rename.qualname_len:
  description: "len(pathlib.Path.rename.__qualname__) == 11 — 'Path.rename' has 11 characters; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Path.rename.__qualname__.__len__
  args: []
  expected: 11

