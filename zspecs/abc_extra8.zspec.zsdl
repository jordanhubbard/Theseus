spec: abc_extra8
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc.zspec.zsdl through abc_extra7.zspec.zsdl."
    - "Prior specs cover: ABC/ABCMeta/__name__/__qualname__/__module__/__class__/__bases__; abstractmethod name/module/qualname/isabstractmethod/doc_is_str; get_cache_token type/nonneg; ABC bases/module/abstractmethods (type+len); ABC.__subclasshook__ returns NotImplementedType; ABCMeta instancecheck name/class; deprecated decorators (name/qualname/module/class_type)."
    - "This spec adds new axes: ABCMeta.__subclasscheck__ name and class; ABCMeta.__mro__ length and first/last element; ABC.__mro__ length and last element; ABC.__dict__ class name (mappingproxy); get_cache_token.__qualname__; ABC.__subclasshook__ class name (builtin_function_or_method)."
    - "abc.ABCMeta.__subclasscheck__.__name__ == '__subclasscheck__' — ABCMeta overrides issubclass() checking."
    - "abc.ABCMeta.__subclasscheck__ type is 'function'."
    - "abc.ABCMeta.__mro__ has 3 elements: ABCMeta, type, object."
    - "abc.ABCMeta.__mro__[0].__name__ == 'ABCMeta'."
    - "abc.ABCMeta.__mro__[-1].__name__ == 'object' — MRO always ends with object."
    - "abc.ABC.__mro__ has 2 elements: ABC, object."
    - "abc.ABC.__mro__[-1].__name__ == 'object'."
    - "abc.ABC.__dict__.__class__.__name__ == 'mappingproxy' — class dicts are read-only proxies."
    - "abc.get_cache_token.__qualname__ == 'get_cache_token'."
    - "abc.ABC.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ABCMeta.__subclasscheck__ — name and type
#
# abc_extra covers ABCMeta.__instancecheck__ (name + class).
# ABCMeta also overrides __subclasscheck__ to support issubclass() with ABCs.
# No prior spec checks __subclasscheck__. This is a distinct hook from
# __instancecheck__ and a genuinely new invariant.
# ---------------------------------------------------------------------------

invariant abc_extra8.ABCMeta.subclasscheck_name:
  description: "abc.ABCMeta.__subclasscheck__.__name__ == '__subclasscheck__'"
  category: abcmeta_subclasscheck
  kind: python_call_eq
  function: ABCMeta.__subclasscheck__.__name__.__eq__
  args: ["__subclasscheck__"]
  expected: true

invariant abc_extra8.ABCMeta.subclasscheck_is_function:
  description: "type(abc.ABCMeta.__subclasscheck__).__name__ == 'function'"
  category: abcmeta_subclasscheck
  kind: python_call_eq
  function: ABCMeta.__subclasscheck__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# ABCMeta.__mro__ — method resolution order
#
# No prior spec checks the MRO of ABCMeta. ABCMeta inherits from type, which
# inherits from object. The MRO is [ABCMeta, type, object], length 3.
# ---------------------------------------------------------------------------

invariant abc_extra8.ABCMeta.mro_length:
  description: "len(abc.ABCMeta.__mro__) == 3 — ABCMeta MRO is [ABCMeta, type, object]"
  category: abcmeta_mro
  kind: python_call_eq
  function: ABCMeta.__mro__.__len__
  args: []
  expected: 3

invariant abc_extra8.ABCMeta.mro_first:
  description: "abc.ABCMeta.__mro__[0].__name__ == 'ABCMeta' — first MRO entry is ABCMeta itself"
  category: abcmeta_mro
  kind: python_call_eq
  function: ABCMeta.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "ABCMeta"

invariant abc_extra8.ABCMeta.mro_last:
  description: "abc.ABCMeta.__mro__[-1].__name__ == 'object' — MRO always ends with object"
  category: abcmeta_mro
  kind: python_call_eq
  function: ABCMeta.__mro__.__getitem__
  args: [-1]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# ABC.__mro__ — method resolution order
#
# ABC inherits from object only (single base). Its MRO is [ABC, object], length 2.
# No prior spec checks the MRO of ABC.
# ---------------------------------------------------------------------------

invariant abc_extra8.ABC.mro_length:
  description: "len(abc.ABC.__mro__) == 2 — ABC MRO is [ABC, object]"
  category: abc_mro
  kind: python_call_eq
  function: ABC.__mro__.__len__
  args: []
  expected: 2

invariant abc_extra8.ABC.mro_last:
  description: "abc.ABC.__mro__[-1].__name__ == 'object' — last MRO entry is always object"
  category: abc_mro
  kind: python_call_eq
  function: ABC.__mro__.__getitem__
  args: [-1]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# ABC.__dict__ — class namespace is a read-only mappingproxy
#
# Every Python class stores its attributes in a mappingproxy. This invariant
# confirms the type of ABC's __dict__. No prior spec checks this.
# ---------------------------------------------------------------------------

invariant abc_extra8.ABC.dict_class_name:
  description: "abc.ABC.__dict__.__class__.__name__ == 'mappingproxy' — class dicts are read-only proxies"
  category: abc_class
  kind: python_call_eq
  function: ABC.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# get_cache_token.__qualname__
#
# abc_extra6 covers get_cache_token.__module__ == 'abc'.
# No prior spec checks get_cache_token.__qualname__. For a C-level builtin
# function defined at module top level, __qualname__ == __name__.
# ---------------------------------------------------------------------------

invariant abc_extra8.get_cache_token.qualname:
  description: "abc.get_cache_token.__qualname__ == 'get_cache_token'"
  category: get_cache_token
  kind: python_call_eq
  function: get_cache_token.__qualname__.__eq__
  args: ["get_cache_token"]
  expected: true

# ---------------------------------------------------------------------------
# ABC.__subclasshook__ — class of the method
#
# abc_extra verifies __subclasshook__ returns NotImplementedType (call result).
# No prior spec checks the __class__.__name__ of the __subclasshook__ method
# itself. For ABCMeta-defined classmethods implemented in C, this is
# 'builtin_function_or_method'.
# ---------------------------------------------------------------------------

invariant abc_extra8.ABC.subclasshook_class_name:
  description: "abc.ABC.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'"
  category: abc_class
  kind: python_call_eq
  function: ABC.__subclasshook__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# ABC.__bases__ length
#
# abc.zspec.zsdl checks ABC.__bases__[0].__name__ == 'object'.
# No prior spec checks len(ABC.__bases__) == 1. This confirms ABC has
# exactly one base class (object), as expected for a simple helper class.
# ---------------------------------------------------------------------------

invariant abc_extra8.ABC.bases_len:
  description: "len(abc.ABC.__bases__) == 1 — ABC has exactly one base class (object)"
  category: abc_class
  kind: python_call_eq
  function: ABC.__bases__.__len__
  args: []
  expected: 1
