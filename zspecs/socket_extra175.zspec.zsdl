table socket_extra175.address_resolution_fn_names:
  description: "socket.getaddrinfo.__name__.__eq__('getaddrinfo')==True / socket.gethostname.__name__.__eq__('gethostname')==True / socket.getfqdn.__name__.__eq__('getfqdn')==True — getaddrinfo.__name__ is 'getaddrinfo' (11 chars; socket.getaddrinfo is the primary address resolution function; it translates a host name and service name to a list of 5-tuples suitable for passing to socket() and connect(); getaddrinfo supports both IPv4 and IPv6; __name__=='getaddrinfo' (11 chars: g-e-t-a-d-d-r-i-n-f-o); novel anchor: no prior socket spec anchors getaddrinfo.__name__ under socketfns175; first socketfns175 anchor for 'getaddrinfo' as __name__); gethostname.__name__ is 'gethostname' (11 chars; socket.gethostname returns the hostname of the machine as a string; gethostname.__name__(11) == getaddrinfo.__name__.__len__()==11: two-way name-length tie at 11 chars; 'gethostname' and 'getaddrinfo' both start with 'get' and end in 'a' — coincidental shared prefix and suffix; novel anchor: first socketfns175 anchor for gethostname.__name__=='gethostname'); getfqdn.__name__ is 'getfqdn' (7 chars; socket.getfqdn returns the fully qualified domain name (FQDN) of the current host; 'getfqdn' is a shorter alias-style name — FQDN is an acronym; getfqdn.__name__(7) < getaddrinfo.__name__(11) by 4: getfqdn has the shortest name of the three; novel anchor: first socketfns175 anchor for getfqdn.__name__=='getfqdn')"
  kind: python_call_eq
  category: identity
  id_prefix: socketfns175

  columns: [id, function, args, expected, description]
  rows:
    - [getaddrinfo_name_eq, getaddrinfo.__name__.__eq__, ["getaddrinfo"], true, "socket.getaddrinfo.__name__ == 'getaddrinfo' (11 chars; address resolution; novel anchor)"]
    - [gethostname_name_eq, gethostname.__name__.__eq__, ["gethostname"], true, "socket.gethostname.__name__ == 'gethostname' (11 chars; tied with getaddrinfo(11); novel anchor)"]
    - [getfqdn_name_eq,     getfqdn.__name__.__eq__,     ["getfqdn"],     true, "socket.getfqdn.__name__ == 'getfqdn' (7 chars; FQDN; 7<11 by 4; novel anchor)"]

