spec: array_extra2
version: ">=3.9"
backend: python_module(array)

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/array.html — Python array module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/arraymodule.c"
  notes:
    - "This spec covers invariants not present in array.zspec.zsdl or array_extra.zspec.zsdl."
    - "array.array.__name__ == 'array' — the class name is 'array', same as the module name."
    - "array.array.__module__ == 'array' — the type is implemented at the C level in the array module."
    - "array.typecodes is a module-level str containing all valid typecode characters."
    - "Minimum typecodes on all platforms: b, B, h, H, i, I, l, L, q, Q, f, d (12 codes)."
    - "The typecodes string includes at minimum b, B, h, i, l, q, f, d (8 core codes)."
    - "array.typecodes.__len__() >= 10 on all supported Python 3.x platforms."
    - "itemsize for 'b'==1, 'B'==1, 'h'==2, 'f'==4, 'd'==8 are guaranteed by C standard types."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class identity — array type __name__ and __module__
# ---------------------------------------------------------------------------

invariant array_extra2.class_identity.name:
  description: "array.array.__name__ == 'array' — the class name is 'array'"
  category: class_identity
  kind: python_call_eq
  function: array.__name__.__eq__
  args: ["array"]
  expected: true

invariant array_extra2.class_identity.module:
  description: "array.array.__module__ == 'array' — the class is defined in the C-level array module"
  category: class_identity
  kind: python_call_eq
  function: array.__module__.__eq__
  args: ["array"]
  expected: true

# ---------------------------------------------------------------------------
# typecodes — module-level string of valid typecode characters
# ---------------------------------------------------------------------------

invariant array_extra2.typecodes.is_str:
  description: "array.typecodes.__class__.__name__ == 'str' — typecodes is a plain str"
  category: typecodes
  kind: python_call_eq
  function: typecodes.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant array_extra2.typecodes.min_length:
  description: "len(array.typecodes) >= 10 — at least 10 typecodes on all supported platforms"
  category: typecodes
  kind: python_call_eq
  function: typecodes.__len__
  args: []
  method: __ge__
  method_args: [10]
  expected: true

# ---------------------------------------------------------------------------
# typecodes content — each required typecode is present
# ---------------------------------------------------------------------------

table array_extra2.typecodes.contains:
  kind: python_call_eq
  category: typecodes
  id_prefix: contains

  columns: [id, function, args, expected]
  rows:
    - [b, typecodes.__contains__, ["b"], true]
    - [B, typecodes.__contains__, ["B"], true]
    - [h, typecodes.__contains__, ["h"], true]
    - [i, typecodes.__contains__, ["i"], true]
    - [l, typecodes.__contains__, ["l"], true]
    - [q, typecodes.__contains__, ["q"], true]
    - [f, typecodes.__contains__, ["f"], true]
    - [d, typecodes.__contains__, ["d"], true]

# ---------------------------------------------------------------------------
# itemsize guarantees — platform-invariant sizes via C standard types
# ---------------------------------------------------------------------------

table array_extra2.itemsize:
  kind: python_call_eq
  category: itemsize
  id_prefix: itemsize

  columns: [id, function, args, method, expected]
  rows:
    - [signed_char,   array, ["b", [0]], itemsize, 1]
    - [unsigned_char, array, ["B", [0]], itemsize, 1]
    - [short,         array, ["h", [0]], itemsize, 2]
    - [float,         array, ["f", [0.0]], itemsize, 4]
    - [double,        array, ["d", [0.0]], itemsize, 8]

# ---------------------------------------------------------------------------
# typecode attribute — constructor argument is reflected back
# ---------------------------------------------------------------------------

table array_extra2.typecode_attr:
  kind: python_call_eq
  category: typecode_attr
  id_prefix: typecode

  columns: [id, function, args, method, expected]
  rows:
    - [b, array, ["b", [0]],   typecode, "b"]
    - [B, array, ["B", [0]],   typecode, "B"]
    - [h, array, ["h", [0]],   typecode, "h"]
    - [i, array, ["i", [0]],   typecode, "i"]
    - [f, array, ["f", [0.0]], typecode, "f"]
    - [d, array, ["d", [0.0]], typecode, "d"]
