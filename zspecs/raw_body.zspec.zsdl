spec: raw_body
version: ">=2.5.0"
backend: node(raw-body)

docs: https://github.com/stream-utils/raw-body#readme

provenance:
  derived_from:
    - "raw-body README — https://github.com/stream-utils/raw-body#readme"
    - "Test vectors verified with raw-body via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "raw-body source"
  notes:
    - "Read the body of an incoming HTTP request stream into a Buffer/string with size + encoding limits."
    - "Install: npm install raw-body"
    - "v2 CJS; module export IS getRawBody(stream, [options], [callback])."
    - "Spec covers shape only — feeding a real readable stream via JSON entry_args is not possible."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Rejects/callbacks with an Error carrying a status (413/415/422) on limit/encoding/length issues."
  stderr: "null"
  stickiness: "Each call drains the stream once."
  codes: {}

invariant raw_body.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant raw_body.module_name:
  description: "Function name is 'getRawBody'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: name}
  expected: "getRawBody"

invariant raw_body.module_arity:
  description: "Module function takes 3 args (stream, options, callback)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 3

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T23:16:24Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
