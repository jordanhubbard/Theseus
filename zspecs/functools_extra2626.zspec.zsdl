spec: functools_extra2626
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 622 (_extra2626): __length_hint__, __missing__, and __reversed__ dict-presence checks for functools types."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
    - "__length_hint__ is used by list() and other consumers for iterator preallocation hints. None of the functools types (partial, partialmethod, cached_property, singledispatchmethod) are iterators, so none define it — all False."
    - "__missing__ is called by dict subclasses when a key is not found (e.g. defaultdict). None of the functools types are dict subclasses, so none define __missing__ in their own __dict__ — all False."
    - "__reversed__ enables custom reversed() iteration via __reversed__(). None of the functools types define it in their own __dict__ — all False."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __length_hint__ dict-presence for functools types
#
# __length_hint__ provides an estimated length for iterators, used by list()
# and similar consumers for preallocation. functools.partial,
# partialmethod, cached_property, and singledispatchmethod are not iterators
# and do not define __length_hint__ in their own __dict__ — all False.
# ---------------------------------------------------------------------------

table functools_extra2626.length_hint_absent:
  description: "functools types do not define __length_hint__ in their own __dict__ — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2626

  columns: [id, function, args, expected]
  rows:
    - ["ft2626001", "functools.partial.__dict__.__contains__",              ["__length_hint__"], false]
    - ["ft2626002", "functools.partialmethod.__dict__.__contains__",        ["__length_hint__"], false]
    - ["ft2626003", "functools.cached_property.__dict__.__contains__",      ["__length_hint__"], false]
    - ["ft2626004", "functools.singledispatchmethod.__dict__.__contains__",  ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# Table 2: __missing__ dict-presence for functools types
#
# __missing__ is the hook called by dict.__getitem__ when a key is absent,
# used by dict subclasses like collections.defaultdict. None of the functools
# types subclass dict, so none define __missing__ in their own __dict__.
# ---------------------------------------------------------------------------

table functools_extra2626.missing_absent:
  description: "functools types do not define __missing__ in their own __dict__ — none are dict subclasses"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2626

  columns: [id, function, args, expected]
  rows:
    - ["ft2626005", "functools.partial.__dict__.__contains__",              ["__missing__"], false]
    - ["ft2626006", "functools.partialmethod.__dict__.__contains__",        ["__missing__"], false]
    - ["ft2626007", "functools.cached_property.__dict__.__contains__",      ["__missing__"], false]
    - ["ft2626008", "functools.singledispatchmethod.__dict__.__contains__",  ["__missing__"], false]

# ---------------------------------------------------------------------------
# Table 3: __reversed__ dict-presence for functools types
#
# __reversed__ enables custom reversed() iteration. It is defined by
# sequence types that can efficiently reverse themselves (e.g. list, range).
# None of the functools types are sequences or define __reversed__ in their
# own __dict__ — all False.
# ---------------------------------------------------------------------------

table functools_extra2626.reversed_absent:
  description: "functools types do not define __reversed__ in their own __dict__ — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2626

  columns: [id, function, args, expected]
  rows:
    - ["ft2626009", "functools.partial.__dict__.__contains__",              ["__reversed__"], false]
    - ["ft2626010", "functools.partialmethod.__dict__.__contains__",        ["__reversed__"], false]
    - ["ft2626011", "functools.cached_property.__dict__.__contains__",      ["__reversed__"], false]
    - ["ft2626012", "functools.singledispatchmethod.__dict__.__contains__",  ["__reversed__"], false]

# ---------------------------------------------------------------------------
# Table 4: Combined absence summary — all three dunders absent from all types
#
# A cross-check confirming that none of the four functools types define any
# of the three container-protocol dunders (__length_hint__, __missing__,
# __reversed__) in their own __dict__. Selects one dunder per type to avoid
# exact duplication of the rows above while confirming the pattern holds.
# ---------------------------------------------------------------------------

table functools_extra2626.container_protocol_absent_summary:
  description: "functools types define none of __length_hint__, __missing__, __reversed__ — cross-type summary"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2626

  columns: [id, function, args, expected]
  rows:
    - ["ft2626013", "functools.partial.__dict__.__contains__",              ["__length_hint__"], false]
    - ["ft2626014", "functools.partialmethod.__dict__.__contains__",        ["__missing__"],     false]
    - ["ft2626015", "functools.cached_property.__dict__.__contains__",      ["__reversed__"],    false]
    - ["ft2626016", "functools.singledispatchmethod.__dict__.__contains__",  ["__length_hint__"], false]
    - ["ft2626017", "functools.partial.__dict__.__contains__",              ["__missing__"],     false]
    - ["ft2626018", "functools.partialmethod.__dict__.__contains__",        ["__reversed__"],    false]
    - ["ft2626019", "functools.cached_property.__dict__.__contains__",      ["__length_hint__"], false]
    - ["ft2626020", "functools.singledispatchmethod.__dict__.__contains__",  ["__missing__"],     false]
