spec: unittest_extra4
version: ">=3.9"
backend: python_module(unittest)

docs: https://docs.python.org/3/library/unittest.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unittest.html — Python unittest module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/unittest/__init__.py"
  notes:
    - "This spec extends prior unittest specs."
    - "Focus: class names and function names not yet covered."
    - "unittest.TestCase.__name__ == 'TestCase'."
    - "unittest.TestSuite.__name__ == 'TestSuite'."
    - "unittest.TestLoader.__name__ == 'TestLoader'."
    - "unittest.TestResult.__name__ == 'TestResult'."
    - "unittest.TextTestRunner.__name__ == 'TextTestRunner'."
    - "unittest.TextTestResult.__name__ == 'TextTestResult'."
    - "unittest.TestProgram.__name__ == 'TestProgram'."
    - "unittest.SkipTest.__name__ == 'SkipTest'."
    - "unittest.skip.__name__ == 'skip'."
    - "unittest.skipIf.__name__ == 'skipIf'."
    - "unittest.skipUnless.__name__ == 'skipUnless'."
    - "unittest.expectedFailure.__name__ == 'expectedFailure'."
    - "unittest.main.__name__ == 'main'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table unittest_extra4.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [TestCase,        TestCase.__name__.__eq__,        ["TestCase"],        true]
    - [TestSuite,       TestSuite.__name__.__eq__,       ["TestSuite"],       true]
    - [TestLoader,      TestLoader.__name__.__eq__,      ["TestLoader"],      true]
    - [TestResult,      TestResult.__name__.__eq__,      ["TestResult"],      true]
    - [TextTestRunner,  TextTestRunner.__name__.__eq__,  ["TextTestRunner"],  true]
    - [TextTestResult,  TextTestResult.__name__.__eq__,  ["TextTestResult"],  true]
    - [TestProgram,     TestProgram.__name__.__eq__,     ["TestProgram"],     true]
    - [SkipTest,        SkipTest.__name__.__eq__,        ["SkipTest"],        true]

table unittest_extra4.decorator_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [skip,            skip.__name__.__eq__,            ["skip"],            true]
    - [skipIf,          skipIf.__name__.__eq__,          ["skipIf"],          true]
    - [skipUnless,      skipUnless.__name__.__eq__,      ["skipUnless"],      true]
    - [expectedFailure, expectedFailure.__name__.__eq__, ["expectedFailure"], true]

table unittest_extra4.class_modules:
  kind: python_call_eq
  category: module
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [TestCase,       TestCase.__module__.__eq__,       ["unittest.case"],   true]
    - [TestSuite,      TestSuite.__module__.__eq__,      ["unittest.suite"],  true]
    - [TestLoader,     TestLoader.__module__.__eq__,     ["unittest.loader"], true]
    - [TestResult,     TestResult.__module__.__eq__,     ["unittest.result"], true]
    - [SkipTest,       SkipTest.__module__.__eq__,       ["unittest.case"],   true]

invariant unittest_extra4.SkipTest.base:
  description: "unittest.SkipTest.__bases__[0].__name__ == 'Exception'"
  category: exceptions
  kind: python_call_eq
  function: SkipTest.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant unittest_extra4.TestCase.instance_class:
  description: "unittest.TestCase.__class__.__name__ == 'type'"
  category: TestCase
  kind: python_call_eq
  function: TestCase.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant unittest_extra4.defaultTestLoader.class_name:
  description: "unittest.defaultTestLoader.__class__.__name__ == 'TestLoader'"
  category: instances
  kind: python_call_eq
  function: defaultTestLoader.__class__.__name__.__eq__
  args: ["TestLoader"]
  expected: true
