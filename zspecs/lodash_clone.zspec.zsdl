spec: lodash_clone
version: ">=4.0.0"
backend: node(lodash.clone)

docs: https://lodash.com/docs/#clone

provenance:
  derived_from:
    - "lodash.clone README — https://www.npmjs.com/package/lodash.clone"
    - "Test vectors verified with lodash.clone@4.5.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.clone exports the _.clone function directly as module.exports."
    - "clone(value) creates a shallow clone of value."
    - "For plain values (numbers, strings), returns the same value."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a shallow clone."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_clone.clone:
  kind: node_module_call_eq
  function: ~
  category: clone
  id_prefix: lcln

  columns: [id, args, expected]
  rows:
    - [array,   [[1, 2, 3]],         [1, 2, 3]]
    - [object,  [{"a": 1, "b": 2}],  {"a": 1, "b": 2}]
    - [string,  ["hello"],           "hello"]
    - [number,  [42],                42]

