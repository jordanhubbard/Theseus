spec: hashlib_extra197
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Modules/md5module.c"
  notes:
    - "hashlib.md5.__qualname__ == 'openssl_md5' and hashlib.md5.__name__ == 'openssl_md5' — on macOS/Darwin with OpenSSL, the md5 constructor is the openssl_md5 builtin; __name__ and __qualname__ both reflect the OpenSSL wrapper name."
    - "hashlib.sha256.__qualname__ == 'openssl_sha256' and hashlib.sha256.__name__ == 'openssl_sha256' — same pattern as md5 on OpenSSL-backed platforms."
    - "hashlib.pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac' and hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac' — pbkdf2_hmac is a module-level builtin_function_or_method, not a class wrapper."
    - "hashlib.blake2b.__name__ == 'blake2b' (len=7); hashlib.blake2s.__name__ == 'blake2s' (len=7) — the BLAKE2 constructors are not OpenSSL-backed on macOS and retain their canonical names."
    - "hashlib.md5.__name__.__len__() == 11 ('openssl_md5' has 11 characters); sha256 has 14 ('openssl_sha256'); pbkdf2_hmac has 11 ('pbkdf2_hmac')."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HASH constructor qualnames — md5, sha256, pbkdf2_hmac
# On macOS/Darwin with OpenSSL, md5 and sha256 are openssl_* wrappers.
# ---------------------------------------------------------------------------

table hashlibnamelens197.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: hashlibnamelens197

  columns: [id, function, args, expected, description]
  rows:
    - [md5_qualname,       md5.__qualname__.__eq__,       ["openssl_md5"],    true, "hashlib.md5.__qualname__ == 'openssl_md5' (OpenSSL-backed wrapper on macOS/Darwin)"]
    - [sha256_qualname,    sha256.__qualname__.__eq__,    ["openssl_sha256"], true, "hashlib.sha256.__qualname__ == 'openssl_sha256' (OpenSSL-backed wrapper on macOS/Darwin)"]
    - [pbkdf2_qualname,    pbkdf2_hmac.__qualname__.__eq__, ["pbkdf2_hmac"],  true, "hashlib.pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac' (module-level builtin, not an OpenSSL class wrapper)"]

# ---------------------------------------------------------------------------
# HASH constructor __name__ lengths — md5, sha256, pbkdf2_hmac, blake2b, blake2s
# ---------------------------------------------------------------------------

table hashlibnamelens197.name_lengths:
  kind: python_call_eq
  category: name_lengths
  id_prefix: hashlibnamelens197

  columns: [id, function, args, expected, description]
  rows:
    - [md5_name_len,       md5.__name__.__len__,       [], 11, "len(hashlib.md5.__name__) == 11 ('openssl_md5' has 11 characters)"]
    - [sha256_name_len,    sha256.__name__.__len__,    [], 14, "len(hashlib.sha256.__name__) == 14 ('openssl_sha256' has 14 characters)"]
    - [pbkdf2_name_len,    pbkdf2_hmac.__name__.__len__, [], 11, "len(hashlib.pbkdf2_hmac.__name__) == 11 ('pbkdf2_hmac' has 11 characters)"]
    - [blake2b_name_len,   blake2b.__name__.__len__,   [],  7, "len(hashlib.blake2b.__name__) == 7 ('blake2b' has 7 characters)"]
    - [blake2s_name_len,   blake2s.__name__.__len__,   [],  7, "len(hashlib.blake2s.__name__) == 7 ('blake2s' has 7 characters)"]

# ---------------------------------------------------------------------------
# HASH constructor __name__ equality — md5, sha256, blake2b, blake2s
# (pbkdf2_hmac name equality already tested in hashlib_extra.zspec.zsdl)
# ---------------------------------------------------------------------------

table hashlibnamelens197.name_equality:
  kind: python_call_eq
  category: name_equality
  id_prefix: hashlibnamelens197

  columns: [id, function, args, expected, description]
  rows:
    - [md5_name_eq,     md5.__name__.__eq__,     ["openssl_md5"],    true, "hashlib.md5.__name__ == 'openssl_md5' (OpenSSL-backed constructor name on macOS/Darwin)"]
    - [sha256_name_eq,  sha256.__name__.__eq__,  ["openssl_sha256"], true, "hashlib.sha256.__name__ == 'openssl_sha256' (OpenSSL-backed constructor name on macOS/Darwin)"]
    - [blake2b_name_eq, blake2b.__name__.__eq__,  ["blake2b"],        true, "hashlib.blake2b.__name__ == 'blake2b' (native BLAKE2 constructor, not OpenSSL-backed)"]
    - [blake2s_name_eq, blake2s.__name__.__eq__,  ["blake2s"],        true, "hashlib.blake2s.__name__ == 'blake2s' (native BLAKE2 constructor, not OpenSSL-backed)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashlibnamelens197.md5.qualname:
  description: "hashlib.md5.__qualname__ == 'openssl_md5' (OpenSSL-backed wrapper on macOS/Darwin)"
  category: qualnames
  kind: python_call_eq
  function: md5.__qualname__.__eq__
  args: ["openssl_md5"]
  expected: true

invariant hashlibnamelens197.sha256.qualname:
  description: "hashlib.sha256.__qualname__ == 'openssl_sha256' (OpenSSL-backed wrapper on macOS/Darwin)"
  category: qualnames
  kind: python_call_eq
  function: sha256.__qualname__.__eq__
  args: ["openssl_sha256"]
  expected: true

invariant hashlibnamelens197.pbkdf2_hmac.qualname:
  description: "hashlib.pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac' (module-level builtin function)"
  category: qualnames
  kind: python_call_eq
  function: pbkdf2_hmac.__qualname__.__eq__
  args: ["pbkdf2_hmac"]
  expected: true

invariant hashlibnamelens197.md5.name_len:
  description: "len(hashlib.md5.__name__) == 11 ('openssl_md5' has 11 characters)"
  category: name_lengths
  kind: python_call_eq
  function: md5.__name__.__len__
  args: []
  expected: 11

invariant hashlibnamelens197.sha256.name_len:
  description: "len(hashlib.sha256.__name__) == 14 ('openssl_sha256' has 14 characters)"
  category: name_lengths
  kind: python_call_eq
  function: sha256.__name__.__len__
  args: []
  expected: 14

invariant hashlibnamelens197.pbkdf2_hmac.name_len:
  description: "len(hashlib.pbkdf2_hmac.__name__) == 11 ('pbkdf2_hmac' has 11 characters)"
  category: name_lengths
  kind: python_call_eq
  function: pbkdf2_hmac.__name__.__len__
  args: []
  expected: 11

invariant hashlibnamelens197.blake2b.name_len:
  description: "len(hashlib.blake2b.__name__) == 7 ('blake2b' has 7 characters)"
  category: name_lengths
  kind: python_call_eq
  function: blake2b.__name__.__len__
  args: []
  expected: 7

invariant hashlibnamelens197.blake2s.name_len:
  description: "len(hashlib.blake2s.__name__) == 7 ('blake2s' has 7 characters)"
  category: name_lengths
  kind: python_call_eq
  function: blake2s.__name__.__len__
  args: []
  expected: 7
