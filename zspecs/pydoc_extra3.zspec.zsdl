spec: pydoc_extra3
version: ">=3.9"
backend: python_module(pydoc)

docs: https://docs.python.org/3/library/pydoc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pydoc.html — Python pydoc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pydoc.py"
  notes:
    - "This spec extends pydoc.zspec.zsdl, pydoc_extra.zspec.zsdl, and pydoc_extra2.zspec.zsdl."
    - "pydoc.zspec.zsdl covers: HTMLDoc/TextDoc/ModuleScanner/ErrorDuringImport __name__ and __module__ (table); ErrorDuringImport hierarchy; describe/plain behavior; help/describe/locate/render_doc/plain/pager __name__ (table); module __name__."
    - "pydoc_extra.zspec.zsdl covers: locate/render_doc/resolve __name__ and is_callable; TextDoc/HTMLDoc/Doc/ModuleScanner/Helper __name__ and __module__; plaintext/html/help singleton class names."
    - "pydoc_extra2.zspec.zsdl covers: help.__class__.__name__ via __eq__; plain/render_doc/resolve/describe/locate __module__; function __name__ batch table."
    - "This spec adds: Helper/__qualname__, TextDoc/__qualname__, HTMLDoc/__qualname__, ModuleScanner/__qualname__ — not in any prior spec."
    - "Also adds: Helper.__bases__[0].__name__ — Helper inherits from object."
    - "For top-level classes, __qualname__ == __name__ in CPython."
    - "pydoc.Helper.__bases__[0].__name__ == 'object' — Helper inherits directly from object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Helper — __qualname__
# Not covered by pydoc.zspec.zsdl, pydoc_extra.zspec.zsdl, or pydoc_extra2.zspec.zsdl
# ---------------------------------------------------------------------------

invariant pydoc_extra3.Helper.qualname:
  description: "pydoc.Helper.__qualname__ == 'Helper' — top-level class qualname matches name"
  category: classes
  kind: python_call_eq
  function: Helper.__qualname__.__eq__
  args: ["Helper"]
  expected: true

# ---------------------------------------------------------------------------
# TextDoc — __qualname__
# Not covered by any prior spec
# ---------------------------------------------------------------------------

invariant pydoc_extra3.TextDoc.qualname:
  description: "pydoc.TextDoc.__qualname__ == 'TextDoc' — top-level class qualname matches name"
  category: classes
  kind: python_call_eq
  function: TextDoc.__qualname__.__eq__
  args: ["TextDoc"]
  expected: true

# ---------------------------------------------------------------------------
# HTMLDoc — __qualname__
# Not covered by any prior spec
# ---------------------------------------------------------------------------

invariant pydoc_extra3.HTMLDoc.qualname:
  description: "pydoc.HTMLDoc.__qualname__ == 'HTMLDoc' — top-level class qualname matches name"
  category: classes
  kind: python_call_eq
  function: HTMLDoc.__qualname__.__eq__
  args: ["HTMLDoc"]
  expected: true

# ---------------------------------------------------------------------------
# ModuleScanner — __qualname__
# Not covered by any prior spec
# ---------------------------------------------------------------------------

invariant pydoc_extra3.ModuleScanner.qualname:
  description: "pydoc.ModuleScanner.__qualname__ == 'ModuleScanner' — top-level class qualname matches name"
  category: classes
  kind: python_call_eq
  function: ModuleScanner.__qualname__.__eq__
  args: ["ModuleScanner"]
  expected: true

# ---------------------------------------------------------------------------
# Helper — class hierarchy
# pydoc.zspec.zsdl checks ErrorDuringImport hierarchy. No prior spec checks Helper hierarchy.
# ---------------------------------------------------------------------------

invariant pydoc_extra3.Helper.base_is_object:
  description: "pydoc.Helper.__bases__[0].__name__ == 'object' — Helper inherits directly from object"
  category: hierarchy
  kind: python_call_eq
  function: Helper.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

# ---------------------------------------------------------------------------
# help singleton — __class__.__qualname__
# pydoc_extra.zspec.zsdl checks help.__class__.__name__ == 'Helper'.
# pydoc_extra2.zspec.zsdl checks the same via a different accessor path.
# This invariant checks help.__class__.__qualname__ == 'Helper' — a new vector.
# ---------------------------------------------------------------------------

invariant pydoc_extra3.help.class_qualname:
  description: "pydoc.help.__class__.__qualname__ == 'Helper' — help instance class qualname"
  category: singletons
  kind: python_call_eq
  function: help.__class__.__qualname__.__eq__
  args: ["Helper"]
  expected: true

# ---------------------------------------------------------------------------
# Table: batch __qualname__ checks for documentation formatter classes
# ---------------------------------------------------------------------------

table pydoc_extra3.class_qualnames:
  kind: python_call_eq
  category: classes
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Helper,        Helper.__qualname__.__eq__,        ["Helper"],        true]
    - [TextDoc,       TextDoc.__qualname__.__eq__,       ["TextDoc"],       true]
    - [HTMLDoc,       HTMLDoc.__qualname__.__eq__,       ["HTMLDoc"],       true]
    - [ModuleScanner, ModuleScanner.__qualname__.__eq__, ["ModuleScanner"], true]
