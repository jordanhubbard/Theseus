spec: pathlib_extra386
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "pathlib.Path.__truediv__ and __rtruediv__ implement the / operator for path joining; both report __name__ matching their dunder name"
    - "pathlib.PurePath defines __truediv__, __rtruediv__, __str__, __fspath__, __hash__, __eq__ — all are inherited by Path"
    - "pathlib.Path.__truediv__.__name__ == '__truediv__' and pathlib.Path.__rtruediv__.__name__ == '__rtruediv__'"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath dunder method __name__ identity
# ---------------------------------------------------------------------------

table pathlib_extra386.purepath_dunder_method_names:
  description: "pathlib.PurePath dunder method __name__ identity — __truediv__, __rtruediv__, __str__, __fspath__, __hash__, __eq__; each method's __name__ matches its Python-level dunder name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: plppdunder386

  columns: [id, function, args, expected]
  rows:
    - [truediv_name,  pathlib.PurePath.__truediv__.__name__.__eq__,  ["__truediv__"],  true]
    - [rtruediv_name, pathlib.PurePath.__rtruediv__.__name__.__eq__, ["__rtruediv__"], true]
    - [str_name,      pathlib.PurePath.__str__.__name__.__eq__,      ["__str__"],      true]
    - [fspath_name,   pathlib.PurePath.__fspath__.__name__.__eq__,   ["__fspath__"],   true]
    - [hash_name,     pathlib.PurePath.__hash__.__name__.__eq__,     ["__hash__"],     true]
    - [eq_name,       pathlib.PurePath.__eq__.__name__.__eq__,       ["__eq__"],       true]

# ---------------------------------------------------------------------------
# pathlib.Path division operator method __name__ identity
# ---------------------------------------------------------------------------

table pathlib_extra386.path_truediv_method_names:
  description: "pathlib.Path.__truediv__ and __rtruediv__ __name__ identity — the / operator for Path objects; both report __name__ matching their dunder name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: plptruediv386

  columns: [id, function, args, expected]
  rows:
    - [path_truediv_name,  pathlib.Path.__truediv__.__name__.__eq__,  ["__truediv__"],  true]
    - [path_rtruediv_name, pathlib.Path.__rtruediv__.__name__.__eq__, ["__rtruediv__"], true]
