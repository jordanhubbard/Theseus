spec: iso_3166_1
version: ">=1.0.0"
backend: node(iso-3166-1)

docs: https://www.npmjs.com/package/iso-3166-1

provenance:
  derived_from:
    - "iso-3166-1 README — https://www.npmjs.com/package/iso-3166-1"
    - "Test vectors verified with iso-3166-1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "iso-3166-1 source"
  notes:
    - "iso-3166-1 is an npm package. Install: npm install iso-3166-1"
    - "whereAlpha2(code) looks up a country by its ISO 3166-1 alpha-2 code."
    - "whereAlpha3(code) looks up a country by its ISO 3166-1 alpha-3 code."
    - "Returns {country, alpha2, alpha3, numeric} or undefined if not found."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns country object or undefined."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table iso_3166_1.whereAlpha2:
  kind: node_module_call_eq
  function: whereAlpha2
  category: whereAlpha2
  id_prefix: isoa2

  columns: [id, args, expected]
  rows:
    - [us, ["US"],
       {"country": "United States of America", "alpha2": "US", "alpha3": "USA", "numeric": "840"}]
    - [de, ["DE"],
       {"country": "Germany", "alpha2": "DE", "alpha3": "DEU", "numeric": "276"}]
    - [jp, ["JP"],
       {"country": "Japan", "alpha2": "JP", "alpha3": "JPN", "numeric": "392"}]

table iso_3166_1.whereAlpha3:
  kind: node_module_call_eq
  function: whereAlpha3
  category: whereAlpha3
  id_prefix: isoa3

  columns: [id, args, expected]
  rows:
    - [gbr, ["GBR"],
       {"country": "United Kingdom of Great Britain and Northern Ireland",
        "alpha2": "GB", "alpha3": "GBR", "numeric": "826"}]
    - [fra, ["FRA"],
       {"country": "France", "alpha2": "FR", "alpha3": "FRA", "numeric": "250"}]

