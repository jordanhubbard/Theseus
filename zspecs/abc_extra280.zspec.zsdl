spec: abc_extra280
version: ">=3.9"
backend: python_module(collections.abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — abstract base class hierarchy and module membership"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "All collections.abc classes have __module__ == 'collections.abc'"
    - "Sequence.__bases__ == ['Reversible', 'Collection'] (multiple inheritance)"
    - "MutableSequence.__bases__[0].__name__ == 'Sequence'"
    - "Collection.__bases__ == ['Sized', 'Iterable', 'Container'] (multiple inheritance)"
    - "Iterable.__bases__[0].__name__ == 'object'"
    - "Iterator.__bases__[0].__name__ == 'Iterable'"
    - "Generator.__bases__[0].__name__ == 'Iterator'"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table abc_extra280.sequence_class_names:
  description: "collections.abc sequence-like ABC __name__ attributes"
  kind: python_call_eq
  category: identity
  id_prefix: abc280n

  columns: [id, function, args, expected, description]
  rows:
    - [abc280n001, collections.abc.Sequence.__name__.__eq__, ["Sequence"], true, "Sequence __name__"]
    - [abc280n002, collections.abc.MutableSequence.__name__.__eq__, ["MutableSequence"], true, "MutableSequence __name__"]
    - [abc280n003, collections.abc.Mapping.__name__.__eq__, ["Mapping"], true, "Mapping __name__"]
    - [abc280n004, collections.abc.MutableMapping.__name__.__eq__, ["MutableMapping"], true, "MutableMapping __name__"]
    - [abc280n005, collections.abc.Set.__name__.__eq__, ["Set"], true, "Set __name__"]
    - [abc280n006, collections.abc.MutableSet.__name__.__eq__, ["MutableSet"], true, "MutableSet __name__"]

table abc_extra280.iterator_class_names:
  description: "collections.abc iterator-like and other ABC __name__ attributes"
  kind: python_call_eq
  category: identity
  id_prefix: abc280i

  columns: [id, function, args, expected, description]
  rows:
    - [abc280i001, collections.abc.Iterable.__name__.__eq__, ["Iterable"], true, "Iterable __name__"]
    - [abc280i002, collections.abc.Iterator.__name__.__eq__, ["Iterator"], true, "Iterator __name__"]
    - [abc280i003, collections.abc.Generator.__name__.__eq__, ["Generator"], true, "Generator __name__"]
    - [abc280i004, collections.abc.Callable.__name__.__eq__, ["Callable"], true, "Callable __name__"]
    - [abc280i005, collections.abc.Hashable.__name__.__eq__, ["Hashable"], true, "Hashable __name__"]
    - [abc280i006, collections.abc.Sized.__name__.__eq__, ["Sized"], true, "Sized __name__"]
    - [abc280i007, collections.abc.Container.__name__.__eq__, ["Container"], true, "Container __name__"]

invariant abc_extra280.sequence_module:
  description: "Sequence __module__ is collections.abc"
  category: identity
  kind: python_call_eq
  function: collections.abc.Sequence.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra280.mutable_sequence_base:
  description: "MutableSequence base class is Sequence"
  category: identity
  kind: python_call_eq
  function: collections.abc.MutableSequence.__bases__[0].__name__.__eq__
  args: ["Sequence"]
  expected: true

invariant abc_extra280.mutable_mapping_base:
  description: "MutableMapping base class is Mapping"
  category: identity
  kind: python_call_eq
  function: collections.abc.MutableMapping.__bases__[0].__name__.__eq__
  args: ["Mapping"]
  expected: true

invariant abc_extra280.mutable_set_base:
  description: "MutableSet base class is Set"
  category: identity
  kind: python_call_eq
  function: collections.abc.MutableSet.__bases__[0].__name__.__eq__
  args: ["Set"]
  expected: true

invariant abc_extra280.iterator_base:
  description: "Iterator base class is Iterable"
  category: identity
  kind: python_call_eq
  function: collections.abc.Iterator.__bases__[0].__name__.__eq__
  args: ["Iterable"]
  expected: true

invariant abc_extra280.generator_base:
  description: "Generator base class is Iterator"
  category: identity
  kind: python_call_eq
  function: collections.abc.Generator.__bases__[0].__name__.__eq__
  args: ["Iterator"]
  expected: true

invariant abc_extra280.collection_name:
  description: "Collection __name__ is Collection"
  category: identity
  kind: python_call_eq
  function: collections.abc.Collection.__name__.__eq__
  args: ["Collection"]
  expected: true
