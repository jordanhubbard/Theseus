  columns: [id, function, args, expected]
  rows:
    - ["mp3331009",  operator.contains, [multiprocessing.Process.__dict__,                 "__ior__"], false]
    - ["mp3331010",  operator.contains, [multiprocessing.pool.Pool.__dict__,               "__ior__"], false]
    - ["mp3331011",  operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__ior__"], false]
    - ["mp3331012",  operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__ior__"], false]
    - ["mp3331013",  operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__ior__"], false]
    - ["mp3331014",  operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__ior__"], false]
    - ["mp3331015",  operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__ior__"], false]
    - ["mp3331016",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__ior__"], false]

# ---------------------------------------------------------------------------
# __ixor__ dict-presence — operator.contains(Cls.__dict__, '__ixor__')
#
# All 8 multiprocessing classes return false for __ixor__.
# In-place bitwise XOR (__ixor__, ^=) is the augmented assignment variant
#   of __xor__. Wave 661 confirmed __xor__ is false for all 8 mp types.
# managers._BaseSetProxy key note: set defines __ixor__ for in-place
#   symmetric difference (s ^= t). However, _BaseSetProxy.__dict__ does NOT
#   contain __ixor__ — the proxy does not forward in-place set algebra
#   operations. This is consistent with __iand__ and __ior__: _BaseSetProxy
#   proxies set, which has __iand__/__ior__/__ixor__ for in-place set algebra,
#   but the proxy dict does not contain any of them. No in-place proxy
#   forwarding is implemented.
# managers._BaseDictProxy: dict defines no __ixor__. False.
# managers.BaseListProxy: list defines no __ixor__. False.
# Process/Pool/AsyncResult/MapResult/SyncManager: no in-place XOR defined.
# ---------------------------------------------------------------------------

