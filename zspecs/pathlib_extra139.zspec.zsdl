spec: pathlib_extra139
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path I/O methods and filesystem-mutation methods — __qualname__ string equality and length checks for read_text, write_text, read_bytes, write_bytes, open, mkdir, rmdir, unlink, touch, rename, replace."
    - "All listed pathlib.Path methods are pure Python functions (not C descriptors), so their __class__.__name__ == 'function'."
    - "These methods are defined directly on Path (not inherited from PurePath), so __qualname__ == 'Path.<methodname>'."
    - "pathlib.Path.read_text.__qualname__ == 'Path.read_text' (length 14)."
    - "pathlib.Path.write_text.__qualname__ == 'Path.write_text' (length 15)."
    - "pathlib.Path.read_bytes.__qualname__ == 'Path.read_bytes' (length 15)."
    - "pathlib.Path.write_bytes.__qualname__ == 'Path.write_bytes' (length 16)."
    - "pathlib.Path.open.__qualname__ == 'Path.open' (length 9)."
    - "pathlib.Path.mkdir.__qualname__ == 'Path.mkdir' (length 10)."
    - "pathlib.Path.rmdir.__qualname__ == 'Path.rmdir' (length 10)."
    - "pathlib.Path.unlink.__qualname__ == 'Path.unlink' (length 11)."
    - "pathlib.Path.touch.__qualname__ == 'Path.touch' (length 10)."
    - "pathlib.Path.rename.__qualname__ == 'Path.rename' (length 11)."
    - "pathlib.Path.replace.__qualname__ == 'Path.replace' (length 12)."
    - "All methods' __module__ == 'pathlib' since Path is a pure Python class."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path I/O method __qualname__ equality and lengths
# read_text: 'Path.read_text' (14), write_text: 'Path.write_text' (15),
# read_bytes: 'Path.read_bytes' (15), write_bytes: 'Path.write_bytes' (16),
# open: 'Path.open' (9).
# ---------------------------------------------------------------------------

table pathlib_extra139.path_io_method_qualnames:
  description: "pathlib.Path I/O method __qualname__ string equality and lengths: read_text=14, write_text=15, read_bytes=15, write_bytes=16, open=9"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathlibio139

  columns: [id, function, args, expected]
  rows:
    - [rt_qn_eq,   Path.read_text.__qualname__.__eq__,    ["Path.read_text"],   true]
    - [rt_qn_len,  Path.read_text.__qualname__.__len__,   [],                   14]
    - [wt_qn_eq,   Path.write_text.__qualname__.__eq__,   ["Path.write_text"],  true]
    - [wt_qn_len,  Path.write_text.__qualname__.__len__,  [],                   15]
    - [rb_qn_eq,   Path.read_bytes.__qualname__.__eq__,   ["Path.read_bytes"],  true]
    - [rb_qn_len,  Path.read_bytes.__qualname__.__len__,  [],                   15]
    - [wb_qn_eq,   Path.write_bytes.__qualname__.__eq__,  ["Path.write_bytes"], true]
    - [wb_qn_len,  Path.write_bytes.__qualname__.__len__, [],                   16]
    - [op_qn_eq,   Path.open.__qualname__.__eq__,         ["Path.open"],        true]
    - [op_qn_len,  Path.open.__qualname__.__len__,        [],                   9]
    - [rt_not_pp,  Path.read_text.__qualname__.__eq__,    ["PurePath.read_text"], false]

# ---------------------------------------------------------------------------
# pathlib.Path filesystem-mutation method __qualname__ equality and lengths
# mkdir: 'Path.mkdir' (10), rmdir: 'Path.rmdir' (10),
# unlink: 'Path.unlink' (11), touch: 'Path.touch' (10),
# rename: 'Path.rename' (11), replace: 'Path.replace' (12).
# ---------------------------------------------------------------------------

table pathlib_extra139.path_mutation_method_qualnames:
  description: "pathlib.Path filesystem-mutation method __qualname__ equality and lengths: mkdir=10, rmdir=10, unlink=11, touch=10, rename=11, replace=12"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathlibio139

  columns: [id, function, args, expected]
  rows:
    - [mkdir_qn_eq,   Path.mkdir.__qualname__.__eq__,    ["Path.mkdir"],   true]
    - [mkdir_qn_len,  Path.mkdir.__qualname__.__len__,   [],               10]
    - [rmdir_qn_eq,   Path.rmdir.__qualname__.__eq__,    ["Path.rmdir"],   true]
    - [rmdir_qn_len,  Path.rmdir.__qualname__.__len__,   [],               10]
    - [unlink_qn_eq,  Path.unlink.__qualname__.__eq__,   ["Path.unlink"],  true]
    - [unlink_qn_len, Path.unlink.__qualname__.__len__,  [],               11]
    - [touch_qn_eq,   Path.touch.__qualname__.__eq__,    ["Path.touch"],   true]
    - [touch_qn_len,  Path.touch.__qualname__.__len__,   [],               10]
    - [rename_qn_eq,  Path.rename.__qualname__.__eq__,   ["Path.rename"],  true]
    - [rename_qn_len, Path.rename.__qualname__.__len__,  [],               11]
    - [replace_qn_eq, Path.replace.__qualname__.__eq__,  ["Path.replace"], true]
    - [replace_qn_len, Path.replace.__qualname__.__len__, [],              12]

# ---------------------------------------------------------------------------
# pathlib.Path method __class__.__name__ == 'function'
# All of these methods are pure Python functions on a pure Python class,
# not C descriptors. __class__.__name__ == 'function' for all.
# Also __module__ == 'pathlib' for all.
# ---------------------------------------------------------------------------

table pathlib_extra139.path_io_method_class_and_module:
  description: "pathlib.Path I/O methods __class__.__name__ == 'function' and __module__ == 'pathlib' for read_text, write_text, read_bytes, write_bytes, open"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathlibio139

  columns: [id, function, args, expected]
  rows:
    - [rt_cls_eq,  Path.read_text.__class__.__name__.__eq__,   ["function"], true]
    - [wt_cls_eq,  Path.write_text.__class__.__name__.__eq__,  ["function"], true]
    - [rb_cls_eq,  Path.read_bytes.__class__.__name__.__eq__,  ["function"], true]
    - [wb_cls_eq,  Path.write_bytes.__class__.__name__.__eq__, ["function"], true]
    - [op_cls_eq,  Path.open.__class__.__name__.__eq__,        ["function"], true]
    - [rt_mod_eq,  Path.read_text.__module__.__eq__,           ["pathlib"],  true]
    - [op_mod_eq,  Path.open.__module__.__eq__,                ["pathlib"],  true]
    - [rt_not_md,  Path.read_text.__class__.__name__.__eq__,   ["method_descriptor"], false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra139.Path.read_text_qualname_eq:
  description: "pathlib.Path.read_text.__qualname__ == 'Path.read_text' (length 14; defined directly on Path, not on PurePath)"
  category: method_identity
  kind: python_call_eq
  function: Path.read_text.__qualname__.__eq__
  args: ["Path.read_text"]
  expected: true

invariant pathlib_extra139.Path.write_bytes_qualname_len_16:
  description: "pathlib.Path.write_bytes.__qualname__.__len__() == 16 ('Path.write_bytes' is 16 chars: 'Path' (4) + '.' (1) + 'write_bytes' (11))"
  category: method_identity
  kind: python_call_eq
  function: Path.write_bytes.__qualname__.__len__
  args: []
  expected: 16

invariant pathlib_extra139.Path.open_qualname_len_9:
  description: "pathlib.Path.open.__qualname__.__len__() == 9 ('Path.open' is 9 chars: 'Path' (4) + '.' (1) + 'open' (4))"
  category: method_identity
  kind: python_call_eq
  function: Path.open.__qualname__.__len__
  args: []
  expected: 9

invariant pathlib_extra139.Path.read_text_is_function:
  description: "pathlib.Path.read_text.__class__.__name__ == 'function' (Path is a pure Python class, so its methods are plain Python functions, not C method_descriptors)"
  category: method_identity
  kind: python_call_eq
  function: Path.read_text.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pathlib_extra139.Path.replace_qualname_len_12:
  description: "pathlib.Path.replace.__qualname__.__len__() == 12 ('Path.replace' is 12 chars: 'Path' (4) + '.' (1) + 'replace' (7))"
  category: method_identity
  kind: python_call_eq
  function: Path.replace.__qualname__.__len__
  args: []
  expected: 12
