spec: struct_extra198
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "struct.__spec__.name == 'struct' — the ModuleSpec name matches the module name."
    - "struct.__spec__.has_location == True — the visible struct module is Lib/struct.py, a Python shim with a known file location."
    - "struct.__spec__.parent == '' — struct is a top-level module; parent is the empty string."
    - "struct.__spec__.__class__.__name__ == 'ModuleSpec' — the spec object is an importlib.machinery.ModuleSpec instance."
    - "struct.__spec__.origin.__class__.__name__ == 'str' — the origin attribute (path to struct.py) is a plain str."
    - "Although the real work is done by _struct (a C extension), import struct loads Lib/struct.py first; that shim's __spec__ has has_location=True and loader=SourceFileLoader."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.__spec__ deeper attributes — name, has_location, parent
# ---------------------------------------------------------------------------

table struct_extra198.spec_name_has_location_parent:
  description: "struct __spec__ name, has_location, and parent attribute checks"
  kind: python_call_eq
  category: identity
  id_prefix: structspec198nhp

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,              __spec__.name.__eq__,                          ["struct"], true, "struct.__spec__.name == 'struct'"]
    - [spec_name_is_str,          __spec__.name.__class__.__name__.__eq__,       ["str"],    true, "struct.__spec__.name is a str object"]
    - [spec_has_location_true,    __spec__.has_location.__eq__,                  [true],     true, "struct.__spec__.has_location == True — struct.py (the Python shim) has a known file location"]
    - [spec_has_location_is_bool, __spec__.has_location.__class__.__name__.__eq__, ["bool"], true, "struct.__spec__.has_location is a bool object"]
    - [spec_parent_empty,         __spec__.parent.__eq__,                        [""],       true, "struct.__spec__.parent == '' — struct is a top-level module"]
    - [spec_parent_is_str,        __spec__.parent.__class__.__name__.__eq__,     ["str"],    true, "struct.__spec__.parent is a str object"]

# ---------------------------------------------------------------------------
# struct.__spec__ deeper attributes — __class__.__name__ and origin type
# ---------------------------------------------------------------------------

table struct_extra198.spec_class_origin_type:
  description: "struct __spec__ class name and origin type attribute checks"
  kind: python_call_eq
  category: identity
  id_prefix: structspec198cot

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_modulespec,    __spec__.__class__.__name__.__eq__,        ["ModuleSpec"], true, "struct.__spec__.__class__.__name__ == 'ModuleSpec'"]
    - [spec_origin_class_str,    __spec__.origin.__class__.__name__.__eq__, ["str"],        true, "struct.__spec__.origin.__class__.__name__ == 'str' — origin is the path to struct.py"]
    - [spec_name_matches_module, __spec__.name.__eq__,                      ["struct"],     true, "struct.__spec__.name equals the module name 'struct'"]
    - [spec_parent_not_none,     __spec__.parent.__class__.__name__.__eq__, ["str"],        true, "struct.__spec__.parent is a str (not None)"]

# ---------------------------------------------------------------------------
# struct.__spec__ deeper attributes — loader and class name type
# ---------------------------------------------------------------------------

table struct_extra198.spec_loader_class_details:
  description: "struct __spec__ loader class name and related attribute checks"
  kind: python_call_eq
  category: identity
  id_prefix: structspec198lcd

  columns: [id, function, args, expected, description]
  rows:
    - [spec_loader_class_eq,       __spec__.loader.__class__.__name__.__eq__,          ["SourceFileLoader"],          true, "struct.__spec__.loader.__class__.__name__ == 'SourceFileLoader' — struct.py shim uses SourceFileLoader"]
    - [spec_loader_module_eq,      __spec__.loader.__class__.__module__.__eq__,         ["_frozen_importlib_external"], true, "struct.__spec__.loader lives in _frozen_importlib_external"]
    - [spec_has_location_is_bool2, __spec__.has_location.__class__.__name__.__eq__,    ["bool"],                       true, "struct.__spec__.has_location type is bool (re-confirmed via loader table)"]
    - [spec_class_name_is_str,     __spec__.__class__.__name__.__class__.__name__.__eq__, ["str"],                     true, "struct.__spec__.__class__.__name__ is itself a str"]

# ---------------------------------------------------------------------------
# Standalone invariants (8 total)
# ---------------------------------------------------------------------------

invariant struct_extra198.spec_name_eq:
  description: "struct.__spec__.name == 'struct'"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["struct"]
  expected: true

invariant struct_extra198.spec_has_location_true:
  description: "struct.__spec__.has_location == True — the Python shim Lib/struct.py has a known disk location"
  category: identity
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [true]
  expected: true

invariant struct_extra198.spec_parent_empty:
  description: "struct.__spec__.parent == '' — struct is a top-level module, not a submodule"
  category: identity
  kind: python_call_eq
  function: __spec__.parent.__eq__
  args: [""]
  expected: true

invariant struct_extra198.spec_class_name_modulespec:
  description: "struct.__spec__.__class__.__name__ == 'ModuleSpec'"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant struct_extra198.spec_origin_class_name_str:
  description: "struct.__spec__.origin.__class__.__name__ == 'str' — origin is the path string to struct.py"
  category: identity
  kind: python_call_eq
  function: __spec__.origin.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant struct_extra198.spec_name_is_str:
  description: "struct.__spec__.name.__class__.__name__ == 'str'"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant struct_extra198.spec_parent_is_str:
  description: "struct.__spec__.parent.__class__.__name__ == 'str'"
  category: identity
  kind: python_call_eq
  function: __spec__.parent.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant struct_extra198.spec_loader_class_name_eq:
  description: "struct.__spec__.loader.__class__.__name__ == 'SourceFileLoader' — the Python shim uses SourceFileLoader, not the C extension's loader"
  category: identity
  kind: python_call_eq
  function: __spec__.loader.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true
