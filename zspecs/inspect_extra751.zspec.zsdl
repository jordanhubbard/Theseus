spec: inspect_extra751
version: ">=3.9"
backend: python_module(inspect)
docs: "Behavioral specs for inspect module stack and traceback function identity checks"
provenance:
  derived_from:
    - "Python 3.9+ standard library inspect module"
  not_derived_from:
    - "any third-party inspect extension"
  notes:
    - "Covers __qualname__ and __module__ identity for inspect stack/traceback functions"
    - "All checks verify that functions belong to the inspect module namespace"
  created_at: "2026-04-12"
error_model: python_exceptions

table inspect_extra751.qualnames:
  description: "Verify __qualname__ and __module__ for inspect stack and traceback functions"
  kind: python_call_eq
  category: identity
  id_prefix: in751xx
  columns: [id, function, args, expected]
  rows:
    - [in751xx001, inspect.stack.__qualname__.__eq__, ["stack"], true]
    - [in751xx002, inspect.stack.__module__.__eq__, ["inspect"], true]
    - [in751xx003, inspect.currentframe.__qualname__.__eq__, ["currentframe"], true]
    - [in751xx004, inspect.getframe.__qualname__.__eq__, ["getframe"], true]
    - [in751xx005, inspect.trace.__qualname__.__eq__, ["trace"], true]
    - [in751xx006, inspect.getouterframes.__qualname__.__eq__, ["getouterframes"], true]
    - [in751xx007, inspect.getinnerframes.__qualname__.__eq__, ["getinnerframes"], true]
    - [in751xx008, inspect.getlineno.__qualname__.__eq__, ["getlineno"], true]
    - [in751xx009, inspect.getfile.__qualname__.__eq__, ["getfile"], true]
    - [in751xx010, inspect.getmodule.__qualname__.__eq__, ["getmodule"], true]
    - [in751xx011, inspect.signature.__qualname__.__eq__, ["signature"], true]
    - [in751xx012, inspect.signature.__module__.__eq__, ["inspect"], true]
