spec: inspect_extra304
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "inspect.getsource(len) raises TypeError — len is a builtin_function_or_method implemented in C with no Python source; Python raises TypeError: module, class, method, function, traceback, frame, or code object was expected, got builtin_function_or_method."
    - "inspect.getsource(42) raises TypeError — 42 is an int, not a module/class/function/etc."
    - "inspect.signature(42) raises TypeError — 42 is not a callable object."
    - "inspect.getfile(int) raises TypeError — int is a built-in class with no associated source file."
    - "inspect.getmodule(int).__name__ == 'builtins' — int is defined in the builtins module."
    - "inspect.isbuiltin(len) == True; isbuiltin(open) == True; isbuiltin(print) == True."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# getsource error cases
#
# inspect.getsource() requires a module, class, method, function, traceback,
# frame, or code object. Built-in functions and plain integers raise TypeError.
#
# Verified:
#   getsource(len) -> TypeError: module, class, method, function, traceback,
#                    frame, or code object was expected, got builtin_function_or_method
#   getsource(42)  -> TypeError: module, class, method, function, traceback,
#                    frame, or code object was expected, got int
# ---------------------------------------------------------------------------

invariant inspect_extra304.getsource_builtin_TypeError:
  description: "inspect.getsource(len) raises TypeError — len is a C builtin with no Python source"
  category: errors
  kind: python_call_raises
  function: getsource
  args: [len]
  expected: TypeError

invariant inspect_extra304.getsource_int_TypeError:
  description: "inspect.getsource(42) raises TypeError — 42 is an int, not a valid source object"
  category: errors
  kind: python_call_raises
  function: getsource
  args: [42]
  expected: TypeError

# ---------------------------------------------------------------------------
# signature error case
#
# inspect.signature() requires a callable. Passing a plain integer raises
# TypeError immediately.
#
# Verified: signature(42) -> TypeError: 42 is not a callable object
# ---------------------------------------------------------------------------

invariant inspect_extra304.signature_non_callable_TypeError:
  description: "inspect.signature(42) raises TypeError — 42 is not a callable object"
  category: errors
  kind: python_call_raises
  function: signature
  args: [42]
  expected: TypeError

# ---------------------------------------------------------------------------
# getfile error case
#
# inspect.getfile() cannot locate a file for built-in types because they
# are implemented in C with no associated Python source file.
#
# Verified: getfile(int) -> TypeError: <class 'int'> is a built-in class
# ---------------------------------------------------------------------------

invariant inspect_extra304.getfile_builtin_type_TypeError:
  description: "inspect.getfile(int) raises TypeError — int is a built-in class with no source file"
  category: errors
  kind: python_call_raises
  function: getfile
  args: [int]
  expected: TypeError

# ---------------------------------------------------------------------------
# getmodule — int lives in builtins
#
# inspect.getmodule(int) returns the builtins module.
# Verified: getmodule(int).__name__ == 'builtins'
# ---------------------------------------------------------------------------

invariant inspect_extra304.getmodule_int_builtins:
  description: "inspect.getmodule(int).__name__ == 'builtins' — int is defined in the builtins module"
  category: identity
  kind: python_call_eq
  function: getmodule
  args: [int]
  method: __name__
  expected: "builtins"

# ---------------------------------------------------------------------------
# isbuiltin — len, open, print are all C-level built-in functions
#
# inspect.isbuiltin() returns True for built-in functions (C-level
# builtin_function_or_method objects).
# Verified: isbuiltin(len) == True, isbuiltin(open) == True,
#           isbuiltin(print) == True.
# ---------------------------------------------------------------------------

invariant inspect_extra304.isbuiltin_len:
  description: "inspect.isbuiltin(len) == True — len is a C-level built-in function"
  category: isbuiltin
  kind: python_call_eq
  function: isbuiltin
  args: [len]
  expected: true

invariant inspect_extra304.isbuiltin_open:
  description: "inspect.isbuiltin(open) == True — open is a C-level built-in function"
  category: isbuiltin
  kind: python_call_eq
  function: isbuiltin
  args: [open]
  expected: true

invariant inspect_extra304.isbuiltin_print:
  description: "inspect.isbuiltin(print) == True — print is a C-level built-in function"
  category: isbuiltin
  kind: python_call_eq
  function: isbuiltin
  args: [print]
  expected: true
