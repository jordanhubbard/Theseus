spec: abc_extra1771
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Wave 565, suffix _extra1771. Theme: async protocol — which stdlib types define __aenter__, __aexit__, __aiter__, __anext__, __await__ in their own __dict__."
    - "abc is a meta-programming library; none of its types define any async protocol methods."
    - "abc.ABCMeta does not define __aenter__, __aexit__, __await__, __aiter__, or __anext__ in its __dict__."
    - "abc.ABC does not define any async protocol methods in its __dict__."
    - "abc.abstractmethod does not define any async protocol methods in its __dict__."
    - "abc.ABCMeta.__dict__ does not contain '__abstractmethods__' — ABCMeta is a metaclass, not a class with abstract methods."
    - "abc.abstractmethod.__dict__.__contains__('__isabstractmethod__') == True — abstractmethod defines __isabstractmethod__ as a property in its class dict."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: async protocol methods absent from abc types
#
# abc.ABCMeta, abc.ABC, and abc.abstractmethod define no async protocol
# methods (__aenter__, __aexit__, __await__, __aiter__, __anext__) in their
# own __dict__.
# ---------------------------------------------------------------------------

table abc_extra1771.async_protocol_absent:
  kind: python_call_eq
  category: async_protocol
  id_prefix: ab1771

  columns: [id, function, args, expected]
  rows:
    - ["ab1771001", abc.ABCMeta.__dict__.__contains__,      ["__aenter__"], false]
    - ["ab1771002", abc.ABCMeta.__dict__.__contains__,      ["__aexit__"],  false]
    - ["ab1771003", abc.ABCMeta.__dict__.__contains__,      ["__await__"],  false]
    - ["ab1771004", abc.ABCMeta.__dict__.__contains__,      ["__aiter__"],  false]
    - ["ab1771005", abc.ABCMeta.__dict__.__contains__,      ["__anext__"],  false]
    - ["ab1771006", abc.ABC.__dict__.__contains__,           ["__aenter__"], false]
    - ["ab1771007", abc.ABC.__dict__.__contains__,           ["__aexit__"],  false]
    - ["ab1771008", abc.ABC.__dict__.__contains__,           ["__await__"],  false]
    - ["ab1771009", abc.ABC.__dict__.__contains__,           ["__aiter__"],  false]
    - ["ab1771010", abc.ABC.__dict__.__contains__,           ["__anext__"],  false]
    - ["ab1771011", abc.abstractmethod.__dict__.__contains__, ["__aenter__"], false]
    - ["ab1771012", abc.abstractmethod.__dict__.__contains__, ["__aexit__"],  false]
    - ["ab1771013", abc.abstractmethod.__dict__.__contains__, ["__await__"],  false]

# ---------------------------------------------------------------------------
# Table 2: complementary abc identity and protocol checks
#
# abc.abstractmethod defines __isabstractmethod__ in its own __dict__.
# abc.ABCMeta defines __instancecheck__ and __subclasscheck__ (metaclass hooks).
# abc.ABCMeta does not define __abstractmethods__ in its __dict__.
# ---------------------------------------------------------------------------

table abc_extra1771.abc_identity_checks:
  kind: python_call_eq
  category: identity
  id_prefix: ab1771

  columns: [id, function, args, expected]
  rows:
    - ["ab1771014", abc.abstractmethod.__dict__.__contains__,   ["__isabstractmethod__"],  true]
    - ["ab1771015", abc.ABCMeta.__dict__.__contains__,          ["__instancecheck__"],     true]
    - ["ab1771016", abc.ABCMeta.__dict__.__contains__,          ["__subclasscheck__"],     true]
    - ["ab1771017", abc.ABCMeta.__dict__.__contains__,          ["__abstractmethods__"],   false]
    - ["ab1771018", abc.abstractmethod.__dict__.__contains__,   ["__aiter__"],             false]
    - ["ab1771019", abc.abstractmethod.__dict__.__contains__,   ["__anext__"],             false]
    - ["ab1771020", abc.ABCMeta.__name__.__eq__,                ["ABCMeta"],               true]
    - ["ab1771021", abc.ABC.__name__.__eq__,                    ["ABC"],                   true]
    - ["ab1771022", abc.abstractmethod.__name__.__eq__,         ["abstractmethod"],        true]
    - ["ab1771023", abc.ABC.__module__.__eq__,                  ["abc"],                   true]
