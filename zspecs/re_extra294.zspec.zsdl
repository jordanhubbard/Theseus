spec: re_extra294
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "re.IGNORECASE.__class__.__name__ == 'RegexFlag' in Python 3.11+ (previously 'int' in older versions)."
    - "re.IGNORECASE == 2, re.MULTILINE == 8, re.DOTALL == 16, re.VERBOSE == 64 — these integer values are stable across Python 3.x."
    - "re.compile('').pattern == '' — the pattern attribute of a compiled empty pattern is an empty string."
    - "re.fullmatch(r'\\d+', 'abc') returns None — NoneType when there is no match."
    - "re.fullmatch(r'\\d+', '123').__class__.__name__ == 'Match' — a successful match returns a re.Match object."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.RegexFlag class names for core flags
#
# In Python 3.11+, re flags are instances of re.RegexFlag (an IntFlag enum).
# Their __class__.__name__ is 'RegexFlag', not 'int'.
# Integer values: IGNORECASE=2, MULTILINE=8, DOTALL=16, VERBOSE=64.
# ---------------------------------------------------------------------------

table re_extra294.flag_class_names:
  description: "re flag __class__.__name__ is 'RegexFlag' for all core flags"
  kind: python_call_eq
  category: flags
  id_prefix: re294a

  columns: [id, function, args, expected, description]
  rows:
    - [re294a001, re.IGNORECASE.__class__.__name__.__eq__, ["RegexFlag"], true, "re.IGNORECASE.__class__.__name__ == 'RegexFlag'"]
    - [re294a002, re.MULTILINE.__class__.__name__.__eq__,  ["RegexFlag"], true, "re.MULTILINE.__class__.__name__ == 'RegexFlag'"]
    - [re294a003, re.DOTALL.__class__.__name__.__eq__,     ["RegexFlag"], true, "re.DOTALL.__class__.__name__ == 'RegexFlag'"]
    - [re294a004, re.VERBOSE.__class__.__name__.__eq__,    ["RegexFlag"], true, "re.VERBOSE.__class__.__name__ == 'RegexFlag'"]

# ---------------------------------------------------------------------------
# re flag integer equality
#
# IGNORECASE=2, MULTILINE=8, DOTALL=16, VERBOSE=64 are the canonical values
# defined by POSIX and used in PCRE-compatible regex engines.
# ---------------------------------------------------------------------------

table re_extra294.flag_integer_values:
  description: "re flag integer equality: IGNORECASE=2, MULTILINE=8, DOTALL=16, VERBOSE=64"
  kind: python_call_eq
  category: flags
  id_prefix: re294b

  columns: [id, function, args, expected, description]
  rows:
    - [re294b001, re.IGNORECASE.__eq__, [2],  true, "re.IGNORECASE == 2"]
    - [re294b002, re.MULTILINE.__eq__,  [8],  true, "re.MULTILINE == 8"]
    - [re294b003, re.DOTALL.__eq__,     [16], true, "re.DOTALL == 16"]
    - [re294b004, re.VERBOSE.__eq__,    [64], true, "re.VERBOSE == 64"]

# ---------------------------------------------------------------------------
# re.compile('').pattern — empty pattern is preserved exactly
#
# Compiling an empty pattern produces a Pattern object whose .pattern
# attribute is the empty string ''.
# ---------------------------------------------------------------------------

invariant re_extra294.compile_empty_pattern_attr:
  description: "re.compile('').pattern == '' — the pattern attribute of a compiled empty regex is an empty string"
  category: compile
  kind: python_call_eq
  function: re.compile
  args: [""]
  method: pattern
  expected: ""

# ---------------------------------------------------------------------------
# re.fullmatch non-match returns None
#
# When re.fullmatch() finds no match, it returns None (not a Match object).
# The result's __class__.__name__ is 'NoneType'.
# ---------------------------------------------------------------------------

invariant re_extra294.fullmatch_no_match_is_none_type:
  description: "re.fullmatch(r'\\d+', 'abc') returns None — type is NoneType when there is no match"
  category: match
  kind: python_call_eq
  function: re.fullmatch
  args: ["\\d+", "abc"]
  method: __class__
  method_chain: __name__
  expected: "NoneType"

# ---------------------------------------------------------------------------
# re.fullmatch successful match returns a Match object
#
# When re.fullmatch() matches the entire string, it returns a re.Match object.
# The result's __class__.__name__ is 'Match'.
# ---------------------------------------------------------------------------

invariant re_extra294.fullmatch_match_class_name:
  description: "re.fullmatch(r'\\d+', '123').__class__.__name__ == 'Match' — successful fullmatch returns a Match object"
  category: match
  kind: python_call_eq
  function: re.fullmatch
  args: ["\\d+", "123"]
  method: __class__
  method_chain: __name__
  expected: "Match"

# ---------------------------------------------------------------------------
# Standalone invariants — flag identity
# ---------------------------------------------------------------------------

invariant re_extra294.ignorecase_is_regexflag:
  description: "re.IGNORECASE.__class__.__name__ == 'RegexFlag' — IGNORECASE is a RegexFlag enum member in Python 3.11+"
  category: flags
  kind: python_call_eq
  function: re.IGNORECASE.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra294.ignorecase_eq_2:
  description: "re.IGNORECASE == 2 — the integer value of the IGNORECASE flag is 2"
  category: flags
  kind: python_call_eq
  function: re.IGNORECASE.__eq__
  args: [2]
  expected: true

invariant re_extra294.multiline_eq_8:
  description: "re.MULTILINE == 8 — the integer value of the MULTILINE flag is 8"
  category: flags
  kind: python_call_eq
  function: re.MULTILINE.__eq__
  args: [8]
  expected: true

invariant re_extra294.dotall_eq_16:
  description: "re.DOTALL == 16 — the integer value of the DOTALL flag is 16"
  category: flags
  kind: python_call_eq
  function: re.DOTALL.__eq__
  args: [16]
  expected: true

invariant re_extra294.verbose_eq_64:
  description: "re.VERBOSE == 64 — the integer value of the VERBOSE flag is 64"
  category: flags
  kind: python_call_eq
  function: re.VERBOSE.__eq__
  args: [64]
  expected: true
