spec: re_extra2116
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/re.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave _extra2116: __or__/__ror__/__ior__, __and__/__rand__/__iand__, __xor__/__rxor__/__ixor__ dict-presence checks."
    - "re.RegexFlag is an IntFlag enum and defines __or__, __ror__, __and__, __rand__, __xor__, __rxor__ in its own __dict__ (True)."
    - "re.RegexFlag does NOT define the in-place variants __ior__, __iand__, __ixor__ in its own __dict__ (False)."
    - "re.Pattern, re.Match, and re.error do not define any of these operators in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __or__ / __ror__ / __ior__ — dict-merge / set-union dict-presence
# re.RegexFlag (IntFlag) defines __or__ and __ror__ but NOT __ior__
# re.Pattern, re.Match, re.error do not define any of these
# ---------------------------------------------------------------------------

table re_extra2116.or_protocol:
  description: "re types __or__/__ror__/__ior__ dict-presence"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2116

  columns: [id, function, args, expected]
  rows:
    - ["re2116001", "re.RegexFlag.__dict__.__contains__", ["__or__"],  true]
    - ["re2116002", "re.RegexFlag.__dict__.__contains__", ["__ror__"], true]
    - ["re2116003", "re.RegexFlag.__dict__.__contains__", ["__ior__"], false]
    - ["re2116004", "re.Pattern.__dict__.__contains__",   ["__or__"],  false]
    - ["re2116005", "re.Pattern.__dict__.__contains__",   ["__ror__"], false]
    - ["re2116006", "re.Pattern.__dict__.__contains__",   ["__ior__"], false]
    - ["re2116007", "re.Match.__dict__.__contains__",     ["__or__"],  false]
    - ["re2116008", "re.Match.__dict__.__contains__",     ["__ror__"], false]
    - ["re2116009", "re.Match.__dict__.__contains__",     ["__ior__"], false]
    - ["re2116010", "re.error.__dict__.__contains__",     ["__or__"],  false]
    - ["re2116011", "re.error.__dict__.__contains__",     ["__ror__"], false]
    - ["re2116012", "re.error.__dict__.__contains__",     ["__ior__"], false]

# ---------------------------------------------------------------------------
# __and__ / __rand__ / __iand__ — set-intersection dict-presence
# re.RegexFlag (IntFlag) defines __and__ and __rand__ but NOT __iand__
# re.Pattern, re.Match, re.error do not define any of these
# ---------------------------------------------------------------------------

table re_extra2116.and_protocol:
  description: "re types __and__/__rand__/__iand__ dict-presence"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2116

  columns: [id, function, args, expected]
  rows:
    - ["re2116013", "re.RegexFlag.__dict__.__contains__", ["__and__"],  true]
    - ["re2116014", "re.RegexFlag.__dict__.__contains__", ["__rand__"], true]
    - ["re2116015", "re.RegexFlag.__dict__.__contains__", ["__iand__"], false]
    - ["re2116016", "re.Pattern.__dict__.__contains__",   ["__and__"],  false]
    - ["re2116017", "re.Pattern.__dict__.__contains__",   ["__rand__"], false]
    - ["re2116018", "re.Pattern.__dict__.__contains__",   ["__iand__"], false]
    - ["re2116019", "re.Match.__dict__.__contains__",     ["__and__"],  false]
    - ["re2116020", "re.Match.__dict__.__contains__",     ["__rand__"], false]
    - ["re2116021", "re.Match.__dict__.__contains__",     ["__iand__"], false]
    - ["re2116022", "re.error.__dict__.__contains__",     ["__and__"],  false]
    - ["re2116023", "re.error.__dict__.__contains__",     ["__rand__"], false]
    - ["re2116024", "re.error.__dict__.__contains__",     ["__iand__"], false]

# ---------------------------------------------------------------------------
# __xor__ / __rxor__ / __ixor__ — set-symmetric-difference dict-presence
# re.RegexFlag (IntFlag) defines __xor__ and __rxor__ but NOT __ixor__
# re.Pattern, re.Match, re.error do not define any of these
# ---------------------------------------------------------------------------

table re_extra2116.xor_protocol:
  description: "re types __xor__/__rxor__/__ixor__ dict-presence"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2116

  columns: [id, function, args, expected]
  rows:
    - ["re2116025", "re.RegexFlag.__dict__.__contains__", ["__xor__"],  true]
    - ["re2116026", "re.RegexFlag.__dict__.__contains__", ["__rxor__"], true]
    - ["re2116027", "re.RegexFlag.__dict__.__contains__", ["__ixor__"], false]
    - ["re2116028", "re.Pattern.__dict__.__contains__",   ["__xor__"],  false]
    - ["re2116029", "re.Pattern.__dict__.__contains__",   ["__rxor__"], false]
    - ["re2116030", "re.Pattern.__dict__.__contains__",   ["__ixor__"], false]
    - ["re2116031", "re.Match.__dict__.__contains__",     ["__xor__"],  false]
    - ["re2116032", "re.Match.__dict__.__contains__",     ["__rxor__"], false]
    - ["re2116033", "re.Match.__dict__.__contains__",     ["__ixor__"], false]
    - ["re2116034", "re.error.__dict__.__contains__",     ["__xor__"],  false]
