spec: inspect_extra1306
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "Wave 534 (_extra1306): focuses on exception-raising behavior for bad argument types and counts."
    - "inspect.signature(42) raises TypeError because 42 is not callable."
    - "inspect.getsource(42) raises TypeError because int is not a supported object type."
    - "inspect.getfile(42) raises TypeError because int is not a supported object type."
    - "inspect.Parameter('', 99) raises ValueError because 99 is not a valid Parameter.kind."
    - "inspect.Parameter(123, POSITIONAL_ONLY) raises TypeError because name must be a str."
    - "inspect.Signature([42]) raises AttributeError because list elements must be Parameter objects."
    - "inspect.getfullargspec(42) raises TypeError for unsupported callable."
    - "inspect.getcallargs(42) raises TypeError for unsupported callable."
    - "inspect.getmembers(42, 99) raises TypeError because predicate 99 is not callable."
    - "All exceptions verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table inspect_extra1306.wrong_type_arg_type_errors:
  description: "inspect functions raise TypeError when passed an integer instead of a callable or inspectable object"
  kind: python_call_raises
  category: type_errors
  id_prefix: in1306wt
  columns: [id, function, args, exception]
  rows:
    - [in1306wt001, inspect.signature,      [42], "TypeError"]
    - [in1306wt002, inspect.getsource,      [42], "TypeError"]
    - [in1306wt003, inspect.getfile,        [42], "TypeError"]
    - [in1306wt004, inspect.getfullargspec, [42], "TypeError"]
    - [in1306wt005, inspect.getcallargs,    [42], "TypeError"]
    - [in1306wt006, inspect.getmembers,     [42, 99], "TypeError"]

table inspect_extra1306.missing_args_type_errors:
  description: "inspect functions raise TypeError when called with too few arguments"
  kind: python_call_raises
  category: type_errors
  id_prefix: in1306mi
  columns: [id, function, args, exception]
  rows:
    - [in1306mi001, inspect.signature,      [], "TypeError"]
    - [in1306mi002, inspect.getsource,      [], "TypeError"]
    - [in1306mi003, inspect.getfile,        [], "TypeError"]
    - [in1306mi004, inspect.formatannotation, [], "TypeError"]
    - [in1306mi005, inspect.ismodule,       [], "TypeError"]
    - [in1306mi006, inspect.getdoc,         [], "TypeError"]

table inspect_extra1306.parameter_constructor_errors:
  description: "inspect.Parameter and inspect.Signature raise on bad constructor arguments"
  kind: python_call_raises
  category: constructor_errors
  id_prefix: in1306pc
  columns: [id, function, args, exception]
  rows:
    - [in1306pc001, inspect.Parameter, ["", 99],  "ValueError"]
    - [in1306pc002, inspect.Parameter, [123, 0],  "TypeError"]
    - [in1306pc003, inspect.Parameter, [null, 0], "TypeError"]
    - [in1306pc004, inspect.Signature, [[42]],    "AttributeError"]
    - [in1306pc005, inspect.Parameter, ["x", -1], "ValueError"]
    - [in1306pc006, inspect.Parameter, ["x", 999], "ValueError"]
