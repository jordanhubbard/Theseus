spec: struct_extra24
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra4.zspec.zsdl — covers __qualname__ equality for pack/unpack/pack_into/unpack_from/calcsize/iter_unpack; Struct.__qualname__=='Struct'; error.__qualname__=='error'."
    - "struct_extra20.zspec.zsdl — covers __qualname__.__len__() for pack/unpack/pack_into/unpack_from/calcsize/iter_unpack; __qualname__.__class__.__name__ for pack/unpack."
    - "struct_extra22.zspec.zsdl — covers __module__ equality for Struct/pack/unpack/calcsize/error; Struct/error __module__.__len__(); __module__.__class__.__name__ for Struct/pack/unpack/error."
    - "struct_extra23.zspec.zsdl — covers __module__ equality and __module__.__len__() for pack_into/unpack_from/iter_unpack; __qualname__.__class__.__name__ for calcsize/pack_into/unpack_from/iter_unpack."
  notes:
    - "This spec extends struct_extra23.zspec.zsdl."
    - "Prior specs covered: __qualname__ equality for all six module-level functions plus Struct and error; __qualname__.__len__() for all six functions; __module__ equality for all functions and classes; __module__.__len__() for Struct, error, pack_into, unpack_from, iter_unpack."
    - "This spec covers: __module__.__len__() for pack/unpack/calcsize (the three gaps after extra22 and extra23); __qualname__.__eq__ restated as a grouped table for pack/unpack/calcsize in the extra24 namespace; struct.error.__module__ equality restated as standalone (novel namespace)."
    - "struct.pack.__module__.__len__() == 7 — len('_struct') == 7. extra22 covers Struct and error; extra23 covers pack_into/unpack_from/iter_unpack. pack is the remaining gap. Verified."
    - "struct.unpack.__module__.__len__() == 7 — unpack is the second remaining gap. Verified."
    - "struct.calcsize.__module__.__len__() == 7 — calcsize is the third remaining gap. Verified."
    - "struct.error.__module__ == 'struct' — error is defined in the Python struct wrapper module, not the C extension _struct. Verified."
    - "struct.pack.__qualname__ == 'pack' — len 4. Verified."
    - "struct.unpack.__qualname__ == 'unpack' — len 6. Verified."
    - "struct.calcsize.__qualname__ == 'calcsize' — len 8. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __module__.__len__() for pack/unpack/calcsize
#
# struct_extra22 covers __module__.__len__() for Struct (7) and error (6).
# struct_extra23 covers __module__.__len__() for pack_into/unpack_from/iter_unpack (all 7).
# The three remaining module-level functions — pack, unpack, calcsize — have
# not had their __module__.__len__() checked in any prior spec.
# All three are C builtins in _struct so their module is '_struct' (len 7).
# Verified: pack=7, unpack=7, calcsize=7.
# ---------------------------------------------------------------------------

table struct_extra24.core_function_module_lengths:
  description: "__module__.__len__() == 7 for struct pack/unpack/calcsize — len('_struct') == 7; fills gap left by extra22 and extra23"
  kind: python_call_eq
  category: module_identity
  id_prefix: cfmlen24

  columns: [id, function, args, expected]
  rows:
    - [pack,     pack.__module__.__len__,     [], 7]
    - [unpack,   unpack.__module__.__len__,   [], 7]
    - [calcsize, calcsize.__module__.__len__, [], 7]

# ---------------------------------------------------------------------------
# Table: __qualname__ equality for pack/unpack/calcsize
#
# struct_extra4 covers __qualname__.__eq__ for all six functions. This table
# groups the three core functions together in the extra24 namespace, providing
# a co-located reference alongside the module length checks above.
# Verified: pack='pack', unpack='unpack', calcsize='calcsize'.
# ---------------------------------------------------------------------------

table struct_extra24.core_function_qualnames:
  description: "__qualname__ equality for struct pack/unpack/calcsize — co-located with module length checks in extra24 namespace"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: cfqn24

  columns: [id, function, args, expected]
  rows:
    - [pack,     pack.__qualname__.__eq__,     ["pack"],     true]
    - [unpack,   unpack.__qualname__.__eq__,   ["unpack"],   true]
    - [calcsize, calcsize.__qualname__.__eq__, ["calcsize"], true]

# ---------------------------------------------------------------------------
# Table: __qualname__ equality for pack_into/unpack_from/iter_unpack/error/Struct
#
# Complements the core_function_qualnames table above to cover all remaining
# module-level names in a single spec. struct_extra4 covers these individually;
# this table groups them in the extra24 namespace.
# Verified: pack_into='pack_into', unpack_from='unpack_from',
#   iter_unpack='iter_unpack', error='error', Struct='Struct'.
# ---------------------------------------------------------------------------

table struct_extra24.remaining_qualnames:
  description: "__qualname__ equality for struct pack_into/unpack_from/iter_unpack/error/Struct — grouped in extra24 namespace"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: rqn24

  columns: [id, function, args, expected]
  rows:
    - [pack_into,   pack_into.__qualname__.__eq__,   ["pack_into"],   true]
    - [unpack_from, unpack_from.__qualname__.__eq__, ["unpack_from"], true]
    - [iter_unpack, iter_unpack.__qualname__.__eq__, ["iter_unpack"], true]
    - [error,       error.__qualname__.__eq__,       ["error"],       true]
    - [Struct,      Struct.__qualname__.__eq__,      ["Struct"],      true]

# ---------------------------------------------------------------------------
# Standalone: struct.pack.__module__.__len__() == 7
#
# pack is the primary packing function in the struct module. extra22 documents
# pack.__module__ == '_struct' but does NOT cover pack.__module__.__len__().
# extra23 addresses pack_into/unpack_from/iter_unpack lengths but not pack.
# This standalone anchors the pack case explicitly.
# Verified: len('_struct') == 7.
# ---------------------------------------------------------------------------

invariant struct_extra24.pack.module_len:
  description: "struct.pack.__module__.__len__() == 7 — len('_struct') == 7; gap in extra22 (covered Struct/error) and extra23 (covered pack_into/unpack_from/iter_unpack)"
  category: module_identity
  kind: python_call_eq
  function: pack.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# Standalone: struct.error.__module__ == 'struct'
#
# struct.error is defined in the Python-level struct.py wrapper, not in the
# C extension _struct. Its __module__ is therefore 'struct' (no leading
# underscore), distinguishing it from the six module-level functions.
# extra22 covers this equality; this standalone restates it in the extra24
# namespace to keep all module-identity anchors co-located.
# Verified: struct.error.__module__ == 'struct'.
# ---------------------------------------------------------------------------

invariant struct_extra24.error.module:
  description: "struct.error.__module__ == 'struct' — error is defined in Python wrapper, not C extension _struct; restated in extra24 namespace"
  category: module_identity
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["struct"]
  expected: true
