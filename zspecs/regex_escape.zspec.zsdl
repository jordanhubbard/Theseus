spec: regex_escape
version: ">=4.0.0"
backend: node(regex-escape)
esm: true

docs: https://github.com/IonicaBizau/regex-escape#readme

provenance:
  derived_from:
    - "regex-escape README — https://github.com/IonicaBizau/regex-escape#readme"
    - "MDN — Escaping regex special characters"
    - "Test vectors verified with regex-escape via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "regex-escape source"
  notes:
    - "Escapes a string for safe use as a literal portion of a regular expression."
    - "Install: npm install regex-escape"
    - "v4 ESM only; default export IS the function. Special characters get a backslash prefix."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on string input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant regex_escape.default_export_is_function:
  description: "Default export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.constructor.name"}
  expected: "Function"

invariant regex_escape.default_name:
  description: "Default function name is 'RegexEscape'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.name"}
  expected: "RegexEscape"

invariant regex_escape.escapes_dot_and_star:
  description: "'a.b*c+' becomes 'a\\.b\\*c\\+'"
  category: escape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {call: ["a.b*c+"]}
  expected: "a\\.b\\*c\\+"

invariant regex_escape.plain_text_unchanged:
  description: "Alphanumeric input passes through unmodified"
  category: escape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {call: ["hello"]}
  expected: "hello"

invariant regex_escape.escapes_groups_and_alt:
  description: "Parens and pipe are escaped: '(a|b)' → '\\(a\\|b\\)'"
  category: escape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {call: ["(a|b)"]}
  expected: "\\(a\\|b\\)"

invariant regex_escape.escapes_brackets_and_dash:
  description: "'[a-z]' → '\\[a\\-z\\]'"
  category: escape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {call: ["[a-z]"]}
  expected: "\\[a\\-z\\]"

invariant regex_escape.empty_string_passthrough:
  description: "Empty string returns empty string"
  category: edge
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: default}
    - {call: [""]}
  expected: ""
