spec: theseus_mmap_cr
version: ">=3.8"
backend: python_cleanroom(theseus_mmap_cr)
blocks: mmap

docs: https://docs.python.org/3/library/mmap.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/mmap.html"
  not_derived_from:
    - "CPython source: Modules/mmapmodule.c"
  notes:
    - "Clean-room mmap module. Do NOT import mmap."

error_model: python_exceptions

invariant theseus_mmap_cr.mmap2_write_read:
  description: "mmap write and read round-trip"
  category: behavior
  kind: python_call_eq
  function: mmap2_write_read
  args: []
  expected: true

invariant theseus_mmap_cr.mmap2_find:
  description: "mmap.find() locates a substring"
  category: behavior
  kind: python_call_eq
  function: mmap2_find
  args: []
  expected: true

invariant theseus_mmap_cr.mmap2_seek_tell:
  description: "seek and tell work correctly"
  category: behavior
  kind: python_call_eq
  function: mmap2_seek_tell
  args: []
  expected: true
