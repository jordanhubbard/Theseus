spec: decimal_extra101
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal_extra100.zspec.zsdl."
    - "This spec covers: decimal.Decimal arithmetic operator __qualname__ string equality and __name__ equality for Decimal and Context."
    - "decimal.Decimal.__add__.__qualname__ = 'Decimal.__add__' (length 15)."
    - "decimal.Decimal.__mul__.__qualname__ = 'Decimal.__mul__' (length 15)."
    - "decimal.Decimal.__sub__.__qualname__ = 'Decimal.__sub__' (length 15)."
    - "decimal.Decimal.__truediv__.__qualname__ = 'Decimal.__truediv__' (length 19)."
    - "decimal.Decimal.__mod__.__qualname__ = 'Decimal.__mod__' (length 15)."
    - "decimal.Decimal.__neg__.__qualname__ = 'Decimal.__neg__' (length 15)."
    - "decimal.Decimal.__abs__.__qualname__ = 'Decimal.__abs__' (length 15)."
    - "type(decimal.Decimal.__add__).__name__ = 'wrapper_descriptor'."
    - "decimal.Decimal.__name__ == 'Decimal' (length 7)."
    - "decimal.Context.__name__ == 'Context' (length 7)."
    - "decimal.Decimal.__mro__.__len__() == 2 (Decimal, object)."
    - "decimal.Context.__mro__.__len__() == 2 (Context, object)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal arithmetic operator __qualname__ string equality
# Decimal arithmetic dunder methods are wrapper_descriptor objects (C extension).
# Each method's __qualname__ is 'Decimal.<dunder_name>'.
# __add__, __mul__, __sub__, __mod__, __neg__, __abs__ all have len 15.
# __truediv__ has len 19.
# ---------------------------------------------------------------------------

table decimal_extra101.Decimal_operator_qualnames:
  description: "decimal.Decimal operator __qualname__ values: __add__='Decimal.__add__', __mul__='Decimal.__mul__', __sub__='Decimal.__sub__', __truediv__='Decimal.__truediv__', __mod__='Decimal.__mod__'"
  kind: python_call_eq
  category: qualnames
  id_prefix: decqual101a

  columns: [id, function, args, expected, description]
  rows:
    - [dec_add_qn,      "Decimal.__add__.__qualname__.__eq__",      ["Decimal.__add__"],      true,  "decimal.Decimal.__add__.__qualname__ == 'Decimal.__add__'"]
    - [dec_mul_qn,      "Decimal.__mul__.__qualname__.__eq__",      ["Decimal.__mul__"],      true,  "decimal.Decimal.__mul__.__qualname__ == 'Decimal.__mul__'"]
    - [dec_sub_qn,      "Decimal.__sub__.__qualname__.__eq__",      ["Decimal.__sub__"],      true,  "decimal.Decimal.__sub__.__qualname__ == 'Decimal.__sub__'"]
    - [dec_truediv_qn,  "Decimal.__truediv__.__qualname__.__eq__",  ["Decimal.__truediv__"],  true,  "decimal.Decimal.__truediv__.__qualname__ == 'Decimal.__truediv__'"]
    - [dec_mod_qn,      "Decimal.__mod__.__qualname__.__eq__",      ["Decimal.__mod__"],      true,  "decimal.Decimal.__mod__.__qualname__ == 'Decimal.__mod__'"]
    - [dec_neg_qn,      "Decimal.__neg__.__qualname__.__eq__",      ["Decimal.__neg__"],      true,  "decimal.Decimal.__neg__.__qualname__ == 'Decimal.__neg__'"]
    - [dec_abs_qn,      "Decimal.__abs__.__qualname__.__eq__",      ["Decimal.__abs__"],      true,  "decimal.Decimal.__abs__.__qualname__ == 'Decimal.__abs__'"]
    - [dec_add_not_ctx, "Decimal.__add__.__qualname__.__eq__",      ["Context.__add__"],      false, "decimal.Decimal.__add__.__qualname__ != 'Context.__add__' (Decimal and Context have distinct operator qualnames)"]

# ---------------------------------------------------------------------------
# decimal.Decimal operator __qualname__ lengths
# __add__, __mul__, __sub__, __mod__, __neg__, __abs__ len=15.
# __truediv__ len=19.
# ---------------------------------------------------------------------------

table decimal_extra101.Decimal_operator_qualname_lengths:
  description: "decimal.Decimal operator __qualname__ lengths: __add__/__mul__/__sub__/__mod__/__neg__/__abs__=15, __truediv__=19"
  kind: python_call_eq
  category: qualnames
  id_prefix: decqual101b

  columns: [id, function, args, expected, description]
  rows:
    - [dec_add_qn_len,     "Decimal.__add__.__qualname__.__len__",     [], 15, "decimal.Decimal.__add__.__qualname__.__len__() == 15 ('Decimal.__add__' has 15 chars)"]
    - [dec_mul_qn_len,     "Decimal.__mul__.__qualname__.__len__",     [], 15, "decimal.Decimal.__mul__.__qualname__.__len__() == 15 ('Decimal.__mul__' has 15 chars)"]
    - [dec_sub_qn_len,     "Decimal.__sub__.__qualname__.__len__",     [], 15, "decimal.Decimal.__sub__.__qualname__.__len__() == 15 ('Decimal.__sub__' has 15 chars)"]
    - [dec_truediv_qn_len, "Decimal.__truediv__.__qualname__.__len__", [], 19, "decimal.Decimal.__truediv__.__qualname__.__len__() == 19 ('Decimal.__truediv__' has 19 chars)"]
    - [dec_mod_qn_len,     "Decimal.__mod__.__qualname__.__len__",     [], 15, "decimal.Decimal.__mod__.__qualname__.__len__() == 15 ('Decimal.__mod__' has 15 chars)"]
    - [dec_neg_qn_len,     "Decimal.__neg__.__qualname__.__len__",     [], 15, "decimal.Decimal.__neg__.__qualname__.__len__() == 15 ('Decimal.__neg__' has 15 chars)"]
    - [dec_abs_qn_len,     "Decimal.__abs__.__qualname__.__len__",     [], 15, "decimal.Decimal.__abs__.__qualname__.__len__() == 15 ('Decimal.__abs__' has 15 chars)"]

# ---------------------------------------------------------------------------
# decimal.Decimal and decimal.Context __name__ and __mro__ length
# Decimal.__name__ == 'Decimal' (len 7); Context.__name__ == 'Context' (len 7).
# Both have MRO length 2: (Decimal, object) and (Context, object).
# ---------------------------------------------------------------------------

table decimal_extra101.Decimal_Context_name_mro:
  description: "decimal.Decimal and decimal.Context __name__ equality and __mro__ length: Decimal.__name__='Decimal'(len 7), Context.__name__='Context'(len 7), both __mro__ len=2"
  kind: python_call_eq
  category: class_names
  id_prefix: decqual101c

  columns: [id, function, args, expected, description]
  rows:
    - [dec_name_eq,      Decimal.__name__.__eq__,      ["Decimal"], true,  "decimal.Decimal.__name__ == 'Decimal'"]
    - [dec_name_len,     Decimal.__name__.__len__,      [],          7,     "decimal.Decimal.__name__.__len__() == 7 ('Decimal' has 7 characters)"]
    - [ctx_name_eq,      Context.__name__.__eq__,       ["Context"], true,  "decimal.Context.__name__ == 'Context'"]
    - [ctx_name_len,     Context.__name__.__len__,       [],         7,     "decimal.Context.__name__.__len__() == 7 ('Context' has 7 characters)"]
    - [dec_mro_len,      "Decimal.__mro__.__len__",      [],         2,     "decimal.Decimal.__mro__.__len__() == 2 (Decimal, object)"]
    - [ctx_mro_len,      "Context.__mro__.__len__",      [],         2,     "decimal.Context.__mro__.__len__() == 2 (Context, object)"]
    - [dec_name_ne_ctx,  Decimal.__name__.__eq__,        ["Context"],false,  "decimal.Decimal.__name__ != 'Context' (Decimal and Context are distinct classes)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra101.Decimal.add_qualname:
  description: "decimal.Decimal.__add__.__qualname__ == 'Decimal.__add__' (C extension wrapper_descriptor; __qualname__ uses the bare class name 'Decimal', not 'decimal.Decimal')"
  category: qualnames
  kind: python_call_eq
  function: Decimal.__add__.__qualname__.__eq__
  args: ["Decimal.__add__"]
  expected: true

invariant decimal_extra101.Decimal.truediv_qualname_len:
  description: "decimal.Decimal.__truediv__.__qualname__.__len__() == 19 ('Decimal.__truediv__' is the longest operator __qualname__ here because '__truediv__' is 11 characters vs 7 for '__add__' etc.)"
  category: qualnames
  kind: python_call_eq
  function: Decimal.__truediv__.__qualname__.__len__
  args: []
  expected: 19

invariant decimal_extra101.Decimal.name_is_Decimal:
  description: "decimal.Decimal.__name__ == 'Decimal' (the bare class name without module prefix; Decimal is a C extension type whose __name__ is 'Decimal' and __module__ is 'decimal')"
  category: class_names
  kind: python_call_eq
  function: Decimal.__name__.__eq__
  args: ["Decimal"]
  expected: true

invariant decimal_extra101.Context.name_is_Context:
  description: "decimal.Context.__name__ == 'Context' (the bare class name for the decimal arithmetic context; same length as 'Decimal' — both are 7 characters)"
  category: class_names
  kind: python_call_eq
  function: Context.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra101.Decimal.mro_len_2:
  description: "decimal.Decimal.__mro__.__len__() == 2 (Decimal's MRO is (Decimal, object); it has no intermediate base classes, giving a minimal MRO of length 2)"
  category: class_names
  kind: python_call_eq
  function: Decimal.__mro__.__len__
  args: []
  expected: 2
