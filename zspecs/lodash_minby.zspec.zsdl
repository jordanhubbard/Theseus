spec: lodash_minby
version: ">=4.0.0"
backend: node(lodash.minby)

docs: https://lodash.com/docs/#minBy

provenance:
  derived_from:
    - "lodash.minby README — https://www.npmjs.com/package/lodash.minby"
    - "Test vectors verified with lodash.minby@4.6.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.minby exports the _.minBy function directly as module.exports."
    - "minBy(array, iteratee) returns the element with the minimum iteratee result."
    - "String iteratee plucks the named property."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the element with the minimum iteratee value."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_minby.minby:
  kind: node_module_call_eq
  function: ~
  category: minby
  id_prefix: lminb

  columns: [id, args, expected]
  rows:
    - [by_n,  [[{"n": 1}, {"n": 3}, {"n": 2}], "n"],  {"n": 1}]
    - [by_v,  [[{"v": 10}, {"v": 30}, {"v": 5}], "v"],  {"v": 5}]

