# ---------------------------------------------------------------------------
# Table 1: itertools.count __iter__ and __next__ slot qualnames and class names
#
# Wave 261 theme: itertools.count iterator protocol slot qualnames.
#
# itertools.count.__iter__.__qualname__.__eq__('count.__iter__') == True
# itertools.count.__iter__.__qualname__.__len__() == 14
# itertools.count.__iter__.__class__.__name__.__eq__('wrapper_descriptor') == True
# itertools.count.__next__.__qualname__.__eq__('count.__next__') == True
# itertools.count.__next__.__qualname__.__len__() == 14
# itertools.count.__next__.__class__.__name__.__eq__('wrapper_descriptor') == True
#
# count is a C extension type implementing the iterator protocol.
# __iter__ and __next__ are wrapper_descriptors with qualnames
# 'count.__iter__' and 'count.__next__' (both length 14). New to extra129.
# ---------------------------------------------------------------------------

table itertools_extra129.count_iter_next_qualnames:
  description: "itertools.count __iter__/__next__ __qualname__ (len 14) and __class__.__name__ == 'wrapper_descriptor'; iterator protocol slots on C extension type; wave 261; new to extra129"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolscount129

  columns: [id, function, args, expected, description]
  rows:
    - [count_iter_qualname_eq,
       "count.__iter__.__qualname__.__eq__",
       ["count.__iter__"],
       true,
       "itertools.count.__iter__.__qualname__.__eq__('count.__iter__') == True — count is a C extension type implementing the iterator protocol; __iter__ is a wrapper_descriptor slot whose __qualname__ includes the type name as a dotted prefix, giving 'count.__iter__'; str.__eq__('count.__iter__') returns True; new to extra129"]
    - [count_iter_qualname_len_eq_14,
       "count.__iter__.__qualname__.__len__",
       [],
       14,
       "itertools.count.__iter__.__qualname__.__len__() == 14 — __qualname__ is 'count.__iter__' which has 14 characters; len('count.__iter__') == 14; new to extra129"]
    - [count_iter_class_name_eq_wrapper_descriptor,
       "count.__iter__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.count.__iter__.__class__.__name__.__eq__('wrapper_descriptor') == True — __iter__ accessed on the C extension type is a wrapper_descriptor (CPython internal type for C-level tp_iter slots); __class__.__name__ is 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra129"]
    - [count_next_qualname_eq,
       "count.__next__.__qualname__.__eq__",
       ["count.__next__"],
       true,
       "itertools.count.__next__.__qualname__.__eq__('count.__next__') == True — __next__ is a wrapper_descriptor slot on the C extension type; its __qualname__ is 'count.__next__'; str.__eq__('count.__next__') returns True; new to extra129"]
    - [count_next_qualname_len_eq_14,
       "count.__next__.__qualname__.__len__",
       [],
       14,
       "itertools.count.__next__.__qualname__.__len__() == 14 — __qualname__ is 'count.__next__' which has 14 characters; len('count.__next__') == 14; new to extra129"]
    - [count_next_class_name_eq_wrapper_descriptor,
       "count.__next__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.count.__next__.__class__.__name__.__eq__('wrapper_descriptor') == True — __next__ accessed on the C extension type is a wrapper_descriptor (CPython internal type for tp_iternext slots); __class__.__name__ is 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra129"]

# ---------------------------------------------------------------------------
# Table 2: itertools.count __new__ qualname and type identity
#
# Wave 261 theme: itertools.count __new__ slot identity and class attributes.
#
# itertools.count.__new__.__qualname__.__eq__('count.__new__') == True
# itertools.count.__new__.__qualname__.__len__() == 13
# itertools.count.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True
# itertools.count.__class__.__name__.__eq__('type') == True
# itertools.count.__module__.__eq__('itertools') == True
#
# __new__ on a C extension type is a builtin_function_or_method (not a
# wrapper_descriptor); its qualname is 'count.__new__' (len 13).
# New to extra129.
# ---------------------------------------------------------------------------

table itertools_extra129.count_new_identity:
  description: "itertools.count __new__ qualname (len 13) and __class__.__name__ 'builtin_function_or_method'; count type identity __class__.__name__ and __module__; wave 261; new to extra129"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolscount129

  columns: [id, function, args, expected, description]
  rows:
    - [count_new_qualname_eq,
       "count.__new__.__qualname__.__eq__",
       ["count.__new__"],
       true,
       "itertools.count.__new__.__qualname__.__eq__('count.__new__') == True — __new__ on the C extension type has a __qualname__ of 'count.__new__'; unlike __iter__ and __next__ which are wrapper_descriptors, __new__ is a builtin_function_or_method; str.__eq__('count.__new__') returns True; new to extra129"]
    - [count_new_qualname_len_eq_13,
       "count.__new__.__qualname__.__len__",
       [],
       13,
       "itertools.count.__new__.__qualname__.__len__() == 13 — __qualname__ is 'count.__new__' which has 13 characters; len('count.__new__') == 13; new to extra129"]
    - [count_new_class_name_eq_builtin,
       "count.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.count.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — unlike __iter__ and __next__ which are wrapper_descriptors, __new__ on a C extension type is a builtin_function_or_method; __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra129"]
    - [count_class_name_eq_type,
       "count.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.count.__class__.__name__.__eq__('type') == True — itertools.count is a C extension type defined in Modules/itertoolsmodule.c; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra129"]
    - [count_module_eq_itertools,
       "count.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.count.__module__.__eq__('itertools') == True — count is a C extension type in Modules/itertoolsmodule.c; its __module__ attribute is set to 'itertools' by the module initializer; str.__eq__('itertools') returns True; new to extra129"]

# ---------------------------------------------------------------------------
# Table 3: itertools.count __name__, __qualname__, and __mro__ length
#
# Wave 261 theme: itertools.count class name and MRO identity.
#
# itertools.count.__name__.__eq__('count') == True
# itertools.count.__qualname__.__eq__('count') == True
# itertools.count.__mro__.__len__() == 2
#
# count is a C extension type; its __name__ and __qualname__ are both
# 'count'; MRO is [count, object] (length 2). New to extra129.
# ---------------------------------------------------------------------------

table itertools_extra129.count_name_mro:
  description: "itertools.count __name__=='count', __qualname__=='count', __mro__ len==2 ([count, object]); C extension type; wave 261; new to extra129"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolscount129

  columns: [id, function, args, expected, description]
  rows:
    - [count_name_eq_count,
       "count.__name__.__eq__",
       ["count"],
       true,
       "itertools.count.__name__.__eq__('count') == True — the __name__ attribute of the C extension type is 'count', matching the tp_name field in the PyTypeObject; str.__eq__('count') returns True; new to extra129"]
    - [count_qualname_eq_count,
       "count.__qualname__.__eq__",
       ["count"],
       true,
       "itertools.count.__qualname__.__eq__('count') == True — count is a top-level C extension type; __qualname__ equals the simple type name 'count'; str.__eq__('count') returns True; new to extra129"]
    - [count_mro_len_eq_2,
       "count.__mro__.__len__",
       [],
       2,
       "itertools.count.__mro__.__len__() == 2 — the MRO of count is [count, object]; as a C extension type inheriting directly from object it has exactly two MRO entries; len(__mro__) is 2; new to extra129"]
    - [count_name_len_eq_5,
       "count.__name__.__len__",
       [],
       5,
       "itertools.count.__name__.__len__() == 5 — __name__ is 'count' which has 5 characters; len('count') == 5; new to extra129"]
    - [count_qualname_len_eq_5,
       "count.__qualname__.__len__",
       [],
       5,
       "itertools.count.__qualname__.__len__() == 5 — __qualname__ is 'count' which has 5 characters; len('count') == 5; new to extra129"]

