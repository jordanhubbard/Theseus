spec: mp2911
version: ">=3.9"
error_model: python_exceptions
provenance:
  derived_from: [multiprocessing source, Python docs, https://docs.python.org/3/library/multiprocessing.html]
  not_derived_from: [any external dataset, multiprocessing_extra2896.zspec.zsdl — covers __itruediv__/__ifloordiv__/__imod__ dict-presence, multiprocessing_extra2881.zspec.zsdl — covers __iadd__/__isub__/__imul__ dict-presence, multiprocessing_extra2866.zspec.zsdl — covers __rand__/__ror__/__rxor__ dict-presence, multiprocessing_extra2851.zspec.zsdl — covers __rlshift__/__rrshift__/__rpow__ dict-presence]
  notes: [Wave 641 theme — __ilshift__/__irshift__/__ipow__ dict-presence checks for multiprocessing types. In-place left-shift, right-shift, and power operators. Process/Pool/AsyncResult/MapResult/SyncManager are process-management primitives lacking these dunders. managers.ListProxy defines __iadd__ and __imul__ but NOT bitshift or power dunders — lists are not numeric shift/power types. managers.SetProxy defines __isub__ but none of the shift/power dunders. All proxy types and raw multiprocessing primitives (Queue/Lock/Array) also lack these dunders. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0 2026-04-13.]
  created_at: "2026-04-13"

table mp2911.ilshift:
  kind: python_call_eq
  columns: [id, function, args, expected]
  rows:
    - ["mp2911001", operator.contains, [multiprocessing.Process.__dict__, "__ilshift__"], false]
    - ["mp2911002", operator.contains, [multiprocessing.pool.Pool.__dict__, "__ilshift__"], false]
    - ["mp2911003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__, "__ilshift__"], false]
    - ["mp2911004", operator.contains, [multiprocessing.pool.MapResult.__dict__, "__ilshift__"], false]
    - ["mp2911005", operator.contains, [multiprocessing.managers.SyncManager.__dict__, "__ilshift__"], false]
    - ["mp2911006", operator.contains, [multiprocessing.managers.BaseProxy.__dict__, "__ilshift__"], false]

