spec: keyword_extra
version: ">=3.9"
backend: python_module(keyword)

docs: https://docs.python.org/3/library/keyword.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/keyword.html — Python keyword module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/keyword.py"
  notes:
    - "This spec covers aspects not in keyword.zspec.zsdl: kwlist type check, iskeyword/__name__, issoftkeyword/__name__, len(kwlist) >= 35."
    - "kwlist is a plain Python list of strings; __class__.__name__ == 'list'."
    - "iskeyword is a function defined in keyword.py; its __name__ == 'iskeyword'."
    - "issoftkeyword was added in Python 3.9; its __name__ == 'issoftkeyword'."
    - "Python 3.12 has exactly 35 hard keywords. Future versions may add more, so the spec uses __ge__ for the lower bound."
    - "iskeyword('else') == True — 'else' is a keyword not tested in keyword.zspec.zsdl."
    - "iskeyword('hello') == False — non-keyword confirmed false."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# kwlist — type identity
#
# kwlist is a module-level list of all Python keywords.
# __class__.__name__ == 'list' confirms it is a plain Python list.
# ---------------------------------------------------------------------------

invariant keyword_extra.kwlist.type_is_list:
  description: "kwlist.__class__.__name__ == 'list'"
  category: kwlist
  kind: python_call_eq
  function: kwlist.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# kwlist — length lower bound
#
# Python 3.12 has 35 keywords. We verify len(kwlist) >= 35 using __ge__.
# ---------------------------------------------------------------------------

invariant keyword_extra.kwlist.len_ge_35:
  description: "len(kwlist) >= 35 — Python 3 has at least 35 keywords"
  category: kwlist
  kind: python_call_eq
  function: kwlist.__len__
  args: []
  method: __ge__
  method_args: [35]
  expected: true

# ---------------------------------------------------------------------------
# iskeyword — function identity
# ---------------------------------------------------------------------------

invariant keyword_extra.iskeyword.function_name:
  description: "iskeyword.__name__ == 'iskeyword'"
  category: iskeyword
  kind: python_call_eq
  function: iskeyword.__name__.__eq__
  args: ["iskeyword"]
  expected: true

# ---------------------------------------------------------------------------
# iskeyword — additional true cases not in keyword.zspec.zsdl
# ---------------------------------------------------------------------------

invariant keyword_extra.iskeyword.else_is_keyword:
  description: "iskeyword('else') == True"
  category: iskeyword
  kind: python_call_eq
  function: iskeyword
  args: ["else"]
  expected: true

invariant keyword_extra.iskeyword.elif_is_keyword:
  description: "iskeyword('elif') == True"
  category: iskeyword
  kind: python_call_eq
  function: iskeyword
  args: ["elif"]
  expected: true

invariant keyword_extra.iskeyword.try_is_keyword:
  description: "iskeyword('try') == True"
  category: iskeyword
  kind: python_call_eq
  function: iskeyword
  args: ["try"]
  expected: true

invariant keyword_extra.iskeyword.except_is_keyword:
  description: "iskeyword('except') == True"
  category: iskeyword
  kind: python_call_eq
  function: iskeyword
  args: ["except"]
  expected: true

invariant keyword_extra.iskeyword.with_is_keyword:
  description: "iskeyword('with') == True"
  category: iskeyword
  kind: python_call_eq
  function: iskeyword
  args: ["with"]
  expected: true

invariant keyword_extra.iskeyword.yield_is_keyword:
  description: "iskeyword('yield') == True"
  category: iskeyword
  kind: python_call_eq
  function: iskeyword
  args: ["yield"]
  expected: true

# ---------------------------------------------------------------------------
# iskeyword — false cases not in keyword.zspec.zsdl
# ---------------------------------------------------------------------------

invariant keyword_extra.iskeyword.hello_false:
  description: "iskeyword('hello') == False"
  category: iskeyword
  kind: python_call_eq
  function: iskeyword
  args: ["hello"]
  expected: false

# ---------------------------------------------------------------------------
# issoftkeyword — function identity (Python 3.9+)
# ---------------------------------------------------------------------------

invariant keyword_extra.issoftkeyword.function_name:
  description: "issoftkeyword.__name__ == 'issoftkeyword'"
  category: issoftkeyword
  kind: python_call_eq
  function: issoftkeyword.__name__.__eq__
  args: ["issoftkeyword"]
  expected: true
