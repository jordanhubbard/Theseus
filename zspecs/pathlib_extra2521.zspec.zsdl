spec: pathlib_extra2521
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
  notes:
    - "Wave 2521 theme: __bool__, __index__, __int__ dict-presence in pathlib classes."
    - "None of the pathlib classes (Path, PurePath, PurePosixPath, PureWindowsPath) define __bool__, __int__, or __index__ in their own __dict__."
    - "pathlib path objects are truthy by default (object.__bool__) — no truthiness override is defined."
    - "Paths are not integers and cannot be used as sequence indices — no __int__ or __index__ defined."
    - "pathlib.PurePath defines rich comparison operators (__eq__, __lt__, __le__, __gt__, __ge__) and __hash__, __str__, __repr__, __fspath__, __truediv__, __rtruediv__, __bytes__."
    - "pathlib.Path.__dict__ is sparse — it inherits nearly everything from PurePath and adds only concrete filesystem methods (__new__ and file-system operation methods)."
    - "pathlib.PurePosixPath.__dict__ and pathlib.PureWindowsPath.__dict__ contain only __slots__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __bool__ dict-presence — no pathlib class defines truthiness override
# ---------------------------------------------------------------------------

table pathlib_extra2521.bool_protocol:
  description: "__bool__ is absent from all pathlib class __dict__s — pathlib types rely on default object truthiness"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2521

  columns: [id, function, args, expected]
  rows:
    - ["pp2521001", "pathlib.Path.__dict__.__contains__",           ["__bool__"], false]
    - ["pp2521002", "pathlib.PurePath.__dict__.__contains__",       ["__bool__"], false]
    - ["pp2521003", "pathlib.PurePosixPath.__dict__.__contains__",  ["__bool__"], false]
    - ["pp2521004", "pathlib.PureWindowsPath.__dict__.__contains__", ["__bool__"], false]

# ---------------------------------------------------------------------------
# __int__ dict-presence — no pathlib class defines integer coercion
# ---------------------------------------------------------------------------

table pathlib_extra2521.int_protocol:
  description: "__int__ is absent from all pathlib class __dict__s — path objects cannot be coerced to int"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2521

  columns: [id, function, args, expected]
  rows:
    - ["pp2521005", "pathlib.Path.__dict__.__contains__",           ["__int__"], false]
    - ["pp2521006", "pathlib.PurePath.__dict__.__contains__",       ["__int__"], false]
    - ["pp2521007", "pathlib.PurePosixPath.__dict__.__contains__",  ["__int__"], false]
    - ["pp2521008", "pathlib.PureWindowsPath.__dict__.__contains__", ["__int__"], false]

# ---------------------------------------------------------------------------
# __index__ dict-presence — no pathlib class defines the indexing protocol
# ---------------------------------------------------------------------------

table pathlib_extra2521.index_protocol:
  description: "__index__ is absent from all pathlib class __dict__s — path objects cannot be used as sequence indices"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2521

  columns: [id, function, args, expected]
  rows:
    - ["pp2521009", "pathlib.Path.__dict__.__contains__",           ["__index__"], false]
    - ["pp2521010", "pathlib.PurePath.__dict__.__contains__",       ["__index__"], false]
    - ["pp2521011", "pathlib.PurePosixPath.__dict__.__contains__",  ["__index__"], false]
    - ["pp2521012", "pathlib.PureWindowsPath.__dict__.__contains__", ["__index__"], false]

# ---------------------------------------------------------------------------
# PurePath comparison protocol — present in __dict__ (contrast with absent numeric protocol)
# ---------------------------------------------------------------------------

table pathlib_extra2521.comparison_protocol:
  description: "PurePath defines comparison and hashing operators in its __dict__ — confirming which protocol IS present"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2521

  columns: [id, function, args, expected]
  rows:
    - ["pp2521013", "pathlib.PurePath.__dict__.__contains__", ["__eq__"],        true]
    - ["pp2521014", "pathlib.PurePath.__dict__.__contains__", ["__lt__"],        true]
    - ["pp2521015", "pathlib.PurePath.__dict__.__contains__", ["__hash__"],      true]
    - ["pp2521016", "pathlib.PurePath.__dict__.__contains__", ["__str__"],       true]
    - ["pp2521017", "pathlib.PurePath.__dict__.__contains__", ["__fspath__"],    true]
    - ["pp2521018", "pathlib.PurePath.__dict__.__contains__", ["__truediv__"],   true]
    - ["pp2521019", "pathlib.PurePath.__dict__.__contains__", ["__rtruediv__"],  true]
    - ["pp2521020", "pathlib.PurePath.__dict__.__contains__", ["__bytes__"],     true]
