spec: email_mime
version: ">=3.0"
backend: python_module(email.mime.text)

docs: https://docs.python.org/3/library/email.mime.html

provenance:
  derived_from:
    - "Python 3 email.mime documentation — https://docs.python.org/3/library/email.mime.html"
    - "RFC 2045 — MIME Part One: Format of Internet Message Bodies"
    - "RFC 2046 — MIME Part Two: Media Types"
    - "Test vectors verified with Python 3.14 on macOS Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/email/mime/text.py"
    - "CPython source: Lib/email/mime/base.py"
    - "CPython source: Lib/email/mime/nonmultipart.py"
  notes:
    - "MIMEText(payload, subtype) constructs a MIME message with Content-Type 'text/<subtype>'."
    - "MIMEText.__bases__[0].__name__ == 'MIMENonMultipart' — direct parent class."
    - "get_content_type() returns the full media type string, e.g. 'text/plain'."
    - "get_payload() returns the payload string when no decode argument is given."
    - "The default subtype is 'plain'; 'html' produces 'text/html'."
    - "MIMEText.__module__ == 'email.mime.text' verified with Python 3.14."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# class_names
# ---------------------------------------------------------------------------

invariant email_mime.class_names.MIMEText:
  description: "MIMEText.__name__ == 'MIMEText'"
  category: classes
  kind: python_call_eq
  function: MIMEText.__name__.__eq__
  args: ["MIMEText"]
  expected: true

# ---------------------------------------------------------------------------
# module
# ---------------------------------------------------------------------------

invariant email_mime.module.MIMEText:
  description: "MIMEText.__module__ == 'email.mime.text'"
  category: module
  kind: python_call_eq
  function: MIMEText.__module__.__eq__
  args: ["email.mime.text"]
  expected: true

# ---------------------------------------------------------------------------
# hierarchy
# ---------------------------------------------------------------------------

invariant email_mime.hierarchy.MIMEText_base:
  description: "MIMEText.__bases__[0].__name__ == 'MIMENonMultipart' — MIMEText inherits from MIMENonMultipart"
  category: hierarchy
  kind: python_call_eq
  function: MIMEText.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "MIMENonMultipart"

# ---------------------------------------------------------------------------
# content_type — get_content_type() returns correct MIME type
# ---------------------------------------------------------------------------

invariant email_mime.content_type.plain:
  description: "MIMEText('hello', 'plain').get_content_type() == 'text/plain'"
  category: content_type
  rfc: "RFC 2046"
  kind: python_call_eq
  function: MIMEText
  args: ["hello", "plain"]
  method: get_content_type
  method_args: []
  expected: "text/plain"

invariant email_mime.content_type.html:
  description: "MIMEText('hello', 'html').get_content_type() == 'text/html'"
  category: content_type
  rfc: "RFC 2046"
  kind: python_call_eq
  function: MIMEText
  args: ["hello", "html"]
  method: get_content_type
  method_args: []
  expected: "text/html"

invariant email_mime.content_type.default_plain:
  description: "MIMEText('hello').get_content_type() == 'text/plain' — default subtype is 'plain'"
  category: content_type
  rfc: "RFC 2046"
  kind: python_call_eq
  function: MIMEText
  args: ["hello"]
  method: get_content_type
  method_args: []
  expected: "text/plain"

# ---------------------------------------------------------------------------
# payload — get_payload() returns the supplied text
# ---------------------------------------------------------------------------

invariant email_mime.payload.plain:
  description: "MIMEText('hello', 'plain').get_payload() == 'hello'"
  category: payload
  rfc: "RFC 2045"
  kind: python_call_eq
  function: MIMEText
  args: ["hello", "plain"]
  method: get_payload
  method_args: []
  expected: "hello"

invariant email_mime.payload.html:
  description: "MIMEText('<b>hi</b>', 'html').get_payload() == '<b>hi</b>'"
  category: payload
  rfc: "RFC 2045"
  kind: python_call_eq
  function: MIMEText
  args: ["<b>hi</b>", "html"]
  method: get_payload
  method_args: []
  expected: "<b>hi</b>"

# ---------------------------------------------------------------------------
# main_type — get_content_maintype() always returns 'text'
# ---------------------------------------------------------------------------

invariant email_mime.main_type.plain:
  description: "MIMEText('hello', 'plain').get_content_maintype() == 'text'"
  category: content_type
  rfc: "RFC 2046"
  kind: python_call_eq
  function: MIMEText
  args: ["hello", "plain"]
  method: get_content_maintype
  method_args: []
  expected: "text"

# ---------------------------------------------------------------------------
# subtype — get_content_subtype() returns the subtype component
# ---------------------------------------------------------------------------

invariant email_mime.subtype.plain:
  description: "MIMEText('hello', 'plain').get_content_subtype() == 'plain'"
  category: content_type
  rfc: "RFC 2046"
  kind: python_call_eq
  function: MIMEText
  args: ["hello", "plain"]
  method: get_content_subtype
  method_args: []
  expected: "plain"

invariant email_mime.subtype.html:
  description: "MIMEText('hello', 'html').get_content_subtype() == 'html'"
  category: content_type
  rfc: "RFC 2046"
  kind: python_call_eq
  function: MIMEText
  args: ["hello", "html"]
  method: get_content_subtype
  method_args: []
  expected: "html"
