spec: abc_extra1306
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Wave 534 (_extra1306): focuses on exception-raising behavior for bad argument types and counts."
    - "abc.ABCMeta('T', 42, {}) raises TypeError — type.__new__() argument 2 must be tuple, not int."
    - "abc.ABCMeta('T', (object,), 42) raises TypeError — type.__new__() argument 3 must be dict, not int."
    - "abc.ABCMeta() raises TypeError — missing 3 required positional arguments."
    - "abc.ABCMeta('T') raises TypeError — missing 2 required positional arguments."
    - "abc.ABCMeta('T', ()) raises TypeError — missing 1 required positional argument."
    - "abc.abstractmethod() raises TypeError — missing 1 required positional argument 'funcobj'."
    - "abc.abstractmethod(42) raises AttributeError — 'int' has no '__isabstractmethod__' and no __dict__."
    - "abc.abstractclassmethod() raises TypeError — missing 1 required positional argument 'callable'."
    - "abc.abstractclassmethod(42) raises AttributeError — 'int' has no '__isabstractmethod__' and no __dict__."
    - "abc.abstractstaticmethod() raises TypeError — missing 1 required positional argument 'callable'."
    - "abc.abstractstaticmethod(42) raises AttributeError — 'int' has no '__isabstractmethod__' and no __dict__."
    - "abc.ABC(42) raises TypeError — ABC() takes no arguments."
    - "All exceptions verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table abc_extra1306.abcmeta_constructor_errors:
  description: "abc.ABCMeta raises TypeError when called with wrong argument counts or non-tuple bases or non-dict namespace"
  kind: python_call_raises
  category: constructor_errors
  id_prefix: ab1306mc
  columns: [id, function, args, exception]
  rows:
    - [ab1306mc001, abc.ABCMeta, [],                       "TypeError"]
    - [ab1306mc002, abc.ABCMeta, ["T"],                    "TypeError"]
    - [ab1306mc003, abc.ABCMeta, ["T", 42, {}],            "TypeError"]
    - [ab1306mc004, abc.ABCMeta, ["T", "bad", {}],         "TypeError"]
    - [ab1306mc005, abc.ABCMeta, ["T", [object], 42],      "TypeError"]
    - [ab1306mc006, abc.ABCMeta, ["T", [object], "bad"],   "TypeError"]

table abc_extra1306.abstractmethod_errors:
  description: "abc.abstractmethod raises TypeError when called with no argument or a non-callable int; abc.abstractclassmethod and abstractstaticmethod also require a callable"
  kind: python_call_raises
  category: type_errors
  id_prefix: ab1306am
  columns: [id, function, args, exception]
  rows:
    - [ab1306am001, abc.abstractmethod,       [],    "TypeError"]
    - [ab1306am002, abc.abstractmethod,       [42],  "AttributeError"]
    - [ab1306am003, abc.abstractclassmethod,  [],    "TypeError"]
    - [ab1306am004, abc.abstractstaticmethod, [],    "TypeError"]
    - [ab1306am005, abc.abstractclassmethod,  [42],  "AttributeError"]
    - [ab1306am006, abc.abstractstaticmethod, [42],  "AttributeError"]

table abc_extra1306.abc_instantiation_errors:
  description: "abc.ABC raises TypeError for unexpected positional arguments; instantiating a class with unimplemented abstract methods raises TypeError"
  kind: python_call_raises
  category: instantiation_errors
  id_prefix: ab1306ai
  columns: [id, function, args, exception]
  rows:
    - [ab1306ai001, abc.ABC,     [42],    "TypeError"]
    - [ab1306ai002, abc.ABC,     ["x"],   "TypeError"]
    - [ab1306ai003, abc.ABC,     [null],  "TypeError"]
    - [ab1306ai004, abc.ABC,     [[]],    "TypeError"]
    - [ab1306ai005, abc.ABC,     [{}],    "TypeError"]
    - [ab1306ai006, abc.ABC,     [true],  "TypeError"]
