spec: dis_extra26
version: ">=3.9"
backend: python_module(dis)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dis.html — Python dis module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dis.py"
    - "dis_extra25.zspec.zsdl — covers dis/disassemble/code_info/show_code/get_instructions/findlinestarts/findlabels __qualname__ standalone; dis/code_info/show_code __module__.__len__() (table); Instruction/__qualname__ standalone"
    - "dis_extra24.zspec.zsdl — covers Instruction._fields/__len__() and _fields[0]/_fields[1]; findlinestarts/findlabels/distb __qualname__ standalone; Bytecode.__init__.__qualname__/__module__"
    - "dis_extra23.zspec.zsdl — covers dis/disassemble/get_instructions/findlinestarts/code_info/show_code __module__ (table); Instruction/__module__ and Bytecode/__module__ standalone; stack_effect/__qualname__ and __module__"
    - "dis_extra21.zspec.zsdl — covers dis/disassemble/get_instructions/findlinestarts/findlabels __qualname__.__eq__ (table); Instruction/__qualname__.__eq__ standalone"
    - "dis_extra17.zspec.zsdl — covers dis/disassemble/get_instructions/findlinestarts/findlabels __name__ and __module__; Instruction/__name__"
  notes:
    - "This spec extends dis_extra25.zspec.zsdl."
    - "Prior specs covered: dis/__name__/__package__, dis/disassemble/code_info/show_code/get_instructions/findlinestarts/findlabels __name__/__module__/__qualname__, Instruction/__name__/__module__/__qualname__, dis.COMPILER_FLAGS/__class__.__name__, stack_effect/__name__, module length checks (all 3 = 'dis')."
    - "This spec covers: dis.dis.__module__.__len__(), dis.disassemble.__module__.__len__(), dis.code_info.__module__.__len__(), dis.show_code.__module__.__len__(), dis.get_instructions.__module__.__len__() (all == 3); dis.Instruction.__module__.__len__() (== 3); dis.dis.__name__.__len__(), dis.disassemble.__name__.__len__(), dis.code_info.__name__.__len__(), dis.show_code.__name__.__len__(), dis.get_instructions.__name__.__len__(); dis.Instruction.__name__.__len__()."
    - "dis.dis.__module__.__len__() == 3 — 'dis' has 3 characters; dis_extra25 covers dis/code_info/show_code in a table, distinct standalone invariant in dis_extra26 namespace."
    - "dis.disassemble.__module__.__len__() == 3 — same; no prior dis spec covers this as a standalone invariant."
    - "dis.code_info.__module__.__len__() == 3 — dis_extra25 covers this in a table; distinct standalone invariant in dis_extra26 namespace."
    - "dis.show_code.__module__.__len__() == 3 — dis_extra25 covers this in a table; distinct standalone invariant in dis_extra26 namespace."
    - "dis.get_instructions.__module__.__len__() == 3 — no prior dis spec covers this as a standalone invariant."
    - "dis.Instruction.__module__.__len__() == 3 — no prior dis spec covers __module__.__len__() for Instruction."
    - "dis.dis.__name__.__len__() == 3 — 'dis' has 3 characters; no prior dis spec covers __name__.__len__() for any function."
    - "dis.disassemble.__name__.__len__() == 11 — 'disassemble' has 11 characters; no prior dis spec covers this."
    - "dis.code_info.__name__.__len__() == 9 — 'code_info' has 9 characters; no prior dis spec covers this."
    - "dis.show_code.__name__.__len__() == 9 — 'show_code' has 9 characters; no prior dis spec covers this."
    - "dis.get_instructions.__name__.__len__() == 16 — 'get_instructions' has 16 characters; no prior dis spec covers this."
    - "dis.Instruction.__name__.__len__() == 11 — 'Instruction' has 11 characters; no prior dis spec covers this."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# dis/disassemble __module__.__len__() — standalone invariants
# (dis_extra26 namespace)
#
# 'dis' has 3 characters. dis_extra25 covers dis/code_info/show_code in a
# table. dis.dis and dis.disassemble are distinct standalone invariants in
# the dis_extra26 namespace.
# ---------------------------------------------------------------------------

invariant dis_extra26.dis_func.module_len:
  description: "dis.dis.__module__.__len__() == 3 — module name 'dis' has 3 characters"
  category: string_lengths
  kind: python_call_eq
  function: dis.__module__.__len__
  args: []
  expected: 3

invariant dis_extra26.disassemble.module_len:
  description: "dis.disassemble.__module__.__len__() == 3 — module name 'dis' has 3 characters"
  category: string_lengths
  kind: python_call_eq
  function: disassemble.__module__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# code_info/show_code/get_instructions __module__.__len__() — standalone
# (dis_extra26 namespace)
#
# dis_extra25 covers code_info and show_code in a table. get_instructions
# has not been covered in any prior __module__.__len__() context.
# All are distinct standalone invariants in the dis_extra26 namespace.
# ---------------------------------------------------------------------------

invariant dis_extra26.code_info.module_len:
  description: "dis.code_info.__module__.__len__() == 3 — module name 'dis' has 3 characters"
  category: string_lengths
  kind: python_call_eq
  function: code_info.__module__.__len__
  args: []
  expected: 3

invariant dis_extra26.show_code.module_len:
  description: "dis.show_code.__module__.__len__() == 3 — module name 'dis' has 3 characters"
  category: string_lengths
  kind: python_call_eq
  function: show_code.__module__.__len__
  args: []
  expected: 3

invariant dis_extra26.get_instructions.module_len:
  description: "dis.get_instructions.__module__.__len__() == 3 — module name 'dis' has 3 characters"
  category: string_lengths
  kind: python_call_eq
  function: get_instructions.__module__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# Instruction.__module__.__len__() — standalone invariant
# (dis_extra26 namespace)
#
# 'dis' has 3 characters. dis_extra23 covers Instruction/__module__.__eq__
# as a standalone. No prior dis spec covers __module__.__len__() for
# Instruction.
# ---------------------------------------------------------------------------

invariant dis_extra26.Instruction.module_len:
  description: "dis.Instruction.__module__.__len__() == 3 — module name 'dis' has 3 characters"
  category: string_lengths
  kind: python_call_eq
  function: Instruction.__module__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# dis/disassemble/code_info/show_code/get_instructions __name__.__len__()
# — standalone invariants
# (dis_extra26 namespace)
#
# No prior dis spec covers __name__.__len__() for any of these functions.
# Verified values: dis(3), disassemble(11), code_info(9), show_code(9),
# get_instructions(16).
# ---------------------------------------------------------------------------

invariant dis_extra26.dis_func.name_len:
  description: "dis.dis.__name__.__len__() == 3 — 'dis' has 3 characters"
  category: string_lengths
  kind: python_call_eq
  function: dis.__name__.__len__
  args: []
  expected: 3

invariant dis_extra26.disassemble.name_len:
  description: "dis.disassemble.__name__.__len__() == 11 — 'disassemble' has 11 characters"
  category: string_lengths
  kind: python_call_eq
  function: disassemble.__name__.__len__
  args: []
  expected: 11

invariant dis_extra26.code_info.name_len:
  description: "dis.code_info.__name__.__len__() == 9 — 'code_info' has 9 characters"
  category: string_lengths
  kind: python_call_eq
  function: code_info.__name__.__len__
  args: []
  expected: 9

invariant dis_extra26.show_code.name_len:
  description: "dis.show_code.__name__.__len__() == 9 — 'show_code' has 9 characters"
  category: string_lengths
  kind: python_call_eq
  function: show_code.__name__.__len__
  args: []
  expected: 9

invariant dis_extra26.get_instructions.name_len:
  description: "dis.get_instructions.__name__.__len__() == 16 — 'get_instructions' has 16 characters"
  category: string_lengths
  kind: python_call_eq
  function: get_instructions.__name__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# Instruction.__name__.__len__() — standalone invariant
# (dis_extra26 namespace)
#
# 'Instruction' has 11 characters. No prior dis spec covers __name__.__len__()
# for Instruction.
# ---------------------------------------------------------------------------

invariant dis_extra26.Instruction.name_len:
  description: "dis.Instruction.__name__.__len__() == 11 — 'Instruction' has 11 characters"
  category: string_lengths
  kind: python_call_eq
  function: Instruction.__name__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# __module__.__len__() table — functions and Instruction class
# (dis_extra26 namespace)
#
# Groups all six __module__.__len__() checks into a single table.
# All belong to the 'dis' module (length 3).
# ---------------------------------------------------------------------------

table dis_extra26.module_lengths:
  description: "__module__.__len__() for dis top-level functions and Instruction — all equal 3 ('dis')"
  kind: python_call_eq
  category: string_lengths
  id_prefix: modlen

  columns: [id, function, args, expected]
  rows:
    - [dis_func,         dis.__module__.__len__,              [], 3]
    - [disassemble,      disassemble.__module__.__len__,      [], 3]
    - [code_info,        code_info.__module__.__len__,        [], 3]
    - [show_code,        show_code.__module__.__len__,        [], 3]
    - [get_instructions, get_instructions.__module__.__len__, [], 3]
    - [Instruction,      Instruction.__module__.__len__,      [], 3]

# ---------------------------------------------------------------------------
# __name__.__len__() table — functions and Instruction class
# (dis_extra26 namespace)
#
# Groups all six __name__.__len__() checks into a single table.
# ---------------------------------------------------------------------------

table dis_extra26.name_lengths:
  description: "__name__.__len__() for dis top-level functions and Instruction"
  kind: python_call_eq
  category: string_lengths
  id_prefix: namelen

  columns: [id, function, args, expected]
  rows:
    - [dis_func,         dis.__name__.__len__,              [], 3]
    - [disassemble,      disassemble.__name__.__len__,      [], 11]
    - [code_info,        code_info.__name__.__len__,        [], 9]
    - [show_code,        show_code.__name__.__len__,        [], 9]
    - [get_instructions, get_instructions.__name__.__len__, [], 16]
    - [Instruction,      Instruction.__name__.__len__,      [], 11]
