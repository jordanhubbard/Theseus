  args: ["cmp_to_key"]
  expected: true

invariant functools_extra174.cmp_to_key_module_functools_c:
  description: "functools.cmp_to_key.__module__ == '_functools' — cmp_to_key is implemented in _functoolsmodule.c; __module__ is '_functools', not 'functools'; wave 298; new to extra174"
  kind: python_call_eq
  function: cmp_to_key.__module__.__eq__
