invariant functools_extra174.cmp_to_key_class_builtin:
  description: "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method' — cmp_to_key is a C builtin function, not a Python function or C type; wave 298; new to extra174"
  kind: python_call_eq
  function: cmp_to_key.__class__.__name__.__eq__
