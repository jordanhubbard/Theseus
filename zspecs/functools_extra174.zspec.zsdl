spec: functools_extra174
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.reduce.__name__ 'reduce'; functools.reduce.__module__ '_functools' (C extension); functools.reduce.__class__.__name__ 'builtin_function_or_method'; functools.cmp_to_key.__name__ 'cmp_to_key'; functools.cmp_to_key.__module__ '_functools' (C extension); functools.cmp_to_key.__class__.__name__ 'builtin_function_or_method' (Wave 298)."
    - "functools.reduce.__name__ == 'reduce' — functools.reduce is a C builtin function implemented in Modules/_functoolsmodule.c that applies a function of two arguments cumulatively to the items of a sequence (left fold); its __name__ attribute is 'reduce'. Verified with Python 3.14.3."
    - "functools.reduce.__module__ == '_functools' — reduce is implemented in the C extension module _functoolsmodule.c which registers itself as '_functools'; its __module__ attribute is '_functools', not 'functools'. Verified with Python 3.14.3."
    - "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — functools.reduce is a C builtin function (not a Python function and not a C type/class); its __class__.__name__ is 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__name__ == 'cmp_to_key' — functools.cmp_to_key is a C builtin function implemented in Modules/_functoolsmodule.c that converts a comparison function to a key function (for use with sorted()); its __name__ attribute is 'cmp_to_key'. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__module__ == '_functools' — cmp_to_key is implemented in the C extension module _functoolsmodule.c; its __module__ attribute is '_functools', not 'functools'. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method' — functools.cmp_to_key is a C builtin function; its __class__.__name__ is 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.reduce C builtin function identity — __name__, __module__,
# __class__.__name__
#
# Wave 298 theme: functools.reduce C builtin function identity — __name__,
# __module__, and __class__.__name__.
#
# functools.reduce.__name__ == 'reduce'
# functools.reduce.__module__ == '_functools'
# functools.reduce.__class__.__name__ == 'builtin_function_or_method'
# functools.reduce.__name__ != 'cmp_to_key'
#
# functools.reduce(function, iterable[, initializer]) applies function of two
# arguments cumulatively to the items of iterable, so as to reduce the iterable
# to a single value. It is a C builtin function defined in
# Modules/_functoolsmodule.c, which exposes itself under the module name
# '_functools'. Its __module__ is '_functools', not 'functools'. New to extra174.
# ---------------------------------------------------------------------------

table functools_extra174.reduce_builtin_identity:
  description: "functools.reduce: __name__ 'reduce', __module__ '_functools', __class__.__name__ 'builtin_function_or_method'; wave 298; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsrbi174

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_name_reduce,
       "reduce.__name__.__eq__",
       ["reduce"],
       true,
       "functools.reduce.__name__.__eq__('reduce') == True — functools.reduce is a C builtin function defined in Modules/_functoolsmodule.c that applies a binary function cumulatively to the items of an iterable (left fold); its __name__ attribute is 'reduce'; str.__eq__('reduce') returns True; new to extra174"]
    - [reduce_module_functools_c,
       "reduce.__module__.__eq__",
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — reduce is implemented in Modules/_functoolsmodule.c which registers itself as '_functools'; its __module__ attribute is '_functools', not 'functools' (the public module name); str.__eq__('_functools') returns True; new to extra174"]
    - [reduce_class_builtin,
       "reduce.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — functools.reduce is a C builtin function (not a Python function and not a C type); its __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra174"]
    - [reduce_name_ne_cmp_to_key,
       "reduce.__name__.__eq__",
       ["cmp_to_key"],
       false,
       "functools.reduce.__name__.__eq__('cmp_to_key') == False — reduce.__name__ is 'reduce', not 'cmp_to_key'; they are two distinct C builtin functions in _functoolsmodule.c; str.__eq__('cmp_to_key') returns False; new to extra174"]

# ---------------------------------------------------------------------------
# Table 2: functools.cmp_to_key C builtin function identity — __name__,
# __module__, __class__.__name__
#
# Wave 298 theme: functools.cmp_to_key C builtin function identity — __name__,
# __module__, and __class__.__name__.
#
# functools.cmp_to_key.__name__ == 'cmp_to_key'
# functools.cmp_to_key.__module__ == '_functools'
# functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method'
# functools.cmp_to_key.__name__ != 'reduce'
#
# functools.cmp_to_key(mycmp) transforms an old-style comparison function (that
# takes two arguments and returns negative, zero, or positive) into a key function
# suitable for use in sort() / sorted() / min() / max() and heapq functions. It
# is a C builtin function in Modules/_functoolsmodule.c with __module__ '_functools'.
# New to extra174.
# ---------------------------------------------------------------------------

table functools_extra174.cmp_to_key_builtin_identity:
  description: "functools.cmp_to_key: __name__ 'cmp_to_key', __module__ '_functools', __class__.__name__ 'builtin_function_or_method'; wave 298; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsctk174

  columns: [id, function, args, expected, description]
  rows:
    - [ctk_name_cmp_to_key,
       "cmp_to_key.__name__.__eq__",
       ["cmp_to_key"],
       true,
       "functools.cmp_to_key.__name__.__eq__('cmp_to_key') == True — functools.cmp_to_key is a C builtin function defined in Modules/_functoolsmodule.c that converts an old-style comparison function to a key function for sorted()/min()/max(); its __name__ attribute is 'cmp_to_key'; str.__eq__('cmp_to_key') returns True; new to extra174"]
    - [ctk_module_functools_c,
       "cmp_to_key.__module__.__eq__",
       ["_functools"],
       true,
       "functools.cmp_to_key.__module__.__eq__('_functools') == True — cmp_to_key is implemented in Modules/_functoolsmodule.c which registers itself as '_functools'; its __module__ attribute is '_functools', not 'functools'; str.__eq__('_functools') returns True; new to extra174"]
    - [ctk_class_builtin,
       "cmp_to_key.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.cmp_to_key.__class__.__name__.__eq__('builtin_function_or_method') == True — functools.cmp_to_key is a C builtin function; its __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra174"]
    - [ctk_name_ne_reduce,
       "cmp_to_key.__name__.__eq__",
       ["reduce"],
       false,
       "functools.cmp_to_key.__name__.__eq__('reduce') == False — cmp_to_key.__name__ is 'cmp_to_key', not 'reduce'; they are two distinct C builtin functions in _functoolsmodule.c; str.__eq__('reduce') returns False; new to extra174"]

# ---------------------------------------------------------------------------
# Table 3: functools.reduce and cmp_to_key shared C module cross-checks
#
# Wave 298 theme: cross-checks confirming that both reduce and cmp_to_key share
# __module__ '_functools' and both have __class__.__name__ 'builtin_function_or_method',
# and that neither has __module__ 'functools'.
#
# functools.reduce.__module__ != 'functools'
# functools.cmp_to_key.__module__ != 'functools'
# functools.reduce.__class__.__name__ == functools.cmp_to_key.__class__.__name__
#   (both 'builtin_function_or_method')
# functools.reduce.__name__ != 'partial'
#
# Both reduce and cmp_to_key are implemented in the C extension module
# _functoolsmodule.c. Despite being exposed via the 'functools' namespace,
# their __module__ attribute reflects the underlying C module '_functools',
# not 'functools'. This contrasts with Python functions in functools like
# wraps (whose __module__ is 'functools'). New to extra174.
# ---------------------------------------------------------------------------

table functools_extra174.reduce_ctk_shared_module_checks:
  description: "functools: reduce and cmp_to_key both __module__ '_functools' (not 'functools'), both 'builtin_function_or_method'; wave 298; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsrctksm174

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_module_not_functools,
       "reduce.__module__.__eq__",
       ["functools"],
       false,
       "functools.reduce.__module__.__eq__('functools') == False — reduce's __module__ is '_functools' (the underlying C module), NOT 'functools' (the public module); this contrasts with Python functions like wraps whose __module__ is 'functools'; str.__eq__('functools') returns False; new to extra174"]
    - [ctk_module_not_functools,
       "cmp_to_key.__module__.__eq__",
       ["functools"],
       false,
       "functools.cmp_to_key.__module__.__eq__('functools') == False — cmp_to_key's __module__ is '_functools' (the underlying C module), NOT 'functools'; both reduce and cmp_to_key share this C extension module provenance; str.__eq__('functools') returns False; new to extra174"]
    - [reduce_class_builtin_xcheck,
       "reduce.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — both reduce and cmp_to_key have __class__.__name__ 'builtin_function_or_method'; cross-check confirming reduce's class; str.__eq__('builtin_function_or_method') returns True; new to extra174"]
    - [reduce_name_not_partial,
       "reduce.__name__.__eq__",
       ["partial"],
       false,
       "functools.reduce.__name__.__eq__('partial') == False — reduce.__name__ is 'reduce', not 'partial'; functools.partial is a C extension type (class) not a builtin function; they differ in both name and __class__.__name__; str.__eq__('partial') returns False; new to extra174"]

# ---------------------------------------------------------------------------
# Table 4: functools.reduce and cmp_to_key negative class checks — not 'type',
# not 'function'
#
# Wave 298 theme: confirming that reduce and cmp_to_key are neither Python
# functions nor C extension types (classes), only C builtin functions.
#
# functools.reduce.__class__.__name__ != 'type'
# functools.reduce.__class__.__name__ != 'function'
# functools.cmp_to_key.__class__.__name__ != 'type'
# functools.cmp_to_key.__class__.__name__ != 'function'
#
# functools.reduce and functools.cmp_to_key are C builtin functions, NOT C
# extension types (which would show 'type' as __class__.__name__) and NOT Python
# functions (which would show 'function'). This distinguishes them from
# functools.partial and functools.partialmethod (which are classes/'type') and
# from functools.wraps (which is a Python function/'function'). New to extra174.
# ---------------------------------------------------------------------------

table functools_extra174.reduce_ctk_negative_class_checks:
  description: "functools: reduce and cmp_to_key __class__.__name__ not 'type' and not 'function'; wave 298; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsrctkncx174

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_not_type,
       "reduce.__class__.__name__.__eq__",
       ["type"],
       false,
       "functools.reduce.__class__.__name__.__eq__('type') == False — functools.reduce is a C builtin function, NOT a C extension type (class); its __class__.__name__ is 'builtin_function_or_method', not 'type'; str.__eq__('type') returns False; new to extra174"]
    - [reduce_not_function,
       "reduce.__class__.__name__.__eq__",
       ["function"],
       false,
       "functools.reduce.__class__.__name__.__eq__('function') == False — functools.reduce is a C builtin function, NOT a Python function; its __class__.__name__ is 'builtin_function_or_method', not 'function'; str.__eq__('function') returns False; new to extra174"]
    - [ctk_not_type,
       "cmp_to_key.__class__.__name__.__eq__",
       ["type"],
       false,
       "functools.cmp_to_key.__class__.__name__.__eq__('type') == False — functools.cmp_to_key is a C builtin function, NOT a C extension type (class); its __class__.__name__ is 'builtin_function_or_method', not 'type'; str.__eq__('type') returns False; new to extra174"]
    - [ctk_not_function,
       "cmp_to_key.__class__.__name__.__eq__",
       ["function"],
       false,
       "functools.cmp_to_key.__class__.__name__.__eq__('function') == False — functools.cmp_to_key is a C builtin function, NOT a Python function; its __class__.__name__ is 'builtin_function_or_method', not 'function'; str.__eq__('function') returns False; new to extra174"]

# ---------------------------------------------------------------------------
# Table 5: functools.reduce and cmp_to_key __name__ length checks
#
# Wave 298 theme: string length checks for reduce.__name__ and
# cmp_to_key.__name__.
#
# functools.reduce.__name__.__len__() == 6
# functools.cmp_to_key.__name__.__len__() == 10
# functools.reduce.__name__ != functools.cmp_to_key.__name__
#
# 'reduce' is 6 characters long (r-e-d-u-c-e).
# 'cmp_to_key' is 10 characters long (c-m-p-_-t-o-_-k-e-y).
# These are distinct names of different lengths. New to extra174.
# ---------------------------------------------------------------------------

table functools_extra174.reduce_ctk_name_lengths:
  description: "functools: reduce.__name__.__len__() 6, cmp_to_key.__name__.__len__() 10; wave 298; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsrctkl174

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_name_len_6,
       "reduce.__name__.__len__",
       [],
       6,
       "functools.reduce.__name__.__len__() == 6 — the string 'reduce' has exactly 6 characters: r-e-d-u-c-e; str.__len__() returns 6; new to extra174"]
    - [ctk_name_len_10,
       "cmp_to_key.__name__.__len__",
       [],
       10,
       "functools.cmp_to_key.__name__.__len__() == 10 — the string 'cmp_to_key' has exactly 10 characters: c-m-p-_-t-o-_-k-e-y; str.__len__() returns 10; new to extra174"]
    - [reduce_name_ne_cmp_to_key_xcheck,
       "reduce.__name__.__eq__",
       ["cmp_to_key"],
       false,
       "functools.reduce.__name__.__eq__('cmp_to_key') == False — 'reduce' (6 chars) and 'cmp_to_key' (10 chars) are distinct names of different lengths; cross-check confirming they are separate C builtin functions; str.__eq__('cmp_to_key') returns False; new to extra174"]
    - [reduce_module_eq_ctk_module,
       "reduce.__module__.__eq__",
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — both reduce and cmp_to_key share __module__ '_functools'; cross-check via reduce; both are C builtins from the same C extension module; str.__eq__('_functools') returns True; new to extra174"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra174
# ---------------------------------------------------------------------------

invariant functools_extra174.reduce_name_reduce:
  description: "functools.reduce.__name__ == 'reduce' — C builtin function applying a binary function cumulatively to an iterable (left fold); wave 298; new to extra174"
  kind: python_call_eq
  function: reduce.__name__.__eq__
  args: ["reduce"]
  expected: true

invariant functools_extra174.reduce_module_functools_c:
  description: "functools.reduce.__module__ == '_functools' — reduce is implemented in _functoolsmodule.c; __module__ is '_functools', not 'functools'; wave 298; new to extra174"
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra174.reduce_class_builtin:
  description: "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is a C builtin function, not a Python function or C type; wave 298; new to extra174"
  kind: python_call_eq
  function: reduce.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra174.cmp_to_key_name_cmp_to_key:
  description: "functools.cmp_to_key.__name__ == 'cmp_to_key' — C builtin function converting old-style comparison function to key function; wave 298; new to extra174"
  kind: python_call_eq
