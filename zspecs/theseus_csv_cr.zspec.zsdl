spec: theseus_csv_cr
version: ">=3.8"
backend: python_cleanroom(theseus_csv_cr)
blocks: csv

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/csv.html"
  not_derived_from:
    - "CPython source: Lib/csv.py, Modules/_csv.c (internal implementation)"
  notes:
    - "Clean-room CSV reader/writer. Do NOT import csv."
    - "reader(f, dialect): iterate rows as lists of strings."
    - "writer(f, dialect): write rows to CSV."
    - "DictReader, DictWriter: CSV with named columns."

error_model: python_exceptions

invariant theseus_csv_cr.csv2_write_read:
  description: "write rows to StringIO then read back"
  category: reader
  kind: python_call_eq
  function: csv2_write_read
  args: []
  expected: true

invariant theseus_csv_cr.csv2_quoting:
  description: "fields with commas are properly quoted"
  category: writer
  kind: python_call_eq
  function: csv2_quoting
  args: []
  expected: true

invariant theseus_csv_cr.csv2_dictreader:
  description: "DictReader returns dicts with header keys"
  category: DictReader
  kind: python_call_eq
  function: csv2_dictreader
  args: []
  expected: true
