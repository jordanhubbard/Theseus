spec: threading_extra197
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.Barrier.__name__ == 'Barrier' (len=7); Barrier is a Python class defined in threading.py that implements a thread barrier synchronization primitive; verified with Python 3.14.3."
    - "threading.Barrier.__module__ == 'threading' (len=9); Barrier is defined at the top level of threading.py; verified with Python 3.14.3."
    - "threading.Barrier.__bases__[0].__name__ == 'object' (len=6); Barrier inherits directly from object; verified with Python 3.14.3."
    - "threading.Barrier.__init__.__qualname__ == 'Barrier.__init__' (len=16); the __init__ method is defined inside the Barrier class; verified with Python 3.14.3."
    - "threading.Barrier.wait.__qualname__ == 'Barrier.wait' (len=12); wait is a method defined inside the Barrier class that blocks until all parties have called it; verified with Python 3.14.3."
    - "threading.Barrier.reset.__qualname__ == 'Barrier.reset' (len=13); reset is a method defined inside the Barrier class that resets the barrier to the initial state; verified with Python 3.14.3."
    - "threading.Barrier.abort.__qualname__ == 'Barrier.abort' (len=13); abort is a method defined inside the Barrier class that puts the barrier into a broken state; verified with Python 3.14.3."
    - "threading.Barrier.parties.__class__.__name__ == 'property' (len=8); parties is a property descriptor on the Barrier class that returns the number of threads required to trip the barrier; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

