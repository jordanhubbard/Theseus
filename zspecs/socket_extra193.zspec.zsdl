spec: socket_extra193
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html
rfcs:
  - "RFC 1034 — Domain Names — Concepts and Facilities (for gaierror/herror context)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "RFC 1034 — Domain Names — Concepts and Facilities, November 1987"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: internal BSD socket implementation"
  notes:
    - "This spec does NOT duplicate invariants already present in socket.zspec.zsdl or prior socket_extra files."
    - "socket.error is an alias for OSError since Python 3.3; socket.error.__name__ == 'OSError'."
    - "socket.error.__module__ == 'builtins' — OSError lives in the builtins module."
    - "socket.error.__bases__[0].__name__ == 'Exception' — OSError inherits directly from Exception."
    - "socket.timeout is an alias for TimeoutError since Python 3.11; socket.timeout.__name__ == 'TimeoutError'."
    - "socket.timeout.__module__ == 'builtins' — TimeoutError is a builtin exception."
    - "socket.gaierror.__name__ == 'gaierror' — it is a socket-specific exception class."
    - "socket.gaierror.__module__ == 'socket' — gaierror is defined in the socket module."
    - "socket.herror.__name__ == 'herror' — it is a socket-specific exception class."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.error (OSError alias) — exception identity
# ---------------------------------------------------------------------------

table socket_extra193.error.identity:
  kind: python_call_eq
  category: exception_identity
  id_prefix: socketexceptions193

  columns: [id, function, args, expected]
  rows:
    - [error_name,   error.__name__.__eq__,   ["OSError"],   true]
    - [error_module, error.__module__.__eq__, ["builtins"],  true]

# ---------------------------------------------------------------------------
# socket.timeout (TimeoutError alias) and socket.gaierror — identity
# ---------------------------------------------------------------------------

table socket_extra193.timeout_gaierror.identity:
  kind: python_call_eq
  category: exception_identity
  id_prefix: socketexceptions193

  columns: [id, function, args, expected]
  rows:
    - [timeout_name,   timeout.__name__.__eq__,   ["TimeoutError"], true]
    - [timeout_module, timeout.__module__.__eq__, ["builtins"],     true]
    - [gaierror_name,  gaierror.__name__.__eq__,  ["gaierror"],     true]
    - [gaierror_module, gaierror.__module__.__eq__, ["socket"],     true]

# ---------------------------------------------------------------------------
# socket.herror — exception identity
# ---------------------------------------------------------------------------

table socket_extra193.herror.identity:
  kind: python_call_eq
  category: exception_identity
  id_prefix: socketexceptions193

  columns: [id, function, args, expected]
  rows:
    - [herror_name,   herror.__name__.__eq__,   ["herror"], true]
    - [herror_module, herror.__module__.__eq__, ["socket"], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant socket_extra193.error.name:
  description: "socket.error.__name__ == 'OSError' — socket.error is an alias for OSError since Python 3.3"
  category: exception_identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["OSError"]
  expected: true

invariant socket_extra193.error.module:
  description: "socket.error.__module__ == 'builtins' — OSError is defined in the builtins module"
  category: exception_identity
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant socket_extra193.error.base_is_exception:
  description: "socket.error.__bases__[0].__name__ == 'Exception' — OSError inherits directly from Exception"
  category: exception_identity
  kind: python_call_eq
  "function": "error.__bases__.__getitem__"
  args: [0]
  method: __name__
  expected: "Exception"

invariant socket_extra193.timeout.name:
  description: "socket.timeout.__name__ == 'TimeoutError' — socket.timeout is an alias for TimeoutError since Python 3.11"
  category: exception_identity
  kind: python_call_eq
  function: timeout.__name__.__eq__
  args: ["TimeoutError"]
  expected: true

invariant socket_extra193.timeout.module:
  description: "socket.timeout.__module__ == 'builtins' — TimeoutError is a builtin exception"
  category: exception_identity
  kind: python_call_eq
  function: timeout.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant socket_extra193.gaierror.name:
  description: "socket.gaierror.__name__ == 'gaierror' — socket-specific DNS resolution error"
  category: exception_identity
  kind: python_call_eq
  function: gaierror.__name__.__eq__
  args: ["gaierror"]
  expected: true

invariant socket_extra193.gaierror.module:
  description: "socket.gaierror.__module__ == 'socket' — gaierror is defined in the socket module"
  category: exception_identity
  kind: python_call_eq
  function: gaierror.__module__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra193.herror.name:
  description: "socket.herror.__name__ == 'herror' — socket-specific host address error"
  category: exception_identity
  kind: python_call_eq
  function: herror.__name__.__eq__
  args: ["herror"]
  expected: true
