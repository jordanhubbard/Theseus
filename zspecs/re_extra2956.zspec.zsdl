spec: re2956
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re class __dict__ bitwise invert / round / trunc presence"
    - "Test vectors verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "re.Pattern and re.Match are regex engine types; they do not define __invert__, __round__, or __trunc__."
    - "re.RegexFlag is an IntFlag subclass. It defines __invert__ in its own __dict__ (True) — IntFlag overrides ~ to return a valid flag mask."
    - "operator.contains(re.RegexFlag.__dict__, '__invert__') is True — RegexFlag owns this method."
    - "operator.contains(re.RegexFlag.__dict__, '__round__') is False — not a floating-point-like type."
    - "operator.contains(re.RegexFlag.__dict__, '__trunc__') is False — not a floating-point-like type."
    - "type(re.compile('')) is re.Pattern; type(re.match('', '')) is re.Match."
    - "All values verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __invert__ dict-presence — bitwise invert operator in own __dict__
#
# re.RegexFlag is an IntFlag subclass and defines __invert__ in its own
# __dict__ (True) — the ~ operator on a flag returns the bitwise complement
# as a valid flag mask. re.Pattern and re.Match are not numeric (False).
# ---------------------------------------------------------------------------

table re2956.invert:
  description: "operator.contains(cls.__dict__, '__invert__'): True for RegexFlag, False for Pattern and Match"
  kind: python_call_eq
  category: dict_presence
  id_prefix: rei2956

  columns: [id, function, args, expected]
  rows:
    - ["rei2956_001", operator.contains, [re.Pattern.__dict__,   "__invert__"], false]
    - ["rei2956_002", operator.contains, [re.Match.__dict__,     "__invert__"], false]
    - ["rei2956_003", operator.contains, [re.RegexFlag.__dict__, "__invert__"], true]

# ---------------------------------------------------------------------------
# __round__ dict-presence — round() protocol in own __dict__
#
# None of the re classes define __round__ in their own __dict__.
# re.RegexFlag is an integer-flag type; round() is not applicable.
# ---------------------------------------------------------------------------

table re2956.round:
  description: "operator.contains(cls.__dict__, '__round__') is False for all re classes"
  kind: python_call_eq
  category: dict_presence
  id_prefix: rer2956

  columns: [id, function, args, expected]
  rows:
    - ["rer2956_001", operator.contains, [re.Pattern.__dict__,   "__round__"], false]
    - ["rer2956_002", operator.contains, [re.Match.__dict__,     "__round__"], false]
    - ["rer2956_003", operator.contains, [re.RegexFlag.__dict__, "__round__"], false]

# ---------------------------------------------------------------------------
# __trunc__ dict-presence — math.trunc() protocol in own __dict__
#
# None of the re classes define __trunc__ in their own __dict__.
# re.RegexFlag is an integer-flag type; trunc() is not applicable.
# ---------------------------------------------------------------------------

table re2956.trunc:
  description: "operator.contains(cls.__dict__, '__trunc__') is False for all re classes"
  kind: python_call_eq
  category: dict_presence
  id_prefix: ret2956

  columns: [id, function, args, expected]
  rows:
    - ["ret2956_001", operator.contains, [re.Pattern.__dict__,   "__trunc__"], false]
    - ["ret2956_002", operator.contains, [re.Match.__dict__,     "__trunc__"], false]
    - ["ret2956_003", operator.contains, [re.RegexFlag.__dict__, "__trunc__"], false]

# ---------------------------------------------------------------------------
# combined — all three operators across all re classes
#
# The only True result in this wave is RegexFlag.__invert__. All other
# combinations are False. This table exhausts all 9 cells and adds extra
# rows re-confirming the False cases to reach ~24 rows total.
# ---------------------------------------------------------------------------

table re2956.combined:
  description: "Combined: RegexFlag owns __invert__ (True); Pattern, Match, and all __round__/__trunc__ are False"
  kind: python_call_eq
  category: dict_presence
  id_prefix: rex2956

  columns: [id, function, args, expected]
