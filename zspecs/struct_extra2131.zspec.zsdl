spec: struct_extra2131
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct.zspec.zsdl — covers pack/unpack/calcsize vectors, format strings"
    - "struct_extra.zspec.zsdl — covers Struct attrs, error class name, pack_into/unpack_from"
  notes:
    - "Wave extra2131, theme: exception protocol dict-presence."
    - "Checks whether exception-related protocol attributes (__cause__, __context__, __traceback__, __suppress_context__, __notes__, args, with_traceback) appear in the __dict__ of struct types."
    - "struct.error is an exception type (subclasses Exception via BaseException); despite this, exception protocol instance attrs are NOT in its class __dict__."
    - "struct.error.__dict__ contains only: __module__, __weakref__, __doc__. It does not override any exception protocol attribute."
    - "struct.Struct is a C extension non-exception type; its __dict__ contains method descriptors but none of the exception protocol attributes."
    - "struct.Struct.__dict__ contains: __new__, __repr__, __getattribute__, __setattr__, __delattr__, __init__, iter_unpack, pack, pack_into, unpack, unpack_from, __sizeof__, format, size."
    - "__cause__, __context__, __traceback__, __suppress_context__ are instance attributes set by CPython exception machinery — NOT in any class __dict__."
    - "args and with_traceback are defined in BaseException.__dict__, not re-defined in struct.error.__dict__."
    - "__notes__ is not defined in BaseException.__dict__ on Python 3.9-3.10 (added in 3.11); not in struct.error.__dict__ regardless."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.error — exception protocol attributes absent from class __dict__
# struct.error subclasses Exception but does not define any protocol attr itself.
# ---------------------------------------------------------------------------

table struct_extra2131.error_exception_protocol:
  kind: python_call_eq
  category: exception_protocol
  id_prefix: st2131

  columns: [id, function, args, expected]
  rows:
    - ["st2131001", error.__dict__.__contains__, ["__cause__"],             false]
    - ["st2131002", error.__dict__.__contains__, ["__context__"],           false]
    - ["st2131003", error.__dict__.__contains__, ["__traceback__"],         false]
    - ["st2131004", error.__dict__.__contains__, ["__suppress_context__"],  false]
    - ["st2131005", error.__dict__.__contains__, ["__notes__"],             false]
    - ["st2131006", error.__dict__.__contains__, ["args"],                  false]
    - ["st2131007", error.__dict__.__contains__, ["with_traceback"],        false]

# ---------------------------------------------------------------------------
# struct.Struct — exception protocol attributes absent from class __dict__
# Struct is a non-exception C extension type.
# ---------------------------------------------------------------------------

table struct_extra2131.struct_exception_protocol:
  kind: python_call_eq
  category: exception_protocol
  id_prefix: st2131

  columns: [id, function, args, expected]
  rows:
    - ["st2131008", Struct.__dict__.__contains__, ["__cause__"],             false]
    - ["st2131009", Struct.__dict__.__contains__, ["__context__"],           false]
    - ["st2131010", Struct.__dict__.__contains__, ["__traceback__"],         false]
    - ["st2131011", Struct.__dict__.__contains__, ["__suppress_context__"],  false]
    - ["st2131012", Struct.__dict__.__contains__, ["__notes__"],             false]
    - ["st2131013", Struct.__dict__.__contains__, ["args"],                  false]
    - ["st2131014", Struct.__dict__.__contains__, ["with_traceback"],        false]

# ---------------------------------------------------------------------------
# struct.error — positive presence: own attributes that ARE in __dict__
# struct.error only defines __module__, __weakref__, __doc__ in its own dict.
# ---------------------------------------------------------------------------

table struct_extra2131.error_real_attrs:
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2131

  columns: [id, function, args, expected]
  rows:
    - ["st2131015", error.__dict__.__contains__, ["__module__"],   true]
    - ["st2131016", error.__dict__.__contains__, ["__doc__"],      true]
    - ["st2131017", error.__dict__.__contains__, ["__weakref__"],  true]

# ---------------------------------------------------------------------------
# struct.Struct — positive presence: method descriptors ARE in __dict__
# Confirms __dict__.__contains__ works correctly for the Struct C extension type.
# ---------------------------------------------------------------------------

table struct_extra2131.struct_real_attrs:
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2131

  columns: [id, function, args, expected]
  rows:
    - ["st2131018", Struct.__dict__.__contains__, ["pack"],         true]
    - ["st2131019", Struct.__dict__.__contains__, ["unpack"],       true]
    - ["st2131020", Struct.__dict__.__contains__, ["pack_into"],    true]
    - ["st2131021", Struct.__dict__.__contains__, ["unpack_from"],  true]
    - ["st2131022", Struct.__dict__.__contains__, ["iter_unpack"],  true]
    - ["st2131023", Struct.__dict__.__contains__, ["format"],       true]
    - ["st2131024", Struct.__dict__.__contains__, ["size"],         true]
    - ["st2131025", Struct.__dict__.__contains__, ["__sizeof__"],   true]

# ---------------------------------------------------------------------------
# struct.error — exception protocol attrs not defined on Exception itself
# Confirms the negative result propagates: error is-a Exception, and the
# protocol attrs are on BaseException, not Exception or error.
# ---------------------------------------------------------------------------

invariant struct_extra2131.error.no_exception_class_in_own_dict:
  description: "struct.error.__dict__.__contains__('__init__') == False — struct.error does not override __init__"
  category: dict_membership
  kind: python_call_eq
  function: error.__dict__.__contains__
  args: ["__init__"]
  expected: false

invariant struct_extra2131.error.no_reduce_in_own_dict:
  description: "struct.error.__dict__.__contains__('__reduce__') == False — struct.error does not override __reduce__"
  category: dict_membership
  kind: python_call_eq
  function: error.__dict__.__contains__
  args: ["__reduce__"]
  expected: false
