spec: hashlib_extra255
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
  notes:
    - "Wave 255 theme: hashlib hash constructor __name__ identity for sha3 and blake2 algorithms / algorithms_guaranteed membership for additional algorithms."
    - "hashlib.sha3_224.__name__ == 'openssl_sha3_224'. OpenSSL-backed constructor carries 'openssl_' prefix. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_384.__name__ == 'openssl_sha3_384'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__name__ == 'openssl_sha3_512'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__name__ == 'blake2b'. blake2b is a _blake2 C extension type, not an OpenSSL builtin, so its __name__ lacks the 'openssl_' prefix. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__name__ == 'blake2s'. Same as blake2b — _blake2 extension type, no 'openssl_' prefix. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_224.__qualname__ == 'openssl_sha3_224'. For C builtins, __qualname__ == __name__ at top level. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__qualname__ == 'blake2b'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha3_224' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha3_384' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'sha3_512' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'blake2b' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "'blake2s' in hashlib.algorithms_guaranteed == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: sha3_224/sha3_384/sha3_512 are OpenSSL-backed (type is builtin_function_or_method); blake2b/blake2s are _blake2 extension types (type is 'type'). This explains the naming difference."
    - "Note: algorithms_guaranteed is a frozenset of 14 algorithm names that are available on all Python platforms."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha3_224.__name__.__eq__('openssl_sha3_224')
# hashlib.sha3_384.__name__.__eq__('openssl_sha3_384')
# hashlib.sha3_512.__name__.__eq__('openssl_sha3_512')
# hashlib.blake2b.__name__.__eq__('blake2b')
# hashlib.blake2s.__name__.__eq__('blake2s')
#
# Wave 255 theme: sha3 and blake2 constructor __name__ identity.
#
# sha3_224, sha3_384, and sha3_512 are SHA-3 family algorithms backed by OpenSSL
# via the _hashlib C extension. Their __name__ carries the 'openssl_' prefix
# (e.g., 'openssl_sha3_224'). blake2b and blake2s are provided by the separate
# _blake2 C extension (not OpenSSL), so their __name__ is simply 'blake2b' and
# 'blake2s' without any prefix. For all C builtins at top level, __qualname__
# equals __name__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra255.sha3_blake2_constructor_names:
  description: "hashlib sha3/blake2 constructor __name__ identity — sha3_224/__name__.__eq__('openssl_sha3_224')==True / sha3_384/__name__.__eq__('openssl_sha3_384')==True / sha3_512/__name__.__eq__('openssl_sha3_512')==True / blake2b/__name__.__eq__('blake2b')==True / blake2s/__name__.__eq__('blake2s')==True — sha3 constructors are OpenSSL-backed (_hashlib C extension) and carry 'openssl_' prefix; blake2b/blake2s are _blake2 extension types without prefix; wave 255 theme: sha3 and blake2 constructor __name__ identity; verified with Python 3.14.3"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibsha3blake255

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_224_name,  sha3_224.__name__.__eq__,  ["openssl_sha3_224"], true, "sha3_224.__name__ is 'openssl_sha3_224'; OpenSSL-backed SHA-3 constructor from _hashlib extension"]
    - [sha3_384_name,  sha3_384.__name__.__eq__,  ["openssl_sha3_384"], true, "sha3_384.__name__ is 'openssl_sha3_384'; OpenSSL-backed SHA-3 constructor from _hashlib extension"]
    - [sha3_512_name,  sha3_512.__name__.__eq__,  ["openssl_sha3_512"], true, "sha3_512.__name__ is 'openssl_sha3_512'; OpenSSL-backed SHA-3 constructor from _hashlib extension"]
    - [blake2b_name,   blake2b.__name__.__eq__,   ["blake2b"],          true, "blake2b.__name__ is 'blake2b'; _blake2 extension type, no 'openssl_' prefix"]
    - [blake2s_name,   blake2s.__name__.__eq__,   ["blake2s"],          true, "blake2s.__name__ is 'blake2s'; _blake2 extension type, no 'openssl_' prefix"]

# ---------------------------------------------------------------------------
# hashlib.sha3_224.__qualname__.__eq__('openssl_sha3_224')
# hashlib.blake2b.__qualname__.__eq__('blake2b')
# hashlib.blake2s.__qualname__.__eq__('blake2s')
#
# Wave 255 theme: sha3 and blake2 constructor __qualname__ identity.
#
# For C builtins at top level, __qualname__ equals __name__ (no class prefix is
# present). sha3_224.__qualname__ is 'openssl_sha3_224' (same as __name__).
# blake2b.__qualname__ is 'blake2b' and blake2s.__qualname__ is 'blake2s'.
# This cross-checks the __qualname__==__name__ invariant for these constructors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra255.sha3_blake2_constructor_qualnames:
  description: "hashlib sha3/blake2 constructor __qualname__ identity — sha3_224/__qualname__.__eq__('openssl_sha3_224')==True / blake2b/__qualname__.__eq__('blake2b')==True / blake2s/__qualname__.__eq__('blake2s')==True — for C builtins at top level __qualname__==__name__; sha3_224 qualname carries openssl_ prefix; blake2b/blake2s qualnames have no prefix; wave 255 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibsha3blake255

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_224_qualname, sha3_224.__qualname__.__eq__, ["openssl_sha3_224"], true, "sha3_224.__qualname__ == 'openssl_sha3_224'; __qualname__==__name__ for top-level C builtins"]
    - [blake2b_qualname,  blake2b.__qualname__.__eq__,  ["blake2b"],          true, "blake2b.__qualname__ == 'blake2b'; __qualname__==__name__ for top-level C extension types"]
    - [blake2s_qualname,  blake2s.__qualname__.__eq__,  ["blake2s"],          true, "blake2s.__qualname__ == 'blake2s'; __qualname__==__name__ for top-level C extension types"]

# ---------------------------------------------------------------------------
# 'sha3_224' in hashlib.algorithms_guaranteed
# 'sha3_384' in hashlib.algorithms_guaranteed
# 'sha3_512' in hashlib.algorithms_guaranteed
# 'blake2b' in hashlib.algorithms_guaranteed
# 'blake2s' in hashlib.algorithms_guaranteed
#
# Wave 255 theme: algorithms_guaranteed membership for sha3 and blake2 algorithms.
#
# hashlib.algorithms_guaranteed is a frozenset of algorithm name strings that are
# available on all Python platforms. The sha3 family (sha3_224, sha3_384, sha3_512)
# and BLAKE2 family (blake2b, blake2s) are part of the guaranteed set. The
# __contains__ method returns True for each of these names. Verified Python
# 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra255.algorithms_guaranteed_sha3_blake2_membership:
  description: "hashlib.algorithms_guaranteed membership for sha3/blake2 algorithms — algorithms_guaranteed.__contains__('sha3_224')==True / __contains__('sha3_384')==True / __contains__('sha3_512')==True / __contains__('blake2b')==True / __contains__('blake2s')==True — these five algorithms are in the guaranteed cross-platform set; algorithms_guaranteed is a frozenset; wave 255 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: set_membership
  id_prefix: hashlibsha3blake255

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_224_in_guaranteed, algorithms_guaranteed.__contains__, ["sha3_224"], true, "'sha3_224' is in algorithms_guaranteed; SHA-3 available on all Python platforms"]
    - [sha3_384_in_guaranteed, algorithms_guaranteed.__contains__, ["sha3_384"], true, "'sha3_384' is in algorithms_guaranteed; SHA-3 available on all Python platforms"]
    - [sha3_512_in_guaranteed, algorithms_guaranteed.__contains__, ["sha3_512"], true, "'sha3_512' is in algorithms_guaranteed; SHA-3 available on all Python platforms"]
    - [blake2b_in_guaranteed,  algorithms_guaranteed.__contains__, ["blake2b"],  true, "'blake2b' is in algorithms_guaranteed; BLAKE2b available on all Python platforms"]
    - [blake2s_in_guaranteed,  algorithms_guaranteed.__contains__, ["blake2s"],  true, "'blake2s' is in algorithms_guaranteed; BLAKE2s available on all Python platforms"]

# ---------------------------------------------------------------------------
# hashlib.sha3_224.__name__.__eq__('openssl_sha3_224') — standalone
#
# hashlib.sha3_224.__name__ is 'openssl_sha3_224'. sha3_224 is the SHA3-224
# algorithm from the SHA-3 family standardized in FIPS 202. On macOS/Darwin,
# it is implemented via OpenSSL through the _hashlib C extension, so its __name__
# carries the 'openssl_' prefix. The type of the sha3_224 constructor is
# 'builtin_function_or_method'. In contrast, blake2b is a 'type' object from
# the _blake2 extension and lacks the prefix. This is the first standalone
# anchor for sha3_224.__name__ under hashlibsha3blake255.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra255.sha3_224_name_openssl:
  description: "hashlib.sha3_224.__name__.__eq__('openssl_sha3_224') == True — sha3_224 is the SHA3-224 algorithm backed by OpenSSL via _hashlib C extension; its __name__ carries the 'openssl_' prefix; type is builtin_function_or_method (unlike blake2b which is a 'type' from _blake2); first standalone for sha3_224.__name__ under hashlibsha3blake255; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: type_identity
  kind: python_call_eq
  function: sha3_224.__name__.__eq__
  args: ["openssl_sha3_224"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__name__.__eq__('blake2b') — standalone
#
# hashlib.blake2b.__name__ is 'blake2b'. Unlike the OpenSSL-backed SHA-3 constructors
# (which have 'openssl_' prefixed names), blake2b is provided by the _blake2 C
# extension. The _blake2 module implements BLAKE2b and BLAKE2s natively without
# going through OpenSSL, so the constructor names are the plain algorithm names
# without any prefix. blake2b.__qualname__ is also 'blake2b' (same as __name__
# for top-level C extension types). This is the first standalone anchor for
# blake2b.__name__ under hashlibsha3blake255.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra255.blake2b_name_plain:
  description: "hashlib.blake2b.__name__.__eq__('blake2b') == True — blake2b is provided by the _blake2 C extension (not OpenSSL), so its __name__ is plain 'blake2b' without 'openssl_' prefix; blake2b is a 'type' object (not builtin_function_or_method); __qualname__=='blake2b'=__name__; first standalone for blake2b.__name__ under hashlibsha3blake255; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: type_identity
  kind: python_call_eq
  function: blake2b.__name__.__eq__
  args: ["blake2b"]
  expected: true

# ---------------------------------------------------------------------------
# 'blake2b' in hashlib.algorithms_guaranteed — standalone
#
# 'blake2b' is in hashlib.algorithms_guaranteed. hashlib.algorithms_guaranteed
# is a frozenset of hash algorithm names that are guaranteed to be available
# on every Python platform. BLAKE2b was added to the guaranteed set in
# Python 3.6 when the _blake2 C extension was incorporated into CPython's
# standard library build. This means users can rely on blake2b being available
# without checking algorithms_available first. This is the first standalone
# anchor for blake2b in algorithms_guaranteed under hashlibsha3blake255.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra255.blake2b_in_algorithms_guaranteed:
  description: "hashlib.algorithms_guaranteed.__contains__('blake2b') == True — 'blake2b' is in the guaranteed cross-platform set; blake2b was added to CPython's _blake2 extension in Python 3.6 and is available on all platforms; users can rely on blake2b without checking algorithms_available; first standalone for blake2b membership under hashlibsha3blake255; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: set_membership
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["blake2b"]
  expected: true
