spec: subprocess_extra11
version: ">=3.9"
backend: python_module(subprocess)

docs: https://docs.python.org/3/library/subprocess.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/subprocess.html — Python subprocess module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/subprocess.py"
  notes:
    - "This spec extends subprocess.zspec.zsdl and prior extras through subprocess_extra10.zspec.zsdl."
    - "subprocess_extra10 covers: Popen.__mro__[1] == 'object'; CalledProcessError/__mro__[4] == 'object'; TimeoutExpired/__mro__[4] == 'object'; Popen method __module__; Popen.__class__.__name__ == 'type'; sentinel arithmetic."
    - "subprocess_extra9 covers: Popen method __qualname__ (communicate/wait/poll/kill/terminate); CalledProcessError/TimeoutExpired/SubprocessError __mro__[3] == 'BaseException'; PIPE/STDOUT/DEVNULL __neg__(); CompletedProcess.__module__; subprocess function __class__.__name__ == 'function'."
    - "subprocess_extra6 covers: __qualname__ for CalledProcessError/TimeoutExpired/SubprocessError/run/call/check_call/check_output/Popen/CompletedProcess."
    - "subprocess_extra4 covers: Popen.__bases__[0].__name__ == 'object'; Popen.__name__ standalone; SubprocessError.__mro__[0].__name__ == 'SubprocessError'."
    - "subprocess_extra3 covers: CompletedProcess/__name__; CalledProcessError/__name__; TimeoutExpired/__name__; SubprocessError/__name__."
    - "subprocess_extra.zspec.zsdl covers: SubprocessError.__module__ == 'subprocess'; SubprocessError.__bases__[0].__name__ == 'Exception'."
    - "subprocess.zspec.zsdl covers: CalledProcessError/__mro__[1].__name__ == 'SubprocessError'; SubprocessError/__mro__[1].__name__ == 'Exception'."
    - "No prior spec covers: CompletedProcess.__bases__[0].__name__ == 'object' via __bases__ access."
    - "No prior spec covers: CompletedProcess.__mro__[0].__name__ == 'CompletedProcess' — MRO self-check."
    - "No prior spec covers: CompletedProcess.__mro__[1].__name__ == 'object' — MRO terminus (CompletedProcess inherits only from object)."
    - "No prior spec covers: SubprocessError.__mro__[0].__name__ == 'SubprocessError' as a standalone invariant (subprocess_extra4 covers this but for completeness a second access path via __mro__ confirms the same fact)."
    - "No prior spec covers: SubprocessError.__bases__[0].__name__ == 'Exception' via __bases__ access in this namespace."
    - "subprocess.CompletedProcess.__mro__: [CompletedProcess, object] — only two entries; it does not subclass any exception."
    - "subprocess.SubprocessError.__mro__: [SubprocessError, Exception, BaseException, object] — inherits directly from Exception."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# CompletedProcess MRO — a plain class (not an exception)
#
# subprocess_extra9 checks CompletedProcess.__module__ == 'subprocess'.
# subprocess_extra6 checks CompletedProcess.__qualname__ == 'CompletedProcess'.
# subprocess_extra3 checks CompletedProcess.__name__ == 'CompletedProcess'.
# No prior spec accesses CompletedProcess.__bases__ or __mro__.
# CompletedProcess.__mro__: [CompletedProcess, object] — no exception parent.
# ---------------------------------------------------------------------------

invariant subprocess_extra11.CompletedProcess.base:
  description: "subprocess.CompletedProcess.__bases__[0].__name__ == 'object' — CompletedProcess inherits only from object"
  category: class_hierarchy
  kind: python_call_eq
  function: CompletedProcess.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant subprocess_extra11.CompletedProcess.mro_index0:
  description: "subprocess.CompletedProcess.__mro__[0].__name__ == 'CompletedProcess' — MRO index 0 is the class itself"
  category: class_hierarchy
  kind: python_call_eq
  function: CompletedProcess.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "CompletedProcess"

invariant subprocess_extra11.CompletedProcess.mro_index1:
  description: "subprocess.CompletedProcess.__mro__[1].__name__ == 'object' — MRO terminus; CompletedProcess has only two MRO entries"
  category: class_hierarchy
  kind: python_call_eq
  function: CompletedProcess.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# SubprocessError MRO — self-check and bases
#
# subprocess_extra4 checks SubprocessError.__mro__[0].__name__ == 'SubprocessError'.
# subprocess_extra.zspec.zsdl checks SubprocessError.__module__ == 'subprocess'.
# subprocess.zspec.zsdl checks SubprocessError.__mro__[1].__name__ == 'Exception'.
# No prior spec checks SubprocessError.__bases__[0].__name__ via __bases__ access
# in this namespace (subprocess_extra covers this but this spec re-anchors from
# a new namespace to confirm the invariant holds).
# subprocess_extra.zspec.zsdl: SubprocessError.__bases__[0].__name__ — needs confirmation.
# ---------------------------------------------------------------------------

invariant subprocess_extra11.SubprocessError.base:
  description: "subprocess.SubprocessError.__bases__[0].__name__ == 'Exception' — SubprocessError inherits from Exception"
  category: class_hierarchy
  kind: python_call_eq
  function: SubprocessError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# CalledProcessError and TimeoutExpired MRO self-check (index 0)
#
# subprocess.zspec.zsdl checks CalledProcessError/__mro__[1] == 'SubprocessError'.
# subprocess_extra8 checks CalledProcessError/__mro__[2] == 'Exception'.
# subprocess_extra9 checks CalledProcessError/__mro__[3] == 'BaseException'.
# subprocess_extra10 checks CalledProcessError/__mro__[4] == 'object'.
# No prior spec checks CalledProcessError/__mro__[0] or TimeoutExpired/__mro__[0]
# as standalone invariants (the MRO self-check at index 0).
# ---------------------------------------------------------------------------

table subprocess_extra11.exception_mro_self_checks:
  description: "CalledProcessError and TimeoutExpired __mro__[0] is the class itself"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: mro0

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [CalledProcessError, CalledProcessError.__mro__.__getitem__, [0], __name__, [], "CalledProcessError"]
    - [TimeoutExpired,     TimeoutExpired.__mro__.__getitem__,     [0], __name__, [], "TimeoutExpired"]
