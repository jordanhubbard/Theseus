spec: multiprocessing_extra1081
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing Value, Array, Manager, Pool, and Pipe documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks multiprocessing.Value/Array module and qualname, multiprocessing.Manager class module, multiprocessing.Pool class module/qualname, multiprocessing.Pipe function module/qualname — behaviors not covered by extra1051 or extra1066"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra1081.value_and_array_identity:
  description: "multiprocessing.Value and Array module and qualname identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: mp1081va
  columns: [id, function, args, expected]
  rows:
    - [mp1081va001, multiprocessing.Value.__module__.__eq__,          ["multiprocessing.sharedctypes"], true]
    - [mp1081va002, multiprocessing.Value.__qualname__.__eq__,        ["Value"],                        true]
    - [mp1081va003, multiprocessing.Value.__class__.__name__.__eq__,  ["function"],                     true]
    - [mp1081va004, multiprocessing.Array.__module__.__eq__,          ["multiprocessing.sharedctypes"], true]
    - [mp1081va005, multiprocessing.Array.__qualname__.__eq__,        ["Array"],                        true]
    - [mp1081va006, multiprocessing.Array.__class__.__name__.__eq__,  ["function"],                     true]
    - [mp1081va007, multiprocessing.Array.__name__.__eq__,            ["Array"],                        true]

table multiprocessing_extra1081.pool_module_identity:
  description: "multiprocessing.Pool class module and qualname identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: mp1081pm
  columns: [id, function, args, expected]
  rows:
    - [mp1081pm001, multiprocessing.Pool.__module__.__eq__,          ["multiprocessing.pool"], true]
    - [mp1081pm002, multiprocessing.Pool.__qualname__.__eq__,        ["Pool"],                 true]
    - [mp1081pm003, multiprocessing.Pool.__name__.__eq__,            ["Pool"],                 true]
    - [mp1081pm004, multiprocessing.Pool.__class__.__name__.__eq__,  ["type"],                 true]
    - [mp1081pm005, multiprocessing.Pool.map.__qualname__.__eq__,    ["Pool.map"],             true]
    - [mp1081pm006, multiprocessing.Pool.apply.__qualname__.__eq__,  ["Pool.apply"],           true]
    - [mp1081pm007, multiprocessing.Pool.close.__qualname__.__eq__,  ["Pool.close"],           true]

table multiprocessing_extra1081.manager_and_pipe_identity:
  description: "multiprocessing.Manager class module and Pipe function module/qualname identity"
  kind: python_call_eq
  category: function_identity
  id_prefix: mp1081mp
  columns: [id, function, args, expected]
  rows:
    - [mp1081mp001, multiprocessing.Manager.__module__.__eq__,           ["multiprocessing.managers"], true]
    - [mp1081mp002, multiprocessing.Manager.__qualname__.__eq__,         ["SyncManager"],              true]
    - [mp1081mp003, multiprocessing.Manager.__class__.__name__.__eq__,   ["type"],                     true]
    - [mp1081mp004, multiprocessing.Pipe.__module__.__eq__,              ["multiprocessing.connection"], true]
    - [mp1081mp005, multiprocessing.Pipe.__qualname__.__eq__,            ["Pipe"],                     true]
    - [mp1081mp006, multiprocessing.Pipe.__name__.__eq__,                ["Pipe"],                     true]
    - [mp1081mp007, multiprocessing.Pipe.__class__.__name__.__eq__,      ["function"],                 true]
