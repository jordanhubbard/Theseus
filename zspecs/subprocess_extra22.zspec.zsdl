spec: subprocess_extra22
version: ">=3.9"
backend: python_module(subprocess)

docs: https://docs.python.org/3/library/subprocess.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/subprocess.html — Python subprocess module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/subprocess.py"
    - "subprocess_extra21.zspec.zsdl — covers __module__.__len__()==10 and __name__.__len__() for Popen/CompletedProcess/CalledProcessError/TimeoutExpired/SubprocessError/run; NOT __qualname__.__len__() for any Popen instance methods."
  notes:
    - "This spec extends subprocess_extra21.zspec.zsdl."
    - "Prior specs covered: Popen/CompletedProcess/CalledProcessError/TimeoutExpired/SubprocessError/run __module__.__len__()==10 and __name__.__len__(); Popen.__init__.__name__; class __qualname__/__module__/__name__ values; PIPE/STDOUT/DEVNULL; exception inheritance."
    - "This spec covers: Popen method __qualname__.__len__() for __init__/communicate/wait/poll/kill/terminate; Popen method __name__.__len__() for __init__/communicate/wait/poll/kill/terminate; Popen method __module__.__len__()==10 for all six methods."
    - "Popen.__init__.__qualname__=='Popen.__init__' (len 14). Verified."
    - "Popen.communicate.__qualname__=='Popen.communicate' (len 17). Verified."
    - "Popen.wait.__qualname__=='Popen.wait' (len 10). Verified."
    - "Popen.poll.__qualname__=='Popen.poll' (len 10). Verified."
    - "Popen.kill.__qualname__=='Popen.kill' (len 10). Verified."
    - "Popen.terminate.__qualname__=='Popen.terminate' (len 15). Verified."
    - "Popen method __name__ lengths: __init__=8, communicate=11, wait=4, poll=4, kill=4, terminate=9. Verified."
    - "All Popen methods have __module__=='subprocess' (len 10). Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: Popen method __qualname__.__len__()
#
# No prior subprocess spec checks __qualname__.__len__() for Popen instance
# methods. All qualnames follow the 'Popen.METHOD' pattern. Lengths:
#   __init__    -> 'Popen.__init__'    len 14
#   communicate -> 'Popen.communicate' len 17
#   wait        -> 'Popen.wait'        len 10
#   poll        -> 'Popen.poll'        len 10
#   kill        -> 'Popen.kill'        len 10
#   terminate   -> 'Popen.terminate'   len 15
# Verified: all values above.
# ---------------------------------------------------------------------------

table subprocess_extra22.popen_method_qualname_lengths:
  description: "__qualname__.__len__() for Popen instance methods — pattern 'Popen.METHOD'"
  kind: python_call_eq
  category: method_attrs
  id_prefix: pmqlen22

  columns: [id, function, args, expected]
  rows:
    - [init,        "Popen.__init__.__qualname__.__len__",    [], 14]
    - [communicate, Popen.communicate.__qualname__.__len__,   [], 17]
    - [wait,        Popen.wait.__qualname__.__len__,          [], 10]
    - [poll,        Popen.poll.__qualname__.__len__,          [], 10]
    - [kill,        Popen.kill.__qualname__.__len__,          [], 10]
    - [terminate,   Popen.terminate.__qualname__.__len__,     [], 15]

# ---------------------------------------------------------------------------
# Table: Popen method __name__.__len__()
#
# No prior subprocess spec checks __name__.__len__() for Popen instance methods.
# Lengths: __init__=8, communicate=11, wait=4, poll=4, kill=4, terminate=9.
# Verified: all values above.
# ---------------------------------------------------------------------------

table subprocess_extra22.popen_method_name_lengths:
  description: "__name__.__len__() for Popen instance methods"
  kind: python_call_eq
  category: method_attrs
  id_prefix: pmnlen22

  columns: [id, function, args, expected]
  rows:
    - [init,        "Popen.__init__.__name__.__len__",    [], 8]
    - [communicate, Popen.communicate.__name__.__len__,   [], 11]
    - [wait,        Popen.wait.__name__.__len__,          [], 4]
    - [poll,        Popen.poll.__name__.__len__,          [], 4]
    - [kill,        Popen.kill.__name__.__len__,          [], 4]
    - [terminate,   Popen.terminate.__name__.__len__,     [], 9]

# ---------------------------------------------------------------------------
# Standalone invariants — Popen method __qualname__.__len__()
# ---------------------------------------------------------------------------

invariant subprocess_extra22.Popen_init.qualname_len:
  description: "subprocess.Popen.__init__.__qualname__.__len__() == 14 — 'Popen.__init__' has 14 characters"
  category: method_attrs
  kind: python_call_eq
  function: "Popen.__init__.__qualname__.__len__"
  args: []
  expected: 14

invariant subprocess_extra22.Popen_communicate.qualname_len:
  description: "subprocess.Popen.communicate.__qualname__.__len__() == 17 — 'Popen.communicate' has 17 characters"
  category: method_attrs
  kind: python_call_eq
  function: Popen.communicate.__qualname__.__len__
  args: []
  expected: 17

invariant subprocess_extra22.Popen_wait.qualname_len:
  description: "subprocess.Popen.wait.__qualname__.__len__() == 10 — 'Popen.wait' has 10 characters"
  category: method_attrs
  kind: python_call_eq
  function: Popen.wait.__qualname__.__len__
  args: []
  expected: 10

invariant subprocess_extra22.Popen_poll.qualname_len:
  description: "subprocess.Popen.poll.__qualname__.__len__() == 10 — 'Popen.poll' has 10 characters"
  category: method_attrs
  kind: python_call_eq
  function: Popen.poll.__qualname__.__len__
  args: []
  expected: 10

invariant subprocess_extra22.Popen_kill.qualname_len:
  description: "subprocess.Popen.kill.__qualname__.__len__() == 10 — 'Popen.kill' has 10 characters"
  category: method_attrs
  kind: python_call_eq
  function: Popen.kill.__qualname__.__len__
  args: []
  expected: 10

invariant subprocess_extra22.Popen_terminate.qualname_len:
  description: "subprocess.Popen.terminate.__qualname__.__len__() == 15 — 'Popen.terminate' has 15 characters"
  category: method_attrs
  kind: python_call_eq
  function: Popen.terminate.__qualname__.__len__
  args: []
  expected: 15
