spec: re_extra751
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

docs:
  summary: Verifies re module RegexFlag constant values and class membership
  tags: [re, regex, constants, RegexFlag, stdlib]

provenance:
  derived_from:
    - https://docs.python.org/3/library/re.html#flags
  not_derived_from: []
  notes:
    - Covers integer values and class name of RegexFlag members; values are defined by CPython and must not change across minor versions
  created_at: "2026-04-12"

table re_extra751.name:
  description: re module RegexFlag constant value and class name checks
  kind: python_call_eq
  category: constants
  id_prefix: re751xx
  columns: [id, function, args, expected]
  rows:
    - [re751xx001, re.IGNORECASE.value.__eq__, [2], true]
    - [re751xx002, re.MULTILINE.value.__eq__, [8], true]
    - [re751xx003, re.DOTALL.value.__eq__, [16], true]
    - [re751xx004, re.VERBOSE.value.__eq__, [64], true]
    - [re751xx005, re.UNICODE.value.__eq__, [32], true]
    - [re751xx006, re.ASCII.value.__eq__, [256], true]
    - [re751xx007, re.LOCALE.value.__eq__, [4], true]
    - [re751xx008, re.IGNORECASE.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [re751xx009, re.MULTILINE.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [re751xx010, re.DOTALL.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [re751xx011, re.VERBOSE.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [re751xx012, re.ASCII.__class__.__name__.__eq__, ["RegexFlag"], true]
