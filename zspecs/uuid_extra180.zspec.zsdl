spec: uuid_extra180
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "uuid.__name__ == 'uuid' — len=4; the module's own __name__."
    - "uuid.__package__ == '' — empty string; uuid is a top-level module, not None."
    - "uuid.UUID.__mro__ len == 2 — [UUID, object]; UUID has no intermediate base classes."
    - "uuid.UUID.__bases__[0].__name__ == 'object' — UUID directly extends object."
    - "uuid.UUID.__class__.__name__ == 'type' — UUID is a regular class created by type."
    - "uuid.UUID.__doc__.__class__.__name__ == 'str' — UUID class has a str docstring."
    - "uuid.SafeUUID.__mro__ len == 3 — [SafeUUID, Enum, object]; plain Enum subclass."
    - "uuid.SafeUUID.__bases__[0].__name__ == 'Enum' — SafeUUID directly extends Enum."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: uuid module __name__ and __package__ identity
#
# uuid.__name__    == 'uuid'  (len=4)
# uuid.__package__ == ''      (empty string; top-level module, not None)
#
# The uuid module is a pure Python module in Lib/uuid.py.  Its __name__
# is 'uuid' and __package__ is the empty string because it is a top-level
# module with no sub-package hierarchy.
# ---------------------------------------------------------------------------

table uuid_extra180.module_name_package:
  description: "uuid module __name__ and __package__ identity; new to extra180"
  kind: python_call_eq
  category: identity
  id_prefix: uuidmodule180

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name_eq,
       uuid.__name__.__eq__,
       ["uuid"],
       true,
       "uuid.__name__.__eq__('uuid') == True — module name; len=4; new to extra180"]
    - [mod_name_len,
       uuid.__name__.__len__,
       [],
       4,
       "uuid.__name__.__len__() == 4 — 'uuid' has 4 characters; new to extra180"]
    - [mod_pkg_eq,
       uuid.__package__.__eq__,
       [""],
       true,
       "uuid.__package__.__eq__('') == True — top-level module; __package__ is empty string not None; new to extra180"]
    - [mod_pkg_len,
       uuid.__package__.__len__,
       [],
       0,
       "uuid.__package__.__len__() == 0 — empty string has 0 characters; new to extra180"]

# ---------------------------------------------------------------------------
# Table 2: uuid.UUID class MRO and bases identity
#
# uuid.UUID.__mro__.__len__()        == 2   ([UUID, object])
# uuid.UUID.__bases__[0].__name__    == 'object'
# uuid.UUID.__class__.__name__       == 'type'
# uuid.UUID.__doc__.__class__.__name__ == 'str'
#
# UUID is a plain Python class with no intermediate base classes.  Its MRO
# is exactly [UUID, object], giving __mro__.__len__() == 2.  The class is
# constructed by the built-in metaclass 'type'.
# ---------------------------------------------------------------------------

table uuid_extra180.uuid_class_mro:
  description: "uuid.UUID class MRO, bases, metaclass, and doc identity; new to extra180"
  kind: python_call_eq
  category: identity
  id_prefix: uuidmodule180

  columns: [id, function, args, expected, description]
  rows:
    - [uuid_mro_len,
       uuid.UUID.__mro__.__len__,
       [],
       2,
       "uuid.UUID.__mro__.__len__() == 2 — MRO is [UUID, object]; no intermediate base classes; new to extra180"]
    - [uuid_bases_name,
       uuid.UUID.__bases__[0].__name__.__eq__,
       ["object"],
       true,
       "uuid.UUID.__bases__[0].__name__.__eq__('object') == True — UUID directly extends object; new to extra180"]
    - [uuid_class_name,
       uuid.UUID.__class__.__name__.__eq__,
       ["type"],
       true,
       "uuid.UUID.__class__.__name__.__eq__('type') == True — UUID is a regular class created by built-in type; new to extra180"]
    - [uuid_doc_class,
       uuid.UUID.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "uuid.UUID.__doc__.__class__.__name__.__eq__('str') == True — UUID class has a str docstring; new to extra180"]

# ---------------------------------------------------------------------------
# Table 3: uuid.SafeUUID class MRO and bases identity
#
# uuid.SafeUUID.__mro__.__len__()     == 3   ([SafeUUID, Enum, object])
# uuid.SafeUUID.__bases__[0].__name__ == 'Enum'
# uuid.SafeUUID.__class__.__name__    == 'EnumType'
#
# SafeUUID is a plain Enum subclass with no integer mixin, so its MRO is
# [SafeUUID, Enum, object] — exactly 3 elements.  The metaclass is EnumType
# (the Enum metaclass, previously named EnumMeta, renamed in Python 3.11).
# ---------------------------------------------------------------------------

table uuid_extra180.safeuuid_class_mro:
  description: "uuid.SafeUUID class MRO, bases, and metaclass identity; new to extra180"
  kind: python_call_eq
  category: identity
  id_prefix: uuidmodule180

  columns: [id, function, args, expected, description]
  rows:
    - [safeuuid_mro_len,
       uuid.SafeUUID.__mro__.__len__,
       [],
       3,
       "uuid.SafeUUID.__mro__.__len__() == 3 — MRO is [SafeUUID, Enum, object]; plain Enum, no int mixin; new to extra180"]
    - [safeuuid_bases_name,
       uuid.SafeUUID.__bases__[0].__name__.__eq__,
       ["Enum"],
       true,
       "uuid.SafeUUID.__bases__[0].__name__.__eq__('Enum') == True — SafeUUID directly extends Enum; new to extra180"]
    - [safeuuid_class_name,
       uuid.SafeUUID.__class__.__name__.__eq__,
       ["EnumType"],
       true,
       "uuid.SafeUUID.__class__.__name__.__eq__('EnumType') == True — SafeUUID metaclass is EnumType (Python 3.11+ name); new to extra180"]
    - [safeuuid_qualname,
       uuid.SafeUUID.__qualname__.__eq__,
       ["SafeUUID"],
       true,
       "uuid.SafeUUID.__qualname__.__eq__('SafeUUID') == True — qualified name matches simple name; new to extra180"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra180
# ---------------------------------------------------------------------------

invariant uuid_extra180.module_name_is_uuid:
  description: "uuid.__name__ == 'uuid' — module name; len=4; new to extra180"
  category: identity
  kind: python_call_eq
  function: uuid.__name__.__eq__
  args: ["uuid"]
  expected: true

invariant uuid_extra180.module_package_is_empty:
  description: "uuid.__package__ == '' — top-level module; empty string not None; new to extra180"
  category: identity
  kind: python_call_eq
  function: uuid.__package__.__eq__
  args: [""]
  expected: true

invariant uuid_extra180.uuid_mro_len:
  description: "uuid.UUID.__mro__.__len__() == 2 — MRO is [UUID, object]; no intermediate base classes; new to extra180"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.__mro__.__len__
  args: []
  expected: 2

invariant uuid_extra180.uuid_bases_object:
  description: "uuid.UUID.__bases__[0].__name__ == 'object' — UUID directly extends object; new to extra180"
  category: identity
  kind: python_call_eq
  function: "uuid.UUID.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant uuid_extra180.uuid_class_is_type:
  description: "uuid.UUID.__class__.__name__ == 'type' — UUID is a regular class created by built-in type; new to extra180"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant uuid_extra180.uuid_doc_is_str:
  description: "uuid.UUID.__doc__.__class__.__name__ == 'str' — UUID class has a str docstring; new to extra180"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant uuid_extra180.safeuuid_mro_len:
  description: "uuid.SafeUUID.__mro__.__len__() == 3 — MRO is [SafeUUID, Enum, object]; plain Enum, no int mixin; new to extra180"
  category: identity
  kind: python_call_eq
  function: uuid.SafeUUID.__mro__.__len__
  args: []
  expected: 3

invariant uuid_extra180.safeuuid_bases_enum:
  description: "uuid.SafeUUID.__bases__[0].__name__ == 'Enum' — SafeUUID directly extends Enum; new to extra180"
  category: identity
  kind: python_call_eq
  function: uuid.SafeUUID.__bases__[0].__name__.__eq__
  args: ["Enum"]
  expected: true
