spec: hmac_extra19
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html
rfcs:
  - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"
  - "RFC 2202 — Test Cases for HMAC-MD5 and HMAC-SHA-1"

provenance:
  derived_from:
    - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication, February 1997"
    - "RFC 2202 — Test Cases for HMAC-MD5 and HMAC-SHA-1, September 1997"
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
    - "hmac_extra18.zspec.zsdl — covers new(sha256) hexdigest class name and length; compare_digest str equal/unequal/bytes equal."
    - "hmac_extra17.zspec.zsdl — covers new/compare_digest/digest __name__/__module__; HMAC __qualname__/__module__/__bases__."
    - "hmac_extra16.zspec.zsdl — covers hexdigest/digest lengths for md5/sha256/sha512; function __name__/__module__ table."
    - "hmac_extra14.zspec.zsdl — covers hexdigest is str; hexdigest_len sha256/sha1/md5; compare_digest equal/unequal; sha256 digest_size."
    - "hmac_extra13.zspec.zsdl — covers RFC 2202/4231 test vectors; compare_digest/new __name__; sha256 name/block_size."
  notes:
    - "This spec extends hmac through hmac_extra18; it does NOT duplicate invariants present in those files."
    - "Focus: new(b'key', b'msg', 'sha1') digest_size and block_size; hmac.digest(sha256) return length; new/__qualname__ and digest/__qualname__; sha1 HMAC hexdigest length."
    - "hmac.new(b'key', b'msg', 'sha1').digest_size == 20: SHA-1 HMAC produces a 160-bit (20-byte) digest. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.new(b'key', b'msg', 'sha1').block_size == 64: SHA-1 uses 512-bit (64-byte) blocks. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.digest(b'key', b'msg', 'sha256').__len__() == 32: SHA-256 HMAC raw digest is 32 bytes. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.new.__qualname__ == 'new': standard __qualname__ for a module-level function. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.digest.__qualname__ == 'digest': standard __qualname__ for a module-level function. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.new(b'key', b'msg', 'sha1').hexdigest().__len__() == 40: SHA-1 produces 160 bits = 40 hex chars. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hmac.new(b'key', b'msg', 'sha1') — digest_size and block_size (extra19)
#
# SHA-1 HMAC: digest_size == 20 (160-bit output), block_size == 64 (512-bit
# block). hmac_extra14 covers sha256 digest_size from extra14.
# hmac_extra13 covers sha256 block_size from extra13.
# No prior spec covers sha1-keyed new() digest_size/block_size from extra19.
# ---------------------------------------------------------------------------

invariant hmac_extra19.new.sha1.digest_size:
  description: "hmac.new(b'key', b'msg', 'sha1').digest_size == 20 — SHA-1 HMAC produces a 20-byte digest"
  category: digest_sizes
  kind: python_call_eq
  function: new
  args: [!ascii "key", !ascii "msg", "sha1"]
  method: digest_size
  method_args: []
  expected: 20

invariant hmac_extra19.new.sha1.block_size:
  description: "hmac.new(b'key', b'msg', 'sha1').block_size == 64 — SHA-1 uses 64-byte blocks"
  category: block_sizes
  kind: python_call_eq
  function: new
  args: [!ascii "key", !ascii "msg", "sha1"]
  method: block_size
  method_args: []
  expected: 64

# ---------------------------------------------------------------------------
# hmac.new(b'key', b'msg', 'sha1').hexdigest() — length (extra19 namespace)
#
# SHA-1 produces a 160-bit digest = 40 hex characters.
# hmac_extra14 covers sha1 hexdigest_len from extra14 (via table).
# hmac_extra16 covers sha1 hexdigest length from extra16 (via table).
# This invariant anchors the sha1 hexdigest length from extra19 namespace.
# ---------------------------------------------------------------------------

invariant hmac_extra19.new.sha1.hexdigest.len:
  description: "hmac.new(b'key', b'msg', 'sha1').hexdigest().__len__() == 40 — SHA-1 HMAC yields 40 hex chars"
  category: digests
  kind: python_call_eq
  function: new
  args: [!ascii "key", !ascii "msg", "sha1"]
  method: hexdigest
  method_args: []
  method_chain: __len__
  method_chain_args: []
  expected: 40

# ---------------------------------------------------------------------------
# hmac.digest(b'key', b'msg', 'sha256') — return length (extra19 namespace)
#
# hmac.digest() returns a bytes object. SHA-256 produces 32 bytes.
# hmac_extra13 covers digest() sha256 len from extra13.
# hmac_extra16 covers digest length from extra16 (via table).
# This invariant anchors the digest length from the extra19 namespace using
# method_chain on the returned bytes object.
# ---------------------------------------------------------------------------

invariant hmac_extra19.digest.sha256.len:
  description: "hmac.digest(b'key', b'msg', 'sha256').__len__() == 32 — SHA-256 HMAC raw digest is 32 bytes"
  category: digest_sizes
  kind: python_call_eq
  function: digest
  args: [!ascii "key", !ascii "msg", "sha256"]
  method_chain: __len__
  method_chain_args: []
  expected: 32

# ---------------------------------------------------------------------------
# hmac.new and hmac.digest — __qualname__ attributes (extra19 namespace)
#
# hmac_extra14 covers __qualname__ for new/digest/compare_digest/HMAC via
# a table from extra14. hmac_extra17 re-anchors new.__name__ and
# digest.__name__ from extra17. These invariants anchor __qualname__
# from the extra19 namespace as standalone invariants.
# ---------------------------------------------------------------------------

invariant hmac_extra19.new.qualname:
  description: "hmac.new.__qualname__ == 'new' — standard qualname for module-level function"
  category: function_names
  kind: python_call_eq
  function: new.__qualname__.__eq__
  args: ["new"]
  expected: true

invariant hmac_extra19.digest.qualname:
  description: "hmac.digest.__qualname__ == 'digest' — standard qualname for module-level function"
  category: function_names
  kind: python_call_eq
  function: digest.__qualname__.__eq__
  args: ["digest"]
  expected: true
