spec: find_up
version: ">=8.0.0"
backend: node(find-up)

docs: https://github.com/sindresorhus/find-up#readme

provenance:
  derived_from:
    - "find-up README — https://github.com/sindresorhus/find-up#readme"
    - "Test vectors verified with find-up via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "find-up source"
  notes:
    - "find-up walks up parent directories looking for a file or directory by name."
    - "Install: npm install find-up"
    - "Usage: const {findUpSync} = require('find-up'); findUpSync('package.json') -> absolute path or undefined."
    - "Tests run inside a per-invariant tempdir sandbox. Setup creates the target file (or omits it for the absent case)."
    - "Return values are absolute paths whose prefix is the unknowable sandbox dir; we chain .endsWith('/<basename>') for portable comparison."
    - "find-up v8 is ESM-internally but exposes a CJS shim that supports require() under modern Node; we use the CJS path via backend: node(find-up)."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "findUpSync returns an absolute path string when found, undefined when not found."
  stderr: "null"
  stickiness: "Each invariant runs in a fresh sandbox."
  codes: {}

# ── findUpSync — single-name lookup walking up from cwd ─────────────────────

table find_up.findUpSync:
  kind: node_sandbox_chain_eq
  category: findUpSync
  entry: named
  function: findUpSync
  id_prefix: find

  columns: [id, entry_args, chain, setup, expected]
  rows:
    - [target_in_cwd,
       ["target.txt"],
       [{method: endsWith, args: ["/target.txt"]}],
       [{path: "target.txt", content: "hi"}],
       true]

    - [target_missing_returns_undefined,
       ["never_existed.txt"], [],
       [],
       ~]

    - [different_extension_missing,
       ["target.json"], [],
       [{path: "target.txt", content: "wrong-ext"}],
       ~]

    - [absolute_path_when_present,
       ["found.cfg"],
       [{method: startsWith, args: ["/"]}],
       [{path: "found.cfg", content: ""}],
       true]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T18:14:48Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
