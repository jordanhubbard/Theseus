spec: abc_extra2
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Extends abc.zspec.zsdl, abc_extra.zspec.zsdl, and abc_meta.zspec.zsdl."
    - "abc.ABC.__name__ == 'ABC' — the helper class name is the simple string 'ABC'."
    - "abc.ABC.__module__ == 'abc' — ABC is defined directly in the abc module."
    - "abc.ABCMeta.__name__ == 'ABCMeta' — the metaclass carries its own name."
    - "abc.ABCMeta.__module__ == 'abc' — ABCMeta is defined in the abc module."
    - "abc.abstractmethod.__name__ == 'abstractmethod' — function/class identity."
    - "abc.abstractmethod.__module__ == 'abc' — implemented in pure Python, lives in abc."
    - "abc.get_cache_token.__name__ == 'get_cache_token' — C builtin name attribute."
    - "abc.update_abstractmethods.__name__ == 'update_abstractmethods' (Python >= 3.10)."
    - "abstractclassmethod.__name__ == 'abstractclassmethod' if present (<3.13); gated by version constraint."
    - "ABCMeta.__qualname__ == 'ABCMeta' — top-level class, qualname equals __name__."
    - "ABC.__qualname__ == 'ABC' — top-level class, qualname equals __name__."
    - "abstractmethod.__qualname__ == 'abstractmethod' — already in abc.zspec.zsdl; reconfirmed via module chain here."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ABC — class name and module
#
# abc.ABC is the helper class that makes subclasses into ABCs via inheritance.
# Its __name__ is 'ABC' and its __module__ is 'abc'.
# ---------------------------------------------------------------------------

invariant abc_extra2.ABC.name:
  description: "abc.ABC.__name__ == 'ABC'"
  category: abc_class
  kind: python_call_eq
  function: ABC.__name__.__eq__
  args: ["ABC"]
  expected: true

invariant abc_extra2.ABC.module:
  description: "abc.ABC.__module__ == 'abc'"
  category: abc_class
  kind: python_call_eq
  function: ABC.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra2.ABC.qualname:
  description: "abc.ABC.__qualname__ == 'ABC' — top-level class, qualname matches __name__"
  category: abc_class
  kind: python_call_eq
  function: ABC.__qualname__.__eq__
  args: ["ABC"]
  expected: true

# ---------------------------------------------------------------------------
# ABCMeta — class name and module
#
# abc.ABCMeta is the metaclass for abstract base classes. Its __name__ is
# 'ABCMeta' and its __module__ is 'abc'.
# ---------------------------------------------------------------------------

invariant abc_extra2.ABCMeta.name:
  description: "abc.ABCMeta.__name__ == 'ABCMeta'"
  category: abcmeta_class
  kind: python_call_eq
  function: ABCMeta.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra2.ABCMeta.module:
  description: "abc.ABCMeta.__module__ == 'abc'"
  category: abcmeta_class
  kind: python_call_eq
  function: ABCMeta.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra2.ABCMeta.qualname:
  description: "abc.ABCMeta.__qualname__ == 'ABCMeta' — top-level class, qualname matches __name__"
  category: abcmeta_class
  kind: python_call_eq
  function: ABCMeta.__qualname__.__eq__
  args: ["ABCMeta"]
  expected: true

# ---------------------------------------------------------------------------
# abstractmethod — __name__ and __module__
#
# abc.abstractmethod is a pure-Python function. Its __name__ is 'abstractmethod'
# and its __module__ is 'abc' (not '_abc', which is the C extension).
# ---------------------------------------------------------------------------

invariant abc_extra2.abstractmethod.name:
  description: "abc.abstractmethod.__name__ == 'abstractmethod'"
  category: abstractmethod_identity
  kind: python_call_eq
  function: abstractmethod.__name__.__eq__
  args: ["abstractmethod"]
  expected: true

invariant abc_extra2.abstractmethod.module:
  description: "abc.abstractmethod.__module__ == 'abc' — pure Python, not the C extension"
  category: abstractmethod_identity
  kind: python_call_eq
  function: abstractmethod.__module__.__eq__
  args: ["abc"]
  expected: true

# ---------------------------------------------------------------------------
# get_cache_token — __name__
#
# abc.get_cache_token is implemented in the _abc C extension and re-exported
# through the abc module. Its __name__ is 'get_cache_token'.
# (Module == '_abc' is covered in abc_meta.zspec.zsdl.)
# ---------------------------------------------------------------------------

invariant abc_extra2.get_cache_token.name:
  description: "abc.get_cache_token.__name__ == 'get_cache_token'"
  category: get_cache_token
  kind: python_call_eq
  function: get_cache_token.__name__.__eq__
  args: ["get_cache_token"]
  expected: true

# ---------------------------------------------------------------------------
# update_abstractmethods — __name__ (Python >= 3.10)
#
# abc.update_abstractmethods(cls) was added in Python 3.10. It is implemented
# in the _abc C extension. We confirm only the __name__ here; type and module
# are covered in abc_meta.zspec.zsdl.
# ---------------------------------------------------------------------------

invariant abc_extra2.update_abstractmethods.name:
  description: "abc.update_abstractmethods.__name__ == 'update_abstractmethods' (Python >= 3.10)"
  category: update_abstractmethods
  version: ">=3.10"
  kind: python_call_eq
  function: update_abstractmethods.__name__.__eq__
  args: ["update_abstractmethods"]
  expected: true

# ---------------------------------------------------------------------------
# abstractclassmethod — __name__ (deprecated, still present in <3.13)
#
# abc.abstractclassmethod was deprecated in Python 3.3 and removed in 3.13.
# When present its __name__ is 'abstractclassmethod'.
# ---------------------------------------------------------------------------

invariant abc_extra2.abstractclassmethod.name:
  description: "abc.abstractclassmethod.__name__ == 'abstractclassmethod' (deprecated, present <3.13)"
  category: deprecated
  version: ">=3.9,<3.13"
  kind: python_call_eq
  function: abstractclassmethod.__name__.__eq__
  args: ["abstractclassmethod"]
  expected: true

# ---------------------------------------------------------------------------
# ABCMeta — type identity
#
# ABCMeta is itself an instance of 'type', because it is a metaclass.
# We confirm that its __class__.__name__ is 'type'.
# ---------------------------------------------------------------------------

invariant abc_extra2.ABCMeta.class_is_type:
  description: "type(abc.ABCMeta).__name__ == 'type' — ABCMeta is itself a type"
  category: abcmeta_class
  kind: python_call_eq
  function: ABCMeta.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# ABC — metaclass identity
#
# abc.ABC is an instance of ABCMeta (not plain type). We confirm that its
# metaclass name is 'ABCMeta'.
# ---------------------------------------------------------------------------

invariant abc_extra2.ABC.metaclass_is_abcmeta:
  description: "type(abc.ABC).__name__ == 'ABCMeta' — ABC is an instance of ABCMeta"
  category: abc_class
  kind: python_call_eq
  function: ABC.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

# ---------------------------------------------------------------------------
# abstractmethod — type identity
#
# abstractmethod is a plain Python function. Confirming that its class is
# 'function' is a distinct invariant from __name__ and __module__.
# ---------------------------------------------------------------------------

invariant abc_extra2.abstractmethod.type_is_function:
  description: "type(abc.abstractmethod).__name__ == 'function'"
  category: abstractmethod_identity
  kind: python_call_eq
  function: abstractmethod.__class__.__name__.__eq__
  args: ["function"]
  expected: true
