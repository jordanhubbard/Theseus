spec: multiprocessing_extra179
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/queues.py"
  notes:
    - "This spec covers: multiprocessing.queues.Queue, multiprocessing.queues.SimpleQueue, and multiprocessing.queues.JoinableQueue class identity. Note: multiprocessing.Queue, multiprocessing.SimpleQueue, and multiprocessing.JoinableQueue at the top-level are methods on the multiprocessing context object, not classes directly; the actual classes reside in multiprocessing.queues. Queue.__name__=='Queue' (len=5); Queue.__module__=='multiprocessing.queues'; Queue.__bases__[0].__name__=='object'; SimpleQueue.__name__=='SimpleQueue' (len=11); SimpleQueue.__module__=='multiprocessing.queues'; SimpleQueue.__bases__[0].__name__=='object'; JoinableQueue.__name__=='JoinableQueue' (len=13); JoinableQueue.__bases__[0].__name__=='Queue'."
    - "multiprocessing.queues.Queue.__name__ == 'Queue' (len=5: Q-u-e-u-e). Queue is a process-safe FIFO queue using a pipe and locks, suitable for producer-consumer patterns across processes. Its __module__ is 'multiprocessing.queues' and it inherits directly from object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.queues.SimpleQueue.__name__ == 'SimpleQueue' (len=11: S-i-m-p-l-e-Q-u-e-u-e). SimpleQueue is a simplified process-safe queue with fewer features than Queue; it also inherits from object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.queues.JoinableQueue.__name__ == 'JoinableQueue' (len=13: J-o-i-n-a-b-l-e-Q-u-e-u-e). JoinableQueue extends Queue with task_done/join support for tracking task completion. It subclasses Queue directly. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.queues.Queue class identity — __name__, __module__, __qualname__
#
# multiprocessing.queues.Queue.__name__ == 'Queue' (len=5)
# multiprocessing.queues.Queue.__module__ == 'multiprocessing.queues'
# multiprocessing.queues.Queue.__bases__[0].__name__ == 'object'
#
# Queue is the standard process-safe FIFO queue in multiprocessing.
# New to extra179.
# ---------------------------------------------------------------------------

table multiprocessing_extra179.queue_identity:
  description: "multiprocessing.queues.Queue.__name__ 'Queue' len 5; __module__ 'multiprocessing.queues'; __bases__[0].__name__=='object'; new to extra179"
  kind: python_call_eq
  category: identity
  id_prefix: mpqueue179

  columns: [id, function, args, expected, description]
  rows:
    - [q_name_eq,
       Queue.__name__.__eq__,
       ["Queue"],
       true,
       "multiprocessing.queues.Queue.__name__.__eq__('Queue') == True — Queue is a process-safe FIFO queue using a pipe and background thread; its __name__ is 'Queue' (5 chars: Q-u-e-u-e); str.__eq__('Queue') returns True; new to extra179"]
    - [q_name_len_5,
       Queue.__name__.__len__,
       [],
       5,
       "multiprocessing.queues.Queue.__name__.__len__() == 5 — 'Queue' has 5 characters: Q-u-e-u-e; shorter than 'SimpleQueue'=11 and 'JoinableQueue'=13; NAME LENGTHS: Queue=5 < SimpleQueue=11 < JoinableQueue=13; str.__len__() returns 5; new to extra179"]
    - [q_module_eq,
       Queue.__module__.__eq__,
       ["multiprocessing.queues"],
       true,
       "multiprocessing.queues.Queue.__module__.__eq__('multiprocessing.queues') == True — Queue is defined in the multiprocessing.queues submodule; its __module__ is 'multiprocessing.queues'; str.__eq__('multiprocessing.queues') returns True; new to extra179"]
    - [q_base0_name_eq,
       "Queue.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "multiprocessing.queues.Queue.__bases__[0].__name__.__eq__('object') == True — Queue inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra179"]
    - [q_qualname_eq,
       Queue.__qualname__.__eq__,
       ["Queue"],
       true,
       "multiprocessing.queues.Queue.__qualname__.__eq__('Queue') == True — Queue is a top-level class in multiprocessing.queues so its __qualname__ equals its __name__; str.__eq__('Queue') returns True; new to extra179"]

# ---------------------------------------------------------------------------
# Table 2: multiprocessing.queues.SimpleQueue class identity
#
# multiprocessing.queues.SimpleQueue.__name__ == 'SimpleQueue' (len=11)
# multiprocessing.queues.SimpleQueue.__module__ == 'multiprocessing.queues'
# multiprocessing.queues.SimpleQueue.__bases__[0].__name__ == 'object'
#
# SimpleQueue is a lightweight process-safe queue with a simpler implementation.
# New to extra179.
# ---------------------------------------------------------------------------

table multiprocessing_extra179.simplequeue_identity:
  description: "multiprocessing.queues.SimpleQueue.__name__ 'SimpleQueue' len 11; __module__ 'multiprocessing.queues'; __bases__[0].__name__=='object'; new to extra179"
  kind: python_call_eq
  category: identity
  id_prefix: mpqueue179

  columns: [id, function, args, expected, description]
  rows:
    - [sq_name_eq,
       SimpleQueue.__name__.__eq__,
       ["SimpleQueue"],
       true,
       "multiprocessing.queues.SimpleQueue.__name__.__eq__('SimpleQueue') == True — SimpleQueue is a simplified process-safe queue with close/empty/get/put methods only; its __name__ is 'SimpleQueue' (11 chars: S-i-m-p-l-e-Q-u-e-u-e); str.__eq__('SimpleQueue') returns True; new to extra179"]
    - [sq_name_len_11,
       SimpleQueue.__name__.__len__,
       [],
       11,
       "multiprocessing.queues.SimpleQueue.__name__.__len__() == 11 — 'SimpleQueue' has 11 characters: S-i-m-p-l-e-Q-u-e-u-e; NAME LENGTHS: Queue=5 < SimpleQueue=11 < JoinableQueue=13; str.__len__() returns 11; new to extra179"]
    - [sq_module_eq,
       SimpleQueue.__module__.__eq__,
       ["multiprocessing.queues"],
       true,
       "multiprocessing.queues.SimpleQueue.__module__.__eq__('multiprocessing.queues') == True — SimpleQueue is defined in the same multiprocessing.queues submodule as Queue; its __module__ is 'multiprocessing.queues'; str.__eq__('multiprocessing.queues') returns True; new to extra179"]
    - [sq_base0_name_eq,
       "SimpleQueue.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "multiprocessing.queues.SimpleQueue.__bases__[0].__name__.__eq__('object') == True — SimpleQueue also inherits directly from object, unlike JoinableQueue which subclasses Queue; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra179"]
    - [sq_bases_len_1,
       "SimpleQueue.__bases__.__len__",
       [],
       1,
       "multiprocessing.queues.SimpleQueue.__bases__.__len__() == 1 — SimpleQueue has exactly one direct base class: object; __bases__ is a 1-element tuple; tuple.__len__() returns 1; new to extra179"]

# ---------------------------------------------------------------------------
# Table 3: multiprocessing.queues.JoinableQueue class identity
#
# multiprocessing.queues.JoinableQueue.__name__ == 'JoinableQueue' (len=13)
# multiprocessing.queues.JoinableQueue.__module__ == 'multiprocessing.queues'
# multiprocessing.queues.JoinableQueue.__bases__[0].__name__ == 'Queue'
#
# JoinableQueue extends Queue with task_done/join for tracking completion.
# New to extra179.
# ---------------------------------------------------------------------------

table multiprocessing_extra179.joinablequeue_identity:
  description: "multiprocessing.queues.JoinableQueue.__name__ 'JoinableQueue' len 13; __module__ 'multiprocessing.queues'; __bases__[0].__name__=='Queue'; new to extra179"
  kind: python_call_eq
  category: identity
  id_prefix: mpqueue179

  columns: [id, function, args, expected, description]
  rows:
    - [jq_name_eq,
       JoinableQueue.__name__.__eq__,
       ["JoinableQueue"],
       true,
       "multiprocessing.queues.JoinableQueue.__name__.__eq__('JoinableQueue') == True — JoinableQueue extends Queue with task_done() and join() methods for tracking when all items have been processed; its __name__ is 'JoinableQueue' (13 chars: J-o-i-n-a-b-l-e-Q-u-e-u-e); str.__eq__('JoinableQueue') returns True; new to extra179"]
    - [jq_name_len_13,
       JoinableQueue.__name__.__len__,
       [],
       13,
       "multiprocessing.queues.JoinableQueue.__name__.__len__() == 13 — 'JoinableQueue' has 13 characters: J-o-i-n-a-b-l-e-Q-u-e-u-e; longest of the three queue names; NAME LENGTHS: Queue=5 < SimpleQueue=11 < JoinableQueue=13; str.__len__() returns 13; new to extra179"]
    - [jq_module_eq,
       JoinableQueue.__module__.__eq__,
       ["multiprocessing.queues"],
       true,
       "multiprocessing.queues.JoinableQueue.__module__.__eq__('multiprocessing.queues') == True — JoinableQueue is defined in the same multiprocessing.queues submodule; its __module__ is 'multiprocessing.queues'; str.__eq__('multiprocessing.queues') returns True; new to extra179"]
    - [jq_base0_name_eq,
       "JoinableQueue.__bases__[0].__name__.__eq__",
       ["Queue"],
       true,
       "multiprocessing.queues.JoinableQueue.__bases__[0].__name__.__eq__('Queue') == True — JoinableQueue's sole direct base class is multiprocessing.queues.Queue; unlike SimpleQueue, JoinableQueue extends Queue with join/task_done semantics; __bases__[0].__name__ is 'Queue'; str.__eq__('Queue') returns True; new to extra179"]
    - [jq_qualname_eq,
       JoinableQueue.__qualname__.__eq__,
       ["JoinableQueue"],
       true,
       "multiprocessing.queues.JoinableQueue.__qualname__.__eq__('JoinableQueue') == True — JoinableQueue is a top-level class so its __qualname__ equals its __name__; str.__eq__('JoinableQueue') returns True; new to extra179"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra179
# ---------------------------------------------------------------------------

invariant multiprocessing_extra179.queue_name_eq:
  description: "multiprocessing.queues.Queue.__name__ == 'Queue' — process-safe FIFO queue using pipe and locks; name len=5 (Q-u-e-u-e); new to extra179"
  category: identity
  kind: python_call_eq
  function: Queue.__name__.__eq__
  args: ["Queue"]
  expected: true

invariant multiprocessing_extra179.queue_module_eq:
  description: "multiprocessing.queues.Queue.__module__ == 'multiprocessing.queues' — defined in the queues submodule alongside SimpleQueue and JoinableQueue; new to extra179"
  category: identity
  kind: python_call_eq
  function: Queue.__module__.__eq__
  args: ["multiprocessing.queues"]
  expected: true

invariant multiprocessing_extra179.queue_base0_name_eq:
  description: "multiprocessing.queues.Queue.__bases__[0].__name__ == 'object' — Queue inherits directly from object; new to extra179"
  category: identity
  kind: python_call_eq
  function: "Queue.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant multiprocessing_extra179.simplequeue_name_eq:
  description: "multiprocessing.queues.SimpleQueue.__name__ == 'SimpleQueue' — lightweight process-safe queue with close/empty/get/put only; name len=11; new to extra179"
  category: identity
  kind: python_call_eq
  function: SimpleQueue.__name__.__eq__
  args: ["SimpleQueue"]
  expected: true

invariant multiprocessing_extra179.simplequeue_module_eq:
  description: "multiprocessing.queues.SimpleQueue.__module__ == 'multiprocessing.queues' — defined in the same module as Queue and JoinableQueue; new to extra179"
  category: identity
  kind: python_call_eq
  function: SimpleQueue.__module__.__eq__
  args: ["multiprocessing.queues"]
  expected: true

invariant multiprocessing_extra179.simplequeue_base0_name_eq:
  description: "multiprocessing.queues.SimpleQueue.__bases__[0].__name__ == 'object' — SimpleQueue inherits directly from object, not from Queue; new to extra179"
  category: identity
  kind: python_call_eq
  function: "SimpleQueue.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant multiprocessing_extra179.joinablequeue_name_eq:
  description: "multiprocessing.queues.JoinableQueue.__name__ == 'JoinableQueue' — extends Queue with task_done/join for completion tracking; name len=13; new to extra179"
  category: identity
  kind: python_call_eq
  function: JoinableQueue.__name__.__eq__
  args: ["JoinableQueue"]
  expected: true

invariant multiprocessing_extra179.joinablequeue_base0_name_eq:
  description: "multiprocessing.queues.JoinableQueue.__bases__[0].__name__ == 'Queue' — JoinableQueue directly subclasses Queue, adding join/task_done semantics; new to extra179"
  category: identity
  kind: python_call_eq
  function: "JoinableQueue.__bases__[0].__name__.__eq__"
  args: ["Queue"]
  expected: true
