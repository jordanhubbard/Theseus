spec: types_extra10
version: ">=3.9"
backend: python_module(types)

docs: https://docs.python.org/3/library/types.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/types.html — Python types module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/types.py"
    - "types.zspec.zsdl — covers __name__ for FunctionType/MethodType/ModuleType/NoneType/GeneratorType/MappingProxyType/SimpleNamespace/LambdaType/CoroutineType/AsyncGeneratorType/UnionType"
    - "types_extra.zspec.zsdl — covers __name__ for CodeType/BuiltinFunctionType/TracebackType/FrameType"
    - "types_extra2.zspec.zsdl — covers __module__ and __bases__[0].__name__ for FunctionType/LambdaType/CodeType/MethodType and others"
    - "types_extra4.zspec.zsdl — covers __name__/__module__ table for FunctionType/CodeType/MethodType"
    - "types_extra5.zspec.zsdl — covers __qualname__ for FunctionType/LambdaType/MethodType"
    - "types_extra6.zspec.zsdl — covers __qualname__ for CodeType"
    - "types_extra9.zspec.zsdl — covers __name__.__eq__ for FunctionType/LambdaType/CodeType/MethodType as individual invariants"
  notes:
    - "This spec adds: __bases__.__len__ == 1 for FunctionType, LambdaType, CodeType, and MethodType."
    - "types_extra2 covers __bases__[0].__name__ for FunctionType/CodeType/MethodType via table rows."
    - "types_extra5 covers __bases__.__len__ for some types via fractions_extra5 style — check needed."
    - "New axis: __bases__.__len__ == 1 asserted via __eq__ for FunctionType, LambdaType, CodeType, MethodType."
    - "types.FunctionType.__bases__ has exactly one element: object."
    - "types.LambdaType is types.FunctionType — identical object; __bases__ is the same tuple."
    - "types.CodeType.__bases__ has exactly one element: object."
    - "types.MethodType.__bases__ has exactly one element: object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bases__.__len__ == 1 — FunctionType, LambdaType, CodeType, MethodType
#
# types_extra2 covers __bases__[0].__name__ for these types via a table.
# types_extra5 covers __bases__.__len__ for some other types.
# This spec adds the __bases__.__len__ == 1 check as individual invariants
# for the four target types, expressed as boolean __eq__ contracts.
# ---------------------------------------------------------------------------

invariant types_extra10.FunctionType.bases_len:
  description: "types.FunctionType.__bases__.__len__() == 1 — single direct base (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: FunctionType.__bases__.__len__
  args: []
  expected: 1

invariant types_extra10.LambdaType.bases_len:
  description: "types.LambdaType.__bases__.__len__() == 1 — LambdaType is FunctionType; single base (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: LambdaType.__bases__.__len__
  args: []
  expected: 1

invariant types_extra10.CodeType.bases_len:
  description: "types.CodeType.__bases__.__len__() == 1 — single direct base (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: CodeType.__bases__.__len__
  args: []
  expected: 1

invariant types_extra10.MethodType.bases_len:
  description: "types.MethodType.__bases__.__len__() == 1 — single direct base (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: MethodType.__bases__.__len__
  args: []
  expected: 1
