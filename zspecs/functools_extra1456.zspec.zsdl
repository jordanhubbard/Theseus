spec: functools_extra1456
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
    - "functools_extra1441.zspec.zsdl — covers __subclasshook__, __instancecheck__, __subclasscheck__ ABC-machinery checks"
    - "functools_extra1426.zspec.zsdl — covers __format__ and __dir__ method type and dict-presence checks"
  notes:
    - "Wave 544 (_extra1456): focuses on __contains__ and __iter__ container/iterable protocol method presence checks for functools classes."
    - "functools.partial does not define '__contains__' in its own __dict__ — partial is a callable wrapper, not a container. Verified Python 3.14.4."
    - "functools.cached_property does not define '__contains__' in its own __dict__ — cached_property is a descriptor, not a container. Verified Python 3.14.4."
    - "functools.singledispatchmethod does not define '__contains__' in its own __dict__ — singledispatchmethod is a descriptor, not a container. Verified Python 3.14.4."
    - "functools.partialmethod does not define '__contains__' in its own __dict__ — partialmethod is a descriptor, not a container. Verified Python 3.14.4."
    - "functools.partial does not define '__iter__' in its own __dict__ — partial is not iterable. Verified Python 3.14.4."
    - "functools.cached_property does not define '__iter__' in its own __dict__ — cached_property is not iterable. Verified Python 3.14.4."
    - "functools.singledispatchmethod does not define '__iter__' in its own __dict__ — singledispatchmethod is not iterable. Verified Python 3.14.4."
    - "functools.partialmethod does not define '__iter__' in its own __dict__ — partialmethod is not iterable. Verified Python 3.14.4."
    - "None of partial, cached_property, singledispatchmethod, partialmethod implement the container protocol (__contains__) or the iterator protocol (__iter__/__next__) in their own class __dict__. All verified Python 3.14.4."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools class __contains__ dict absence
#
# Wave 544 theme: '__contains__' not in own __dict__ for functools classes.
# partial, cached_property, singledispatchmethod, and partialmethod are all
# callable wrappers or descriptors — none implement the container protocol.
# ---------------------------------------------------------------------------

table functools_extra1456.contains_dict_membership:
  description: "functools classes: '__contains__' not in own __dict__ for partial, cached_property, singledispatchmethod, partialmethod; wave 544; new to extra1456"
  kind: python_call_eq
  category: contains_dict_membership
  id_prefix: fu1456cd

  columns: [id, function, args, expected, description]
  rows:
    - [fu1456cd001,
       "partial.__dict__.__contains__",
       ["__contains__"],
       false,
       "functools.partial.__dict__.__contains__('__contains__') == False — partial is a callable wrapper, not a container; no __contains__ in own class __dict__; new to extra1456"]
    - [fu1456cd002,
       "cached_property.__dict__.__contains__",
       ["__contains__"],
       false,
       "functools.cached_property.__dict__.__contains__('__contains__') == False — cached_property is a descriptor, not a container; no __contains__ in own class __dict__; new to extra1456"]
    - [fu1456cd003,
       "singledispatchmethod.__dict__.__contains__",
       ["__contains__"],
       false,
       "functools.singledispatchmethod.__dict__.__contains__('__contains__') == False — singledispatchmethod is a descriptor, not a container; no __contains__ in own class __dict__; new to extra1456"]
    - [fu1456cd004,
       "partialmethod.__dict__.__contains__",
       ["__contains__"],
       false,
       "functools.partialmethod.__dict__.__contains__('__contains__') == False — partialmethod is a descriptor, not a container; no __contains__ in own class __dict__; new to extra1456"]
    - [fu1456cd005,
       "partial.__dict__.__contains__",
       ["__iter__"],
       false,
       "functools.partial.__dict__.__contains__('__iter__') == False — partial is not iterable; no __iter__ in own class __dict__; new to extra1456"]
    - [fu1456cd006,
       "cached_property.__dict__.__contains__",
       ["__iter__"],
       false,
       "functools.cached_property.__dict__.__contains__('__iter__') == False — cached_property is not iterable; no __iter__ in own class __dict__; new to extra1456"]
    - [fu1456cd007,
       "singledispatchmethod.__dict__.__contains__",
       ["__iter__"],
       false,
       "functools.singledispatchmethod.__dict__.__contains__('__iter__') == False — singledispatchmethod is not iterable; no __iter__ in own class __dict__; new to extra1456"]
    - [fu1456cd008,
       "partialmethod.__dict__.__contains__",
       ["__iter__"],
       false,
       "functools.partialmethod.__dict__.__contains__('__iter__') == False — partialmethod is not iterable; no __iter__ in own class __dict__; new to extra1456"]

# ---------------------------------------------------------------------------
# Table 2: functools class __next__ dict absence
