# ---------------------------------------------------------------------------
# Standalone invariants — extra1456
# ---------------------------------------------------------------------------

invariant functools_extra1456.partial_contains_not_in_dict:
  description: "'__contains__' not in functools.partial.__dict__ — partial does not define the container protocol; wave 544; new to extra1456"
  kind: python_call_eq
  function: partial.__dict__.__contains__
  args: ["__contains__"]
  expected: false

invariant functools_extra1456.partial_iter_not_in_dict:
  description: "'__iter__' not in functools.partial.__dict__ — partial does not define the iterable protocol; wave 544; new to extra1456"
  kind: python_call_eq
  function: partial.__dict__.__contains__
  args: ["__iter__"]
  expected: false

invariant functools_extra1456.partial_next_not_in_dict:
  description: "'__next__' not in functools.partial.__dict__ — partial does not define the iterator protocol; wave 544; new to extra1456"
  kind: python_call_eq
  function: partial.__dict__.__contains__
  args: ["__next__"]
  expected: false

invariant functools_extra1456.cached_property_contains_not_in_dict:
  description: "'__contains__' not in functools.cached_property.__dict__ — cached_property does not define the container protocol; wave 544; new to extra1456"
  kind: python_call_eq
  function: cached_property.__dict__.__contains__
  args: ["__contains__"]
  expected: false
