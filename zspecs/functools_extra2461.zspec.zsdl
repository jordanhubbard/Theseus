spec: functools_extra2461
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "Theme: __len__ and __length_hint__ dict-presence — checking whether functools classes define the length protocol in their class __dict__."
    - "functools.partial.__dict__.__contains__('__len__') == False — partial is a C extension type wrapping a callable; it is not a container and does not define __len__ in its class dict. Verified with Python 3.14.3."
    - "functools.partial.__dict__.__contains__('__length_hint__') == False — partial is not an iterator and does not define __length_hint__ in its class dict. Verified with Python 3.14.3."
    - "functools.partialmethod.__dict__.__contains__('__len__') == False — partialmethod is a descriptor class for partial methods; it is not a container and does not define __len__ in its class dict. Verified with Python 3.14.3."
    - "functools.partialmethod.__dict__.__contains__('__length_hint__') == False — partialmethod does not define __length_hint__ in its class dict. Verified with Python 3.14.3."
    - "functools.cached_property.__dict__.__contains__('__len__') == False — cached_property is a descriptor; it is not a container and does not define __len__ in its class dict. Verified with Python 3.14.3."
    - "functools.cached_property.__dict__.__contains__('__length_hint__') == False — cached_property does not define __length_hint__ in its class dict. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__dict__.__contains__('__len__') == False — singledispatchmethod is a descriptor class; it is not a container. Verified with Python 3.14.3."
    - "functools.lru_cache.__dict__.__contains__('__len__') == False — lru_cache is a decorator factory; not a container. Verified with Python 3.14.3."
    - "functools.MappingProxyType.__dict__.__contains__('__len__') == True — MappingProxyType wraps a mapping and delegates __len__ to the underlying mapping; it defines __len__ in its class dict. Verified with Python 3.14.3."
    - "functools.MappingProxyType.__dict__.__contains__('__length_hint__') == False — MappingProxyType does not define __length_hint__; it is not an iterator. Verified with Python 3.14.3."
    - "functools.itemgetter.__dict__.__contains__('__len__') == False — itemgetter is a callable, not a container. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __len__ dict-presence for functools classes
#
# Theme: which functools classes define __len__ in their class __dict__?
#
# functools.partial.__dict__.__contains__('__len__') == False
# functools.partialmethod.__dict__.__contains__('__len__') == False
# functools.cached_property.__dict__.__contains__('__len__') == False
# functools.singledispatchmethod.__dict__.__contains__('__len__') == False
# functools.lru_cache.__dict__.__contains__('__len__') == False
# functools.itemgetter.__dict__.__contains__('__len__') == False
# functools.MappingProxyType.__dict__.__contains__('__len__') == True
#
# None of the higher-order-function classes in functools define __len__
# because they are callable wrappers or descriptors, not containers.
# MappingProxyType is the exception: it wraps a mapping and exposes __len__.
# ---------------------------------------------------------------------------

table functools_extra2461.len_dict_presence:
  description: "__len__ in class __dict__ for functools types; MappingProxyType is the only one with __len__"
  kind: python_call_eq
  category: identity
  id_prefix: ft2461

  columns: [id, function, args, expected]
  rows:
    - ["ft2461001", partial.__dict__.__contains__, ["__len__"], false]
    - ["ft2461002", partialmethod.__dict__.__contains__, ["__len__"], false]
    - ["ft2461003", cached_property.__dict__.__contains__, ["__len__"], false]
    - ["ft2461004", singledispatchmethod.__dict__.__contains__, ["__len__"], false]
    - ["ft2461005", lru_cache.__dict__.__contains__, ["__len__"], false]
    - ["ft2461006", itemgetter.__dict__.__contains__, ["__len__"], false]
    - ["ft2461007", MappingProxyType.__dict__.__contains__, ["__len__"], true]

# ---------------------------------------------------------------------------
# Table 2: __length_hint__ dict-presence for functools classes
#
# Theme: which functools classes define __length_hint__ in their class __dict__?
#
# functools.partial.__dict__.__contains__('__length_hint__') == False
# functools.partialmethod.__dict__.__contains__('__length_hint__') == False
# functools.cached_property.__dict__.__contains__('__length_hint__') == False
# functools.singledispatchmethod.__dict__.__contains__('__length_hint__') == False
# functools.lru_cache.__dict__.__contains__('__length_hint__') == False
# functools.itemgetter.__dict__.__contains__('__length_hint__') == False
# functools.MappingProxyType.__dict__.__contains__('__length_hint__') == False
#
# No functools class defines __length_hint__. The length hint protocol is
# for iterators that can estimate remaining items; none of these classes
# serve as iterators.
# ---------------------------------------------------------------------------

table functools_extra2461.length_hint_dict_presence:
  description: "__length_hint__ in class __dict__ for functools types; none define it"
  kind: python_call_eq
  category: identity
  id_prefix: ft2461

  columns: [id, function, args, expected]
  rows:
    - ["ft2461008", partial.__dict__.__contains__, ["__length_hint__"], false]
    - ["ft2461009", partialmethod.__dict__.__contains__, ["__length_hint__"], false]
    - ["ft2461010", cached_property.__dict__.__contains__, ["__length_hint__"], false]
    - ["ft2461011", singledispatchmethod.__dict__.__contains__, ["__length_hint__"], false]
    - ["ft2461012", lru_cache.__dict__.__contains__, ["__length_hint__"], false]
    - ["ft2461013", itemgetter.__dict__.__contains__, ["__length_hint__"], false]
    - ["ft2461014", MappingProxyType.__dict__.__contains__, ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# Table 3: cross-checks — MappingProxyType defines __len__ but not __length_hint__
#
# MappingProxyType.__dict__.__contains__('__len__') == True
# MappingProxyType.__dict__.__contains__('__length_hint__') == False
# MappingProxyType.__dict__.__contains__('__iter__') == True
# MappingProxyType.__dict__.__contains__('__contains__') == True
# partial.__dict__.__contains__('__len__') == False  (cross-check)
# partial.__dict__.__contains__('func') == True      (cross-check: partial does have 'func')
#
# These cross-checks confirm the asymmetry: MappingProxyType is sized but
# partial is not, and partial has domain-specific descriptors like 'func'.
# ---------------------------------------------------------------------------

table functools_extra2461.mapping_proxy_cross_checks:
  description: "MappingProxyType __len__ vs __length_hint__ and iteration protocol; partial cross-checks"
  kind: python_call_eq
  category: identity
  id_prefix: ft2461

  columns: [id, function, args, expected]
  rows:
    - ["ft2461015", MappingProxyType.__dict__.__contains__, ["__len__"], true]
    - ["ft2461016", MappingProxyType.__dict__.__contains__, ["__length_hint__"], false]
    - ["ft2461017", MappingProxyType.__dict__.__contains__, ["__iter__"], true]
    - ["ft2461018", MappingProxyType.__dict__.__contains__, ["__contains__"], true]
    - ["ft2461019", partial.__dict__.__contains__, ["__len__"], false]
    - ["ft2461020", partial.__dict__.__contains__, ["func"], true]
