spec: threading_extra361
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "threading.Lock.__class__.__name__ == 'type' — Lock is actually a C extension type exposed via the _thread module; type(threading.Lock).__name__ is 'type'. Verified with Python 3.14.3."
    - "threading.Lock().__class__.__name__ == 'lock' — an instance of threading.Lock() returns a _thread.lock object whose __class__.__name__ is 'lock' (lowercase). Verified with Python 3.14.3."
    - "threading.Lock().__class__.__module__ == '_thread' — the lock instance's C type lives in _thread. Verified with Python 3.14.3."
    - "threading.RLock.__class__.__name__ == 'function' — RLock is a factory function, not a class; type(threading.RLock).__name__ is 'function'. Verified with Python 3.14.3."
    - "threading.RLock().__class__.__name__ == 'RLock' — an RLock() instance's __class__.__name__ is 'RLock'. Verified with Python 3.14.3."
    - "threading.Event.__name__ == 'Event' — pure-Python class in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Event.__module__ == 'threading' — defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Event.__bases__[0].__name__ == 'object' — Event inherits directly from object. Verified with Python 3.14.3."
    - "threading.Semaphore.__name__ == 'Semaphore' — pure-Python class in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Semaphore.__module__ == 'threading' — defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Semaphore.__bases__[0].__name__ == 'object' — Semaphore inherits directly from object. Verified with Python 3.14.3."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Lock and threading.RLock factory identity
#
# threading.Lock.__class__.__name__ == 'type'
# threading.Lock().__class__.__name__ == 'lock'
# threading.Lock().__class__.__module__ == '_thread'
# threading.RLock.__class__.__name__ == 'function'
# threading.RLock().__class__.__name__ == 'RLock'
#
# threading.Lock is exposed as a C extension type from the _thread module.
# Its __class__ is the metaclass 'type'. Instances of Lock() have
# __class__.__name__ == 'lock' (lowercase) and __class__.__module__ == '_thread'.
# threading.RLock is a factory function (not a class directly);
# type(threading.RLock).__name__ is 'function'. Instances have __class__.__name__ == 'RLock'.
# ---------------------------------------------------------------------------

table threading_extra361.lock_rlock_factory_identity:
  description: "threading.Lock (C type, __class__.__name__=='type') and threading.RLock (factory function, __class__.__name__=='function') identity; instances verified separately; new to extra361"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadinglock361

  columns: [id, function, args, expected, description]
  rows:
    - [lock_class_name_eq_type,
       "Lock.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.Lock.__class__.__name__.__eq__('type') == True — threading.Lock is exposed as a C extension type from the _thread module; as a class, its __class__ is the metaclass 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra361"]
    - [lock_instance_class_name_eq_lock,
       "Lock().__class__.__name__.__eq__",
       ["lock"],
       true,
       "threading.Lock().__class__.__name__.__eq__('lock') == True — creating a Lock() instance returns a _thread.lock object; the instance's __class__.__name__ is 'lock' (lowercase); str.__eq__('lock') returns True; new to extra361"]
    - [lock_instance_class_module_eq,
       "Lock().__class__.__module__.__eq__",
       ["_thread"],
       true,
       "threading.Lock().__class__.__module__.__eq__('_thread') == True — the lock instance's C type is defined in the _thread extension module; __class__.__module__ is '_thread'; str.__eq__('_thread') returns True; new to extra361"]
    - [rlock_class_name_eq_function,
       "RLock.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.RLock.__class__.__name__.__eq__('function') == True — threading.RLock is a factory function defined in Lib/threading.py (not a class directly); type(threading.RLock).__name__ is 'function'; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra361"]
    - [rlock_instance_class_name_eq,
       "RLock().__class__.__name__.__eq__",
       ["RLock"],
       true,
       "threading.RLock().__class__.__name__.__eq__('RLock') == True — calling the RLock factory returns an instance whose __class__.__name__ is 'RLock'; str.__eq__('RLock') returns True; new to extra361"]

# ---------------------------------------------------------------------------
# Table 2: threading.Event class identity
#
# threading.Event.__name__ == 'Event'
# threading.Event.__module__ == 'threading'
# threading.Event.__bases__[0].__name__ == 'object'
#
# Event is a pure-Python synchronization primitive defined in Lib/threading.py.
# It manages an internal flag. It inherits directly from object.
# ---------------------------------------------------------------------------

table threading_extra361.event_class_identity:
  description: "threading.Event class identity: __name__, __module__, __bases__[0].__name__; Event is a pure-Python synchronization primitive in Lib/threading.py inheriting from object; new to extra361"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingevent361

  columns: [id, function, args, expected, description]
  rows:
    - [event_name_eq,
       "Event.__name__.__eq__",
       ["Event"],
       true,
       "threading.Event.__name__.__eq__('Event') == True — Event is a pure-Python class defined in Lib/threading.py that manages an internal flag for thread synchronization; its __name__ attribute is 'Event'; str.__eq__('Event') returns True; new to extra361"]
    - [event_module_eq,
       "Event.__module__.__eq__",
       ["threading"],
       true,
       "threading.Event.__module__.__eq__('threading') == True — Event is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra361"]
    - [event_bases_first_eq_object,
       "Event.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Event.__bases__[0].__name__.__eq__('object') == True — Event inherits directly from object with no intermediate base class; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra361"]

# ---------------------------------------------------------------------------
# Table 3: threading.Semaphore class identity
#
# threading.Semaphore.__name__ == 'Semaphore'
# threading.Semaphore.__module__ == 'threading'
# threading.Semaphore.__bases__[0].__name__ == 'object'
#
# Semaphore is a pure-Python synchronization primitive defined in Lib/threading.py.
# It manages an internal counter. It inherits directly from object.
# BoundedSemaphore is a subclass of Semaphore.
# ---------------------------------------------------------------------------

table threading_extra361.semaphore_class_identity:
  description: "threading.Semaphore class identity: __name__, __module__, __bases__[0].__name__; Semaphore is a pure-Python synchronization primitive in Lib/threading.py inheriting from object; new to extra361"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingsema361

  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_name_eq,
       "Semaphore.__name__.__eq__",
       ["Semaphore"],
       true,
       "threading.Semaphore.__name__.__eq__('Semaphore') == True — Semaphore is a pure-Python class defined in Lib/threading.py that manages a counting semaphore for thread synchronization; its __name__ attribute is 'Semaphore'; str.__eq__('Semaphore') returns True; new to extra361"]
    - [semaphore_module_eq,
       "Semaphore.__module__.__eq__",
       ["threading"],
       true,
       "threading.Semaphore.__module__.__eq__('threading') == True — Semaphore is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra361"]
    - [semaphore_bases_first_eq_object,
       "Semaphore.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Semaphore.__bases__[0].__name__.__eq__('object') == True — Semaphore inherits directly from object with no intermediate base class; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra361"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra361
# ---------------------------------------------------------------------------

invariant threading_extra361.lock_class_name:
  description: "threading.Lock.__class__.__name__ == 'type' — Lock is a C extension type from _thread; its __class__ is the metaclass 'type'; new to extra361"
  kind: python_call_eq
  function: Lock.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant threading_extra361.lock_instance_class_name:
  description: "threading.Lock().__class__.__name__ == 'lock' — Lock() returns a _thread.lock instance; instance __class__.__name__ is lowercase 'lock'; new to extra361"
  kind: python_call_eq
  function: Lock().__class__.__name__.__eq__
  args: ["lock"]
  expected: true

invariant threading_extra361.lock_instance_class_module:
  description: "threading.Lock().__class__.__module__ == '_thread' — lock instance C type is defined in _thread extension module; new to extra361"
  kind: python_call_eq
  function: Lock().__class__.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra361.rlock_class_name:
  description: "threading.RLock.__class__.__name__ == 'function' — RLock is a factory function, not a class; its __class__.__name__ is 'function'; new to extra361"
  kind: python_call_eq
  function: RLock.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra361.rlock_instance_class_name:
  description: "threading.RLock().__class__.__name__ == 'RLock' — RLock factory returns instance with __class__.__name__ == 'RLock'; new to extra361"
  kind: python_call_eq
  function: RLock().__class__.__name__.__eq__
  args: ["RLock"]
  expected: true

invariant threading_extra361.event_name:
  description: "threading.Event.__name__ == 'Event' — pure-Python synchronization class in Lib/threading.py; new to extra361"
  kind: python_call_eq
  function: Event.__name__.__eq__
  args: ["Event"]
  expected: true

invariant threading_extra361.event_module:
  description: "threading.Event.__module__ == 'threading' — defined in Lib/threading.py; new to extra361"
  kind: python_call_eq
  function: Event.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra361.event_bases_object:
  description: "threading.Event.__bases__[0].__name__ == 'object' — Event inherits directly from object; new to extra361"
  kind: python_call_eq
  function: Event.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

invariant threading_extra361.semaphore_name:
  description: "threading.Semaphore.__name__ == 'Semaphore' — pure-Python counting semaphore class in Lib/threading.py; new to extra361"
  kind: python_call_eq
  function: Semaphore.__name__.__eq__
  args: ["Semaphore"]
  expected: true

invariant threading_extra361.semaphore_module:
  description: "threading.Semaphore.__module__ == 'threading' — defined in Lib/threading.py; new to extra361"
  kind: python_call_eq
  function: Semaphore.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra361.semaphore_bases_object:
  description: "threading.Semaphore.__bases__[0].__name__ == 'object' — Semaphore inherits directly from object; new to extra361"
  kind: python_call_eq
  function: Semaphore.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true
