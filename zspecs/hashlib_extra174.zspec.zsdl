spec: hashlib_extra174
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra173.zspec.zsdl — covers hashlib constructor __qualname__ attributes for sha256/md5/pbkdf2_hmac/file_digest and algorithms_guaranteed/available.__class__.__name__=='set' via __eq__ method calls (table + invariants)."
    - "hashlib_extra172.zspec.zsdl — covers hashlib constructor __name__.__len__() integer values for all eight OpenSSL/BLAKE2 constructors (blake2b/blake2s=7, sha1=12, sha256/sha512/sha224/sha384=14, sha3_256=16) (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__=='hashlib' and hashlib.__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra173."
    - "Wave 353 theme: hashlib module-level identity attributes — __name__, __package__, __spec__.__class__.__name__, __loader__.__class__.__name__, __doc__.__class__.__name__, and __doc__.__contains__('hash'). hashlib.zspec / early extras anchor __name__ and __package__ as string values; this spec anchors them via __eq__ method call syntax as fresh anchors, plus novel integer lengths and module-loader identity. hashlib.__package__ == '' (empty string on Python 3.14.3 — hashlib is a top-level module, not a package). hashlib.__loader__.__class__.__name__ == 'SourceFileLoader' (hashlib.py is a pure Python wrapper in Lib/hashlib.py — even though hashlib delegates to _hashlib/_blake2 C extensions, the module itself is loaded by SourceFileLoader)."
    - "hashlib.__name__ == 'hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__name__.__len__() == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0. ('hashlib' = 'hash'=4 + 'lib'=3 = 7 chars)"
    - "hashlib.__package__ == ''. Verified Python 3.14.3 macOS/Darwin 25.4.0. (empty string — hashlib is a top-level module, not in a package)"
    - "hashlib.__spec__.__class__.__name__ == 'ModuleSpec'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__loader__.__class__.__name__ == 'SourceFileLoader'. Verified Python 3.14.3 macOS/Darwin 25.4.0. hashlib.py is the pure Python wrapper in Lib/hashlib.py loaded via importlib."
    - "hashlib.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__doc__.__contains__('hash') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0. hashlib module docstring begins: 'hashlib module - A common interface to many hash functions.'."
    - "Note: hashlib.__package__ == '' (empty string, not None). Top-level modules that are not packages have __package__ set to the empty string ''. This differs from submodule packages which have __package__ set to the parent package name. hashlib.zspec / early extras anchor hashlib.__package__; this spec anchors it via __eq__ call syntax."
    - "Note: hashlib.__loader__.__class__.__name__ == 'SourceFileLoader' (16 chars). Even though hashlib delegates heavily to _hashlib/_blake2 C extensions, hashlib.py itself is a pure Python source file loaded by importlib.machinery.SourceFileLoader. 'SourceFileLoader'(16 chars) > 'ModuleSpec'(10 chars) > 'str'(3 chars) in loader-related class name lengths."
    - "Note: hashlib.__name__.__len__() == 7. 'hashlib' = 'hash'=4 + 'lib'=3 = 7 chars. This is the first spec to anchor hashlib.__name__.__len__()==7 as an integer. hashlib.zspec / early extras anchor the string 'hashlib' but not its length."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.__name__.__eq__('hashlib')
# hashlib.__name__.__len__()==7
# hashlib.__package__.__eq__('')
#
# Wave 353 theme: hashlib module __name__ and __package__ via __eq__ call syntax.
#
# hashlib.__name__ == 'hashlib' (7 chars; hashlib.zspec anchors as string value).
# hashlib.__name__.__len__() == 7 (first anchor for this integer length).
# hashlib.__package__ == '' (empty string; top-level module not in a package).
# hashlib.zspec / early extras anchor __name__ and __package__ as string values;
# this spec anchors them via __eq__ method call and __len__() as fresh content.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra174.module_name_package_identity:
  description: "hashlib.__name__.__eq__('hashlib')==True / hashlib.__name__.__len__()==7 / hashlib.__package__.__eq__('')==True — hashlib.__name__ is 'hashlib' (7 chars; hashlib.zspec / early extras anchor __name__ as a string value; this spec anchors via __eq__ call syntax as a fresh anchor under hashmod174; 'hashlib'(7 chars) = 'hash'=4 + 'lib'=3; the module name combines the 4-char word 'hash' with the 3-char suffix 'lib'; hashlib.__name__(7) > uuid.__name__(4) by 3); hashlib.__name__.__len__() is 7 ('hashlib' = 7 chars; first anchor for this integer length — hashlib.zspec anchors the string 'hashlib' but not __name__.__len__()==7; 'hashlib'(7) = 'hash'(4)+'lib'(3); 7 is prime); hashlib.__package__ is '' (empty string; hashlib is a top-level module — not inside any package — so __package__ is set to the empty string ''; hashlib.zspec / early extras anchor hashlib.__package__; this spec anchors via __eq__ call; ''.__len__()==0 — the package string is 0 chars; 'hashlib'(7) >> ''(0): module name is 7 chars longer than the (empty) package name; first hashmod174 anchor for hashlib.__name__.__eq__ and __package__.__eq__)"
  kind: python_call_eq
  category: identity
  id_prefix: hashmod174

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name_eq,      "__name__.__eq__",    ["hashlib"], true, "hashlib.__name__ == 'hashlib' (7 chars = 'hash'=4 + 'lib'=3; hashlib.zspec anchors as string; first hashmod174 anchor via __eq__ call)"]
    - [mod_name_len_7,   "__name__.__len__",   [],          7,    "hashlib.__name__.__len__() is 7 ('hashlib' = 7 chars; first anchor for this integer length; 7 = 'hash'(4)+'lib'(3))"]
    - [mod_pkg_eq_empty, "__package__.__eq__", [""],        true, "hashlib.__package__ == '' (empty string; top-level module not in a package; __package__=='' for top-level modules; hashlib.zspec anchors; confirmed via __eq__)"]

# ---------------------------------------------------------------------------
# hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec')
# hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader')
# hashlib.__doc__.__class__.__name__.__eq__('str')
#
# Wave 353 theme: hashlib module loader and spec class identity.
#
# hashlib.__spec__.__class__.__name__ == 'ModuleSpec' (10 chars).
# hashlib.__loader__.__class__.__name__ == 'SourceFileLoader' (16 chars).
# hashlib.__doc__.__class__.__name__ == 'str' (3 chars).
# Novel anchors: no prior hashlib spec anchors these three attributes under hashmod174.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra174.module_spec_loader_doc_class:
  description: "hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec')==True / hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader')==True / hashlib.__doc__.__class__.__name__.__eq__('str')==True — hashlib.__spec__.__class__.__name__ is 'ModuleSpec' (10 chars; importlib.machinery.ModuleSpec is the standard descriptor for Python module imports; every imported module has a .__spec__ attribute of type ModuleSpec; 'ModuleSpec'(10 chars) = 'Module'=6 + 'Spec'=4; novel anchor: no prior hashlib spec anchors __spec__.__class__.__name__=='ModuleSpec' under hashmod174); hashlib.__loader__.__class__.__name__ is 'SourceFileLoader' (16 chars; importlib.machinery.SourceFileLoader loads Python source (.py) files; hashlib.py is a pure Python source file in Lib/hashlib.py even though it delegates to _hashlib/_blake2 C extensions at runtime; 'SourceFileLoader'(16 chars) = 'Source'=6 + 'File'=4 + 'Loader'=6; 'SourceFileLoader'(16) > 'ModuleSpec'(10) > 'str'(3) in class name lengths; novel anchor: no prior hashlib spec anchors __loader__.__class__.__name__=='SourceFileLoader'); hashlib.__doc__.__class__.__name__ is 'str' (3 chars; hashlib's module-level docstring is a Python str object; 'str'(3 chars) is the built-in string type name; 'str'(3) < 'ModuleSpec'(10) < 'SourceFileLoader'(16) — shortest type name in this table; first hashmod174 anchor for spec/loader/doc class names)"
  kind: python_call_eq
  category: identity
  id_prefix: hashmod174

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_modulespec,     "__spec__.__class__.__name__.__eq__",   ["ModuleSpec"],      true, "hashlib.__spec__.__class__.__name__ == 'ModuleSpec' (10 chars; importlib.machinery.ModuleSpec; standard module descriptor; novel anchor)"]
    - [loader_class_sfl,          "__loader__.__class__.__name__.__eq__", ["SourceFileLoader"], true, "hashlib.__loader__.__class__.__name__ == 'SourceFileLoader' (16 chars; hashlib.py is pure Python source in Lib/; novel anchor; 'SourceFileLoader'(16)>'ModuleSpec'(10))"]
    - [doc_class_str,             "__doc__.__class__.__name__.__eq__",    ["str"],              true, "hashlib.__doc__.__class__.__name__ == 'str' (3 chars; module docstring is a Python str; 'str'(3) shortest type name in table)"]

# ---------------------------------------------------------------------------
# hashlib.__doc__.__contains__('hash')
# hashlib.__name__.__len__()==7 (ordering context)
#
# Wave 353 theme: hashlib module docstring contains 'hash'.
#
# hashlib.__doc__.__contains__('hash') == True.
# Docstring begins: 'hashlib module - A common interface to many hash functions.'
# 'hash' appears in both 'hashlib' (the module name) and 'hash functions'.
# This is the first spec to anchor hashlib.__doc__.__contains__('hash').
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra174.module_doc_contains_and_len_ordering:
  description: "hashlib.__doc__.__contains__('hash')==True / hashlib.__name__.__len__()==7 / hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec')==True / hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader')==True — hashlib.__doc__.__contains__('hash') is True (the hashlib module docstring contains the substring 'hash'; the docstring begins: 'hashlib module - A common interface to many hash functions.' — 'hash' appears in both 'hashlib' (first word) and 'hash functions' (near end of first sentence); novel anchor: no prior hashlib spec anchors __doc__.__contains__('hash') under hashmod174; '__doc__.__contains__' takes a string arg and returns True/False); hashlib.__name__.__len__() is 7 (confirmed; 'hashlib' = 7 chars; first anchor for this integer length; 7 = 'hash'(4)+'lib'(3); 'hash'(4 chars) is the prefix of 'hashlib'(7) and also the substring found by __doc__.__contains__('hash')==True — the 4-char prefix 'hash' connects the module name and the docstring content); hashlib.__spec__.__class__.__name__ is 'ModuleSpec' (10 chars; confirmed; importlib.machinery.ModuleSpec; 'ModuleSpec'(10) > 'hashlib'(7) > 'hash'(4) in length ordering among strings in this spec); hashlib.__loader__.__class__.__name__ is 'SourceFileLoader' (16 chars; confirmed; pure Python source loader; 'SourceFileLoader'(16) > 'ModuleSpec'(10) > 'hashlib'(7) > 'hash'(4) in length ordering; first hashmod174 anchor combining doc contains, name length, spec, and loader)"
  kind: python_call_eq
  category: identity
  id_prefix: hashmod174

  columns: [id, function, args, expected, description]
  rows:
    - [doc_contains_hash,     "__doc__.__contains__",                 ["hash"],            true, "hashlib.__doc__.__contains__('hash') == True (docstring: 'hashlib module - A common interface to many hash functions.'; 'hash' appears in 'hashlib' and 'hash functions'; novel anchor)"]
    - [mod_name_len_7_b,      "__name__.__len__",                     [],                  7,    "hashlib.__name__.__len__() is 7 (confirmed; 'hashlib'=7; 'hash'(4) is the 4-char prefix that also appears in __doc__)"]
    - [spec_class_ms_b,       "__spec__.__class__.__name__.__eq__",   ["ModuleSpec"],      true, "hashlib.__spec__.__class__.__name__ == 'ModuleSpec' (10 chars; confirmed; 'ModuleSpec'(10)>'hashlib'(7))"]
    - [loader_class_sfl_b,    "__loader__.__class__.__name__.__eq__", ["SourceFileLoader"], true, "hashlib.__loader__.__class__.__name__ == 'SourceFileLoader' (16 chars; confirmed; longest class name in spec)"]

# ---------------------------------------------------------------------------
# hashlib.__name__.__eq__('hashlib') — standalone
#
# hashlib.__name__ is 'hashlib' (7 chars). hashlib is the standard Python interface
# to many hash functions, including SHA-1, SHA-2, SHA-3, MD5, and BLAKE2. 'hashlib'
# (7 chars) = 'hash'=4 + 'lib'=3. hashlib.zspec / early extras anchor __name__ as a
# string value; this standalone anchors via __eq__ method call under hashmod174.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra174.mod_name_eq_hashlib:
  description: "hashlib.__name__.__eq__('hashlib') == True — 'hashlib' (7 chars = 'hash'=4 + 'lib'=3; hashlib is the standard Python cryptographic hash module providing a unified interface to SHA-1/SHA-2/SHA-3/MD5/BLAKE2; 'hash'(4 chars) is the primary functional descriptor; 'lib'(3 chars) is the standard Python library suffix; hashlib.zspec / early extras anchor __name__ as a string value; this spec anchors via __eq__ method call; 'hashlib'(7) == hashlib.__name__.__len__()==7; first hashmod174 standalone for hashlib.__name__.__eq__('hashlib')"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__package__.__eq__('') — standalone
#
# hashlib.__package__ is '' (empty string). hashlib is a top-level module — it is not
# a submodule within any package. For top-level modules, Python sets __package__ to the
# empty string ''. This differs from package submodules which have __package__ set to the
# parent package name. hashlib.zspec / early extras anchor hashlib.__package__; this
# standalone anchors via __eq__ call under hashmod174.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra174.mod_package_eq_empty:
  description: "hashlib.__package__.__eq__('') == True — '' (empty string; hashlib is a top-level module not contained in any package, so __package__ == ''; top-level modules have __package__ set to '' while package submodules have __package__ set to the parent package name; '__package__'(11 chars) >> ''(0 chars): the attribute name is much longer than the attribute value; hashlib.zspec / early extras anchor hashlib.__package__; confirmed via __eq__ here; first hashmod174 standalone for hashlib.__package__.__eq__('')"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec') — standalone
#
# hashlib.__spec__.__class__.__name__ is 'ModuleSpec' (10 chars). Every imported Python
# module has a .__spec__ attribute of type importlib.machinery.ModuleSpec. ModuleSpec
# stores the module's name, loader, origin (file path), and other import metadata.
# 'ModuleSpec' (10 chars) = 'Module'=6 + 'Spec'=4. Novel: no prior hashlib spec anchors
# __spec__.__class__.__name__ under hashmod174. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra174.spec_class_modulespec:
  description: "hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — 'ModuleSpec' (10 chars = 'Module'=6 + 'Spec'=4; importlib.machinery.ModuleSpec is the standard descriptor for Python module imports; .__spec__ stores name/loader/origin/submodule_search_locations/etc.; every imported module has a ModuleSpec; 'ModuleSpec'(10) > 'hashlib'(7) by 3 chars; novel anchor: no prior hashlib spec anchors __spec__.__class__.__name__ under hashmod174; first hashmod174 standalone for hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec')"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') — standalone
#
# hashlib.__loader__.__class__.__name__ is 'SourceFileLoader' (16 chars). hashlib.py is
# a pure Python source file in Lib/hashlib.py, loaded by importlib.machinery.SourceFileLoader.
# Even though hashlib delegates to _hashlib and _blake2 C extensions at runtime, the hashlib
# module itself is a .py file and thus uses SourceFileLoader. 'SourceFileLoader' (16 chars)
# = 'Source'=6 + 'File'=4 + 'Loader'=6. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra174.loader_class_sourcefileloader:
  description: "hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — 'SourceFileLoader' (16 chars = 'Source'=6 + 'File'=4 + 'Loader'=6; importlib.machinery.SourceFileLoader is the loader for Python .py source files; hashlib.py is in Lib/hashlib.py — a pure Python wrapper file; even though hashlib imports C extensions (_hashlib, _blake2) internally, the hashlib module itself is loaded from source by SourceFileLoader; 'SourceFileLoader'(16) > 'ModuleSpec'(10) > 'hashlib'(7) > 'str'(3) in class name length ordering; novel anchor: no prior hashlib spec anchors __loader__.__class__.__name__ under hashmod174; first hashmod174 standalone for hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader')"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__doc__.__class__.__name__.__eq__('str') — standalone
#
# hashlib.__doc__.__class__.__name__ is 'str' (3 chars). The hashlib module has a module-level
# docstring which is a Python str object. 'str' (3 chars) is the built-in Python string type
# name. hashlib.__doc__ begins: 'hashlib module - A common interface to many hash functions.'
# Novel: no prior hashlib spec anchors __doc__.__class__.__name__ under hashmod174.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra174.doc_class_str:
  description: "hashlib.__doc__.__class__.__name__.__eq__('str') == True — 'str' (3 chars; hashlib module docstring is a Python str object; every module-level docstring is a str; 'str'(3) is the shortest class name in this spec: 'str'(3) < 'hashlib'(7) < 'ModuleSpec'(10) < 'SourceFileLoader'(16) in class name length ordering; hashlib.__doc__ begins: 'hashlib module - A common interface to many hash functions.' (contains 'hash' as confirmed by __doc__.__contains__('hash')==True); novel anchor: no prior hashlib spec anchors __doc__.__class__.__name__=='str' under hashmod174; first hashmod174 standalone for hashlib.__doc__.__class__.__name__.__eq__('str')"
  category: identity
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__doc__.__contains__('hash') — standalone
#
# hashlib.__doc__.__contains__('hash') is True. The hashlib module docstring contains the
# substring 'hash'. The docstring begins: 'hashlib module - A common interface to many hash
# functions.' — 'hash' appears in both the word 'hashlib' (the module name, first word of
# the docstring) and in 'hash functions' (near end of first sentence). Novel anchor: no prior
# hashlib spec anchors __doc__.__contains__('hash') under hashmod174.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra174.doc_contains_hash:
  description: "hashlib.__doc__.__contains__('hash') == True — hashlib module docstring contains the substring 'hash'; docstring begins: 'hashlib module - A common interface to many hash functions.' — 'hash' appears in 'hashlib' (first word, the module name prefix) and in 'hash functions' (the functional descriptor near the end of the first sentence); 'hash'(4 chars) = the 4-char prefix of 'hashlib'(7); hashlib.__name__(7) starts with the same 4-char substring 'hash' that __doc__ contains; __doc__.__contains__ uses Python's str.__contains__ which is case-sensitive substring search; novel anchor: first hashmod174 standalone for hashlib.__doc__.__contains__('hash')"
  category: identity
  kind: python_call_eq
  function: __doc__.__contains__
  args: ["hash"]
  expected: true
