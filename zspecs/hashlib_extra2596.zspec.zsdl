spec: hashlib_extra2596
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_hashlib.c"
  notes:
    - "Wave 2596 theme: __get__/__set__/__delete__ descriptor protocol dict-presence — checking whether _hashlib.HASH implements the descriptor protocol in its own class __dict__."
    - "_hashlib.HASH is the C-extension type returned by hashlib.md5(), hashlib.sha256(), etc."
    - "_hashlib.HASH.__dict__.__contains__('__get__') == False — hash objects are not descriptors; they do not implement the descriptor protocol. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
    - "_hashlib.HASH.__dict__.__contains__('__set__') == False — hash objects do not define __set__, so they are not data descriptors. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
    - "_hashlib.HASH.__dict__.__contains__('__delete__') == False — hash objects do not define __delete__, confirming non-descriptor status. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
    - "_hashlib.HASH.__dict__.__contains__('__set_name__') == False — __set_name__ is also absent; the class is not a descriptor at all."
    - "Note: _hashlib.HASH.__dict__ DOES contain descriptor-typed values (digest_size, block_size, name are getset_descriptors) but the HASH class itself does not implement __get__/__set__/__delete__."
    - "_hashlib.HASH.__dict__.__contains__('update') == True — update() feeds data into the hash accumulator."
    - "_hashlib.HASH.__dict__.__contains__('digest') == True — digest() returns the binary hash value."
    - "_hashlib.HASH.__dict__.__contains__('hexdigest') == True — hexdigest() returns the hex-encoded hash value."
    - "_hashlib.HASH.__dict__.__contains__('digest_size') == True — digest_size is a getset_descriptor exposing the output byte count."
    - "_hashlib.HASH.__dict__.__contains__('block_size') == True — block_size is a getset_descriptor exposing the internal block size."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __get__ absence — _hashlib.HASH does not implement the non-data descriptor protocol
#
# For a class to act as a non-data descriptor, it must define __get__ in its
# own __dict__. _hashlib.HASH does not. Hash objects are stateful accumulators,
# not attribute descriptors.
# ---------------------------------------------------------------------------

table hashlib_extra2596.get_absent:
  description: "__get__ is absent from _hashlib.HASH.__dict__ — hash objects do not implement the non-data descriptor protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2596

  columns: [id, function, args, expected]
  rows:
    - ["hl2596001", "md5().__class__.__dict__.__contains__",    ["__get__"], false]
    - ["hl2596002", "sha256().__class__.__dict__.__contains__", ["__get__"], false]
    - ["hl2596003", "sha1().__class__.__dict__.__contains__",   ["__get__"], false]

# ---------------------------------------------------------------------------
# __set__ absence — _hashlib.HASH does not implement the data descriptor write protocol
#
# A data descriptor must define __set__ (and/or __delete__). _hashlib.HASH
# defines neither. The class is not usable as an attribute descriptor at all.
# ---------------------------------------------------------------------------

table hashlib_extra2596.set_absent:
  description: "__set__ is absent from _hashlib.HASH.__dict__ — hash objects do not implement the data descriptor write protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2596

  columns: [id, function, args, expected]
  rows:
    - ["hl2596004", "md5().__class__.__dict__.__contains__",    ["__set__"], false]
    - ["hl2596005", "sha256().__class__.__dict__.__contains__", ["__set__"], false]
    - ["hl2596006", "sha1().__class__.__dict__.__contains__",   ["__set__"], false]

# ---------------------------------------------------------------------------
# __delete__ absence — _hashlib.HASH does not implement the data descriptor delete protocol
#
# __delete__ is the third component of the data descriptor protocol.
# Its absence from _hashlib.HASH.__dict__ confirms hash objects are not
# data descriptors of any kind.
# ---------------------------------------------------------------------------

table hashlib_extra2596.delete_absent:
  description: "__delete__ is absent from _hashlib.HASH.__dict__ — hash objects do not implement the data descriptor delete protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2596

  columns: [id, function, args, expected]
  rows:
    - ["hl2596007", "md5().__class__.__dict__.__contains__",    ["__delete__"], false]
    - ["hl2596008", "sha256().__class__.__dict__.__contains__", ["__delete__"], false]
    - ["hl2596009", "sha1().__class__.__dict__.__contains__",   ["__delete__"], false]

# ---------------------------------------------------------------------------
# Core API present — confirming the __dict__ lookup works
#
# These True entries confirm that __dict__.__contains__ is functioning
# correctly and that _hashlib.HASH genuinely has an API in its __dict__,
# just not the descriptor protocol methods.
# ---------------------------------------------------------------------------

table hashlib_extra2596.core_api_present:
  description: "Core hash API methods are present in _hashlib.HASH.__dict__, contrasting with absent descriptor protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2596

  columns: [id, function, args, expected]
  rows:
    - ["hl2596010", "md5().__class__.__dict__.__contains__", ["update"],      true]
    - ["hl2596011", "md5().__class__.__dict__.__contains__", ["digest"],      true]
    - ["hl2596012", "md5().__class__.__dict__.__contains__", ["hexdigest"],   true]
    - ["hl2596013", "md5().__class__.__dict__.__contains__", ["copy"],        true]
    - ["hl2596014", "md5().__class__.__dict__.__contains__", ["digest_size"], true]
    - ["hl2596015", "md5().__class__.__dict__.__contains__", ["block_size"],  true]
    - ["hl2596016", "md5().__class__.__dict__.__contains__", ["name"],        true]
