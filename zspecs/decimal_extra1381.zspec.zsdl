    - [dc1381ca004, decimal.InvalidOperation.__dict__.__contains__,  ["__abstractmethods__"], false, "decimal.InvalidOperation.__dict__.__contains__('__abstractmethods__') == False (all four decimal classes absent check 4/4); verified with Python 3.12"]
    - [dc1381ca005, decimal.Decimal.__dict__.__contains__,          ["__abstractmethods__"], false, "decimal.Decimal.__dict__.__contains__('__abstractmethods__') == False (cross-check anchor: Decimal absent); verified with Python 3.12"]
