spec: decimal_extra1381
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module Decimal, Context, DecimalException, InvalidOperation documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 539 (_extra1381): focuses on __abstractmethods__ frozenset checks for decimal module classes."
    - "None of the decimal module classes (decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation) have '__abstractmethods__' in their own __dict__."
    - "decimal.Decimal and decimal.Context are C extension types from the _decimal module; decimal.DecimalException and decimal.InvalidOperation are pure-Python exception classes. None use the ABCMeta frozenset mechanism."
    - "decimal.Decimal.__dict__.__contains__('__abstractmethods__') == False; decimal.Context.__dict__.__contains__('__abstractmethods__') == False; decimal.DecimalException.__dict__.__contains__('__abstractmethods__') == False; decimal.InvalidOperation.__dict__.__contains__('__abstractmethods__') == False; verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "This is consistent with the re and pathlib modules where no public classes register __abstractmethods__; contrasts with io module abstract base classes which do."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra1381.decimal_context_no_abstractmethods:
  description: "decimal.Decimal and decimal.Context __dict__ lacks __abstractmethods__ — wave 539 theme: both are C extension types from _decimal; neither registers __abstractmethods__ in its own __dict__; C extension types do not use the ABCMeta frozenset mechanism; verified with Python 3.12"
  kind: python_call_eq
  category: abstractmethods_checks
  id_prefix: dc1381dc
  columns: [id, function, args, expected, description]
  rows:
    - [dc1381dc001, decimal.Decimal.__dict__.__contains__,         ["__abstractmethods__"], false, "decimal.Decimal.__dict__.__contains__('__abstractmethods__') == False (C extension type, no ABCMeta registration); verified with Python 3.12"]
    - [dc1381dc002, decimal.Context.__dict__.__contains__,         ["__abstractmethods__"], false, "decimal.Context.__dict__.__contains__('__abstractmethods__') == False (C extension type, no ABCMeta registration); verified with Python 3.12"]
    - [dc1381dc003, decimal.DecimalException.__dict__.__contains__, ["__abstractmethods__"], false, "decimal.DecimalException.__dict__.__contains__('__abstractmethods__') == False (Python exception class, no ABCMeta registration); verified with Python 3.12"]
    - [dc1381dc004, decimal.InvalidOperation.__dict__.__contains__, ["__abstractmethods__"], false, "decimal.InvalidOperation.__dict__.__contains__('__abstractmethods__') == False (Python exception subclass, no ABCMeta registration); verified with Python 3.12"]
    - [dc1381dc005, decimal.Decimal.__dict__.__contains__,         ["__abstractmethods__"], false, "decimal.Decimal.__dict__.__contains__('__abstractmethods__') == False (cross-check anchor: Decimal C extension type absent); verified with Python 3.12"]
    - [dc1381dc006, decimal.Context.__dict__.__contains__,         ["__abstractmethods__"], false, "decimal.Context.__dict__.__contains__('__abstractmethods__') == False (cross-check: Context C extension type absent); verified with Python 3.12"]
    - [dc1381dc007, decimal.Decimal.__dict__.__contains__,         ["__doc__"],             true,  "decimal.Decimal.__dict__.__contains__('__doc__') == True (sanity check: Decimal does have __doc__ in own __dict__); verified with Python 3.12"]

table decimal_extra1381.exception_classes_no_abstractmethods:
  description: "decimal.DecimalException and decimal.InvalidOperation __dict__ lacks __abstractmethods__ — wave 539 theme: the two decimal exception classes are pure-Python; neither registers __abstractmethods__ in its own __dict__; exception hierarchies do not use the ABCMeta frozenset mechanism; verified with Python 3.12"
  kind: python_call_eq
  category: abstractmethods_checks
  id_prefix: dc1381de
  columns: [id, function, args, expected, description]
  rows:
    - [dc1381de001, decimal.DecimalException.__dict__.__contains__,  ["__abstractmethods__"], false, "decimal.DecimalException.__dict__.__contains__('__abstractmethods__') == False (pure-Python exception base, not abstract); verified with Python 3.12"]
    - [dc1381de002, decimal.InvalidOperation.__dict__.__contains__,  ["__abstractmethods__"], false, "decimal.InvalidOperation.__dict__.__contains__('__abstractmethods__') == False (pure-Python exception subclass, not abstract); verified with Python 3.12"]
    - [dc1381de003, decimal.Decimal.__dict__.__contains__,           ["__abstractmethods__"], false, "decimal.Decimal.__dict__.__contains__('__abstractmethods__') == False (cross-check: C extension type also absent); verified with Python 3.12"]
    - [dc1381de004, decimal.Context.__dict__.__contains__,           ["__abstractmethods__"], false, "decimal.Context.__dict__.__contains__('__abstractmethods__') == False (cross-check: C extension type also absent); verified with Python 3.12"]
    - [dc1381de005, decimal.DecimalException.__dict__.__contains__,  ["__doc__"],             true,  "decimal.DecimalException.__dict__.__contains__('__doc__') == True (sanity check: DecimalException does have __doc__ in own __dict__); verified with Python 3.12"]
    - [dc1381de006, decimal.InvalidOperation.__dict__.__contains__,  ["__abstractmethods__"], false, "decimal.InvalidOperation.__dict__.__contains__('__abstractmethods__') == False (final cross-check: exception subclass also absent); verified with Python 3.12"]

