spec: abc_extra781
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - abc standard library documentation
    - CPython source for abc module
  not_derived_from:
    - any third-party abstract base class frameworks
    - zope.interface or similar ABC alternatives
  notes:
    - Covers __all__, module-level identity attributes, and class/function name checks
    - __loader__ and __spec__ checks confirm standard import machinery is in use
  created_at: "2026-04-12"

table abc_extra781.name:
  description: abc module __all__ and special attribute identity checks
  kind: python_call_eq
  category: stdlib_identity
  id_prefix: ab781
  columns: [id, function, args, expected]
  rows:
    - [ab781xx001, abc.__all__.__class__.__name__.__eq__, ["list"], true]
    - [ab781xx002, abc.__name__.__eq__, ["abc"], true]
    - [ab781xx003, abc.__package__.__eq__, ["abc"], true]
    - [ab781xx004, abc.__loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true]
    - [ab781xx005, abc.__spec__.__class__.__name__.__eq__, ["ModuleSpec"], true]
    - [ab781xx006, abc.ABC.__name__.__eq__, ["ABC"], true]
    - [ab781xx007, abc.ABCMeta.__name__.__eq__, ["ABCMeta"], true]
    - [ab781xx008, abc.abstractmethod.__name__.__eq__, ["abstractmethod"], true]
    - [ab781xx009, abc.get_cache_token.__name__.__eq__, ["get_cache_token"], true]
    - [ab781xx010, abc.update_abstractmethods.__name__.__eq__, ["update_abstractmethods"], true]
    - [ab781xx011, abc.ABC.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [ab781xx012, abc.ABCMeta.__bases__.__class__.__name__.__eq__, ["tuple"], true]
