spec: termios_extra3
version: ">=3.9"
backend: python_module(termios)

docs: https://docs.python.org/3/library/termios.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/termios.html — Python termios module documentation"
    - "POSIX.1-2017 — termios(3): TCIFLUSH=1, TCOFLUSH=2, TCIOFLUSH=3, TCION=4, TCOON=2, TCIOFF=3, TCOOFF=1 on macOS"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/termios.c"
  notes:
    - "This spec extends termios.zspec.zsdl, termios_extra.zspec.zsdl, and termios_extra2.zspec.zsdl."
    - "termios covers: function __name__ for all 6 functions, TCSANOW/TCSADRAIN/TCSAFLUSH values, ECHO/ICANON/NOFLSH type checks, ECHO > 0."
    - "termios_extra covers: 5 function __name__ checks, TCSANOW/TCSADRAIN/TCSAFLUSH class checks, IFLAG/OFLAG/CFLAG/LFLAG/ISPEED/OSPEED/CC value pins."
    - "termios_extra2 covers: tcsendbreak __name__, all-function __qualname__ and type tables, TCSANOW/TCSADRAIN/TCSAFLUSH compact value table, index constants class checks, TCSANOW < TCSADRAIN and TCSADRAIN < TCSAFLUSH."
    - "New here: termios module __name__ and __package__; tcflush/tcflow action constants (TCIFLUSH/TCOFLUSH/TCIOFLUSH and TCION/TCOON/TCIOFF/TCOOFF) value pins; baud rate constants B0/B9600/B115200 value pins; NCCS value; VMIN/VTIME value pins."
    - "TCIFLUSH=1, TCOFLUSH=2, TCIOFLUSH=3 — tcflush(fd, queue_selector) queue selector values."
    - "TCION=4, TCOON=2, TCIOFF=3, TCOOFF=1 — tcflow(fd, action) action values on macOS."
    - "B0=0, B9600=9600, B115200=115200 — baud rate constants; B9600 and B115200 numerically equal the baud rate."
    - "NCCS=20 — size of the c_cc control-character array on macOS."
    - "VMIN=16, VTIME=17 — indices into the c_cc array for minimum byte count and timeout."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module __name__ and __package__ — not covered in any prior termios spec
# ---------------------------------------------------------------------------

invariant termios_extra3.module.name:
  description: "termios.__name__ == 'termios' — the module's own __name__ attribute"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["termios"]
  expected: true

invariant termios_extra3.module.package:
  description: "termios.__package__ == '' — termios is a top-level C extension module"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# tcflush queue-selector constants — value pins
# termios_extra2 covers TCSANOW/TCSADRAIN/TCSAFLUSH only; these are distinct constants
# used as the second argument to tcflush(). Not covered in any prior spec.
# TCIFLUSH=1, TCOFLUSH=2, TCIOFLUSH=3 on macOS (POSIX standard values).
# ---------------------------------------------------------------------------

table termios_extra3.tcflush_constants.values:
  kind: python_call_eq
  category: constants
  id_prefix: tcflush_val

  columns: [id, function, args, expected]
  rows:
    - [TCIFLUSH,  TCIFLUSH.__eq__,  [1], true]
    - [TCOFLUSH,  TCOFLUSH.__eq__,  [2], true]
    - [TCIOFLUSH, TCIOFLUSH.__eq__, [3], true]

# ---------------------------------------------------------------------------
# tcflow action constants — value pins
# Used as the second argument to tcflow(). Not covered in any prior spec.
# TCIOFF=3, TCOOFF=1, TCION=4, TCOON=2 on macOS.
# ---------------------------------------------------------------------------

table termios_extra3.tcflow_constants.values:
  kind: python_call_eq
  category: constants
  id_prefix: tcflow_val

  columns: [id, function, args, expected]
  rows:
    - [TCIOFF, TCIOFF.__eq__, [3], true]
    - [TCOOFF, TCOOFF.__eq__, [1], true]
    - [TCION,  TCION.__eq__,  [4], true]
    - [TCOON,  TCOON.__eq__,  [2], true]

# ---------------------------------------------------------------------------
# Baud rate constants — value pins
# B0, B9600, and B115200 are portable; the numeric value equals the baud rate
# for B9600 and B115200 on POSIX platforms (not the case on all embedded BSPs).
# Not covered in any prior termios spec.
# ---------------------------------------------------------------------------

invariant termios_extra3.B0.value:
  description: "termios.B0 == 0 — hang up (disconnect) baud rate sentinel"
  category: constants
  kind: python_call_eq
  function: B0.__eq__
  args: [0]
  expected: true

invariant termios_extra3.B9600.value:
  description: "termios.B9600 == 9600 — 9600 baud rate constant (macOS/Linux: value equals baud rate)"
  category: constants
  kind: python_call_eq
  function: B9600.__eq__
  args: [9600]
  expected: true

invariant termios_extra3.B115200.value:
  description: "termios.B115200 == 115200 — 115200 baud rate constant (macOS/Linux: value equals baud rate)"
  category: constants
  kind: python_call_eq
  function: B115200.__eq__
  args: [115200]
  expected: true

# ---------------------------------------------------------------------------
# NCCS — size of the c_cc control-character array
# Defined by POSIX; value is 20 on macOS. Not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant termios_extra3.NCCS.value:
  description: "termios.NCCS == 20 — number of control characters in c_cc array (macOS)"
  category: constants
  kind: python_call_eq
  function: NCCS.__eq__
  args: [20]
  expected: true

# ---------------------------------------------------------------------------
# VMIN and VTIME — c_cc array indices for non-canonical mode parameters
# Not covered in any prior termios spec.
# VMIN=16, VTIME=17 on macOS.
# ---------------------------------------------------------------------------

invariant termios_extra3.VMIN.value:
  description: "termios.VMIN == 16 — c_cc index for minimum bytes in non-canonical read (macOS)"
  category: constants
  kind: python_call_eq
  function: VMIN.__eq__
  args: [16]
  expected: true

invariant termios_extra3.VTIME.value:
  description: "termios.VTIME == 17 — c_cc index for timeout in non-canonical read (macOS)"
  category: constants
  kind: python_call_eq
  function: VTIME.__eq__
  args: [17]
  expected: true
