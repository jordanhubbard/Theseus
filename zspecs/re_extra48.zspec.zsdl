spec: re_extra48
version: ">=3.11"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra47.zspec.zsdl — covers re.error.__qualname__.__len__()==12 (post-3.12 rename); re.PatternError.__name__/__qualname__/__module__/__bases__[0].__name__/__mro__.__len__()."
    - "re_extra45.zspec.zsdl — covers RegexFlag._value_ for IGNORECASE/ASCII/LOCALE/UNICODE/DEBUG/NOFLAG; re.A/re.I __class__.__name__=='RegexFlag'."
    - "re_extra41.zspec.zsdl — covers VERBOSE._value_ and MULTILINE._value_ attributes."
    - "re_extra35.zspec.zsdl — covers RegexFlag.__name__.__len__()==9; RegexFlag.__mro__.__len__()==7."
    - "re_extra27.zspec.zsdl — covers RegexFlag.__module__.__eq__('re'); RegexFlag.__bases__[0].__name__.__eq__('IntFlag')."
    - "re_extra14.zspec.zsdl — covers RegexFlag.__name__/__qualname__/__module__ equality."
  notes:
    - "This spec extends re_extra47.zspec.zsdl."
    - "Prior specs collectively covered: all RegexFlag class identity attributes — __name__/__qualname__/__module__/__bases__[0].__name__/__mro__.__len__() via equality and length anchors (re_extra14/27/35); all flag ._value_ attributes for IGNORECASE/ASCII/LOCALE/UNICODE/DEBUG/NOFLAG/VERBOSE/MULTILINE (re_extra41/re_extra45); all flag .value attributes for IGNORECASE/MULTILINE/DOTALL/VERBOSE/ASCII/LOCALE/UNICODE/NOFLAG (re_extra7/re_extra10); all flag __class__.__name__=='RegexFlag' for all flags and aliases (re_extra2/re_extra10/re_extra45); re.error.__module__=='re' via PatternError path (re_extra47); re.IGNORECASE.__class__.__name__=='RegexFlag' (re_extra2). NO prior re spec checks any flag's ._name_ attribute (the IntEnum/IntFlag canonical member name string)."
    - "This spec covers: re.IGNORECASE._name_=='IGNORECASE' (NOVEL — ._name_ is the enum member's canonical name string, distinct from .value and ._value_; no prior re spec accesses ._name_ for any flag; novel equality anchor in re_extra48 namespace); re.ASCII._name_=='ASCII' (NOVEL — same reasoning; no prior re spec covers ._name_ for ASCII); re.MULTILINE._name_=='MULTILINE' (NOVEL); re.DOTALL._name_=='DOTALL' (NOVEL); re.VERBOSE._name_=='VERBOSE' (NOVEL — re_extra41 covers VERBOSE._value_==64 but NOT ._name_; novel); re.UNICODE._name_=='UNICODE' (NOVEL — re_extra45 covers UNICODE._value_ but NOT ._name_; novel); re.LOCALE._name_=='LOCALE' (NOVEL — re_extra45 covers LOCALE._value_ but NOT ._name_; novel)."
    - "re.IGNORECASE._name_ == 'IGNORECASE'. For Python IntFlag members, ._name_ is the canonical enum member name. It is distinct from ._value_ (the integer value) and .value (same as ._value_). No prior re spec accesses ._name_ for any flag. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.ASCII._name_ == 'ASCII'. ASCII is the re flag for ASCII-only character class matching. Its ._name_ is the enum member name string. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.MULTILINE._name_ == 'MULTILINE'. MULTILINE enables '^' and '$' to match at embedded newlines. Its ._name_ is 'MULTILINE'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.DOTALL._name_ == 'DOTALL'. DOTALL enables '.' to match newlines. Its ._name_ is 'DOTALL'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.VERBOSE._name_ == 'VERBOSE'. VERBOSE allows whitespace and comments in patterns. re_extra41 covers ._value_==64 but not ._name_. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.UNICODE._name_ == 'UNICODE'. UNICODE enables Unicode-aware matching (default in Python 3). re_extra45 covers ._value_==32 but not ._name_. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.LOCALE._name_ == 'LOCALE'. LOCALE enables locale-aware matching. re_extra45 covers ._value_==4 but not ._name_. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.RegexFlag member ._name_ attributes
#
# For Python's IntFlag enum (which RegexFlag subclasses), each member has a
# ._name_ attribute that stores the canonical enum member name as a string.
# This is distinct from:
#   ._value_ — the integer value (e.g. IGNORECASE._value_ == 2)
#   .value   — same as ._value_ (e.g. IGNORECASE.value == 2)
#
# The ._name_ attribute mirrors the member's identifier:
#
#   re.IGNORECASE._name_ == 'IGNORECASE'   (10 chars)
#   re.ASCII._name_      == 'ASCII'        ( 5 chars)
#   re.MULTILINE._name_  == 'MULTILINE'    ( 9 chars)
#   re.DOTALL._name_     == 'DOTALL'       ( 6 chars)
#   re.VERBOSE._name_    == 'VERBOSE'      ( 7 chars)
#   re.UNICODE._name_    == 'UNICODE'      ( 7 chars)
#   re.LOCALE._name_     == 'LOCALE'       ( 6 chars)
#
# Prior re specs cover ._value_ (re_extra41/re_extra45) and .value
# (re_extra7/re_extra10) and __class__.__name__=='RegexFlag' (re_extra2/re_extra10)
# for all flags, but NO prior re spec accesses ._name_ for any flag.
#
# All seven equality anchors are novel in the re_extra48 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra48.regexflag_name_attrs:
  description: "re.RegexFlag member ._name_ equality: IGNORECASE/'IGNORECASE'/ASCII/'ASCII'/MULTILINE/'MULTILINE'/DOTALL/'DOTALL'/VERBOSE/'VERBOSE'/UNICODE/'UNICODE'/LOCALE/'LOCALE' — ._name_ is the canonical IntFlag enum member name string, distinct from ._value_ and .value; no prior re spec accesses ._name_ for any flag; all seven novel equality anchors in re_extra48 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: flag_identity
  id_prefix: rfna48

  columns: [id, function, args, expected]
  rows:
    - [IGNORECASE_name, IGNORECASE._name_.__eq__, ["IGNORECASE"], true]
    - [ASCII_name,      ASCII._name_.__eq__,      ["ASCII"],      true]
    - [MULTILINE_name,  MULTILINE._name_.__eq__,  ["MULTILINE"],  true]
    - [DOTALL_name,     DOTALL._name_.__eq__,     ["DOTALL"],     true]
    - [VERBOSE_name,    VERBOSE._name_.__eq__,    ["VERBOSE"],    true]
    - [UNICODE_name,    UNICODE._name_.__eq__,    ["UNICODE"],    true]
    - [LOCALE_name,     LOCALE._name_.__eq__,     ["LOCALE"],     true]

# ---------------------------------------------------------------------------
# re.RegexFlag member ._name_ string lengths
#
# The ._name_ string for each flag has a length that equals the length of
# its Python identifier. These are complementary length anchors to the
# equality checks above.
#
#   IGNORECASE._name_.__len__() == 10
#   ASCII._name_.__len__()      ==  5
#   MULTILINE._name_.__len__()  ==  9
#   DOTALL._name_.__len__()     ==  6
#   VERBOSE._name_.__len__()    ==  7
#   UNICODE._name_.__len__()    ==  7
#   LOCALE._name_.__len__()     ==  6
#
# No prior re spec checks ._name_.__len__() for any flag.
# All seven are novel length anchors in the re_extra48 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra48.regexflag_name_attr_lens:
  description: "re.RegexFlag member ._name_.__len__(): IGNORECASE(10)/ASCII(5)/MULTILINE(9)/DOTALL(6)/VERBOSE(7)/UNICODE(7)/LOCALE(6) — length of enum member name string; no prior re spec checks ._name_.__len__() for any flag; all seven novel length anchors in re_extra48 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: flag_identity
  id_prefix: rfnal48

  columns: [id, function, args, expected]
  rows:
    - [IGNORECASE_name_len, IGNORECASE._name_.__len__, [], 10]
    - [ASCII_name_len,      ASCII._name_.__len__,      [],  5]
    - [MULTILINE_name_len,  MULTILINE._name_.__len__,  [],  9]
    - [DOTALL_name_len,     DOTALL._name_.__len__,     [],  6]
    - [VERBOSE_name_len,    VERBOSE._name_.__len__,    [],  7]
    - [UNICODE_name_len,    UNICODE._name_.__len__,    [],  7]
    - [LOCALE_name_len,     LOCALE._name_.__len__,     [],  6]
