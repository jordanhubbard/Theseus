spec: abc_extra275
version: ">=3.9"
backend: python_module(collections.abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — Python collections.abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
    - "abc_extra274.zspec.zsdl — covers collections.abc.ItemsView, KeysView, ValuesView, and MappingView class identity"
  notes:
    - "This spec covers: collections.abc.Set and collections.abc.MutableSet class identity; collections.abc.Sequence class identity and method qualnames (index, count). NEW in extra275: collections.abc.Set.__name__=='Set'; collections.abc.Set.__module__=='collections.abc'; collections.abc.Set.__bases__[0].__name__=='Collection'; collections.abc.Set.__mro__.__len__()==6 ([Set, Collection, Sized, Iterable, Container, object]); collections.abc.Set.__qualname__=='Set'; collections.abc.Set.__name__.__len__()==3 (shortest class name in spec); collections.abc.MutableSet.__name__=='MutableSet'; collections.abc.MutableSet.__module__=='collections.abc'; collections.abc.MutableSet.__bases__[0].__name__=='Set'; collections.abc.MutableSet.__mro__.__len__()==7; collections.abc.Sequence.__name__=='Sequence'; collections.abc.Sequence.__module__=='collections.abc'; collections.abc.Sequence.__bases__[0].__name__=='Reversible'; collections.abc.Sequence.__mro__.__len__()==7; collections.abc.Sequence.index.__qualname__=='Sequence.index' (len=14); collections.abc.Sequence.count.__qualname__=='Sequence.count' (len=14). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "collections.abc.Set.__mro__.__len__() == 6 — Set's MRO is [Set, Collection, Sized, Iterable, Container, object]; Set inherits from Collection (its sole direct base); Collection's MRO adds [Collection, Sized, Iterable, Container, object] (len=5); Set.__mro__.__len__() is 6. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "collections.abc.MutableSet.__mro__.__len__() == 7 — MutableSet's MRO is [MutableSet, Set, Collection, Sized, Iterable, Container, object]; MutableSet inherits from Set, adding one level to Set's 6-element MRO. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "collections.abc.Sequence.index.__qualname__ == 'Sequence.index' (len=14: 'Sequence.'=9+'index'=5); collections.abc.Sequence.count.__qualname__ == 'Sequence.count' (len=14: 'Sequence.'=9+'count'=5); both method qualnames are the same length. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# collections.abc.Set and MutableSet class identity — extra275
#
# Set.__name__                    == 'Set'
# Set.__module__                  == 'collections.abc'
# Set.__bases__[0].__name__       == 'Collection'
# Set.__mro__.__len__()           == 6
# Set.__qualname__                == 'Set'
# Set.__name__.__len__()          == 3
# MutableSet.__name__             == 'MutableSet'
# MutableSet.__module__           == 'collections.abc'
# MutableSet.__bases__[0].__name__ == 'Set'
# MutableSet.__mro__.__len__()    == 7
# MutableSet.__qualname__         == 'MutableSet'
# MutableSet.__name__.__len__()   == 10
# ---------------------------------------------------------------------------

table abc_extra275.cabc_set_mutableset_identity:
  description: "collections.abc.Set and MutableSet class identity checks in cabcset275 namespace — Set and MutableSet are defined in Lib/_collections_abc.py; Set inherits from Collection (single direct base); Set.__name__.__eq__('Set')==True; Set.__module__.__eq__('collections.abc')==True (len=15: 'collections'=11+'.abc'=4); Set.__bases__[0].__name__.__eq__('Collection')==True; Set.__mro__.__len__()==6 ([Set, Collection, Sized, Iterable, Container, object]); Set.__qualname__.__eq__('Set')==True; Set.__name__.__len__()==3 ('Set'=3, shortest class name in spec); MutableSet inherits from Set; MutableSet.__name__.__eq__('MutableSet')==True; MutableSet.__module__.__eq__('collections.abc')==True (same module); MutableSet.__bases__[0].__name__.__eq__('Set')==True; MutableSet.__mro__.__len__()==7 ([MutableSet, Set, Collection, Sized, Iterable, Container, object]); MutableSet.__qualname__.__eq__('MutableSet')==True; MutableSet.__name__.__len__()==10 ('MutableSet'=10, longest class name in spec); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cabcset275

  columns: [id, function, args, expected, description]
  rows:
    - [set_name_eq,    collections.abc.Set.__name__.__eq__,                          ["Set"],              true, "collections.abc.Set.__name__ == 'Set'; verified with Python 3.14.3"]
    - [set_mod_eq,     collections.abc.Set.__module__.__eq__,                        ["collections.abc"],  true, "collections.abc.Set.__module__ == 'collections.abc' (len=15); verified with Python 3.14.3"]
    - [set_base0_eq,   "collections.abc.Set.__bases__[0].__name__.__eq__",           ["Collection"],       true, "collections.abc.Set.__bases__[0].__name__ == 'Collection'; verified with Python 3.14.3"]
    - [set_mro_len,    collections.abc.Set.__mro__.__len__,                          [],                   6,    "collections.abc.Set.__mro__.__len__() == 6 — [Set, Collection, Sized, Iterable, Container, object]; verified with Python 3.14.3"]
    - [set_qn_eq,      collections.abc.Set.__qualname__.__eq__,                      ["Set"],              true, "collections.abc.Set.__qualname__ == 'Set'; verified with Python 3.14.3"]
    - [set_name_len,   collections.abc.Set.__name__.__len__,                         [],                   3,    "collections.abc.Set.__name__.__len__() == 3 ('Set'=3, shortest class name in spec); verified with Python 3.14.3"]
    - [ms_name_eq,     collections.abc.MutableSet.__name__.__eq__,                   ["MutableSet"],       true, "collections.abc.MutableSet.__name__ == 'MutableSet'; verified with Python 3.14.3"]
    - [ms_mod_eq,      collections.abc.MutableSet.__module__.__eq__,                 ["collections.abc"],  true, "collections.abc.MutableSet.__module__ == 'collections.abc' (same as Set); verified with Python 3.14.3"]
    - [ms_base0_eq,    "collections.abc.MutableSet.__bases__[0].__name__.__eq__",    ["Set"],              true, "collections.abc.MutableSet.__bases__[0].__name__ == 'Set'; verified with Python 3.14.3"]
    - [ms_mro_len,     collections.abc.MutableSet.__mro__.__len__,                   [],                   7,    "collections.abc.MutableSet.__mro__.__len__() == 7 — [MutableSet, Set, Collection, Sized, Iterable, Container, object]; verified with Python 3.14.3"]
    - [ms_qn_eq,       collections.abc.MutableSet.__qualname__.__eq__,               ["MutableSet"],       true, "collections.abc.MutableSet.__qualname__ == 'MutableSet' (module-level class); verified with Python 3.14.3"]
    - [ms_name_len,    collections.abc.MutableSet.__name__.__len__,                  [],                   10,   "collections.abc.MutableSet.__name__.__len__() == 10 ('MutableSet'=10, longest class name in spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# collections.abc.Sequence class identity and method qualnames — extra275
#
# Sequence.__name__                   == 'Sequence'
# Sequence.__module__                 == 'collections.abc'
# Sequence.__bases__[0].__name__      == 'Reversible'
# Sequence.__mro__.__len__()          == 7
# Sequence.__qualname__               == 'Sequence'
# Sequence.index.__qualname__         == 'Sequence.index'  (len=14)
# Sequence.count.__qualname__         == 'Sequence.count'  (len=14)
# Sequence.index.__name__             == 'index'
# Sequence.count.__name__             == 'count'
# ---------------------------------------------------------------------------

table abc_extra275.cabc_sequence_identity:
  description: "collections.abc.Sequence class identity and method qualname checks in cabcseq275 namespace — Sequence is defined in Lib/_collections_abc.py; Sequence inherits from Reversible and Collection (two direct bases); Sequence.__name__.__eq__('Sequence')==True; Sequence.__module__.__eq__('collections.abc')==True (len=15, same as Set and MutableSet); Sequence.__bases__[0].__name__.__eq__('Reversible')==True (first base in declaration order); Sequence.__mro__.__len__()==7 ([Sequence, Reversible, Collection, Sized, Iterable, Container, object]); Sequence.__qualname__.__eq__('Sequence')==True; Sequence.__name__.__len__()==8 ('Sequence'=8); Sequence.index.__qualname__.__eq__('Sequence.index')==True (len=14: 'Sequence.'=9+'index'=5); Sequence.count.__qualname__.__eq__('Sequence.count')==True (len=14: 'Sequence.'=9+'count'=5); both method qualnames have the same length (14); Sequence.index.__name__.__eq__('index')==True; Sequence.count.__name__.__eq__('count')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cabcseq275

  columns: [id, function, args, expected, description]
  rows:
    - [seq_name_eq,     collections.abc.Sequence.__name__.__eq__,                    ["Sequence"],         true, "collections.abc.Sequence.__name__ == 'Sequence'; verified with Python 3.14.3"]
    - [seq_mod_eq,      collections.abc.Sequence.__module__.__eq__,                  ["collections.abc"],  true, "collections.abc.Sequence.__module__ == 'collections.abc' (len=15); verified with Python 3.14.3"]
    - [seq_base0_eq,    "collections.abc.Sequence.__bases__[0].__name__.__eq__",     ["Reversible"],       true, "collections.abc.Sequence.__bases__[0].__name__ == 'Reversible' (first direct base); verified with Python 3.14.3"]
    - [seq_mro_len,     collections.abc.Sequence.__mro__.__len__,                    [],                   7,    "collections.abc.Sequence.__mro__.__len__() == 7 — [Sequence, Reversible, Collection, Sized, Iterable, Container, object]; verified with Python 3.14.3"]
    - [seq_qn_eq,       collections.abc.Sequence.__qualname__.__eq__,                ["Sequence"],         true, "collections.abc.Sequence.__qualname__ == 'Sequence' (module-level class); verified with Python 3.14.3"]
    - [seq_name_len,    collections.abc.Sequence.__name__.__len__,                   [],                   8,    "collections.abc.Sequence.__name__.__len__() == 8 ('Sequence'=8); verified with Python 3.14.3"]
    - [idx_qn_eq,       collections.abc.Sequence.index.__qualname__.__eq__,          ["Sequence.index"],   true, "Sequence.index.__qualname__ == 'Sequence.index' (len=14); verified with Python 3.14.3"]
    - [idx_qn_len,      collections.abc.Sequence.index.__qualname__.__len__,         [],                   14,   "Sequence.index.__qualname__.__len__() == 14 ('Sequence.index'=14: 'Sequence.'=9+'index'=5); verified with Python 3.14.3"]
    - [cnt_qn_eq,       collections.abc.Sequence.count.__qualname__.__eq__,          ["Sequence.count"],   true, "Sequence.count.__qualname__ == 'Sequence.count' (len=14, same as index); verified with Python 3.14.3"]
    - [cnt_qn_len,      collections.abc.Sequence.count.__qualname__.__len__,         [],                   14,   "Sequence.count.__qualname__.__len__() == 14 ('Sequence.count'=14: 'Sequence.'=9+'count'=5); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra275
# ---------------------------------------------------------------------------

invariant abc_extra275.Set_module_is_collections_abc:
  description: "collections.abc.Set.__module__.__eq__('collections.abc') returns True — Set is defined in Lib/_collections_abc.py and exposed as collections.abc.Set; its __module__ is 'collections.abc' (len=15: 'collections'=11+'.abc'=4); Set inherits from Collection (single base); Set.__mro__.__len__() is 6 ([Set, Collection, Sized, Iterable, Container, object]); Set.__name__.__len__() is 3 ('Set'=3, the shortest class name in this spec); Set is the abstract base for set-like collections that support membership testing (__contains__), iteration (__iter__), and cardinality (__len__); NEW in extra275: first standalone Set.__module__ invariant in cabcset275 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: collections.abc.Set.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra275.Set_mro_len_is_6:
  description: "collections.abc.Set.__mro__.__len__() == 6 — Set's MRO is [Set, Collection, Sized, Iterable, Container, object] (length=6); Set inherits from Collection (its sole direct base); Collection contributes [Collection, Sized, Iterable, Container, object] (5 elements), giving Set a 6-element chain; compare MRO depths: Set=6, MutableSet=7 (adds one level for MutableSet itself), Sequence=7 (same depth as MutableSet but different chain); Set.__bases__[0].__name__ is 'Collection'; Set.__module__ is 'collections.abc'; NEW in extra275: first standalone Set MRO length invariant in cabcset275 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: collections.abc.Set.__mro__.__len__
  args: []
  expected: 6

invariant abc_extra275.MutableSet_base_is_Set:
  description: "collections.abc.MutableSet.__bases__[0].__name__.__eq__('Set') returns True — MutableSet inherits from Set as its sole direct base; MutableSet's MRO is [MutableSet, Set, Collection, Sized, Iterable, Container, object] (length=7); adding MutableSet as the first element extends Set's 6-element chain by exactly 1; MutableSet provides mutable set operations (add, discard) on top of Set's read-only interface; MutableSet.__module__ is 'collections.abc'; MutableSet.__name__.__len__() is 10 ('MutableSet'=10, longest class name in spec); NEW in extra275: first standalone MutableSet base class invariant in cabcset275 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "collections.abc.MutableSet.__bases__[0].__name__.__eq__"
  args: ["Set"]
  expected: true

invariant abc_extra275.Sequence_base_is_Reversible:
  description: "collections.abc.Sequence.__bases__[0].__name__.__eq__('Reversible') returns True — Sequence's first direct base is Reversible; Sequence inherits from both Reversible and Collection (two direct bases); Sequence.__mro__.__len__() is 7 ([Sequence, Reversible, Collection, Sized, Iterable, Container, object]); Reversible is placed first in Sequence's declaration, hence __bases__[0].__name__ == 'Reversible'; Sequence.__module__ is 'collections.abc'; Sequence.__name__.__len__() is 8 ('Sequence'=8); NEW in extra275: first standalone Sequence base class invariant in cabcseq275 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "collections.abc.Sequence.__bases__[0].__name__.__eq__"
  args: ["Reversible"]
  expected: true

invariant abc_extra275.Sequence_index_qualname_len_is_14:
  description: "collections.abc.Sequence.index.__qualname__.__len__() == 14 — Sequence.index.__qualname__ is 'Sequence.index' (len=14: 'Sequence.'=9+'index'=5); Sequence.count.__qualname__ is 'Sequence.count' (also len=14: 'Sequence.'=9+'count'=5); both method qualnames are equal in length; Sequence.index.__qualname__.__eq__('Sequence.index') returns True; Sequence.index and Sequence.count are both mixin methods defined in Lib/_collections_abc.py; Sequence.index returns the first index of a value; Sequence.count returns the number of occurrences of a value; NEW in extra275: first standalone Sequence.index qualname length invariant in cabcseq275 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: collections.abc.Sequence.index.__qualname__.__len__
  args: []
  expected: 14

invariant abc_extra275.Sequence_count_qualname_eq:
  description: "collections.abc.Sequence.count.__qualname__.__eq__('Sequence.count') returns True — Sequence.count.__qualname__ is 'Sequence.count' (len=14: 'Sequence.'=9+'count'=5); Sequence.count.__qualname__.__len__() is 14 (same as Sequence.index.__qualname__.__len__()==14); both index and count are mixin methods provided by Sequence for concrete subclasses; Sequence.count.__name__ is 'count' (len=5); Sequence.count.__module__ is 'collections.abc'; Sequence.__mro__.__len__() is 7; NEW in extra275: first standalone Sequence.count qualname invariant in cabcseq275 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: collections.abc.Sequence.count.__qualname__.__eq__
  args: ["Sequence.count"]
  expected: true
