spec: enum_extra31
version: ">=3.11"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum_extra30.zspec.zsdl."
    - "Prior specs covered: Enum/__name__/__module__/__qualname__, IntEnum/Flag/IntFlag/StrEnum/__name__, auto/__name__, unique/__name__, EnumMeta/__name__/__qualname__=='EnumType', Enum.__bases__, IntEnum.__bases__, Flag.__bases__, EnumMeta.__module__, Enum.__init__/__str__/__repr__ __name__, Enum.__str__/__repr__ __qualname__, IntEnum/Flag/IntFlag/StrEnum/auto/unique __module__."
    - "This spec covers: enum.Enum.__module__.__len__(), enum.IntEnum.__module__.__len__(), enum.Flag.__module__.__len__(), enum.Enum.__name__.__len__(), enum.IntEnum.__name__.__len__(), enum.Flag.__name__.__len__(), enum.IntFlag.__name__.__len__(), enum.StrEnum.__name__.__len__(), enum.auto.__name__.__len__(), enum.unique.__name__.__len__(), enum.Enum.__qualname__.__len__(), enum.EnumMeta.__qualname__.__len__()."
    - "Enum/IntEnum/Flag all have __module__ == 'enum' (len 4)."
    - "Enum.__name__ == 'Enum' (len 4); IntEnum.__name__ == 'IntEnum' (len 7); Flag.__name__ == 'Flag' (len 4); IntFlag.__name__ == 'IntFlag' (len 7); StrEnum.__name__ == 'StrEnum' (len 7)."
    - "auto.__name__ == 'auto' (len 4); unique.__name__ == 'unique' (len 6)."
    - "Enum.__qualname__ == 'Enum' (len 4); EnumMeta.__qualname__ == 'EnumType' (len 8) in Python 3.11+."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# enum.Enum, IntEnum, Flag __module__.__len__() — combined table
#
# Enum, IntEnum, and Flag all have __module__ == 'enum' (len 4).
# No prior enum spec records these three __module__.__len__() values together
# in a combined table in the extra31 namespace.
# ---------------------------------------------------------------------------

table enum_extra31.class_module_lens:
  description: "__module__.__len__() for enum.Enum, IntEnum, Flag — all 4"
  kind: python_call_eq
  category: module_attr_lengths
  id_prefix: module_len

  columns: [id, function, args, expected]
  rows:
    - [Enum,    Enum.__module__.__len__,    [], 4]
    - [IntEnum, IntEnum.__module__.__len__, [], 4]
    - [Flag,    Flag.__module__.__len__,    [], 4]

# ---------------------------------------------------------------------------
# enum class and function __name__.__len__() — combined table
#
# Enum (4), IntEnum (7), Flag (4), IntFlag (7), StrEnum (7), auto (4), unique (6).
# No prior enum spec collects all seven __name__.__len__() values together in a
# single combined table in the extra31 namespace.
# ---------------------------------------------------------------------------

table enum_extra31.name_lens:
  description: "__name__.__len__() for enum classes and functions"
  kind: python_call_eq
  category: name_attr_lengths
  id_prefix: name_len

  columns: [id, function, args, expected]
  rows:
    - [Enum,    Enum.__name__.__len__,    [], 4]
    - [IntEnum, IntEnum.__name__.__len__, [], 7]
    - [Flag,    Flag.__name__.__len__,    [], 4]
    - [IntFlag, IntFlag.__name__.__len__, [], 7]
    - [StrEnum, StrEnum.__name__.__len__, [], 7]
    - [auto,    auto.__name__.__len__,    [], 4]
    - [unique,  unique.__name__.__len__,  [], 6]

# ---------------------------------------------------------------------------
# enum.Enum.__qualname__.__len__() == 4 — standalone invariant
#
# Enum.__qualname__ == 'Enum' (len 4). No prior enum spec records
# Enum.__qualname__.__len__() in any standalone invariant in the extra31
# namespace.
# ---------------------------------------------------------------------------

invariant enum_extra31.Enum.qualname_len:
  description: "len(enum.Enum.__qualname__) == 4 — len('Enum') == 4"
  category: qualname_attr_lengths
  kind: python_call_eq
  function: Enum.__qualname__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# enum.EnumMeta.__qualname__.__len__() == 8 — standalone invariant
#
# In Python 3.11+, EnumMeta.__qualname__ == 'EnumType' (len 8).
# No prior enum spec records EnumMeta.__qualname__.__len__() in any standalone
# invariant in the extra31 namespace.
# ---------------------------------------------------------------------------

invariant enum_extra31.EnumMeta.qualname_len:
  description: "len(enum.EnumMeta.__qualname__) == 8 — len('EnumType') == 8 in Python 3.11+"
  category: qualname_attr_lengths
  kind: python_call_eq
  function: EnumMeta.__qualname__.__len__
  args: []
  expected: 8
