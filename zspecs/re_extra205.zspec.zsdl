spec: re_extra205
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra204.zspec.zsdl — covers re.__name__, re.__package__, re.__spec__.name, re.__loader__.__class__.__name__, re.__doc__.__class__.__name__"
  notes:
    - "This spec covers re.__spec__ deeper attributes: name, has_location, parent, __class__.__name__, and submodule_search_locations.__class__.__name__."
    - "re.__spec__.name == 're'; the ModuleSpec name matches the module name; confirmed Python 3.14.3 macOS."
    - "re.__spec__.has_location == True; re is a pure-Python package with __init__.py, loaded from disk; confirmed Python 3.14.3 macOS."
    - "re.__spec__.parent == 're'; re is a package, so __spec__.parent equals the package name; confirmed Python 3.14.3 macOS."
    - "re.__spec__.__class__.__name__ == 'ModuleSpec'; all module specs are ModuleSpec instances; confirmed Python 3.14.3 macOS."
    - "re.__spec__.submodule_search_locations.__class__.__name__ == 'list'; packages have a submodule_search_locations list; confirmed Python 3.14.3 macOS."
    - "re is a package (directory with __init__.py), so has_location is True and submodule_search_locations is a list with one entry."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re.__spec__.name identity
# name == 're', length == 2
# ---------------------------------------------------------------------------

table re_extra205.spec_name:
  description: "re.__spec__.name attribute identity: value, equality, and length"
  kind: python_call_eq
  category: spec_identity
  id_prefix: respec205

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,        re.__spec__.name.__eq__,   ["re"], true,  "re.__spec__.name == 're'; the ModuleSpec name matches the module name; confirmed Python 3.14.3 macOS"]
    - [name_len,       re.__spec__.name.__len__,  [],     2,     "re.__spec__.name.__len__() == 2; 're' has r(1)e(2); confirmed Python 3.14.3 macOS"]
    - [name_not_sre,   re.__spec__.name.__eq__,   ["sre"], false, "re.__spec__.name != 'sre'; the public module name differs from the C accelerator sre; confirmed Python 3.14.3 macOS"]
    - [name_not_empty, re.__spec__.name.__eq__,   [""],   false, "re.__spec__.name is not empty string; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re.__spec__.has_location and re.__spec__.parent
# has_location == True (file-based package), parent == 're' (is a package)
# ---------------------------------------------------------------------------

table re_extra205.spec_has_location_and_parent:
  description: "re.__spec__.has_location and re.__spec__.parent attribute identity"
  kind: python_call_eq
  category: spec_identity
  id_prefix: respec205

  columns: [id, function, args, expected, description]
  rows:
    - [has_location_true,      re.__spec__.has_location.__eq__,   [true],  true,  "re.__spec__.has_location == True; re is a pure-Python package loaded from disk; confirmed Python 3.14.3 macOS"]
    - [has_location_not_false, re.__spec__.has_location.__eq__,   [false], false, "re.__spec__.has_location != False; re has a file location; confirmed Python 3.14.3 macOS"]
    - [parent_eq,              re.__spec__.parent.__eq__,         ["re"],  true,  "re.__spec__.parent == 're'; re is a package, __spec__.parent equals the package name; confirmed Python 3.14.3 macOS"]
    - [parent_len,             re.__spec__.parent.__len__,        [],      2,     "re.__spec__.parent.__len__() == 2; 're' has r(1)e(2); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re.__spec__.__class__.__name__ and submodule_search_locations class name
# __class__.__name__ == 'ModuleSpec', submodule_search_locations.__class__.__name__ == 'list'
# ---------------------------------------------------------------------------

table re_extra205.spec_class_and_submodule:
  description: "re.__spec__.__class__.__name__ and submodule_search_locations.__class__.__name__ identity"
  kind: python_call_eq
  category: spec_identity
  id_prefix: respec205

  columns: [id, function, args, expected, description]
  rows:
    - [class_name_eq,     re.__spec__.__class__.__name__.__eq__,                                  ["ModuleSpec"], true,  "re.__spec__.__class__.__name__ == 'ModuleSpec'; all module specs are ModuleSpec instances; confirmed Python 3.14.3 macOS"]
    - [class_name_len,    re.__spec__.__class__.__name__.__len__,                                 [],             10,    "re.__spec__.__class__.__name__.__len__() == 10; 'ModuleSpec' has 10 characters; confirmed Python 3.14.3 macOS"]
    - [ssl_class_name_eq, "re.__spec__.submodule_search_locations.__class__.__name__.__eq__",     ["list"],       true,  "re.__spec__.submodule_search_locations.__class__.__name__ == 'list'; packages have a list for submodule_search_locations; confirmed Python 3.14.3 macOS"]
    - [ssl_class_name_len, "re.__spec__.submodule_search_locations.__class__.__name__.__len__",   [],             4,     "re.__spec__.submodule_search_locations.__class__.__name__.__len__() == 4; 'list' has l(1)i(2)s(3)t(4); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra205.spec_name_eq:
  description: "re.__spec__.name == 're' — the ModuleSpec name matches the module name; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: re.__spec__.name.__eq__
  args: ["re"]
  expected: true

invariant re_extra205.spec_name_len:
  description: "re.__spec__.name.__len__() == 2 — 're' has r(1)e(2); confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: re.__spec__.name.__len__
  args: []
  expected: 2

invariant re_extra205.spec_has_location_true:
  description: "re.__spec__.has_location == True — re is a pure-Python package loaded from disk; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: re.__spec__.has_location.__eq__
  args: [true]
  expected: true

invariant re_extra205.spec_parent_eq:
  description: "re.__spec__.parent == 're' — re is a package, __spec__.parent equals the package name; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: re.__spec__.parent.__eq__
  args: ["re"]
  expected: true

invariant re_extra205.spec_parent_len:
  description: "re.__spec__.parent.__len__() == 2 — 're' has two characters; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: re.__spec__.parent.__len__
  args: []
  expected: 2

invariant re_extra205.spec_class_name_eq:
  description: "re.__spec__.__class__.__name__ == 'ModuleSpec' — all module specs are ModuleSpec instances; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: re.__spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant re_extra205.spec_class_name_len:
  description: "re.__spec__.__class__.__name__.__len__() == 10 — 'ModuleSpec' has 10 characters; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: re.__spec__.__class__.__name__.__len__
  args: []
  expected: 10

invariant re_extra205.spec_ssl_class_name_eq:
  description: "re.__spec__.submodule_search_locations.__class__.__name__ == 'list' — packages have a list for submodule_search_locations; confirmed Python 3.14.3 macOS"
  category: spec_identity
  kind: python_call_eq
  function: "re.__spec__.submodule_search_locations.__class__.__name__.__eq__"
  args: ["list"]
  expected: true

