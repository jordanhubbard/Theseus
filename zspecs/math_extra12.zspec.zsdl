spec: math_extra12
version: ">=3.9"
backend: python_module(math)

docs: https://docs.python.org/3/library/math.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/math.html — Python math documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/mathmodule.c"
  notes:
    - "This spec extends math.zspec.zsdl and prior extras through math_extra11.zspec.zsdl."
    - "math.zspec covers: tau gt/lt bounds; math_extra4 covers tau.__eq__ exact value."
    - "No prior spec covers math.degrees(2*pi)==360.0 (two full rotations)."
    - "No prior spec covers math.gcd(0,0)==0 (gcd of two zeros)."
    - "No prior spec covers math.lcm(12,18)==36 (larger lcm vector)."
    - "No prior spec covers math.perm(7,0)==1 (no items chosen) or perm(4,4)==24 (all chosen)."
    - "No prior spec covers math.isqrt(0)==0 or math.isqrt(100)==10."
    - "No prior spec covers math.prod([2,3,4])==24 (three-element product)."
    - "No prior spec covers math.fabs(0.0)==0.0 (absolute value of zero)."
    - "No prior spec covers math.copysign(-5.0, 0.0)==5.0 (positive zero gives positive sign)."
    - "math.degrees(2 * math.pi) == 360.0 — two radians to degrees conversion."
    - "math.gcd(0, 0) == 0 — gcd of two zeros is 0 by convention."
    - "math.lcm(12, 18) == 36 — lcm of 12 and 18 is 36."
    - "math.perm(7, 0) == 1 — there is exactly one way to arrange zero items."
    - "math.perm(4, 4) == 24 — P(4,4) = 4! = 24 (arrange all four items)."
    - "math.isqrt(0) == 0 — integer square root of zero is zero."
    - "math.isqrt(100) == 10 — integer square root of 100 is 10 (perfect square)."
    - "math.prod([2, 3, 4]) == 24 — product of three elements."
    - "math.fabs(0.0) == 0.0 — absolute value of zero is zero."
    - "math.copysign(-5.0, 0.0) == 5.0 — positive zero gives positive sign."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# degrees — two full rotations
#
# math.zspec covers degrees(pi)==180.0 and degrees(0.0)==0.0.
# math_extra9 covers radians(180)==pi and radians(0)==0.0.
# No prior spec covers degrees(2*pi)==360.0 (two full rotations).
# The value 6.283185307179586 is 2*math.pi, verified in Python 3.12.
# ---------------------------------------------------------------------------

invariant math_extra12.degrees.two_pi:
  description: "math.degrees(6.283185307179586) == 360.0 — 2*pi radians is 360 degrees"
  category: angle_conversion
  kind: python_call_eq
  function: degrees
  args: [6.283185307179586]
  expected: 360.0

# ---------------------------------------------------------------------------
# gcd — edge case: gcd(0, 0) == 0
#
# math.zspec covers gcd(12,8), gcd(0,5), gcd(7,7), gcd(13,7).
# No prior spec covers gcd(0, 0) == 0.
# By convention, gcd(0, 0) == 0 (Python 3 math.gcd follows this).
# ---------------------------------------------------------------------------

invariant math_extra12.gcd.zero_zero:
  description: "math.gcd(0, 0) == 0 — gcd of two zeros is 0 by convention"
  category: gcd
  kind: python_call_eq
  function: gcd
  args: [0, 0]
  expected: 0

# ---------------------------------------------------------------------------
# lcm — larger value vector
#
# math.zspec and math_extra4 cover lcm(4,6)==12.
# No prior spec covers lcm(12,18)==36.
# lcm(12,18): 12=2^2*3, 18=2*3^2, so lcm=2^2*3^2=36.
# ---------------------------------------------------------------------------

invariant math_extra12.lcm.twelve_eighteen:
  description: "math.lcm(12, 18) == 36 — lcm of 12 and 18 is 36"
  category: lcm
  kind: python_call_eq
  function: lcm
  args: [12, 18]
  expected: 36

# ---------------------------------------------------------------------------
# perm — zero items chosen, and all items chosen
#
# math.zspec covers perm(5,2)==20; math_extra4 covers perm(5,0) and perm(4,2).
# No prior spec covers perm(7,0)==1 (zero picks from any n) or perm(4,4)==24.
# perm(n, 0) == 1 for any n because there is exactly one way to arrange nothing.
# perm(4, 4) == 4! == 24 because we arrange all four elements.
# ---------------------------------------------------------------------------

invariant math_extra12.perm.seven_pick_zero:
  description: "math.perm(7, 0) == 1 — exactly one way to arrange zero items"
  category: combinatorics
  kind: python_call_eq
  function: perm
  args: [7, 0]
  expected: 1

invariant math_extra12.perm.four_pick_all:
  description: "math.perm(4, 4) == 24 — P(4,4) = 4! = 24, arrange all four items"
  category: combinatorics
  kind: python_call_eq
  function: perm
  args: [4, 4]
  expected: 24

# ---------------------------------------------------------------------------
# isqrt — zero and large perfect square
#
# math.zspec covers isqrt(16)==4 and isqrt(15)==3; math_extra4/5 cover isqrt(9/10/16/17).
# No prior spec covers isqrt(0)==0 or isqrt(100)==10.
# ---------------------------------------------------------------------------

invariant math_extra12.isqrt.zero:
  description: "math.isqrt(0) == 0 — integer square root of zero is zero"
  category: isqrt
  kind: python_call_eq
  function: isqrt
  args: [0]
  expected: 0

invariant math_extra12.isqrt.hundred:
  description: "math.isqrt(100) == 10 — integer square root of 100 is 10"
  category: isqrt
  kind: python_call_eq
  function: isqrt
  args: [100]
  expected: 10

# ---------------------------------------------------------------------------
# prod — three-element product
#
# math_extra4 covers prod([1,2,3,4])==24 and prod([])==1.
# math_extra5 covers prod([1,2,3,4,5])==120.
# No prior spec covers prod([2,3,4])==24 (three elements).
# ---------------------------------------------------------------------------

invariant math_extra12.prod.three_elements:
  description: "math.prod([2, 3, 4]) == 24 — product of three distinct elements"
  category: prod
  kind: python_call_eq
  function: prod
  args: [[2, 3, 4]]
  expected: 24

# ---------------------------------------------------------------------------
# fabs — absolute value of zero
#
# math.zspec covers fabs(-5.0)==5.0 and fabs(3.0)==3.0.
# No prior spec covers fabs(0.0)==0.0.
# ---------------------------------------------------------------------------

invariant math_extra12.fabs.zero:
  description: "math.fabs(0.0) == 0.0 — absolute value of zero is zero"
  category: fabs
  kind: python_call_eq
  function: fabs
  args: [0.0]
  expected: 0.0

# ---------------------------------------------------------------------------
# copysign — zero sign bit
#
# math.zspec covers copysign(1.0,-5.0)==-1.0 and copysign(-3.0,1.0)==3.0.
# No prior spec covers copysign(-5.0, 0.0)==5.0 (positive zero gives positive sign).
# Positive zero has a positive sign bit, so copysign(-5.0, 0.0) == 5.0.
# ---------------------------------------------------------------------------

invariant math_extra12.copysign.positive_zero_sign:
  description: "math.copysign(-5.0, 0.0) == 5.0 — positive zero gives positive sign"
  category: copysign
  kind: python_call_eq
  function: copysign
  args: [-5.0, 0.0]
  expected: 5.0
