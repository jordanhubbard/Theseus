spec: cli_cursor
version: ">=5.0.0"
backend: node(cli-cursor)
esm: true

docs: https://github.com/sindresorhus/cli-cursor#readme

provenance:
  derived_from:
    - "cli-cursor README — https://github.com/sindresorhus/cli-cursor#readme"
    - "Test vectors verified with cli-cursor via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "cli-cursor source"
  notes:
    - "Show / hide / toggle the terminal cursor — used by ora, listr, cli-spinners."
    - "Install: npm install cli-cursor"
    - "v5 ESM only; named exports show / hide / toggle (write ANSI escape sequences to stderr)."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Functions never throw on TTY/non-TTY streams."
  stderr: "Writes ANSI cursor-control sequences to stderr."
  stickiness: "Internal hidden-state flag mirrors the real cursor state."
  codes: {}

invariant cli_cursor.has_show:
  description: "show() exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.show.constructor.name"}
  expected: "Function"

invariant cli_cursor.has_hide:
  description: "hide() exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.hide.constructor.name"}
  expected: "Function"

invariant cli_cursor.has_toggle:
  description: "toggle() exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.toggle.constructor.name"}
  expected: "Function"

invariant cli_cursor.show_arity:
  description: "show takes 0 declared args (uses default stream)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.show.length"}
  expected: 0

invariant cli_cursor.hide_arity:
  description: "hide takes 0 declared args"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.hide.length"}
  expected: 0

invariant cli_cursor.toggle_arity:
  description: "toggle takes 2 args (force, writableStream)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.toggle.length"}
  expected: 2

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T06:16:25Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
