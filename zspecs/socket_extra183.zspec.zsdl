spec: socket_extra183
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra182.zspec.zsdl — prior extras."
  notes:
    - "socket.socket.__name__ == 'socket' — len=6; the Python-level socket class is named 'socket'."
    - "socket.socket.__module__ == 'socket' — the Python-level class is defined in the socket module."
    - "socket.socket.__qualname__ == 'socket' — top-level class; qualname equals name."
    - "socket.socket.__bases__[0].__name__ == 'socket' — base class is _socket.socket (C extension); NOT 'object'."
    - "socket.socket.__bases__[0].__module__ == '_socket' — the C-level base is in the _socket extension module."
    - "socket.socket.connect.__name__ == 'connect' — len=7."
    - "socket.socket.bind.__name__ == 'bind' — len=4."
    - "socket.socket.listen.__name__ == 'listen' — len=6."
    - "socket.socket.accept.__name__ == 'accept' — len=6."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: socket.socket class name, module, and qualname identity
#
# socket.socket.__name__     == 'socket'   (len=6)
# socket.socket.__module__   == 'socket'
# socket.socket.__qualname__ == 'socket'
#
# The Python-level socket class wraps the C-level _socket.socket.
# ---------------------------------------------------------------------------

table socket_extra183.socket_class_identity:
  description: "socket.socket __name__, __module__, and __qualname__ identity; new to extra183"
  kind: python_call_eq
  category: identity
  id_prefix: socketsocket183

  columns: [id, function, args, expected, description]
  rows:
    - [socket_name_eq,
       socket.__name__.__eq__,
       ["socket"],
       true,
       "socket.socket.__name__.__eq__('socket') == True — Python socket class is named 'socket'; len=6; new to extra183"]
    - [socket_name_len,
       socket.__name__.__len__,
       [],
       6,
       "socket.socket.__name__.__len__() == 6 — 'socket' has 6 characters; new to extra183"]
    - [socket_module_eq,
       socket.__module__.__eq__,
       ["socket"],
       true,
       "socket.socket.__module__.__eq__('socket') == True — socket class is defined in the socket module; new to extra183"]
    - [socket_qualname_eq,
       socket.__qualname__.__eq__,
       ["socket"],
       true,
       "socket.socket.__qualname__.__eq__('socket') == True — top-level class; qualname equals name; new to extra183"]

# ---------------------------------------------------------------------------
# Table 2: socket.socket base class identity
#
# socket.socket.__bases__[0].__name__   == 'socket'  (C-level _socket.socket)
# socket.socket.__bases__[0].__module__ == '_socket'
#
# The Python socket class inherits from _socket.socket, not from object directly.
# socket.socket.__bases__[0].__name__ is 'socket', NOT 'object'.
# ---------------------------------------------------------------------------

table socket_extra183.socket_base_class_identity:
  description: "socket.socket base class is _socket.socket (C extension), not object; new to extra183"
  kind: python_call_eq
  category: identity
  id_prefix: socketsocket183

  columns: [id, function, args, expected, description]
  rows:
    - [base_name_eq,
       "socket.__bases__[0].__name__.__eq__",
       ["socket"],
       true,
       "socket.socket.__bases__[0].__name__.__eq__('socket') == True — base is _socket.socket, a C extension class; new to extra183"]
    - [base_module_eq,
       "socket.__bases__[0].__module__.__eq__",
       ["_socket"],
       true,
       "socket.socket.__bases__[0].__module__.__eq__('_socket') == True — base class lives in the _socket C extension module; new to extra183"]

# ---------------------------------------------------------------------------
# Table 3: socket.socket method __name__ values and lengths
#
# socket.socket.connect.__name__ == 'connect' (len=7)
# socket.socket.bind.__name__    == 'bind'    (len=4)
# socket.socket.listen.__name__  == 'listen'  (len=6)
# socket.socket.accept.__name__  == 'accept'  (len=6)
# ---------------------------------------------------------------------------

table socket_extra183.socket_method_names:
  description: "socket.socket method __name__ values for connect, bind, listen, accept; new to extra183"
  kind: python_call_eq
  category: identity
  id_prefix: socketsocket183

  columns: [id, function, args, expected, description]
  rows:
    - [connect_name_eq,
       socket.connect.__name__.__eq__,
       ["connect"],
       true,
       "socket.socket.connect.__name__.__eq__('connect') == True — connect method is named 'connect'; len=7; new to extra183"]
    - [connect_name_len,
       socket.connect.__name__.__len__,
       [],
       7,
       "socket.socket.connect.__name__.__len__() == 7 — 'connect' has 7 characters; new to extra183"]
    - [bind_name_eq,
       socket.bind.__name__.__eq__,
       ["bind"],
       true,
       "socket.socket.bind.__name__.__eq__('bind') == True — bind method is named 'bind'; len=4; new to extra183"]
    - [bind_name_len,
       socket.bind.__name__.__len__,
       [],
       4,
       "socket.socket.bind.__name__.__len__() == 4 — 'bind' has 4 characters; new to extra183"]
    - [listen_name_eq,
       socket.listen.__name__.__eq__,
       ["listen"],
       true,
       "socket.socket.listen.__name__.__eq__('listen') == True — listen method is named 'listen'; len=6; new to extra183"]
    - [listen_name_len,
       socket.listen.__name__.__len__,
       [],
       6,
       "socket.socket.listen.__name__.__len__() == 6 — 'listen' has 6 characters; new to extra183"]
    - [accept_name_eq,
       socket.accept.__name__.__eq__,
       ["accept"],
       true,
       "socket.socket.accept.__name__.__eq__('accept') == True — accept method is named 'accept'; len=6; new to extra183"]
    - [accept_name_len,
       socket.accept.__name__.__len__,
       [],
       6,
       "socket.socket.accept.__name__.__len__() == 6 — 'accept' has 6 characters; new to extra183"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra183
# ---------------------------------------------------------------------------

invariant socket_extra183.socket_name_is_socket:
  description: "socket.socket.__name__ == 'socket' — the Python socket class is named 'socket'; len=6; new to extra183"
  category: identity
  kind: python_call_eq
  function: socket.__name__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra183.socket_module_is_socket:
  description: "socket.socket.__module__ == 'socket' — socket class is defined in the socket module; new to extra183"
  category: identity
  kind: python_call_eq
  function: socket.__module__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra183.socket_qualname_is_socket:
  description: "socket.socket.__qualname__ == 'socket' — top-level class; qualname equals name; new to extra183"
  category: identity
  kind: python_call_eq
  function: socket.__qualname__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra183.socket_base_name_is_socket:
  description: "socket.socket.__bases__[0].__name__ == 'socket' — base is _socket.socket C extension class, not object; new to extra183"
  category: identity
  kind: python_call_eq
  function: "socket.__bases__[0].__name__.__eq__"
  args: ["socket"]
  expected: true

invariant socket_extra183.connect_name_is_connect:
  description: "socket.socket.connect.__name__ == 'connect' — connect method name; len=7; new to extra183"
  category: identity
  kind: python_call_eq
  function: socket.connect.__name__.__eq__
  args: ["connect"]
  expected: true

invariant socket_extra183.bind_name_is_bind:
  description: "socket.socket.bind.__name__ == 'bind' — bind method name; len=4; new to extra183"
  category: identity
  kind: python_call_eq
  function: socket.bind.__name__.__eq__
  args: ["bind"]
  expected: true

invariant socket_extra183.listen_name_is_listen:
  description: "socket.socket.listen.__name__ == 'listen' — listen method name; len=6; new to extra183"
  category: identity
  kind: python_call_eq
  function: socket.listen.__name__.__eq__
  args: ["listen"]
  expected: true

invariant socket_extra183.accept_name_is_accept:
  description: "socket.socket.accept.__name__ == 'accept' — accept method name; len=6; new to extra183"
  category: identity
  kind: python_call_eq
  function: socket.accept.__name__.__eq__
  args: ["accept"]
  expected: true
