spec: uuid_extra182
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 9562 — Universally Unique IDentifiers (UUID)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 9562 — Universally Unique IDentifiers (UUID) — https://www.rfc-editor.org/rfc/rfc9562"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "CPython source: internal PRNG or MAC address resolution"
  notes:
    - "This spec covers uuid.UUID method __qualname__ attributes not previously covered in uuid_extra.zspec.zsdl."
    - "uuid_extra.zspec.zsdl covers: UUID.__name__=='UUID', UUID.__module__=='uuid'; uuid1/3/4/5.__name__ function names; uuid4() return class and version; NAMESPACE_* class membership; UUID instance .int and .hex types."
    - "uuid.UUID.__str__.__qualname__ == 'UUID.__str__' (len=12); all method qualnames start with 'UUID.' prefix (5 chars)."
    - "uuid.UUID.__eq__.__qualname__ == 'UUID.__eq__' (len=11) — shortest qualname in this spec."
    - "uuid.UUID.__lt__.__qualname__ == 'UUID.__lt__' (len=11) — tied with __eq__ as shortest."
    - "uuid.UUID.__repr__.__qualname__ == 'UUID.__repr__' (len=13) — tied longest with __hash__ and __init__."
    - "uuid.UUID.__hash__.__qualname__ == 'UUID.__hash__' (len=13) — tied longest with __repr__ and __init__."
    - "uuid.UUID.__init__.__qualname__ == 'UUID.__init__' (len=13) — tied longest with __repr__ and __hash__."
    - "All 7 methods have __module__ == 'uuid' (Python-defined in Lib/uuid.py)."
    - "Qualname length ordering: __eq__=__lt__=11 < __int__=__str__=12 < __hash__=__repr__=__init__=13."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID method __qualname__ equality checks
#
# All 7 methods: __str__, __repr__, __hash__, __int__, __eq__, __lt__, __init__
# All qualnames follow the pattern 'UUID.<method_name>'
# ---------------------------------------------------------------------------

table uuid_extra182.UUID_method_qualnames:
  description: "uuid.UUID method __qualname__ equality checks in uuidqualnames182 namespace — all seven UUID dunder methods carry __qualname__ attributes of the form 'UUID.<methodname>'; UUID.__str__.__qualname__.__eq__('UUID.__str__')==True (len=12: 'UUID.'=5+'__str__'=7=12); UUID.__repr__.__qualname__.__eq__('UUID.__repr__')==True (len=13: 'UUID.'=5+'__repr__'=8=13, tied longest with __hash__ and __init__); UUID.__hash__.__qualname__.__eq__('UUID.__hash__')==True (len=13: tied longest); UUID.__int__.__qualname__.__eq__('UUID.__int__')==True (len=12: 'UUID.'=5+'__int__'=7=12, tied with __str__); UUID.__eq__.__qualname__.__eq__('UUID.__eq__')==True (len=11: 'UUID.'=5+'__eq__'=6=11, shortest); UUID.__lt__.__qualname__.__eq__('UUID.__lt__')==True (len=11: tied shortest with __eq__); UUID.__init__.__qualname__.__eq__('UUID.__init__')==True (len=13: 'UUID.'=5+'__init__'=8=13, tied longest); length ordering: __eq__=__lt__=11 < __int__=__str__=12 < __hash__=__repr__=__init__=13; all verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: uuidqualnames182

  columns: [id, function, args, expected, description]
  rows:
    - [str_qn_eq,    UUID.__str__.__qualname__.__eq__,    ["UUID.__str__"],    true, "uuid.UUID.__str__.__qualname__ == 'UUID.__str__' (len=12); verified with Python 3.14.3"]
    - [repr_qn_eq,   UUID.__repr__.__qualname__.__eq__,   ["UUID.__repr__"],   true, "uuid.UUID.__repr__.__qualname__ == 'UUID.__repr__' (len=13, tied longest); verified with Python 3.14.3"]
    - [hash_qn_eq,   UUID.__hash__.__qualname__.__eq__,   ["UUID.__hash__"],   true, "uuid.UUID.__hash__.__qualname__ == 'UUID.__hash__' (len=13, tied longest); verified with Python 3.14.3"]
    - [int_qn_eq,    UUID.__int__.__qualname__.__eq__,    ["UUID.__int__"],    true, "uuid.UUID.__int__.__qualname__ == 'UUID.__int__' (len=12, tied with __str__); verified with Python 3.14.3"]
    - [eq_qn_eq,     UUID.__eq__.__qualname__.__eq__,     ["UUID.__eq__"],     true, "uuid.UUID.__eq__.__qualname__ == 'UUID.__eq__' (len=11, shortest in spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# uuid.UUID method __qualname__ length checks
#
# Length ordering: __eq__=__lt__=11 < __int__=__str__=12 < __hash__=__repr__=__init__=13
# ---------------------------------------------------------------------------

table uuid_extra182.UUID_method_qualname_lengths:
  description: "uuid.UUID method __qualname__ length checks in uuidqualnames182 namespace — qualname lengths reflect method name lengths plus the fixed 'UUID.' prefix (5 chars); __eq__.__qualname__.__len__()==11 (shortest: 'UUID.__eq__'=5+6=11, '__eq__'=6); __lt__.__qualname__.__len__()==11 (shortest tied: 'UUID.__lt__'=5+6=11, '__lt__'=6, same suffix length as '__eq__'); __int__.__qualname__.__len__()==12 ('UUID.__int__'=5+7=12, '__int__'=7); __str__.__qualname__.__len__()==12 (tied with __int__: 'UUID.__str__'=5+7=12, '__str__'=7); __hash__.__qualname__.__len__()==13 (longest: 'UUID.__hash__'=5+8=13, '__hash__'=8); __repr__.__qualname__.__len__()==13 (longest tied: 'UUID.__repr__'=5+8=13, '__repr__'=8); __init__.__qualname__.__len__()==13 (longest tied: 'UUID.__init__'=5+8=13, '__init__'=8); the three length-13 qualnames form the longest group; all verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: uuidqualnames182a

  columns: [id, function, args, expected, description]
  rows:
    - [lt_qn_eq,     UUID.__lt__.__qualname__.__eq__,     ["UUID.__lt__"],     true, "uuid.UUID.__lt__.__qualname__ == 'UUID.__lt__' (len=11, tied shortest with __eq__); verified with Python 3.14.3"]
    - [init_qn_eq,   UUID.__init__.__qualname__.__eq__,   ["UUID.__init__"],   true, "uuid.UUID.__init__.__qualname__ == 'UUID.__init__' (len=13, tied longest with __repr__ and __hash__); verified with Python 3.14.3"]
    - [eq_qn_len,    UUID.__eq__.__qualname__.__len__,     [],                  11,   "uuid.UUID.__eq__.__qualname__.__len__() == 11 (shortest: 'UUID.__eq__'=5+6=11); verified with Python 3.14.3"]
    - [lt_qn_len,    UUID.__lt__.__qualname__.__len__,     [],                  11,   "uuid.UUID.__lt__.__qualname__.__len__() == 11 (tied shortest: 'UUID.__lt__'=5+6=11); verified with Python 3.14.3"]
    - [str_qn_len,   UUID.__str__.__qualname__.__len__,    [],                  12,   "uuid.UUID.__str__.__qualname__.__len__() == 12 ('UUID.__str__'=5+7=12); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# uuid.UUID method __module__ checks
#
# All 7 methods have __module__ == 'uuid' (Python-defined in Lib/uuid.py)
# ---------------------------------------------------------------------------

table uuid_extra182.UUID_method_modules:
  description: "uuid.UUID method __module__ checks in uuidqualnames182 namespace — all seven UUID dunder methods are Python-defined in Lib/uuid.py, so each method's __module__ is 'uuid'; UUID.__str__.__module__.__eq__('uuid')==True; UUID.__hash__.__module__.__eq__('uuid')==True; UUID.__eq__.__module__.__eq__('uuid')==True; UUID.__init__.__module__.__eq__('uuid')==True; UUID.__repr__.__module__.__eq__('uuid')==True; 'uuid'=4 chars; this is consistent for all methods since uuid is a pure-Python module (no C accelerator for the UUID class itself); compare: hashlib.blake2b.__module__=='_blake2' (C extension) vs uuid.UUID methods.__module__=='uuid' (Python); all verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  category: method_modules
  id_prefix: uuidqualnames182b

  columns: [id, function, args, expected, description]
  rows:
    - [str_mod_eq,    UUID.__str__.__module__.__eq__,    ["uuid"], true, "uuid.UUID.__str__.__module__ == 'uuid' (Python-defined in Lib/uuid.py); verified with Python 3.14.3"]
    - [hash_mod_eq,   UUID.__hash__.__module__.__eq__,   ["uuid"], true, "uuid.UUID.__hash__.__module__ == 'uuid' (Python-defined); verified with Python 3.14.3"]
    - [eq_mod_eq,     UUID.__eq__.__module__.__eq__,     ["uuid"], true, "uuid.UUID.__eq__.__module__ == 'uuid' (Python-defined); verified with Python 3.14.3"]
    - [init_mod_eq,   UUID.__init__.__module__.__eq__,   ["uuid"], true, "uuid.UUID.__init__.__module__ == 'uuid' (Python-defined); verified with Python 3.14.3"]
    - [repr_mod_eq,   UUID.__repr__.__module__.__eq__,   ["uuid"], true, "uuid.UUID.__repr__.__module__ == 'uuid' (Python-defined); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — uuid_extra182
# ---------------------------------------------------------------------------

invariant uuid_extra182.UUID_str_qualname_len_12:
  description: "uuid.UUID.__str__.__qualname__.__len__() == 12 — 'UUID.__str__' has 12 characters: 'UUID.'=5 prefix plus '__str__'=7; __str__ is the method that renders a UUID as its canonical 8-4-4-4-12 hyphenated hex string representation; len=12 places __str__ in the middle length group (len=12: __str__, __int__); the shorter group is __eq__=__lt__=11; the longer group is __hash__=__repr__=__init__=13; uuid.UUID.__str__.__module__=='uuid' (Python-defined); uuid.UUID.__str__.__qualname__=='UUID.__str__'; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: qualname_lengths
  kind: python_call_eq
  function: UUID.__str__.__qualname__.__len__
  args: []
  expected: 12

invariant uuid_extra182.UUID_int_qualname_len_12:
  description: "uuid.UUID.__int__.__qualname__.__len__() == 12 — 'UUID.__int__' has 12 characters: 'UUID.'=5 plus '__int__'=7; __int__ returns the 128-bit integer representation of the UUID (same as uuid.int attribute); len=12 ties with __str__; uuid.UUID.__int__.__module__=='uuid'; uuid.UUID.__int__.__qualname__=='UUID.__int__'; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: qualname_lengths
  kind: python_call_eq
  function: UUID.__int__.__qualname__.__len__
  args: []
  expected: 12

invariant uuid_extra182.UUID_repr_qualname_len_13:
  description: "uuid.UUID.__repr__.__qualname__.__len__() == 13 — 'UUID.__repr__' has 13 characters: 'UUID.'=5 plus '__repr__'=8; __repr__ is one of the three tied-longest qualnames in this spec (__repr__=__hash__=__init__=13); __repr__ renders the UUID as 'UUID(\"<hex-str>\")' which is a valid Python expression; uuid.UUID.__repr__.__module__=='uuid'; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: qualname_lengths
  kind: python_call_eq
  function: UUID.__repr__.__qualname__.__len__
  args: []
  expected: 13

invariant uuid_extra182.UUID_hash_qualname_len_13:
  description: "uuid.UUID.__hash__.__qualname__.__len__() == 13 — 'UUID.__hash__' has 13 characters: 'UUID.'=5 plus '__hash__'=8; __hash__ is one of the three tied-longest qualnames in this spec; UUID is hashable so it can be used as a dictionary key or in a set; uuid.UUID.__hash__.__module__=='uuid'; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: qualname_lengths
  kind: python_call_eq
  function: UUID.__hash__.__qualname__.__len__
  args: []
  expected: 13

invariant uuid_extra182.UUID_init_qualname_len_13:
  description: "uuid.UUID.__init__.__qualname__.__len__() == 13 — 'UUID.__init__' has 13 characters: 'UUID.'=5 plus '__init__'=8; __init__ is one of the three tied-longest qualnames in this spec; UUID.__init__ accepts hex string, bytes, bytes_le, fields tuple, or int to construct a UUID; uuid.UUID.__init__.__module__=='uuid'; uuid.UUID.__init__.__qualname__=='UUID.__init__'; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: qualname_lengths
  kind: python_call_eq
  function: UUID.__init__.__qualname__.__len__
  args: []
  expected: 13

invariant uuid_extra182.UUID_lt_module_is_uuid:
  description: "uuid.UUID.__lt__.__module__ == 'uuid' — __lt__ is the less-than comparison method; UUID objects are ordered by their 128-bit integer value; uuid.UUID.__lt__.__module__=='uuid' (Python-defined in Lib/uuid.py); uuid.UUID.__lt__.__qualname__=='UUID.__lt__' (len=11, tied shortest with __eq__); all UUID comparison methods (__eq__, __lt__) are Python-defined in the uuid module; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: method_modules
  kind: python_call_eq
  function: UUID.__lt__.__module__.__eq__
  args: ["uuid"]
  expected: true

invariant uuid_extra182.UUID_int_module_is_uuid:
  description: "uuid.UUID.__int__.__module__ == 'uuid' — __int__ is Python-defined in Lib/uuid.py; uuid.UUID.__int__.__qualname__=='UUID.__int__' (len=12); the 128-bit integer value is stored as uuid.int attribute; __int__ returns this value directly; all UUID dunder methods are pure Python, none are C extension methods; uuid.UUID is not backed by a C accelerator in CPython; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: method_modules
  kind: python_call_eq
  function: UUID.__int__.__module__.__eq__
  args: ["uuid"]
  expected: true

invariant uuid_extra182.UUID_eq_qualname_is_shortest:
  description: "uuid.UUID.__eq__.__qualname__.__len__() == 11 — 'UUID.__eq__' has 11 characters: 'UUID.'=5 plus '__eq__'=6; this is the shortest qualname in the spec (tied with __lt__=11); '__eq__'=6 is the shortest dunder name among the seven methods covered (__eq__=__lt__=6 < __str__=__int__=7 < __hash__=__repr__=__init__=8); uuid.UUID.__eq__.__module__=='uuid'; uuid.UUID.__eq__.__qualname__=='UUID.__eq__'; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: qualname_lengths
  kind: python_call_eq
  function: UUID.__eq__.__qualname__.__len__
  args: []
  expected: 11
