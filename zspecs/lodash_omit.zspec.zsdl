spec: lodash_omit
version: ">=4.0.0"
backend: node(lodash.omit)

docs: https://lodash.com/docs/#omit

provenance:
  derived_from:
    - "lodash.omit README — https://www.npmjs.com/package/lodash.omit"
    - "Test vectors verified with lodash.omit@4.5.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.omit exports the _.omit function directly as module.exports."
    - "omit(object, keys) creates a new object without the specified keys."
    - "Specified keys are dropped; all others are preserved."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a new object with the specified keys removed. No errors for valid inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_omit.omit:
  kind: node_module_call_eq
  function: ~
  category: omit
  id_prefix: lom

  columns: [id, args, expected]
  rows:
    - [one_key,   [{"a": 1, "b": 2, "c": 3}, ["b"]],      {"a": 1, "c": 3}]
    - [two_keys,  [{"x": 1, "y": 2, "z": 3}, ["x", "z"]], {"y": 2}]
    - [missing,   [{"a": 1}, ["b"]],                       {"a": 1}]
