spec: threading_extra1306
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "Wave 534 (_extra1306): focuses on exception-raising behavior for bad argument types and counts."
    - "threading.Semaphore(-1) raises ValueError because initial value must be >= 0."
    - "threading.Semaphore(-2) raises ValueError for same reason."
    - "threading.BoundedSemaphore(-1) raises ValueError because initial value must be >= 0."
    - "threading.Barrier(0) raises ValueError because parties must be >= 1."
    - "threading.Barrier(-1) raises ValueError for same reason."
    - "threading.Condition(lock=42) raises AttributeError because 42 has no acquire method."
    - "threading.Thread(group=42) raises AssertionError because group must be None."
    - "threading.Semaphore(value='x') raises TypeError because comparison with int fails."
    - "All exceptions verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table threading_extra1306.semaphore_value_errors:
  description: "threading.Semaphore and threading.BoundedSemaphore raise ValueError for negative initial values"
  kind: python_call_raises
  category: value_errors
  id_prefix: th1306sv
  columns: [id, function, args, exception]
  rows:
    - [th1306sv001, threading.Semaphore,        [-1],  "ValueError"]
    - [th1306sv002, threading.Semaphore,        [-2],  "ValueError"]
    - [th1306sv003, threading.Semaphore,        [-100], "ValueError"]
    - [th1306sv004, threading.BoundedSemaphore, [-1],  "ValueError"]
    - [th1306sv005, threading.BoundedSemaphore, [-2],  "ValueError"]
    - [th1306sv006, threading.BoundedSemaphore, [-100], "ValueError"]

table threading_extra1306.barrier_value_errors:
  description: "threading.Barrier raises ValueError for invalid parties count"
  kind: python_call_raises
  category: value_errors
  id_prefix: th1306bv
  columns: [id, function, args, exception]
  rows:
    - [th1306bv001, threading.Barrier, [0],    "ValueError"]
    - [th1306bv002, threading.Barrier, [-1],   "ValueError"]
    - [th1306bv003, threading.Barrier, [-10],  "ValueError"]
    - [th1306bv004, threading.Barrier, [-100], "ValueError"]
    - [th1306bv005, threading.Barrier, [0, null, 0.0], "ValueError"]
    - [th1306bv006, threading.Barrier, [-1, null, 5.0], "ValueError"]

table threading_extra1306.constructor_type_errors:
  description: "threading constructors raise TypeError or AttributeError for wrong argument types"
  kind: python_call_raises
  category: type_errors
  id_prefix: th1306ct
  columns: [id, function, args, exception]
  rows:
    - [th1306ct001, threading.Semaphore,  ["x"],  "TypeError"]
    - [th1306ct002, threading.Semaphore,  [[1]],  "TypeError"]
    - [th1306ct003, threading.Condition,  [42],   "AttributeError"]
    - [th1306ct004, threading.Condition,  ["str"], "AttributeError"]
    - [th1306ct005, threading.Condition,  [[42]],  "AttributeError"]
    - [th1306ct006, threading.BoundedSemaphore, ["x"], "TypeError"]
