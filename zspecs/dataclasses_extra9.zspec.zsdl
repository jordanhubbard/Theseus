spec: dataclasses_extra9
version: ">=3.9"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "This spec extends dataclasses.zspec.zsdl and prior extras."
    - "Prior specs (dataclasses through dataclasses_extra8 and dataclasses_field) cover: __name__/__module__/__qualname__ for dataclass/field/fields/asdict/astuple/replace/make_dataclass/is_dataclass/Field/FrozenInstanceError/InitVar; FrozenInstanceError.__bases__[0].__name__ == 'AttributeError'; FrozenInstanceError.__bases__[0].__qualname__ == 'AttributeError'; Field.__name__, Field.__module__, Field.__qualname__ (extra4, extra5, extra6, extra8); MISSING and KW_ONLY sentinel class names."
    - "NEW in this spec: Field.__bases__[0].__name__ (not yet tested); Field.__bases__.__len__ (not yet tested); FrozenInstanceError.__bases__.__len__ (only [0].__name__ tested); InitVar.__bases__[0].__name__ (not yet tested); InitVar.__bases__.__len__ (not yet tested)."
    - "dataclasses.Field.__bases__[0].__name__ == 'object' — Field is a plain Python class with object as its sole base."
    - "dataclasses.Field.__bases__.__len__() == 1 — exactly one direct base."
    - "dataclasses.FrozenInstanceError.__bases__.__len__() == 1 — exactly one direct base (AttributeError)."
    - "dataclasses.InitVar.__bases__[0].__name__ == 'object' — InitVar is a plain Python class with object as its sole base."
    - "dataclasses.InitVar.__bases__.__len__() == 1 — exactly one direct base."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Field.__bases__ — base class identity and count
#
# dataclasses.Field is a plain Python class (not a subclass of any special
# base). Its sole base is object. Prior specs verified Field.__name__,
# Field.__module__, and Field.__qualname__, but no spec has tested Field's
# inheritance chain or how many bases it has.
# ---------------------------------------------------------------------------

invariant dataclasses_extra9.Field.base_is_object:
  description: "dataclasses.Field.__bases__[0].__name__ == 'object' — Field inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Field.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant dataclasses_extra9.Field.bases_len:
  description: "dataclasses.Field.__bases__.__len__() == 1 — Field has exactly one direct base (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: Field.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# FrozenInstanceError.__bases__.__len__() == 1
#
# dataclasses_field.zspec.zsdl and dataclasses_extra5 verified that
# FrozenInstanceError.__bases__[0].__name__ == 'AttributeError'.
# dataclasses_extra8 verified the __qualname__ of that base.
# Not yet verified: that there is exactly one base (i.e., __len__() == 1).
# ---------------------------------------------------------------------------

invariant dataclasses_extra9.FrozenInstanceError.bases_len:
  description: "dataclasses.FrozenInstanceError.__bases__.__len__() == 1 — exactly one direct base (AttributeError)"
  category: class_hierarchy
  kind: python_call_eq
  function: FrozenInstanceError.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# InitVar.__bases__ — base class identity and count
#
# dataclasses.InitVar is the marker class for init-only fields. It is a plain
# Python class whose sole base is object. Prior specs verified InitVar.__name__,
# __module__, and __qualname__, but no spec has tested its inheritance chain.
# ---------------------------------------------------------------------------

invariant dataclasses_extra9.InitVar.base_is_object:
  description: "dataclasses.InitVar.__bases__[0].__name__ == 'object' — InitVar inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: InitVar.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant dataclasses_extra9.InitVar.bases_len:
  description: "dataclasses.InitVar.__bases__.__len__() == 1 — InitVar has exactly one direct base (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: InitVar.__bases__.__len__
  args: []
  expected: 1
