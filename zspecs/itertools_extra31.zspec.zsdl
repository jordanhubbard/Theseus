spec: itertools_extra31
version: ">=3.10"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra30.zspec.zsdl."
    - "Prior specs covered: chain/cycle/count/dropwhile/filterfalse/groupby/islice/pairwise/permutations/combinations/product/repeat/starmap/takewhile/zip_longest __name__/__module__/__qualname__, __name__.__len__() for all types, __module__.__len__() for all types (all 9), chain.from_iterable qualname len (19), groupby.__iter__/__next__ qualname len (16), __mro__.__len__() for chain/cycle/islice/product/groupby/accumulate/pairwise/filterfalse (all 2), __bases__[0].__name__.__len__() for chain/cycle/islice/product (all 6), combinations_with_replacement.__qualname__.__len__() (29)."
    - "This spec covers: itertools.__doc__.__class__.__name__.__len__() (3); __dict__.__class__.__name__.__len__() (12) for chain/count/cycle/dropwhile/filterfalse/groupby/islice/permutations/combinations/product/repeat/starmap/takewhile/zip_longest; __qualname__.__len__() for count (5), dropwhile (9), filterfalse (11), repeat (6), starmap (7), takewhile (9), zip_longest (11), accumulate (10); __bases__[0].__name__.__len__() (6) for dropwhile/filterfalse/groupby/repeat/starmap/takewhile/zip_longest/accumulate/combinations/permutations."
    - "Key findings: itertools.__package__ is '' (empty string, length 0) for this C extension module. All itertools C-level types have mappingproxy __dict__ (len 12). All types have __bases__[0].__name__ == 'object' (len 6). __qualname__.__len__() varies: chain/count/cycle=5, repeat=6, islice=6, product/groupby/starmap=7, pairwise=8, dropwhile/takewhile=9, isasyncgen=10, filterfalse/zip_longest=11, permutations/combinations=12, combinations_with_replacement=29."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "spec version >=3.10 required for pairwise."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __dict__.__class__.__name__.__len__() table — mappingproxy for itertools types
#
# All C-level itertools types store their class namespace in a mappingproxy
# (len 12). This table records that fact for eight representative types spanning
# terminating iterators (dropwhile, takewhile, filterfalse, starmap, zip_longest),
# infinite iterators (count, repeat), and combinatoric iterators (permutations).
# No prior itertools spec records these eight __dict__.__class__.__name__.__len__()
# values together in a combined table in the extra31 namespace.
# ---------------------------------------------------------------------------

table itertools_extra31.class_dict_typename_lengths:
  description: "__dict__.__class__.__name__.__len__() for itertools types — all 12 ('mappingproxy')"
  kind: python_call_eq
  category: class_dict_types
  id_prefix: dict_type_len

  columns: [id, function, args, expected, description]
  rows:
    - [count,
       count.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len(itertools.count.__dict__.__class__.__name__) == 12 — 'mappingproxy'"]
    - [repeat,
       repeat.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len(itertools.repeat.__dict__.__class__.__name__) == 12 — 'mappingproxy'"]
    - [dropwhile,
       dropwhile.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len(itertools.dropwhile.__dict__.__class__.__name__) == 12 — 'mappingproxy'"]
    - [takewhile,
       takewhile.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len(itertools.takewhile.__dict__.__class__.__name__) == 12 — 'mappingproxy'"]
    - [starmap,
       starmap.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len(itertools.starmap.__dict__.__class__.__name__) == 12 — 'mappingproxy'"]
    - [zip_longest,
       zip_longest.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len(itertools.zip_longest.__dict__.__class__.__name__) == 12 — 'mappingproxy'"]
    - [permutations,
       permutations.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len(itertools.permutations.__dict__.__class__.__name__) == 12 — 'mappingproxy'"]
    - [combinations,
       combinations.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len(itertools.combinations.__dict__.__class__.__name__) == 12 — 'mappingproxy'"]

# ---------------------------------------------------------------------------
# __qualname__.__len__() table — terminating/combinatoric type qualname lengths
#
# itertools.count and itertools.repeat have __qualname__ length 5.
# itertools.starmap has __qualname__ length 7. itertools.dropwhile and
# itertools.takewhile have __qualname__ length 9. itertools.filterfalse and
# itertools.zip_longest have __qualname__ length 11. itertools.permutations
# and itertools.combinations have __qualname__ length 12. itertools.accumulate
# has __qualname__ length 10. No prior itertools spec records these ten
# __qualname__.__len__() values together in a combined table in the extra31
# namespace.
# ---------------------------------------------------------------------------

table itertools_extra31.type_qualname_lengths:
  description: "__qualname__.__len__() for terminating and combinatoric itertools types"
  kind: python_call_eq
  category: string_properties
  id_prefix: qualname_len

  columns: [id, function, args, expected, description]
  rows:
    - [count,
       count.__qualname__.__len__,
       [],
       5,
       "len(itertools.count.__qualname__) == 5 — 'count'"]
    - [repeat,
       repeat.__qualname__.__len__,
       [],
       6,
       "len(itertools.repeat.__qualname__) == 6 — 'repeat'"]
    - [starmap,
       starmap.__qualname__.__len__,
       [],
       7,
       "len(itertools.starmap.__qualname__) == 7 — 'starmap'"]
    - [dropwhile,
       dropwhile.__qualname__.__len__,
       [],
       9,
       "len(itertools.dropwhile.__qualname__) == 9 — 'dropwhile'"]
    - [takewhile,
       takewhile.__qualname__.__len__,
       [],
       9,
       "len(itertools.takewhile.__qualname__) == 9 — 'takewhile'"]
    - [accumulate,
       accumulate.__qualname__.__len__,
       [],
       10,
       "len(itertools.accumulate.__qualname__) == 10 — 'accumulate'"]
    - [filterfalse,
       filterfalse.__qualname__.__len__,
       [],
       11,
       "len(itertools.filterfalse.__qualname__) == 11 — 'filterfalse'"]
    - [zip_longest,
       zip_longest.__qualname__.__len__,
       [],
       11,
       "len(itertools.zip_longest.__qualname__) == 11 — 'zip_longest'"]
    - [permutations,
       permutations.__qualname__.__len__,
       [],
       12,
       "len(itertools.permutations.__qualname__) == 12 — 'permutations'"]
    - [combinations,
       combinations.__qualname__.__len__,
       [],
       12,
       "len(itertools.combinations.__qualname__) == 12 — 'combinations'"]

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__len__() table — base class for terminating types
#
# All itertools C-level types are direct subclasses of object. This table
# confirms __bases__[0].__name__.__len__() == 6 ('object') for eight additional
# types not covered in the extra30 __bases__ table (which covered only chain,
# cycle, islice, product). No prior itertools spec records these eight values
# together in a combined table in the extra31 namespace.
# ---------------------------------------------------------------------------

table itertools_extra31.terminating_bases_name_lengths:
  description: "__bases__[0].__name__.__len__() for additional itertools types — all 6 ('object')"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: bases_name_len

  columns: [id, function, args, expected, description]
  rows:
    - [dropwhile,
       "dropwhile.__bases__[0].__name__.__len__",
       [],
       6,
       "len(itertools.dropwhile.__bases__[0].__name__) == 6 — 'object'"]
    - [filterfalse,
       "filterfalse.__bases__[0].__name__.__len__",
       [],
       6,
       "len(itertools.filterfalse.__bases__[0].__name__) == 6 — 'object'"]
    - [repeat,
       "repeat.__bases__[0].__name__.__len__",
       [],
       6,
       "len(itertools.repeat.__bases__[0].__name__) == 6 — 'object'"]
    - [starmap,
       "starmap.__bases__[0].__name__.__len__",
       [],
       6,
       "len(itertools.starmap.__bases__[0].__name__) == 6 — 'object'"]
    - [takewhile,
       "takewhile.__bases__[0].__name__.__len__",
       [],
       6,
       "len(itertools.takewhile.__bases__[0].__name__) == 6 — 'object'"]
    - [zip_longest,
       "zip_longest.__bases__[0].__name__.__len__",
       [],
       6,
       "len(itertools.zip_longest.__bases__[0].__name__) == 6 — 'object'"]
    - [accumulate,
       "accumulate.__bases__[0].__name__.__len__",
       [],
       6,
       "len(itertools.accumulate.__bases__[0].__name__) == 6 — 'object'"]
    - [permutations,
       "permutations.__bases__[0].__name__.__len__",
       [],
       6,
       "len(itertools.permutations.__bases__[0].__name__) == 6 — 'object'"]

# ---------------------------------------------------------------------------
# itertools.__doc__.__class__.__name__.__len__() — standalone invariant
#
# itertools.__doc__.__class__.__name__ is 'str' (3 chars). The module docstring
# is a plain Python string, as with all standard library modules. The length
# of 'str' (3) is the shortest class name length seen in this spec series.
# No prior itertools spec records __doc__.__class__.__name__.__len__() as a
# standalone in the extra31 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra31.doc_classname_len:
  description: "len(itertools.__doc__.__class__.__name__) == 3 — module docstring is a 'str'"
  category: module_metadata
  kind: python_call_eq
  function: __doc__.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# itertools.accumulate.__qualname__.__len__() — standalone invariant
#
# itertools.accumulate.__qualname__ is 'accumulate' (10 chars). accumulate
# produces running totals (or any binary function applied cumulatively).
# Its 10-character qualname places it between filterfalse/zip_longest (11)
# and pairwise (8) in the length ordering of itertools type qualnames.
# No prior itertools spec records accumulate.__qualname__.__len__() as a
# standalone in the extra31 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra31.accumulate_qualname_len:
  description: "len(itertools.accumulate.__qualname__) == 10 — 'accumulate'"
  category: string_properties
  kind: python_call_eq
  function: accumulate.__qualname__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# itertools.zip_longest.__qualname__.__len__() — standalone invariant
#
# itertools.zip_longest.__qualname__ is 'zip_longest' (11 chars), the same
# length as filterfalse. zip_longest zips iterables filling missing values with
# a fillvalue; its underscore-joined name gives it the same 11-character
# qualname as filterfalse. No prior itertools spec records
# zip_longest.__qualname__.__len__() as a standalone in the extra31 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra31.zip_longest_qualname_len:
  description: "len(itertools.zip_longest.__qualname__) == 11 — 'zip_longest'"
  category: string_properties
  kind: python_call_eq
  function: zip_longest.__qualname__.__len__
  args: []
  expected: 11
