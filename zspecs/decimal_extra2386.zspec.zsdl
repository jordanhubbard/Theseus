spec: decimal_extra2386
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "Wave 2386 (decimal_extra2386): __str__ and __repr__ implementation type classification for decimal module types."
    - "decimal.Decimal is a C type (accelerated by _decimal.c); its __repr__ and __str__ are C-level slot wrappers: 'wrapper_descriptor'."
    - "decimal.Context is a C type (accelerated by _decimal.c); its __repr__ and __str__ are C-level slot wrappers: 'wrapper_descriptor'."
    - "decimal.DecimalException is a Python exception class that inherits from ArithmeticError; its __repr__ and __str__ are C-level wrappers inherited from BaseException: 'wrapper_descriptor'."
    - "All three decimal types yield 'wrapper_descriptor' for both __repr__.__class__.__name__ and __str__.__class__.__name__, which is uniform despite the difference between C extension types and Python exception classes."
    - "The uniformity arises because Python exception __repr__/__str__ are defined at the C level in BaseException (Objects/exceptions.c), not in Python."
    - "decimal.Decimal defines a custom tp_repr and tp_str at the C level in _decimal.c; these appear as wrapper_descriptor from Python."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# decimal.Decimal — __repr__ and __str__ implementation type
# ---------------------------------------------------------------------------

table decimal_extra2386.decimal_str_repr:
  description: "decimal.Decimal.__repr__.__class__.__name__ and decimal.Decimal.__str__.__class__.__name__ — both are 'wrapper_descriptor'; decimal.Decimal is a C type accelerated by _decimal.c with custom tp_repr and tp_str slots; from Python these C-level implementations appear as wrapper_descriptor objects"
  kind: python_call_eq
  category: classnames
  id_prefix: dc2386

  columns: [id, function, args, expected]
  rows:
    - ["dc2386001", "decimal.Decimal.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["dc2386002", "decimal.Decimal.__str__.__class__.__name__.__eq__",  ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# decimal.Context — __repr__ and __str__ implementation type
# ---------------------------------------------------------------------------

table decimal_extra2386.context_str_repr:
  description: "decimal.Context.__repr__.__class__.__name__ and decimal.Context.__str__.__class__.__name__ — both are 'wrapper_descriptor'; decimal.Context is a C type in _decimal.c representing the arithmetic context (precision, rounding, flags, traps); its custom tp_repr produces a repr string showing all context settings"
  kind: python_call_eq
  category: classnames
  id_prefix: dc2386

  columns: [id, function, args, expected]
  rows:
    - ["dc2386003", "decimal.Context.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["dc2386004", "decimal.Context.__str__.__class__.__name__.__eq__",  ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# decimal.DecimalException — __repr__ and __str__ implementation type
# ---------------------------------------------------------------------------

table decimal_extra2386.decimalexception_str_repr:
  description: "decimal.DecimalException.__repr__.__class__.__name__ and decimal.DecimalException.__str__.__class__.__name__ — both are 'wrapper_descriptor'; DecimalException inherits from ArithmeticError -> Exception -> BaseException; BaseException defines __repr__ and __str__ at the C level in Objects/exceptions.c, so the slot wrappers are 'wrapper_descriptor' even though DecimalException itself is a Python class"
  kind: python_call_eq
  category: classnames
  id_prefix: dc2386

  columns: [id, function, args, expected]
  rows:
    - ["dc2386005", "decimal.DecimalException.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["dc2386006", "decimal.DecimalException.__str__.__class__.__name__.__eq__",  ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# Negative cross-checks — confirm 'function' does not appear for any decimal type
# ---------------------------------------------------------------------------

table decimal_extra2386.not_function:
  description: "All three decimal types do NOT have 'function' for __repr__ or __str__ — unlike pathlib path classes (Python functions) or re.RegexFlag.__repr__ (enum-defined Python function), all decimal types have C-level slot implementations for both dunder methods"
  kind: python_call_eq
  category: classnames
  id_prefix: dc2386

  columns: [id, function, args, expected]
  rows:
    - ["dc2386007", "decimal.Decimal.__repr__.__class__.__name__.__eq__",          ["function"], false]
    - ["dc2386008", "decimal.Decimal.__str__.__class__.__name__.__eq__",           ["function"], false]
    - ["dc2386009", "decimal.Context.__repr__.__class__.__name__.__eq__",          ["function"], false]
    - ["dc2386010", "decimal.Context.__str__.__class__.__name__.__eq__",           ["function"], false]
    - ["dc2386011", "decimal.DecimalException.__repr__.__class__.__name__.__eq__", ["function"], false]
    - ["dc2386012", "decimal.DecimalException.__str__.__class__.__name__.__eq__",  ["function"], false]

# ---------------------------------------------------------------------------
# Uniformity: all three decimal types agree on wrapper_descriptor for both slots
# ---------------------------------------------------------------------------

table decimal_extra2386.uniform_wrapper_descriptor:
  description: "All three decimal types uniformly return 'wrapper_descriptor' for both __repr__.__class__.__name__ and __str__.__class__.__name__ — this uniformity distinguishes them from pathlib (all 'function') and re.RegexFlag (mixed); within the decimal module there is no asymmetry between __repr__ and __str__ for any of the three covered types"
  kind: python_call_eq
  category: classnames
  id_prefix: dc2386

  columns: [id, function, args, expected]
  rows:
    - ["dc2386013", "decimal.Decimal.__repr__.__class__.__name__.__eq__",          ["wrapper_descriptor"], true]
    - ["dc2386014", "decimal.Decimal.__str__.__class__.__name__.__eq__",           ["wrapper_descriptor"], true]
    - ["dc2386015", "decimal.Context.__repr__.__class__.__name__.__eq__",          ["wrapper_descriptor"], true]
    - ["dc2386016", "decimal.Context.__str__.__class__.__name__.__eq__",           ["wrapper_descriptor"], true]
    - ["dc2386017", "decimal.DecimalException.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["dc2386018", "decimal.DecimalException.__str__.__class__.__name__.__eq__",  ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# Extra rows — confirm decimal.Decimal and decimal.Context repr differs from str
# at the class level (both wrapper_descriptor, but distinct descriptors)
# ---------------------------------------------------------------------------

table decimal_extra2386.repr_str_not_identical:
  description: "decimal.Decimal.__repr__ is not the same object as decimal.Decimal.__str__ — even though both have class 'wrapper_descriptor', they are distinct C slot wrappers bound to different underlying C functions (tp_repr vs tp_str); likewise for decimal.Context"
  kind: python_call_eq
  category: classnames
  id_prefix: dc2386

  columns: [id, function, args, expected]
  rows:
    - ["dc2386019", "decimal.Decimal.__repr__.__eq__", ["decimal.Decimal.__str__"], false]
    - ["dc2386020", "decimal.Context.__repr__.__eq__",  ["decimal.Context.__str__"], false]
