spec: mean
version: ">=1.0.1"
backend: node(mean)

docs: https://www.npmjs.com/package/mean

provenance:
  derived_from:
    - "mean README — https://www.npmjs.com/package/mean"
    - "Test vectors verified with mean via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "mean source"
  notes:
    - "mean is an npm package. Install: npm install mean"
    - "Returns the arithmetic mean (average) of an array of numbers."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table mean.calculate:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: mean

  columns: [id, args, expected]
  rows:
    - [five,    [[1, 2, 3, 4, 5]],  3]
    - [even,    [[2, 4, 6, 8]],     5]
    - [single,  [[42]],             42]
