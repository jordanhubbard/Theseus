spec: decimal_extra1606
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __slots__ and slot descriptor protocol"
    - "decimal.Decimal and decimal.Context are C extension types (from _decimal); C types do not use Python __slots__"
    - "decimal.Decimal exposes real and imag as getset_descriptor; arithmetic dunder methods are wrapper_descriptor"
    - "decimal.Decimal regular methods (sqrt, quantize, compare, etc.) are method_descriptor"
    - "decimal.Context arithmetic properties (prec, rounding, Emax, Emin, capitals, clamp) are getset_descriptor"
    - "decimal.Context methods are method_descriptor; dunder special methods are wrapper_descriptor"
    - "decimal.DecimalException and all its subclasses are Python exception classes with no explicit __slots__"
    - "C types do not expose __dict__ or __weakref__ in the class dict; instance storage is managed at the C level"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: decimal.Decimal and decimal.Context — no __slots__ (C types)
# ---------------------------------------------------------------------------

table decimal_extra1606.decimal_no_slots:
  description: "decimal.Decimal and decimal.Context are C extension types — neither defines __slots__, __dict__, or __weakref__ in its own class dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1606ns

  columns: [id, function, args, expected]
  rows:
    - ["dc1606ns001", decimal.Decimal.__dict__.__contains__,  ["__slots__"],   false]
    - ["dc1606ns002", decimal.Context.__dict__.__contains__,  ["__slots__"],   false]
    - ["dc1606ns003", decimal.Decimal.__dict__.__contains__,  ["__dict__"],    false]
    - ["dc1606ns004", decimal.Context.__dict__.__contains__,  ["__dict__"],    false]
    - ["dc1606ns005", decimal.Decimal.__dict__.__contains__,  ["__weakref__"], false]
    - ["dc1606ns006", decimal.Context.__dict__.__contains__,  ["__weakref__"], false]
    - ["dc1606ns007", decimal.Decimal.__dict__.__contains__,  ["real"],        true]
    - ["dc1606ns008", decimal.Decimal.__dict__.__contains__,  ["imag"],        true]
    - ["dc1606ns009", decimal.Decimal.__dict__.__contains__,  ["__repr__"],    true]
    - ["dc1606ns010", decimal.Decimal.__dict__.__contains__,  ["__str__"],     true]
    - ["dc1606ns011", decimal.Decimal.__dict__.__contains__,  ["__add__"],     true]
    - ["dc1606ns012", decimal.Decimal.__dict__.__contains__,  ["__sub__"],     true]
    - ["dc1606ns013", decimal.Decimal.__dict__.__contains__,  ["__mul__"],     true]
    - ["dc1606ns014", decimal.Decimal.__dict__.__contains__,  ["__truediv__"], true]
    - ["dc1606ns015", decimal.Decimal.__dict__.__contains__,  ["__mod__"],     true]
    - ["dc1606ns016", decimal.Decimal.__dict__.__contains__,  ["__pow__"],     true]
    - ["dc1606ns017", decimal.Decimal.__dict__.__contains__,  ["__neg__"],     true]
    - ["dc1606ns018", decimal.Decimal.__dict__.__contains__,  ["__pos__"],     true]
    - ["dc1606ns019", decimal.Decimal.__dict__.__contains__,  ["__abs__"],     true]
    - ["dc1606ns020", decimal.Decimal.__dict__.__contains__,  ["__bool__"],    true]
    - ["dc1606ns021", decimal.Decimal.__dict__.__contains__,  ["sqrt"],        true]
    - ["dc1606ns022", decimal.Decimal.__dict__.__contains__,  ["quantize"],    true]
    - ["dc1606ns023", decimal.Decimal.__dict__.__contains__,  ["normalize"],   true]
    - ["dc1606ns024", decimal.Context.__dict__.__contains__,  ["prec"],        true]
    - ["dc1606ns025", decimal.Context.__dict__.__contains__,  ["rounding"],    true]
    - ["dc1606ns026", decimal.Context.__dict__.__contains__,  ["Emax"],        true]
    - ["dc1606ns027", decimal.Context.__dict__.__contains__,  ["Emin"],        true]
    - ["dc1606ns028", decimal.Context.__dict__.__contains__,  ["capitals"],    true]
    - ["dc1606ns029", decimal.Context.__dict__.__contains__,  ["clamp"],       true]
    - ["dc1606ns030", decimal.Context.__dict__.__contains__,  ["sqrt"],        true]

# ---------------------------------------------------------------------------
# Table 2: decimal attribute and method descriptor types
# ---------------------------------------------------------------------------

table decimal_extra1606.decimal_attr_types:
  description: "decimal.Decimal and decimal.Context expose C-level attributes as getset_descriptor, regular methods as method_descriptor, and dunder special methods as wrapper_descriptor"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1606at

  columns: [id, function, args, expected]
  rows:
    - ["dc1606at001", type(decimal.Decimal.__dict__["real"]).__name__.__eq__,         ["getset_descriptor"],  true]
    - ["dc1606at002", type(decimal.Decimal.__dict__["imag"]).__name__.__eq__,         ["getset_descriptor"],  true]
    - ["dc1606at003", type(decimal.Decimal.__dict__["__add__"]).__name__.__eq__,      ["wrapper_descriptor"], true]
    - ["dc1606at004", type(decimal.Decimal.__dict__["__sub__"]).__name__.__eq__,      ["wrapper_descriptor"], true]
    - ["dc1606at005", type(decimal.Decimal.__dict__["__mul__"]).__name__.__eq__,      ["wrapper_descriptor"], true]
    - ["dc1606at006", type(decimal.Decimal.__dict__["__truediv__"]).__name__.__eq__,  ["wrapper_descriptor"], true]
    - ["dc1606at007", type(decimal.Decimal.__dict__["__mod__"]).__name__.__eq__,      ["wrapper_descriptor"], true]
    - ["dc1606at008", type(decimal.Decimal.__dict__["__pow__"]).__name__.__eq__,      ["wrapper_descriptor"], true]
    - ["dc1606at009", type(decimal.Decimal.__dict__["__neg__"]).__name__.__eq__,      ["wrapper_descriptor"], true]
    - ["dc1606at010", type(decimal.Decimal.__dict__["__pos__"]).__name__.__eq__,      ["wrapper_descriptor"], true]
    - ["dc1606at011", type(decimal.Decimal.__dict__["__abs__"]).__name__.__eq__,      ["wrapper_descriptor"], true]
    - ["dc1606at012", type(decimal.Decimal.__dict__["__str__"]).__name__.__eq__,      ["wrapper_descriptor"], true]
    - ["dc1606at013", type(decimal.Decimal.__dict__["__repr__"]).__name__.__eq__,     ["wrapper_descriptor"], true]
    - ["dc1606at014", type(decimal.Decimal.__dict__["__bool__"]).__name__.__eq__,     ["wrapper_descriptor"], true]
    - ["dc1606at015", type(decimal.Decimal.__dict__["__hash__"]).__name__.__eq__,     ["wrapper_descriptor"], true]
    - ["dc1606at016", type(decimal.Decimal.__dict__["__eq__"]).__name__.__eq__,       ["wrapper_descriptor"], true]
    - ["dc1606at017", type(decimal.Decimal.__dict__["__lt__"]).__name__.__eq__,       ["wrapper_descriptor"], true]
    - ["dc1606at018", type(decimal.Decimal.__dict__["__float__"]).__name__.__eq__,    ["wrapper_descriptor"], true]
    - ["dc1606at019", type(decimal.Decimal.__dict__["__int__"]).__name__.__eq__,      ["wrapper_descriptor"], true]
    - ["dc1606at020", type(decimal.Decimal.__dict__["sqrt"]).__name__.__eq__,         ["method_descriptor"],  true]
    - ["dc1606at021", type(decimal.Decimal.__dict__["quantize"]).__name__.__eq__,     ["method_descriptor"],  true]
    - ["dc1606at022", type(decimal.Decimal.__dict__["normalize"]).__name__.__eq__,    ["method_descriptor"],  true]
    - ["dc1606at023", type(decimal.Decimal.__dict__["compare"]).__name__.__eq__,      ["method_descriptor"],  true]
    - ["dc1606at024", type(decimal.Decimal.__dict__["is_nan"]).__name__.__eq__,       ["method_descriptor"],  true]
    - ["dc1606at025", type(decimal.Decimal.__dict__["is_finite"]).__name__.__eq__,    ["method_descriptor"],  true]
    - ["dc1606at026", type(decimal.Decimal.__dict__["is_zero"]).__name__.__eq__,      ["method_descriptor"],  true]
    - ["dc1606at027", type(decimal.Context.__dict__["prec"]).__name__.__eq__,         ["getset_descriptor"],  true]
    - ["dc1606at028", type(decimal.Context.__dict__["rounding"]).__name__.__eq__,     ["getset_descriptor"],  true]
    - ["dc1606at029", type(decimal.Context.__dict__["Emax"]).__name__.__eq__,         ["getset_descriptor"],  true]
    - ["dc1606at030", type(decimal.Context.__dict__["Emin"]).__name__.__eq__,         ["getset_descriptor"],  true]
    - ["dc1606at031", type(decimal.Context.__dict__["capitals"]).__name__.__eq__,     ["getset_descriptor"],  true]
    - ["dc1606at032", type(decimal.Context.__dict__["clamp"]).__name__.__eq__,        ["getset_descriptor"],  true]
    - ["dc1606at033", type(decimal.Context.__dict__["sqrt"]).__name__.__eq__,         ["method_descriptor"],  true]
    - ["dc1606at034", type(decimal.Context.__dict__["add"]).__name__.__eq__,          ["method_descriptor"],  true]
    - ["dc1606at035", type(decimal.Context.__dict__["__repr__"]).__name__.__eq__,     ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# Table 3: decimal exception hierarchy — no __slots__
# ---------------------------------------------------------------------------

table decimal_extra1606.decimal_exceptions_no_slots:
  description: "decimal.DecimalException and all its standard subclasses are Python exception classes; none define __slots__ or __dict__ explicitly — they inherit instance __dict__ from BaseException"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1606ex

  columns: [id, function, args, expected]
  rows:
    - ["dc1606ex001", decimal.DecimalException.__dict__.__contains__,  ["__slots__"], false]
    - ["dc1606ex002", decimal.InvalidOperation.__dict__.__contains__,  ["__slots__"], false]
    - ["dc1606ex003", decimal.DivisionByZero.__dict__.__contains__,    ["__slots__"], false]
    - ["dc1606ex004", decimal.Overflow.__dict__.__contains__,          ["__slots__"], false]
    - ["dc1606ex005", decimal.Underflow.__dict__.__contains__,         ["__slots__"], false]
    - ["dc1606ex006", decimal.Inexact.__dict__.__contains__,           ["__slots__"], false]
    - ["dc1606ex007", decimal.Rounded.__dict__.__contains__,           ["__slots__"], false]
    - ["dc1606ex008", decimal.Subnormal.__dict__.__contains__,         ["__slots__"], false]
    - ["dc1606ex009", decimal.FloatOperation.__dict__.__contains__,    ["__slots__"], false]
    - ["dc1606ex010", decimal.Clamped.__dict__.__contains__,           ["__slots__"], false]
    - ["dc1606ex011", decimal.DivisionImpossible.__dict__.__contains__, ["__slots__"], false]
    - ["dc1606ex012", decimal.DivisionUndefined.__dict__.__contains__, ["__slots__"], false]
    - ["dc1606ex013", decimal.ConversionSyntax.__dict__.__contains__,  ["__slots__"], false]
    - ["dc1606ex014", decimal.InvalidOperation.__dict__.__contains__,  ["__module__"], true]
    - ["dc1606ex015", decimal.DivisionByZero.__dict__.__contains__,    ["__module__"], true]
    - ["dc1606ex016", decimal.Overflow.__dict__.__contains__,          ["__module__"], true]
    - ["dc1606ex017", decimal.Underflow.__dict__.__contains__,         ["__module__"], true]
    - ["dc1606ex018", decimal.Inexact.__dict__.__contains__,           ["__module__"], true]
    - ["dc1606ex019", decimal.Rounded.__dict__.__contains__,           ["__module__"], true]
    - ["dc1606ex020", decimal.Subnormal.__dict__.__contains__,         ["__module__"], true]
    - ["dc1606ex021", decimal.FloatOperation.__dict__.__contains__,    ["__module__"], true]
    - ["dc1606ex022", decimal.Clamped.__dict__.__contains__,           ["__module__"], true]
    - ["dc1606ex023", decimal.DivisionImpossible.__dict__.__contains__, ["__module__"], true]
    - ["dc1606ex024", decimal.DivisionUndefined.__dict__.__contains__, ["__module__"], true]
    - ["dc1606ex025", decimal.ConversionSyntax.__dict__.__contains__,  ["__module__"], true]
    - ["dc1606ex026", decimal.DecimalException.__dict__.__contains__,  ["__dict__"],  false]
    - ["dc1606ex027", decimal.InvalidOperation.__dict__.__contains__,  ["__dict__"],  false]
    - ["dc1606ex028", decimal.DivisionByZero.__dict__.__contains__,    ["__dict__"],  false]
    - ["dc1606ex029", decimal.Overflow.__dict__.__contains__,          ["__dict__"],  false]
    - ["dc1606ex030", decimal.FloatOperation.__dict__.__contains__,    ["__dict__"],  false]
