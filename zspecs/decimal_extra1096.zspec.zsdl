spec: decimal_extra1096
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module Decimal object protocol dunders: __new__, __hash__, __repr__, __str__, __format__, __reduce__, __copy__, and __deepcopy__ documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks Decimal object-protocol dunder __qualname__ values not covered in _extra1066 (conversion/comparison) or _extra1081 (arithmetic/comparison/context); covers __new__, __hash__, __repr__, __str__, __format__, __reduce__, __copy__, and __deepcopy__"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra1096.decimal_construction_dunders:
  description: "decimal.Decimal construction and hashing dunder method __qualname__ checks"
  kind: python_call_eq
  category: decimal_construction_dunders
  id_prefix: dc1096nd
  columns: [id, function, args, expected]
  rows:
    - [dc1096nd001, decimal.Decimal.__new__.__qualname__.__eq__,   ["Decimal.__new__"],   true]
    - [dc1096nd002, decimal.Decimal.__hash__.__qualname__.__eq__,  ["Decimal.__hash__"],  true]
    - [dc1096nd003, decimal.Decimal.__bool__.__qualname__.__eq__,  ["Decimal.__bool__"],  true]
    - [dc1096nd004, decimal.Decimal.__new__.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [dc1096nd005, decimal.Decimal.__hash__.__class__.__name__.__eq__, ["wrapper_descriptor"],         true]
    - [dc1096nd006, decimal.Decimal.__bool__.__class__.__name__.__eq__, ["wrapper_descriptor"],         true]
    - [dc1096nd007, decimal.Decimal.__module__.__eq__,             ["decimal"],           true]
    - [dc1096nd008, decimal.Decimal.__qualname__.__eq__,           ["Decimal"],           true]

table decimal_extra1096.decimal_repr_str_format_dunders:
  description: "decimal.Decimal __repr__, __str__, and __format__ dunder method __qualname__ checks"
  kind: python_call_eq
  category: decimal_repr_str_format_dunders
  id_prefix: dc1096rf
  columns: [id, function, args, expected]
  rows:
    - [dc1096rf001, decimal.Decimal.__repr__.__qualname__.__eq__,   ["Decimal.__repr__"],   true]
    - [dc1096rf002, decimal.Decimal.__str__.__qualname__.__eq__,    ["Decimal.__str__"],    true]
    - [dc1096rf003, decimal.Decimal.__format__.__qualname__.__eq__, ["Decimal.__format__"], true]
    - [dc1096rf004, decimal.Decimal.__repr__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true]
    - [dc1096rf005, decimal.Decimal.__str__.__class__.__name__.__eq__,    ["wrapper_descriptor"], true]
    - [dc1096rf006, decimal.Decimal.__format__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [dc1096rf007, decimal.Decimal.__repr__.__qualname__.__eq__,   ["Decimal.__str__"],    false]

table decimal_extra1096.decimal_reduce_copy_dunders:
  description: "decimal.Decimal __reduce__, __copy__, and __deepcopy__ dunder method __qualname__ checks"
  kind: python_call_eq
  category: decimal_reduce_copy_dunders
  id_prefix: dc1096rc
  columns: [id, function, args, expected]
  rows:
    - [dc1096rc001, decimal.Decimal.__reduce__.__qualname__.__eq__,   ["Decimal.__reduce__"],   true]
    - [dc1096rc002, decimal.Decimal.__copy__.__qualname__.__eq__,     ["Decimal.__copy__"],     true]
    - [dc1096rc003, decimal.Decimal.__deepcopy__.__qualname__.__eq__, ["Decimal.__deepcopy__"], true]
    - [dc1096rc004, decimal.Decimal.__reduce__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true]
    - [dc1096rc005, decimal.Decimal.__copy__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true]
    - [dc1096rc006, decimal.Decimal.__deepcopy__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [dc1096rc007, decimal.Decimal.__floor__.__qualname__.__eq__,    ["Decimal.__floor__"],    true]
    - [dc1096rc008, decimal.Decimal.__ceil__.__qualname__.__eq__,     ["Decimal.__ceil__"],     true]
    - [dc1096rc009, decimal.Decimal.__round__.__qualname__.__eq__,    ["Decimal.__round__"],    true]
