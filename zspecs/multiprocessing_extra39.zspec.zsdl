spec: multiprocessing_extra39
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#exceptions — multiprocessing exception hierarchy"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra38.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', Process.__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() tables, Process method __qualname__.__len__() tables, Pool method tables, Process/Pool __mro__.__len__() tables, __all__ metadata, class __dict__ tables, DefaultContext method qualname lengths, BaseProcess metadata, function __name__.__len__() for cpu_count/current_process/active_children/parent_process/get_start_method, pool result class tables, Process/__name__=='Process' (extra37), Process/__module__=='multiprocessing.context' (extra37), Queue/__name__=='Queue' (extra37), Pipe/__name__=='Pipe' (extra37), Process method qualname lens for start/join/run (extra37), Process.__bases__[0].__name__=='BaseProcess'/__mro__.__len__()==3/Manager.__name__=='Manager' (extra38), function __name__/__module__ string equality for cpu_count/current_process/active_children (extra38)."
    - "This spec covers: AuthenticationError/__name__=='AuthenticationError'; AuthenticationError/__module__=='multiprocessing.context' (23 chars); AuthenticationError/__bases__[0].__name__=='ProcessError' (NOT 'Exception' — AuthenticationError extends ProcessError, not Exception directly); ProcessError/__name__=='ProcessError'; ProcessError/__bases__[0].__name__=='Exception'; BufferTooShort/__name__=='BufferTooShort'; TimeoutError/__name__=='TimeoutError'; TimeoutError/__bases__[0].__name__=='ProcessError' (NOT 'OSError' — the multiprocessing TimeoutError extends ProcessError, making it distinct from the built-in TimeoutError which extends OSError)."
    - "IMPORTANT: multiprocessing.AuthenticationError.__bases__[0].__name__ == 'ProcessError', NOT 'Exception'. The multiprocessing exception hierarchy is: ProcessError -> Exception -> ..., and AuthenticationError, BufferTooShort, and TimeoutError all inherit from ProcessError (not directly from Exception). This was verified with Python 3.14.3."
    - "IMPORTANT: multiprocessing.TimeoutError.__bases__[0].__name__ == 'ProcessError', NOT 'OSError'. The multiprocessing.TimeoutError is a domain-specific exception in the multiprocessing hierarchy. It is distinct from the built-in TimeoutError (which extends OSError). Both exist in Python, but multiprocessing.TimeoutError extends multiprocessing.ProcessError."
    - "multiprocessing.AuthenticationError.__module__ == 'multiprocessing.context' (23 chars). ProcessError.__module__ == 'multiprocessing.context' (23 chars). BufferTooShort.__module__ == 'multiprocessing.context' (23 chars). TimeoutError.__module__ == 'multiprocessing.context' (23 chars). All four exception classes are defined in the context submodule."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.ProcessError identity — extra39 namespace
#
# ProcessError is the root of the multiprocessing exception hierarchy:
#   ProcessError.__name__            == 'ProcessError' (12 chars)
#   ProcessError.__bases__[0].__name__ == 'Exception'
#   ProcessError.__module__          == 'multiprocessing.context' (23 chars)
# ProcessError extends Python's built-in Exception. All other multiprocessing
# exceptions (AuthenticationError, BufferTooShort, TimeoutError) inherit from
# ProcessError, NOT directly from Exception.
# ---------------------------------------------------------------------------

table multiprocessing_extra39.process_error_identity:
  description: "multiprocessing.ProcessError identity in extra39 namespace — __name__, base class, and __module__"
  kind: python_call_eq
  category: class_names
  id_prefix: mpprocerrident39

  columns: [id, function, args, expected, description]
  rows:
    - [name,       ProcessError.__name__.__eq__,                  ["ProcessError"],           true, "ProcessError.__name__ == 'ProcessError' (12 chars)"]
    - [bases0,     "ProcessError.__bases__[0].__name__.__eq__",   ["Exception"],              true, "ProcessError.__bases__[0].__name__ == 'Exception' — root of the multiprocessing exception hierarchy"]
    - [module,     ProcessError.__module__.__eq__,                ["multiprocessing.context"], true, "ProcessError.__module__ == 'multiprocessing.context' (23 chars)"]

# ---------------------------------------------------------------------------
# multiprocessing exception subclass identity — extra39 namespace
#
# Three exception classes that inherit from ProcessError:
#   AuthenticationError.__name__              == 'AuthenticationError' (19 chars)
#   AuthenticationError.__bases__[0].__name__ == 'ProcessError'
#   BufferTooShort.__name__                   == 'BufferTooShort'      (14 chars)
#   TimeoutError.__name__                     == 'TimeoutError'        (12 chars)
#   TimeoutError.__bases__[0].__name__        == 'ProcessError'
# All three inherit from ProcessError, NOT from Exception directly.
# This is the multiprocessing.TimeoutError — distinct from the built-in
# TimeoutError (which extends OSError). The module for all is 'multiprocessing.context'.
# ---------------------------------------------------------------------------

table multiprocessing_extra39.exception_subclass_names:
  description: "multiprocessing exception subclass __name__ string equality in extra39 namespace"
  kind: python_call_eq
  category: class_names
  id_prefix: mpexcsubnames39

  columns: [id, function, args, expected, description]
  rows:
    - [AuthenticationError_name, AuthenticationError.__name__.__eq__, ["AuthenticationError"], true, "AuthenticationError.__name__ == 'AuthenticationError' (19 chars)"]
    - [BufferTooShort_name,      BufferTooShort.__name__.__eq__,      ["BufferTooShort"],      true, "BufferTooShort.__name__ == 'BufferTooShort' (14 chars)"]
    - [TimeoutError_name,        TimeoutError.__name__.__eq__,        ["TimeoutError"],        true, "TimeoutError.__name__ == 'TimeoutError' (12 chars)"]

table multiprocessing_extra39.exception_base_classes:
  description: "multiprocessing exception __bases__[0].__name__ string equality in extra39 namespace — AuthenticationError and TimeoutError both extend ProcessError"
  kind: python_call_eq
  category: class_names
  id_prefix: mpexcbases39

  columns: [id, function, args, expected, description]
  rows:
    - [AuthenticationError_base, "AuthenticationError.__bases__[0].__name__.__eq__", ["ProcessError"], true, "AuthenticationError.__bases__[0].__name__ == 'ProcessError' — NOT Exception directly"]
    - [TimeoutError_base,        "TimeoutError.__bases__[0].__name__.__eq__",        ["ProcessError"], true, "TimeoutError.__bases__[0].__name__ == 'ProcessError' — the multiprocessing TimeoutError, distinct from the built-in TimeoutError (which extends OSError)"]

table multiprocessing_extra39.exception_modules:
  description: "multiprocessing exception __module__ string equality in extra39 namespace — all four live in multiprocessing.context"
  kind: python_call_eq
  category: module_names
  id_prefix: mpexcmods39

  columns: [id, function, args, expected, description]
  rows:
    - [AuthenticationError_mod, AuthenticationError.__module__.__eq__, ["multiprocessing.context"], true, "AuthenticationError.__module__ == 'multiprocessing.context' (23 chars)"]
    - [BufferTooShort_mod,      BufferTooShort.__module__.__eq__,      ["multiprocessing.context"], true, "BufferTooShort.__module__ == 'multiprocessing.context' (23 chars)"]
    - [TimeoutError_mod,        TimeoutError.__module__.__eq__,        ["multiprocessing.context"], true, "TimeoutError.__module__ == 'multiprocessing.context' (23 chars)"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra39
# ---------------------------------------------------------------------------

invariant multiprocessing_extra39.ProcessError_name_eq:
  description: "multiprocessing.ProcessError.__name__ == 'ProcessError' — the root exception class for the multiprocessing exception hierarchy (12 chars)"
  category: class_names
  kind: python_call_eq
  function: ProcessError.__name__.__eq__
  args: ["ProcessError"]
  expected: true

invariant multiprocessing_extra39.ProcessError_bases0_name_eq:
  description: "multiprocessing.ProcessError.__bases__[0].__name__ == 'Exception' — ProcessError is the root; it inherits from Python's built-in Exception class"
  category: class_names
  kind: python_call_eq
  function: "ProcessError.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant multiprocessing_extra39.AuthenticationError_name_eq:
  description: "multiprocessing.AuthenticationError.__name__ == 'AuthenticationError' — raised when an authentication failure occurs in multiprocessing (19 chars)"
  category: class_names
  kind: python_call_eq
  function: AuthenticationError.__name__.__eq__
  args: ["AuthenticationError"]
  expected: true

invariant multiprocessing_extra39.AuthenticationError_bases0_name_eq:
  description: "multiprocessing.AuthenticationError.__bases__[0].__name__ == 'ProcessError' — AuthenticationError inherits from ProcessError, not directly from Exception"
  category: class_names
  kind: python_call_eq
  function: "AuthenticationError.__bases__[0].__name__.__eq__"
  args: ["ProcessError"]
  expected: true

invariant multiprocessing_extra39.AuthenticationError_module_eq:
  description: "multiprocessing.AuthenticationError.__module__ == 'multiprocessing.context' — all multiprocessing exception classes are defined in the context submodule (23 chars)"
  category: module_names
  kind: python_call_eq
  function: AuthenticationError.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra39.BufferTooShort_name_eq:
  description: "multiprocessing.BufferTooShort.__name__ == 'BufferTooShort' — raised when a buffer is too small to receive a message (14 chars)"
  category: class_names
  kind: python_call_eq
  function: BufferTooShort.__name__.__eq__
  args: ["BufferTooShort"]
  expected: true

invariant multiprocessing_extra39.TimeoutError_name_eq:
  description: "multiprocessing.TimeoutError.__name__ == 'TimeoutError' — the multiprocessing-domain timeout exception; distinct from the built-in TimeoutError (12 chars)"
  category: class_names
  kind: python_call_eq
  function: TimeoutError.__name__.__eq__
  args: ["TimeoutError"]
  expected: true

invariant multiprocessing_extra39.TimeoutError_bases0_name_eq:
  description: "multiprocessing.TimeoutError.__bases__[0].__name__ == 'ProcessError' — the multiprocessing TimeoutError extends ProcessError, NOT OSError (the built-in TimeoutError extends OSError)"
  category: class_names
  kind: python_call_eq
  function: "TimeoutError.__bases__[0].__name__.__eq__"
  args: ["ProcessError"]
  expected: true
