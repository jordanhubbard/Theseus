spec: inspect_extra172
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.stack.__name__ 'stack'; inspect.stack.__module__ 'inspect'; inspect.currentframe.__name__ 'currentframe'; inspect.currentframe.__module__ 'inspect'; inspect.getframeinfo.__name__ 'getframeinfo'; inspect.getframeinfo.__module__ 'inspect'; inspect.FrameInfo.__name__ 'FrameInfo'; inspect.FrameInfo.__module__ 'inspect' (Wave 301)."
    - "inspect.stack.__name__ == 'stack' — inspect.stack is a Python function defined in Lib/inspect.py that returns a list of FrameInfo named tuples for the caller's stack; its __name__ is 'stack'. Verified with Python 3.14.3."
    - "inspect.stack.__module__ == 'inspect' — stack is defined in Lib/inspect.py; its __module__ attribute is 'inspect'. Verified with Python 3.14.3."
    - "inspect.currentframe.__name__ == 'currentframe' — inspect.currentframe is a Python function defined in Lib/inspect.py (it wraps sys._getframe); its __name__ is 'currentframe'. Verified with Python 3.14.3."
    - "inspect.currentframe.__module__ == 'inspect' — currentframe is defined in Lib/inspect.py; its __module__ attribute is 'inspect'. Verified with Python 3.14.3."
    - "inspect.currentframe.__class__.__name__ == 'function' — inspect.currentframe is a regular Python function (def currentframe(): return sys._getframe(1) or similar); its __class__.__name__ is 'function'. Verified with Python 3.14.3."
    - "inspect.getframeinfo.__name__ == 'getframeinfo' — inspect.getframeinfo is a Python function defined in Lib/inspect.py that returns a Traceback named tuple for a frame object; its __name__ is 'getframeinfo'. Verified with Python 3.14.3."
    - "inspect.getframeinfo.__module__ == 'inspect' — getframeinfo is defined in Lib/inspect.py; its __module__ attribute is 'inspect'. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__name__ == 'FrameInfo' — inspect.FrameInfo is a NamedTuple class (subclass of tuple) defined in Lib/inspect.py representing a frame info record with fields filename, lineno, function, code_context, index, positions; its __name__ is 'FrameInfo'. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__module__ == 'inspect' — FrameInfo is defined in Lib/inspect.py; its __module__ attribute is 'inspect'. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__class__.__name__ == 'type' — FrameInfo is a class object (a NamedTuple subclass); its metaclass is 'type'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.stack Python function identity — __name__, __module__,
# __class__.__name__
#
# Wave 301 theme: inspect.stack Python function identity — __name__,
# __module__, and __class__.__name__.
#
# inspect.stack.__name__ == 'stack'
# inspect.stack.__module__ == 'inspect'
# inspect.stack.__class__.__name__ == 'function'
# inspect.stack.__name__ != 'currentframe'
#
# inspect.stack(context=1) returns a list of FrameInfo named tuples for the
# caller's call stack. Each FrameInfo has a frame, filename, lineno, function,
# code_context, and index. It is a Python function defined in Lib/inspect.py.
# New to extra172.
# ---------------------------------------------------------------------------

table inspect_extra172.stack_identity:
  description: "inspect.stack: __name__ 'stack', __module__ 'inspect', __class__.__name__ 'function'; wave 301; new to extra172"
  kind: python_call_eq
  category: identity
  id_prefix: inspectsi172

  columns: [id, function, args, expected, description]
  rows:
    - [stack_name_stack,
       "stack.__name__.__eq__",
       ["stack"],
       true,
       "inspect.stack.__name__.__eq__('stack') == True — inspect.stack is a Python function defined in Lib/inspect.py that returns a list of FrameInfo named tuples for the caller's call stack; its __name__ attribute is 'stack'; str.__eq__('stack') returns True; new to extra172"]
    - [stack_module_inspect,
       "stack.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.stack.__module__.__eq__('inspect') == True — inspect.stack is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra172"]
    - [stack_class_function,
       "stack.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.stack.__class__.__name__.__eq__('function') == True — inspect.stack is a regular Python function defined with def in Lib/inspect.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra172"]
    - [stack_name_ne_currentframe,
       "stack.__name__.__eq__",
       ["currentframe"],
       false,
       "inspect.stack.__name__.__eq__('currentframe') == False — stack.__name__ is 'stack', not 'currentframe'; stack returns the full call stack as FrameInfo tuples while currentframe returns only the calling frame object; they are distinct functions; str.__eq__('currentframe') returns False; new to extra172"]

# ---------------------------------------------------------------------------
# Table 2: inspect.currentframe Python function identity — __name__, __module__,
# __class__.__name__
#
# Wave 301 theme: inspect.currentframe Python function identity — __name__,
# __module__, and __class__.__name__.
#
# inspect.currentframe.__name__ == 'currentframe'
# inspect.currentframe.__module__ == 'inspect'
# inspect.currentframe.__class__.__name__ == 'function'
# inspect.currentframe.__name__ != 'stack'
#
# inspect.currentframe() returns the frame object for the caller's current
# stack frame. It is a Python function defined in Lib/inspect.py that wraps
# sys._getframe(). Its __class__.__name__ is 'function' — it is a regular
# Python function, not a builtin. New to extra172.
# ---------------------------------------------------------------------------

table inspect_extra172.currentframe_identity:
  description: "inspect.currentframe: __name__ 'currentframe', __module__ 'inspect', __class__.__name__ 'function'; wave 301; new to extra172"
  kind: python_call_eq
  category: identity
  id_prefix: inspectcfi172

  columns: [id, function, args, expected, description]
  rows:
    - [currentframe_name_currentframe,
       "currentframe.__name__.__eq__",
       ["currentframe"],
       true,
       "inspect.currentframe.__name__.__eq__('currentframe') == True — inspect.currentframe is a Python function defined in Lib/inspect.py that returns the frame object for the caller's current stack frame; its __name__ attribute is 'currentframe'; str.__eq__('currentframe') returns True; new to extra172"]
    - [currentframe_module_inspect,
       "currentframe.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.currentframe.__module__.__eq__('inspect') == True — inspect.currentframe is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra172"]
    - [currentframe_class_function,
       "currentframe.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.currentframe.__class__.__name__.__eq__('function') == True — inspect.currentframe is a regular Python function defined with def in Lib/inspect.py (not a C builtin); its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra172"]
    - [currentframe_name_ne_stack,
       "currentframe.__name__.__eq__",
       ["stack"],
       false,
       "inspect.currentframe.__name__.__eq__('stack') == False — currentframe.__name__ is 'currentframe', not 'stack'; currentframe returns the single current frame object while stack returns the full call stack as a list of FrameInfo tuples; they serve different purposes; str.__eq__('stack') returns False; new to extra172"]

# ---------------------------------------------------------------------------
# Table 3: inspect.getframeinfo Python function identity — __name__, __module__,
# __class__.__name__, name length
#
# Wave 301 theme: inspect.getframeinfo Python function identity — __name__,
# __module__, __class__.__name__, and __name__.__len__().
#
# inspect.getframeinfo.__name__ == 'getframeinfo'
# inspect.getframeinfo.__module__ == 'inspect'
# inspect.getframeinfo.__class__.__name__ == 'function'
# inspect.getframeinfo.__name__.__len__() == 12
#
# inspect.getframeinfo(frame, context=1) gets information about a frame or
# traceback object, returning a Traceback named tuple with fields filename,
# lineno, function, code_context, and index. 'getframeinfo' is 12 characters
# long. New to extra172.
# ---------------------------------------------------------------------------

table inspect_extra172.getframeinfo_identity:
  description: "inspect.getframeinfo: __name__ 'getframeinfo', __module__ 'inspect', __class__.__name__ 'function', name len 12; wave 301; new to extra172"
  kind: python_call_eq
  category: identity
  id_prefix: inspectgfi172

  columns: [id, function, args, expected, description]
  rows:
    - [getframeinfo_name_eq,
       "getframeinfo.__name__.__eq__",
       ["getframeinfo"],
       true,
       "inspect.getframeinfo.__name__.__eq__('getframeinfo') == True — inspect.getframeinfo is a Python function defined in Lib/inspect.py that returns a Traceback named tuple describing a frame or traceback object; its __name__ attribute is 'getframeinfo'; str.__eq__('getframeinfo') returns True; new to extra172"]
    - [getframeinfo_module_inspect,
       "getframeinfo.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getframeinfo.__module__.__eq__('inspect') == True — inspect.getframeinfo is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra172"]
    - [getframeinfo_class_function,
       "getframeinfo.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.getframeinfo.__class__.__name__.__eq__('function') == True — inspect.getframeinfo is a regular Python function defined with def in Lib/inspect.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra172"]
    - [getframeinfo_name_len_12,
       "getframeinfo.__name__.__len__",
       [],
       12,
       "inspect.getframeinfo.__name__.__len__() == 12 — the string 'getframeinfo' has exactly 12 characters: g-e-t-f-r-a-m-e-i-n-f-o; str.__len__() returns 12; new to extra172"]

# ---------------------------------------------------------------------------
# Table 4: inspect.FrameInfo class identity — __name__, __module__,
# __class__.__name__
#
# Wave 301 theme: inspect.FrameInfo class identity — __name__, __module__,
# and __class__.__name__.
#
# inspect.FrameInfo.__name__ == 'FrameInfo'
# inspect.FrameInfo.__module__ == 'inspect'
# inspect.FrameInfo.__class__.__name__ == 'type'
# inspect.FrameInfo.__name__ != 'Traceback'
#
# inspect.FrameInfo is a NamedTuple subclass (a class) defined in
# Lib/inspect.py representing a record from the call stack. It has fields:
# frame, filename, lineno, function, code_context, index, positions. As a
# class object, its __class__.__name__ is 'type'. New to extra172.
# ---------------------------------------------------------------------------

table inspect_extra172.frameinfo_identity:
  description: "inspect.FrameInfo: __name__ 'FrameInfo', __module__ 'inspect', __class__.__name__ 'type'; wave 301; new to extra172"
  kind: python_call_eq
  category: identity
  id_prefix: inspectfii172

  columns: [id, function, args, expected, description]
  rows:
    - [frameinfo_name_frameinfo,
       "FrameInfo.__name__.__eq__",
       ["FrameInfo"],
       true,
       "inspect.FrameInfo.__name__.__eq__('FrameInfo') == True — inspect.FrameInfo is a NamedTuple subclass defined in Lib/inspect.py representing a call-stack frame record (frame, filename, lineno, function, code_context, index, positions); its __name__ attribute is 'FrameInfo'; str.__eq__('FrameInfo') returns True; new to extra172"]
    - [frameinfo_module_inspect,
       "FrameInfo.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.FrameInfo.__module__.__eq__('inspect') == True — inspect.FrameInfo is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra172"]
    - [frameinfo_class_type,
       "FrameInfo.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.FrameInfo.__class__.__name__.__eq__('type') == True — inspect.FrameInfo is a class object (a NamedTuple subclass); its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra172"]
    - [frameinfo_name_ne_traceback,
       "FrameInfo.__name__.__eq__",
       ["Traceback"],
       false,
       "inspect.FrameInfo.__name__.__eq__('Traceback') == False — FrameInfo.__name__ is 'FrameInfo', not 'Traceback'; inspect.Traceback is a separate NamedTuple for traceback records (filename, lineno, function, code_context, index) while FrameInfo also includes the live frame object and positions; str.__eq__('Traceback') returns False; new to extra172"]

# ---------------------------------------------------------------------------
# Table 5: name length cross-checks — stack, currentframe, getframeinfo, FrameInfo
#
# Wave 301 theme: __name__.__len__() for stack (5), currentframe (12),
# getframeinfo (12), and FrameInfo (9).
#
# inspect.stack.__name__.__len__() == 5
# inspect.currentframe.__name__.__len__() == 12
# inspect.getframeinfo.__name__.__len__() == 12
# inspect.FrameInfo.__name__.__len__() == 9
#
# 'stack' is 5 chars; 'currentframe' and 'getframeinfo' coincidentally share
# the same length (12 chars); 'FrameInfo' is 9 chars. Length ordering:
# stack(5) < FrameInfo(9) < currentframe(12) == getframeinfo(12). New to
# extra172.
# ---------------------------------------------------------------------------

table inspect_extra172.name_lengths:
  description: "inspect: stack name len 5, currentframe len 12, getframeinfo len 12, FrameInfo len 9; wave 301; new to extra172"
  kind: python_call_eq
  category: identity
  id_prefix: inspectnl172

  columns: [id, function, args, expected, description]
  rows:
    - [stack_name_len_5,
       "stack.__name__.__len__",
       [],
       5,
       "inspect.stack.__name__.__len__() == 5 — the string 'stack' has exactly 5 characters: s-t-a-c-k; str.__len__() returns 5; new to extra172"]
    - [currentframe_name_len_12,
       "currentframe.__name__.__len__",
       [],
       12,
       "inspect.currentframe.__name__.__len__() == 12 — the string 'currentframe' has exactly 12 characters: c-u-r-r-e-n-t-f-r-a-m-e; str.__len__() returns 12; new to extra172"]
    - [getframeinfo_name_len_12,
       "getframeinfo.__name__.__len__",
       [],
       12,
       "inspect.getframeinfo.__name__.__len__() == 12 — the string 'getframeinfo' has exactly 12 characters: g-e-t-f-r-a-m-e-i-n-f-o; coincidentally the same length as 'currentframe'; str.__len__() returns 12; new to extra172"]
    - [frameinfo_name_len_9,
       "FrameInfo.__name__.__len__",
       [],
       9,
       "inspect.FrameInfo.__name__.__len__() == 9 — the string 'FrameInfo' has exactly 9 characters: F-r-a-m-e-I-n-f-o; str.__len__() returns 9; new to extra172"]

