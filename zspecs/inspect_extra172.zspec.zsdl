# Standalone invariants — extra172
# ---------------------------------------------------------------------------

invariant inspect_extra172.stack_name_eq:
  description: "inspect.stack.__name__ == 'stack' — Python function returning the caller's full call stack as a list of FrameInfo tuples; wave 301; new to extra172"
  kind: python_call_eq
  function: stack.__name__.__eq__
  args: ["stack"]
  expected: true

invariant inspect_extra172.stack_module_inspect:
  description: "inspect.stack.__module__ == 'inspect' — stack is defined in Lib/inspect.py; wave 301; new to extra172"
  kind: python_call_eq
  function: stack.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra172.currentframe_name_eq:
