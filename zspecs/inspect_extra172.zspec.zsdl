  kind: python_call_eq
  function: currentframe.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra172.getframeinfo_name_eq:
  description: "inspect.getframeinfo.__name__ == 'getframeinfo' — Python function returning a Traceback named tuple for a frame object; wave 301; new to extra172"
  kind: python_call_eq
  function: getframeinfo.__name__.__eq__
  args: ["getframeinfo"]
  expected: true

invariant inspect_extra172.getframeinfo_module_inspect:
  description: "inspect.getframeinfo.__module__ == 'inspect' — getframeinfo is defined in Lib/inspect.py; wave 301; new to extra172"
  kind: python_call_eq
  function: getframeinfo.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra172.frameinfo_name_eq:
  description: "inspect.FrameInfo.__name__ == 'FrameInfo' — NamedTuple subclass representing a call-stack frame record with frame, filename, lineno, function, code_context, index, positions fields; wave 301; new to extra172"
  kind: python_call_eq
  function: FrameInfo.__name__.__eq__
  args: ["FrameInfo"]
  expected: true

invariant inspect_extra172.frameinfo_module_inspect:
  description: "inspect.FrameInfo.__module__ == 'inspect' — FrameInfo is defined in Lib/inspect.py; wave 301; new to extra172"
  kind: python_call_eq
  function: FrameInfo.__module__.__eq__
