spec: abc_extra224
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "abc.ABCMeta.__instancecheck__.__name__ == '__instancecheck__' — method name; qualname is 'ABCMeta.__instancecheck__'; verified with Python 3.14.3."
    - "abc.ABCMeta.__subclasscheck__.__name__ == '__subclasscheck__' — method name; qualname is 'ABCMeta.__subclasscheck__'; verified with Python 3.14.3."
    - "abc.get_cache_token.__name__ == 'get_cache_token' — function name; module is '_abc' (C accelerator); verified with Python 3.14.3."
    - "abc.get_cache_token.__module__ == '_abc' — get_cache_token is implemented in the C accelerator module; verified with Python 3.14.3."
    - "abc.get_cache_token.__qualname__ == 'get_cache_token' — simple top-level function; verified with Python 3.14.3."
    - "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' — nested method qualname; verified with Python 3.14.3."
    - "abc.ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' — nested method qualname; verified with Python 3.14.3."
    - "abc.ABCMeta.__name__ == 'ABCMeta' — 7 characters; module is 'abc'; verified with Python 3.14.3."
    - "abc.abstractmethod.__name__ == 'abstractmethod' — decorator function name; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc module function identity contracts — extra224 namespace
#
# abc.get_cache_token is implemented in C (_abc); its name, module, qualname
# must remain stable across Python versions.
# ---------------------------------------------------------------------------

table abc_extra224.get_cache_token_identity:
  description: "abc.get_cache_token __name__, __module__, and __qualname__ contracts in abc224gct namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc224gct

  columns: [id, function, args, expected, description]
  rows:
    - [gct_name_eq,     get_cache_token.__name__.__eq__,     ["get_cache_token"], true, "abc.get_cache_token.__name__ == 'get_cache_token'; verified with Python 3.14.3"]
    - [gct_module_eq,   get_cache_token.__module__.__eq__,   ["_abc"],            true, "abc.get_cache_token.__module__ == '_abc' — C accelerator module; verified with Python 3.14.3"]
    - [gct_qualname_eq, get_cache_token.__qualname__.__eq__, ["get_cache_token"], true, "abc.get_cache_token.__qualname__ == 'get_cache_token'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta.__instancecheck__ and __subclasscheck__ identity — extra224 namespace
#
# Both are methods on ABCMeta; qualnames are nested 'ABCMeta.__instancecheck__'
# and 'ABCMeta.__subclasscheck__'.
# ---------------------------------------------------------------------------

table abc_extra224.abcmeta_check_identity:
  description: "abc.ABCMeta.__instancecheck__ and __subclasscheck__ name/qualname contracts in abc224mc namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc224mc

  columns: [id, function, args, expected, description]
  rows:
    - [instancecheck_name_eq,     ABCMeta.__instancecheck__.__name__.__eq__,     ["__instancecheck__"],          true, "abc.ABCMeta.__instancecheck__.__name__ == '__instancecheck__'; verified with Python 3.14.3"]
    - [instancecheck_qualname_eq, ABCMeta.__instancecheck__.__qualname__.__eq__, ["ABCMeta.__instancecheck__"],  true, "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__'; verified with Python 3.14.3"]
    - [subclasscheck_name_eq,     ABCMeta.__subclasscheck__.__name__.__eq__,     ["__subclasscheck__"],          true, "abc.ABCMeta.__subclasscheck__.__name__ == '__subclasscheck__'; verified with Python 3.14.3"]
    - [subclasscheck_qualname_eq, ABCMeta.__subclasscheck__.__qualname__.__eq__, ["ABCMeta.__subclasscheck__"],  true, "abc.ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta and abc.abstractmethod class name contracts — extra224 namespace
#
# ABCMeta.__name__ == 'ABCMeta'; abstractmethod.__name__ == 'abstractmethod'.
# ---------------------------------------------------------------------------

table abc_extra224.abcmeta_abstractmethod_names:
  description: "abc.ABCMeta and abc.abstractmethod __name__ and __module__ contracts in abc224amn namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc224amn

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_name_eq,         ABCMeta.__name__.__eq__,          ["ABCMeta"],        true, "abc.ABCMeta.__name__ == 'ABCMeta'; verified with Python 3.14.3"]
    - [abcmeta_name_len_7,      ABCMeta.__name__.__len__,         [],                 7,    "abc.ABCMeta.__name__.__len__() == 7 — 'ABCMeta' has 7 characters; verified with Python 3.14.3"]
    - [abcmeta_module_eq,       ABCMeta.__module__.__eq__,        ["abc"],            true, "abc.ABCMeta.__module__ == 'abc'; verified with Python 3.14.3"]
    - [abstractmethod_name_eq,  abstractmethod.__name__.__eq__,   ["abstractmethod"], true, "abc.abstractmethod.__name__ == 'abstractmethod'; verified with Python 3.14.3"]
    - [abstractmethod_module_eq, abstractmethod.__module__.__eq__, ["abc"],           true, "abc.abstractmethod.__module__ == 'abc'; verified with Python 3.14.3"]
