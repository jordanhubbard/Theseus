  category: bitwise_ops
  id_prefix: dc1546cx
  columns: [id, function, args, expected, description]
  rows:
    - [dc1546cx001,
       decimal.Context.__dict__.__contains__,
       ["__and__"],
       false,
       "decimal.Context.__dict__.__contains__('__and__') == False — decimal.Context is the arithmetic context object for decimal operations; it holds configuration (precision, rounding, traps) and dispatches arithmetic operations; __and__ is absent; verified with Python 3.14.3"]
