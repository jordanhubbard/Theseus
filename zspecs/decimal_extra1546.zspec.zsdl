       ["__rxor__"],
       false,
       "decimal.Context.__dict__.__contains__('__rxor__') == False — decimal.Context does not define __rxor__ in its own __dict__; verified with Python 3.14.3"]
    - [dc1546cx010,
       decimal.Context.__dict__.__contains__,
       ["prec"],
       true,
       "decimal.Context.__dict__.__contains__('prec') == True — positive anchor: decimal.Context defines 'prec' as a descriptor in its own __dict__; prec controls the number of significant digits in Decimal arithmetic operations; Context's __dict__ contains configuration descriptors and arithmetic dispatch methods but no bitwise operators; verified with Python 3.14.3"]
    - [dc1546cx011,
       decimal.Context.__dict__.__contains__,
       ["rounding"],
       true,
       "decimal.Context.__dict__.__contains__('rounding') == True — positive anchor: decimal.Context defines 'rounding' as a descriptor in its own __dict__; rounding specifies the rounding mode (ROUND_HALF_UP, ROUND_HALF_EVEN, etc.); no bitwise operators present alongside configuration descriptors; verified with Python 3.14.3"]
    - [dc1546cx012,
       decimal.Context.__dict__.__contains__,
       ["sqrt"],
       true,
       "decimal.Context.__dict__.__contains__('sqrt') == True — positive anchor: decimal.Context defines 'sqrt' in its own __dict__; Context.sqrt(x) computes the square root of x under the context's precision and rounding settings; Context has arithmetic dispatch methods but no bitwise operators; verified with Python 3.14.3"]

