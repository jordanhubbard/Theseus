spec: decimal_extra1546
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module Decimal, Context, DecimalException, InvalidOperation documentation"
    - "IBM General Decimal Arithmetic Specification, Version 1.72 — bitwise operation semantics"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra1531.zspec.zsdl — covers comparison operator __dict__ presence checks (wave 549)"
    - "decimal_extra1516.zspec.zsdl — covers arithmetic/numeric operator presence (wave 548)"
    - "decimal_extra1501.zspec.zsdl — covers wave 547 decimal checks"
  notes:
    - "Wave 550 (_extra1546): bitwise operator __dict__ presence checks for decimal module classes."
    - "decimal.Decimal does NOT define any bitwise operators (__and__, __or__, __xor__, __invert__, __lshift__, __rshift__, __rand__, __ror__, __rxor__) in its own __dict__. The IBM General Decimal Arithmetic Specification does define integer-mode and/or/xor operations, but CPython's decimal.Decimal does NOT expose these as Python operator dunder methods."
    - "decimal.Context does NOT define any bitwise operators. Context objects are arithmetic configuration objects, not numeric values."
    - "decimal.DecimalException and decimal.InvalidOperation define no bitwise operators. They are exception classes with minimal __dict__ contents."
    - "For reference: decimal.Decimal DOES define arithmetic operators (__add__, __sub__, __mul__, __truediv__, __neg__, __abs__, etc.) and comparison operators (__lt__, __le__, __gt__, __ge__, __ne__, __eq__, __hash__) — but zero bitwise operators."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra1546.decimal_bitwise_ops_absent:
  description: "decimal.Decimal bitwise operator absence — all bitwise operators absent from decimal.Decimal.__dict__; Decimal defines arithmetic and comparison operators but no bitwise operators; the IBM GDA spec defines integer and/or/xor but CPython does not expose these as Python dunder methods; wave 550"
  kind: python_call_eq
  category: bitwise_ops
  id_prefix: dc1546dc
  columns: [id, function, args, expected, description]
  rows:
    - [dc1546dc001,
       decimal.Decimal.__dict__.__contains__,
       ["__and__"],
       false,
       "decimal.Decimal.__dict__.__contains__('__and__') == False — decimal.Decimal does not define __and__ (bitwise AND) in its own __dict__; the IBM General Decimal Arithmetic Specification defines integer-mode and/or/xor operations on coefficient digits, but CPython's decimal.Decimal does NOT expose these as Python operator dunder methods; __and__ is absent; verified with Python 3.14.3"]
    - [dc1546dc002,
       decimal.Decimal.__dict__.__contains__,
       ["__or__"],
       false,
       "decimal.Decimal.__dict__.__contains__('__or__') == False — decimal.Decimal does not define __or__ in its own __dict__; Python's | operator on Decimal would raise TypeError; verified with Python 3.14.3"]
    - [dc1546dc003,
       decimal.Decimal.__dict__.__contains__,
       ["__xor__"],
       false,
       "decimal.Decimal.__dict__.__contains__('__xor__') == False — decimal.Decimal does not define __xor__ in its own __dict__; Python's ^ operator on Decimal would raise TypeError; verified with Python 3.14.3"]
    - [dc1546dc004,
       decimal.Decimal.__dict__.__contains__,
       ["__invert__"],
       false,
       "decimal.Decimal.__dict__.__contains__('__invert__') == False — decimal.Decimal does not define __invert__ (unary bitwise NOT, ~) in its own __dict__; ~Decimal('1') would raise TypeError; verified with Python 3.14.3"]
    - [dc1546dc005,
       decimal.Decimal.__dict__.__contains__,
       ["__lshift__"],
       false,
       "decimal.Decimal.__dict__.__contains__('__lshift__') == False — decimal.Decimal does not define __lshift__ (left bitshift <<) in its own __dict__; verified with Python 3.14.3"]
    - [dc1546dc006,
       decimal.Decimal.__dict__.__contains__,
       ["__rshift__"],
       false,
       "decimal.Decimal.__dict__.__contains__('__rshift__') == False — decimal.Decimal does not define __rshift__ (right bitshift >>) in its own __dict__; verified with Python 3.14.3"]
    - [dc1546dc007,
       decimal.Decimal.__dict__.__contains__,
       ["__rand__"],
       false,
       "decimal.Decimal.__dict__.__contains__('__rand__') == False — decimal.Decimal does not define __rand__ (reflected bitwise AND) in its own __dict__; verified with Python 3.14.3"]
    - [dc1546dc008,
       decimal.Decimal.__dict__.__contains__,
       ["__ror__"],
       false,
       "decimal.Decimal.__dict__.__contains__('__ror__') == False — decimal.Decimal does not define __ror__ (reflected bitwise OR) in its own __dict__; verified with Python 3.14.3"]
    - [dc1546dc009,
       decimal.Decimal.__dict__.__contains__,
       ["__rxor__"],
       false,
       "decimal.Decimal.__dict__.__contains__('__rxor__') == False — decimal.Decimal does not define __rxor__ (reflected bitwise XOR) in its own __dict__; zero of the nine bitwise operator dunders are present in Decimal.__dict__; verified with Python 3.14.3"]
    - [dc1546dc010,
       decimal.Decimal.__dict__.__contains__,
       ["__add__"],
       true,
       "decimal.Decimal.__dict__.__contains__('__add__') == True — positive anchor: decimal.Decimal defines __add__ in its own __dict__; Decimal + Decimal implements IEEE 754 addition; this confirms Decimal has a rich operator __dict__ (arithmetic and comparison operators are present) while bitwise operators are entirely absent; verified with Python 3.14.3"]
    - [dc1546dc011,
       decimal.Decimal.__dict__.__contains__,
       ["__mul__"],
       true,
       "decimal.Decimal.__dict__.__contains__('__mul__') == True — positive anchor: decimal.Decimal defines __mul__ in its own __dict__; Decimal multiplication is defined; confirms Decimal has arithmetic operators but no bitwise operators; verified with Python 3.14.3"]
    - [dc1546dc012,
       decimal.Decimal.__dict__.__contains__,
       ["is_nan"],
       true,
       "decimal.Decimal.__dict__.__contains__('is_nan') == True — positive anchor: decimal.Decimal defines 'is_nan' in its own __dict__; is_nan() returns True if the operand is a (quiet or signaling) NaN; Decimal has a rich __dict__ with arithmetic, comparison, and predicate methods — but zero bitwise operators; verified with Python 3.14.3"]

table decimal_extra1546.context_bitwise_ops_absent:
  description: "decimal.Context bitwise operator absence — all bitwise operators absent from decimal.Context.__dict__; Context is an arithmetic configuration object specifying precision, rounding mode, and trap enablers; it defines arithmetic dispatch methods (add, subtract, multiply, divide, sqrt) and configuration descriptors (prec, rounding) but no bitwise operators; wave 550"
