spec: struct_extra2236
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "Theme: __slots__ and slot descriptor protocol — checking __slots__, __weakref__, __dict__, __abstractmethods__, __init__, __new__ presence in class __dict__."
    - "struct.Struct is a C extension type from the _struct module."
    - "C extension types do not define __slots__ at the Python level; __slots__ absent from Struct.__dict__."
    - "C extension types do not expose __weakref__ descriptor in __dict__ (GC handled at C level)."
    - "struct.Struct defines both __init__ and __new__ in its __dict__ (C tp_init and tp_new are exposed)."
    - "struct.error is a pure-Python exception class inheriting from Exception."
    - "struct.error defines __weakref__ in its __dict__ (exception classes get a weakref slot by default)."
    - "struct.error does NOT define __slots__, __dict__, __abstractmethods__, __init__, or __new__ in its own __dict__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

table struct_extra2236.Struct_slots:
  description: "struct.Struct C extension type — __slots__ descriptor protocol membership"
  kind: python_call_eq
  category: slots_protocol
  id_prefix: st2236
  columns: [id, function, args, expected]
  rows:
    - ["st2236001", struct.Struct.__dict__.__contains__, ["__slots__"], false]
    - ["st2236002", struct.Struct.__dict__.__contains__, ["__weakref__"], false]
    - ["st2236003", struct.Struct.__dict__.__contains__, ["__dict__"], false]
    - ["st2236004", struct.Struct.__dict__.__contains__, ["__abstractmethods__"], false]
    - ["st2236005", struct.Struct.__dict__.__contains__, ["__init__"], true]
    - ["st2236006", struct.Struct.__dict__.__contains__, ["__new__"], true]
    - ["st2236007", struct.Struct.__dict__.__contains__, ["__subclasshook__"], false]

table struct_extra2236.error_slots:
  description: "struct.error exception class — __slots__ descriptor protocol membership"
  kind: python_call_eq
  category: slots_protocol
  id_prefix: st2236
  columns: [id, function, args, expected]
  rows:
    - ["st2236008", struct.error.__dict__.__contains__, ["__slots__"], false]
    - ["st2236009", struct.error.__dict__.__contains__, ["__weakref__"], true]
    - ["st2236010", struct.error.__dict__.__contains__, ["__dict__"], false]
    - ["st2236011", struct.error.__dict__.__contains__, ["__abstractmethods__"], false]
    - ["st2236012", struct.error.__dict__.__contains__, ["__init__"], false]
    - ["st2236013", struct.error.__dict__.__contains__, ["__new__"], false]
    - ["st2236014", struct.error.__dict__.__contains__, ["__subclasshook__"], false]

table struct_extra2236.Struct_classname:
  description: "struct.Struct class identity attributes"
  kind: python_call_eq
  category: classnames
  id_prefix: st2236
  columns: [id, function, args, expected]
  rows:
    - ["st2236015", struct.Struct.__name__.__eq__, ["Struct"], true]
    - ["st2236016", struct.Struct.__module__.__eq__, ["_struct"], true]
    - ["st2236017", struct.Struct.__class__.__name__.__eq__, ["type"], true]
    - ["st2236018", struct.Struct.__qualname__.__eq__, ["Struct"], true]
    - ["st2236019", struct.Struct.__dict__.__contains__, ["__doc__"], true]

table struct_extra2236.error_classname:
  description: "struct.error exception class identity attributes"
  kind: python_call_eq
  category: classnames
  id_prefix: st2236
  columns: [id, function, args, expected]
  rows:
    - ["st2236020", struct.error.__name__.__eq__, ["error"], true]
    - ["st2236021", struct.error.__module__.__eq__, ["struct"], true]
    - ["st2236022", struct.error.__qualname__.__eq__, ["error"], true]
    - ["st2236023", struct.error.__bases__.__len__, [], 1]
    - ["st2236024", struct.error.__dict__.__contains__, ["__doc__"], true]
    - ["st2236025", struct.error.__class__.__name__.__eq__, ["type"], true]
