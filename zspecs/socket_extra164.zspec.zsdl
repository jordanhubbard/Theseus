table socket_extra164.socket_dict_sendfile_dup_inheritable:
  description: "socket.socket.__dict__.__contains__('sendfile')==True / __dict__.__contains__('dup')==True / __dict__.__contains__('get_inheritable')==True / __dict__.__contains__('set_inheritable')==True — __dict__.__contains__('sendfile') is True ('sendfile' is a Python function defined in Lib/socket.py; efficiently sends a file over the socket using OS sendfile syscall where available; falls back to send-based implementation; _sendfile_use_sendfile and _sendfile_use_send are the two private implementation variants); __dict__.__contains__('dup') is True ('dup' is a Python function defined in Lib/socket.py; duplicates the socket; returns a new socket object with a duplicated file descriptor; defined in Python to ensure the new socket has proper Python socket wrapper state); __dict__.__contains__('get_inheritable') is True ('get_inheritable' is a Python method that returns whether the socket file descriptor is inheritable by child processes; wraps the C-level get_inheritable function); __dict__.__contains__('set_inheritable') is True ('set_inheritable' is a Python method that sets whether the socket fd is inheritable; wraps C-level set_inheritable; paired with get_inheritable); all four are Python-defined in Lib/socket.py (not from C base type); first sockdict164 anchor for sendfile/dup/inheritable membership"
  kind: python_call_eq
  category: identity
  id_prefix: sockdict164

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_sendfile,         "socket.__dict__.__contains__", ["sendfile"],         true, "socket.socket.__dict__.__contains__('sendfile') == True ('sendfile' is Python-defined in Lib/socket.py; uses OS sendfile syscall where available)"]
    - [dict_has_dup,              "socket.__dict__.__contains__", ["dup"],              true, "socket.socket.__dict__.__contains__('dup') == True ('dup' is Python-defined in Lib/socket.py; duplicates socket with new fd; preserves Python wrapper state)"]
    - [dict_has_get_inheritable,  "socket.__dict__.__contains__", ["get_inheritable"],  true, "socket.socket.__dict__.__contains__('get_inheritable') == True ('get_inheritable' is Python-defined; returns whether socket fd is inheritable by child processes)"]
    - [dict_has_set_inheritable,  "socket.__dict__.__contains__", ["set_inheritable"],  true, "socket.socket.__dict__.__contains__('set_inheritable') == True ('set_inheritable' is Python-defined; sets whether socket fd is inheritable; paired with get_inheritable)"]

