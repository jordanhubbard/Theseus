spec: socket_extra164
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra163.zspec.zsdl — covers socket.__spec__.origin.__class__.__name__=='str' / origin.__contains__('socket') / submodule_search_locations NoneType / __spec__.__class__.__name__=='ModuleSpec' / spec attribute lengths (table + invariants)."
    - "socket_extra162.zspec.zsdl — covers socket.socket.__repr__/__str__/__enter__/__exit__ qualname strings and lengths / function vs wrapper_descriptor types (table + invariants)."
    - "socket_extra161.zspec.zsdl — covers socket.socket.send/__recv/__sendto/__recvfrom qualname strings and lengths / all four are method_descriptor (table + invariants)."
    - "socket_extra160.zspec.zsdl — covers socket.socket.bind/__listen/__accept/__close qualname strings and lengths (table + invariants)."
    - "socket_extra159.zspec.zsdl — covers socket.socket.__name__ / socket.__module__ / socket.__bases__[0].__name__ / socket.__init__.__qualname__ / socket.connect.__qualname__ (table + invariants)."
    - "socket_extra156.zspec.zsdl — covers socket.__spec__.__class__.__name__=='ModuleSpec' / socket.socket method qualnames (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra93 through socket_extra163."
    - "Wave 346 theme: socket.socket.__dict__ key membership checks via __dict__.__contains__ — 'accept', 'close', 'detach', 'makefile', 'sendfile', 'dup'. Note: 'connect', 'bind', 'listen', 'send', 'recv' are NOT in socket.socket.__dict__ — they are inherited from the underlying C socket type (socketmodule.c) and appear in the MRO but not in socket.socket.__dict__ directly. socket.socket is a Python class (Lib/socket.py) that wraps the C socket type; its __dict__ contains only the Python-level methods defined in socket.socket itself."
    - "socket.socket.__dict__.__len__() == 28. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__class__.__name__ == 'mappingproxy'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('accept') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('close') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('detach') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('makefile') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('sendfile') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('dup') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('get_inheritable') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('set_inheritable') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.socket is a Python class defined in Lib/socket.py that wraps the C-level socket type (_socket.socket). The __dict__ of socket.socket contains only the methods and attributes defined in the Python class body itself. Methods like 'connect', 'bind', 'listen', 'send', and 'recv' are provided by the underlying C type (_socket.socket) and appear in socket.socket instances via MRO lookup, but they are NOT in socket.socket.__dict__. The 28 entries in socket.socket.__dict__ are the Python-level methods and slots added by socket.py: accept, close, detach, dup, family, get_inheritable, makefile, sendfile, set_inheritable, type, and various dunders and private methods."
    - "Note: socket.socket.__dict__.__len__() == 28. The 28 entries include: Python-defined methods (accept/close/detach/dup/makefile/sendfile/get_inheritable/set_inheritable = 8 public methods), properties (family/type = 2), dunder methods (__init__/__repr__/__enter__/__exit__/__getstate__/__slots__/__weakref__/__doc__/__module__/__firstlineno__/__static_attributes__ = 11 dunders/infra), and private methods (_closed/_io_refs/_decref_socketios/_real_close/_check_sendfile_params/_sendfile_use_send/_sendfile_use_sendfile = 7 private). 8+2+11+7 = 28."
    - "Note: socket.socket.__dict__.__class__.__name__ == 'mappingproxy' (12 chars). All Python class __dict__ objects are mappingproxy instances. socket.socket is defined as a regular Python class in Lib/socket.py."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('accept')
# socket.socket.__dict__.__contains__('close')
# socket.socket.__dict__.__contains__('detach')
# socket.socket.__dict__.__contains__('makefile')
#
# Wave 346 theme: socket.socket.__dict__ Python-defined method membership.
#
# socket.__dict__.__contains__('accept') == True (Python-defined in Lib/socket.py).
# socket.__dict__.__contains__('close') == True (Python-defined in Lib/socket.py).
# socket.__dict__.__contains__('detach') == True (Python-defined in Lib/socket.py).
# socket.__dict__.__contains__('makefile') == True (Python-defined in Lib/socket.py).
# Note: 'connect'/'bind'/'listen'/'send'/'recv' are NOT in socket.socket.__dict__
# (they are from the C base type _socket.socket, not from the Python wrapper class).
# No prior socket spec anchors these as a table under sockdict164.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra164.socket_dict_accept_close_detach_makefile:
  description: "socket.socket.__dict__.__contains__('accept')==True / __dict__.__contains__('close')==True / __dict__.__contains__('detach')==True / __dict__.__contains__('makefile')==True — __dict__.__contains__('accept') is True ('accept' is a Python function defined in Lib/socket.py; returns (conn, address) pair from incoming connection; accepts one connection and returns a new socket; defined in Python to support the socket context and io_refs logic; socket_extra160 anchors accept qualname 'socket.accept' as a row); __dict__.__contains__('close') is True ('close' is a Python function defined in Lib/socket.py; closes the socket file descriptor; handles _io_refs reference counting and _real_close logic; socket_extra160 anchors close as a row); __dict__.__contains__('detach') is True ('detach' is a Python function defined in Lib/socket.py; detaches the file descriptor from the socket object and returns it; fd remains open after detach); __dict__.__contains__('makefile') is True ('makefile' is a Python function defined in Lib/socket.py; returns a file object associated with the socket; used for socket-based file I/O); note: 'connect'/'bind'/'listen'/'send'/'recv' are NOT in socket.socket.__dict__ (they come from the C base type _socket.socket and are inherited via MRO, not defined in the Python socket.socket class); first sockdict164 anchor for these four method memberships"
  kind: python_call_eq
  category: identity
  id_prefix: sockdict164

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_accept,   "socket.__dict__.__contains__", ["accept"],   true, "socket.socket.__dict__.__contains__('accept') == True ('accept' is Python-defined in Lib/socket.py; returns (conn, address); handles io_refs; socket_extra160 anchors qualname)"]
    - [dict_has_close,    "socket.__dict__.__contains__", ["close"],    true, "socket.socket.__dict__.__contains__('close') == True ('close' is Python-defined in Lib/socket.py; handles _io_refs and _real_close logic; socket_extra160 anchors qualname)"]
    - [dict_has_detach,   "socket.__dict__.__contains__", ["detach"],   true, "socket.socket.__dict__.__contains__('detach') == True ('detach' is Python-defined in Lib/socket.py; detaches fd from socket object; fd remains open)"]
    - [dict_has_makefile, "socket.__dict__.__contains__", ["makefile"], true, "socket.socket.__dict__.__contains__('makefile') == True ('makefile' is Python-defined in Lib/socket.py; returns file object associated with socket for file-mode I/O)"]

