# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('accept') — standalone
#
# socket.socket.__dict__.__contains__('accept') is True. 'accept' is a Python function
# defined in Lib/socket.py. It wraps the underlying C-level accept() with Python-specific
# logic: it calls self._real_accept() (from the C base type) and then wraps the returned
# file descriptor in a new socket.socket() Python object. 'accept' is in socket.socket.__dict__
# because it is defined in the Python class body (not in the C base type _socket.socket).
# socket_extra160 anchors 'socket.accept' qualname as a table row.
# Note: 'bind', 'listen', 'connect', 'send', 'recv' are NOT in socket.socket.__dict__
# because they are provided by the C base type _socket.socket, not by the Python class.
# No prior socket spec anchors this as a standalone under sockdict164.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra164.socket_dict_contains_accept:
  description: "socket.socket.__dict__.__contains__('accept') == True — 'accept' is Python-defined in Lib/socket.py (not from C base type _socket.socket); wraps C-level accept with Python socket wrapper creation; defined in socket.socket class body; socket_extra160 anchors 'socket.accept' qualname as table row; 'bind'/'listen'/'connect'/'send'/'recv' are NOT in socket.socket.__dict__ (they are from C base type); socket.socket.__dict__.__len__()==28; socket.socket.__dict__.__class__.__name__=='mappingproxy'; first sockdict164 standalone for __contains__('accept')"
  category: identity
  kind: python_call_eq
  function: socket.__dict__.__contains__
  args: ["accept"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('close') — standalone
#
# socket.socket.__dict__.__contains__('close') is True. 'close' is a Python function
# defined in Lib/socket.py. It manages reference counting via self._io_refs and calls
# self._real_close() (from the C base type) when the ref count reaches zero. 'close'
# is in socket.socket.__dict__ because the Python class provides enhanced close logic
# (tracking of io references created via makefile()) rather than using the C-level close
# directly. socket_extra160 anchors 'socket.close' qualname as a table row.
# No prior socket spec anchors this as a standalone under sockdict164.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra164.socket_dict_contains_close:
  description: "socket.socket.__dict__.__contains__('close') == True — 'close' is Python-defined in Lib/socket.py; manages _io_refs reference counting (for makefile() file objects sharing the socket fd); calls _real_close() when ref count reaches zero; defined in socket.socket class body for enhanced Python-level close semantics; socket_extra160 anchors 'socket.close' qualname as table row; socket.socket.__dict__.__len__()==28; first sockdict164 standalone for __contains__('close')"
  category: identity
  kind: python_call_eq
  function: socket.__dict__.__contains__
  args: ["close"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__len__() == 28 — standalone
#
# socket.socket.__dict__.__len__() is 28. The socket.socket class dict has 28 entries:
# 8 public Python methods: accept, close, detach, dup, makefile, sendfile,
#   get_inheritable, set_inheritable
# 2 properties: family, type
# 11 dunders/infrastructure: __init__, __repr__, __enter__, __exit__, __getstate__,
#   __slots__, __weakref__, __doc__, __module__, __firstlineno__, __static_attributes__
# 7 private methods: _closed, _io_refs, _decref_socketios, _real_close,
#   _check_sendfile_params, _sendfile_use_send, _sendfile_use_sendfile
# Total: 8 + 2 + 11 + 7 = 28.
# This is larger than struct.Struct.__dict__.__len__()==16 (C type, fewer Python additions)
# but smaller than uuid.UUID.__dict__.__len__()==37 (pure Python class with many properties).
# No prior socket spec anchors socket.socket.__dict__.__len__() as a standalone under
# sockdict164. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra164.socket_dict_len_28:
  description: "socket.socket.__dict__.__len__() == 28 — 28 entries: 8 public methods (accept/close/detach/dup/makefile/sendfile/get_inheritable/set_inheritable) + 2 properties (family/type) + 11 dunders/infra (__init__/__repr__/__enter__/__exit__/__getstate__/__slots__/__weakref__/__doc__/__module__/__firstlineno__/__static_attributes__) + 7 private (_closed/_io_refs/_decref_socketios/_real_close/_check_sendfile_params/_sendfile_use_send/_sendfile_use_sendfile); 8+2+11+7=28; larger than struct.Struct.__dict__.__len__()==16 (C type) but smaller than uuid.UUID.__dict__.__len__()==37 (pure Python class); socket.socket is a Python class wrapping the C socket type; first sockdict164 standalone for __len__()==28"
  category: identity
  kind: python_call_eq
  function: socket.__dict__.__len__
  args: []
  expected: 28

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('makefile') — standalone
#
# socket.socket.__dict__.__contains__('makefile') is True. 'makefile' is a Python function
# defined in Lib/socket.py. It returns a file object (SocketIO) associated with the socket,
# providing a file-like interface for reading and writing socket data. The mode parameter
# controls whether the file object is read-only ('r'), write-only ('w'), or read-write
# ('rw'). 'makefile' is in socket.socket.__dict__ because it is a complex Python-level
# wrapper that manages _io_refs reference counting (each makefile() call increments
# self._io_refs, and closing the file object decrements it). 'makefile' is the
# Python-specific enhancement over the C-level socket that enables buffered file I/O.
# No prior socket spec anchors this as a standalone under sockdict164.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra164.socket_dict_contains_makefile:
  description: "socket.socket.__dict__.__contains__('makefile') == True — 'makefile' is Python-defined in Lib/socket.py; returns a SocketIO file object for buffered file-mode socket I/O; mode parameter controls read/write/readwrite behavior; manages _io_refs reference counting (increment on makefile() call, decrement on file object close; socket.close() waits until _io_refs reaches 0 via _decref_socketios); 'makefile' is a Python-specific enhancement over C socket; socket.socket.__dict__.__len__()==28; first sockdict164 standalone for __contains__('makefile')"
  category: identity
  kind: python_call_eq
  function: socket.__dict__.__contains__
  args: ["makefile"]
  expected: true

