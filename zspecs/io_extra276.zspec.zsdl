spec: io_extra276
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/io.py"
  notes:
    - "io.TextIOWrapper is a C-extension class; its methods are method_descriptor objects."
    - "TextIOWrapper.read, readline, write, flush, seek, tell, detach all have __class__.__name__ == 'method_descriptor'."
    - "TextIOWrapper.reconfigure is also a method_descriptor (added in Python 3.7)."
    - "TextIOWrapper.encoding is a member_descriptor (C-level slot attribute)."
    - "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' (C-extension internal base class)."
    - "io.TextIOWrapper.__module__ == '_io' (C extension module, not the public 'io' facade)."
    - "TextIOWrapper method qualnames follow 'TextIOWrapper.<method_name>' pattern."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: TextIOWrapper method __name__ identity
# ---------------------------------------------------------------------------

table io_extra276.textiowrapper_method_names:
  description: "io.TextIOWrapper method __name__ for read, readline, write, flush, seek, tell, reconfigure, detach"
  kind: python_call_eq
  category: identity
  id_prefix: nm

  columns: [id, function, args, expected, description]
  rows:
    - [read_name,        TextIOWrapper.read.__name__.__eq__,        ["read"],        true, "io.TextIOWrapper.read.__name__ == 'read'"]
    - [readline_name,    TextIOWrapper.readline.__name__.__eq__,    ["readline"],    true, "io.TextIOWrapper.readline.__name__ == 'readline'"]
    - [write_name,       TextIOWrapper.write.__name__.__eq__,       ["write"],       true, "io.TextIOWrapper.write.__name__ == 'write'"]
    - [flush_name,       TextIOWrapper.flush.__name__.__eq__,       ["flush"],       true, "io.TextIOWrapper.flush.__name__ == 'flush'"]
    - [seek_name,        TextIOWrapper.seek.__name__.__eq__,        ["seek"],        true, "io.TextIOWrapper.seek.__name__ == 'seek'"]
    - [tell_name,        TextIOWrapper.tell.__name__.__eq__,        ["tell"],        true, "io.TextIOWrapper.tell.__name__ == 'tell'"]
    - [reconfigure_name, TextIOWrapper.reconfigure.__name__.__eq__, ["reconfigure"], true, "io.TextIOWrapper.reconfigure.__name__ == 'reconfigure'"]
    - [detach_name,      TextIOWrapper.detach.__name__.__eq__,      ["detach"],      true, "io.TextIOWrapper.detach.__name__ == 'detach'"]

# ---------------------------------------------------------------------------
# Table: TextIOWrapper method __class__.__name__ (all method_descriptor)
# ---------------------------------------------------------------------------

table io_extra276.textiowrapper_method_classes:
  description: "io.TextIOWrapper method __class__.__name__ for read, readline, write, flush, seek, tell, reconfigure, detach (all method_descriptor)"
  kind: python_call_eq
  category: identity
  id_prefix: cls

  columns: [id, function, args, expected, description]
  rows:
    - [read_class,        TextIOWrapper.read.__class__.__name__.__eq__,        ["method_descriptor"], true, "io.TextIOWrapper.read.__class__.__name__ == 'method_descriptor'"]
    - [readline_class,    TextIOWrapper.readline.__class__.__name__.__eq__,    ["method_descriptor"], true, "io.TextIOWrapper.readline.__class__.__name__ == 'method_descriptor'"]
    - [write_class,       TextIOWrapper.write.__class__.__name__.__eq__,       ["method_descriptor"], true, "io.TextIOWrapper.write.__class__.__name__ == 'method_descriptor'"]
    - [flush_class,       TextIOWrapper.flush.__class__.__name__.__eq__,       ["method_descriptor"], true, "io.TextIOWrapper.flush.__class__.__name__ == 'method_descriptor'"]
    - [seek_class,        TextIOWrapper.seek.__class__.__name__.__eq__,        ["method_descriptor"], true, "io.TextIOWrapper.seek.__class__.__name__ == 'method_descriptor'"]
    - [tell_class,        TextIOWrapper.tell.__class__.__name__.__eq__,        ["method_descriptor"], true, "io.TextIOWrapper.tell.__class__.__name__ == 'method_descriptor'"]
    - [reconfigure_class, TextIOWrapper.reconfigure.__class__.__name__.__eq__, ["method_descriptor"], true, "io.TextIOWrapper.reconfigure.__class__.__name__ == 'method_descriptor'"]
    - [detach_class,      TextIOWrapper.detach.__class__.__name__.__eq__,      ["method_descriptor"], true, "io.TextIOWrapper.detach.__class__.__name__ == 'method_descriptor'"]

# ---------------------------------------------------------------------------
# Standalone invariants: class identity, qualnames, encoding descriptor
# ---------------------------------------------------------------------------

invariant io_extra276.TextIOWrapper.name:
  description: "io.TextIOWrapper.__name__ == 'TextIOWrapper'"
  category: identity
  kind: python_call_eq
  function: TextIOWrapper.__name__.__eq__
  args: ["TextIOWrapper"]
  expected: true

invariant io_extra276.TextIOWrapper.module:
  description: "io.TextIOWrapper.__module__ == '_io' (C extension module)"
  category: identity
  kind: python_call_eq
  function: TextIOWrapper.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra276.TextIOWrapper.base.name:
  description: "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase'"
  category: identity
  kind: python_call_eq
  function: "TextIOWrapper.__bases__[0].__name__.__eq__"
  args: ["_TextIOBase"]
  expected: true

invariant io_extra276.TextIOWrapper.read.qualname:
  description: "io.TextIOWrapper.read.__qualname__ == 'TextIOWrapper.read'"
  category: identity
  kind: python_call_eq
  function: TextIOWrapper.read.__qualname__.__eq__
  args: ["TextIOWrapper.read"]
  expected: true

invariant io_extra276.TextIOWrapper.write.qualname:
  description: "io.TextIOWrapper.write.__qualname__ == 'TextIOWrapper.write'"
  category: identity
  kind: python_call_eq
  function: TextIOWrapper.write.__qualname__.__eq__
  args: ["TextIOWrapper.write"]
  expected: true

invariant io_extra276.TextIOWrapper.readline.qualname:
  description: "io.TextIOWrapper.readline.__qualname__ == 'TextIOWrapper.readline'"
  category: identity
  kind: python_call_eq
  function: TextIOWrapper.readline.__qualname__.__eq__
  args: ["TextIOWrapper.readline"]
  expected: true

invariant io_extra276.TextIOWrapper.reconfigure.qualname:
  description: "io.TextIOWrapper.reconfigure.__qualname__ == 'TextIOWrapper.reconfigure'"
  category: identity
  kind: python_call_eq
  function: TextIOWrapper.reconfigure.__qualname__.__eq__
  args: ["TextIOWrapper.reconfigure"]
  expected: true

invariant io_extra276.TextIOWrapper.encoding.is_member_descriptor:
  description: "io.TextIOWrapper.encoding is a member_descriptor (C-level slot attribute)"
  category: identity
  kind: python_call_eq
  function: TextIOWrapper.encoding.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true
