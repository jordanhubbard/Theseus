spec: pipx_rust
version: ">=3.9"
backend: rust_module(pipx_rust)

docs: https://pipx.pypa.io/

provenance:
  derived_from:
    - "https://pipx.pypa.io/ — pipx tool"
  notes:
    - "pipx installs and runs Python CLI tools in isolated environments."
    - "pipx.commands is importable."
    - "pipx.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant pipx_rust.has_commands:
  description: "pipx.commands is importable"
  category: presence
  kind: python_call_eq
  function: pipx_has_commands
  args: []
  expected: true

invariant pipx_rust.has_main:
  description: "pipx has main entry point"
  category: presence
  kind: python_call_eq
  function: pipx_has_main
  args: []
  expected: true

invariant pipx_rust.version_nonempty:
  description: "pipx.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: pipx_version_nonempty
  args: []
  expected: true

