spec: decimal_extra452
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal.Context defaults, rounding constants, and context function identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Rounding constants are plain strings in the decimal module"
    - "DefaultContext, BasicContext, ExtendedContext are pre-constructed Context instances"
    - "getcontext, setcontext, localcontext are module-level callables"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra452.context_function_names:
  description: "decimal module context management function __name__ identity"
  kind: python_call_eq
  category: function_identity
  id_prefix: DCF

  columns: [id, function, args, expected]
  rows:
    - [DCF001, decimal.getcontext.__name__.__eq__,    ["getcontext"],    true]
    - [DCF002, decimal.setcontext.__name__.__eq__,    ["setcontext"],    true]
    - [DCF003, decimal.localcontext.__name__.__eq__,  ["localcontext"],  true]

table decimal_extra452.predefined_contexts:
  description: "decimal pre-defined context objects are Context instances"
  kind: python_call_eq
  category: class_identity
  id_prefix: DPC

  columns: [id, function, args, expected]
  rows:
    - [DPC001, decimal.DefaultContext.__class__.__name__.__eq__,  ["Context"], true]
    - [DPC002, decimal.BasicContext.__class__.__name__.__eq__,    ["Context"], true]
    - [DPC003, decimal.ExtendedContext.__class__.__name__.__eq__, ["Context"], true]

table decimal_extra452.rounding_constants:
  description: "decimal rounding string constant values"
  kind: python_call_eq
  category: constant_values
  id_prefix: DRC

  columns: [id, function, args, expected]
  rows:
    - [DRC001, decimal.ROUND_UP.__eq__,        ["ROUND_UP"],        true]
    - [DRC002, decimal.ROUND_DOWN.__eq__,      ["ROUND_DOWN"],      true]
    - [DRC003, decimal.ROUND_CEILING.__eq__,   ["ROUND_CEILING"],   true]
    - [DRC004, decimal.ROUND_FLOOR.__eq__,     ["ROUND_FLOOR"],     true]
    - [DRC005, decimal.ROUND_HALF_UP.__eq__,   ["ROUND_HALF_UP"],   true]
    - [DRC006, decimal.ROUND_HALF_DOWN.__eq__, ["ROUND_HALF_DOWN"], true]
    - [DRC007, decimal.ROUND_HALF_EVEN.__eq__, ["ROUND_HALF_EVEN"], true]
