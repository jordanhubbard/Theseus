    - ["io2071012", "io.BytesIO.__dict__.__contains__",  ["__getattribute__"], false]
    - ["io2071013", "io.StringIO.__dict__.__contains__", ["__getattribute__"], false]
    - ["io2071014", "io.FileIO.__dict__.__contains__",   ["__getattribute__"], false]
    - ["io2071015", "io.RawIOBase.__dict__.__contains__", ["__getattribute__"], false]

