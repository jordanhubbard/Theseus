spec: io_extra2071
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/io.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 585 (_extra2071): __pos__/__neg__, __getattribute__, __reduce__/__reduce_ex__, __copy__/__deepcopy__ dict-presence checks."
    - "io.IOBase, io.BytesIO, io.StringIO, io.FileIO, io.RawIOBase are all I/O types; none define numeric sign operators."
    - "None of the io types define __pos__ or __neg__ (unary sign); they are not numeric types."
    - "None of the io types define __getattribute__ in their own __dict__; attribute lookup falls through to object.__getattribute__."
    - "None of the io types define __reduce__ or __reduce_ex__ in their own __dict__; pickling is not customized at the class level."
    - "None of the io types define __copy__ or __deepcopy__ in their own __dict__; copy protocol is not customized."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table io_extra2071.unary_sign_protocol:
  description: "io types __pos__/__neg__ dict-presence checks — all False; io types are not numeric"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2071

  columns: [id, function, args, expected]
  rows:
    - ["io2071001", "io.IOBase.__dict__.__contains__",   ["__pos__"], false]
    - ["io2071002", "io.IOBase.__dict__.__contains__",   ["__neg__"], false]
    - ["io2071003", "io.BytesIO.__dict__.__contains__",  ["__pos__"], false]
    - ["io2071004", "io.BytesIO.__dict__.__contains__",  ["__neg__"], false]
    - ["io2071005", "io.StringIO.__dict__.__contains__", ["__pos__"], false]
    - ["io2071006", "io.StringIO.__dict__.__contains__", ["__neg__"], false]
    - ["io2071007", "io.FileIO.__dict__.__contains__",   ["__pos__"], false]
    - ["io2071008", "io.FileIO.__dict__.__contains__",   ["__neg__"], false]
    - ["io2071009", "io.RawIOBase.__dict__.__contains__", ["__pos__"], false]
    - ["io2071010", "io.RawIOBase.__dict__.__contains__", ["__neg__"], false]

