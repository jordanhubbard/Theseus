spec: struct_extra285
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Interpret bytes as packed binary data"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "struct.pack('>H', -1) raises struct.error: 'H' format requires 0 <= number <= 65535"
    - "struct.pack('>h', 32768) raises struct.error: 'h' format requires -32768 <= number <= 32767"
    - "struct.pack('>B', 256) raises struct.error: 'B' format requires 0 <= number <= 255"
    - "struct.pack('>b', -129) raises struct.error: 'b' format requires -128 <= number <= 127"
    - "struct.unpack('>I', b'abc') raises struct.error: unpack requires a buffer of 4 bytes"
    - "struct.calcsize('9z') raises struct.error: bad char in struct format"
    - "calcsize('>5H') == 10 (5 * 2 bytes each)"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table struct_extra285.pack_error_conditions:
  description: "struct.pack raises struct.error for out-of-range values"
  kind: python_call_raises
  category: errors
  id_prefix: sx285e

  columns: [id, function, args, raises, description]
  rows:
    - [sx285e001, struct.pack, [">H", -1], struct.error, "unsigned short H rejects negative value -1"]
    - [sx285e002, struct.pack, [">h", 32768], struct.error, "signed short h rejects 32768 (max is 32767)"]
    - [sx285e003, struct.pack, [">B", 256], struct.error, "unsigned byte B rejects 256 (max is 255)"]
    - [sx285e004, struct.pack, [">b", -129], struct.error, "signed byte b rejects -129 (min is -128)"]
    - [sx285e005, struct.unpack, [">I", "abc"], struct.error, "unpack requires 4 bytes for >I but buffer is 3"]
    - [sx285e006, struct.calcsize, ["9z"], struct.error, "z is not a valid struct format character"]

table struct_extra285.calcsize_count_formats:
  description: "struct.calcsize returns correct byte counts for formats with count prefixes"
  kind: python_call_eq
  category: correctness
  id_prefix: sx285c

  columns: [id, function, args, expected, description]
  rows:
    - [sx285c001, struct.calcsize, [">4s"], 4, "4-byte string format is 4 bytes"]
    - [sx285c002, struct.calcsize, [">10s"], 10, "10-byte string format is 10 bytes"]
    - [sx285c003, struct.calcsize, [">2I"], 8, "two unsigned ints (2 * 4) = 8 bytes"]
    - [sx285c004, struct.calcsize, [">3b"], 3, "three signed bytes (3 * 1) = 3 bytes"]
    - [sx285c005, struct.calcsize, [">5H"], 10, "five unsigned shorts (5 * 2) = 10 bytes"]

invariant struct_extra285.pack_negative_unsigned_short:
  description: "struct.pack with '>H' and a negative integer raises struct.error"
  category: errors
  kind: python_call_raises
  function: struct.pack
  args: [">H", -1]
  raises: struct.error

invariant struct_extra285.calcsize_4s:
  description: "struct.calcsize('>4s') == 4"
  category: correctness
  kind: python_call_eq
  function: struct.calcsize
  args: [">4s"]
  expected: 4
