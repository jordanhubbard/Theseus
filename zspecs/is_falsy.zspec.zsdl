spec: is_falsy
version: ">=0.0.1"
backend: node(is-falsy)

docs: https://www.npmjs.com/package/is-falsy

provenance:
  derived_from:
    - "is-falsy README — https://www.npmjs.com/package/is-falsy"
    - "Test vectors verified with is-falsy via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-falsy source"
  notes:
    - "is-falsy is an npm package. Install: npm install is-falsy"
    - "Returns true if the value is falsy (0, null, empty string, false)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_falsy.check:
  kind: node_module_call_eq
  function: isFalsy
  category: validation
  id_prefix: isfalsy

  columns: [id, args, expected]
  rows:
    - [zero,      [0],      true]
    - [one,       [1],      false]
    - [empty_str, [""],     true]
