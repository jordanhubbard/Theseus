error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_falsy.check:
  kind: node_module_call_eq
  function: isFalsy
  category: validation
  id_prefix: isfalsy

  columns: [id, args, expected]
  rows:
    - [zero,      [0],      true]
    - [one,       [1],      false]
    - [empty_str, [""],     true]

