spec: abc_extra1501
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Wave 547 theme: async protocol method __dict__ presence checks. The abc module defines no async protocol methods in any of its classes."
    - "abc.ABC does NOT define __await__, __aenter__, __aexit__, __aiter__, or __anext__ in its own __dict__. ABC is a helper class for abstract base class definition only."
    - "abc.ABCMeta does NOT define any async protocol methods in its own __dict__. ABCMeta is a metaclass for abstract base classes — it manages @abstractmethod tracking but has no async protocol."
    - "abc.abstractmethod does NOT define any async protocol methods in its own __dict__. abstractmethod is a decorator function class; it adds __isabstractmethod__=True to the decorated method but provides no async protocol."
    - "The abc module's purpose is to enforce interface contracts (via @abstractmethod) at class instantiation time. It is entirely synchronous and orthogonal to the async protocol."
    - "Importantly, abc does NOT define abstract async method versions in a way that would add __await__, __aenter__, etc. to its own classes. The abc module can be used to define abstract async methods (via @abstractmethod on async def), but abc.ABC itself has none."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc.ABC has no async protocol in __dict__
#
# abc.ABC.__dict__.__contains__('__await__')  == False
# abc.ABC.__dict__.__contains__('__aenter__') == False
# abc.ABC.__dict__.__contains__('__aexit__')  == False
# abc.ABC.__dict__.__contains__('__aiter__')  == False
# abc.ABC.__dict__.__contains__('__anext__')  == False
# abc.ABC.__dict__.__contains__('__abstractmethods__') == True  (established)
# ---------------------------------------------------------------------------

table abc_extra1501.abc_ABC_no_async_protocol:
  description: "abc.ABC has no async protocol methods in its own __dict__ — ab1501ac namespace. abc.ABC.__dict__.__contains__('__await__')==False (abc.ABC is a helper class for abstract base class definition; it has no async protocol; ABC is defined via 'class ABC(metaclass=ABCMeta): pass' and its __dict__ contains only __abstractmethods__, __slots__, __doc__, and a few other class metadata attributes — no async protocol methods); abc.ABC.__dict__.__contains__('__aenter__')==False (ABC is not an async context manager; it provides no 'async with' support; its purpose is enforcing interface contracts via @abstractmethod at instantiation); abc.ABC.__dict__.__contains__('__aexit__')==False (no async exit protocol on ABC); abc.ABC.__dict__.__contains__('__aiter__')==False (ABC is not an async iterator); abc.ABC.__dict__.__contains__('__anext__')==False (no async iteration on ABC); abc.ABC.__dict__.__contains__('__abstractmethods__')==True (established in prior specs: __abstractmethods__ IS in abc.ABC.__dict__ as frozenset(); this is the only notable protocol-like attribute in ABC.__dict__ and it is for tracking abstract method enforcement, not async protocol); verified with Python 3.14.4"
  kind: python_call_eq
  category: async_protocol
  id_prefix: ab1501ac

  columns: [id, function, args, expected, description]
  rows:
    - [ab1501ac001, abc.ABC.__dict__.__contains__, ["__await__"],           false, "abc.ABC.__dict__.__contains__('__await__')==False — ABC has no async protocol; verified with Python 3.14.4"]
    - [ab1501ac002, abc.ABC.__dict__.__contains__, ["__aenter__"],          false, "abc.ABC.__dict__.__contains__('__aenter__')==False — ABC is not an async context manager; verified with Python 3.14.4"]
    - [ab1501ac003, abc.ABC.__dict__.__contains__, ["__aexit__"],           false, "abc.ABC.__dict__.__contains__('__aexit__')==False — no async exit protocol on ABC; verified with Python 3.14.4"]
    - [ab1501ac004, abc.ABC.__dict__.__contains__, ["__aiter__"],           false, "abc.ABC.__dict__.__contains__('__aiter__')==False — ABC is not an async iterator; verified with Python 3.14.4"]
    - [ab1501ac005, abc.ABC.__dict__.__contains__, ["__anext__"],           false, "abc.ABC.__dict__.__contains__('__anext__')==False — no async iteration on ABC; verified with Python 3.14.4"]
    - [ab1501ac006, abc.ABC.__dict__.__contains__, ["__abstractmethods__"], true,  "abc.ABC.__dict__.__contains__('__abstractmethods__')==True — established in prior specs; frozenset() in ABC.__dict__; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Table 2: abc.ABCMeta has no async protocol in __dict__
#
# abc.ABCMeta.__dict__.__contains__('__await__')  == False
# abc.ABCMeta.__dict__.__contains__('__aenter__') == False
# abc.ABCMeta.__dict__.__contains__('__aexit__')  == False
# abc.ABCMeta.__dict__.__contains__('__aiter__')  == False
# abc.ABCMeta.__dict__.__contains__('__anext__')  == False
# abc.ABCMeta.__dict__.__contains__('register')   == True  (sync metaclass method)
# ---------------------------------------------------------------------------

table abc_extra1501.abc_ABCMeta_no_async_protocol:
  description: "abc.ABCMeta has no async protocol methods in its own __dict__ — ab1501am namespace. abc.ABCMeta.__dict__.__contains__('__await__')==False (ABCMeta is a metaclass — a subclass of type; it manages abstract base class registration and @abstractmethod tracking; it has no async protocol in its own __dict__); abc.ABCMeta.__dict__.__contains__('__aenter__')==False (ABCMeta is not an async context manager; metaclasses generally don't implement async protocols — they control class creation); abc.ABCMeta.__dict__.__contains__('__aexit__')==False (no async exit protocol on ABCMeta); abc.ABCMeta.__dict__.__contains__('__aiter__')==False (ABCMeta is not an async iterator); abc.ABCMeta.__dict__.__contains__('__anext__')==False (no async iteration on ABCMeta); abc.ABCMeta.__dict__.__contains__('register')==True (ABCMeta.register() IS defined directly in ABCMeta.__dict__; it is the method used to register virtual subclasses of an ABC: 'MyABC.register(SomeClass)' — purely synchronous); verified with Python 3.14.4"
  kind: python_call_eq
  category: async_protocol
  id_prefix: ab1501am

  columns: [id, function, args, expected, description]
  rows:
    - [ab1501am001, abc.ABCMeta.__dict__.__contains__, ["__await__"],  false, "ABCMeta.__dict__.__contains__('__await__')==False — ABCMeta has no async protocol; verified with Python 3.14.4"]
    - [ab1501am002, abc.ABCMeta.__dict__.__contains__, ["__aenter__"], false, "ABCMeta.__dict__.__contains__('__aenter__')==False — ABCMeta is not an async context manager; verified with Python 3.14.4"]
    - [ab1501am003, abc.ABCMeta.__dict__.__contains__, ["__aexit__"],  false, "ABCMeta.__dict__.__contains__('__aexit__')==False — no async exit protocol on ABCMeta; verified with Python 3.14.4"]
    - [ab1501am004, abc.ABCMeta.__dict__.__contains__, ["__aiter__"],  false, "ABCMeta.__dict__.__contains__('__aiter__')==False — ABCMeta is not an async iterator; verified with Python 3.14.4"]
    - [ab1501am005, abc.ABCMeta.__dict__.__contains__, ["__anext__"],  false, "ABCMeta.__dict__.__contains__('__anext__')==False — no async iteration on ABCMeta; verified with Python 3.14.4"]
    - [ab1501am006, abc.ABCMeta.__dict__.__contains__, ["register"],   true,  "ABCMeta.__dict__.__contains__('register')==True — ABCMeta.register() is defined directly in ABCMeta.__dict__; synchronous virtual subclass registration; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Table 3: Cross-module contrast — abc vs asyncio for async protocol
#
# abc.ABC.__dict__.__contains__('__await__')      == False
# asyncio.Future.__dict__.__contains__('__await__') == True
# abc.ABC.__dict__.__contains__('__aenter__')     == False
# asyncio.TaskGroup.__dict__.__contains__('__aenter__') == True
# abc.ABCMeta.__dict__.__contains__('__aiter__')  == False
# asyncio.StreamReader.__dict__.__contains__('__aiter__') == True
# ---------------------------------------------------------------------------

table abc_extra1501.abc_vs_asyncio_contrast:
  description: "Cross-module contrast: abc classes vs asyncio classes for async protocol __dict__ presence — ab1501xc namespace. abc.ABC.__dict__.__contains__('__await__')==False (ABC is a helper class for abstract method tracking; not awaitable; has no __await__ in __dict__); asyncio.Future.__dict__.__contains__('__await__')==True (asyncio.Future IS awaitable; defines __await__ in its C-level __dict__); the abc module defines abstract interfaces while asyncio provides concrete async protocol implementations — these are complementary but orthogonal concerns; abc.ABC.__dict__.__contains__('__aenter__')==False (ABC is not an async context manager); asyncio.TaskGroup.__dict__.__contains__('__aenter__')==True (TaskGroup IS an async context manager with __aenter__ in its own __dict__; one could define an abstract async context manager ABC using abc.ABC with @abstractmethod on async def __aenter__ and __aexit__, but abc.ABC itself provides none); abc.ABCMeta.__dict__.__contains__('__aiter__')==False (ABCMeta is not an async iterator); asyncio.StreamReader.__dict__.__contains__('__aiter__')==True (StreamReader IS an async iterator); abc.ABC.__dict__.__contains__('__anext__')==False vs asyncio.StreamReader.__dict__.__contains__('__anext__')==True; verified with Python 3.14.4"
  kind: python_call_eq
  category: async_protocol
  id_prefix: ab1501xc

  columns: [id, function, args, expected, description]
  rows:
    - [ab1501xc001, abc.ABC.__dict__.__contains__,      ["__await__"],  false, "abc.ABC.__dict__.__contains__('__await__')==False — no async protocol; contrast asyncio.Future which is True; verified with Python 3.14.4"]
    - [ab1501xc002, asyncio.Future.__dict__.__contains__, ["__await__"],  true,  "asyncio.Future.__dict__.__contains__('__await__')==True — async future; contrast abc.ABC which is False; verified with Python 3.14.4"]
    - [ab1501xc003, abc.ABC.__dict__.__contains__,      ["__aenter__"], false, "abc.ABC.__dict__.__contains__('__aenter__')==False — no async ctx manager; contrast asyncio.TaskGroup which is True; verified with Python 3.14.4"]
    - [ab1501xc004, asyncio.TaskGroup.__dict__.__contains__, ["__aenter__"], true, "asyncio.TaskGroup.__dict__.__contains__('__aenter__')==True — async ctx manager; contrast abc.ABC which is False; verified with Python 3.14.4"]
    - [ab1501xc005, abc.ABCMeta.__dict__.__contains__, ["__aiter__"],   false, "abc.ABCMeta.__dict__.__contains__('__aiter__')==False — no async iteration; contrast asyncio.StreamReader which is True; verified with Python 3.14.4"]
    - [ab1501xc006, asyncio.StreamReader.__dict__.__contains__, ["__aiter__"], true, "asyncio.StreamReader.__dict__.__contains__('__aiter__')==True — async iterator; contrast abc.ABCMeta which is False; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1501
# ---------------------------------------------------------------------------

invariant abc_extra1501.abc_ABC_no_await:
  description: "abc.ABC.__dict__.__contains__('__await__') returns False — abc.ABC does not define __await__ in its own __dict__; ABC is a helper class that uses ABCMeta as its metaclass to enable abstract method enforcement; ABC.__dict__ contains __abstractmethods__ (frozenset()), __slots__, __doc__, and class metadata — no async protocol methods; the abc module is entirely synchronous and orthogonal to Python's async/await system; wave 547 theme: async protocol __dict__ presence; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: async_protocol
  kind: python_call_eq
  function: abc.ABC.__dict__.__contains__
  args: ["__await__"]
  expected: false

invariant abc_extra1501.abc_ABC_no_aenter:
  description: "abc.ABC.__dict__.__contains__('__aenter__') returns False — abc.ABC does not define __aenter__ in its own __dict__; ABC is not an async context manager; while it is possible to define an abstract async context manager by using @abstractmethod on async def __aenter__ and __aexit__ within a subclass of ABC, the ABC class itself provides no implementation of these methods; abc.ABC is solely for interface contract enforcement; wave 547 theme; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: async_protocol
  kind: python_call_eq
  function: abc.ABC.__dict__.__contains__
  args: ["__aenter__"]
  expected: false

invariant abc_extra1501.abc_ABCMeta_no_await:
  description: "abc.ABCMeta.__dict__.__contains__('__await__') returns False — abc.ABCMeta does not define __await__ in its own __dict__; ABCMeta is a metaclass (subclass of type) that provides abstract base class machinery: it processes @abstractmethod decorators during class creation, computes __abstractmethods__, and raises TypeError when abstract classes are instantiated without all abstract methods implemented; ABCMeta itself has no async protocol; wave 547 theme; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: async_protocol
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__contains__
  args: ["__await__"]
  expected: false

invariant abc_extra1501.abc_ABCMeta_no_aenter:
  description: "abc.ABCMeta.__dict__.__contains__('__aenter__') returns False — abc.ABCMeta does not define __aenter__ in its own __dict__; ABCMeta is not an async context manager; ABCMeta's public interface in its __dict__ includes register(), __instancecheck__(), __subclasscheck__(), and __subclasshook__() — all synchronous methods for virtual subclass registration and isinstance/issubclass override; no async protocol methods exist in ABCMeta.__dict__; wave 547 theme; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: async_protocol
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__contains__
  args: ["__aenter__"]
  expected: false
