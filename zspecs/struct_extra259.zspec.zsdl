spec: struct_extra259
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra258.zspec.zsdl — covers Struct class __init__/__new__ qualnames; Struct('>I') and Struct('!H') format/size/pack vectors."
    - "struct_extra.zspec.zsdl — covers Struct format/size attrs; calcsize extra formats; pack_into/unpack_from/iter_unpack function names; error class name and base."
    - "struct.zspec.zsdl — covers pack/unpack/calcsize vectors; roundtrip invariants; error cases for wrong buffer size."
  notes:
    - "struct.__name__ == 'struct' — the module __name__ attribute. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.__package__ == '' — struct is a top-level stdlib module; __package__ is the empty string. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.__spec__.__class__.__name__ == 'ModuleSpec' — struct.__spec__ is an importlib.machinery.ModuleSpec. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.__spec__.name == 'struct' — the ModuleSpec .name is the fully-qualified module name. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.__loader__.__class__.__name__ == 'SourceFileLoader' — struct is loaded via SourceFileLoader. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.__all__ is a list (not a tuple or set); len(struct.__all__) == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.__all__ contains 'pack', 'unpack', 'calcsize', 'Struct', 'error'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.pack('!I', 'not_an_int') raises struct.error: 'required argument is not an integer'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.pack('!II', 1) raises struct.error: 'pack expected 2 items for packing (got 1)'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.pack('!I', 1, 2) raises struct.error: 'pack expected 1 items for packing (got 2)'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct module identity — __name__, __package__, __spec__, __loader__
# ---------------------------------------------------------------------------

table struct_extra259.module_identity:
  description: "struct module identity attributes: __name__, __package__, __spec__ class and name, __loader__ class; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: structid259

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,         __name__.__eq__,                        ["struct"],           true, "struct.__name__ == 'struct' — module name attribute"]
    - [package_eq,      __package__.__eq__,                     [""],                 true, "struct.__package__ == '' — top-level module has empty string package"]
    - [spec_class_name, __spec__.__class__.__name__.__eq__,      ["ModuleSpec"],       true, "struct.__spec__.__class__.__name__ == 'ModuleSpec'"]
    - [spec_name_eq,    __spec__.name.__eq__,                   ["struct"],           true, "struct.__spec__.name == 'struct'"]
    - [loader_class,    __loader__.__class__.__name__.__eq__,    ["SourceFileLoader"], true, "struct.__loader__.__class__.__name__ == 'SourceFileLoader'"]

# ---------------------------------------------------------------------------
# struct.__all__ — type and key members
# struct.__all__ is a list of 8 entries; contains 'pack', 'unpack', 'calcsize',
# 'Struct', 'error', 'pack_into', 'unpack_from', 'iter_unpack'
# ---------------------------------------------------------------------------

invariant struct_extra259.all_type_is_list:
  description: "struct.__all__.__class__.__name__ == 'list' — __all__ is a list in the struct module"
  category: identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant struct_extra259.all_len:
  description: "len(struct.__all__) == 8 — struct.__all__ has 8 entries"
  category: identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 8

table struct_extra259.all_key_members:
  description: "struct.__all__.__contains__ checks for key members: pack, unpack, calcsize, Struct, error; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: structid259

  columns: [id, function, args, expected, description]
  rows:
    - [has_pack,      __all__.__contains__, ["pack"],      true, "struct.__all__ contains 'pack'"]
    - [has_unpack,    __all__.__contains__, ["unpack"],    true, "struct.__all__ contains 'unpack'"]
    - [has_calcsize,  __all__.__contains__, ["calcsize"],  true, "struct.__all__ contains 'calcsize'"]
    - [has_Struct,    __all__.__contains__, ["Struct"],    true, "struct.__all__ contains 'Struct'"]
    - [has_error,     __all__.__contains__, ["error"],     true, "struct.__all__ contains 'error'"]

# ---------------------------------------------------------------------------
# struct.pack error conditions — wrong type, wrong argument count
# struct.pack raises struct.error (not TypeError) for all three cases.
# ---------------------------------------------------------------------------

table struct_extra259.pack_error_conditions:
  description: "struct.pack raises struct.error for wrong argument type and wrong argument count; verified with Python 3.14.3"
  kind: python_call_raises
  category: errors
  id_prefix: structerr259

  columns: [id, function, args, raises, description]
  rows:
    - [wrong_type,      pack, ["!I", "not_an_int"], struct.error, "struct.pack('!I', 'not_an_int') raises struct.error — string is not an integer"]
    - [too_few_args,    pack, ["!II", 1],           struct.error, "struct.pack('!II', 1) raises struct.error — format requires 2 args but got 1"]
    - [too_many_args,   pack, ["!I", 1, 2],         struct.error, "struct.pack('!I', 1, 2) raises struct.error — format requires 1 arg but got 2"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant struct_extra259.module_name:
  description: "struct.__name__ == 'struct' — the module's __name__ attribute is the bare module name"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["struct"]
  expected: true

invariant struct_extra259.module_package:
  description: "struct.__package__ == '' — struct is a top-level stdlib module; __package__ is the empty string"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant struct_extra259.spec_class_name:
  description: "struct.__spec__.__class__.__name__ == 'ModuleSpec' — __spec__ is an importlib.machinery.ModuleSpec"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant struct_extra259.spec_name:
  description: "struct.__spec__.name == 'struct' — the ModuleSpec .name is the fully-qualified module name"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["struct"]
  expected: true

invariant struct_extra259.loader_class:
  description: "struct.__loader__.__class__.__name__ == 'SourceFileLoader' — struct loads via SourceFileLoader"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant struct_extra259.pack_wrong_type_raises:
  description: "struct.pack('!I', 'not_an_int') raises struct.error — string is not a valid integer argument for '!I'"
  category: errors
  kind: python_call_raises
  function: pack
  args: ["!I", "not_an_int"]
  raises: struct.error

invariant struct_extra259.pack_too_few_args_raises:
  description: "struct.pack('!II', 1) raises struct.error — format '!II' requires 2 arguments but only 1 was given"
  category: errors
  kind: python_call_raises
  function: pack
  args: ["!II", 1]
  raises: struct.error

invariant struct_extra259.pack_too_many_args_raises:
  description: "struct.pack('!I', 1, 2) raises struct.error — format '!I' requires 1 argument but 2 were given"
  category: errors
  kind: python_call_raises
  function: pack
  args: ["!I", 1, 2]
  raises: struct.error
