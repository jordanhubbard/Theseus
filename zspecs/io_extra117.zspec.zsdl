spec: io_extra117
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec extends io_extra116.zspec.zsdl."
    - "This spec covers: io.RawIOBase and io.BufferedIOBase and io.TextIOBase abstract method qualnames (read, readinto, write, read1, readline) and their types."
    - "All these abstract methods use the '_RawIOBase.', '_BufferedIOBase.', or '_TextIOBase.' prefix because the C implementations live in _io._RawIOBase, _io._BufferedIOBase, and _io._TextIOBase."
    - "io.RawIOBase.read.__qualname__ == '_RawIOBase.read' (len 15); type 'method_descriptor'."
    - "io.RawIOBase.readinto.__qualname__ == '_RawIOBase.readinto' (len 19); type 'method_descriptor'."
    - "io.BufferedIOBase.read.__qualname__ == '_BufferedIOBase.read' (len 20); type 'method_descriptor'."
    - "io.BufferedIOBase.read1.__qualname__ == '_BufferedIOBase.read1' (len 21); type 'method_descriptor'."
    - "io.BufferedIOBase.write.__qualname__ == '_BufferedIOBase.write' (len 21); type 'method_descriptor'."
    - "io.TextIOBase.read.__qualname__ == '_TextIOBase.read' (len 16); type 'method_descriptor'."
    - "io.TextIOBase.write.__qualname__ == '_TextIOBase.write' (len 17); type 'method_descriptor'."
    - "io.TextIOBase.readline.__qualname__ == '_TextIOBase.readline' (len 20); type 'method_descriptor'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.RawIOBase.read and io.RawIOBase.readinto qualnames and types
# Both use '_RawIOBase.' prefix (not 'RawIOBase.') because the C implementation
# lives in _io._RawIOBase.
# read: '_RawIOBase.read' (15 chars); readinto: '_RawIOBase.readinto' (19 chars).
# Both are 'method_descriptor' (C extension tp_methods entries).
# ---------------------------------------------------------------------------

table io_extra117.RawIOBase_read_readinto_qualnames:
  description: "io.RawIOBase read/readinto __qualname__: read='_RawIOBase.read'(15), readinto='_RawIOBase.readinto'(19); both type 'method_descriptor'; '_RawIOBase.' prefix reflects C implementation in _io._RawIOBase"
  kind: python_call_eq
  category: qualnames
  id_prefix: iobase117a

  columns: [id, function, args, expected, description]
  rows:
    - [raw_read_type,       "RawIOBase.read.__class__.__name__.__eq__",      ["method_descriptor"],   true,  "type(io.RawIOBase.read).__name__ == 'method_descriptor' (C extension tp_methods entry)"]
    - [raw_read_qn_eq,      "RawIOBase.read.__qualname__.__eq__",            ["_RawIOBase.read"],     true,  "io.RawIOBase.read.__qualname__ == '_RawIOBase.read' ('_RawIOBase.' prefix reflects _io._RawIOBase C type)"]
    - [raw_read_qn_len,     "RawIOBase.read.__qualname__.__len__",           [],                      15,    "io.RawIOBase.read.__qualname__.__len__() == 15 ('_RawIOBase.read' has 15 chars)"]
    - [raw_readinto_type,   "RawIOBase.readinto.__class__.__name__.__eq__",  ["method_descriptor"],   true,  "type(io.RawIOBase.readinto).__name__ == 'method_descriptor' (C extension tp_methods entry)"]
    - [raw_readinto_qn_eq,  "RawIOBase.readinto.__qualname__.__eq__",        ["_RawIOBase.readinto"], true,  "io.RawIOBase.readinto.__qualname__ == '_RawIOBase.readinto' (abstract method; subclasses must implement)"]
    - [raw_readinto_qn_len, "RawIOBase.readinto.__qualname__.__len__",       [],                      19,    "io.RawIOBase.readinto.__qualname__.__len__() == 19 ('_RawIOBase.readinto' has 19 chars)"]
    - [raw_read_ne_plain,   "RawIOBase.read.__qualname__.__eq__",            ["RawIOBase.read"],      false, "io.RawIOBase.read.__qualname__ != 'RawIOBase.read' (C type uses '_RawIOBase.' not 'RawIOBase.' prefix)"]
    - [raw_readinto_gt_read, "RawIOBase.readinto.__qualname__.__len__.__gt__", [15],                  true,  "len('_RawIOBase.readinto') > len('_RawIOBase.read') (19 > 15; readinto is longer)"]

# ---------------------------------------------------------------------------
# io.BufferedIOBase.read, read1, write qualnames and types
# All three use '_BufferedIOBase.' prefix because the C implementation lives
# in _io._BufferedIOBase.
# read: '_BufferedIOBase.read' (20 chars).
# read1: '_BufferedIOBase.read1' (21 chars).
# write: '_BufferedIOBase.write' (21 chars).
# All are 'method_descriptor' (C extension tp_methods entries).
# ---------------------------------------------------------------------------

table io_extra117.BufferedIOBase_read_read1_write_qualnames:
  description: "io.BufferedIOBase read/read1/write __qualname__: read='_BufferedIOBase.read'(20), read1='_BufferedIOBase.read1'(21), write='_BufferedIOBase.write'(21); all 'method_descriptor'"
  kind: python_call_eq
  category: qualnames
  id_prefix: iobase117b

  columns: [id, function, args, expected, description]
  rows:
    - [buf_read_type,       "BufferedIOBase.read.__class__.__name__.__eq__",   ["method_descriptor"],      true,  "type(io.BufferedIOBase.read).__name__ == 'method_descriptor' (C extension tp_methods entry)"]
    - [buf_read_qn_eq,      "BufferedIOBase.read.__qualname__.__eq__",         ["_BufferedIOBase.read"],   true,  "io.BufferedIOBase.read.__qualname__ == '_BufferedIOBase.read' ('_BufferedIOBase.' prefix reflects C type)"]
    - [buf_read_qn_len,     "BufferedIOBase.read.__qualname__.__len__",        [],                         20,    "io.BufferedIOBase.read.__qualname__.__len__() == 20 ('_BufferedIOBase.read' has 20 chars)"]
    - [buf_read1_type,      "BufferedIOBase.read1.__class__.__name__.__eq__",  ["method_descriptor"],      true,  "type(io.BufferedIOBase.read1).__name__ == 'method_descriptor'"]
    - [buf_read1_qn_eq,     "BufferedIOBase.read1.__qualname__.__eq__",        ["_BufferedIOBase.read1"],  true,  "io.BufferedIOBase.read1.__qualname__ == '_BufferedIOBase.read1' (reads up to size bytes without blocking)"]
    - [buf_read1_qn_len,    "BufferedIOBase.read1.__qualname__.__len__",       [],                         21,    "io.BufferedIOBase.read1.__qualname__.__len__() == 21 ('_BufferedIOBase.read1' has 21 chars)"]
    - [buf_write_type,      "BufferedIOBase.write.__class__.__name__.__eq__",  ["method_descriptor"],      true,  "type(io.BufferedIOBase.write).__name__ == 'method_descriptor'"]
    - [buf_write_qn_eq,     "BufferedIOBase.write.__qualname__.__eq__",        ["_BufferedIOBase.write"],  true,  "io.BufferedIOBase.write.__qualname__ == '_BufferedIOBase.write' (writes bytes-like object)"]
    - [buf_write_qn_len,    "BufferedIOBase.write.__qualname__.__len__",       [],                         21,    "io.BufferedIOBase.write.__qualname__.__len__() == 21 ('_BufferedIOBase.write' has 21 chars; same length as read1)"]
    - [buf_read1_eq_write_len, "BufferedIOBase.read1.__qualname__.__len__.__eq__", [21],                   true,  "len('_BufferedIOBase.read1') == len('_BufferedIOBase.write') == 21 (read1 and write share identical qualname length)"]

# ---------------------------------------------------------------------------
# io.TextIOBase.read, write, readline qualnames and types
# All three use '_TextIOBase.' prefix because the C implementation lives
# in _io._TextIOBase.
# read: '_TextIOBase.read' (16 chars).
# write: '_TextIOBase.write' (17 chars).
# readline: '_TextIOBase.readline' (20 chars).
# All are 'method_descriptor' (C extension tp_methods entries).
# ---------------------------------------------------------------------------

table io_extra117.TextIOBase_read_write_readline_qualnames:
  description: "io.TextIOBase read/write/readline __qualname__: read='_TextIOBase.read'(16), write='_TextIOBase.write'(17), readline='_TextIOBase.readline'(20); all 'method_descriptor'"
  kind: python_call_eq
  category: qualnames
  id_prefix: iobase117c

  columns: [id, function, args, expected, description]
  rows:
    - [txt_read_type,       "TextIOBase.read.__class__.__name__.__eq__",      ["method_descriptor"],     true,  "type(io.TextIOBase.read).__name__ == 'method_descriptor' (C extension tp_methods entry)"]
    - [txt_read_qn_eq,      "TextIOBase.read.__qualname__.__eq__",            ["_TextIOBase.read"],      true,  "io.TextIOBase.read.__qualname__ == '_TextIOBase.read' ('_TextIOBase.' prefix reflects _io._TextIOBase C type)"]
    - [txt_read_qn_len,     "TextIOBase.read.__qualname__.__len__",           [],                        16,    "io.TextIOBase.read.__qualname__.__len__() == 16 ('_TextIOBase.read' has 16 chars)"]
    - [txt_write_type,      "TextIOBase.write.__class__.__name__.__eq__",     ["method_descriptor"],     true,  "type(io.TextIOBase.write).__name__ == 'method_descriptor'"]
    - [txt_write_qn_eq,     "TextIOBase.write.__qualname__.__eq__",           ["_TextIOBase.write"],     true,  "io.TextIOBase.write.__qualname__ == '_TextIOBase.write' (abstract write; raises UnsupportedOperation by default)"]
    - [txt_write_qn_len,    "TextIOBase.write.__qualname__.__len__",          [],                        17,    "io.TextIOBase.write.__qualname__.__len__() == 17 ('_TextIOBase.write' has 17 chars)"]
    - [txt_readline_type,   "TextIOBase.readline.__class__.__name__.__eq__",  ["method_descriptor"],     true,  "type(io.TextIOBase.readline).__name__ == 'method_descriptor'"]
    - [txt_readline_qn_eq,  "TextIOBase.readline.__qualname__.__eq__",        ["_TextIOBase.readline"],  true,  "io.TextIOBase.readline.__qualname__ == '_TextIOBase.readline' (reads until newline or EOF)"]
    - [txt_readline_qn_len, "TextIOBase.readline.__qualname__.__len__",       [],                        20,    "io.TextIOBase.readline.__qualname__.__len__() == 20 ('_TextIOBase.readline' has 20 chars; longest in this group)"]
    - [txt_read_lt_write,   "TextIOBase.read.__qualname__.__len__.__lt__",    [17],                      true,  "len('_TextIOBase.read') < len('_TextIOBase.write') (16 < 17; read is shorter than write by one char)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra117.RawIOBase.read_qualname:
  description: "io.RawIOBase.read.__qualname__ == '_RawIOBase.read' (length 15; the '_RawIOBase.' prefix is 11 chars and 'read' adds 4; the underscore-prefixed class name reflects the C implementation type _io._RawIOBase; the method is abstract and raises UnsupportedOperation when called directly)"
  category: qualnames
  kind: python_call_eq
  function: "RawIOBase.read.__qualname__.__eq__"
  args: ["_RawIOBase.read"]
  expected: true

invariant io_extra117.RawIOBase.readinto_qualname_len:
  description: "io.RawIOBase.readinto.__qualname__.__len__() == 19 ('_RawIOBase.readinto' has 19 characters; '_RawIOBase.' (11) + 'readinto' (8) == 19; readinto is the primary abstract method of RawIOBase that subclasses must implement — it reads bytes into a pre-allocated buffer)"
  category: qualnames
  kind: python_call_eq
  function: "RawIOBase.readinto.__qualname__.__len__"
  args: []
  expected: 19

invariant io_extra117.BufferedIOBase.read_qualname_len:
  description: "io.BufferedIOBase.read.__qualname__.__len__() == 20 ('_BufferedIOBase.read' has 20 characters; '_BufferedIOBase.' (16) + 'read' (4) == 20; BufferedIOBase.read is abstract and is overridden by BufferedReader to implement buffered reads)"
  category: qualnames
  kind: python_call_eq
  function: "BufferedIOBase.read.__qualname__.__len__"
  args: []
  expected: 20

invariant io_extra117.BufferedIOBase.write_qualname_len:
  description: "io.BufferedIOBase.write.__qualname__.__len__() == 21 ('_BufferedIOBase.write' has 21 characters; '_BufferedIOBase.' (16) + 'write' (5) == 21; write and read1 share the same qualname length of 21 — the longest among BufferedIOBase methods examined)"
  category: qualnames
  kind: python_call_eq
  function: "BufferedIOBase.write.__qualname__.__len__"
  args: []
  expected: 21

invariant io_extra117.TextIOBase.readline_qualname_len:
  description: "io.TextIOBase.readline.__qualname__.__len__() == 20 ('_TextIOBase.readline' has 20 characters; '_TextIOBase.' (12) + 'readline' (8) == 20; it is the longest TextIOBase method qualname examined; readline reads until a newline character or EOF and returns the string including the newline)"
  category: qualnames
  kind: python_call_eq
  function: "TextIOBase.readline.__qualname__.__len__"
  args: []
  expected: 20
