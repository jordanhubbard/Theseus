spec: threading_extra272
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.Event.__bases__[0].__name__ == 'object' — Event inherits directly from object."
    - "Event methods: set(3), clear(5), wait(4), is_set(6 longest); all are 'function' class."
    - "Event.set.__qualname__ == 'Event.set'; all method qualnames follow 'Event.<method>' pattern."
    - "threading.Semaphore.__enter__.__name__ == 'acquire' — __enter__ is aliased to acquire; __exit__.__name__ == '__exit__'."
    - "Semaphore.acquire.__qualname__ == 'Semaphore.acquire'; Semaphore.__enter__.__qualname__ == 'Semaphore.acquire' (aliased)."
    - "Semaphore.__exit__.__qualname__ == 'Semaphore.__exit__'; __exit__ has its own qualname unlike __enter__."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.Event class and method identity
#
# Event.__module__ == 'threading'; __bases__[0].__name__ == 'object'.
# Methods: set(3) < wait(4) < clear(5) < is_set(6 longest name).
# All methods are 'function' class with qualname 'Event.<method>'.
# ---------------------------------------------------------------------------

table threading_extra272.event_identity:
  description: "threading.Event class and method identity — module 'threading', base 'object'; methods set(3), wait(4), clear(5), is_set(6 longest); all are function class with Event.<method> qualname; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex272ev

  columns: [id, function, args, expected, description]
  rows:
    - [ev_name_eq,             Event.__name__.__eq__,                       ["Event"],                      true, "threading.Event.__name__ == 'Event'; verified with Python 3.14.3"]
    - [ev_name_len,            Event.__name__.__len__,                      [],                             5,    "threading.Event.__name__.__len__() == 5; verified with Python 3.14.3"]
    - [ev_mod_eq,              Event.__module__.__eq__,                     ["threading"],                  true, "threading.Event.__module__ == 'threading'; verified with Python 3.14.3"]
    - [ev_base_eq,             Event.__bases__.__getitem__(0).__name__.__eq__, ["object"],                  true, "threading.Event.__bases__[0].__name__ == 'object' — direct object subclass; verified with Python 3.14.3"]
    - [es_name_eq,             Event.set.__name__.__eq__,                   ["set"],                        true, "threading.Event.set.__name__ == 'set' (len=3 — shortest method name); verified with Python 3.14.3"]
    - [es_name_len,            Event.set.__name__.__len__,                  [],                             3,    "threading.Event.set.__name__.__len__() == 3; verified with Python 3.14.3"]
    - [es_cls_eq,              Event.set.__class__.__name__.__eq__,         ["function"],                   true, "threading.Event.set.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [es_qn_eq,               Event.set.__qualname__.__eq__,               ["Event.set"],                  true, "threading.Event.set.__qualname__ == 'Event.set'; verified with Python 3.14.3"]
    - [ec_name_eq,             Event.clear.__name__.__eq__,                 ["clear"],                      true, "threading.Event.clear.__name__ == 'clear' (len=5); verified with Python 3.14.3"]
    - [ec_name_len,            Event.clear.__name__.__len__,                [],                             5,    "threading.Event.clear.__name__.__len__() == 5; verified with Python 3.14.3"]
    - [ec_cls_eq,              Event.clear.__class__.__name__.__eq__,       ["function"],                   true, "threading.Event.clear.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [ew_name_eq,             Event.wait.__name__.__eq__,                  ["wait"],                       true, "threading.Event.wait.__name__ == 'wait' (len=4); verified with Python 3.14.3"]
    - [ew_name_len,            Event.wait.__name__.__len__,                 [],                             4,    "threading.Event.wait.__name__.__len__() == 4; verified with Python 3.14.3"]
    - [ew_cls_eq,              Event.wait.__class__.__name__.__eq__,        ["function"],                   true, "threading.Event.wait.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [ei_name_eq,             Event.is_set.__name__.__eq__,                ["is_set"],                     true, "threading.Event.is_set.__name__ == 'is_set' (len=6 — longest method name); verified with Python 3.14.3"]
    - [ei_name_len,            Event.is_set.__name__.__len__,               [],                             6,    "threading.Event.is_set.__name__.__len__() == 6 — longest Event method name; verified with Python 3.14.3"]
    - [ei_cls_eq,              Event.is_set.__class__.__name__.__eq__,      ["function"],                   true, "threading.Event.is_set.__class__.__name__ == 'function'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# threading.Semaphore class and method identity
#
# Semaphore.acquire.__qualname__ == 'Semaphore.acquire'.
# Semaphore.__enter__ is aliased to acquire: __enter__.__name__ == 'acquire'.
# Semaphore.__enter__.__qualname__ == 'Semaphore.acquire' (aliased).
# Semaphore.__exit__.__name__ == '__exit__' (own name); __qualname__ == 'Semaphore.__exit__'.
# ---------------------------------------------------------------------------

table threading_extra272.semaphore_identity:
  description: "threading.Semaphore method identity — acquire, release, __enter__(aliased to acquire), __exit__; __enter__.__name__=='acquire' shows the alias; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex272se

  columns: [id, function, args, expected, description]
  rows:
    - [sa_name_eq,             Semaphore.acquire.__name__.__eq__,           ["acquire"],                    true, "threading.Semaphore.acquire.__name__ == 'acquire'; verified with Python 3.14.3"]
    - [sa_qn_eq,               Semaphore.acquire.__qualname__.__eq__,       ["Semaphore.acquire"],          true, "threading.Semaphore.acquire.__qualname__ == 'Semaphore.acquire'; verified with Python 3.14.3"]
    - [sa_cls_eq,              Semaphore.acquire.__class__.__name__.__eq__, ["function"],                   true, "threading.Semaphore.acquire.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [sr_name_eq,             Semaphore.release.__name__.__eq__,           ["release"],                    true, "threading.Semaphore.release.__name__ == 'release'; verified with Python 3.14.3"]
    - [sr_qn_eq,               Semaphore.release.__qualname__.__eq__,       ["Semaphore.release"],          true, "threading.Semaphore.release.__qualname__ == 'Semaphore.release'; verified with Python 3.14.3"]
    - [sr_cls_eq,              Semaphore.release.__class__.__name__.__eq__, ["function"],                   true, "threading.Semaphore.release.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [se_name_eq,             Semaphore.__enter__.__name__.__eq__,         ["acquire"],                    true, "threading.Semaphore.__enter__.__name__ == 'acquire' — __enter__ is aliased to acquire method; verified with Python 3.14.3"]
    - [se_qn_eq,               Semaphore.__enter__.__qualname__.__eq__,     ["Semaphore.acquire"],          true, "threading.Semaphore.__enter__.__qualname__ == 'Semaphore.acquire' — confirms __enter__ is the same function as acquire; verified with Python 3.14.3"]
    - [se_cls_eq,              Semaphore.__enter__.__class__.__name__.__eq__, ["function"],                 true, "threading.Semaphore.__enter__.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [sx_name_eq,             Semaphore.__exit__.__name__.__eq__,          ["__exit__"],                   true, "threading.Semaphore.__exit__.__name__ == '__exit__' (own name, not aliased); verified with Python 3.14.3"]
    - [sx_qn_eq,               Semaphore.__exit__.__qualname__.__eq__,      ["Semaphore.__exit__"],         true, "threading.Semaphore.__exit__.__qualname__ == 'Semaphore.__exit__'; verified with Python 3.14.3"]
    - [sx_cls_eq,              Semaphore.__exit__.__class__.__name__.__eq__, ["function"],                  true, "threading.Semaphore.__exit__.__class__.__name__ == 'function'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — threading_extra272
# ---------------------------------------------------------------------------

invariant threading_extra272.event_name_is_event:
  description: "threading.Event.__name__ == 'Event' (len=5) — class name matches the export name"
  category: identity
  kind: python_call_eq
  function: Event.__name__.__eq__
  args: ["Event"]
  expected: true

invariant threading_extra272.event_module_is_threading:
  description: "threading.Event.__module__ == 'threading' — Event is defined in the threading module"
  category: identity
  kind: python_call_eq
  function: Event.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra272.event_base_is_object:
  description: "threading.Event.__bases__[0].__name__ == 'object' — Event inherits directly from object"
  category: identity
  kind: python_call_eq
  function: Event.__bases__.__getitem__(0).__name__.__eq__
  args: ["object"]
  expected: true

invariant threading_extra272.event_set_qualname_is_event_set:
  description: "threading.Event.set.__qualname__ == 'Event.set' — qualname follows Class.method pattern"
  category: identity
  kind: python_call_eq
  function: Event.set.__qualname__.__eq__
  args: ["Event.set"]
  expected: true

invariant threading_extra272.event_is_set_name_is_longest:
  description: "threading.Event.is_set.__name__.__len__() == 6 — 'is_set' is the longest Event method name; longer than clear(5), wait(4), set(3)"
  category: identity
  kind: python_call_eq
  function: Event.is_set.__name__.__len__
  args: []
  expected: 6

invariant threading_extra272.semaphore_enter_aliased_to_acquire:
  description: "threading.Semaphore.__enter__.__name__ == 'acquire' — __enter__ is aliased to the acquire method, sharing the same function object"
  category: identity
  kind: python_call_eq
  function: Semaphore.__enter__.__name__.__eq__
  args: ["acquire"]
  expected: true

invariant threading_extra272.semaphore_exit_own_name:
  description: "threading.Semaphore.__exit__.__name__ == '__exit__' — unlike __enter__, __exit__ has its own name and is not aliased"
  category: identity
  kind: python_call_eq
  function: Semaphore.__exit__.__name__.__eq__
  args: ["__exit__"]
  expected: true
