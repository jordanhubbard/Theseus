spec: re_extra225
version: ">=3.13"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re module class and error hierarchy contracts — PatternError MRO, function __class__.__name__, IGNORECASE flag type."
    - "re.PatternError.__class__.__name__ == 'type'; PatternError is a plain class; verified with Python 3.14.3."
    - "re.PatternError.__mro__.__len__() == 4: [PatternError, Exception, BaseException, object]; verified with Python 3.14.3."
    - "re.PatternError.__mro__[0].__name__ == 'PatternError'; verified with Python 3.14.3."
    - "re.PatternError.__mro__[1].__name__ == 'Exception'; PatternError directly extends Exception; verified with Python 3.14.3."
    - "re.compile.__class__.__name__ == 'function'; verified with Python 3.14.3."
    - "re.match.__class__.__name__ == 'function'; verified with Python 3.14.3."
    - "re.search.__class__.__name__ == 'function'; verified with Python 3.14.3."
    - "re.sub.__class__.__name__ == 'function'; verified with Python 3.14.3."
    - "re.IGNORECASE.__class__.__name__ == 'RegexFlag'; IGNORECASE is a Flag enum in Python 3.11+; verified with Python 3.14.3."
    - "re.IGNORECASE.__class__.__bases__[0].__name__ == 'IntFlag'; RegexFlag inherits from IntFlag; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re function __class__.__name__ values
# Top-level module functions have __class__.__name__ == 'function'.
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table re_extra225.function_class_names:
  description: "re function __class__.__name__ contracts for compile, match, search, sub; all are plain functions; verified with Python 3.14.3"
  kind: python_call_eq
  category: function_metadata
  id_prefix: refnclsname225

  columns: [id, function, args, expected]
  rows:
    - [compile_classname, compile.__class__.__name__.__eq__, ["function"], true]
    - [match_classname,   match.__class__.__name__.__eq__,   ["function"], true]
    - [search_classname,  search.__class__.__name__.__eq__,  ["function"], true]
    - [sub_classname,     sub.__class__.__name__.__eq__,     ["function"], true]

# ---------------------------------------------------------------------------
# re.PatternError class type and MRO length
# PatternError is a plain class (metaclass == type) and extends Exception directly.
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table re_extra225.patternerror_meta:
  description: "re.PatternError __class__.__name__ and MRO length contracts; extends Exception directly; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_metadata
  id_prefix: repatterrmeta225

  columns: [id, function, args, expected]
  rows:
    - [patternerror_classname, PatternError.__class__.__name__.__eq__, ["type"], true]
    - [patternerror_mro_len,   PatternError.__mro__.__len__,           [],       4]

# ---------------------------------------------------------------------------
# Standalone invariants
# Functions with [ in path must be double-quoted.
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

invariant re_extra225.PatternError.class_type:
  description: "re.PatternError.__class__.__name__ == 'type' — PatternError is a plain class with metaclass type; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: PatternError.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant re_extra225.PatternError.mro_len:
  description: "re.PatternError.__mro__.__len__() == 4: PatternError -> Exception -> BaseException -> object; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: PatternError.__mro__.__len__
  args: []
  expected: 4

invariant re_extra225.PatternError.mro0_name:
  description: "re.PatternError.__mro__[0].__name__ == 'PatternError' — first MRO element is the class itself; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: "PatternError.__mro__[0].__name__.__eq__"
  args: ["PatternError"]
  expected: true

invariant re_extra225.PatternError.mro1_name:
  description: "re.PatternError.__mro__[1].__name__ == 'Exception' — PatternError directly extends Exception; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: "PatternError.__mro__[1].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant re_extra225.IGNORECASE.class_name:
  description: "re.IGNORECASE.__class__.__name__ == 'RegexFlag' — IGNORECASE is an instance of the RegexFlag IntFlag enum in Python 3.11+; verified with Python 3.14.3"
  category: flag_metadata
  kind: python_call_eq
  function: IGNORECASE.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra225.IGNORECASE.base_class_name:
  description: "re.IGNORECASE.__class__.__bases__[0].__name__ == 'IntFlag' — RegexFlag inherits from IntFlag; verified with Python 3.14.3"
  category: flag_metadata
  kind: python_call_eq
  function: "IGNORECASE.__class__.__bases__[0].__name__.__eq__"
  args: ["IntFlag"]
  expected: true
