spec: reprlib_extra2
version: ">=3.9"
backend: python_module(reprlib)

docs: https://docs.python.org/3/library/reprlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/reprlib.html — Python reprlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/reprlib.py"
  notes:
    - "This spec extends reprlib.zspec.zsdl and reprlib_extra.zspec.zsdl."
    - "reprlib.zspec.zsdl covers: Repr.__name__, recursive_repr.__name__, aRepr.__class__.__name__, module-level repr() return-value checks."
    - "reprlib_extra.zspec.zsdl covers: Repr.__module__, recursive_repr.__name__, repr.__name__, aRepr.__class__.__name__, aRepr.maxstring/maxlist/maxdict/maxtuple type checks."
    - "This spec adds: Repr class name (anchor), repr.__name__, aRepr class name (anchor), Repr.maxstring/maxlevel class type checks on the class itself (not instance), Repr.__bases__ check, and additional Repr instance attribute type checks."
    - "reprlib.Repr.maxstring is an int attribute on the Repr class (class-level default)."
    - "reprlib.Repr.maxlevel is an int attribute on the Repr class (class-level default)."
    - "reprlib.aRepr is the module-level Repr() instance used by the module-level repr() function."
    - "reprlib.repr is a bound method of reprlib.aRepr; its __name__ is 'repr'."
    - "reprlib.recursive_repr is a decorator factory; its __name__ is 'recursive_repr'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Repr class — name and module
# ---------------------------------------------------------------------------

invariant reprlib_extra2.Repr.name:
  description: "reprlib.Repr.__name__ == 'Repr'"
  category: classnames
  kind: python_call_eq
  function: Repr.__name__.__eq__
  args: ["Repr"]
  expected: true

invariant reprlib_extra2.Repr.module:
  description: "reprlib.Repr.__module__ == 'reprlib'"
  category: classnames
  kind: python_call_eq
  function: Repr.__module__.__eq__
  args: ["reprlib"]
  expected: true

invariant reprlib_extra2.Repr.base_is_object:
  description: "reprlib.Repr.__bases__[0].__name__ == 'object' — Repr inherits from object"
  category: classnames
  kind: python_call_eq
  function: Repr.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

# ---------------------------------------------------------------------------
# Repr class-level attribute type checks
# ---------------------------------------------------------------------------

invariant reprlib_extra2.Repr.maxstring_is_int:
  description: "reprlib.Repr.maxstring.__class__.__name__ == 'int'"
  category: class_attributes
  kind: python_call_eq
  function: Repr.maxstring.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant reprlib_extra2.Repr.maxlevel_is_int:
  description: "reprlib.Repr.maxlevel.__class__.__name__ == 'int'"
  category: class_attributes
  kind: python_call_eq
  function: Repr.maxlevel.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant reprlib_extra2.Repr.maxlist_is_int:
  description: "reprlib.Repr.maxlist.__class__.__name__ == 'int'"
  category: class_attributes
  kind: python_call_eq
  function: Repr.maxlist.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant reprlib_extra2.Repr.maxdict_is_int:
  description: "reprlib.Repr.maxdict.__class__.__name__ == 'int'"
  category: class_attributes
  kind: python_call_eq
  function: Repr.maxdict.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# module-level repr function — name check
# ---------------------------------------------------------------------------

invariant reprlib_extra2.repr.name:
  description: "reprlib.repr.__name__ == 'repr' — module-level repr is a bound method of aRepr"
  category: funcnames
  kind: python_call_eq
  function: repr.__name__.__eq__
  args: ["repr"]
  expected: true

# ---------------------------------------------------------------------------
# recursive_repr — function name check
# ---------------------------------------------------------------------------

invariant reprlib_extra2.recursive_repr.name:
  description: "reprlib.recursive_repr.__name__ == 'recursive_repr'"
  category: funcnames
  kind: python_call_eq
  function: recursive_repr.__name__.__eq__
  args: ["recursive_repr"]
  expected: true

# ---------------------------------------------------------------------------
# aRepr — module-level Repr instance type
# ---------------------------------------------------------------------------

invariant reprlib_extra2.aRepr.class_name:
  description: "reprlib.aRepr.__class__.__name__ == 'Repr' — aRepr is a Repr instance"
  category: aRepr
  kind: python_call_eq
  function: aRepr.__class__.__name__.__eq__
  args: ["Repr"]
  expected: true

# ---------------------------------------------------------------------------
# aRepr — instance attribute type checks
# ---------------------------------------------------------------------------

table reprlib_extra2.aRepr_attr_types:
  description: "reprlib.aRepr instance attributes are plain int values"
  kind: python_call_eq
  category: aRepr
  id_prefix: atype

  columns: [id, function, args, expected]
  rows:
    - [maxstring,  aRepr.maxstring.__class__.__name__.__eq__,  ["int"],  true]
    - [maxlevel,   aRepr.maxlevel.__class__.__name__.__eq__,   ["int"],  true]
    - [maxlist,    aRepr.maxlist.__class__.__name__.__eq__,    ["int"],  true]
    - [maxdict,    aRepr.maxdict.__class__.__name__.__eq__,    ["int"],  true]
    - [maxtuple,   aRepr.maxtuple.__class__.__name__.__eq__,   ["int"],  true]
    - [maxset,     aRepr.maxset.__class__.__name__.__eq__,     ["int"],  true]
    - [maxfrozenset, aRepr.maxfrozenset.__class__.__name__.__eq__, ["int"], true]
    - [maxarray,   aRepr.maxarray.__class__.__name__.__eq__,   ["int"],  true]
