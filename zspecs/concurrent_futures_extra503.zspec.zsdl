spec: concurrent_futures_extra503
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures exception hierarchy"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "CancelledError and TimeoutError are aliases for builtins in Python 3.8+"
    - "BrokenExecutor inherits from RuntimeError"
    - "BrokenProcessPool and BrokenThreadPool both inherit from BrokenExecutor"
    - "InvalidStateError inherits from concurrent.futures.Error"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra503.cancelled_error_identity:
  description: "concurrent.futures.CancelledError class identity invariants"
  kind: python_call_eq
  category: class_identity
  id_prefix: CEI

  columns: [id, function, args, expected]
  rows:
    - [CEI001, concurrent.futures.CancelledError.__name__.__eq__, ["CancelledError"], true]

table concurrent_futures_extra503.cancelled_error_bases:
  description: "concurrent.futures.CancelledError base class invariants"
  kind: python_call_eq
  category: class_identity
  id_prefix: CEB

  columns: [id, function, args, expected]
  rows:
    - [CEB001, "concurrent.futures.CancelledError.__bases__[0].__name__.__eq__", ["CancelledError"], true]

