spec: asyncio_extra67
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#inspect — Python function __defaults__ documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "This spec extends asyncio_extra66.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__()==13, Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__() tables, InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__/__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, Queue/Lock method qualname string equality, asyncio class __module__ string equality (extra52), Queue/Lock __doc__/__class__/__name__=='str' (extra50), asyncio.__all__.__class__.__name__=='list' (extra51), gather/sleep/__qualname__.__eq__ (extra3/extra22/extra26/extra28/extra43), Queue/__name__.__eq__ and Lock/__name__.__eq__ (extra/extra2/extra5), run/__qualname__.__eq__('run') (extra6/extra22/extra43), Condition/__name__/__qualname__/__len__() (extra53), BoundedSemaphore/__name__/__qualname__/__len__() (extra53), run/__name__.__eq__('run') (extra53), class __dict__.__class__.__name__/__qualname__ == 'mappingproxy' (extra54), class __class__.__module__.__eq__('builtins') (extra55), gather/sleep/wait __class__.__module__.__eq__('builtins') (extra55), Queue/Lock/Event/Semaphore/Condition __init__.__class__.__name__.__eq__('function') (extra55), class __repr__.__class__.__name__ (extra56), class __weakref__.__class__.__name__ (extra56), gather/sleep/wait function __repr__.__class__.__name__ (extra56), asyncio.__all__.__class__.__name__.__eq__('tuple') (extra57), class __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra57), class __subclasshook__.__class__.__name__ (extra57), asyncio.__all__.__contains__ membership checks (extra58), asyncio.__package__.__eq__('asyncio') (extra58), Queue/Lock __doc__.__class__.__name__.__eq__('str') (extra58), __loader__/__spec__/__file__/__cached__ __class__.__name__ (extra59), __spec__.origin/__spec__.submodule_search_locations/__spec__.has_location/__loader__.__class__.__name__.__len__() (extra60), Queue/Lock __init__ and put/get/empty/full/qsize/acquire/release __qualname__.__eq__ (extra61), gather/sleep/wait __annotations__.__class__.__name__.__eq__('dict'), gather __globals__.__class__.__name__.__eq__('dict'), gather __globals__.__contains__('gather'), Queue.__doc__.__contains__('Queue') (extra62), gather/sleep/Queue.__init__/Lock.__init__ __defaults__/__code__/__class__.__name__ checks (extra63), gather/sleep/Queue.__init__/Lock.__init__ __code__.co_name equality and co_argcount values (extra64), gather/sleep/Queue.__init__ co_varnames/co_filename/co_flags attribute chains (extra65), gather/sleep/Queue.__init__ co_consts/co_nlocals/co_stacksize type identity (extra66)."
    - "This spec covers (asynciodef67 namespace): wave 233 theme — __defaults__ type identity for sleep/Queue.__init__, NoneType identity for gather/Lock.__init__, and Event/Semaphore class identity (__class__.__name__=='type', __module__=='asyncio.locks', __qualname__). NEW in extra67: sleep.__defaults__.__class__.__name__=='tuple'; sleep.__defaults__.__len__()==1; Queue.__init__.__defaults__.__class__.__name__=='tuple'; Queue.__init__.__defaults__.__len__()==1; gather.__defaults__.__class__.__name__=='NoneType'; Lock.__init__.__defaults__.__class__.__name__=='NoneType'; Event.__class__.__name__=='type'; Event.__module__=='asyncio.locks'; Event.__qualname__=='Event'; Semaphore.__class__.__name__=='type'; Semaphore.__module__=='asyncio.locks'; Semaphore.__qualname__=='Semaphore'."
    - "asyncio.sleep.__defaults__.__class__.__name__ == 'tuple'. sleep(delay, result=None) has one positional-or-keyword parameter with a default (result=None). __defaults__ is (None,), a one-element tuple. __class__.__name__ is 'tuple'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.sleep.__defaults__.__len__() == 1. sleep.__defaults__ is (None,), a one-element tuple. len((None,)) == 1. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__init__.__defaults__.__class__.__name__ == 'tuple'. Queue.__init__(self, maxsize=0) has one positional-or-keyword parameter with a default (maxsize=0). __defaults__ is (0,), a one-element tuple. __class__.__name__ is 'tuple'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.gather.__defaults__ is None. gather(*coros_or_futures, return_exceptions=False) has no positional-or-keyword parameters with defaults; keyword-only defaults live in __kwdefaults__. __defaults__ is None. None.__class__.__name__ is 'NoneType'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__module__ == 'asyncio.locks'. Event is defined in Lib/asyncio/locks.py as a plain class. Its __module__ attribute is 'asyncio.locks'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.__module__ == 'asyncio.locks'. Semaphore is defined in Lib/asyncio/locks.py as a plain class. Its __module__ attribute is 'asyncio.locks'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio __defaults__ tuple checks — extra67
#
# Wave 233 theme: __defaults__ type identity and length.
#
# sleep(delay, result=None) has __defaults__==(None,), a one-element tuple.
# Queue.__init__(self, maxsize=0) has __defaults__==(0,), a one-element tuple.
# Both have __defaults__.__class__.__name__=='tuple' and __len__()==1.
# ---------------------------------------------------------------------------

table asyncio_extra67.sleep_queue_defaults:
  description: "asyncio sleep/__defaults__ and Queue.__init__/__defaults__ type identity and length checks in asynciodef67 namespace — wave 233 theme: __defaults__ type identity; sleep(delay, result=None) has __defaults__==(None,) a one-element tuple; Queue.__init__(self, maxsize=0) has __defaults__==(0,) a one-element tuple; both have __class__.__name__=='tuple' and __len__()==1; NEW in extra67: no prior asyncio spec has checked __defaults__.__len__() via standalone invariant for sleep or Queue.__init__; verified with Python 3.14.3"
  kind: python_call_eq
  category: defaults
  id_prefix: asynciodef67

  columns: [id, function, args, expected, description]
  rows:
    - [sleep_defaults_class,      sleep.__defaults__.__class__.__name__.__eq__,       ["tuple"], true, "sleep.__defaults__.__class__.__name__ == 'tuple' — sleep(delay, result=None) has one positional-or-keyword parameter with a default (result=None); __defaults__ is (None,) a one-element tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra67: first __defaults__.__class__.__name__.__eq__ check for sleep in the asynciodef67 namespace; verified with Python 3.14.3"]
    - [sleep_defaults_len,        sleep.__defaults__.__len__,                          [],        1,    "sleep.__defaults__.__len__() == 1 — sleep.__defaults__ is (None,) a one-element tuple; len((None,)) == 1; NEW in extra67: first __defaults__.__len__() check for sleep in the asynciodef67 namespace; verified with Python 3.14.3"]
    - [queue_init_defaults_class, Queue.__init__.__defaults__.__class__.__name__.__eq__, ["tuple"], true, "Queue.__init__.__defaults__.__class__.__name__ == 'tuple' — Queue.__init__(self, maxsize=0) has one positional-or-keyword parameter with a default (maxsize=0); __defaults__ is (0,) a one-element tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra67: first __defaults__.__class__.__name__.__eq__ check for Queue.__init__ in the asynciodef67 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio __defaults__ NoneType checks — extra67
#
# Wave 233 theme: __defaults__ NoneType identity.
#
# gather(*coros_or_futures, return_exceptions=False) has no positional-or-keyword
# defaults; __defaults__ is None (NoneType).
# Lock.__init__(self) has no parameters with defaults; __defaults__ is None.
# ---------------------------------------------------------------------------

table asyncio_extra67.none_defaults:
  description: "asyncio gather/__defaults__ and Lock.__init__/__defaults__ NoneType checks in asynciodef67 namespace — wave 233 theme: __defaults__ NoneType identity; gather has no positional defaults (__defaults__ is None, NoneType); Lock.__init__(self) has no parameters with defaults (__defaults__ is None, NoneType); NEW in extra67: no prior asyncio spec has checked Lock.__init__.__defaults__.__class__.__name__ in the asynciodef67 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: defaults
  id_prefix: asynciodef67a

  columns: [id, function, args, expected, description]
  rows:
    - [gather_defaults_class,    gather.__defaults__.__class__.__name__.__eq__,         ["NoneType"], true, "gather.__defaults__.__class__.__name__ == 'NoneType' — gather(*coros_or_futures, return_exceptions=False) has no positional-or-keyword parameters with defaults; keyword-only default return_exceptions=False lives in __kwdefaults__; __defaults__ is None; None.__class__.__name__ is 'NoneType'; NEW in extra67: first __defaults__.__class__.__name__.__eq__ check for gather in the asynciodef67 namespace; verified with Python 3.14.3"]
    - [lock_init_defaults_class, Lock.__init__.__defaults__.__class__.__name__.__eq__,  ["NoneType"], true, "Lock.__init__.__defaults__.__class__.__name__ == 'NoneType' — Lock.__init__(self) has no parameters with defaults; __defaults__ is None; None.__class__.__name__ is 'NoneType'; NEW in extra67: first __defaults__.__class__.__name__.__eq__ check for Lock.__init__ in the asynciodef67 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio Event class identity checks — extra67
#
# Wave 233 theme: Event class identity.
#
# asyncio.Event is a class defined in asyncio.locks. Its metaclass is 'type'
# (i.e. Event.__class__.__name__ == 'type'), its __module__ is 'asyncio.locks',
# and its __qualname__ is 'Event'.
# ---------------------------------------------------------------------------

table asyncio_extra67.Event_identity:
  description: "asyncio Event class identity checks in asynciodef67 namespace — wave 233 theme: Event class identity; Event.__class__.__name__=='type' (Event is an ordinary class); Event.__module__=='asyncio.locks' (defined in Lib/asyncio/locks.py); Event.__qualname__=='Event' (simple top-level class name); NEW in extra67: no prior asyncio spec has checked Event.__module__.__eq__('asyncio.locks') or Event.__qualname__.__eq__('Event') in the asynciodef67 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciodef67b

  columns: [id, function, args, expected, description]
  rows:
    - [event_class_name,  Event.__class__.__name__.__eq__,  ["type"],          true, "Event.__class__.__name__ == 'type' — asyncio.Event is an ordinary Python class; its metaclass is the built-in 'type'; Event.__class__.__name__ is 'type'; NEW in extra67: first __class__.__name__.__eq__('type') check for Event in the asynciodef67 namespace; verified with Python 3.14.3"]
    - [event_module,      Event.__module__.__eq__,          ["asyncio.locks"], true, "Event.__module__ == 'asyncio.locks' — Event is defined in Lib/asyncio/locks.py which sets __name__ == 'asyncio.locks'; Event.__module__ is 'asyncio.locks'; NEW in extra67: first __module__.__eq__ check for Event in the asynciodef67 namespace; verified with Python 3.14.3"]
    - [event_qualname,    Event.__qualname__.__eq__,        ["Event"],         true, "Event.__qualname__ == 'Event' — Event is a top-level class in asyncio.locks; its qualified name is simply 'Event'; __qualname__.__eq__('Event') returns True; NEW in extra67: first __qualname__.__eq__ check for Event in the asynciodef67 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio Semaphore class identity checks — extra67
#
# Wave 233 theme: Semaphore class identity.
#
# asyncio.Semaphore is a class defined in asyncio.locks. Its metaclass is
# 'type', its __module__ is 'asyncio.locks', and its __qualname__ is
# 'Semaphore'.
# ---------------------------------------------------------------------------

table asyncio_extra67.Semaphore_identity:
  description: "asyncio Semaphore class identity checks in asynciodef67 namespace — wave 233 theme: Semaphore class identity; Semaphore.__class__.__name__=='type' (Semaphore is an ordinary class); Semaphore.__module__=='asyncio.locks' (defined in Lib/asyncio/locks.py); Semaphore.__qualname__=='Semaphore' (simple top-level class name); NEW in extra67: no prior asyncio spec has checked Semaphore.__module__.__eq__('asyncio.locks') or Semaphore.__qualname__.__eq__('Semaphore') in the asynciodef67 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciodef67c

  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_class_name, Semaphore.__class__.__name__.__eq__,  ["type"],          true, "Semaphore.__class__.__name__ == 'type' — asyncio.Semaphore is an ordinary Python class; its metaclass is the built-in 'type'; Semaphore.__class__.__name__ is 'type'; NEW in extra67: first __class__.__name__.__eq__('type') check for Semaphore in the asynciodef67 namespace; verified with Python 3.14.3"]
    - [semaphore_module,     Semaphore.__module__.__eq__,          ["asyncio.locks"], true, "Semaphore.__module__ == 'asyncio.locks' — Semaphore is defined in Lib/asyncio/locks.py which sets __name__ == 'asyncio.locks'; Semaphore.__module__ is 'asyncio.locks'; NEW in extra67: first __module__.__eq__ check for Semaphore in the asynciodef67 namespace; verified with Python 3.14.3"]
    - [semaphore_qualname,   Semaphore.__qualname__.__eq__,        ["Semaphore"],     true, "Semaphore.__qualname__ == 'Semaphore' — Semaphore is a top-level class in asyncio.locks; its qualified name is simply 'Semaphore'; __qualname__.__eq__('Semaphore') returns True; NEW in extra67: first __qualname__.__eq__ check for Semaphore in the asynciodef67 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra67
# ---------------------------------------------------------------------------

invariant asyncio_extra67.sleep_defaults_tuple:
  description: "asyncio.sleep.__defaults__.__class__.__name__.__eq__('tuple') returns True — sleep(delay, result=None) has one positional-or-keyword parameter with a default (result=None); __defaults__ is (None,) a one-element tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra67: first standalone __defaults__.__class__.__name__.__eq__('tuple') invariant for sleep in the asynciodef67 namespace; wave 233 first __defaults__ type identity invariant for sleep; verified with Python 3.14.3"
  category: defaults
  kind: python_call_eq
  function: sleep.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant asyncio_extra67.sleep_defaults_len_1:
  description: "asyncio.sleep.__defaults__.__len__() == 1 — sleep.__defaults__ is (None,) a one-element tuple; len((None,)) == 1; __len__() returns 1; NEW in extra67: first standalone __defaults__.__len__() invariant for sleep in the asynciodef67 namespace; wave 233 first __defaults__ length invariant for sleep; verified with Python 3.14.3"
  category: defaults
  kind: python_call_eq
  function: sleep.__defaults__.__len__
  args: []
  expected: 1

invariant asyncio_extra67.gather_defaults_NoneType:
  description: "asyncio.gather.__defaults__.__class__.__name__.__eq__('NoneType') returns True — gather(*coros_or_futures, return_exceptions=False) has no positional-or-keyword parameters with defaults; keyword-only default return_exceptions=False lives in __kwdefaults__; __defaults__ is None; None.__class__.__name__ is 'NoneType'; NEW in extra67: first standalone __defaults__.__class__.__name__.__eq__('NoneType') invariant for gather in the asynciodef67 namespace; wave 233 first __defaults__ NoneType identity invariant for gather; verified with Python 3.14.3"
  category: defaults
  kind: python_call_eq
  function: gather.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant asyncio_extra67.Event_module_asyncio_locks:
  description: "asyncio.Event.__module__.__eq__('asyncio.locks') returns True — Event is defined in Lib/asyncio/locks.py; the module sets its __name__ to 'asyncio.locks'; Event.__module__ is 'asyncio.locks'; NEW in extra67: first standalone __module__.__eq__('asyncio.locks') invariant for Event in the asynciodef67 namespace; wave 233 first __module__ identity invariant for Event; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Event.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra67.Semaphore_module_asyncio_locks:
  description: "asyncio.Semaphore.__module__.__eq__('asyncio.locks') returns True — Semaphore is defined in Lib/asyncio/locks.py; the module sets its __name__ to 'asyncio.locks'; Semaphore.__module__ is 'asyncio.locks'; NEW in extra67: first standalone __module__.__eq__('asyncio.locks') invariant for Semaphore in the asynciodef67 namespace; wave 233 first __module__ identity invariant for Semaphore; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Semaphore.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true
