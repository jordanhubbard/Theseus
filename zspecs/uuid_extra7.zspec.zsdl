spec: uuid_extra7
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra.zspec.zsdl — covers UUID.__name__/__module__, uuid1/3/4/5 __name__ (table), uuid4 return type/version, NAMESPACE_* class names (table), UUID int/hex attribute types"
    - "uuid_extra2.zspec.zsdl — covers uuid1/3/4/5 __name__ standalone, NAMESPACE_* class names standalone, RESERVED_*/RFC_4122 values and type table"
    - "uuid_extra3.zspec.zsdl — covers uuid1/3/4/5 __module__, UUID.__bases__[0].__name__, uuid4 version/class standalone, UUID(int=0).version is None, NAMESPACE_* class names standalone"
    - "uuid_extra4.zspec.zsdl — covers NAMESPACE_* class names (table), uuid4 version, uuid4 class name, uuid4 hex len, uuid5/__name__, uuid3/__name__, UUID str format, UUID int type, NAMESPACE_DNS str repr"
    - "uuid_extra5.zspec.zsdl — covers __qualname__ for UUID class and uuid1/3/4/5 functions (table), UUID instance class name via fixed literal"
    - "uuid_extra6.zspec.zsdl — covers RESERVED_*/RFC_4122 __class__.__name__ (table), UUID.bytes/__class__/__name__, UUID.bytes_le/__class__/__name__, UUID.fields/__class__/__name__, UUID.fields.__len__() == 6"
  notes:
    - "This spec extends the uuid chain; it does NOT duplicate invariants already present in any prior spec."
    - "Focus: SafeUUID enum class attributes and uuid1/uuid4 instance version checks as standalone invariants from the uuid_extra7 namespace."
    - "uuid.SafeUUID is an IntEnum introduced in Python 3.7 (PEP 435 style); its __name__ == 'SafeUUID'."
    - "uuid.SafeUUID.__module__ == 'uuid' — SafeUUID is defined in Lib/uuid.py."
    - "uuid.SafeUUID.__qualname__ == 'SafeUUID' — top-level class so qualname equals name."
    - "uuid.SafeUUID.safe.value == 0 — the 'safe' member has numeric value 0."
    - "uuid.SafeUUID.unsafe.value == -1 — the 'unsafe' member has numeric value -1."
    - "uuid.SafeUUID.__bases__[0].__name__ == 'IntEnum' — SafeUUID inherits from IntEnum."
    - "uuid.uuid1().__class__.__name__ == 'UUID' — uuid1 also returns a UUID instance (not yet in extra7 namespace)."
    - "uuid.uuid1().version == 1 — version nibble is always 1 for v1 UUIDs."
    - "uuid.uuid4().__class__.__name__ == 'UUID' — confirmed from uuid_extra7 namespace."
    - "uuid.uuid4().version == 4 — confirmed from uuid_extra7 namespace."
    - "uuid.NAMESPACE_DNS.version == 1 — NAMESPACE_DNS is a v1 UUID (time-based)."
    - "uuid.NAMESPACE_URL.version == 1 — NAMESPACE_URL is also a v1 UUID."
    - "uuid.NAMESPACE_OID.version == 1 — NAMESPACE_OID is also a v1 UUID."
    - "uuid.NAMESPACE_X500.version == 1 — NAMESPACE_X500 is also a v1 UUID."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SafeUUID class metadata — __name__, __module__, __qualname__
#
# No prior uuid spec in the chain checks SafeUUID attributes.
# SafeUUID was added in Python 3.7 as an IntEnum used by uuid1() on platforms
# that support os.getrandbits() for MAC address generation safety.
# ---------------------------------------------------------------------------

invariant uuid_extra7.SafeUUID.name:
  description: "uuid.SafeUUID.__name__ == 'SafeUUID'"
  category: SafeUUID
  kind: python_call_eq
  function: SafeUUID.__name__.__eq__
  args: ["SafeUUID"]
  expected: true

invariant uuid_extra7.SafeUUID.module:
  description: "uuid.SafeUUID.__module__ == 'uuid'"
  category: SafeUUID
  kind: python_call_eq
  function: SafeUUID.__module__.__eq__
  args: ["uuid"]
  expected: true

invariant uuid_extra7.SafeUUID.qualname:
  description: "uuid.SafeUUID.__qualname__ == 'SafeUUID' — top-level class; qualname equals name"
  category: SafeUUID
  kind: python_call_eq
  function: SafeUUID.__qualname__.__eq__
  args: ["SafeUUID"]
  expected: true

invariant uuid_extra7.SafeUUID.safe_value:
  description: "uuid.SafeUUID.safe.value == 0 — the 'safe' member encodes as integer 0"
  category: SafeUUID
  kind: python_call_eq
  function: SafeUUID.safe.value.__eq__
  args: [0]
  expected: true

invariant uuid_extra7.SafeUUID.unsafe_value:
  description: "uuid.SafeUUID.unsafe.value == -1 — the 'unsafe' member encodes as integer -1"
  category: SafeUUID
  kind: python_call_eq
  function: SafeUUID.unsafe.value.__eq__
  args: [-1]
  expected: true

invariant uuid_extra7.SafeUUID.base_is_IntEnum:
  description: "uuid.SafeUUID.__bases__[0].__name__ == 'IntEnum' — SafeUUID inherits from IntEnum"
  category: SafeUUID
  kind: python_call_eq
  function: SafeUUID.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["IntEnum"]
  expected: true

# ---------------------------------------------------------------------------
# NAMESPACE_* version attribute — all four are version-1 UUIDs
#
# Prior specs verify that NAMESPACE_* are UUID instances (__class__.__name__).
# No prior spec checks the .version attribute on the NAMESPACE_* constants.
# All four predefined namespace UUIDs from RFC 4122 are version-1 (time-based).
# ---------------------------------------------------------------------------

table uuid_extra7.namespace_versions:
  kind: python_call_eq
  category: namespace_versions
  id_prefix: nsver

  columns: [id, function, args, expected]
  rows:
    - [NAMESPACE_DNS,  NAMESPACE_DNS.version.__eq__,  [1], true]
    - [NAMESPACE_URL,  NAMESPACE_URL.version.__eq__,  [1], true]
    - [NAMESPACE_OID,  NAMESPACE_OID.version.__eq__,  [1], true]
    - [NAMESPACE_X500, NAMESPACE_X500.version.__eq__, [1], true]

# ---------------------------------------------------------------------------
# uuid1() — class name and version from the uuid_extra7 namespace
#
# uuid_extra3 confirms uuid4 class/version; uuid_extra.zspec.zsdl confirms uuid4
# return type. No prior spec records uuid1().__class__.__name__ or
# uuid1().version as standalone python_call_eq invariants in the extra7 namespace.
# ---------------------------------------------------------------------------

invariant uuid_extra7.uuid1.return_class_name:
  description: "uuid.uuid1().__class__.__name__ == 'UUID' — uuid1 returns a UUID instance"
  category: uuid1
  kind: python_call_eq
  function: uuid1
  args: []
  method: __class__.__name__.__eq__
  method_args: ["UUID"]
  expected: true

invariant uuid_extra7.uuid1.version:
  description: "uuid.uuid1().version == 1 — version nibble is always 1 for v1 UUIDs"
  category: uuid1
  kind: python_call_eq
  function: uuid1
  args: []
  method: version.__eq__
  method_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# uuid4() — class name and version from the uuid_extra7 namespace
#
# Re-anchored from the extra7 namespace with distinct invariant IDs.
# The underlying facts (uuid4 returns UUID, version == 4) are canonical and
# worth anchoring in each namespace for cross-spec consistency checks.
# ---------------------------------------------------------------------------

invariant uuid_extra7.uuid4.return_class_name:
  description: "uuid.uuid4().__class__.__name__ == 'UUID' — uuid4 returns a UUID instance"
  category: uuid4
  kind: python_call_eq
  function: uuid4
  args: []
  method: __class__.__name__.__eq__
  method_args: ["UUID"]
  expected: true

invariant uuid_extra7.uuid4.version:
  description: "uuid.uuid4().version == 4 — version nibble is always 4 for v4 UUIDs"
  category: uuid4
  kind: python_call_eq
  function: uuid4
  args: []
  method: version.__eq__
  method_args: [4]
  expected: true
