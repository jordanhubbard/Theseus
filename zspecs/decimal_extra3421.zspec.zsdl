spec: dc3421
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal: Decimal fixed-point and floating-point arithmetic"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 675 (dc3421): __hash__, __eq__, __lt__ dict-presence checks for decimal types."
    - "Classes covered: decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow."
    - "Theme: __hash__/__eq__/__lt__ dict-presence (hash(x), x==y, x<y)."
    - "decimal.Decimal defines __hash__ (true): Decimal objects are hashable."
    - "decimal.Decimal defines __eq__ (true): Decimal objects support == numeric comparison."
    - "decimal.Decimal defines __lt__ (true): Decimal objects support < numeric ordering."
    - "decimal.Context does NOT define __hash__, __eq__, or __lt__ in its own __dict__: Context is a precision/rounding configuration object."
    - "decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow are exception subclasses with no hash/equality/ordering protocol defined in their own __dict__."
    - "decimal.Decimal is unique among the covered types in this wave: it is the only type defining __hash__, __eq__, and __lt__ (all true), reflecting its status as a complete numeric type with rich comparison and hashing semantics."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __hash__ dict-presence — operator.contains(Cls.__dict__, '__hash__')
#
# decimal.Decimal DOES define __hash__ in its own __dict__: true.
# Decimal objects are hashable and can be used as dict keys or set members.
# All other decimal classes: false.
# ---------------------------------------------------------------------------

table dc3421.hash:
  description: "decimal types __hash__ dict-presence checks; wave 675"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3421

  columns: [id, function, args, expected]
  rows:
    - ["dc3421001", operator.contains, [decimal.Decimal.__dict__,          "__hash__"], true]
    - ["dc3421002", operator.contains, [decimal.Context.__dict__,           "__hash__"], false]
    - ["dc3421003", operator.contains, [decimal.DecimalException.__dict__,  "__hash__"], false]
    - ["dc3421004", operator.contains, [decimal.InvalidOperation.__dict__,  "__hash__"], false]
    - ["dc3421005", operator.contains, [decimal.Overflow.__dict__,          "__hash__"], false]
    - ["dc3421006", operator.contains, [decimal.Underflow.__dict__,         "__hash__"], false]

