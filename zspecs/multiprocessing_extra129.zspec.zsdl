invariant multiprocessing_extra129.Queue_mro_len_is_2:
  description: "multiprocessing.queues.Queue.__mro__.__len__() == 2 — multiprocessing.queues.Queue's MRO is [Queue, object]; this minimal 2-element chain reflects Queue's direct inheritance from object with no intermediate classes; contrast with asyncio.Queue (MRO=[Queue, _LoopBoundMixin, object], len=3) which has the _LoopBoundMixin intermediate; contrast also with asyncio.PriorityQueue (MRO len=4) and asyncio.LifoQueue (MRO len=4); multiprocessing.queues.Queue uses a process-safe implementation via pipes and semaphores internally without needing a mixin class; Queue.__module__ is 'multiprocessing.queues' (len=22); NEW in extra129: first standalone multiprocessing.queues.Queue MRO length invariant in mpqueuesid129 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.queues.Queue.__mro__.__len__"
  args: []
  expected: 2

invariant multiprocessing_extra129.JoinableQueue_mro_len_is_3:
  description: "multiprocessing.queues.JoinableQueue.__mro__.__len__() == 3 — JoinableQueue's MRO is [JoinableQueue, Queue, object]; this 3-element chain includes the parent Queue class from which JoinableQueue inherits all the basic queue operations (put, get, close, etc.); JoinableQueue adds join() and task_done() for worker synchronization (analogous to threading.Thread.join); JoinableQueue.__bases__[0].__name__ is 'Queue' (not 'object'); JoinableQueue.__name__.__len__() is 13; JoinableQueue.join.__qualname__ is 'JoinableQueue.join' (len=18, defined directly in JoinableQueue); NEW in extra129: first standalone JoinableQueue MRO length invariant in mpqueuesid129 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.queues.JoinableQueue.__mro__.__len__"
  args: []
  expected: 3

invariant multiprocessing_extra129.Queue_base_is_object:
  description: "multiprocessing.queues.Queue.__bases__[0].__name__.__eq__('object') returns True — multiprocessing.queues.Queue inherits directly from object with no intermediate base classes; this contrasts with JoinableQueue whose base is Queue (not object); it also contrasts with asyncio.Queue whose base is _LoopBoundMixin; multiprocessing.queues.Queue's minimal MRO (len=2) reflects this direct object inheritance; Queue.__module__ is 'multiprocessing.queues' (len=22); Queue.__name__ is 'Queue' (len=5); Queue.put.__qualname__ is 'Queue.put' (len=9); NEW in extra129: first standalone Queue base class invariant in mpqueuesid129 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.queues.Queue.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant multiprocessing_extra129.JoinableQueue_name_len_is_13:
  description: "multiprocessing.queues.JoinableQueue.__name__.__len__() == 13 — JoinableQueue.__name__ is 'JoinableQueue' (13 chars: 'Joinable'=8 + 'Queue'=5); JoinableQueue.__qualname__ is also 'JoinableQueue' (len=13, module-level class so qualname equals name); JoinableQueue.__name__.__len__()==13 matches multiprocessing.queues.Queue module name length? No — Queue.__module__.__len__()==22; compare name lengths: Queue=5, JoinableQueue=13 (difference of 8, the length of 'Joinable'); JoinableQueue.__module__ is 'multiprocessing.queues' (same as Queue); JoinableQueue.task_done.__qualname__.__len__()==23 (longest method qualname in this spec: 'JoinableQueue.'=14+'task_done'=9); NEW in extra129: first standalone JoinableQueue name length invariant in mpqueuesid129 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.queues.JoinableQueue.__name__.__len__"
  args: []
  expected: 13

invariant multiprocessing_extra129.Queue_module_len_is_22:
  description: "multiprocessing.queues.Queue.__module__.__len__() == 22 — multiprocessing.queues.Queue.__module__ is 'multiprocessing.queues' (22 chars: 'multiprocessing.'=16 + 'queues'=6); JoinableQueue.__module__ is also 'multiprocessing.queues' (same len=22) — both classes are defined in the same Lib/multiprocessing/queues.py file; compare module name lengths across queue modules: asyncio.queues=14, multiprocessing.queues=22 (eight chars longer); also compare: multiprocessing.queues is different from multiprocessing.Queue (the top-level attribute re-exported from multiprocessing/__init__.py); NEW in extra129: first standalone Queue module length invariant in mpqueuesid129 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.queues.Queue.__module__.__len__"
