    - ["sk2851002", "socket.AddressFamily.__dict__.__contains__", ["__rlshift__"], false]
    - ["sk2851003", "socket.SocketKind.__dict__.__contains__",    ["__rlshift__"], false]
    - ["sk2851004", "socket.AddressInfo.__dict__.__contains__",   ["__rlshift__"], false]
    - ["sk2851005", "socket.MsgFlag.__dict__.__contains__",       ["__rlshift__"], false]
