spec: socket_extra2851
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 637 (_extra2851): __rlshift__, __rrshift__, __rpow__ dict-presence checks for socket types."
    - "socket.socket is the main socket class (network I/O); it defines no reflected shift or power operators."
    - "socket.AddressFamily, socket.SocketKind, socket.AddressInfo, socket.MsgFlag are IntFlag/IntEnum subclasses."
    - "IntFlag/IntEnum subclasses inherit int's arithmetic operators but do NOT redefine them in their own __dict__."
    - "socket.error, socket.herror, socket.gaierror, socket.timeout are exception subclasses."
    - "Exception classes do not define reflected shift or power operators in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table sk2851.rlshift:
  description: "socket types __rlshift__ dict-presence checks; wave 637"
  kind: python_call_eq
  category: dict_contains
