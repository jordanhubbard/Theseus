spec: uuid_extra179
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "uuid.UUID.__eq__.__name__ == '__eq__' — len=6; comparison dunder."
    - "uuid.UUID.__lt__.__name__ == '__lt__' — len=6; ordering dunder."
    - "uuid.UUID.__str__.__name__ == '__str__' — len=7; string representation."
    - "uuid.UUID.__int__.__name__ == '__int__' — len=7; integer conversion."
    - "uuid.UUID.__repr__.__name__ == '__repr__' — len=8; developer representation."
    - "uuid.UUID.__hash__.__name__ == '__hash__' — len=8; hash support."
    - "uuid.UUID.__format__.__name__ == '__format__' — len=10; format protocol."
    - "uuid.UUID has no __bytes__ attribute in Python 3.14.3 on macOS/Darwin 25.4.0."
    - "Length ordering: __eq__==__lt__(6) < __str__==__int__(7) < __repr__==__hash__(8) < __format__(10)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: uuid.UUID length-6 dunder method names — __eq__ and __lt__
#
# uuid.UUID.__eq__.__name__ == '__eq__'   (len=6)
# uuid.UUID.__lt__.__name__ == '__lt__'   (len=6)
#
# These are the shortest dunder names on uuid.UUID.  Both are 6-character
# strings: two leading underscores, a two-letter verb, two trailing underscores.
# __eq__ implements equality comparison; __lt__ implements less-than ordering,
# enabling UUID objects to be sorted and used in ordered collections.
# ---------------------------------------------------------------------------

table uuid_extra179.dunder_names_len6:
  description: "uuid.UUID __eq__ and __lt__ dunder method names with length 6; new to extra179"
  kind: python_call_eq
  category: identity
  id_prefix: uuiddunder179

  columns: [id, function, args, expected, description]
  rows:
    - [eq_name_eq,
       uuid.UUID.__eq__.__name__.__eq__,
       ["__eq__"],
       true,
       "uuid.UUID.__eq__.__name__.__eq__('__eq__') == True — equality comparison dunder; len=6; new to extra179"]
    - [eq_name_len,
       uuid.UUID.__eq__.__name__.__len__,
       [],
       6,
       "uuid.UUID.__eq__.__name__.__len__() == 6 — '__eq__' has 6 characters; new to extra179"]
    - [lt_name_eq,
       uuid.UUID.__lt__.__name__.__eq__,
       ["__lt__"],
       true,
       "uuid.UUID.__lt__.__name__.__eq__('__lt__') == True — less-than ordering dunder; len=6; new to extra179"]
    - [lt_name_len,
       uuid.UUID.__lt__.__name__.__len__,
       [],
       6,
       "uuid.UUID.__lt__.__name__.__len__() == 6 — '__lt__' has 6 characters; new to extra179"]

# ---------------------------------------------------------------------------
# Table 2: uuid.UUID length-7 and length-8 dunder method names
#
# uuid.UUID.__str__.__name__   == '__str__'    (len=7)
# uuid.UUID.__int__.__name__   == '__int__'    (len=7)
# uuid.UUID.__repr__.__name__  == '__repr__'   (len=8)
# uuid.UUID.__hash__.__name__  == '__hash__'   (len=8)
#
# __str__ returns the canonical hyphenated UUID string form.
# __int__ returns the UUID as a 128-bit integer.
# __repr__ returns a constructor-style representation.
# __hash__ makes UUID hashable for use in sets and as dict keys.
# ---------------------------------------------------------------------------

table uuid_extra179.dunder_names_len7_len8:
  description: "uuid.UUID dunder method names with lengths 7 and 8; new to extra179"
  kind: python_call_eq
  category: identity
  id_prefix: uuiddunder179

  columns: [id, function, args, expected, description]
  rows:
    - [str_name_eq,
       uuid.UUID.__str__.__name__.__eq__,
       ["__str__"],
       true,
       "uuid.UUID.__str__.__name__.__eq__('__str__') == True — string representation dunder; len=7; new to extra179"]
    - [str_name_len,
       uuid.UUID.__str__.__name__.__len__,
       [],
       7,
       "uuid.UUID.__str__.__name__.__len__() == 7 — '__str__' has 7 characters; new to extra179"]
    - [int_name_eq,
       uuid.UUID.__int__.__name__.__eq__,
       ["__int__"],
       true,
       "uuid.UUID.__int__.__name__.__eq__('__int__') == True — integer conversion dunder; len=7; new to extra179"]
    - [int_name_len,
       uuid.UUID.__int__.__name__.__len__,
       [],
       7,
       "uuid.UUID.__int__.__name__.__len__() == 7 — '__int__' has 7 characters; new to extra179"]
    - [repr_name_eq,
       uuid.UUID.__repr__.__name__.__eq__,
       ["__repr__"],
       true,
       "uuid.UUID.__repr__.__name__.__eq__('__repr__') == True — developer representation dunder; len=8; new to extra179"]
    - [repr_name_len,
       uuid.UUID.__repr__.__name__.__len__,
       [],
       8,
       "uuid.UUID.__repr__.__name__.__len__() == 8 — '__repr__' has 8 characters; new to extra179"]
    - [hash_name_eq,
       uuid.UUID.__hash__.__name__.__eq__,
       ["__hash__"],
       true,
       "uuid.UUID.__hash__.__name__.__eq__('__hash__') == True — hash support dunder; len=8; new to extra179"]
    - [hash_name_len,
       uuid.UUID.__hash__.__name__.__len__,
       [],
       8,
       "uuid.UUID.__hash__.__name__.__len__() == 8 — '__hash__' has 8 characters; new to extra179"]

# ---------------------------------------------------------------------------
# Table 3: uuid.UUID length-10 dunder method name — __format__
#
# uuid.UUID.__format__.__name__ == '__format__'   (len=10)
#
# __format__ implements the format protocol used by str.format() and f-strings.
# At len=10 it is the longest dunder name tested here, extending the ordering:
# 6 < 7 < 8 < 10.
# ---------------------------------------------------------------------------

table uuid_extra179.dunder_names_len10:
  description: "uuid.UUID __format__ dunder method name with length 10; new to extra179"
  kind: python_call_eq
  category: identity
  id_prefix: uuiddunder179

  columns: [id, function, args, expected, description]
  rows:
    - [format_name_eq,
       uuid.UUID.__format__.__name__.__eq__,
       ["__format__"],
       true,
       "uuid.UUID.__format__.__name__.__eq__('__format__') == True — format protocol dunder; len=10; new to extra179"]
    - [format_name_len,
       uuid.UUID.__format__.__name__.__len__,
       [],
       10,
       "uuid.UUID.__format__.__name__.__len__() == 10 — '__format__' has 10 characters; new to extra179"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra179
# ---------------------------------------------------------------------------

invariant uuid_extra179.eq_name_is_eq:
  description: "uuid.UUID.__eq__.__name__ == '__eq__' — equality comparison dunder; len=6; new to extra179"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.__eq__.__name__.__eq__
  args: ["__eq__"]
  expected: true

invariant uuid_extra179.lt_name_is_lt:
  description: "uuid.UUID.__lt__.__name__ == '__lt__' — less-than ordering dunder; len=6; new to extra179"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.__lt__.__name__.__eq__
  args: ["__lt__"]
  expected: true

invariant uuid_extra179.str_name_is_str:
  description: "uuid.UUID.__str__.__name__ == '__str__' — string representation dunder; len=7; new to extra179"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.__str__.__name__.__eq__
  args: ["__str__"]
  expected: true

invariant uuid_extra179.int_name_is_int:
  description: "uuid.UUID.__int__.__name__ == '__int__' — integer conversion dunder; len=7; new to extra179"
  category: identity
