  args: ["__repr__"]
  expected: true

invariant uuid_extra179.hash_name_is_hash:
  description: "uuid.UUID.__hash__.__name__ == '__hash__' — hash support for sets and dict keys; len=8; new to extra179"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.__hash__.__name__.__eq__
  args: ["__hash__"]
  expected: true

invariant uuid_extra179.format_name_is_format:
  description: "uuid.UUID.__format__.__name__ == '__format__' — format protocol dunder; len=10; new to extra179"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.__format__.__name__.__eq__
  args: ["__format__"]
  expected: true
