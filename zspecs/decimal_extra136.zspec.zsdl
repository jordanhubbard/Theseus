spec: decimal_extra136
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal wrapper_descriptor identity for comparison operators (__hash__, __eq__, __lt__, __le__, __gt__, __ge__) and type-conversion operators (__bool__, __float__, __int__) and unary operators (__abs__, __neg__, __pos__)."
    - "All covered operators are wrapper_descriptor instances (C slot wrappers), not method_descriptor."
    - "Decimal.__hash__.__class__.__name__ == 'wrapper_descriptor'; __qualname__ == 'Decimal.__hash__' (15)."
    - "Decimal.__eq__.__class__.__name__ == 'wrapper_descriptor'; __qualname__ == 'Decimal.__eq__' (14)."
    - "Decimal.__lt__/__le__/__gt__/__ge__ are all wrapper_descriptor; qualnames 13, 13, 13, 13 characters."
    - "Decimal.__bool__/__float__/__int__ are wrapper_descriptor; qualnames 15, 16, 14 characters."
    - "Decimal.__abs__/__neg__/__pos__ are wrapper_descriptor; qualnames 14, 14, 14 characters."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal comparison operator wrapper_descriptor identity
# __hash__, __eq__, __lt__, __le__, __gt__, __ge__ are all wrapper_descriptor.
# __hash__.__qualname__ == 'Decimal.__hash__' (16 chars).
# __eq__.__qualname__ == 'Decimal.__eq__' (14 chars).
# __lt__/__le__/__gt__/__ge__ qualnames are each 14/14/14/14 chars.
# ---------------------------------------------------------------------------

table decimal_extra136.Decimal_comparison_ops_identity:
  description: "decimal.Decimal comparison operators are wrapper_descriptor: __hash__, __eq__, __lt__, __le__, __gt__, __ge__; all have __class__.__name__='wrapper_descriptor'"
  kind: python_call_eq
  category: wrapper_descriptor
  id_prefix: decdec136

  columns: [id, function, args, expected]
  rows:
    - [hash_cls_eq,  "Decimal.__hash__.__class__.__name__.__eq__",  ["wrapper_descriptor"], true]
    - [eq_cls_eq,    "Decimal.__eq__.__class__.__name__.__eq__",    ["wrapper_descriptor"], true]
    - [lt_cls_eq,    "Decimal.__lt__.__class__.__name__.__eq__",    ["wrapper_descriptor"], true]
    - [le_cls_eq,    "Decimal.__le__.__class__.__name__.__eq__",    ["wrapper_descriptor"], true]
    - [gt_cls_eq,    "Decimal.__gt__.__class__.__name__.__eq__",    ["wrapper_descriptor"], true]
    - [ge_cls_eq,    "Decimal.__ge__.__class__.__name__.__eq__",    ["wrapper_descriptor"], true]
    - [hash_qn_eq,   "Decimal.__hash__.__qualname__.__eq__",        ["Decimal.__hash__"],   true]
    - [hash_qn_len,  "Decimal.__hash__.__qualname__.__len__",       [],                     16]
    - [eq_qn_eq,     "Decimal.__eq__.__qualname__.__eq__",          ["Decimal.__eq__"],     true]
    - [eq_qn_len,    "Decimal.__eq__.__qualname__.__len__",         [],                     14]
    - [lt_qn_eq,     "Decimal.__lt__.__qualname__.__eq__",          ["Decimal.__lt__"],     true]
    - [lt_qn_len,    "Decimal.__lt__.__qualname__.__len__",         [],                     14]

# ---------------------------------------------------------------------------
# decimal.Decimal type-conversion wrapper_descriptor identity
# __bool__, __float__, __int__ are all wrapper_descriptor.
# __bool__.__qualname__ == 'Decimal.__bool__' (15 chars).
# __float__.__qualname__ == 'Decimal.__float__' (17 chars).
# __int__.__qualname__ == 'Decimal.__int__' (15 chars).
# ---------------------------------------------------------------------------

table decimal_extra136.Decimal_conversion_ops_identity:
  description: "decimal.Decimal type-conversion operators are wrapper_descriptor: __bool__, __float__, __int__; qualname lengths 15, 17, 15"
  kind: python_call_eq
  category: wrapper_descriptor
  id_prefix: decdec136

  columns: [id, function, args, expected]
  rows:
    - [bool_cls_eq,    "Decimal.__bool__.__class__.__name__.__eq__",   ["wrapper_descriptor"], true]
    - [float_cls_eq,   "Decimal.__float__.__class__.__name__.__eq__",  ["wrapper_descriptor"], true]
    - [int_cls_eq,     "Decimal.__int__.__class__.__name__.__eq__",    ["wrapper_descriptor"], true]
    - [bool_qn_eq,     "Decimal.__bool__.__qualname__.__eq__",         ["Decimal.__bool__"],   true]
    - [bool_qn_len,    "Decimal.__bool__.__qualname__.__len__",        [],                     15]
    - [float_qn_eq,    "Decimal.__float__.__qualname__.__eq__",        ["Decimal.__float__"],  true]
    - [float_qn_len,   "Decimal.__float__.__qualname__.__len__",       [],                     17]
    - [int_qn_eq,      "Decimal.__int__.__qualname__.__eq__",          ["Decimal.__int__"],    true]
    - [int_qn_len,     "Decimal.__int__.__qualname__.__len__",         [],                     15]

# ---------------------------------------------------------------------------
# decimal.Decimal unary arithmetic wrapper_descriptor identity
# __abs__, __neg__, __pos__ are all wrapper_descriptor.
# __abs__.__qualname__ == 'Decimal.__abs__' (15 chars).
# __neg__.__qualname__ == 'Decimal.__neg__' (15 chars).
# __pos__.__qualname__ == 'Decimal.__pos__' (15 chars).
# ---------------------------------------------------------------------------

table decimal_extra136.Decimal_unary_ops_identity:
  description: "decimal.Decimal unary operators are wrapper_descriptor: __abs__, __neg__, __pos__; all qualname length 15"
  kind: python_call_eq
  category: wrapper_descriptor
  id_prefix: decdec136

  columns: [id, function, args, expected]
  rows:
    - [abs_cls_eq,   "Decimal.__abs__.__class__.__name__.__eq__",  ["wrapper_descriptor"], true]
    - [neg_cls_eq,   "Decimal.__neg__.__class__.__name__.__eq__",  ["wrapper_descriptor"], true]
    - [pos_cls_eq,   "Decimal.__pos__.__class__.__name__.__eq__",  ["wrapper_descriptor"], true]
    - [abs_qn_eq,    "Decimal.__abs__.__qualname__.__eq__",        ["Decimal.__abs__"],    true]
    - [abs_qn_len,   "Decimal.__abs__.__qualname__.__len__",       [],                     15]
    - [neg_qn_eq,    "Decimal.__neg__.__qualname__.__eq__",        ["Decimal.__neg__"],    true]
    - [neg_qn_len,   "Decimal.__neg__.__qualname__.__len__",       [],                     15]
    - [pos_qn_eq,    "Decimal.__pos__.__qualname__.__eq__",        ["Decimal.__pos__"],    true]
    - [pos_qn_len,   "Decimal.__pos__.__qualname__.__len__",       [],                     15]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra136.Decimal.__hash__is_wrapper_descriptor:
  description: "decimal.Decimal.__hash__.__class__.__name__ == 'wrapper_descriptor' (not method_descriptor; __hash__ is implemented via the tp_hash C slot wrapper, required for use as a dict key or set member)"
  category: wrapper_descriptor
  kind: python_call_eq
  function: "Decimal.__hash__.__class__.__name__.__eq__"
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra136.Decimal.__bool__is_wrapper_descriptor:
  description: "decimal.Decimal.__bool__.__class__.__name__ == 'wrapper_descriptor' (bool conversion is a C slot wrapper via tp_as_number->nb_bool; Decimal.__bool__() returns False only for Decimal('0') and Decimal('0.0'))"
  category: wrapper_descriptor
  kind: python_call_eq
  function: "Decimal.__bool__.__class__.__name__.__eq__"
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra136.Decimal.__float__qualname_len_17:
  description: "decimal.Decimal.__float__.__qualname__.__len__() == 17 ('Decimal.__float__' has 17 characters; one more than __bool__ (15) and __int__ (15) because '__float__' is one character longer than '__bool__' and '__int__')"
  category: wrapper_descriptor
  kind: python_call_eq
  function: "Decimal.__float__.__qualname__.__len__"
  args: []
  expected: 17

invariant decimal_extra136.Decimal.__hash__qualname_len_16:
  description: "decimal.Decimal.__hash__.__qualname__.__len__() == 16 ('Decimal.__hash__' has 16 characters; one more than __eq__ (14) and one fewer than __float__ (17))"
  category: wrapper_descriptor
  kind: python_call_eq
  function: "Decimal.__hash__.__qualname__.__len__"
  args: []
  expected: 16

invariant decimal_extra136.Decimal.__abs__is_wrapper_descriptor:
  description: "decimal.Decimal.__abs__.__class__.__name__ == 'wrapper_descriptor' (unary absolute value is a C slot wrapper via nb_absolute; for Decimal, abs() returns the magnitude and always yields a positive or zero Decimal)"
  category: wrapper_descriptor
  kind: python_call_eq
  function: "Decimal.__abs__.__class__.__name__.__eq__"
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra136.Decimal.__neg__qualname_len_15:
  description: "decimal.Decimal.__neg__.__qualname__.__len__() == 15 ('Decimal.__neg__' has 15 characters; same length as __abs__ and __pos__ (both 15) — all three unary operators share this qualname length)"
  category: wrapper_descriptor
  kind: python_call_eq
  function: "Decimal.__neg__.__qualname__.__len__"
  args: []
  expected: 15
