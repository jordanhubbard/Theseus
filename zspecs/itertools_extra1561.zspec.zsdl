spec: itertools_extra1561
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "Wave 551 theme: numeric type conversion protocol dict-presence checks via __dict__.__contains__ for itertools classes."
    - "itertools.chain.__dict__.__contains__ returns False for all numeric dunder methods. chain is a C extension type; it is an iterator combiner with no numeric conversion semantics. Verified with Python 3.14."
    - "itertools.count.__dict__.__contains__ returns False for all numeric dunder methods. count is a C extension type that produces arithmetic sequences; its __dict__ does not include any numeric conversion protocol dunders. Verified with Python 3.14."
    - "itertools.cycle.__dict__.__contains__ returns False for all numeric dunder methods. cycle is a C extension iterator type; numeric conversion protocol dunders are absent from its __dict__. Verified with Python 3.14."
    - "itertools.accumulate.__dict__.__contains__ returns False for all numeric dunder methods. accumulate is a C extension type; no numeric conversion operators in its own __dict__. Verified with Python 3.14."
    - "itertools.combinations.__dict__.__contains__ returns False for all numeric dunder methods. combinations is a C extension type producing combinatorial sequences; it defines no numeric protocol. Verified with Python 3.14."
    - "Numeric dunders checked: __bool__, __int__, __float__, __complex__, __index__, __trunc__, __floor__, __ceil__, __round__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.chain — numeric type conversion protocol dict-presence checks
#
# Wave 551 theme: chain is a C extension type (Modules/itertoolsmodule.c).
# Its own __dict__ does not contain any numeric conversion dunder methods.
# chain is a sequence combiner; numeric type conversion is semantically inapplicable.
# ---------------------------------------------------------------------------

table itertools_extra1561.chain_numeric_dict_contains:
  description: "itertools.chain.__dict__.__contains__ returns False for all numeric type conversion dunders; wave 551; new to extra1561"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1561ch

  columns: [id, function, args, expected, description]
  rows:
    - ["it1561ch001",
       "chain.__dict__.__contains__",
       ["__bool__"],
       false,
       "itertools.chain.__dict__.__contains__('__bool__') == False — chain is a C extension type; its __dict__ does not define __bool__; wave 551; new to extra1561"]
    - ["it1561ch002",
       "chain.__dict__.__contains__",
       ["__int__"],
       false,
       "itertools.chain.__dict__.__contains__('__int__') == False — chain does not define __int__ in its own class __dict__; wave 551; new to extra1561"]
    - ["it1561ch003",
       "chain.__dict__.__contains__",
       ["__float__"],
       false,
       "itertools.chain.__dict__.__contains__('__float__') == False — chain does not define __float__ in its own class __dict__; wave 551; new to extra1561"]
    - ["it1561ch004",
       "chain.__dict__.__contains__",
       ["__complex__"],
       false,
       "itertools.chain.__dict__.__contains__('__complex__') == False — chain does not define __complex__ in its own class __dict__; wave 551; new to extra1561"]
    - ["it1561ch005",
       "chain.__dict__.__contains__",
       ["__index__"],
       false,
       "itertools.chain.__dict__.__contains__('__index__') == False — chain does not define __index__ in its own class __dict__; wave 551; new to extra1561"]
    - ["it1561ch006",
       "chain.__dict__.__contains__",
       ["__trunc__"],
       false,
       "itertools.chain.__dict__.__contains__('__trunc__') == False — chain does not define __trunc__ in its own class __dict__; wave 551; new to extra1561"]
    - ["it1561ch007",
       "chain.__dict__.__contains__",
       ["__floor__"],
       false,
       "itertools.chain.__dict__.__contains__('__floor__') == False — chain does not define __floor__ in its own class __dict__; wave 551; new to extra1561"]
    - ["it1561ch008",
       "chain.__dict__.__contains__",
       ["__ceil__"],
       false,
       "itertools.chain.__dict__.__contains__('__ceil__') == False — chain does not define __ceil__ in its own class __dict__; wave 551; new to extra1561"]
    - ["it1561ch009",
       "chain.__dict__.__contains__",
       ["__round__"],
       false,
       "itertools.chain.__dict__.__contains__('__round__') == False — chain does not define __round__ in its own class __dict__; wave 551; new to extra1561"]

