spec: socket_extra1966
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/socket.html"
    - "CPython source: Lib/socket.py, Modules/_socket.c"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 1966 (_extra1966): __enter__/__exit__, __aenter__/__aexit__, __del__ dict-presence checks."
    - "socket.socket defines __enter__ and __exit__ (socket objects are context managers)."
    - "socket.SocketType is _socket.socket (the C-level type); it does NOT define __enter__/__exit__ but DOES define __del__."
    - "socket.socket (Python-level wrapper) does NOT define __del__ in its own __dict__."
    - "socket.error, socket.timeout, socket.gaierror, socket.herror do not define context manager protocol."
    - "socket.AddressFamily and socket.SocketKind (IntEnum subclasses) do not define context manager protocol."
    - "No socket type defines __aenter__ or __aexit__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table socket_extra1966.context_manager_protocol:
  description: "socket.socket __enter__/__exit__ dict-presence checks (socket IS a context manager)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1966

  columns: [id, function, args, expected]
  rows:
    - ["sk1966001", "socket.socket.__dict__.__contains__", ["__enter__"], true]
    - ["sk1966002", "socket.socket.__dict__.__contains__", ["__exit__"], true]
    - ["sk1966003", "socket.error.__dict__.__contains__", ["__enter__"], false]
    - ["sk1966004", "socket.error.__dict__.__contains__", ["__exit__"], false]
    - ["sk1966005", "socket.timeout.__dict__.__contains__", ["__enter__"], false]
    - ["sk1966006", "socket.timeout.__dict__.__contains__", ["__exit__"], false]
    - ["sk1966007", "socket.gaierror.__dict__.__contains__", ["__enter__"], false]
    - ["sk1966008", "socket.gaierror.__dict__.__contains__", ["__exit__"], false]
    - ["sk1966009", "socket.herror.__dict__.__contains__", ["__enter__"], false]
    - ["sk1966010", "socket.herror.__dict__.__contains__", ["__exit__"], false]

table socket_extra1966.sockettype_finalizer:
  description: "socket.SocketType __del__ dict-presence check (C-level socket defines __del__)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1966

  columns: [id, function, args, expected]
  rows:
    - ["sk1966011", "socket.SocketType.__dict__.__contains__", ["__del__"], true]
    - ["sk1966012", "socket.socket.__dict__.__contains__", ["__del__"], false]
    - ["sk1966013", "socket.error.__dict__.__contains__", ["__del__"], false]
    - ["sk1966014", "socket.timeout.__dict__.__contains__", ["__del__"], false]
    - ["sk1966015", "socket.gaierror.__dict__.__contains__", ["__del__"], false]
    - ["sk1966016", "socket.herror.__dict__.__contains__", ["__del__"], false]

table socket_extra1966.async_context_manager_protocol:
  description: "socket types __aenter__/__aexit__ dict-presence checks (none define async CM)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1966

  columns: [id, function, args, expected]
  rows:
    - ["sk1966017", "socket.socket.__dict__.__contains__", ["__aenter__"], false]
    - ["sk1966018", "socket.socket.__dict__.__contains__", ["__aexit__"], false]
    - ["sk1966019", "socket.error.__dict__.__contains__", ["__aenter__"], false]
    - ["sk1966020", "socket.error.__dict__.__contains__", ["__aexit__"], false]
    - ["sk1966021", "socket.timeout.__dict__.__contains__", ["__aenter__"], false]
    - ["sk1966022", "socket.timeout.__dict__.__contains__", ["__aexit__"], false]
    - ["sk1966023", "socket.gaierror.__dict__.__contains__", ["__aenter__"], false]
    - ["sk1966024", "socket.gaierror.__dict__.__contains__", ["__aexit__"], false]
    - ["sk1966025", "socket.herror.__dict__.__contains__", ["__aenter__"], false]
    - ["sk1966026", "socket.herror.__dict__.__contains__", ["__aexit__"], false]

table socket_extra1966.enum_types_protocol:
  description: "socket.AddressFamily and socket.SocketKind context manager and finalizer absence"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1966

  columns: [id, function, args, expected]
  rows:
    - ["sk1966027", "socket.AddressFamily.__dict__.__contains__", ["__enter__"], false]
    - ["sk1966028", "socket.AddressFamily.__dict__.__contains__", ["__exit__"], false]
    - ["sk1966029", "socket.AddressFamily.__dict__.__contains__", ["__aenter__"], false]
    - ["sk1966030", "socket.AddressFamily.__dict__.__contains__", ["__aexit__"], false]
    - ["sk1966031", "socket.AddressFamily.__dict__.__contains__", ["__del__"], false]
    - ["sk1966032", "socket.SocketKind.__dict__.__contains__", ["__enter__"], false]
    - ["sk1966033", "socket.SocketKind.__dict__.__contains__", ["__exit__"], false]
    - ["sk1966034", "socket.SocketKind.__dict__.__contains__", ["__aenter__"], false]
    - ["sk1966035", "socket.SocketKind.__dict__.__contains__", ["__aexit__"], false]
    - ["sk1966036", "socket.SocketKind.__dict__.__contains__", ["__del__"], false]
