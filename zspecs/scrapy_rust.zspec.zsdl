spec: scrapy_rust
version: ">=3.9"
backend: rust_module(scrapy_rust)

docs: https://docs.scrapy.org/en/latest/

provenance:
  derived_from:
    - "https://docs.scrapy.org/en/latest/ — Scrapy documentation"
  not_derived_from:
    - "scrapy source: scrapy/__init__.py"
  notes:
    - "Scrapy is a web scraping framework for Python."
    - "scrapy.Spider is available as a class."
    - "scrapy.Spider.__name__ == 'Spider'."
    - "scrapy.http.Request is available."
    - "scrapy.http.Response is available."
    - "scrapy.__version__ is a non-empty string."
    - "Expose scrapy_spider_name() -> str: scrapy.Spider.__name__."
    - "Expose scrapy_has_http() -> bool: hasattr(scrapy, 'http')."
    - "Expose scrapy_version_nonempty() -> bool: len(scrapy.__version__) > 0."
    - "All test vectors verified against scrapy 2.13.1."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# scrapy_spider_name — Spider class name
invariant scrapy_rust.spider.class_name:
  description: "scrapy.Spider.__name__ == 'Spider'"
  category: spider
  kind: python_call_eq
  function: scrapy_spider_name
  args: []
  expected: "Spider"

# scrapy_has_http — http module present
invariant scrapy_rust.module.has_http:
  description: "scrapy.http is available"
  category: module
  kind: python_call_eq
  function: scrapy_has_http
  args: []
  expected: true

# scrapy_version_nonempty — version non-empty
invariant scrapy_rust.version.nonempty:
  description: "scrapy.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: scrapy_version_nonempty
  args: []
  expected: true

