spec: io_extra220
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra219.zspec.zsdl — covers io class __doc__ contains checks (different words)"
  notes:
    - "io.BytesIO.__doc__.__contains__('buffer') == True; doc: 'Buffered I/O implementation using an in-memory bytes buffer.'; confirmed Python 3.14.3 macOS."
    - "io.StringIO.__doc__.__contains__('buffer') == True; doc mentions in-memory buffer; confirmed Python 3.14.3 macOS."
    - "io.StringIO.__doc__.__contains__('initial') == False; substring 'initial' does not appear standalone; confirmed Python 3.14.3 macOS."
    - "io.BufferedReader.__doc__.__contains__('raw') == True; doc says 'readable raw IO object'; confirmed Python 3.14.3 macOS."
    - "io.BufferedWriter.__doc__.__contains__('raw') == True; doc mentions 'sequential RawIO object'; confirmed Python 3.14.3 macOS."
    - "io.TextIOWrapper.__doc__.__contains__('encoding') == True; doc mentions the encoding parameter; confirmed Python 3.14.3 macOS."
    - "io.TextIOWrapper.__doc__.__contains__('newline') == True; doc mentions newline handling; confirmed Python 3.14.3 macOS."
    - "io.FileIO.__doc__.__contains__('mode') == True; doc describes the mode parameter; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __doc__ contains checks for in-memory I/O classes (new words)
# BytesIO and StringIO __doc__ string substring membership — different words
# ---------------------------------------------------------------------------

table io_extra220.memory_io_doc_contains_extra:
  description: "io.BytesIO and io.StringIO __doc__ string contains additional expected substrings"
  kind: python_call_eq
  category: identity
  id_prefix: iodoccontains220a

  columns: [id, function, args, expected, description]
  rows:
    - [bytesio_doc_contains_buffer,       io.BytesIO.__doc__.__contains__,   ["buffer"],    true,  "io.BytesIO.__doc__.__contains__('buffer') == True; doc says 'in-memory bytes buffer'; confirmed Python 3.14.3 macOS"]
    - [bytesio_doc_contains_Buffered,     io.BytesIO.__doc__.__contains__,   ["Buffered"],  true,  "io.BytesIO.__doc__.__contains__('Buffered') == True; doc starts with 'Buffered I/O implementation'; confirmed Python 3.14.3 macOS"]
    - [bytesio_doc_contains_memory,       io.BytesIO.__doc__.__contains__,   ["memory"],    true,  "io.BytesIO.__doc__.__contains__('memory') == True; doc says 'in-memory bytes buffer'; confirmed Python 3.14.3 macOS"]
    - [stringio_doc_contains_buffer,      io.StringIO.__doc__.__contains__,  ["buffer"],    true,  "io.StringIO.__doc__.__contains__('buffer') == True; doc says 'in-memory buffer'; confirmed Python 3.14.3 macOS"]
    - [stringio_doc_contains_initial_val, io.StringIO.__doc__.__contains__,  ["initial_value"], true, "io.StringIO.__doc__.__contains__('initial_value') == True; doc mentions the initial_value argument; confirmed Python 3.14.3 macOS"]
    - [stringio_doc_contains_newline,     io.StringIO.__doc__.__contains__,  ["newline"],   true,  "io.StringIO.__doc__.__contains__('newline') == True; doc mentions newline argument; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: __doc__ contains checks for buffered I/O classes (new words)
# BufferedReader and BufferedWriter __doc__ string substring membership
# ---------------------------------------------------------------------------

table io_extra220.buffered_io_doc_contains_extra:
  description: "io.BufferedReader and io.BufferedWriter __doc__ string contains additional expected substrings"
  kind: python_call_eq
  category: identity
  id_prefix: iodoccontains220b

  columns: [id, function, args, expected, description]
  rows:
    - [bufferedreader_doc_contains_raw,        io.BufferedReader.__doc__.__contains__, ["raw"],        true, "io.BufferedReader.__doc__.__contains__('raw') == True; doc says 'readable raw IO object'; confirmed Python 3.14.3 macOS"]
    - [bufferedreader_doc_contains_buffered,   io.BufferedReader.__doc__.__contains__, ["buffered"],   true, "io.BufferedReader.__doc__.__contains__('buffered') == True; doc says 'new buffered reader'; confirmed Python 3.14.3 macOS"]
    - [bufferedreader_doc_contains_IO,         io.BufferedReader.__doc__.__contains__, ["IO"],         true, "io.BufferedReader.__doc__.__contains__('IO') == True; doc mentions 'raw IO object'; confirmed Python 3.14.3 macOS"]
    - [bufferedreader_doc_contains_object,     io.BufferedReader.__doc__.__contains__, ["object"],     true, "io.BufferedReader.__doc__.__contains__('object') == True; doc mentions IO object; confirmed Python 3.14.3 macOS"]
    - [bufferedwriter_doc_contains_raw,        io.BufferedWriter.__doc__.__contains__, ["raw"],        true, "io.BufferedWriter.__doc__.__contains__('raw') == True; doc mentions 'sequential RawIO object'; confirmed Python 3.14.3 macOS"]
    - [bufferedwriter_doc_contains_writeable,  io.BufferedWriter.__doc__.__contains__, ["writeable"],  true, "io.BufferedWriter.__doc__.__contains__('writeable') == True; doc says 'writeable sequential RawIO object'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: __doc__ contains checks for TextIOWrapper and FileIO (new words)
# TextIOWrapper and FileIO __doc__ string substring membership
# ---------------------------------------------------------------------------

table io_extra220.text_and_fileio_doc_contains_extra:
  description: "io.TextIOWrapper and io.FileIO __doc__ string contains additional expected substrings"
  kind: python_call_eq
  category: identity
  id_prefix: iodoccontains220c

  columns: [id, function, args, expected, description]
  rows:
    - [textiowrapper_doc_contains_encoding, io.TextIOWrapper.__doc__.__contains__, ["encoding"], true, "io.TextIOWrapper.__doc__.__contains__('encoding') == True; doc describes the encoding parameter; confirmed Python 3.14.3 macOS"]
    - [textiowrapper_doc_contains_newline,  io.TextIOWrapper.__doc__.__contains__, ["newline"],  true, "io.TextIOWrapper.__doc__.__contains__('newline') == True; doc describes newline handling; confirmed Python 3.14.3 macOS"]
    - [textiowrapper_doc_contains_line,     io.TextIOWrapper.__doc__.__contains__, ["line"],     true, "io.TextIOWrapper.__doc__.__contains__('line') == True; doc says 'Character and line based layer'; confirmed Python 3.14.3 macOS"]
    - [textiowrapper_doc_contains_name,     io.TextIOWrapper.__doc__.__contains__, ["name"],     true, "io.TextIOWrapper.__doc__.__contains__('name') == True; doc describes the name of the encoding; confirmed Python 3.14.3 macOS"]
    - [fileio_doc_contains_mode,            io.FileIO.__doc__.__contains__,        ["mode"],     true, "io.FileIO.__doc__.__contains__('mode') == True; doc describes the mode parameter; confirmed Python 3.14.3 macOS"]
    - [fileio_doc_contains_Open,            io.FileIO.__doc__.__contains__,        ["Open"],     true, "io.FileIO.__doc__.__contains__('Open') == True; doc starts with 'Open a file.'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra220.bytesio_doc_contains_buffer:
  description: "io.BytesIO.__doc__.__contains__('buffer') == True — BytesIO doc says 'in-memory bytes buffer'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.BytesIO.__doc__.__contains__
  args: ["buffer"]
  expected: true

invariant io_extra220.stringio_doc_contains_buffer:
  description: "io.StringIO.__doc__.__contains__('buffer') == True — StringIO doc says 'in-memory buffer'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.StringIO.__doc__.__contains__
  args: ["buffer"]
  expected: true

invariant io_extra220.bufferedreader_doc_contains_raw:
  description: "io.BufferedReader.__doc__.__contains__('raw') == True — BufferedReader doc says 'readable raw IO object'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.BufferedReader.__doc__.__contains__
  args: ["raw"]
  expected: true

invariant io_extra220.bufferedwriter_doc_contains_raw:
  description: "io.BufferedWriter.__doc__.__contains__('raw') == True — BufferedWriter doc mentions sequential RawIO object; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.BufferedWriter.__doc__.__contains__
  args: ["raw"]
  expected: true

invariant io_extra220.textiowrapper_doc_contains_encoding:
  description: "io.TextIOWrapper.__doc__.__contains__('encoding') == True — TextIOWrapper doc describes the encoding parameter; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.TextIOWrapper.__doc__.__contains__
  args: ["encoding"]
  expected: true

invariant io_extra220.textiowrapper_doc_contains_newline:
  description: "io.TextIOWrapper.__doc__.__contains__('newline') == True — TextIOWrapper doc describes newline handling; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.TextIOWrapper.__doc__.__contains__
  args: ["newline"]
  expected: true

invariant io_extra220.fileio_doc_contains_mode:
  description: "io.FileIO.__doc__.__contains__('mode') == True — FileIO doc describes the mode parameter; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.FileIO.__doc__.__contains__
  args: ["mode"]
  expected: true
