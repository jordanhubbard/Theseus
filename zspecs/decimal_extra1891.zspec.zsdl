spec: decimal_extra1891
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "Tests unary arithmetic protocol, async iteration protocol, __fspath__, and decimal sign/special methods"
    - "decimal.Decimal implements the full unary arithmetic protocol: __abs__, __neg__, __pos__, __round__, __floor__, __ceil__, __trunc__"
    - "decimal.Context does not implement unary arithmetic dunder methods"
    - "None of the decimal types implement async iteration or __fspath__"
    - "Decimal.is_signed, is_zero, is_nan, is_snan, is_qnan, is_infinite, is_finite, is_normal, is_subnormal, is_canonical are all defined in Decimal.__dict__"
  created_at: "2026-04-12"

table decimal_extra1891.unary_arithmetic:
  columns: [id, function, args, expected]
  rows:
    - ["dc1891-ua-001", "decimal.Decimal.__dict__.__contains__", ["__abs__"], true]
    - ["dc1891-ua-002", "decimal.Decimal.__dict__.__contains__", ["__neg__"], true]
    - ["dc1891-ua-003", "decimal.Decimal.__dict__.__contains__", ["__pos__"], true]
    - ["dc1891-ua-004", "decimal.Decimal.__dict__.__contains__", ["__round__"], true]
    - ["dc1891-ua-005", "decimal.Decimal.__dict__.__contains__", ["__floor__"], true]
    - ["dc1891-ua-006", "decimal.Decimal.__dict__.__contains__", ["__ceil__"], true]
    - ["dc1891-ua-007", "decimal.Decimal.__dict__.__contains__", ["__trunc__"], true]
    - ["dc1891-ua-008", "decimal.Context.__dict__.__contains__", ["__abs__"], false]

table decimal_extra1891.fspath_aiter_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["dc1891-fa-001", "decimal.Decimal.__dict__.__contains__", ["__fspath__"], false]
    - ["dc1891-fa-002", "decimal.Decimal.__dict__.__contains__", ["__aiter__"], false]
    - ["dc1891-fa-003", "decimal.Decimal.__dict__.__contains__", ["__anext__"], false]
    - ["dc1891-fa-004", "decimal.Context.__dict__.__contains__", ["__fspath__"], false]
    - ["dc1891-fa-005", "decimal.Context.__dict__.__contains__", ["__aiter__"], false]
    - ["dc1891-fa-006", "decimal.DecimalException.__dict__.__contains__", ["__fspath__"], false]
    - ["dc1891-fa-007", "decimal.Decimal.__dict__.__contains__", ["__length_hint__"], false]
    - ["dc1891-fa-008", "decimal.Context.__dict__.__contains__", ["__length_hint__"], false]

table decimal_extra1891.decimal_sign_special_methods:
  columns: [id, function, args, expected]
  rows:
    - ["dc1891-sm-001", "decimal.Decimal.__dict__.__contains__", ["is_signed"], true]
    - ["dc1891-sm-002", "decimal.Decimal.__dict__.__contains__", ["is_zero"], true]
    - ["dc1891-sm-003", "decimal.Decimal.__dict__.__contains__", ["is_nan"], true]
    - ["dc1891-sm-004", "decimal.Decimal.__dict__.__contains__", ["is_snan"], true]
    - ["dc1891-sm-005", "decimal.Decimal.__dict__.__contains__", ["is_qnan"], true]
    - ["dc1891-sm-006", "decimal.Decimal.__dict__.__contains__", ["is_infinite"], true]
    - ["dc1891-sm-007", "decimal.Decimal.__dict__.__contains__", ["is_finite"], true]
    - ["dc1891-sm-008", "decimal.Decimal.__dict__.__contains__", ["is_normal"], true]
    - ["dc1891-sm-009", "decimal.Decimal.__dict__.__contains__", ["is_subnormal"], true]
    - ["dc1891-sm-010", "decimal.Decimal.__dict__.__contains__", ["is_canonical"], true]
