spec: just_clone
version: ">=6.2.0"
backend: node(just-clone)

docs: https://www.npmjs.com/package/just-clone

provenance:
  derived_from:
    - "just-clone README — https://www.npmjs.com/package/just-clone"
    - "Test vectors verified with just-clone via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "just-clone source"
  notes:
    - "just-clone is an npm package. Install: npm install just-clone"
    - "The module exports a single function that deep-clones objects and arrays."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a deep clone of the input."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_clone.clone:
  kind: node_module_call_eq
  function: ~
  category: transform
  id_prefix: jclone

  columns: [id, args, expected]
  rows:
    - [object, [{"a": 1, "b": {"c": 2}}], {"a": 1, "b": {"c": 2}}]
    - [array,  [[1, [2, 3]]],             [1, [2, 3]]]
