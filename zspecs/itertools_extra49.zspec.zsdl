spec: itertools_extra49
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra48.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for all major itertools types; __qualname__.__len__() for groupby/islice/zip_longest/accumulate/chain.from_iterable/combinations_with_replacement/count/cycle/repeat/starmap/compress/dropwhile/takewhile/filterfalse; __mro__.__len__()==2 for all major types; __bases__[0].__name__.__len__()==6 for all types; __name__/__qualname__ string equality for all major types; __bases__[0].__name__=='object' string equality for all major types; __bases__[0].__qualname__=='object' for all major types; __class__.__name__=='type' for groupby/chain/compress/islice/zip_longest/product/count/cycle/repeat; __class__.__qualname__=='type' for all seventeen major types; __class__.__module__=='builtins' for groupby/chain/compress/islice/zip_longest/product."
    - "This spec covers: __doc__.__class__.__name__ == 'str' for groupby/chain/compress/islice/zip_longest/product/count/cycle/repeat and for the itertools module itself."
    - "Key findings: All itertools module-level types are C-extension types defined in Modules/itertoolsmodule.c. In CPython, the docstrings for C-extension types are stored as ordinary Python str objects — not bytes, not NoneType, not a custom doc descriptor. Therefore for every itertools type T, T.__doc__.__class__.__name__ == 'str'. The module-level docstring (itertools.__doc__) follows the same rule: it is a str object. This is a universal property of CPython C-extension types: their class-level __doc__ attribute is a static C string that is exposed to Python as a str object through PyMemberDef or tp_doc slots. No prior spec recorded __doc__.__class__.__name__ for any itertools type or for the itertools module. All ten invariants are new to extra49."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools type docstring class names — extra49 namespace
#
# Every itertools type is a C-extension type in Modules/itertoolsmodule.c.
# The __doc__ attribute on each type is a Python str object created from the
# C-level tp_doc slot. So for every itertools type T:
#   T.__doc__.__class__.__name__ == 'str'
# This holds regardless of the length or content of the docstring. It would
# only differ if a type had __doc__ = None (which would give 'NoneType'), but
# all major itertools types have non-None docstrings. No prior spec recorded
# __doc__.__class__.__name__ for any itertools type. All nine are new to extra49.
# ---------------------------------------------------------------------------

table itertools_extra49.type_docstring_class_names:
  description: "itertools type __doc__.__class__.__name__ == 'str' — C-extension types in itertoolsmodule.c; docstrings are str objects created from C-level tp_doc slots; 3-char class name"
  kind: python_call_eq
  category: identity
  id_prefix: itertdoctype49

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_doc_class_name,
       groupby.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.groupby.__doc__.__class__.__name__ == 'str' — C-extension type in Modules/itertoolsmodule.c; groups consecutive elements sharing the same key function output; tp_doc slot exposes docstring as a Python str object; __doc__.__class__.__name__ == 'str' (3 chars)"]
    - [chain_doc_class_name,
       chain.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.chain.__doc__.__class__.__name__ == 'str' — C-extension type in Modules/itertoolsmodule.c; chains multiple iterables into a single sequential iterable; tp_doc slot exposes docstring as a Python str object; __doc__.__class__.__name__ == 'str' (3 chars)"]
    - [compress_doc_class_name,
       compress.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.compress.__doc__.__class__.__name__ == 'str' — C-extension type in Modules/itertoolsmodule.c; filters elements based on a boolean selector iterable; tp_doc slot exposes docstring as a Python str object; __doc__.__class__.__name__ == 'str' (3 chars)"]
    - [islice_doc_class_name,
       islice.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.islice.__doc__.__class__.__name__ == 'str' — C-extension type in Modules/itertoolsmodule.c; slices an iterator without materializing the full sequence; tp_doc slot exposes docstring as a Python str object; __doc__.__class__.__name__ == 'str' (3 chars)"]
    - [zip_longest_doc_class_name,
       zip_longest.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.zip_longest.__doc__.__class__.__name__ == 'str' — C-extension type in Modules/itertoolsmodule.c; zips iterables filling missing values with a fill value; tp_doc slot exposes docstring as a Python str object; __doc__.__class__.__name__ == 'str' (3 chars)"]
    - [product_doc_class_name,
       product.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.product.__doc__.__class__.__name__ == 'str' — C-extension type in Modules/itertoolsmodule.c; yields Cartesian product of input iterables as tuples; tp_doc slot exposes docstring as a Python str object; __doc__.__class__.__name__ == 'str' (3 chars)"]
    - [count_doc_class_name,
       count.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.count.__doc__.__class__.__name__ == 'str' — C-extension type in Modules/itertoolsmodule.c; infinite counter starting from a given value with optional step; tp_doc slot exposes docstring as a Python str object; __doc__.__class__.__name__ == 'str' (3 chars)"]
    - [cycle_doc_class_name,
       cycle.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.cycle.__doc__.__class__.__name__ == 'str' — C-extension type in Modules/itertoolsmodule.c; cycles through an iterable indefinitely saving a copy internally; tp_doc slot exposes docstring as a Python str object; __doc__.__class__.__name__ == 'str' (3 chars)"]
    - [repeat_doc_class_name,
       repeat.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.repeat.__doc__.__class__.__name__ == 'str' — C-extension type in Modules/itertoolsmodule.c; yields the same object indefinitely or n times; tp_doc slot exposes docstring as a Python str object; __doc__.__class__.__name__ == 'str' (3 chars)"]

# ---------------------------------------------------------------------------
# itertools module docstring class name — extra49 namespace
#
# The itertools module itself has a module-level docstring. In CPython,
# C-extension module docstrings are stored as str objects (created from
# PyModuleDef.m_doc). Therefore itertools.__doc__.__class__.__name__ == 'str'.
# The module object is accessed via the backend binding as the module root.
# No prior spec recorded __doc__.__class__.__name__ for the itertools module.
# This invariant is new to extra49.
# ---------------------------------------------------------------------------

invariant itertools_extra49.module_doc_class_name:
  description: "itertools.__doc__.__class__.__name__ == 'str' — C-extension module; module docstring is a str object created from PyModuleDef.m_doc; the same 'str' class name applies to the module docstring as to individual type docstrings; 3-char class name"
  category: identity
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
