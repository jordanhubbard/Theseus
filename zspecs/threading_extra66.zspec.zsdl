spec: threading_extra66
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra65.zspec.zsdl."
    - "Wave 231 theme: __code__ attribute chains — co_varnames, co_filename, co_flags for Thread.__init__/Thread.start/Thread.run/current_thread."
    - "Thread.__init__.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple of local variable names in CPython code objects. Verified with Python 3.14.3."
    - "Thread.__init__.__code__.co_varnames[0] == 'self' — the first argument of __init__ is always 'self' for a method defined in a class body. Verified with Python 3.14.3."
    - "Thread.start.__code__.co_varnames[0] == 'self' — the first argument of start(self) is 'self'. Verified with Python 3.14.3."
    - "Thread.run.__code__.co_varnames[0] == 'self' — the first argument of run(self) is 'self'. Verified with Python 3.14.3."
    - "current_thread.__code__.co_varnames.__class__.__name__ == 'tuple' — current_thread is a module-level pure-Python function; co_varnames is a tuple. Verified with Python 3.14.3."
    - "Thread.__init__.__code__.co_filename.__class__.__name__ == 'str' — co_filename is always a str object holding the source file path. Verified with Python 3.14.3."
    - "Thread.__init__.__code__.co_filename.__contains__('.py') == True — threading is a pure-Python module (Lib/threading.py), so co_filename ends with '.py'. Verified with Python 3.14.3."
    - "current_thread.__code__.co_filename.__contains__('.py') == True — current_thread is also defined in Lib/threading.py. Verified with Python 3.14.3."
    - "Thread.__init__.__code__.co_flags.__class__.__name__ == 'int' — co_flags is always a plain Python int bitmask. Verified with Python 3.14.3."
    - "current_thread.__code__.co_flags.__class__.__name__ == 'int' — same invariant for current_thread. Verified with Python 3.14.3."
    - "No prior threading spec checks co_varnames[0] (the first local variable name), co_filename, or co_flags for any threading function. All checks in this spec are new to extra66."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading __code__.co_varnames.__class__.__name__ — extra66
#
# Wave 231 theme: co_varnames is always a tuple.
#
# co_varnames (PyCodeObject.co_varnames) is a tuple of strings containing the
# names of all local variables (parameters first, then locals) in a code object.
# In CPython this is always stored as a Python tuple.
#
# Thread.__init__.__code__.co_varnames.__class__.__name__ == 'tuple'
# current_thread.__code__.co_varnames.__class__.__name__ == 'tuple'
#
# Both are pure-Python functions in Lib/threading.py.
# No prior threading spec checks co_varnames.__class__.__name__. New to extra66.
# ---------------------------------------------------------------------------

table threading_extra66.co_varnames_class_name:
  description: "threading function __code__.co_varnames.__class__.__name__.__eq__('tuple')==true — co_varnames is always a tuple in CPython; wave 231 co_varnames chains; new to extra66"
  kind: python_call_eq
  category: co_varnames
  id_prefix: thrdcode3_66

  columns: [id, function, args, expected, description]
  rows:
    - [thread_init_code_co_varnames_class_name_eq_tuple,
       Thread.__init__.__code__.co_varnames.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "threading.Thread.__init__.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — Thread.__init__ is a pure-Python method (Lib/threading.py); its __code__ is a PyCodeObject; PyCodeObject.co_varnames is a tuple of strings for all local variable names (parameters first, starting with 'self'); the tuple built-in type has __name__ == 'tuple' (5 chars); __eq__ returns True; no prior threading spec checks co_varnames.__class__.__name__ for Thread.__init__; new to extra66"]
    - [current_thread_code_co_varnames_class_name_eq_tuple,
       current_thread.__code__.co_varnames.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "threading.current_thread.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — current_thread is a pure-Python module-level function (Lib/threading.py); its co_varnames is a tuple of strings for all local variable names; tuple.__name__ == 'tuple'; __eq__ returns True; no prior threading spec checks co_varnames.__class__.__name__ for current_thread; new to extra66"]

# ---------------------------------------------------------------------------
# threading __code__.co_varnames[0] — extra66
#
# Wave 231 theme: co_varnames[0] is the first parameter name.
#
# co_varnames[0] is the name of the first positional parameter, since
# co_varnames lists all locals with parameters first. For instance methods
# defined in a class body, co_varnames[0] is always 'self'.
#
# Thread.__init__(self, ...) → co_varnames[0] == 'self'
# Thread.start(self) → co_varnames[0] == 'self'
# Thread.run(self) → co_varnames[0] == 'self'
#
# Function values containing '[' MUST be double-quoted in table rows.
# No prior threading spec checks co_varnames[0]. New to extra66.
# ---------------------------------------------------------------------------

table threading_extra66.co_varnames_first_arg:
  description: "threading method __code__.co_varnames[0].__eq__('self') — all Thread methods have 'self' as first param; wave 231 co_varnames first arg; new to extra66"
  kind: python_call_eq
  category: co_varnames
  id_prefix: thrdcode3_66

  columns: [id, function, args, expected, description]
  rows:
    - [thread_init_code_co_varnames_0_eq_self,
       "Thread.__init__.__code__.co_varnames[0].__eq__",
       ["self"],
       true,
       "threading.Thread.__init__.__code__.co_varnames[0].__eq__('self') == True — Thread.__init__ is a pure-Python method (Lib/threading.py) with signature __init__(self, group=None, target=None, name=None, args=(), kwargs=None, *, daemon=None, context=None); co_varnames lists all locals with parameters first; co_varnames[0] is the first parameter name, which is 'self' (4 chars) — the implicit self parameter of an instance method; __eq__ on the str 'self' returns True when the argument equals 'self'; no prior threading spec checks co_varnames[0] for Thread.__init__; new to extra66"]
    - [thread_start_code_co_varnames_0_eq_self,
       "Thread.start.__code__.co_varnames[0].__eq__",
       ["self"],
       true,
       "threading.Thread.start.__code__.co_varnames[0].__eq__('self') == True — Thread.start is a pure-Python method (Lib/threading.py) with signature start(self); co_varnames[0] is the first parameter name, which is 'self' (4 chars); __eq__ returns True; no prior threading spec checks co_varnames[0] for Thread.start; new to extra66"]
    - [thread_run_code_co_varnames_0_eq_self,
       "Thread.run.__code__.co_varnames[0].__eq__",
       ["self"],
       true,
       "threading.Thread.run.__code__.co_varnames[0].__eq__('self') == True — Thread.run is a pure-Python method (Lib/threading.py) with signature run(self); co_varnames[0] is the first parameter name, which is 'self' (4 chars); __eq__ returns True; no prior threading spec checks co_varnames[0] for Thread.run; new to extra66"]

# ---------------------------------------------------------------------------
# threading __code__.co_filename.__class__.__name__ — extra66
#
# Wave 231 theme: co_filename is always a str.
#
# co_filename (PyCodeObject.co_filename) stores the path of the source file
# where the function was defined, as a Python str. For threading (a pure-Python
# module in Lib/threading.py), co_filename is a str object.
#
# Thread.__init__.__code__.co_filename.__class__.__name__ == 'str'
# current_thread.__code__.co_filename.__class__.__name__ == 'str'
#
# No prior threading spec checks co_filename.__class__.__name__. New to extra66.
# ---------------------------------------------------------------------------

table threading_extra66.co_filename_class_name:
  description: "threading function __code__.co_filename.__class__.__name__.__eq__('str')==true — co_filename is always a str; wave 231 co_filename chains; new to extra66"
  kind: python_call_eq
  category: co_filename
  id_prefix: thrdcode3_66

  columns: [id, function, args, expected, description]
  rows:
    - [thread_init_code_co_filename_class_name_eq_str,
       Thread.__init__.__code__.co_filename.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.Thread.__init__.__code__.co_filename.__class__.__name__.__eq__('str') == True — Thread.__init__ is a pure-Python method (Lib/threading.py); its __code__ is a PyCodeObject; PyCodeObject.co_filename is a str holding the absolute path of the source file; str.__name__ == 'str' (3 chars); __eq__ returns True; no prior threading spec checks co_filename.__class__.__name__ for Thread.__init__; new to extra66"]
    - [current_thread_code_co_filename_class_name_eq_str,
       current_thread.__code__.co_filename.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.current_thread.__code__.co_filename.__class__.__name__.__eq__('str') == True — current_thread is a pure-Python module-level function (Lib/threading.py); co_filename is a str holding the path to Lib/threading.py; str.__name__ == 'str'; __eq__ returns True; no prior threading spec checks co_filename.__class__.__name__ for current_thread; new to extra66"]

# ---------------------------------------------------------------------------
# threading __code__.co_filename.__contains__('.py') — extra66
#
# Wave 231 theme: co_filename ends with '.py' for pure-Python threading.
#
# threading is a pure-Python module (Lib/threading.py). Therefore the
# co_filename attribute of every function defined there contains the
# substring '.py'.
#
# Thread.__init__.__code__.co_filename.__contains__('.py') == True
# current_thread.__code__.co_filename.__contains__('.py') == True
# Thread.start.__code__.co_filename.__contains__('.py') == True
#
# No prior threading spec checks co_filename.__contains__. New to extra66.
# ---------------------------------------------------------------------------

table threading_extra66.co_filename_contains_py:
  description: "threading function __code__.co_filename.__contains__('.py')==true — threading is pure-Python so co_filename contains '.py'; wave 231 co_filename chains; new to extra66"
  kind: python_call_eq
  category: co_filename
  id_prefix: thrdcode3_66

  columns: [id, function, args, expected, description]
  rows:
    - [thread_init_code_co_filename_contains_py,
       Thread.__init__.__code__.co_filename.__contains__,
       [".py"],
       true,
       "threading.Thread.__init__.__code__.co_filename.__contains__('.py') == True — Thread.__init__ is defined in Lib/threading.py; PyCodeObject.co_filename is the absolute path to that file as a str; the path necessarily contains the substring '.py' (the .py file extension); str.__contains__ returns True; no prior threading spec checks co_filename.__contains__('.py') for Thread.__init__; new to extra66"]
    - [current_thread_code_co_filename_contains_py,
       current_thread.__code__.co_filename.__contains__,
       [".py"],
       true,
       "threading.current_thread.__code__.co_filename.__contains__('.py') == True — current_thread is defined in Lib/threading.py; co_filename is the absolute path to Lib/threading.py; the path contains '.py'; __contains__ returns True; no prior threading spec checks co_filename.__contains__('.py') for current_thread; new to extra66"]
    - [thread_start_code_co_filename_contains_py,
       Thread.start.__code__.co_filename.__contains__,
       [".py"],
       true,
       "threading.Thread.start.__code__.co_filename.__contains__('.py') == True — Thread.start is defined in Lib/threading.py; co_filename is the absolute path to Lib/threading.py; the path contains '.py'; __contains__ returns True; no prior threading spec checks co_filename.__contains__('.py') for Thread.start; new to extra66"]

# ---------------------------------------------------------------------------
# threading __code__.co_flags.__class__.__name__ — extra66
#
# Wave 231 theme: co_flags is always an int.
#
# co_flags (PyCodeObject.co_flags) is a bitmask of integer flags describing
# properties of the code object. In CPython this field is always a plain int.
#
# Thread.__init__.__code__.co_flags.__class__.__name__ == 'int'
# current_thread.__code__.co_flags.__class__.__name__ == 'int'
#
# No prior threading spec checks co_flags.__class__.__name__. New to extra66.
# ---------------------------------------------------------------------------

table threading_extra66.co_flags_class_name:
  description: "threading function __code__.co_flags.__class__.__name__.__eq__('int')==true — co_flags is always a plain int bitmask; wave 231 co_flags chains; new to extra66"
  kind: python_call_eq
  category: co_flags
  id_prefix: thrdcode3_66

  columns: [id, function, args, expected, description]
  rows:
    - [thread_init_code_co_flags_class_name_eq_int,
       Thread.__init__.__code__.co_flags.__class__.__name__.__eq__,
       ["int"],
       true,
       "threading.Thread.__init__.__code__.co_flags.__class__.__name__.__eq__('int') == True — Thread.__init__ is a pure-Python method (Lib/threading.py); its __code__ is a PyCodeObject; PyCodeObject.co_flags is a bitmask of integer flags (e.g., CO_OPTIMIZED, CO_NEWLOCALS) stored as a Python int; int.__name__ == 'int' (3 chars); __eq__ returns True; no prior threading spec checks co_flags.__class__.__name__ for Thread.__init__; new to extra66"]
    - [current_thread_code_co_flags_class_name_eq_int,
       current_thread.__code__.co_flags.__class__.__name__.__eq__,
       ["int"],
       true,
       "threading.current_thread.__code__.co_flags.__class__.__name__.__eq__('int') == True — current_thread is a pure-Python module-level function (Lib/threading.py); co_flags is a Python int bitmask; int.__name__ == 'int'; __eq__ returns True; no prior threading spec checks co_flags.__class__.__name__ for current_thread; new to extra66"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra66
# ---------------------------------------------------------------------------

invariant threading_extra66.Thread_init_co_varnames_tuple:
  description: "threading.Thread.__init__.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — co_varnames is always a tuple in CPython; wave 231 co_varnames chains; new to extra66"
  kind: python_call_eq
  function: Thread.__init__.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant threading_extra66.Thread_init_co_varnames_self:
  description: "threading.Thread.__init__.__code__.co_varnames[0].__eq__('self') == True — first parameter of __init__ is always 'self' for an instance method; wave 231 co_varnames first arg; new to extra66"
  kind: python_call_eq
  function: "Thread.__init__.__code__.co_varnames[0].__eq__"
  args: ["self"]
  expected: true

invariant threading_extra66.Thread_start_co_varnames_self:
  description: "threading.Thread.start.__code__.co_varnames[0].__eq__('self') == True — first parameter of start is 'self'; wave 231 co_varnames first arg; new to extra66"
  kind: python_call_eq
  function: "Thread.start.__code__.co_varnames[0].__eq__"
  args: ["self"]
  expected: true

invariant threading_extra66.Thread_init_co_filename_contains_py:
  description: "threading.Thread.__init__.__code__.co_filename.__contains__('.py') == True — threading is pure-Python so co_filename contains '.py'; wave 231 co_filename chains; new to extra66"
  kind: python_call_eq
  function: Thread.__init__.__code__.co_filename.__contains__
  args: [".py"]
  expected: true

invariant threading_extra66.Thread_init_co_flags_int:
  description: "threading.Thread.__init__.__code__.co_flags.__class__.__name__.__eq__('int') == True — co_flags is always a plain int bitmask; wave 231 co_flags chains; new to extra66"
  kind: python_call_eq
  function: Thread.__init__.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true
