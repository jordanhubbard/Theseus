spec: lodash_zip
version: ">=4.0.0"
backend: node(lodash.zip)

docs: https://lodash.com/docs/#zip

provenance:
  derived_from:
    - "lodash.zip README — https://www.npmjs.com/package/lodash.zip"
    - "Test vectors verified with lodash.zip@4.2.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.zip exports the _.zip function directly as module.exports."
    - "zip(...arrays) creates an array of grouped element arrays from input arrays."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array of pairs. No errors for array inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_zip.zip:
  kind: node_module_call_eq
  function: ~
  category: zip
  id_prefix: lzip

  columns: [id, args, expected]
  rows:
    - [two_arrays,   [[1, 2, 3], ["a", "b", "c"]],  [[1, "a"], [2, "b"], [3, "c"]]]
    - [three_arrays, [[1, 2], ["a", "b"], [true, false]],  [[1, "a", true], [2, "b", false]]]

