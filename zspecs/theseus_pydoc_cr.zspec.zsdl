spec: theseus_pydoc_cr
version: ">=3.0"
backend: python_cleanroom(theseus_pydoc_cr)
blocks: pydoc

docs: https://docs.python.org/3/library/pydoc.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/pydoc.html"
  not_derived_from:
    - "CPython source: Lib/pydoc.py"
  notes:
    - "Clean-room pydoc module. Do NOT import pydoc."

error_model: python_exceptions

invariant theseus_pydoc_cr.pydoc2_render_doc:
  description: "render_doc() returns documentation for an object"
  category: behavior
  kind: python_call_eq
  function: pydoc2_render_doc
  args: []
  expected: true

invariant theseus_pydoc_cr.pydoc2_text_doc:
  description: "TextDoc class can format module documentation"
  category: behavior
  kind: python_call_eq
  function: pydoc2_text_doc
  args: []
  expected: true

invariant theseus_pydoc_cr.pydoc2_locate:
  description: "locate() finds an object by dotted name"
  category: behavior
  kind: python_call_eq
  function: pydoc2_locate
  args: []
  expected: true
