spec: itertools_extra117
version: ">=3.10"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra116.zspec.zsdl."
    - "This spec covers: itertools.islice and itertools.takewhile class slot qualname attributes not yet covered — islice.__next__.__qualname__ ('islice.__next__', len 15), islice.__iter__.__qualname__ ('islice.__iter__', len 15), takewhile.__next__.__qualname__ ('takewhile.__next__', len 18), takewhile.__iter__.__qualname__ ('takewhile.__iter__', len 18), dropwhile.__next__.__qualname__ ('dropwhile.__next__', len 18); wave 268."
    - "itertools.islice.__next__.__qualname__ == 'islice.__next__'. Verified with Python 3.14.3."
    - "itertools.islice.__iter__.__qualname__ == 'islice.__iter__'. Verified with Python 3.14.3."
    - "len(itertools.islice.__next__.__qualname__) == 15. Verified with Python 3.14.3."
    - "len(itertools.islice.__iter__.__qualname__) == 15. Verified with Python 3.14.3."
    - "itertools.takewhile.__next__.__qualname__ == 'takewhile.__next__'. Verified with Python 3.14.3."
    - "itertools.takewhile.__iter__.__qualname__ == 'takewhile.__iter__'. Verified with Python 3.14.3."
    - "len(itertools.takewhile.__next__.__qualname__) == 18. Verified with Python 3.14.3."
    - "len(itertools.takewhile.__iter__.__qualname__) == 18. Verified with Python 3.14.3."
    - "itertools.dropwhile.__next__.__qualname__ == 'dropwhile.__next__'. Verified with Python 3.14.3."
    - "len(itertools.dropwhile.__next__.__qualname__) == 18. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.islice.__next__ and __iter__ slot qualnames
#
# Wave 268 theme: itertools.islice is a C-extension iterator type. Its slot
# attributes __next__ and __iter__ are both wrapper_descriptors. Both have
# qualnames with the 'islice.' prefix: islice.__next__.__qualname__ is
# 'islice.__next__' (15 chars) and islice.__iter__.__qualname__ is
# 'islice.__iter__' (15 chars) — both equal length. This contrasts with the
# chain.__next__/__iter__ qualnames (14 chars each, one char shorter because
# 'chain' is 5 chars vs 'islice' is 6 chars). Previously covered: chain
# __next__/__iter__ qualnames (extra116). New here: islice.__next__.__qualname__,
# islice.__iter__.__qualname__ and their lengths.
#
# islice.__next__.__qualname__ == 'islice.__next__'   (len 15)
# islice.__iter__.__qualname__ == 'islice.__iter__'   (len 15)
#
# New to extra117.
# ---------------------------------------------------------------------------

table itertools_extra117.islice_next_iter_qualnames:
  description: "itertools.islice slot qualnames: __next__='islice.__next__'(15), __iter__='islice.__iter__'(15); both len=15; one longer than chain slot qualnames (14); both wrapper_descriptor; wave 268; new to extra117"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsiniq117

  columns: [id, function, args, expected, description]
  rows:
    - [islice_next_qualname,
       "islice.__next__.__qualname__.__eq__",
       ["islice.__next__"],
       true,
       "itertools.islice.__next__.__qualname__.__eq__('islice.__next__') == True — islice defines tp_iternext which surfaces as '__next__'; qualname is 'islice.__next__' (15 chars); str.__eq__('islice.__next__') returns True; new to extra117"]
    - [islice_next_qualname_len,
       "islice.__next__.__qualname__.__len__",
       [],
       15,
       "itertools.islice.__next__.__qualname__.__len__() == 15 — 'islice.__next__' has 15 chars: islice(6)+dot(1)+__next__(8); one more than chain.__next__.__qualname__.__len__() (14) because 'islice' is 6 chars vs 'chain' is 5; str.__len__() returns 15; new to extra117"]
    - [islice_iter_qualname,
       "islice.__iter__.__qualname__.__eq__",
       ["islice.__iter__"],
       true,
       "itertools.islice.__iter__.__qualname__.__eq__('islice.__iter__') == True — islice defines tp_iter which surfaces as '__iter__'; qualname is 'islice.__iter__' (15 chars); str.__eq__('islice.__iter__') returns True; new to extra117"]
    - [islice_iter_qualname_len,
       "islice.__iter__.__qualname__.__len__",
       [],
       15,
       "itertools.islice.__iter__.__qualname__.__len__() == 15 — 'islice.__iter__' has 15 chars: islice(6)+dot(1)+__iter__(8); same length as islice.__next__.__qualname__; str.__len__() returns 15; new to extra117"]
    - [islice_next_name,
       "islice.__next__.__name__.__eq__",
       ["__next__"],
       true,
       "itertools.islice.__next__.__name__.__eq__('__next__') == True — the bare __name__ of the tp_iternext slot wrapper is '__next__' (8 chars); str.__eq__('__next__') returns True; new to extra117"]
    - [islice_next_class_name,
       "islice.__next__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.islice.__next__.__class__.__name__.__eq__('wrapper_descriptor') == True — C slot tp_iternext is exposed as a wrapper_descriptor; same type as chain.__next__; str.__eq__('wrapper_descriptor') returns True; new to extra117"]

# ---------------------------------------------------------------------------
# Table 2: itertools.takewhile.__next__ and __iter__ slot qualnames
#
# Wave 268 theme: itertools.takewhile is a C-extension iterator that yields
# elements as long as a predicate returns true. Its __next__ and __iter__ slot
# qualnames are 'takewhile.__next__' and 'takewhile.__iter__' — both 18 chars,
# 3 chars longer than islice's 15-char qualnames because 'takewhile' is 9 chars
# vs 'islice' is 6 chars. Previously covered: chain __next__/__iter__ qualnames
# (extra116), islice qualnames (Table 1 above). New here: takewhile.__next__
# and __iter__ qualnames.
#
# takewhile.__next__.__qualname__ == 'takewhile.__next__'   (len 18)
# takewhile.__iter__.__qualname__ == 'takewhile.__iter__'   (len 18)
#
# New to extra117.
# ---------------------------------------------------------------------------

table itertools_extra117.takewhile_next_iter_qualnames:
  description: "itertools.takewhile slot qualnames: __next__='takewhile.__next__'(18), __iter__='takewhile.__iter__'(18); both len=18; 3 more than islice (15), 4 more than chain (14); both wrapper_descriptor; wave 268; new to extra117"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolstwiq117

  columns: [id, function, args, expected, description]
  rows:
    - [takewhile_next_qualname,
       "takewhile.__next__.__qualname__.__eq__",
       ["takewhile.__next__"],
       true,
       "itertools.takewhile.__next__.__qualname__.__eq__('takewhile.__next__') == True — takewhile defines tp_iternext; qualname is 'takewhile.__next__' (18 chars); str.__eq__('takewhile.__next__') returns True; new to extra117"]
    - [takewhile_next_qualname_len,
       "takewhile.__next__.__qualname__.__len__",
       [],
       18,
       "itertools.takewhile.__next__.__qualname__.__len__() == 18 — 'takewhile.__next__' has 18 chars: takewhile(9)+dot(1)+__next__(8); 3 more than islice (15) and 4 more than chain (14); str.__len__() returns 18; new to extra117"]
    - [takewhile_iter_qualname,
       "takewhile.__iter__.__qualname__.__eq__",
       ["takewhile.__iter__"],
       true,
       "itertools.takewhile.__iter__.__qualname__.__eq__('takewhile.__iter__') == True — takewhile defines tp_iter; qualname is 'takewhile.__iter__' (18 chars); str.__eq__('takewhile.__iter__') returns True; new to extra117"]
    - [takewhile_iter_qualname_len,
       "takewhile.__iter__.__qualname__.__len__",
       [],
       18,
       "itertools.takewhile.__iter__.__qualname__.__len__() == 18 — 'takewhile.__iter__' has 18 chars; same length as takewhile.__next__.__qualname__; str.__len__() returns 18; new to extra117"]
    - [takewhile_next_class_name,
       "takewhile.__next__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.takewhile.__next__.__class__.__name__.__eq__('wrapper_descriptor') == True — C slot tp_iternext is a wrapper_descriptor; same type as islice.__next__ and chain.__next__; str.__eq__('wrapper_descriptor') returns True; new to extra117"]

# ---------------------------------------------------------------------------
# Table 3: itertools.dropwhile.__next__ qualname and length comparison
#
# Wave 268 theme: itertools.dropwhile is a C-extension iterator that drops
# elements while a predicate is true then yields all remaining. Its __next__
# qualname is 'dropwhile.__next__' (18 chars) — same length as takewhile's
# because 'dropwhile' also has 9 chars. Similarly dropwhile.__iter__.__qualname__
# is 'dropwhile.__iter__' (18 chars). This 3-way comparison (islice=15,
# takewhile=18, dropwhile=18) illustrates how slot qualname length scales
# with the class name length. New here: dropwhile.__next__.__qualname__,
# dropwhile.__iter__.__qualname__.
#
# dropwhile.__next__.__qualname__ == 'dropwhile.__next__'   (len 18)
# dropwhile.__iter__.__qualname__ == 'dropwhile.__iter__'   (len 18)
#
# New to extra117.
# ---------------------------------------------------------------------------

table itertools_extra117.dropwhile_qualnames_comparison:
  description: "itertools.dropwhile slot qualnames: __next__='dropwhile.__next__'(18), __iter__='dropwhile.__iter__'(18); equal to takewhile lengths; islice(15) < takewhile=dropwhile(18); wave 268; new to extra117"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsdwqc117

  columns: [id, function, args, expected, description]
  rows:
    - [dropwhile_next_qualname,
       "dropwhile.__next__.__qualname__.__eq__",
       ["dropwhile.__next__"],
       true,
       "itertools.dropwhile.__next__.__qualname__.__eq__('dropwhile.__next__') == True — dropwhile defines tp_iternext; qualname is 'dropwhile.__next__' (18 chars); same length as takewhile.__next__.__qualname__; str.__eq__('dropwhile.__next__') returns True; new to extra117"]
    - [dropwhile_next_qualname_len,
       "dropwhile.__next__.__qualname__.__len__",
       [],
       18,
       "itertools.dropwhile.__next__.__qualname__.__len__() == 18 — 'dropwhile.__next__' has 18 chars: dropwhile(9)+dot(1)+__next__(8); equal to takewhile.__next__.__qualname__.__len__() (18); str.__len__() returns 18; new to extra117"]
    - [dropwhile_iter_qualname,
       "dropwhile.__iter__.__qualname__.__eq__",
       ["dropwhile.__iter__"],
       true,
       "itertools.dropwhile.__iter__.__qualname__.__eq__('dropwhile.__iter__') == True — dropwhile defines tp_iter; qualname is 'dropwhile.__iter__' (18 chars); str.__eq__('dropwhile.__iter__') returns True; new to extra117"]
    - [dropwhile_iter_qualname_len,
       "dropwhile.__iter__.__qualname__.__len__",
       [],
       18,
       "itertools.dropwhile.__iter__.__qualname__.__len__() == 18 — 'dropwhile.__iter__' has 18 chars; same as takewhile.__iter__.__qualname__.__len__(); str.__len__() returns 18; new to extra117"]
    - [islice_vs_dropwhile_len_diff,
       "islice.__next__.__qualname__.__len__",
       [],
       15,
       "itertools.islice.__next__.__qualname__.__len__() == 15 — 15 is 3 less than dropwhile (18); the length difference equals the class name length difference: 'islice'(6) vs 'dropwhile'(9); str.__len__() returns 15; new to extra117"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra117
# ---------------------------------------------------------------------------

invariant itertools_extra117.islice_next_qualname:
  description: "itertools.islice.__next__.__qualname__ == 'islice.__next__' — tp_iternext slot; qualname length 15; 1 more than chain (14); wave 268; new to extra117"
  kind: python_call_eq
  function: islice.__next__.__qualname__.__eq__
  args: ["islice.__next__"]
  expected: true

invariant itertools_extra117.islice_iter_qualname:
  description: "itertools.islice.__iter__.__qualname__ == 'islice.__iter__' — tp_iter slot; qualname length 15; equal to islice.__next__ qualname length; wave 268; new to extra117"
  kind: python_call_eq
  function: islice.__iter__.__qualname__.__eq__
  args: ["islice.__iter__"]
  expected: true

invariant itertools_extra117.takewhile_next_qualname:
  description: "itertools.takewhile.__next__.__qualname__ == 'takewhile.__next__' — qualname length 18; 3 more than islice (15); wave 268; new to extra117"
  kind: python_call_eq
  function: takewhile.__next__.__qualname__.__eq__
  args: ["takewhile.__next__"]
  expected: true

invariant itertools_extra117.takewhile_iter_qualname:
  description: "itertools.takewhile.__iter__.__qualname__ == 'takewhile.__iter__' — qualname length 18; equal to takewhile.__next__ qualname length; wave 268; new to extra117"
  kind: python_call_eq
  function: takewhile.__iter__.__qualname__.__eq__
  args: ["takewhile.__iter__"]
  expected: true

invariant itertools_extra117.dropwhile_next_qualname:
  description: "itertools.dropwhile.__next__.__qualname__ == 'dropwhile.__next__' — qualname length 18; equal to takewhile (same class name length 9); wave 268; new to extra117"
  kind: python_call_eq
  function: dropwhile.__next__.__qualname__.__eq__
  args: ["dropwhile.__next__"]
  expected: true
