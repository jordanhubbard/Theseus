spec: uuid_extra1756
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/uuid.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 564 (_extra1756): arithmetic operator protocol dict-presence checks."
    - "uuid.UUID: Python class — not a numeric type; no arithmetic operators in __dict__; all eight arithmetic dunders absent."
    - "uuid.SafeUUID: Python IntEnum subclass — enum values are compared by integer; no arithmetic operators defined in its own __dict__."
    - "Complementary checks: uuid.uuid4.__class__.__name__ == 'function'; uuid.uuid1.__class__.__name__ == 'function'; uuid.uuid3.__class__.__name__ == 'function'; uuid.uuid5.__class__.__name__ == 'function'; uuid.getnode.__class__.__name__ == 'function'."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: arithmetic operator protocol dict-presence checks for uuid types
#
# Wave 564 theme: which uuid types define __add__, __sub__, __mul__,
# __truediv__, __floordiv__, __pow__, __neg__, __pos__ in their own __dict__.
#
# uuid.UUID: Python class (Lib/uuid.py) — represents a UUID value; not a
#   numeric type; no arithmetic operators defined in __dict__.
# uuid.SafeUUID: Python IntEnum subclass (Lib/uuid.py) — an enum for
#   indicating UUID generation safety; enum members are compared as integers
#   but SafeUUID does not define any arithmetic operators in its own __dict__.
# ---------------------------------------------------------------------------

table uuid_extra1756.arithmetic_operators:
  description: "uuid types arithmetic operator dict-presence checks — all False — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1756

  columns: [id, function, args, expected]
  rows:
    - ["uu1756001", "uuid.UUID.__dict__.__contains__", ["__add__"], false]
    - ["uu1756002", "uuid.UUID.__dict__.__contains__", ["__sub__"], false]
    - ["uu1756003", "uuid.UUID.__dict__.__contains__", ["__mul__"], false]
    - ["uu1756004", "uuid.UUID.__dict__.__contains__", ["__truediv__"], false]
    - ["uu1756005", "uuid.UUID.__dict__.__contains__", ["__floordiv__"], false]
    - ["uu1756006", "uuid.UUID.__dict__.__contains__", ["__pow__"], false]
    - ["uu1756007", "uuid.UUID.__dict__.__contains__", ["__neg__"], false]
    - ["uu1756008", "uuid.UUID.__dict__.__contains__", ["__pos__"], false]
    - ["uu1756009", "uuid.SafeUUID.__dict__.__contains__", ["__add__"], false]
    - ["uu1756010", "uuid.SafeUUID.__dict__.__contains__", ["__sub__"], false]
    - ["uu1756011", "uuid.SafeUUID.__dict__.__contains__", ["__mul__"], false]
    - ["uu1756012", "uuid.SafeUUID.__dict__.__contains__", ["__truediv__"], false]
    - ["uu1756013", "uuid.SafeUUID.__dict__.__contains__", ["__floordiv__"], false]
    - ["uu1756014", "uuid.SafeUUID.__dict__.__contains__", ["__pow__"], false]
    - ["uu1756015", "uuid.SafeUUID.__dict__.__contains__", ["__neg__"], false]
    - ["uu1756016", "uuid.SafeUUID.__dict__.__contains__", ["__pos__"], false]

# ---------------------------------------------------------------------------
# Table 2: complementary module-level attribute checks for uuid
#
# Unique checks not covered in earlier waves:
# - uuid.uuid4.__class__.__name__ == 'function' — generator functions are plain Python functions
# - uuid.uuid1.__class__.__name__ == 'function'
# - uuid.uuid3.__class__.__name__ == 'function'
# - uuid.uuid5.__class__.__name__ == 'function'
# - uuid.getnode.__class__.__name__ == 'function' — helper to get the hardware MAC address
# These contrast with the dict-presence checks above and confirm that all
# uuid generator functions are plain Python functions (not C builtins).
# ---------------------------------------------------------------------------

table uuid_extra1756.module_level_attributes:
  description: "uuid module-level function class name checks — all 'function' — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1756

  columns: [id, function, args, expected]
  rows:
    - ["uu1756017", "uuid.uuid4.__class__.__name__.__eq__", ["function"], true]
    - ["uu1756018", "uuid.uuid1.__class__.__name__.__eq__", ["function"], true]
    - ["uu1756019", "uuid.uuid3.__class__.__name__.__eq__", ["function"], true]
    - ["uu1756020", "uuid.uuid5.__class__.__name__.__eq__", ["function"], true]
    - ["uu1756021", "uuid.getnode.__class__.__name__.__eq__", ["function"], true]
    - ["uu1756022", "uuid.UUID.__dict__.__contains__", ["__add__"], false]
    - ["uu1756023", "uuid.UUID.__dict__.__contains__", ["__floordiv__"], false]
