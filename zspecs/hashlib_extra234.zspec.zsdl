spec: hashlib_extra234
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Lib/hashlib.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac' — function name is 'pbkdf2_hmac' (11 characters)."
    - "hashlib.pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac' — qualname equals __name__ (top-level function)."
    - "hashlib.pbkdf2_hmac.__module__ == '_hashlib' — implemented in the _hashlib C extension."
    - "hashlib.scrypt.__name__ == 'scrypt' — function name is 'scrypt' (6 characters)."
    - "hashlib.scrypt.__qualname__ == 'scrypt' — qualname equals __name__ (top-level function)."
    - "hashlib.scrypt.__module__ == '_hashlib' — implemented in the _hashlib C extension."
    - "hashlib.file_digest.__name__ == 'file_digest' — function name is 'file_digest' (11 characters)."
    - "hashlib.file_digest.__qualname__ == 'file_digest' — qualname equals __name__ (top-level function)."
    - "hashlib.file_digest.__module__ == 'hashlib' — implemented in the hashlib Python module."
    - "len('pbkdf2_hmac') == 11; len('scrypt') == 6; len('file_digest') == 11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac function identity contracts
#
# hashlib.pbkdf2_hmac.__name__     == 'pbkdf2_hmac'
# hashlib.pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac'
# hashlib.pbkdf2_hmac.__module__   == '_hashlib'
#
# pbkdf2_hmac derives a key from a password using PBKDF2 with an HMAC
# pseudorandom function. It is implemented in the _hashlib C extension.
# The function name is 'pbkdf2_hmac' (11 characters, includes underscore).
# ---------------------------------------------------------------------------

table hashlib_extra234.pbkdf2_hmac_identity:
  description: "pbkdf2_hmac.__name__=='pbkdf2_hmac'; __qualname__=='pbkdf2_hmac'; __module__=='_hashlib'; function identity contracts; new to extra234"
  kind: python_call_eq
  category: identity
  id_prefix: hashlib234

  columns: [id, function, args, expected, description]
  rows:
    - [pbkdf2_hmac_name_eq,
       "pbkdf2_hmac.__name__.__eq__",
       ["pbkdf2_hmac"],
       true,
       "hashlib.pbkdf2_hmac.__name__.__eq__('pbkdf2_hmac') == True — pbkdf2_hmac derives a cryptographic key using PBKDF2-HMAC; __name__ is 'pbkdf2_hmac' (11 characters); new anchor in extra234 namespace; verified Python 3.14.3"]
    - [pbkdf2_hmac_qualname_eq,
       "pbkdf2_hmac.__qualname__.__eq__",
       ["pbkdf2_hmac"],
       true,
       "hashlib.pbkdf2_hmac.__qualname__.__eq__('pbkdf2_hmac') == True — pbkdf2_hmac is a top-level function so __qualname__ equals __name__; both are 'pbkdf2_hmac' (11 characters); new anchor in extra234 namespace; verified Python 3.14.3"]
    - [pbkdf2_hmac_module_eq,
       "pbkdf2_hmac.__module__.__eq__",
       ["_hashlib"],
       true,
       "hashlib.pbkdf2_hmac.__module__.__eq__('_hashlib') == True — pbkdf2_hmac is implemented in the _hashlib C extension, not the pure Python hashlib module; new anchor in extra234 namespace; verified Python 3.14.3"]
    - [pbkdf2_hmac_name_len_11,
       "pbkdf2_hmac.__name__.__len__",
       [],
       11,
       "hashlib.pbkdf2_hmac.__name__.__len__() == 11 — the string 'pbkdf2_hmac' has 11 characters; same length as 'file_digest'; portable length anchor; new anchor in extra234 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# hashlib.scrypt function identity contracts
#
# hashlib.scrypt.__name__     == 'scrypt'
# hashlib.scrypt.__qualname__ == 'scrypt'
# hashlib.scrypt.__module__   == '_hashlib'
#
# scrypt is the scrypt memory-hard key derivation function (RFC 7914).
# It is implemented in the _hashlib C extension alongside pbkdf2_hmac.
# The function name is 'scrypt' (6 characters).
# ---------------------------------------------------------------------------

table hashlib_extra234.scrypt_identity:
  description: "scrypt.__name__=='scrypt'; __qualname__=='scrypt'; __module__=='_hashlib'; scrypt function identity contracts; new to extra234"
  kind: python_call_eq
  category: identity
  id_prefix: hashlib234a

  columns: [id, function, args, expected, description]
  rows:
    - [scrypt_name_eq,
       "scrypt.__name__.__eq__",
       ["scrypt"],
       true,
       "hashlib.scrypt.__name__.__eq__('scrypt') == True — scrypt is the memory-hard key derivation function defined in RFC 7914; __name__ is 'scrypt' (6 characters); new anchor in extra234 namespace; verified Python 3.14.3"]
    - [scrypt_qualname_eq,
       "scrypt.__qualname__.__eq__",
       ["scrypt"],
       true,
       "hashlib.scrypt.__qualname__.__eq__('scrypt') == True — scrypt is a top-level function so __qualname__ equals __name__; both are 'scrypt' (6 characters); new anchor in extra234 namespace; verified Python 3.14.3"]
    - [scrypt_module_eq,
       "scrypt.__module__.__eq__",
       ["_hashlib"],
       true,
       "hashlib.scrypt.__module__.__eq__('_hashlib') == True — scrypt is implemented in the _hashlib C extension alongside pbkdf2_hmac; new anchor in extra234 namespace; verified Python 3.14.3"]
    - [scrypt_name_len_6,
       "scrypt.__name__.__len__",
       [],
       6,
       "hashlib.scrypt.__name__.__len__() == 6 — the string 'scrypt' has 6 characters; 5 fewer than 'pbkdf2_hmac'; portable length anchor; new anchor in extra234 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# hashlib.file_digest function identity contracts
#
# hashlib.file_digest.__name__     == 'file_digest'
# hashlib.file_digest.__qualname__ == 'file_digest'
# hashlib.file_digest.__module__   == 'hashlib'
#
# file_digest computes a hash digest of a file object (added in Python 3.11).
# Unlike pbkdf2_hmac and scrypt, file_digest is implemented in the pure
# Python hashlib module, so __module__ is 'hashlib' not '_hashlib'.
# ---------------------------------------------------------------------------

table hashlib_extra234.file_digest_identity:
  description: "file_digest.__name__=='file_digest'; __qualname__=='file_digest'; __module__=='hashlib'; file_digest function identity contracts; new to extra234"
  kind: python_call_eq
  category: identity
  id_prefix: hashlib234b

  columns: [id, function, args, expected, description]
  rows:
    - [file_digest_name_eq,
       "file_digest.__name__.__eq__",
       ["file_digest"],
       true,
       "hashlib.file_digest.__name__.__eq__('file_digest') == True — file_digest computes a hash digest of a file object; added in Python 3.11; __name__ is 'file_digest' (11 characters); new anchor in extra234 namespace; verified Python 3.14.3"]
    - [file_digest_qualname_eq,
       "file_digest.__qualname__.__eq__",
       ["file_digest"],
       true,
       "hashlib.file_digest.__qualname__.__eq__('file_digest') == True — file_digest is a top-level function so __qualname__ equals __name__; both are 'file_digest' (11 characters); new anchor in extra234 namespace; verified Python 3.14.3"]
    - [file_digest_module_eq,
       "file_digest.__module__.__eq__",
       ["hashlib"],
       true,
       "hashlib.file_digest.__module__.__eq__('hashlib') == True — unlike pbkdf2_hmac and scrypt, file_digest is implemented in the pure Python hashlib module; __module__ is 'hashlib' not '_hashlib'; new anchor in extra234 namespace; verified Python 3.14.3"]
    - [file_digest_name_len_11,
       "file_digest.__name__.__len__",
       [],
       11,
       "hashlib.file_digest.__name__.__len__() == 11 — the string 'file_digest' has 11 characters; same length as 'pbkdf2_hmac'; portable length anchor; new anchor in extra234 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashlib_extra234.pbkdf2_hmac_name_eq:
  description: "hashlib.pbkdf2_hmac.__name__.__eq__('pbkdf2_hmac') == True — pbkdf2_hmac implements the PBKDF2 (Password-Based Key Derivation Function 2) algorithm using an HMAC pseudorandom function; the function takes hash_name, password, salt, iterations, and optional dklen arguments; it is defined in the _hashlib C extension and exposed via the hashlib module; __name__ is 'pbkdf2_hmac' (11 characters); the name length matches file_digest but differs from scrypt (6); extra234 is the first namespace to anchor hashlib.pbkdf2_hmac.__name__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "pbkdf2_hmac.__name__.__eq__"
  args: ["pbkdf2_hmac"]
  expected: true

invariant hashlib_extra234.scrypt_module_eq:
  description: "hashlib.scrypt.__module__.__eq__('_hashlib') == True — scrypt is the memory-hard key derivation function described in RFC 7914; it requires password, salt, n (CPU/memory cost), r (block size), p (parallelization) parameters; implemented in the _hashlib C extension alongside pbkdf2_hmac; both scrypt and pbkdf2_hmac share the '_hashlib' module, while file_digest uses 'hashlib'; extra234 is the first namespace to anchor hashlib.scrypt.__module__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "scrypt.__module__.__eq__"
  args: ["_hashlib"]
  expected: true

invariant hashlib_extra234.file_digest_module_eq:
  description: "hashlib.file_digest.__module__.__eq__('hashlib') == True — file_digest was added in Python 3.11 to compute the digest of an entire file efficiently; unlike pbkdf2_hmac and scrypt which live in the _hashlib C extension, file_digest is defined in the pure Python hashlib module, so __module__ is 'hashlib'; this contrast is an important identity anchor for distinguishing C-extension vs Python-level hashlib functions; extra234 is the first namespace to anchor hashlib.file_digest.__module__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "file_digest.__module__.__eq__"
  args: ["hashlib"]
  expected: true
