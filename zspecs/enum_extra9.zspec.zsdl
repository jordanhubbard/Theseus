spec: enum_extra9
version: ">=3.11"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum.zspec.zsdl through enum_extra8.zspec.zsdl."
    - "Focus: Python 3.11+ additions to the enum module and IntFlag."
    - "enum.IntFlag.__name__ == 'IntFlag' — covered by prior specs for module, but not __name__.__eq__."
    - "enum.IntFlag.__module__ == 'enum'."
    - "enum.StrEnum.__name__ == 'StrEnum' — new in Python 3.11."
    - "enum.ReprEnum.__name__ == 'ReprEnum' — new in Python 3.11."
    - "enum.nonmember.__name__ == 'nonmember' — new in Python 3.11."
    - "enum.member.__name__ == 'member' — new in Python 3.11."
    - "enum.property.__name__ == 'property' — enum's own property descriptor, new in Python 3.11."
    - "enum.global_enum.__name__ == 'global_enum' — new in Python 3.11."
    - "enum.show_flag_values.__name__ == 'show_flag_values' — present since Python 3.11."
    - "enum.FlagBoundary.__name__ == 'FlagBoundary' — new in Python 3.11."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Python 3.11+ additions — __name__ checks
# Table covers StrEnum, IntFlag, nonmember, member (all Python 3.11+).
# ---------------------------------------------------------------------------

table enum_extra9.py311_names:
  kind: python_call_eq
  category: py311_names
  id_prefix: name

  columns: [id, function, args, expected]
  rows:
    - [StrEnum,   StrEnum.__name__.__eq__,   ["StrEnum"],   true]
    - [IntFlag,   IntFlag.__name__.__eq__,   ["IntFlag"],   true]
    - [nonmember, nonmember.__name__.__eq__, ["nonmember"], true]
    - [member,    member.__name__.__eq__,    ["member"],    true]

# ---------------------------------------------------------------------------
# IntFlag — __module__
# enum_extra8 covers IntEnum.__module__; this adds IntFlag.__module__.
# ---------------------------------------------------------------------------

invariant enum_extra9.IntFlag.module:
  description: "enum.IntFlag.__module__ == 'enum'"
  category: module
  kind: python_call_eq
  function: IntFlag.__module__.__eq__
  args: ["enum"]
  expected: true

# ---------------------------------------------------------------------------
# ReprEnum — new in Python 3.11
# ---------------------------------------------------------------------------

invariant enum_extra9.ReprEnum.name:
  description: "enum.ReprEnum.__name__ == 'ReprEnum'"
  category: py311_names
  kind: python_call_eq
  function: ReprEnum.__name__.__eq__
  args: ["ReprEnum"]
  expected: true

invariant enum_extra9.ReprEnum.module:
  description: "enum.ReprEnum.__module__ == 'enum'"
  category: module
  kind: python_call_eq
  function: ReprEnum.__module__.__eq__
  args: ["enum"]
  expected: true

# ---------------------------------------------------------------------------
# enum.property — enum's own property descriptor (Python 3.11+)
# distinct from the built-in property; lives in enum module namespace
# ---------------------------------------------------------------------------

invariant enum_extra9.enum_property.name:
  description: "enum.property.__name__ == 'property'"
  category: py311_names
  kind: python_call_eq
  function: property.__name__.__eq__
  args: ["property"]
  expected: true

# ---------------------------------------------------------------------------
# enum.global_enum — decorator for exposing Enum members globally (Python 3.11+)
# ---------------------------------------------------------------------------

invariant enum_extra9.global_enum.name:
  description: "enum.global_enum.__name__ == 'global_enum'"
  category: py311_names
  kind: python_call_eq
  function: global_enum.__name__.__eq__
  args: ["global_enum"]
  expected: true

# ---------------------------------------------------------------------------
# enum.show_flag_values — utility function (Python 3.11+)
# ---------------------------------------------------------------------------

invariant enum_extra9.show_flag_values.name:
  description: "enum.show_flag_values.__name__ == 'show_flag_values'"
  category: py311_names
  kind: python_call_eq
  function: show_flag_values.__name__.__eq__
  args: ["show_flag_values"]
  expected: true

# ---------------------------------------------------------------------------
# enum.FlagBoundary — Enum class controlling Flag boundary behavior (Python 3.11+)
# ---------------------------------------------------------------------------

invariant enum_extra9.FlagBoundary.name:
  description: "enum.FlagBoundary.__name__ == 'FlagBoundary'"
  category: py311_names
  kind: python_call_eq
  function: FlagBoundary.__name__.__eq__
  args: ["FlagBoundary"]
  expected: true

invariant enum_extra9.FlagBoundary.module:
  description: "enum.FlagBoundary.__module__ == 'enum'"
  category: module
  kind: python_call_eq
  function: FlagBoundary.__module__.__eq__
  args: ["enum"]
  expected: true

# ---------------------------------------------------------------------------
# StrEnum — hierarchy check (Python 3.11+)
# StrEnum inherits from str and Enum; mro contains str
# ---------------------------------------------------------------------------

invariant enum_extra9.StrEnum.mro_contains_str:
  description: "enum.StrEnum.__mro__[1].__name__ == 'str' — StrEnum inherits from str"
  category: hierarchy
  kind: python_call_eq
  function: StrEnum.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "str"
