spec: re_extra145
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec covers: re.error (alias re.PatternError in Python 3.13+) exception class identity — __name__ ('PatternError', len=12), __module__ ('re'), __qualname__ ('PatternError', len=12), __doc__ length (333), __class__.__name__ ('type'), __bases__[0].__name__ ('Exception'), MRO length (4) and MRO entries. Also covers re.RegexFlag enum class identity — __name__ ('RegexFlag', len=9), __module__ ('re'), __class__.__name__ ('EnumType'), __bases__[0].__name__ ('IntFlag'), MRO length (7) and MRO entries."
    - "re.error.__name__ == 'PatternError' (12 chars) in Python 3.13+; re.error was renamed to re.PatternError as the canonical name. re.error remains as an alias: re.error is re.PatternError is True."
    - "re.error.__module__ == 're' (2 chars)."
    - "re.error.__doc__ len == 333 (covers the exception message format, the msg, pattern, pos, lineno, colno attributes)."
    - "re.error MRO: [PatternError, Exception, BaseException, object] (length 4); __bases__[0] is Exception."
    - "re.RegexFlag.__class__.__name__ == 'EnumType' (not 'type' or 'ABCMeta'); RegexFlag is an IntFlag enum, so its metaclass is EnumType."
    - "re.RegexFlag.__bases__[0].__name__ == 'IntFlag'; MRO length 7: [RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object]."
    - "re.RegexFlag.__doc__ == 'An enumeration.' (15 chars; the default docstring assigned to enum classes)."
    - "re.RegexFlag.__name__ len == 9 ('RegexFlag' has 9 characters)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.error (re.PatternError) exception class identity
# re.error.__name__ == 'PatternError' (12 chars) in Python 3.13+.
# re.error.__module__ == 're' (2 chars).
# re.error.__doc__ len == 333.
# re.error.__class__.__name__ == 'type'.
# re.error.__bases__[0].__name__ == 'Exception'.
# MRO: [PatternError, Exception, BaseException, object] (length 4).
# ---------------------------------------------------------------------------

table re_extra145.error_class_identity:
  description: "re.error class identity: __name__='PatternError' (12), __module__='re' (2), __doc__ len=333 (str), __class__.__name__='type', __bases__[0]='Exception', MRO length=4"
  kind: python_call_eq
  category: class_identity
  id_prefix: reerr145

  columns: [id, function, args, expected, description]
  rows:
    - [err_name_eq,    error.__name__.__eq__,                     ["PatternError"], true, "re.error.__name__ == 'PatternError' (renamed from 'error' in Python 3.13; re.error remains as an alias)"]
    - [err_name_len,   error.__name__.__len__,                    [],               12,   "re.error.__name__.__len__() == 12 ('PatternError' has 12 characters)"]
    - [err_mod_eq,     error.__module__.__eq__,                   ["re"],           true, "re.error.__module__ == 're' (PatternError is defined in the re package)"]
    - [err_mod_len,    error.__module__.__len__,                  [],               2,    "re.error.__module__.__len__() == 2 ('re' has 2 characters)"]
    - [err_doc_cls_eq, error.__doc__.__class__.__name__.__eq__,   ["str"],          true, "re.error.__doc__ is a str (non-None; documents msg, pattern, pos, lineno, colno attributes)"]
    - [err_doc_len,    error.__doc__.__len__,                     [],               333,  "re.error.__doc__.__len__() == 333 (covers the exception attributes msg, pattern, pos, lineno, and colno)"]
    - [err_cls_eq,     error.__class__.__name__.__eq__,           ["type"],         true, "re.error.__class__.__name__ == 'type' (a regular exception class, not an enum or ABC)"]
    - [err_base0_eq,   "error.__bases__[0].__name__.__eq__",      ["Exception"],    true, "re.error.__bases__[0].__name__ == 'Exception' (PatternError directly subclasses Exception)"]
    - [err_mro_len,    "error.__mro__.__len__",                   [],               4,    "re.error.__mro__.__len__() == 4 ([PatternError, Exception, BaseException, object])"]

# ---------------------------------------------------------------------------
# re.error (re.PatternError) MRO entry names
# MRO[0] == 'PatternError'; MRO[1] == 'Exception'.
# MRO[2] == 'BaseException'; MRO[3] == 'object'.
# ---------------------------------------------------------------------------

table re_extra145.error_mro_entries:
  description: "re.error MRO entries: [0]='PatternError', [1]='Exception', [2]='BaseException', [3]='object'"
  kind: python_call_eq
  category: class_identity
  id_prefix: reerr145

  columns: [id, function, args, expected, description]
  rows:
    - [err_mro0_eq, "error.__mro__[0].__name__.__eq__", ["PatternError"],  true, "re.error.__mro__[0].__name__ == 'PatternError' (the exception class itself is its own first MRO entry)"]
    - [err_mro1_eq, "error.__mro__[1].__name__.__eq__", ["Exception"],     true, "re.error.__mro__[1].__name__ == 'Exception' (direct parent; PatternError is a regular exception)"]
    - [err_mro2_eq, "error.__mro__[2].__name__.__eq__", ["BaseException"], true, "re.error.__mro__[2].__name__ == 'BaseException' (grandparent; the root of the exception hierarchy below object)"]
    - [err_mro3_eq, "error.__mro__[3].__name__.__eq__", ["object"],        true, "re.error.__mro__[3].__name__ == 'object' (the universal base class; always last in any Python MRO)"]

# ---------------------------------------------------------------------------
# re.RegexFlag enum class identity
# RegexFlag.__name__ == 'RegexFlag' (9 chars).
# RegexFlag.__module__ == 're' (2 chars).
# RegexFlag.__class__.__name__ == 'EnumType' (the enum metaclass).
# RegexFlag.__bases__[0].__name__ == 'IntFlag'.
# RegexFlag.__doc__ == 'An enumeration.' (15 chars; default enum docstring).
# MRO: [RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object] (length 7).
# ---------------------------------------------------------------------------

table re_extra145.RegexFlag_class_identity:
  description: "re.RegexFlag class identity: __name__='RegexFlag' (9), __module__='re' (2), __doc__ len=15 (str), __class__.__name__='EnumType', __bases__[0]='IntFlag', MRO length=7"
  kind: python_call_eq
  category: class_identity
  id_prefix: rerflag145

  columns: [id, function, args, expected, description]
  rows:
    - [rflag_name_eq,    RegexFlag.__name__.__eq__,                    ["RegexFlag"], true, "re.RegexFlag.__name__ == 'RegexFlag'"]
    - [rflag_name_len,   RegexFlag.__name__.__len__,                   [],            9,    "re.RegexFlag.__name__.__len__() == 9 ('RegexFlag' has 9 characters)"]
    - [rflag_mod_eq,     RegexFlag.__module__.__eq__,                  ["re"],        true, "re.RegexFlag.__module__ == 're'"]
    - [rflag_mod_len,    RegexFlag.__module__.__len__,                 [],            2,    "re.RegexFlag.__module__.__len__() == 2 ('re' has 2 characters)"]
    - [rflag_doc_cls_eq, RegexFlag.__doc__.__class__.__name__.__eq__,  ["str"],       true, "re.RegexFlag.__doc__ is a str ('An enumeration.' — the default docstring for enum classes)"]
    - [rflag_doc_len,    RegexFlag.__doc__.__len__,                    [],            15,   "re.RegexFlag.__doc__.__len__() == 15 ('An enumeration.' has 15 characters including the period)"]
    - [rflag_meta_eq,    RegexFlag.__class__.__name__.__eq__,          ["EnumType"],  true, "re.RegexFlag.__class__.__name__ == 'EnumType' (the metaclass for all Python enum classes; not 'type' or 'ABCMeta')"]
    - [rflag_base0_eq,   "RegexFlag.__bases__[0].__name__.__eq__",     ["IntFlag"],   true, "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' (RegexFlag extends IntFlag, which is itself an int subclass with bitwise flag support)"]
    - [rflag_mro_len,    "RegexFlag.__mro__.__len__",                  [],            7,    "re.RegexFlag.__mro__.__len__() == 7 ([RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object])"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra145.error.name_is_PatternError:
  description: "re.error.__name__ == 'PatternError' (in Python 3.13+, the exception was officially renamed from 'error' to 'PatternError'; re.error remains as a backward-compatible alias, so re.error is re.PatternError evaluates to True; the __name__ attribute reflects the canonical new name 'PatternError' with 12 characters)"
  category: class_identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra145.error.doc_len_333:
  description: "re.error.__doc__.__len__() == 333 (the PatternError docstring documents the exception's attributes: msg (the unformatted error message), pattern (the regex pattern string), pos (where in the string the error occurred), lineno, and colno; at 333 characters it is substantially longer than re.Pattern.__doc__ (35) and re.Match.__doc__ (92) covered in re_extra144)"
  category: doc_identity
  kind: python_call_eq
  function: error.__doc__.__len__
  args: []
  expected: 333

invariant re_extra145.error.mro_len_4:
  description: "re.error.__mro__.__len__() == 4 (MRO is [PatternError, Exception, BaseException, object]; the standard 4-entry MRO for a direct Exception subclass; unlike re.RegexFlag whose MRO has 7 entries due to the enum inheritance chain)"
  category: class_identity
  kind: python_call_eq
  function: "error.__mro__.__len__"
  args: []
  expected: 4

invariant re_extra145.error.base_is_Exception:
  description: "re.error.__bases__[0].__name__ == 'Exception' (PatternError directly subclasses Exception; this means catching 'except Exception' will catch PatternError instances; the MRO is [PatternError, Exception, BaseException, object] with no intermediate classes)"
  category: class_identity
  kind: python_call_eq
  function: "error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant re_extra145.RegexFlag.meta_is_EnumType:
  description: "re.RegexFlag.__class__.__name__ == 'EnumType' (RegexFlag's metaclass is EnumType — the metaclass used by Python's enum module for all Enum subclasses; this distinguishes RegexFlag from regular classes (metaclass 'type') and abstract base classes (metaclass 'ABCMeta'); EnumType enables the enum protocol including member iteration and value lookup)"
  category: class_identity
  kind: python_call_eq
  function: RegexFlag.__class__.__name__.__eq__
  args: ["EnumType"]
  expected: true

invariant re_extra145.RegexFlag.mro_len_7:
  description: "re.RegexFlag.__mro__.__len__() == 7 (MRO is [RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object]; the deep MRO reflects the IntFlag inheritance chain — IntFlag inherits from int and from Flag which inherits from ReprEnum which inherits from Enum; this 7-entry MRO contrasts sharply with re.error's 4-entry MRO)"
  category: class_identity
  kind: python_call_eq
  function: "RegexFlag.__mro__.__len__"
  args: []
  expected: 7

invariant re_extra145.RegexFlag.base_is_IntFlag:
  description: "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' (RegexFlag extends IntFlag, which provides integer-value flag behavior with bitwise AND/OR/XOR support; IGNORECASE | MULTILINE produces a combined RegexFlag value; this design allows flags to be combined and passed as a single integer to C extension regex engine)"
  category: class_identity
  kind: python_call_eq
  function: "RegexFlag.__bases__[0].__name__.__eq__"
  args: ["IntFlag"]
  expected: true

invariant re_extra145.RegexFlag.doc_len_15:
  description: "re.RegexFlag.__doc__.__len__() == 15 (the string 'An enumeration.' has 15 characters; this is the default docstring assigned by Python's enum metaclass to any Enum subclass that does not define its own docstring; RegexFlag does not define a custom docstring, so it inherits this generic one)"
  category: doc_identity
  kind: python_call_eq
  function: RegexFlag.__doc__.__len__
  args: []
  expected: 15

