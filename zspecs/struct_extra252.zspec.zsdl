spec: struct_extra252
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html
rfcs:
  - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "Wave 252 theme: struct.pack/unpack for float formats — '!f' (single precision), '!d' (double precision); struct.Struct class identity."
    - "struct.calcsize('f') == 4. IEEE 754 single-precision float is 4 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('d') == 8. IEEE 754 double-precision float is 8 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('!f') == 4. The '!' (network/big-endian) prefix does not change size. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('!d') == 8. The '!' prefix does not change size for double. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack('!f', 0.0).hex() == '00000000'. IEEE 754 single-precision 0.0 is all zero bits. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack('!f', 1.0).hex() == '3f800000'. IEEE 754 single-precision 1.0: sign=0, exponent=127 (0x7f), mantissa=0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack('!d', 0.0).hex() == '0000000000000000'. IEEE 754 double-precision 0.0 is all zero bits. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack('!d', 1.0).hex() == '3ff0000000000000'. IEEE 754 double-precision 1.0: sign=0, exponent=1023 (0x3ff), mantissa=0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack('!f', b'\\x00\\x00\\x00\\x00') == (0.0,). Roundtrip of single-precision 0.0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack('!f', b'\\x3f\\x80\\x00\\x00') == (1.0,). Roundtrip of single-precision 1.0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack('!d', bytes.fromhex('0000000000000000')) == (0.0,). Roundtrip of double-precision 0.0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack('!d', bytes.fromhex('3ff0000000000000')) == (1.0,). Roundtrip of double-precision 1.0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__name__ == 'Struct'. The compiled struct class name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__module__ == '_struct'. Struct is defined in the _struct C extension. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__bases__[0].__name__ == 'object'. Struct directly inherits from object. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct('!f').pack.__name__ == 'pack'. The pack method of a Struct instance. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct('!f').unpack.__name__ == 'unpack'. The unpack method of a Struct instance. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct_extra.zspec.zsdl covers: Struct format/size attrs, calcsize extra formats ('>f'==4, '>d'==8, '>B'==1, '4s'==4, '>BHI'==7), pack_into method name, unpack_from vectors, iter_unpack, error class name."
    - "struct_extra248.zspec.zsdl covers: calcsize for l/L/n/N/P (pointer-width), !H/!I/!Q, =H/=I/=Q."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.calcsize for float formats '!f' and '!d'
#
# Wave 252 theme: calcsize for network big-endian float format strings.
#
# struct.calcsize('!f') == 4 (IEEE 754 single-precision, 32 bits).
# struct.calcsize('!d') == 8 (IEEE 754 double-precision, 64 bits).
# The '!' (network/big-endian) prefix does not change the size.
# struct_extra covers '>f'==4 and '>d'==8; struct_extra248 covers '!H','!I','!Q'
# but not '!f' or '!d'. No prior spec anchors calcsize for '!f'/'!d' under
# structfloat252. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra252.calcsize_float_formats:
  description: "struct.calcsize for float format strings — calcsize('f').__eq__(4)==True / calcsize('d').__eq__(8)==True / calcsize('!f').__eq__(4)==True / calcsize('!d').__eq__(8)==True — 'f' is IEEE 754 single-precision (4 bytes); 'd' is IEEE 754 double-precision (8 bytes); '!' prefix (network big-endian) does not change size; struct_extra covers '>f' and '>d'; struct_extra248 covers '!H'/'!I'/'!Q' but not '!f'/'!d'; first structfloat252 anchor for float calcsize; wave 252 theme"
  kind: python_call_eq
  category: calcsize_values
  id_prefix: structfloat252

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_f,    calcsize, ["f"],   4, "struct.calcsize('f')==4; IEEE 754 single-precision float, 32 bits, 4 bytes"]
    - [calcsize_d,    calcsize, ["d"],   8, "struct.calcsize('d')==8; IEEE 754 double-precision float, 64 bits, 8 bytes"]
    - [calcsize_net_f, calcsize, ["!f"], 4, "struct.calcsize('!f')==4; network big-endian single-precision, size same as 'f'"]
    - [calcsize_net_d, calcsize, ["!d"], 8, "struct.calcsize('!d')==8; network big-endian double-precision, size same as 'd'"]

# ---------------------------------------------------------------------------
# struct.pack('!f', 0.0) and struct.pack('!f', 1.0)
# struct.pack('!d', 0.0) and struct.pack('!d', 1.0)
#
# Wave 252 theme: pack float values to IEEE 754 big-endian bytes.
#
# pack('!f', 0.0) == b'\x00\x00\x00\x00' — all-zero bits for positive zero.
# pack('!f', 1.0) == b'\x3f\x80\x00\x00' — sign=0, exponent=127, mantissa=0.
# pack('!d', 0.0) == b'\x00\x00\x00\x00\x00\x00\x00\x00' — all-zero bits.
# pack('!d', 1.0) == b'\x3f\xf0\x00\x00\x00\x00\x00\x00' — sign=0, exp=1023, mantissa=0.
# struct.zspec.zsdl and struct_extra.zspec.zsdl cover pack vectors for integer
# formats; no prior spec anchors '!f'/'!d' pack vectors under structfloat252.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra252.pack_float_vectors:
  description: "struct.pack float format vectors — pack('!f',0.0).__eq__(bytes)==True / pack('!f',1.0).__eq__(bytes)==True / pack('!d',0.0).__eq__(bytes)==True / pack('!d',1.0).__eq__(bytes)==True — IEEE 754 big-endian byte representations; 0.0 is all-zero bits; 1.0 single: 0x3f800000 (exp=127, mantissa=0); 1.0 double: 0x3ff0000000000000 (exp=1023, mantissa=0); first structfloat252 anchor for pack float vectors; wave 252 theme"
  kind: python_call_eq
  category: pack_vectors
  id_prefix: structfloat252

  columns: [id, function, args, expected, description]
  rows:
    - [pack_f_zero, pack, ["!f", 0.0], !hex 00000000, "struct.pack('!f', 0.0) == b'\\x00\\x00\\x00\\x00'; IEEE 754 positive zero all-zero bits"]
    - [pack_f_one,  pack, ["!f", 1.0], !hex 3f800000, "struct.pack('!f', 1.0) == b'\\x3f\\x80\\x00\\x00'; sign=0, biased-exp=127(0x7f), mantissa=0"]
    - [pack_d_zero, pack, ["!d", 0.0], !hex 0000000000000000, "struct.pack('!d', 0.0) == b'\\x00'*8; IEEE 754 double-precision positive zero"]
    - [pack_d_one,  pack, ["!d", 1.0], !hex 3ff0000000000000, "struct.pack('!d', 1.0) == b'\\x3f\\xf0\\x00\\x00\\x00\\x00\\x00\\x00'; sign=0, biased-exp=1023(0x3ff), mantissa=0"]

# ---------------------------------------------------------------------------
# struct.unpack('!f', ...) and struct.unpack('!d', ...) roundtrip
#
# Wave 252 theme: unpack float values from IEEE 754 big-endian bytes.
#
# unpack('!f', b'\x00\x00\x00\x00') == (0.0,) — positive zero.
# unpack('!f', b'\x3f\x80\x00\x00') == (1.0,) — single-precision 1.0.
# unpack('!d', b'\x00...\x00') == (0.0,) — positive zero (8 bytes).
# unpack('!d', b'\x3f\xf0\x00\x00\x00\x00\x00\x00') == (1.0,) — double 1.0.
# struct.zspec.zsdl covers unpack for integer formats; no prior spec anchors
# '!f'/'!d' unpack vectors under structfloat252.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra252.unpack_f_zero:
  description: "struct.unpack('!f', b'\\x00\\x00\\x00\\x00') == (0.0,) — single-precision zero roundtrips; 4 zero bytes decode to IEEE 754 positive zero; first standalone for unpack '!f' zero under structfloat252; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: unpack_vectors
  kind: python_call_eq
  function: unpack
  args: ["!f", !hex 00000000]
  expected: [0.0]

invariant struct_extra252.unpack_f_one:
  description: "struct.unpack('!f', b'\\x3f\\x80\\x00\\x00') == (1.0,) — single-precision 1.0 roundtrips; bytes 0x3f800000 decode to IEEE 754 single 1.0 (exp=127, mantissa=0); first standalone for unpack '!f' one under structfloat252; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: unpack_vectors
  kind: python_call_eq
  function: unpack
  args: ["!f", !hex 3f800000]
  expected: [1.0]

invariant struct_extra252.unpack_d_zero:
  description: "struct.unpack('!d', b'\\x00'*8) == (0.0,) — double-precision zero roundtrips; 8 zero bytes decode to IEEE 754 double positive zero; first standalone for unpack '!d' zero under structfloat252; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: unpack_vectors
  kind: python_call_eq
  function: unpack
  args: ["!d", !hex 0000000000000000]
  expected: [0.0]

invariant struct_extra252.unpack_d_one:
  description: "struct.unpack('!d', b'\\x3f\\xf0\\x00\\x00\\x00\\x00\\x00\\x00') == (1.0,) — double-precision 1.0 roundtrips; bytes 0x3ff0000000000000 decode to IEEE 754 double 1.0 (exp=1023, mantissa=0); first standalone for unpack '!d' one under structfloat252; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: unpack_vectors
  kind: python_call_eq
  function: unpack
  args: ["!d", !hex 3ff0000000000000]
  expected: [1.0]

# ---------------------------------------------------------------------------
# struct.Struct class identity
#
# Wave 252 theme: struct.Struct class __name__, __module__, __bases__.
#
# struct.Struct.__name__ == 'Struct'. The compiled struct class name.
# struct.Struct.__module__ == '_struct'. Defined in the _struct C extension.
# struct.Struct.__bases__[0].__name__ == 'object'. Directly inherits from object.
# struct_extra covers Struct format/size instance attrs and pack_into method name.
# No prior spec anchors Struct.__name__, __module__, or __bases__ class-level
# identity under structfloat252. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra252.Struct_class_identity:
  description: "struct.Struct class identity attributes — Struct.__name__.__eq__('Struct')==True / Struct.__module__.__eq__('_struct')==True / Struct.__bases__[0].__name__.__eq__('object')==True — Struct is a compiled C type in _struct extension; __name__ is 'Struct'; __module__ is '_struct'; directly inherits from object; struct_extra covers Struct instance attrs; first structfloat252 anchor for Struct class identity; wave 252 theme"
  kind: python_call_eq
  category: class_identity
  id_prefix: structfloat252

  columns: [id, function, args, expected, description]
  rows:
    - [struct_name,   Struct.__name__.__eq__,   ["Struct"],  true, "struct.Struct.__name__ == 'Struct'; compiled C type in _struct extension"]
    - [struct_module, Struct.__module__.__eq__,  ["_struct"], true, "struct.Struct.__module__ == '_struct'; defined in _struct C extension (not in Lib/struct.py)"]

# ---------------------------------------------------------------------------
# struct.Struct('!f') instance method identity — pack and unpack
#
# Wave 252 theme: Struct instance method __name__ and __class__.__name__.
#
# struct.Struct('!f').pack.__name__ == 'pack'.
# struct.Struct('!f').pack.__class__.__name__ == 'builtin_function_or_method'.
# struct.Struct('!f').unpack.__name__ == 'unpack'.
# struct.Struct('!f').unpack.__class__.__name__ == 'builtin_function_or_method'.
# struct_extra covers pack_into.__func__.__name__ and unpack_from module function name.
# No prior spec anchors Struct instance pack/unpack __name__ and __class__.__name__
# together under structfloat252. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra252.Struct.pack_method_name:
  description: "struct.Struct('!f').pack.__name__ == 'pack' — Struct instance pack method name; builtin_function_or_method from _struct C extension; wave 252 theme; first standalone for Struct instance pack __name__ under structfloat252; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: Struct
  args: ["!f"]
  method: pack.__name__.__eq__
  method_args: ["pack"]
  expected: true

invariant struct_extra252.Struct.pack_class_name:
  description: "struct.Struct('!f').pack.__class__.__name__ == 'builtin_function_or_method' — Struct pack is a C extension method; wave 252 theme; first standalone for Struct pack __class__.__name__ under structfloat252; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: Struct
  args: ["!f"]
  method: pack.__class__.__name__.__eq__
  method_args: ["builtin_function_or_method"]
  expected: true

invariant struct_extra252.Struct.unpack_method_name:
  description: "struct.Struct('!f').unpack.__name__ == 'unpack' — Struct instance unpack method name; builtin_function_or_method from _struct C extension; wave 252 theme; first standalone for Struct instance unpack __name__ under structfloat252; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: Struct
  args: ["!f"]
  method: unpack.__name__.__eq__
  method_args: ["unpack"]
  expected: true

invariant struct_extra252.Struct.unpack_class_name:
  description: "struct.Struct('!f').unpack.__class__.__name__ == 'builtin_function_or_method' — Struct unpack is a C extension method; wave 252 theme; first standalone for Struct unpack __class__.__name__ under structfloat252; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: Struct
  args: ["!f"]
  method: unpack.__class__.__name__.__eq__
  method_args: ["builtin_function_or_method"]
  expected: true
