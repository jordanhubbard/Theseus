spec: geolib
version: ">=3.0.0"
backend: node(geolib)

docs: https://www.npmjs.com/package/geolib

provenance:
  derived_from:
    - "geolib README — https://www.npmjs.com/package/geolib"
    - "Test vectors verified with geolib via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "geolib source"
  notes:
    - "geolib is an npm package. Install: npm install geolib"
    - "getDistance(from, to) returns distance in meters between two geographic coordinates."
    - "isPointInPolygon(point, polygon) returns true if point is inside the polygon."
    - "Coordinates use {latitude, longitude} objects."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns computed geographic value."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table geolib.getDistance:
  kind: node_module_call_eq
  function: getDistance
  category: distance
  id_prefix: geod

  columns: [id, args, expected]
  rows:
    - [same,        [{"latitude": 0, "longitude": 0}, {"latitude": 0, "longitude": 0}],  0]
    - [one_lng_deg, [{"latitude": 0, "longitude": 0}, {"latitude": 0, "longitude": 1}],  111319]
    - [one_lat_deg, [{"latitude": 0, "longitude": 0}, {"latitude": 1, "longitude": 0}],  111319]

table geolib.isPointInPolygon:
  kind: node_module_call_eq
  function: isPointInPolygon
  category: polygon
  id_prefix: geop

  columns: [id, args, expected]
  rows:
    - [inside,  [{"lat": 1, "lon": 1},
                 [{"lat": 0, "lon": 0}, {"lat": 0, "lon": 2},
                  {"lat": 2, "lon": 2}, {"lat": 2, "lon": 0}]],
                true]
    - [outside, [{"lat": 3, "lon": 3},
                 [{"lat": 0, "lon": 0}, {"lat": 0, "lon": 2},
                  {"lat": 2, "lon": 2}, {"lat": 2, "lon": 0}]],
                false]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T18:35:50Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
