spec: re3466
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 678 (re3466): __iter__, __next__, __len__ dict-presence checks for re types."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "Theme: __iter__/__next__/__len__ dict-presence (iterator/sequence protocol)."
    - "re.Match defines __getitem__ (wave 677, true) but does NOT define __iter__, __next__, or __len__ in its own __dict__ (all false)."
    - "re.Pattern and re.RegexFlag do not define any of the three in their own __dict__ (false)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __iter__ dict-presence — operator.contains(Cls.__dict__, '__iter__')
#
# No re class defines __iter__ in its own __dict__; all false.
# re.Match supports subscript access via __getitem__ (wave 677) but does
# not define __iter__. re.Pattern and re.RegexFlag are also false.
# ---------------------------------------------------------------------------

table re3466.iter:
  description: "re types __iter__ dict-presence checks; wave 678"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3466

  columns: [id, function, args, expected]
  rows:
    - ["re3466001", operator.contains, [re.Pattern.__dict__,   "__iter__"], false]
    - ["re3466002", operator.contains, [re.Match.__dict__,     "__iter__"], false]
    - ["re3466003", operator.contains, [re.RegexFlag.__dict__, "__iter__"], false]

# ---------------------------------------------------------------------------
# __next__ dict-presence — operator.contains(Cls.__dict__, '__next__')
#
# No re class defines __next__ in its own __dict__; all false.
# re.Match, re.Pattern, and re.RegexFlag do not implement the iterator
# advancement method in their own __dict__s.
# ---------------------------------------------------------------------------

table re3466.next:
