spec: hashlib_extra185
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_blake2/"
  notes:
    - "hashlib.blake2b.__name__ == 'blake2b' — the C-level class name; module is _blake2."
    - "hashlib.blake2s.__name__ == 'blake2s' — the C-level class name; module is _blake2."
    - "hashlib.blake2b.MAX_DIGEST_SIZE == 64 — BLAKE2b produces up to 512-bit (64-byte) digests."
    - "hashlib.blake2s.MAX_DIGEST_SIZE == 32 — BLAKE2s produces up to 256-bit (32-byte) digests."
    - "hashlib.blake2b.PERSON_SIZE == 16 — BLAKE2b personalization string is up to 16 bytes."
    - "hashlib.blake2s.PERSON_SIZE == 8 — BLAKE2s personalization string is up to 8 bytes."
    - "hashlib.blake2b.SALT_SIZE == 16 — BLAKE2b salt is up to 16 bytes."
    - "hashlib.blake2s.SALT_SIZE == 8 — BLAKE2s salt is up to 8 bytes."
    - "hashlib.blake2b.MAX_KEY_SIZE == 64 — BLAKE2b keyed mode supports up to 64-byte keys."
    - "hashlib.blake2s.MAX_KEY_SIZE == 32 — BLAKE2s keyed mode supports up to 32-byte keys."
    - "hashlib.blake2b.__bases__[0].__name__ == 'object' — blake2b is a direct C extension type."
    - "hashlib.blake2s.__bases__[0].__name__ == 'object' — blake2s is a direct C extension type."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: blake2b class-level size constants
#
# hashlib.blake2b.MAX_DIGEST_SIZE == 64  (BLAKE2b max digest = 512 bits = 64 bytes)
# hashlib.blake2b.PERSON_SIZE    == 16  (personalization string max = 16 bytes)
# hashlib.blake2b.SALT_SIZE      == 16  (salt max = 16 bytes)
# hashlib.blake2b.MAX_KEY_SIZE   == 64  (keyed-mode key max = 64 bytes)
#
# All are C-level integer constants on the blake2b type object. New to extra185.
# ---------------------------------------------------------------------------

table hashlib_extra185.blake2b_size_constants:
  description: "blake2b class-level MAX_DIGEST_SIZE, PERSON_SIZE, SALT_SIZE, MAX_KEY_SIZE constants; new to extra185"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibblake185

  columns: [id, function, args, expected, description]
  rows:
    - [b2b_max_digest_size,
       blake2b.MAX_DIGEST_SIZE.__eq__,
       [64],
       true,
       "hashlib.blake2b.MAX_DIGEST_SIZE.__eq__(64) == True — BLAKE2b max digest is 512 bits (64 bytes); new to extra185"]
    - [b2b_person_size,
       blake2b.PERSON_SIZE.__eq__,
       [16],
       true,
       "hashlib.blake2b.PERSON_SIZE.__eq__(16) == True — BLAKE2b personalization string is up to 16 bytes; new to extra185"]
    - [b2b_salt_size,
       blake2b.SALT_SIZE.__eq__,
       [16],
       true,
       "hashlib.blake2b.SALT_SIZE.__eq__(16) == True — BLAKE2b salt is up to 16 bytes; new to extra185"]
    - [b2b_max_key_size,
       blake2b.MAX_KEY_SIZE.__eq__,
       [64],
       true,
       "hashlib.blake2b.MAX_KEY_SIZE.__eq__(64) == True — BLAKE2b keyed mode supports up to 64-byte keys; new to extra185"]

# ---------------------------------------------------------------------------
# Table 2: blake2s class-level size constants
#
# hashlib.blake2s.MAX_DIGEST_SIZE == 32  (BLAKE2s max digest = 256 bits = 32 bytes)
# hashlib.blake2s.PERSON_SIZE    ==  8  (personalization string max = 8 bytes)
# hashlib.blake2s.SALT_SIZE      ==  8  (salt max = 8 bytes)
# hashlib.blake2s.MAX_KEY_SIZE   == 32  (keyed-mode key max = 32 bytes)
#
# All are C-level integer constants on the blake2s type object. New to extra185.
# ---------------------------------------------------------------------------

table hashlib_extra185.blake2s_size_constants:
  description: "blake2s class-level MAX_DIGEST_SIZE, PERSON_SIZE, SALT_SIZE, MAX_KEY_SIZE constants; new to extra185"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibblake185

  columns: [id, function, args, expected, description]
  rows:
    - [b2s_max_digest_size,
       blake2s.MAX_DIGEST_SIZE.__eq__,
       [32],
       true,
       "hashlib.blake2s.MAX_DIGEST_SIZE.__eq__(32) == True — BLAKE2s max digest is 256 bits (32 bytes); new to extra185"]
    - [b2s_person_size,
       blake2s.PERSON_SIZE.__eq__,
       [8],
       true,
       "hashlib.blake2s.PERSON_SIZE.__eq__(8) == True — BLAKE2s personalization string is up to 8 bytes; new to extra185"]
    - [b2s_salt_size,
       blake2s.SALT_SIZE.__eq__,
       [8],
       true,
       "hashlib.blake2s.SALT_SIZE.__eq__(8) == True — BLAKE2s salt is up to 8 bytes; new to extra185"]
    - [b2s_max_key_size,
       blake2s.MAX_KEY_SIZE.__eq__,
       [32],
       true,
       "hashlib.blake2s.MAX_KEY_SIZE.__eq__(32) == True — BLAKE2s keyed mode supports up to 32-byte keys; new to extra185"]

# ---------------------------------------------------------------------------
# Table 3: blake2b and blake2s class identity attributes
#
# hashlib.blake2b.__name__           == 'blake2b'  (C-level type name)
# hashlib.blake2s.__name__           == 'blake2s'  (C-level type name)
# hashlib.blake2b.__qualname__       == 'blake2b'
# hashlib.blake2s.__qualname__       == 'blake2s'
# hashlib.blake2b.__bases__[0].__name__ == 'object'
# hashlib.blake2s.__bases__[0].__name__ == 'object'
#
# Both types are C extension types from the _blake2 module. New to extra185.
# ---------------------------------------------------------------------------

table hashlib_extra185.blake2_type_identity:
  description: "blake2b and blake2s __name__, __qualname__, and __bases__ identity; new to extra185"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibblake185

  columns: [id, function, args, expected, description]
  rows:
    - [b2b_name_eq,
       blake2b.__name__.__eq__,
       ["blake2b"],
       true,
       "hashlib.blake2b.__name__.__eq__('blake2b') == True — the C-level type is named 'blake2b'; new to extra185"]
    - [b2s_name_eq,
       blake2s.__name__.__eq__,
       ["blake2s"],
       true,
       "hashlib.blake2s.__name__.__eq__('blake2s') == True — the C-level type is named 'blake2s'; new to extra185"]
    - [b2b_qualname_eq,
       blake2b.__qualname__.__eq__,
       ["blake2b"],
       true,
       "hashlib.blake2b.__qualname__.__eq__('blake2b') == True — qualname matches name for top-level type; new to extra185"]
    - [b2s_qualname_eq,
       blake2s.__qualname__.__eq__,
       ["blake2s"],
       true,
       "hashlib.blake2s.__qualname__.__eq__('blake2s') == True — qualname matches name for top-level type; new to extra185"]
    - [b2b_base_name_eq,
       "blake2b.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "hashlib.blake2b.__bases__[0].__name__.__eq__('object') == True — blake2b is a direct C extension type with object as base; new to extra185"]
    - [b2s_base_name_eq,
       "blake2s.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "hashlib.blake2s.__bases__[0].__name__.__eq__('object') == True — blake2s is a direct C extension type with object as base; new to extra185"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra185
# ---------------------------------------------------------------------------

invariant hashlib_extra185.blake2b_max_digest_size_is_64:
  description: "hashlib.blake2b.MAX_DIGEST_SIZE == 64 — BLAKE2b max digest is 512 bits (64 bytes); new to extra185"
  category: identity
  kind: python_call_eq
  function: blake2b.MAX_DIGEST_SIZE.__eq__
  args: [64]
  expected: true

invariant hashlib_extra185.blake2s_max_digest_size_is_32:
  description: "hashlib.blake2s.MAX_DIGEST_SIZE == 32 — BLAKE2s max digest is 256 bits (32 bytes); new to extra185"
  category: identity
  kind: python_call_eq
  function: blake2s.MAX_DIGEST_SIZE.__eq__
  args: [32]
  expected: true

invariant hashlib_extra185.blake2b_person_size_is_16:
  description: "hashlib.blake2b.PERSON_SIZE == 16 — BLAKE2b personalization string is up to 16 bytes; new to extra185"
  category: identity
  kind: python_call_eq
  function: blake2b.PERSON_SIZE.__eq__
  args: [16]
  expected: true

invariant hashlib_extra185.blake2s_person_size_is_8:
  description: "hashlib.blake2s.PERSON_SIZE == 8 — BLAKE2s personalization string is up to 8 bytes; new to extra185"
  category: identity
  kind: python_call_eq
  function: blake2s.PERSON_SIZE.__eq__
  args: [8]
  expected: true

invariant hashlib_extra185.blake2b_salt_size_is_16:
  description: "hashlib.blake2b.SALT_SIZE == 16 — BLAKE2b salt is up to 16 bytes; new to extra185"
  category: identity
  kind: python_call_eq
  function: blake2b.SALT_SIZE.__eq__
  args: [16]
  expected: true

invariant hashlib_extra185.blake2s_salt_size_is_8:
  description: "hashlib.blake2s.SALT_SIZE == 8 — BLAKE2s salt is up to 8 bytes; new to extra185"
  category: identity
  kind: python_call_eq
  function: blake2s.SALT_SIZE.__eq__
  args: [8]
  expected: true

invariant hashlib_extra185.blake2b_max_key_size_is_64:
  description: "hashlib.blake2b.MAX_KEY_SIZE == 64 — BLAKE2b keyed mode supports up to 64-byte keys; new to extra185"
  category: identity
  kind: python_call_eq
  function: blake2b.MAX_KEY_SIZE.__eq__
  args: [64]
  expected: true

invariant hashlib_extra185.blake2s_max_key_size_is_32:
  description: "hashlib.blake2s.MAX_KEY_SIZE == 32 — BLAKE2s keyed mode supports up to 32-byte keys; new to extra185"
  category: identity
  kind: python_call_eq
  function: blake2s.MAX_KEY_SIZE.__eq__
  args: [32]
  expected: true

invariant hashlib_extra185.blake2b_name_is_blake2b:
  description: "hashlib.blake2b.__name__ == 'blake2b' — the C-level BLAKE2b type name; new to extra185"
  category: identity
  kind: python_call_eq
  function: blake2b.__name__.__eq__
  args: ["blake2b"]
  expected: true

invariant hashlib_extra185.blake2s_name_is_blake2s:
  description: "hashlib.blake2s.__name__ == 'blake2s' — the C-level BLAKE2s type name; new to extra185"
  category: identity
  kind: python_call_eq
  function: blake2s.__name__.__eq__
  args: ["blake2s"]
  expected: true
