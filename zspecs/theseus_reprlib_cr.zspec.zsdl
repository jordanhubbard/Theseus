spec: theseus_reprlib_cr
version: ">=3.9"
backend: python_cleanroom(theseus_reprlib_cr)
blocks: reprlib

docs: https://docs.python.org/3/library/reprlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/reprlib.html"
  notes:
    - "Clean-room truncating repr utility. Do NOT import reprlib."
    - "repr(obj): return abbreviated string representation, truncating long sequences."
    - "Repr class: configurable repr with maxlist, maxstring, etc. attributes."
    - "reprlib_repr_long_list(): repr(list(range(100))) is truncated (contains '...')."
    - "reprlib_repr_short_list(): repr([1,2,3]) == '[1, 2, 3]'."
    - "reprlib_repr_long_str(): repr('x'*1000) is truncated."
    - "Export: repr function, Repr class."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_reprlib_cr.repr_long_list_truncated:
  description: "repr(list(range(100))) contains '...'"
  category: repr
  kind: python_call_eq
  function: reprlib_repr_long_list
  args: []
  expected: true

invariant theseus_reprlib_cr.repr_short_list:
  description: "repr([1,2,3]) == '[1, 2, 3]'"
  category: repr
  kind: python_call_eq
  function: reprlib_repr_short_list
  args: []
  expected: "[1, 2, 3]"

invariant theseus_reprlib_cr.repr_long_str_truncated:
  description: "repr('x'*1000) is truncated (contains '...')"
  category: repr
  kind: python_call_eq
  function: reprlib_repr_long_str
  args: []
  expected: true
