spec: functools_extra107
version: ">=3.9"
backend: python_module(functools)
extends: functools_extra106

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra106.zspec.zsdl."
    - "This spec covers: functools module __spec__ and __loader__ class identity including __module__ attrs; functools function __module__ lengths (reduce/_functools vs lru_cache/singledispatch/wraps/cache which are functools); functools.__spec__.name and has_location; functools.__file__ class name; wave 259."
    - "functools.__spec__.__class__.__name__ == 'ModuleSpec'. Verified with Python 3.14.3."
    - "functools.__spec__.__class__.__module__ == '_frozen_importlib'. Verified with Python 3.14.3."
    - "functools.__loader__.__class__.__name__ == 'SourceFileLoader'. Verified with Python 3.14.3."
    - "functools.__loader__.__class__.__module__ == '_frozen_importlib_external'. Verified with Python 3.14.3."
    - "functools.__spec__.name == 'functools' (len 9). Verified with Python 3.14.3."
    - "functools.__spec__.has_location == True. Verified with Python 3.14.3."
    - "functools.__file__.__class__.__name__ == 'str'. Verified with Python 3.14.3."
    - "functools.reduce.__module__ == '_functools' (len 10) — reduce is a C builtin from _functoolsmodule.c. Verified with Python 3.14.3."
    - "functools.partial.__module__ == 'functools' (len 9) — partial is a C type whose __module__ is set to 'functools'. Verified with Python 3.14.3."
    - "functools.lru_cache.__module__ == 'functools' (len 9) — lru_cache is a pure-Python decorator in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.singledispatch.__module__ == 'functools' (len 9). Verified with Python 3.14.3."
    - "functools.wraps.__module__ == 'functools' (len 9). Verified with Python 3.14.3."
    - "functools.cache.__module__ == 'functools' (len 9) — cache is the simple unbounded lru_cache alias added in Python 3.9. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.__spec__ and __loader__ class names and modules
#
# Wave 259 theme: functools module import-machinery attribute identity.
#
# functools.__spec__.__class__.__name__ == 'ModuleSpec'
# functools.__spec__.__class__.__module__ == '_frozen_importlib'
# functools.__loader__.__class__.__name__ == 'SourceFileLoader'
# functools.__loader__.__class__.__module__ == '_frozen_importlib_external'
# functools.__spec__.name == 'functools' (len 9)
# functools.__spec__.has_location == True
# functools.__file__.__class__.__name__ == 'str'
#
# functools is a pure-Python module loaded by SourceFileLoader; its ModuleSpec
# lives in _frozen_importlib; has_location is True because it has a file path.
# New to extra107.
# ---------------------------------------------------------------------------

table functools_extra107.spec_loader_class_identity:
  description: "functools __spec__/__loader__ class names and modules; spec.name=='functools'; spec.has_location==True; __file__ is str; wave 259; new to extra107"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsspec107

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_name_eq_ModuleSpec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "functools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — functools.__spec__ is the ModuleSpec created by the import system when functools was first imported; ModuleSpec is defined in importlib._bootstrap (frozen as _frozen_importlib); __spec__.__class__.__name__ is 'ModuleSpec'; str.__eq__('ModuleSpec') returns True; new to extra107"]
    - [spec_class_module_eq_frozen_importlib,
       "__spec__.__class__.__module__.__eq__",
       ["_frozen_importlib"],
       true,
       "functools.__spec__.__class__.__module__.__eq__('_frozen_importlib') == True — ModuleSpec is defined in importlib._bootstrap which CPython freezes as '_frozen_importlib'; the class's __module__ is '_frozen_importlib'; str.__eq__('_frozen_importlib') returns True; new to extra107"]
    - [loader_class_name_eq_SourceFileLoader,
       "__loader__.__class__.__name__.__eq__",
       ["SourceFileLoader"],
       true,
       "functools.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — functools is a pure-Python source module loaded from Lib/functools.py; CPython uses SourceFileLoader for .py files; __loader__.__class__.__name__ is 'SourceFileLoader'; str.__eq__('SourceFileLoader') returns True; new to extra107"]
    - [loader_class_module_eq_frozen_importlib_external,
       "__loader__.__class__.__module__.__eq__",
       ["_frozen_importlib_external"],
       true,
       "functools.__loader__.__class__.__module__.__eq__('_frozen_importlib_external') == True — SourceFileLoader is defined in importlib._bootstrap_external, frozen as '_frozen_importlib_external'; the loader class's __module__ is '_frozen_importlib_external'; str.__eq__('_frozen_importlib_external') returns True; new to extra107"]
    - [spec_name_len_eq_9,
       "__spec__.name.__len__",
       [],
       9,
       "functools.__spec__.name.__len__() == 9 — __spec__.name is 'functools'; len('functools') == 9 (f-u-n-c-t-o-o-l-s); new to extra107"]
    - [spec_has_location_eq_true,
       "__spec__.has_location.__eq__",
       [true],
       true,
       "functools.__spec__.has_location.__eq__(True) == True — functools is a pure-Python module loaded from Lib/functools.py on the filesystem; has_location is True because the origin is a file path; bool.__eq__(True) returns True; new to extra107"]
    - [file_class_name_eq_str,
       "__file__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.__file__.__class__.__name__.__eq__('str') == True — functools.__file__ is the path string to the .py file on disk; the path is a plain Python str; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra107"]

# ---------------------------------------------------------------------------
# Table 2: functools function __module__ string lengths
#
# Wave 259 theme: functools function __module__ distinguishes C from pure-Python.
#
# functools.reduce.__module__ == '_functools' (len 10) — C builtin
# functools.partial.__module__ == 'functools' (len 9) — C type, __module__ set to 'functools'
# functools.lru_cache.__module__ == 'functools' (len 9) — pure-Python
# functools.singledispatch.__module__ == 'functools' (len 9) — pure-Python
# functools.wraps.__module__ == 'functools' (len 9) — pure-Python
# functools.cache.__module__ == 'functools' (len 9) — pure-Python alias (3.9+)
#
# functools.reduce is a C builtin_function_or_method from _functoolsmodule.c
# and reports __module__ == '_functools'. All pure-Python functions in
# Lib/functools.py report __module__ == 'functools'. New to extra107.
# ---------------------------------------------------------------------------

table functools_extra107.function_module_lengths:
  description: "functools function __module__ lengths: reduce is '_functools' (10), partial/lru_cache/singledispatch/wraps/cache are 'functools' (9); wave 259; new to extra107"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsmodlen107

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_module_len_eq_10,
       "reduce.__module__.__len__",
       [],
       10,
       "functools.reduce.__module__.__len__() == 10 — functools.reduce is implemented as a C builtin in Modules/_functoolsmodule.c; its __module__ is '_functools' (the C extension module name); len('_functools') == 10 (_-f-u-n-c-t-o-o-l-s); new to extra107"]
    - [partial_module_len_eq_9,
       "partial.__module__.__len__",
       [],
       9,
       "functools.partial.__module__.__len__() == 9 — functools.partial is a C extension type from _functoolsmodule.c but its __module__ is set to 'functools' by the module initializer; len('functools') == 9 (f-u-n-c-t-o-o-l-s); new to extra107"]
    - [lru_cache_module_len_eq_9,
       "lru_cache.__module__.__len__",
       [],
       9,
       "functools.lru_cache.__module__.__len__() == 9 — functools.lru_cache is a pure-Python function defined in Lib/functools.py; its __module__ is 'functools'; len('functools') == 9; new to extra107"]
    - [singledispatch_module_len_eq_9,
       "singledispatch.__module__.__len__",
       [],
       9,
       "functools.singledispatch.__module__.__len__() == 9 — functools.singledispatch is a pure-Python function defined in Lib/functools.py; its __module__ is 'functools'; len('functools') == 9; new to extra107"]
    - [wraps_module_len_eq_9,
       "wraps.__module__.__len__",
       [],
       9,
       "functools.wraps.__module__.__len__() == 9 — functools.wraps is a pure-Python decorator defined in Lib/functools.py; it is a partial application of update_wrapper; its __module__ is 'functools'; len('functools') == 9; new to extra107"]
    - [cache_module_len_eq_9,
       "cache.__module__.__len__",
       [],
       9,
       "functools.cache.__module__.__len__() == 9 — functools.cache is the simple unbounded LRU cache alias added in Python 3.9 (it is lru_cache(maxsize=None)); it is a pure-Python function in Lib/functools.py; its __module__ is 'functools'; len('functools') == 9; new to extra107"]

# ---------------------------------------------------------------------------
# Table 3: functools function __module__ equality checks
#
# Wave 259 theme: functools function __module__ string equality.
#
# functools.reduce.__module__ == '_functools'
# functools.lru_cache.__module__ == 'functools'
# functools.wraps.__module__ == 'functools'
# functools.cache.__module__ == 'functools'
# functools.__spec__.name == 'functools'
# functools.__name__ == 'functools'
#
# Equality checks confirm exact __module__ and spec attribute strings.
# New to extra107.
# ---------------------------------------------------------------------------

table functools_extra107.function_module_equality:
  description: "functools reduce/__module__=='_functools'; lru_cache/wraps/cache/__module__=='functools'; spec.name=='functools'; __name__=='functools'; wave 259; new to extra107"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsmodlen107

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_module_eq_functools_c,
       "reduce.__module__.__eq__",
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — functools.reduce is the C builtin sum function from Modules/_functoolsmodule.c; its __module__ attribute is '_functools' (the C extension module); str.__eq__('_functools') returns True; new to extra107"]
    - [lru_cache_module_eq_functools,
       "lru_cache.__module__.__eq__",
       ["functools"],
       true,
       "functools.lru_cache.__module__.__eq__('functools') == True — lru_cache is a pure-Python decorator in Lib/functools.py; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra107"]
    - [wraps_module_eq_functools,
       "wraps.__module__.__eq__",
       ["functools"],
       true,
       "functools.wraps.__module__.__eq__('functools') == True — functools.wraps is a convenience decorator that copies __name__, __doc__ etc from the wrapped function; defined in Lib/functools.py; __module__ is 'functools'; str.__eq__('functools') returns True; new to extra107"]
    - [cache_module_eq_functools,
       "cache.__module__.__eq__",
       ["functools"],
       true,
       "functools.cache.__module__.__eq__('functools') == True — functools.cache is an unbounded LRU cache alias added in Python 3.9; it is defined in Lib/functools.py; __module__ is 'functools'; str.__eq__('functools') returns True; new to extra107"]
    - [spec_name_eq_functools,
       "__spec__.name.__eq__",
       ["functools"],
       true,
       "functools.__spec__.name.__eq__('functools') == True — the ModuleSpec.name attribute holds the dotted module name; for the functools module it is 'functools'; str.__eq__('functools') returns True; new to extra107"]
    - [module_name_eq_functools,
       "__name__.__eq__",
       ["functools"],
       true,
       "functools.__name__.__eq__('functools') == True — the module's __name__ attribute is its dotted name 'functools'; as a top-level module it has no package prefix; str.__eq__('functools') returns True; new to extra107"]

