spec: asyncio_extra370
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "asyncio.gather lives in module asyncio.tasks"
    - "asyncio.sleep lives in module asyncio.tasks"
    - "asyncio.wait lives in module asyncio.tasks"
    - "asyncio.run lives in module asyncio.runners"
    - "asyncio.get_event_loop lives in module _asyncio (C extension)"
    - "asyncio.new_event_loop lives in module asyncio.events"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra370.function_names:
  description: "Verify __name__ attribute of asyncio top-level functions"
  kind: python_call_eq
  category: identity
  id_prefix: aio370n

  columns: [id, function, args, expected]
  rows:
    - [aio370n001, asyncio.gather.__name__.__eq__, ["gather"], true]
    - [aio370n002, asyncio.sleep.__name__.__eq__, ["sleep"], true]
    - [aio370n003, asyncio.wait.__name__.__eq__, ["wait"], true]
    - [aio370n004, asyncio.run.__name__.__eq__, ["run"], true]
    - [aio370n005, asyncio.get_event_loop.__name__.__eq__, ["get_event_loop"], true]
    - [aio370n006, asyncio.new_event_loop.__name__.__eq__, ["new_event_loop"], true]

table asyncio_extra370.function_modules:
  description: "Verify __module__ attribute of asyncio top-level functions"
  kind: python_call_eq
  category: identity
  id_prefix: aio370m

  columns: [id, function, args, expected]
  rows:
    - [aio370m001, asyncio.gather.__module__.__eq__, ["asyncio.tasks"], true]
    - [aio370m002, asyncio.sleep.__module__.__eq__, ["asyncio.tasks"], true]
    - [aio370m003, asyncio.wait.__module__.__eq__, ["asyncio.tasks"], true]
    - [aio370m004, asyncio.run.__module__.__eq__, ["asyncio.runners"], true]
    - [aio370m005, asyncio.get_event_loop.__module__.__eq__, ["_asyncio"], true]
    - [aio370m006, asyncio.new_event_loop.__module__.__eq__, ["asyncio.events"], true]
