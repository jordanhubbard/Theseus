spec: numpy_array_rust
version: ">=3.9"
backend: rust_module(numpy_array_rust)

docs: https://numpy.org/doc/stable/reference/routines.array-creation.html

provenance:
  derived_from:
    - "https://numpy.org/doc/stable/reference/routines.array-creation.html — NumPy array creation"
  not_derived_from:
    - "NumPy source: numpy/core/numeric.py"
  notes:
    - "NumPy array creation functions and array properties."
    - "zeros(n).tolist() == [0.0, 0.0, ..., 0.0] — n-element zero array."
    - "ones(n).tolist() == [1.0, 1.0, ..., 1.0] — n-element ones array."
    - "arange(n).tolist() == [0, 1, 2, ..., n-1] — integer range array."
    - "arange(start, stop, step).tolist() — stepped integer range."
    - "linspace(0, 1, 3).tolist() == [0.0, 0.5, 1.0]."
    - "array([1,2,3]).ndim == 1, array([[1,2],[3,4]]).ndim == 2."
    - "array([1,2,3]).size == 3, array([[1,2],[3,4]]).size == 4."
    - "All test vectors verified against numpy 2.4.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# zeros — array of zeros converted to list
table numpy_array_rust.zeros.tolist:
  kind: python_call_eq
  category: zeros
  id_prefix: npa_zeros
  function: zeros
  method: tolist
  method_args: []

  columns: [id, args, expected]
  rows:
    - [three, [3], [0.0, 0.0, 0.0]]
    - [one,   [1], [0.0]]
    - [four,  [4], [0.0, 0.0, 0.0, 0.0]]

# ones — array of ones converted to list
table numpy_array_rust.ones.tolist:
  kind: python_call_eq
  category: ones
  id_prefix: npa_ones
  function: ones
  method: tolist
  method_args: []

  columns: [id, args, expected]
  rows:
    - [three, [3], [1.0, 1.0, 1.0]]
    - [two,   [2], [1.0, 1.0]]

# arange — integer range array converted to list
table numpy_array_rust.arange.tolist:
  kind: python_call_eq
  category: arange
  id_prefix: npa_arange
  function: arange
  method: tolist
  method_args: []

  columns: [id, args, expected]
  rows:
    - [five,      [5],        [0, 1, 2, 3, 4]]
    - [zero,      [0],        []]
    - [one,       [1],        [0]]
    - [step_2,    [2, 10, 2], [2, 4, 6, 8]]
    - [step_5,    [0, 15, 5], [0, 5, 10]]

# linspace — evenly-spaced floats
table numpy_array_rust.linspace.tolist:
  kind: python_call_eq
  category: linspace
  id_prefix: npa_linsp
  function: linspace
  method: tolist
  method_args: []

  columns: [id, args, expected]
  rows:
    - [zero_one_3, [0.0, 1.0, 3], [0.0, 0.5, 1.0]]
    - [zero_two_3, [0.0, 2.0, 3], [0.0, 1.0, 2.0]]

# array — ndim and size properties
invariant numpy_array_rust.array.ndim_1d:
  description: "array([1,2,3]).ndim == 1"
  category: array_props
  kind: python_call_eq
  function: array
  args: [[1, 2, 3]]
  method: ndim
  expected: 1

invariant numpy_array_rust.array.ndim_2d:
  description: "array([[1,2],[3,4]]).ndim == 2"
  category: array_props
  kind: python_call_eq
  function: array
  args: [[[1, 2], [3, 4]]]
  method: ndim
  expected: 2

invariant numpy_array_rust.array.size_1d:
  description: "array([1,2,3]).size == 3"
  category: array_props
  kind: python_call_eq
  function: array
  args: [[1, 2, 3]]
  method: size
  expected: 3

invariant numpy_array_rust.array.size_2d:
  description: "array([[1,2],[3,4]]).size == 4"
  category: array_props
  kind: python_call_eq
  function: array
  args: [[[1, 2], [3, 4]]]
  method: size
  expected: 4

