spec: string_similarity
version: ">=4.0.0"
backend: node(string-similarity)

docs: https://github.com/aceakash/string-similarity#readme

provenance:
  derived_from:
    - "string-similarity README — https://github.com/aceakash/string-similarity#readme"
    - "Test vectors verified with string-similarity@4.0.4 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "string-similarity source"
  notes:
    - "string-similarity exports { compareTwoStrings, findBestMatch }."
    - "compareTwoStrings(a, b) returns Dice coefficient in [0, 1]: 1=identical, 0=no shared bigrams."
    - "'night' vs 'nacht' share the bigram 'ht', giving Dice = 2*1/(4+4) = 0.25."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "compareTwoStrings returns float in [0, 1]. No errors for string inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table string_similarity.compare:
  kind: node_module_call_eq
  function: compareTwoStrings
  category: compare
  id_prefix: ss

  columns: [id, args, expected]
  rows:
    - [identical,  ["hello", "hello"],  1]
    - [no_overlap, ["hello", "world"],  0]
    - [partial,    ["night", "nacht"],  0.25]
    - [empty,      ["abc", "abc"],      1]
