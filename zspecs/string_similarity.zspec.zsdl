spec: string_similarity
version: ">=4.0.0"
backend: node(string-similarity)

docs: https://www.npmjs.com/package/string-similarity

provenance:
  derived_from:
    - "string-similarity README — https://www.npmjs.com/package/string-similarity"
    - "Test vectors verified with string-similarity via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "string-similarity source"
  notes:
    - "string-similarity is an npm package. Install: npm install string-similarity"
    - "compareTwoStrings(a, b) returns Dice coefficient similarity (0–1)."
    - "findBestMatch(main, targets) returns ratings array and bestMatch object."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns similarity score or best-match object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table string_similarity.compareTwoStrings:
  kind: node_module_call_eq
  function: compareTwoStrings
  category: compare
  id_prefix: sscomp

  columns: [id, args, expected]
  rows:
    - [identical, ["hello", "hello"], 1]
    - [different, ["hello", "world"], 0]
    - [similar,   ["hello", "helo"],  0.8571428571428571]

table string_similarity.findBestMatch:
  kind: node_module_call_eq
  function: findBestMatch
  category: search
  id_prefix: ssbest

  columns: [id, args, expected]
  rows:
    - [best, ["hello", ["world", "hell", "howdy"]],
       {"ratings": [{"target": "world", "rating": 0},
                    {"target": "hell", "rating": 0.8571428571428571},
                    {"target": "howdy", "rating": 0}],
        "bestMatch": {"target": "hell", "rating": 0.8571428571428571},
        "bestMatchIndex": 1}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:15:12Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
