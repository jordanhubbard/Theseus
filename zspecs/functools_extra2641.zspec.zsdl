spec: functools_extra2641
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 623 (_extra2641): __copy__, __deepcopy__, and __sizeof__ dict-presence checks for functools types."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
    - "__copy__ supports copy.copy() shallow copying. None of the functools types (partial, partialmethod, cached_property, singledispatchmethod, lru_cache) define __copy__ in their class __dict__ — all False."
    - "__deepcopy__ supports copy.deepcopy() deep copying. None of the functools types define __deepcopy__ in their class __dict__ — all False."
    - "__sizeof__ is used by sys.getsizeof() for memory introspection. None of the functools types define __sizeof__ in their class __dict__ — all False."
    - "functools.partial is a C extension type; partialmethod, cached_property, singledispatchmethod, and lru_cache are Python-level classes. None define custom copy or sizing protocols in their own __dict__."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __copy__ dict-presence for functools types
#
# __copy__ is the hook for copy.copy() shallow copying. functools.partial,
# partialmethod, cached_property, singledispatchmethod, and lru_cache are
# callable wrappers or descriptors. None define __copy__ in their own
# class __dict__ — all False.
# ---------------------------------------------------------------------------

table functools_extra2641.copy_absent:
  description: "functools types do not define __copy__ in their own __dict__ — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2641

  columns: [id, function, args, expected]
  rows:
    - ["ft2641001", "functools.partial.__dict__.__contains__",             ["__copy__"], false]
    - ["ft2641002", "functools.partialmethod.__dict__.__contains__",       ["__copy__"], false]
    - ["ft2641003", "functools.cached_property.__dict__.__contains__",     ["__copy__"], false]
    - ["ft2641004", "functools.singledispatchmethod.__dict__.__contains__", ["__copy__"], false]
    - ["ft2641005", "functools.lru_cache.__dict__.__contains__",           ["__copy__"], false]

# ---------------------------------------------------------------------------
# Table 2: __deepcopy__ dict-presence for functools types
#
# __deepcopy__ is the hook for copy.deepcopy() deep copying. None of the
# functools types define it in their own class __dict__. Deep copying of
# these objects relies on the default pickle-based mechanism — all False.
# ---------------------------------------------------------------------------

table functools_extra2641.deepcopy_absent:
  description: "functools types do not define __deepcopy__ in their own __dict__ — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2641

  columns: [id, function, args, expected]
  rows:
    - ["ft2641006", "functools.partial.__dict__.__contains__",             ["__deepcopy__"], false]
    - ["ft2641007", "functools.partialmethod.__dict__.__contains__",       ["__deepcopy__"], false]
    - ["ft2641008", "functools.cached_property.__dict__.__contains__",     ["__deepcopy__"], false]
    - ["ft2641009", "functools.singledispatchmethod.__dict__.__contains__", ["__deepcopy__"], false]
    - ["ft2641010", "functools.lru_cache.__dict__.__contains__",           ["__deepcopy__"], false]

# ---------------------------------------------------------------------------
# Table 3: __sizeof__ dict-presence for functools types
#
# __sizeof__ is called by sys.getsizeof() to obtain the memory footprint of
# an object in bytes. None of the functools types define a custom __sizeof__
# in their own class __dict__ — all False. sys.getsizeof() falls back to the
# default object sizing provided by CPython's runtime.
# ---------------------------------------------------------------------------

table functools_extra2641.sizeof_absent:
  description: "functools types do not define __sizeof__ in their own __dict__ — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2641

  columns: [id, function, args, expected]
  rows:
    - ["ft2641011", "functools.partial.__dict__.__contains__",             ["__sizeof__"], false]
    - ["ft2641012", "functools.partialmethod.__dict__.__contains__",       ["__sizeof__"], false]
    - ["ft2641013", "functools.cached_property.__dict__.__contains__",     ["__sizeof__"], false]
    - ["ft2641014", "functools.singledispatchmethod.__dict__.__contains__", ["__sizeof__"], false]
    - ["ft2641015", "functools.lru_cache.__dict__.__contains__",           ["__sizeof__"], false]

# ---------------------------------------------------------------------------
# Table 4: Combined absence summary — all three dunders absent from all types
#
# Cross-check confirming that none of the five functools types define any of
# __copy__, __deepcopy__, or __sizeof__ in their own __dict__. Assigns a
# unique dunder per type in a first pass, then cross-checks remaining
# combinations to confirm the full absence pattern.
# ---------------------------------------------------------------------------

table functools_extra2641.copy_sizeof_absent_summary:
  description: "functools types define none of __copy__, __deepcopy__, __sizeof__ — cross-type summary"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2641

  columns: [id, function, args, expected]
  rows:
    - ["ft2641016", "functools.partial.__dict__.__contains__",             ["__copy__"],     false]
    - ["ft2641017", "functools.partialmethod.__dict__.__contains__",       ["__deepcopy__"], false]
    - ["ft2641018", "functools.cached_property.__dict__.__contains__",     ["__sizeof__"],   false]
    - ["ft2641019", "functools.singledispatchmethod.__dict__.__contains__", ["__copy__"],     false]
    - ["ft2641020", "functools.lru_cache.__dict__.__contains__",           ["__deepcopy__"], false]
    - ["ft2641021", "functools.partial.__dict__.__contains__",             ["__deepcopy__"], false]
    - ["ft2641022", "functools.partialmethod.__dict__.__contains__",       ["__sizeof__"],   false]
    - ["ft2641023", "functools.cached_property.__dict__.__contains__",     ["__copy__"],     false]
    - ["ft2641024", "functools.singledispatchmethod.__dict__.__contains__", ["__sizeof__"],   false]
    - ["ft2641025", "functools.lru_cache.__dict__.__contains__",           ["__copy__"],     false]
