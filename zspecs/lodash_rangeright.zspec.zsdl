spec: lodash_rangeright
version: ">=4.0.0"
backend: node(lodash.rangeright)

docs: https://lodash.com/docs/#rangeRight

provenance:
  derived_from:
    - "lodash.rangeright README — https://www.npmjs.com/package/lodash.rangeright"
    - "Test vectors verified with lodash.rangeright@4.2.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.rangeright exports the _.rangeRight function directly as module.exports."
    - "rangeRight(start, end, step) creates a descending range array."
    - "Like range but in reverse order."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array of numbers in descending order."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_rangeright.rangeright:
  kind: node_module_call_eq
  function: ~
  category: rangeright
  id_prefix: lrr

  columns: [id, args, expected]
  rows:
    - [simple,  [4],           [3, 2, 1, 0]]
    - [start,   [1, 5],        [4, 3, 2, 1]]
    - [step,    [0, 20, 5],    [15, 10, 5, 0]]
    - [empty,   [0],           []]

