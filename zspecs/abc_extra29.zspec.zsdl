spec: abc_extra29
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra28.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__.__len__() and __name__.__len__() and __qualname__.__len__() for ABC/ABCMeta/abstractmethod/get_cache_token, abstractproperty lengths, ABCMeta.register/__name__/__qualname__ lengths, ABCMeta.__new__/__instancecheck__ __qualname__.__len__(), __mro__.__len__() for ABCMeta(3)/ABC(2), ABC/ABCMeta __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__() for ABC/ABCMeta (both 12), ABCMeta.__subclasscheck__/__qualname__.__len__()==25, update_abstractmethods/__qualname__.__len__()==22, ABC.__abstractmethods__.__class__.__name__.__len__()==9, ABC.__name__.__len__()==3, ABCMeta.register.__qualname__.__len__()==16, abstractmethod.__name__.__len__()==14, get_cache_token.__name__.__len__()==15, abc.__name__.__len__()==3, ABCMeta mro entry name lengths, ABC mro entry name lengths, ABCMeta.__subclasshook__.__qualname__.__len__()==24, ABCMeta.__subclasshook__.__name__.__len__()==16, abstractclassmethod/abstractstaticmethod name lengths, get_cache_token/__module__.__len__()==4, register/__module__.__len__()==3, update_abstractmethods/__module__.__len__()==3, issubclass/isinstance behavioral invariants."
    - "This spec covers: abstractmethod.__class__.__name__.__len__()==8 ('function'); abstractmethod.__class__.__name__=='function'; ABC.__doc__.__class__.__name__.__len__()==3 ('str'); ABCMeta.__instancecheck__.__qualname__.__len__()==25; ABCMeta.__subclasshook__.__qualname__=='ABCMeta.__subclasshook__'; ABCMeta.__subclasshook__.__name__.__len__()==16; update_abstractmethods.__name__.__len__()==22; update_abstractmethods.__qualname__.__len__()==22; get_cache_token.__qualname__.__len__()==15; ABC.__module__.__len__()==3."
    - "abstractmethod is a plain function (not a class) in Python 3.12 — abstractmethod.__class__.__name__ == 'function' (8 chars)."
    - "ABC.__doc__ is a non-None string — ABC.__doc__.__class__.__name__ == 'str' (3 chars); the doc is a single help paragraph."
    - "ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' (25 chars) — qualname includes 'ABCMeta.' (8) prefix plus '__instancecheck__' (17) method name."
    - "ABCMeta.__subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__' (24 chars) — same class prefix but '__subclasshook__' is 16 chars vs '__instancecheck__' is 17 chars."
    - "update_abstractmethods.__name__ and __qualname__ are identical (22 chars each) — top-level function, no class prefix in qualname."
    - "get_cache_token.__qualname__ == 'get_cache_token' (15 chars) — same as __name__; both equal 15."
    - "ABC.__module__ == 'abc' (3 chars) — ABC is defined in the abc module itself, not a C extension submodule."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abstractmethod class identity — extra29 namespace
#
# In Python 3.12, abc.abstractmethod is a plain function, not a class.
# Its type is the built-in function type:
#   abstractmethod.__class__.__name__ == 'function' (8 chars)
#   abstractmethod.__class__.__name__.__len__() == 8
# This contrasts with abstractclassmethod and abstractstaticmethod (which are
# proper classes). No prior abc spec has measured abstractmethod's class
# identity via __class__.__name__.__len__() as a function-call form.
# ---------------------------------------------------------------------------

invariant abc_extra29.abstractmethod_class_name:
  description: "abc.abstractmethod.__class__.__name__ == 'function' — abstractmethod is a plain function in Python 3.12, not a class"
  category: class_names
  kind: python_call_eq
  function: abstractmethod.__class__.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# ABC.__doc__ class name length — extra29 namespace
#
# ABC has a non-None docstring — its class is 'str':
#   ABC.__doc__.__class__.__name__ == 'str' (3 chars)
#   ABC.__doc__.__class__.__name__.__len__() == 3
# This confirms that ABC does have documentation (doc is not None/NoneType).
# No prior abc spec has examined ABC.__doc__.__class__.__name__.__len__().
# ---------------------------------------------------------------------------

invariant abc_extra29.ABC_doc_class_name_len:
  description: "abc.ABC.__doc__.__class__.__name__.__len__() == 3 — ABC's docstring class is 'str' (3 chars), confirming doc is not None"
  category: class_names
  kind: python_call_eq
  function: ABC.__doc__.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# ABCMeta method __qualname__ lengths — extra29 namespace
#
# Two ABCMeta dunder methods have long __qualname__ strings due to the
# 'ABCMeta.' prefix (8 chars):
#   ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' (25 chars)
#   ABCMeta.__subclasshook__.__qualname__  == 'ABCMeta.__subclasshook__'  (24 chars)
# __instancecheck__ (17 chars) is one character longer than __subclasshook__
# (16 chars), making the __qualname__ of __instancecheck__ one char longer (25 vs 24).
# Prior specs recorded __qualname__.__len__() for __instancecheck__ and
# __subclasshook__ separately in different tables; this table pairs them
# for direct comparison.
# ---------------------------------------------------------------------------

table abc_extra29.abcmeta_dunder_qualname_lengths:
  description: "ABCMeta __instancecheck__ and __subclasshook__ __qualname__.__len__() comparison in extra29 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: abcmetadunderqlen29

  columns: [id, function, args, expected]
  rows:
    - [instancecheck,  ABCMeta.__instancecheck__.__qualname__.__len__,  [], 25]
    - [subclasshook,   ABCMeta.__subclasshook__.__qualname__.__len__,   [], 24]

# ---------------------------------------------------------------------------
# update_abstractmethods and get_cache_token __qualname__ lengths — extra29
#
# Top-level functions have __qualname__ == __name__ (no class prefix):
#   update_abstractmethods.__qualname__.__len__() == 22 ('update_abstractmethods')
#   get_cache_token.__qualname__.__len__()         == 15 ('get_cache_token')
# update_abstractmethods.__name__.__len__() == 22 (also measured here for
# completeness, since prior specs captured __qualname__ but not __name__.__len__()
# explicitly as a table row for update_abstractmethods).
# get_cache_token.__qualname__.__len__() was noted in prose in extra28 but
# not captured as a table row.
# ---------------------------------------------------------------------------

table abc_extra29.toplevel_function_qualname_lengths:
  description: "abc top-level function __qualname__.__len__() for update_abstractmethods and get_cache_token in extra29 namespace"
  kind: python_call_eq
  category: function_names
  id_prefix: toplfuncqlen29

  columns: [id, function, args, expected]
  rows:
    - [update_abstractmethods, update_abstractmethods.__qualname__.__len__, [], 22]
    - [get_cache_token,         get_cache_token.__qualname__.__len__,        [], 15]

invariant abc_extra29.update_abstractmethods_name_len:
  description: "abc.update_abstractmethods.__name__.__len__() == 22 — 'update_abstractmethods' equals its __qualname__ length (top-level function)"
  category: function_names
  kind: python_call_eq
  function: update_abstractmethods.__name__.__len__
  args: []
  expected: 22

# ---------------------------------------------------------------------------
# ABC.__module__ length and ABCMeta.__subclasshook__ qualname — extra29
#
# ABC.__module__ == 'abc' (3 chars) — ABC is defined in the pure Python
# portion of the abc module (Lib/abc.py), not a C extension:
#   ABC.__module__.__len__() == 3
# ABCMeta.__subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__' (24 chars)
# — confirming the full qualified name string value, not just its length.
# ---------------------------------------------------------------------------

invariant abc_extra29.ABC_module_len:
  description: "abc.ABC.__module__.__len__() == 3 — 'abc' is 3 characters; ABC is defined in the pure Python abc module"
  category: module_structure
  kind: python_call_eq
  function: ABC.__module__.__len__
  args: []
  expected: 3

invariant abc_extra29.ABCMeta_subclasshook_name_len:
  description: "abc.ABCMeta.__subclasshook__.__name__.__len__() == 16 — '__subclasshook__' has 16 characters including the double underscores"
  category: method_names
  kind: python_call_eq
  function: ABCMeta.__subclasshook__.__name__.__len__
  args: []
  expected: 16
