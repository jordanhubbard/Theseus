spec: unittest_extra5
version: ">=3.9"
backend: python_module(unittest)

docs: https://docs.python.org/3/library/unittest.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unittest.html — Python unittest module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/unittest/__init__.py"
  notes:
    - "This spec extends unittest.zspec.zsdl, unittest_extra.zspec.zsdl, unittest_extra2.zspec.zsdl, unittest_extra3.zspec.zsdl, and unittest_extra4.zspec.zsdl."
    - "Focus: __qualname__ attributes for unittest classes, decorators, and functions not yet covered."
    - "unittest.TestCase.__qualname__ == 'TestCase' — simple class, qualname equals name."
    - "unittest.TestSuite.__qualname__ == 'TestSuite'."
    - "unittest.TestLoader.__qualname__ == 'TestLoader'."
    - "unittest.TestResult.__qualname__ == 'TestResult'."
    - "unittest.TextTestRunner.__qualname__ == 'TextTestRunner'."
    - "unittest.TextTestResult.__qualname__ == 'TextTestResult'."
    - "unittest.FunctionTestCase.__qualname__ == 'FunctionTestCase'."
    - "unittest.TestProgram.__qualname__ == 'TestProgram'."
    - "unittest.skip.__qualname__ == 'skip' — skip is a top-level function."
    - "unittest.skipIf.__qualname__ == 'skipIf'."
    - "unittest.skipUnless.__qualname__ == 'skipUnless'."
    - "unittest.expectedFailure.__qualname__ == 'expectedFailure'."
    - "unittest.main.__qualname__ == 'main' — the module-level main symbol."
    - "unittest.TestCase.__module__ == 'unittest.case' — already covered in unittest_extra4 via table; included here as a standalone qualname-bundle companion."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — class objects
# For simple top-level classes, __qualname__ equals __name__.
# Prior specs cover __name__; this spec adds the parallel __qualname__ table.
# ---------------------------------------------------------------------------

table unittest_extra5.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [TestCase,       TestCase.__qualname__.__eq__,       ["TestCase"],       true]
    - [TestSuite,      TestSuite.__qualname__.__eq__,      ["TestSuite"],      true]
    - [TestLoader,     TestLoader.__qualname__.__eq__,     ["TestLoader"],     true]
    - [TestResult,     TestResult.__qualname__.__eq__,     ["TestResult"],     true]
    - [TextTestRunner, TextTestRunner.__qualname__.__eq__, ["TextTestRunner"], true]
    - [TextTestResult, TextTestResult.__qualname__.__eq__, ["TextTestResult"], true]
    - [FunctionTestCase, FunctionTestCase.__qualname__.__eq__, ["FunctionTestCase"], true]
    - [TestProgram,    TestProgram.__qualname__.__eq__,    ["TestProgram"],    true]

# ---------------------------------------------------------------------------
# __qualname__ checks — decorator and main function symbols
# ---------------------------------------------------------------------------

table unittest_extra5.decorator_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: dqname

  columns: [id, function, args, expected]
  rows:
    - [skip,            skip.__qualname__.__eq__,            ["skip"],            true]
    - [skipIf,          skipIf.__qualname__.__eq__,          ["skipIf"],          true]
    - [skipUnless,      skipUnless.__qualname__.__eq__,      ["skipUnless"],      true]
    - [expectedFailure, expectedFailure.__qualname__.__eq__, ["expectedFailure"], true]
    - [main,            main.__qualname__.__eq__,            ["main"],            true]

# ---------------------------------------------------------------------------
# __module__ check — TestCase (companion to qualname coverage above)
# unittest_extra4 covers TestCase.__module__ via table; this is a standalone
# invariant providing the same vector in a different structural form.
# ---------------------------------------------------------------------------

invariant unittest_extra5.TestCase.module:
  description: "unittest.TestCase.__module__ == 'unittest.case'"
  category: modules
  kind: python_call_eq
  function: TestCase.__module__.__eq__
  args: ["unittest.case"]
  expected: true
