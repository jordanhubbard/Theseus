spec: itertools_extra227
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers itertools behavioral output contracts: first-element checks via function-call + method:__next__ for chain, compress, combinations, permutations, product, combinations_with_replacement, islice; repeat(n).__length_hint__(); count(10) first value; repeat(99) first value. All itertools types have __class__.__name__=='type'."
    - "itertools.chain([1,2],[3,4],[5]).__next__() == 1 — chain yields its first element 1 from the first iterable. Verified with Python 3.14.3."
    - "itertools.repeat(42, 5).__length_hint__() == 5 — repeat(42,5) is a finite iterator with exactly 5 remaining elements. Verified with Python 3.14.3."
    - "itertools.islice(range(100), 10).__next__() == 0 — islice(range(100),10) yields 0 as its first value. Verified with Python 3.14.3."
    - "itertools.compress([1,2,3,4,5],[True,False,True,False,True]).__next__() == 1 — compress yields 1 as first selected element. Verified with Python 3.14.3."
    - "itertools.combinations([1,2,3,4],2).__next__() == (1,2) — first r-combination of [1,2,3,4] choosing 2. Verified with Python 3.14.3."
    - "itertools.combinations([1,2,3],3).__next__() == (1,2,3) — only combination of [1,2,3] choosing all 3. Verified with Python 3.14.3."
    - "itertools.permutations([1,2,3]).__next__() == (1,2,3) — first permutation in lexicographic order. Verified with Python 3.14.3."
    - "itertools.permutations([1,2,3],2).__next__() == (1,2) — first 2-permutation. Verified with Python 3.14.3."
    - "itertools.product([1,2],[3,4]).__next__() == (1,3) — first element of Cartesian product. Verified with Python 3.14.3."
    - "itertools.product([1,2],[3,4],[5,6]).__next__() == (1,3,5) — first element of 3-way product. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement([1,2,3],2).__next__() == (1,1) — first CWR combination. Verified with Python 3.14.3."
    - "itertools.count(10).__next__() == 10 — count(10) yields 10 as its first value. Verified with Python 3.14.3."
    - "itertools.repeat(99).__next__() == 99 — repeat(99) yields 99 as its first value. Verified with Python 3.14.3."
    - "All itertools types (chain, repeat, count, etc.) have __class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools type class names — all are 'type' (C extension types)
#
# itertools.chain.__class__.__name__ == 'type'
# itertools.repeat.__class__.__name__ == 'type'
# itertools.count.__class__.__name__ == 'type'
# itertools.islice.__class__.__name__ == 'type'
# itertools.combinations.__class__.__name__ == 'type'
#
# All itertools iterator objects are implemented as C extension types, so their
# metaclass is 'type'. New to extra227.
# ---------------------------------------------------------------------------

table itertools_extra227.type_class_names_part1:
  description: "itertools chain/repeat/count/islice/combinations are all C types; __class__.__name__=='type'; new to extra227"
  kind: python_call_eq
  category: behavioral
  id_prefix: itertoolsextra227typeclass1

  columns: [id, function, args, expected, description]
  rows:
    - [chain_class_is_type,
       chain.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.chain.__class__.__name__ == 'type' — chain is a C extension type implemented in Modules/itertoolsmodule.c; its metaclass is the built-in 'type'; __class__.__name__.__eq__('type') returns True; new to extra227"]
    - [repeat_class_is_type,
       repeat.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.repeat.__class__.__name__ == 'type' — repeat is a C extension type; its metaclass is the built-in 'type'; __class__.__name__.__eq__('type') returns True; new to extra227"]
    - [count_class_is_type,
       count.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.count.__class__.__name__ == 'type' — count is a C extension type; its metaclass is the built-in 'type'; __class__.__name__.__eq__('type') returns True; new to extra227"]
    - [islice_class_is_type,
       islice.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.islice.__class__.__name__ == 'type' — islice is a C extension type; its metaclass is the built-in 'type'; __class__.__name__.__eq__('type') returns True; new to extra227"]
    - [combinations_class_is_type,
       combinations.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.combinations.__class__.__name__ == 'type' — combinations is a C extension type; its metaclass is the built-in 'type'; __class__.__name__.__eq__('type') returns True; new to extra227"]

# ---------------------------------------------------------------------------
# Table 2: itertools type class names — part 2
#
# itertools.permutations.__class__.__name__ == 'type'
# itertools.product.__class__.__name__ == 'type'
# itertools.compress.__class__.__name__ == 'type'
# itertools.combinations_with_replacement.__class__.__name__ == 'type'
# itertools.cycle.__class__.__name__ == 'type'
#
# New to extra227.
# ---------------------------------------------------------------------------

table itertools_extra227.type_class_names_part2:
  description: "itertools permutations/product/compress/cwr/cycle are all C types; __class__.__name__=='type'; new to extra227"
  kind: python_call_eq
  category: behavioral
  id_prefix: itertoolsextra227typeclass2

  columns: [id, function, args, expected, description]
  rows:
    - [permutations_class_is_type,
       permutations.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.permutations.__class__.__name__ == 'type' — permutations is a C extension type; its metaclass is the built-in 'type'; __class__.__name__.__eq__('type') returns True; new to extra227"]
    - [product_class_is_type,
       product.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.product.__class__.__name__ == 'type' — product is a C extension type; its metaclass is the built-in 'type'; __class__.__name__.__eq__('type') returns True; new to extra227"]
    - [compress_class_is_type,
       compress.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.compress.__class__.__name__ == 'type' — compress is a C extension type; its metaclass is the built-in 'type'; __class__.__name__.__eq__('type') returns True; new to extra227"]
    - [cwr_class_is_type,
       combinations_with_replacement.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.combinations_with_replacement.__class__.__name__ == 'type' — combinations_with_replacement is a C extension type; its metaclass is 'type'; __class__.__name__.__eq__('type') returns True; new to extra227"]
    - [cycle_class_is_type,
       cycle.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.cycle.__class__.__name__ == 'type' — cycle is a C extension type; its metaclass is the built-in 'type'; __class__.__name__.__eq__('type') returns True; new to extra227"]

# ---------------------------------------------------------------------------
# Table 3: itertools type qualname contracts
#
# itertools.chain.__qualname__ == 'chain'
# itertools.repeat.__qualname__ == 'repeat'
# itertools.count.__qualname__ == 'count'
# itertools.combinations.__qualname__ == 'combinations'
# itertools.permutations.__qualname__ == 'permutations'
#
# All itertools types have simple unqualified qualnames. New to extra227.
# ---------------------------------------------------------------------------

table itertools_extra227.type_qualnames:
  description: "itertools chain/repeat/count/combinations/permutations qualname contracts; new to extra227"
  kind: python_call_eq
  category: behavioral
  id_prefix: itertoolsextra227typequal

  columns: [id, function, args, expected, description]
  rows:
    - [chain_qualname,
       chain.__qualname__.__eq__,
       ["chain"],
       true,
       "itertools.chain.__qualname__ == 'chain' — chain is a top-level C type with unqualified qualname 'chain'; __qualname__.__eq__('chain') returns True; new to extra227"]
    - [repeat_qualname,
       repeat.__qualname__.__eq__,
       ["repeat"],
       true,
       "itertools.repeat.__qualname__ == 'repeat' — repeat is a top-level C type with unqualified qualname 'repeat'; __qualname__.__eq__('repeat') returns True; new to extra227"]
    - [count_qualname,
       count.__qualname__.__eq__,
       ["count"],
       true,
       "itertools.count.__qualname__ == 'count' — count is a top-level C type with unqualified qualname 'count'; __qualname__.__eq__('count') returns True; new to extra227"]
    - [combinations_qualname,
       combinations.__qualname__.__eq__,
       ["combinations"],
       true,
       "itertools.combinations.__qualname__ == 'combinations' — combinations is a top-level C type with unqualified qualname 'combinations'; __qualname__.__eq__('combinations') returns True; new to extra227"]
    - [permutations_qualname,
       permutations.__qualname__.__eq__,
       ["permutations"],
       true,
       "itertools.permutations.__qualname__ == 'permutations' — permutations is a top-level C type with unqualified qualname 'permutations'; __qualname__.__eq__('permutations') returns True; new to extra227"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra227
# (These use method: __next__ to verify actual behavioral output values)
# ---------------------------------------------------------------------------

invariant itertools_extra227.chain_first_1:
  description: "itertools.chain([1,2],[3,4],[5]).__next__() == 1 — chain concatenates iterables; first element is 1; new to extra227"
  kind: python_call_eq
  function: chain
  args: [[1, 2], [3, 4], [5]]
  method: __next__
  expected: 1

invariant itertools_extra227.repeat_42_5_length_hint:
  description: "itertools.repeat(42, 5).__length_hint__() == 5 — finite repeat has 5 remaining elements; new to extra227"
  kind: python_call_eq
  function: repeat
  args: [42, 5]
  method: __length_hint__
  expected: 5

invariant itertools_extra227.count_10_first:
  description: "itertools.count(10).__next__() == 10 — count(start) yields start as first value; new to extra227"
  kind: python_call_eq
  function: count
  args: [10]
  method: __next__
  expected: 10

invariant itertools_extra227.repeat_99_first:
  description: "itertools.repeat(99).__next__() == 99 — infinite repeat yields 99 as first value; new to extra227"
  kind: python_call_eq
  function: repeat
  args: [99]
  method: __next__
  expected: 99

invariant itertools_extra227.compress_first_1:
  description: "itertools.compress([1,2,3,4,5],[True,False,True,False,True]).__next__() == 1 — first element with True selector is 1; new to extra227"
  kind: python_call_eq
  function: compress
  args: [[1, 2, 3, 4, 5], [true, false, true, false, true]]
  method: __next__
  expected: 1

invariant itertools_extra227.combinations_4_2_first:
  description: "itertools.combinations([1,2,3,4],2).__next__() == (1,2) — C(4,2)=6; first combination is (1,2); new to extra227"
  kind: python_call_eq
  function: combinations
  args: [[1, 2, 3, 4], 2]
  method: __next__
  expected: [1, 2]

invariant itertools_extra227.combinations_3_3_first:
  description: "itertools.combinations([1,2,3],3).__next__() == (1,2,3) — C(3,3)=1; only combination is (1,2,3); new to extra227"
  kind: python_call_eq
  function: combinations
  args: [[1, 2, 3], 3]
  method: __next__
  expected: [1, 2, 3]

invariant itertools_extra227.permutations_3_first:
  description: "itertools.permutations([1,2,3]).__next__() == (1,2,3) — P(3,3)=6; first permutation is (1,2,3); new to extra227"
  kind: python_call_eq
  function: permutations
  args: [[1, 2, 3]]
  method: __next__
  expected: [1, 2, 3]

invariant itertools_extra227.permutations_3_2_first:
  description: "itertools.permutations([1,2,3],2).__next__() == (1,2) — P(3,2)=6; first 2-perm is (1,2); new to extra227"
  kind: python_call_eq
  function: permutations
  args: [[1, 2, 3], 2]
  method: __next__
  expected: [1, 2]

invariant itertools_extra227.product_2x2_first:
  description: "itertools.product([1,2],[3,4]).__next__() == (1,3) — 2x2 Cartesian product; first element is (1,3); new to extra227"
  kind: python_call_eq
  function: product
  args: [[1, 2], [3, 4]]
  method: __next__
  expected: [1, 3]

invariant itertools_extra227.product_3way_first:
  description: "itertools.product([1,2],[3,4],[5,6]).__next__() == (1,3,5) — 2x2x2 product; first element is (1,3,5); new to extra227"
  kind: python_call_eq
  function: product
  args: [[1, 2], [3, 4], [5, 6]]
  method: __next__
  expected: [1, 3, 5]

invariant itertools_extra227.cwr_3_2_first:
  description: "itertools.combinations_with_replacement([1,2,3],2).__next__() == (1,1) — CWR(3,2)=6; first is (1,1); new to extra227"
  kind: python_call_eq
  function: combinations_with_replacement
  args: [[1, 2, 3], 2]
  method: __next__
  expected: [1, 1]

invariant itertools_extra227.chain_class_is_type:
  description: "itertools.chain.__class__.__name__ == 'type' — chain is a C extension type; new to extra227"
  kind: python_call_eq
  function: chain.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra227.repeat_class_is_type:
  description: "itertools.repeat.__class__.__name__ == 'type' — repeat is a C extension type; new to extra227"
  kind: python_call_eq
  function: repeat.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra227.count_class_is_type:
  description: "itertools.count.__class__.__name__ == 'type' — count is a C extension type; new to extra227"
  kind: python_call_eq
  function: count.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra227.combinations_class_is_type:
  description: "itertools.combinations.__class__.__name__ == 'type' — combinations is a C extension type; new to extra227"
  kind: python_call_eq
  function: combinations.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra227.permutations_class_is_type:
  description: "itertools.permutations.__class__.__name__ == 'type' — permutations is a C extension type; new to extra227"
  kind: python_call_eq
  function: permutations.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra227.islice_list_first_0:
  description: "itertools.islice([0,1,2], 2).__next__() == 0 — islice takes first 2 from [0,1,2]; first element is 0; new to extra227"
  kind: python_call_eq
  function: islice
  args: [[0, 1, 2], 2]
  method: __next__
  expected: 0
