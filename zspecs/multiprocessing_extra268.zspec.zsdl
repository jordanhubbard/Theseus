spec: multiprocessing_extra268
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html#multiprocessing.reduction

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/reduction.py"
    - "multiprocessing_extra267.zspec.zsdl — covers multiprocessing.managers DictProxy, ListProxy, NamespaceProxy, and BaseProxy class identity"
  notes:
    - "This spec covers: multiprocessing.reduction module identity and ForkingPickler and AbstractReducer class identity. NEW in extra268: multiprocessing.reduction.__name__=='multiprocessing.reduction'; multiprocessing.reduction.__spec__.name=='multiprocessing.reduction'; multiprocessing.reduction.__name__.__len__()==25; multiprocessing.reduction.ForkingPickler.__name__=='ForkingPickler'; multiprocessing.reduction.ForkingPickler.__module__=='multiprocessing.reduction'; multiprocessing.reduction.ForkingPickler.__bases__[0].__name__=='Pickler'; multiprocessing.reduction.ForkingPickler.__mro__.__len__()==3 ([ForkingPickler, Pickler, object]); multiprocessing.reduction.ForkingPickler.__qualname__=='ForkingPickler'; multiprocessing.reduction.ForkingPickler.register.__qualname__=='ForkingPickler.register'; multiprocessing.reduction.AbstractReducer.__name__=='AbstractReducer'; multiprocessing.reduction.AbstractReducer.__module__=='multiprocessing.reduction'; multiprocessing.reduction.AbstractReducer.__bases__[0].__name__=='object'; multiprocessing.reduction.AbstractReducer.__mro__.__len__()==2; multiprocessing.reduction.dump.__name__=='dump'; multiprocessing.reduction.dump.__module__=='multiprocessing.reduction'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "multiprocessing.reduction.__name__ == 'multiprocessing.reduction' (len=25: 'multiprocessing'=15+'.reduction'=10). The module's __name__ and __spec__.name are both the fully-qualified dotted name 'multiprocessing.reduction'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "multiprocessing.reduction.ForkingPickler.__bases__[0].__name__ == 'Pickler'. ForkingPickler inherits from pickle.Pickler (the C-accelerated pickler); ForkingPickler's MRO is [ForkingPickler, Pickler, object] (length=3). ForkingPickler.register.__qualname__ is 'ForkingPickler.register' (own class method). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "multiprocessing.reduction.AbstractReducer.__bases__[0].__name__ == 'object'. AbstractReducer is a direct subclass of object (MRO length=2); it is the base class used to build custom reduction registries. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.reduction module identity — extra268
#
# multiprocessing.reduction.__name__             == 'multiprocessing.reduction'
# multiprocessing.reduction.__spec__.name        == 'multiprocessing.reduction'
# multiprocessing.reduction.__name__.__len__()   == 25
# ---------------------------------------------------------------------------

table multiprocessing_extra268.mp_reduction_module_identity:
  description: "multiprocessing.reduction module identity checks in mpreduction268 namespace — multiprocessing.reduction is defined in Lib/multiprocessing/reduction.py; its __name__ is 'multiprocessing.reduction' (len=25: 'multiprocessing'=15+'.reduction'=10); __spec__.name is also 'multiprocessing.reduction' (same dotted qualified name as __name__); __name__.__eq__('multiprocessing.reduction')==True; __spec__.name.__eq__('multiprocessing.reduction')==True; __name__.__len__()==25; the module contains ForkingPickler (inherits from Pickler), AbstractReducer (inherits from object), dump() function, and register() classmethod; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpreduction268

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name_eq,      multiprocessing.reduction.__name__.__eq__,             ["multiprocessing.reduction"],  true, "multiprocessing.reduction.__name__ == 'multiprocessing.reduction'; verified with Python 3.14.3"]
    - [mod_spec_eq,      multiprocessing.reduction.__spec__.name.__eq__,        ["multiprocessing.reduction"],  true, "multiprocessing.reduction.__spec__.name == 'multiprocessing.reduction'; verified with Python 3.14.3"]
    - [mod_name_len,     multiprocessing.reduction.__name__.__len__,            [],                             25,   "multiprocessing.reduction.__name__.__len__() == 25 ('multiprocessing.reduction'=25); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.reduction.ForkingPickler and AbstractReducer class identity — extra268
#
# ForkingPickler.__name__                          == 'ForkingPickler'
# ForkingPickler.__module__                        == 'multiprocessing.reduction'
# ForkingPickler.__bases__[0].__name__             == 'Pickler'
# ForkingPickler.__mro__.__len__()                 == 3
# ForkingPickler.__qualname__                      == 'ForkingPickler'
# ForkingPickler.register.__qualname__             == 'ForkingPickler.register'
# AbstractReducer.__name__                         == 'AbstractReducer'
# AbstractReducer.__module__                       == 'multiprocessing.reduction'
# AbstractReducer.__bases__[0].__name__            == 'object'
# AbstractReducer.__mro__.__len__()                == 2
# dump.__name__                                    == 'dump'
# dump.__module__                                  == 'multiprocessing.reduction'
# ---------------------------------------------------------------------------

table multiprocessing_extra268.mp_reduction_classes_identity:
  description: "multiprocessing.reduction ForkingPickler and AbstractReducer class identity checks in mpreduction268a namespace — ForkingPickler is the core serialisation class in multiprocessing.reduction; ForkingPickler.__name__.__eq__('ForkingPickler')==True; ForkingPickler.__module__.__eq__('multiprocessing.reduction')==True (len=25: 'multiprocessing'=15+'.reduction'=10); ForkingPickler.__bases__[0].__name__.__eq__('Pickler')==True (ForkingPickler inherits from pickle.Pickler, the C-accelerated pickler); ForkingPickler.__mro__.__len__()==3 ([ForkingPickler, Pickler, object]); ForkingPickler.__qualname__.__eq__('ForkingPickler')==True; ForkingPickler.__name__.__len__()==14 ('ForkingPickler'=14); ForkingPickler.register.__qualname__.__eq__('ForkingPickler.register')==True (own class method, qualname uses 'ForkingPickler.' prefix); AbstractReducer.__name__.__eq__('AbstractReducer')==True; AbstractReducer.__module__.__eq__('multiprocessing.reduction')==True (same module); AbstractReducer.__bases__[0].__name__.__eq__('object')==True (direct subclass of object, root of the abstract reducer hierarchy); AbstractReducer.__mro__.__len__()==2 ([AbstractReducer, object]); dump.__name__.__eq__('dump')==True (module-level function); dump.__module__.__eq__('multiprocessing.reduction')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpreduction268a

  columns: [id, function, args, expected, description]
  rows:
    - [fp_name_eq,    multiprocessing.reduction.ForkingPickler.__name__.__eq__,                    ["ForkingPickler"],              true, "multiprocessing.reduction.ForkingPickler.__name__ == 'ForkingPickler'; verified with Python 3.14.3"]
    - [fp_mod_eq,     multiprocessing.reduction.ForkingPickler.__module__.__eq__,                  ["multiprocessing.reduction"],   true, "multiprocessing.reduction.ForkingPickler.__module__ == 'multiprocessing.reduction' (len=25); verified with Python 3.14.3"]
    - [fp_base0_eq,   "multiprocessing.reduction.ForkingPickler.__bases__[0].__name__.__eq__",     ["Pickler"],                     true, "multiprocessing.reduction.ForkingPickler.__bases__[0].__name__ == 'Pickler' (inherits from pickle.Pickler); verified with Python 3.14.3"]
    - [fp_mro_len,    multiprocessing.reduction.ForkingPickler.__mro__.__len__,                    [],                              3,    "multiprocessing.reduction.ForkingPickler.__mro__.__len__() == 3 — [ForkingPickler, Pickler, object]; verified with Python 3.14.3"]
    - [fp_qn_eq,      multiprocessing.reduction.ForkingPickler.__qualname__.__eq__,                ["ForkingPickler"],              true, "multiprocessing.reduction.ForkingPickler.__qualname__ == 'ForkingPickler'; verified with Python 3.14.3"]
    - [fp_name_len,   multiprocessing.reduction.ForkingPickler.__name__.__len__,                   [],                              14,   "multiprocessing.reduction.ForkingPickler.__name__.__len__() == 14 ('ForkingPickler'=14); verified with Python 3.14.3"]
    - [fp_reg_qn_eq,  multiprocessing.reduction.ForkingPickler.register.__qualname__.__eq__,       ["ForkingPickler.register"],     true, "multiprocessing.reduction.ForkingPickler.register.__qualname__ == 'ForkingPickler.register' (own class method); verified with Python 3.14.3"]
    - [ar_name_eq,    multiprocessing.reduction.AbstractReducer.__name__.__eq__,                   ["AbstractReducer"],             true, "multiprocessing.reduction.AbstractReducer.__name__ == 'AbstractReducer'; verified with Python 3.14.3"]
    - [ar_mod_eq,     multiprocessing.reduction.AbstractReducer.__module__.__eq__,                 ["multiprocessing.reduction"],   true, "multiprocessing.reduction.AbstractReducer.__module__ == 'multiprocessing.reduction' (same as ForkingPickler); verified with Python 3.14.3"]
    - [ar_base0_eq,   "multiprocessing.reduction.AbstractReducer.__bases__[0].__name__.__eq__",    ["object"],                      true, "multiprocessing.reduction.AbstractReducer.__bases__[0].__name__ == 'object' — direct subclass of object; verified with Python 3.14.3"]
    - [ar_mro_len,    multiprocessing.reduction.AbstractReducer.__mro__.__len__,                   [],                              2,    "multiprocessing.reduction.AbstractReducer.__mro__.__len__() == 2 — [AbstractReducer, object]; verified with Python 3.14.3"]
    - [ar_name_len,   multiprocessing.reduction.AbstractReducer.__name__.__len__,                  [],                              15,   "multiprocessing.reduction.AbstractReducer.__name__.__len__() == 15 ('AbstractReducer'=15, longest class name in spec); verified with Python 3.14.3"]
    - [dump_name_eq,  multiprocessing.reduction.dump.__name__.__eq__,                              ["dump"],                        true, "multiprocessing.reduction.dump.__name__ == 'dump'; verified with Python 3.14.3"]
    - [dump_mod_eq,   multiprocessing.reduction.dump.__module__.__eq__,                            ["multiprocessing.reduction"],   true, "multiprocessing.reduction.dump.__module__ == 'multiprocessing.reduction'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra268
# ---------------------------------------------------------------------------

invariant multiprocessing_extra268.reduction_name_eq_spec_name:
  description: "multiprocessing.reduction.__name__.__eq__('multiprocessing.reduction') returns True — the module's __name__ is 'multiprocessing.reduction' (len=25: 'multiprocessing'=15+'.reduction'=10); this fully-qualified dotted name is the same as __spec__.name; compare with multiprocessing.managers.__name__ == 'multiprocessing.managers' (len=24); the reduction module provides the serialisation infrastructure for cross-process object transfer; ForkingPickler and AbstractReducer are both defined here; NEW in extra268: first standalone reduction.__name__ invariant in mpreduction268 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.reduction.__name__.__eq__
  args: ["multiprocessing.reduction"]
  expected: true

invariant multiprocessing_extra268.ForkingPickler_module_is_multiprocessing_reduction:
  description: "multiprocessing.reduction.ForkingPickler.__module__.__eq__('multiprocessing.reduction') returns True — ForkingPickler is defined in Lib/multiprocessing/reduction.py; its __module__ is 'multiprocessing.reduction' (len=25); ForkingPickler inherits from pickle.Pickler (the C-accelerated pickler), giving it the MRO [ForkingPickler, Pickler, object] (length=3); ForkingPickler.register.__qualname__ is 'ForkingPickler.register' (own classmethod); ForkingPickler is used by the multiprocessing framework to serialise Python objects for inter-process communication; NEW in extra268: first standalone ForkingPickler.__module__ invariant in mpreduction268 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.reduction.ForkingPickler.__module__.__eq__
  args: ["multiprocessing.reduction"]
  expected: true

invariant multiprocessing_extra268.ForkingPickler_base_is_Pickler:
  description: "multiprocessing.reduction.ForkingPickler.__bases__[0].__name__.__eq__('Pickler') returns True — ForkingPickler inherits from pickle.Pickler (the C-extension Pickler from the _pickle module) as its sole direct base; ForkingPickler's MRO is [ForkingPickler, Pickler, object] (length=3); Pickler.__module__ is '_pickle' (the C extension); ForkingPickler.__mro__.__len__() is 3; ForkingPickler extends Pickler to support custom dispatch_table-based reduction of objects for cross-process transfer; ForkingPickler.__name__.__len__() is 14 ('ForkingPickler'=14); compare: AbstractReducer.__bases__[0].__name__ is 'object' (direct from object, MRO length=2), ForkingPickler.__bases__[0].__name__ is 'Pickler' (one intermediate, MRO length=3); NEW in extra268: first standalone ForkingPickler base class invariant in mpreduction268 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.reduction.ForkingPickler.__bases__[0].__name__.__eq__"
  args: ["Pickler"]
  expected: true

invariant multiprocessing_extra268.AbstractReducer_module_is_multiprocessing_reduction:
  description: "multiprocessing.reduction.AbstractReducer.__module__.__eq__('multiprocessing.reduction') returns True — AbstractReducer is defined in Lib/multiprocessing/reduction.py alongside ForkingPickler and dump(); its __module__ is 'multiprocessing.reduction' (len=25, same as ForkingPickler); AbstractReducer.__bases__[0].__name__ is 'object' (direct subclass of object, no intermediate base); AbstractReducer.__mro__.__len__() is 2 ([AbstractReducer, object]); AbstractReducer.__name__.__len__() is 15 ('AbstractReducer'=15, the longest class name in this spec); AbstractReducer is the base class for building custom reduction registries; NEW in extra268: first standalone AbstractReducer.__module__ invariant in mpreduction268 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.reduction.AbstractReducer.__module__.__eq__
  args: ["multiprocessing.reduction"]
  expected: true

invariant multiprocessing_extra268.AbstractReducer_mro_len_is_2:
  description: "multiprocessing.reduction.AbstractReducer.__mro__.__len__() == 2 — AbstractReducer's MRO is [AbstractReducer, object] (length=2); this is the minimal 2-element MRO indicating AbstractReducer inherits directly from object with no intermediate base; compare MRO depths in this spec: AbstractReducer=2 (direct from object), ForkingPickler=3 (inherits from Pickler which inherits from object); AbstractReducer.__bases__[0].__name__ is 'object'; AbstractReducer.__module__ is 'multiprocessing.reduction'; AbstractReducer.__name__.__len__() is 15; NEW in extra268: first standalone AbstractReducer MRO length invariant in mpreduction268 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.reduction.AbstractReducer.__mro__.__len__
  args: []
  expected: 2

invariant multiprocessing_extra268.dump_module_is_multiprocessing_reduction:
  description: "multiprocessing.reduction.dump.__module__.__eq__('multiprocessing.reduction') returns True — dump() is a module-level function defined in Lib/multiprocessing/reduction.py; its __module__ is 'multiprocessing.reduction' (len=25, shared with ForkingPickler and AbstractReducer); dump.__qualname__ is 'dump' (module-level function, qualname equals name); dump.__name__ is 'dump' (len=4); dump.__class__.__name__ is 'function' (regular Python function); dump() uses ForkingPickler to serialize an object to a file-like buffer; NEW in extra268: first standalone dump.__module__ invariant in mpreduction268 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.reduction.dump.__module__.__eq__
  args: ["multiprocessing.reduction"]
  expected: true
