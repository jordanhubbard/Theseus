spec: csv_extra11
version: ">=3.9"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html — Python csv module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
    - "CPython source: Lib/csv.py"
  notes:
    - "This spec extends csv.zspec.zsdl and csv_extra through csv_extra10."
    - "csv_extra9 covers: DictReader/DictWriter __bases__[0]; reader/writer/DictReader/DictWriter __class__.__name__; list_dialects return type; unregister_dialect/__module__."
    - "csv_extra10 covers: Dialect/Error/Sniffer __class__.__name__; get_dialect.__name__."
    - "csv_extra8 covers: QUOTE_ALL/__ne__(0); QUOTE_MINIMAL/__lt__(1); QUOTE_NONNUMERIC/__gt__(1); QUOTE_NONE/__gt__(2)."
    - "csv_extra5 covers: QUOTE_ALL/__class__.__name__ and QUOTE_MINIMAL/__class__.__name__."
    - "csv_extra6 covers: QUOTE_NONNUMERIC/__class__.__name__ and QUOTE_NONE/__class__.__name__."
    - "No prior csv spec checks QUOTE_STRINGS or QUOTE_NOTNULL — added in Python 3.12 (PEP 709 extension); they are int constants with values 4 and 5."
    - "csv.field_size_limit.__name__ == 'field_size_limit' — no prior spec checks __name__ of field_size_limit; only __qualname__ is covered in csv_extra5."
    - "csv.field_size_limit.__module__ == '_csv' — the field_size_limit builtin is implemented in the _csv C extension; no prior spec checks this specific attribute."
    - "csv.excel_tab.doublequote == True — not covered in any prior csv spec (csv.zspec.zsdl covers excel.doublequote; csv_extra4 also covers excel.doublequote only)."
    - "csv.excel_tab.skipinitialspace == False — no prior csv spec checks this attribute for excel_tab."
    - "csv.unix_dialect.doublequote == True — no prior csv spec checks doublequote for unix_dialect."
    - "csv.DictReader.__bases__.__len__() == 1 — csv_extra9 verifies __bases__[0].__name__ but not the tuple length."
    - "csv.excel.__bases__.__len__() == 1 — csv_extra checks excel.__bases__[0].__name__ but not tuple length."
    - "csv.excel_tab.__bases__.__len__() == 1 — csv_extra checks excel_tab.__bases__[0].__name__ but not tuple length."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# QUOTE_STRINGS and QUOTE_NOTNULL — Python 3.12+ constants.
# No prior csv spec in the chain checks these constants; they are plain ints
# with values 4 and 5 respectively (csv.zspec.zsdl and all extras only cover
# QUOTE_MINIMAL/ALL/NONNUMERIC/NONE which are 0–3).
# ---------------------------------------------------------------------------

table csv_extra11.new_quote_constants_values:
  kind: python_call_eq
  category: constants
  id_prefix: newquote11

  columns: [id, function, args, expected]
  rows:
    - [QUOTE_STRINGS,  QUOTE_STRINGS.__eq__,  [4], true]
    - [QUOTE_NOTNULL,  QUOTE_NOTNULL.__eq__,  [5], true]

table csv_extra11.new_quote_constants_types:
  kind: python_call_eq
  category: constants
  id_prefix: newqtype11

  columns: [id, function, args, expected]
  rows:
    - [QUOTE_STRINGS,  QUOTE_STRINGS.__class__.__name__.__eq__,  ["int"], true]
    - [QUOTE_NOTNULL,  QUOTE_NOTNULL.__class__.__name__.__eq__,  ["int"], true]

# ---------------------------------------------------------------------------
# csv.field_size_limit — __name__ and __module__ attributes.
# csv_extra5 covers field_size_limit.__qualname__; no prior spec checks __name__.
# The builtin is implemented in _csv (C extension) so __module__ == '_csv'.
# ---------------------------------------------------------------------------

invariant csv_extra11.field_size_limit.name:
  description: "csv.field_size_limit.__name__ == 'field_size_limit' — unqualified builtin name"
  category: function_names
  kind: python_call_eq
  function: field_size_limit.__name__.__eq__
  args: ["field_size_limit"]
  expected: true

invariant csv_extra11.field_size_limit.module:
  description: "csv.field_size_limit.__module__ == '_csv' — implemented in the _csv C extension"
  category: modules
  kind: python_call_eq
  function: field_size_limit.__module__.__eq__
  args: ["_csv"]
  expected: true

# ---------------------------------------------------------------------------
# csv.excel_tab and csv.unix_dialect — dialect properties not yet covered.
# csv.zspec.zsdl and csv_extra4 cover excel.doublequote and excel.skipinitialspace
# for the excel dialect only; no prior spec checks these on excel_tab or unix_dialect.
# ---------------------------------------------------------------------------

invariant csv_extra11.excel_tab.doublequote:
  description: "csv.excel_tab.doublequote == True — excel_tab uses double-quote escaping"
  category: excel_tab_dialect
  kind: python_call_eq
  function: excel_tab.doublequote.__eq__
  args: [true]
  expected: true

invariant csv_extra11.excel_tab.skipinitialspace:
  description: "csv.excel_tab.skipinitialspace == False — excel_tab does not skip initial space"
  category: excel_tab_dialect
  kind: python_call_eq
  function: excel_tab.skipinitialspace.__eq__
  args: [false]
  expected: true

invariant csv_extra11.unix_dialect.doublequote:
  description: "csv.unix_dialect.doublequote == True — unix_dialect uses double-quote escaping"
  category: unix_dialect
  kind: python_call_eq
  function: unix_dialect.doublequote.__eq__
  args: [true]
  expected: true

# ---------------------------------------------------------------------------
# __bases__.__len__() == 1 for DictReader, excel, excel_tab.
# csv_extra9 verifies DictReader.__bases__[0].__name__ but not tuple length.
# csv_extra covers excel and excel_tab __bases__[0].__name__ but not lengths.
# ---------------------------------------------------------------------------

table csv_extra11.bases_len:
  kind: python_call_eq
  category: hierarchy
  id_prefix: baselen11

  columns: [id, function, args, expected]
  rows:
    - [DictReader, DictReader.__bases__.__len__, [], 1]
    - [excel,      excel.__bases__.__len__,      [], 1]
    - [excel_tab,  excel_tab.__bases__.__len__,  [], 1]
