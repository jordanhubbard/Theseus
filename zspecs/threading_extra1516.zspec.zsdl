spec: threading_extra1516
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "Wave 548 theme: arithmetic/numeric operator protocol dict-presence checks — __add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__, __pow__ and reflected variants __radd__, __rmul__, __rsub__, __rtruediv__, __rfloordiv__, __rmod__, __rpow__ for threading classes."
    - "threading.Thread: no arithmetic operator methods in __dict__. Verified with Python 3.12."
    - "threading.Semaphore: no arithmetic operator methods in __dict__. Verified with Python 3.12."
    - "threading.Barrier: no arithmetic operator methods in __dict__. Verified with Python 3.12."
    - "threading.Condition: no arithmetic operator methods in __dict__. Verified with Python 3.12."
    - "threading.Event: no arithmetic operator methods in __dict__. Verified with Python 3.12."
    - "None of the threading synchronization primitives are numeric types; they model concurrency constructs (threads, locks, semaphores, barriers, events) with no arithmetic operator support."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread — arithmetic operator protocol absence checks
#
# Wave 548 theme: threading.Thread represents a thread of execution.
#
# threading.Thread.__dict__.__contains__("__add__") == False
# threading.Thread.__dict__.__contains__("__mul__") == False
# threading.Thread.__dict__.__contains__("__sub__") == False
# threading.Thread.__dict__.__contains__("__truediv__") == False
# threading.Thread.__dict__.__contains__("__radd__") == False
# threading.Thread.__dict__.__contains__("__rmul__") == False
#
# Thread is a concurrency class. It defines __repr__ and __init__ but
# no arithmetic operator methods. New to extra1516.
# ---------------------------------------------------------------------------

table threading_extra1516.thread_arithmetic_protocol_absence:
  description: "threading.Thread has no arithmetic operator methods in __dict__; Thread is a concurrency class representing a thread of execution with no numeric support; wave 548; new to extra1516"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1516th

  columns: [id, function, args, expected, description]
  rows:
    - [th1516th001,
       "Thread.__dict__.__contains__",
       ["__add__"],
       false,
       "threading.Thread.__dict__.__contains__('__add__') == False — Thread is a concurrency class representing a thread of execution that runs a callable in a separate thread; it is not a numeric type and does not implement the addition operator protocol; __add__ is not in Thread.__dict__; verified with Python 3.12; new to extra1516"]
    - [th1516th002,
       "Thread.__dict__.__contains__",
       ["__mul__"],
       false,
       "threading.Thread.__dict__.__contains__('__mul__') == False — Thread does not implement the multiplication operator protocol; __mul__ is not in Thread.__dict__; verified with Python 3.12; new to extra1516"]
    - [th1516th003,
       "Thread.__dict__.__contains__",
       ["__sub__"],
       false,
       "threading.Thread.__dict__.__contains__('__sub__') == False — Thread does not implement the subtraction operator protocol; __sub__ is not in Thread.__dict__; verified with Python 3.12; new to extra1516"]
    - [th1516th004,
       "Thread.__dict__.__contains__",
       ["__truediv__"],
       false,
       "threading.Thread.__dict__.__contains__('__truediv__') == False — Thread does not implement the true division operator protocol; __truediv__ is not in Thread.__dict__; verified with Python 3.12; new to extra1516"]
    - [th1516th005,
       "Thread.__dict__.__contains__",
       ["__radd__"],
       false,
       "threading.Thread.__dict__.__contains__('__radd__') == False — Thread does not implement the reflected addition operator protocol; __radd__ is not in Thread.__dict__; verified with Python 3.12; new to extra1516"]
    - [th1516th006,
       "Thread.__dict__.__contains__",
       ["__rmul__"],
       false,
       "threading.Thread.__dict__.__contains__('__rmul__') == False — Thread does not implement the reflected multiplication operator protocol; __rmul__ is not in Thread.__dict__; verified with Python 3.12; new to extra1516"]
    - [th1516th007,
       "Thread.__dict__.__contains__",
       ["__repr__"],
       true,
       "threading.Thread.__dict__.__contains__('__repr__') == True — Thread defines __repr__ in its __dict__ for human-readable string representation of thread objects; __repr__ is a representation protocol, not an arithmetic operator protocol; verified with Python 3.12; new to extra1516"]
    - [th1516th008,
       "Thread.__dict__.__contains__",
       ["__init__"],
       true,
       "threading.Thread.__dict__.__contains__('__init__') == True — Thread defines __init__ in its __dict__ for initializing thread objects with target, name, args, kwargs, daemon settings; __init__ is the object initialization protocol, distinct from any arithmetic operator protocol; verified with Python 3.12; new to extra1516"]

# ---------------------------------------------------------------------------
# Table 2: threading.Semaphore and threading.Barrier — arithmetic operator
# protocol absence checks
#
# Wave 548 theme: Semaphore controls access to a shared resource through a
# counter; Barrier synchronizes a fixed number of threads at a checkpoint.
#
# threading.Semaphore.__dict__.__contains__("__add__") == False
# threading.Semaphore.__dict__.__contains__("__floordiv__") == False
# threading.Barrier.__dict__.__contains__("__mul__") == False
# threading.Barrier.__dict__.__contains__("__mod__") == False
# threading.Semaphore.__dict__.__contains__("__rsub__") == False
# threading.Barrier.__dict__.__contains__("__rpow__") == False
#
# Both are synchronization primitives. Semaphore has __enter__ and __exit__;
# Barrier has __repr__ and __init__. Neither implements arithmetic. New to
# extra1516.
# ---------------------------------------------------------------------------

table threading_extra1516.semaphore_barrier_arithmetic_protocol_absence:
  description: "threading.Semaphore and Barrier have no arithmetic operator methods in __dict__; both are synchronization primitives with no numeric support; wave 548; new to extra1516"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1516sb

  columns: [id, function, args, expected, description]
  rows:
    - [th1516sb001,
       "Semaphore.__dict__.__contains__",
       ["__add__"],
       false,
       "threading.Semaphore.__dict__.__contains__('__add__') == False — Semaphore is a synchronization primitive that controls access to a shared resource through an internal counter; it is not a numeric type and does not implement the addition operator protocol; __add__ is not in Semaphore.__dict__; verified with Python 3.12; new to extra1516"]
    - [th1516sb002,
       "Semaphore.__dict__.__contains__",
       ["__floordiv__"],
       false,
       "threading.Semaphore.__dict__.__contains__('__floordiv__') == False — Semaphore does not implement the floor division operator protocol; __floordiv__ is not in Semaphore.__dict__; verified with Python 3.12; new to extra1516"]
    - [th1516sb003,
       "Semaphore.__dict__.__contains__",
       ["__rsub__"],
       false,
       "threading.Semaphore.__dict__.__contains__('__rsub__') == False — Semaphore does not implement the reflected subtraction operator protocol; __rsub__ is not in Semaphore.__dict__; verified with Python 3.12; new to extra1516"]
    - [th1516sb004,
       "Barrier.__dict__.__contains__",
       ["__mul__"],
       false,
       "threading.Barrier.__dict__.__contains__('__mul__') == False — Barrier is a synchronization primitive that blocks threads until a fixed number have reached the barrier checkpoint; it is not a numeric type and does not implement the multiplication operator protocol; __mul__ is not in Barrier.__dict__; verified with Python 3.12; new to extra1516"]
    - [th1516sb005,
       "Barrier.__dict__.__contains__",
       ["__mod__"],
       false,
       "threading.Barrier.__dict__.__contains__('__mod__') == False — Barrier does not implement the modulo operator protocol; __mod__ is not in Barrier.__dict__; verified with Python 3.12; new to extra1516"]
    - [th1516sb006,
       "Barrier.__dict__.__contains__",
       ["__rpow__"],
       false,
       "threading.Barrier.__dict__.__contains__('__rpow__') == False — Barrier does not implement the reflected exponentiation operator protocol; __rpow__ is not in Barrier.__dict__; verified with Python 3.12; new to extra1516"]
    - [th1516sb007,
       "Semaphore.__dict__.__contains__",
       ["__enter__"],
       true,
       "threading.Semaphore.__dict__.__contains__('__enter__') == True — Semaphore IS a context manager and defines __enter__ in its __dict__ allowing use with the with statement; __enter__ is the context manager protocol, not an arithmetic operator protocol; verified with Python 3.12; new to extra1516"]
    - [th1516sb008,
       "Barrier.__dict__.__contains__",
       ["__repr__"],
       true,
       "threading.Barrier.__dict__.__contains__('__repr__') == True — Barrier defines __repr__ in its __dict__ for human-readable string representation showing parties, n_waiting, and broken state; __repr__ is a representation protocol, not an arithmetic operator protocol; verified with Python 3.12; new to extra1516"]

# ---------------------------------------------------------------------------
# Table 3: threading.Condition and threading.Event — arithmetic operator
# protocol absence checks
#
# Wave 548 theme: Condition pairs a Lock with a wait/notify mechanism;
# Event provides a simple flag that threads can wait on or set.
#
# threading.Condition.__dict__.__contains__("__add__") == False
# threading.Condition.__dict__.__contains__("__mul__") == False
# threading.Event.__dict__.__contains__("__sub__") == False
# threading.Event.__dict__.__contains__("__truediv__") == False
# threading.Condition.__dict__.__contains__("__rfloordiv__") == False
# threading.Event.__dict__.__contains__("__rmod__") == False
#
# Both are synchronization primitives. Condition has __enter__ and __exit__;
# Event has __repr__. Neither implements arithmetic. New to extra1516.
# ---------------------------------------------------------------------------

table threading_extra1516.condition_event_arithmetic_protocol_absence:
  description: "threading.Condition and Event have no arithmetic operator methods in __dict__; both are synchronization primitives with no numeric support; wave 548; new to extra1516"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1516ce

  columns: [id, function, args, expected, description]
  rows:
    - [th1516ce001,
       "Condition.__dict__.__contains__",
       ["__add__"],
       false,
       "threading.Condition.__dict__.__contains__('__add__') == False — Condition is a synchronization primitive that pairs a Lock with a wait/notify mechanism allowing threads to wait for a condition and be notified by other threads; it is not a numeric type and does not implement the addition operator protocol; __add__ is not in Condition.__dict__; verified with Python 3.12; new to extra1516"]
    - [th1516ce002,
       "Condition.__dict__.__contains__",
       ["__mul__"],
       false,
       "threading.Condition.__dict__.__contains__('__mul__') == False — Condition does not implement the multiplication operator protocol; __mul__ is not in Condition.__dict__; verified with Python 3.12; new to extra1516"]
    - [th1516ce003,
       "Condition.__dict__.__contains__",
       ["__rfloordiv__"],
       false,
       "threading.Condition.__dict__.__contains__('__rfloordiv__') == False — Condition does not implement the reflected floor division operator protocol; __rfloordiv__ is not in Condition.__dict__; verified with Python 3.12; new to extra1516"]
    - [th1516ce004,
       "Event.__dict__.__contains__",
       ["__sub__"],
       false,
       "threading.Event.__dict__.__contains__('__sub__') == False — Event is a synchronization primitive providing a simple flag that threads can wait on until another thread sets it; it is not a numeric type and does not implement the subtraction operator protocol; __sub__ is not in Event.__dict__; verified with Python 3.12; new to extra1516"]
    - [th1516ce005,
       "Event.__dict__.__contains__",
       ["__truediv__"],
       false,
       "threading.Event.__dict__.__contains__('__truediv__') == False — Event does not implement the true division operator protocol; __truediv__ is not in Event.__dict__; verified with Python 3.12; new to extra1516"]
    - [th1516ce006,
       "Event.__dict__.__contains__",
       ["__rmod__"],
       false,
       "threading.Event.__dict__.__contains__('__rmod__') == False — Event does not implement the reflected modulo operator protocol; __rmod__ is not in Event.__dict__; verified with Python 3.12; new to extra1516"]
    - [th1516ce007,
       "Condition.__dict__.__contains__",
       ["__enter__"],
       true,
       "threading.Condition.__dict__.__contains__('__enter__') == True — Condition IS a context manager and defines __enter__ in its __dict__ allowing use with the with statement to acquire the underlying lock; __enter__ is the context manager protocol, not an arithmetic operator protocol; verified with Python 3.12; new to extra1516"]
    - [th1516ce008,
       "Event.__dict__.__contains__",
       ["__repr__"],
       true,
       "threading.Event.__dict__.__contains__('__repr__') == True — Event defines __repr__ in its __dict__ for human-readable string representation showing the internal flag state; __repr__ is a representation protocol, not an arithmetic operator protocol; verified with Python 3.12; new to extra1516"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1516
# ---------------------------------------------------------------------------

invariant threading_extra1516.thread_no_add:
  description: "threading.Thread.__dict__ does not contain '__add__' — Thread is a concurrency class, not a numeric type; wave 548; new to extra1516"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["__add__"]
  expected: false

invariant threading_extra1516.thread_no_mul:
  description: "threading.Thread.__dict__ does not contain '__mul__' — Thread does not implement the multiplication operator protocol; wave 548; new to extra1516"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["__mul__"]
  expected: false

invariant threading_extra1516.semaphore_no_sub:
  description: "threading.Semaphore.__dict__ does not contain '__sub__' — Semaphore does not implement the subtraction operator protocol; wave 548; new to extra1516"
  kind: python_call_eq
  function: Semaphore.__dict__.__contains__
  args: ["__sub__"]
  expected: false

invariant threading_extra1516.barrier_no_truediv:
  description: "threading.Barrier.__dict__ does not contain '__truediv__' — Barrier does not implement the true division operator protocol; wave 548; new to extra1516"
  kind: python_call_eq
  function: Barrier.__dict__.__contains__
  args: ["__truediv__"]
  expected: false

invariant threading_extra1516.condition_no_pow:
  description: "threading.Condition.__dict__ does not contain '__pow__' — Condition is a synchronization primitive, not a numeric type; wave 548; new to extra1516"
  kind: python_call_eq
  function: Condition.__dict__.__contains__
  args: ["__pow__"]
  expected: false

invariant threading_extra1516.event_no_radd:
  description: "threading.Event.__dict__ does not contain '__radd__' — Event does not implement the reflected addition operator protocol; wave 548; new to extra1516"
  kind: python_call_eq
  function: Event.__dict__.__contains__
  args: ["__radd__"]
  expected: false

invariant threading_extra1516.semaphore_has_enter:
  description: "threading.Semaphore.__dict__ contains '__enter__' — Semaphore IS a context manager; wave 548; new to extra1516"
  kind: python_call_eq
  function: Semaphore.__dict__.__contains__
  args: ["__enter__"]
  expected: true
