# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('hex') — standalone
#
# uuid.UUID.__dict__.__contains__('hex') is True. The 'hex' attribute is a property
# descriptor defined in the UUID class body. It returns the UUID as a 32-character
# hexadecimal string without hyphens (e.g., '550e8400e29b41d4a716446655440000').
# 'hex' is in UUID.__dict__ because it is defined directly in the UUID class, not inherited.
# UUID.hex is equivalent to uuid.UUID.int computed as a hex string.
# uuid.UUID.__dict__.__contains__('hex') == True confirms that 'hex' is a direct attribute
# of the UUID class, accessible without inheritance lookup through the MRO.
# No prior uuid spec anchors this as a standalone under uuiddict156.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra156.UUID_dict_contains_hex:
  description: "uuid.UUID.__dict__.__contains__('hex') == True — 'hex' is a property descriptor in UUID.__dict__; returns 32-char hexadecimal UUID string without hyphens (e.g. '550e8400e29b41d4a716446655440000'); defined directly in UUID class body (not inherited); UUID.__dict__.__len__()==37 (37 total entries); __dict__.__class__.__name__=='mappingproxy'; 'hex' is one of 17 data property descriptors in UUID class; first uuiddict156 standalone for __contains__('hex')"
  category: identity
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["hex"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('bytes') — standalone
#
# uuid.UUID.__dict__.__contains__('bytes') is True. The 'bytes' attribute is a property
# descriptor defined in the UUID class. It returns the UUID as a 16-byte bytes object in
# big-endian byte order. 'bytes_le' is also in UUID.__dict__ and returns the UUID in
# little-endian byte order (as used by Windows GUIDs). Both 'bytes' and 'bytes_le' are
# defined in the UUID class body. uuid.UUID.__dict__.__contains__('bytes') == True confirms
# that 'bytes' is a direct class attribute, not inherited.
# No prior uuid spec anchors this as a standalone under uuiddict156.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra156.UUID_dict_contains_bytes:
  description: "uuid.UUID.__dict__.__contains__('bytes') == True — 'bytes' is a property descriptor in UUID.__dict__; returns UUID as 16-byte bytes object in big-endian byte order; 'bytes_le' is also in __dict__ (little-endian, Windows GUID format); both are defined directly in UUID class body; UUID.__dict__.__len__()==37; 'bytes' is one of the standard UUID representation properties (hex/int/bytes/bytes_le/fields/urn); first uuiddict156 standalone for __contains__('bytes')"
  category: identity
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('__init__') — standalone
#
# uuid.UUID.__dict__.__contains__('__init__') is True. UUID.__init__ is the class
# initializer, defined in Lib/uuid.py. It accepts 7 positional parameters (self, hex,
# bytes, bytes_le, fields, int, version) and 1 keyword-only parameter (is_safe). Because
# UUID.__init__ is defined directly in the UUID class body, it appears in UUID.__dict__.
# uuid_extra149 and uuid_extra155 anchor UUID.__init__.__code__.co_argcount==7 and other
# code object attributes. uuid.UUID.__dict__.__contains__('__init__') == True confirms
# that __init__ is a direct class member, accessible via UUID.__dict__['__init__'].
# No prior uuid spec anchors this as a standalone under uuiddict156.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra156.UUID_dict_contains_init:
  description: "uuid.UUID.__dict__.__contains__('__init__') == True — '__init__' is the UUID initializer defined in Lib/uuid.py; 7 positional params (self/hex/bytes/bytes_le/fields/int/version) + 1 kw-only (is_safe); uuid_extra149 anchors co_argcount==7; uuid_extra155 anchors co_varnames.__len__()==15; defined directly in UUID class so in __dict__; UUID.__dict__.__len__()==37; __init__ is 'function' type (pure Python method); first uuiddict156 standalone for __contains__('__init__')"
  category: identity
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["__init__"]
  expected: true

