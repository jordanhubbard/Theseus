table uuid_extra156.UUID_dict_variant_and_dunder_membership:
  description: "uuid.UUID.__dict__.__contains__('variant')==True / __dict__.__contains__('__init__')==True / __dict__.__contains__('__str__')==True / __dict__.__contains__('__repr__')==True — __dict__.__contains__('variant') is True ('variant' is a property descriptor returning the UUID variant (RFC 4122 or DCE 1.1 or reserved); there are 3 variant types; the variant describes the layout of the UUID fields); __dict__.__contains__('__init__') is True ('__init__' is the UUID initializer method; uuid_extra149 anchors co_argcount==7; defined in Lib/uuid.py as 'function'); __dict__.__contains__('__str__') is True ('__str__' is defined on UUID to return the canonical hyphenated UUID string 'xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx'; 36 chars; defined in Lib/uuid.py); __dict__.__contains__('__repr__') is True ('__repr__' is defined on UUID; returns 'UUID(...)' representation for debugging; defined in Lib/uuid.py); all four are in UUID.__dict__ because all are defined directly in the UUID class body; first uuiddict156 anchor for variant and dunder membership"
  kind: python_call_eq
  category: identity
  id_prefix: uuiddict156

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_variant,  "__dict__.__contains__", ["variant"],  true, "uuid.UUID.__dict__.__contains__('variant') == True ('variant' is a property descriptor for UUID variant type (RFC 4122, DCE 1.1, or reserved))"]
    - [dict_has_init,     "__dict__.__contains__", ["__init__"], true, "uuid.UUID.__dict__.__contains__('__init__') == True ('__init__' is the UUID initializer; uuid_extra149 anchors co_argcount==7; 7 positional params)"]
    - [dict_has_str,      "__dict__.__contains__", ["__str__"],  true, "uuid.UUID.__dict__.__contains__('__str__') == True ('__str__' is defined on UUID; returns canonical hyphenated UUID string 'xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx')"]
    - [dict_has_repr,     "__dict__.__contains__", ["__repr__"], true, "uuid.UUID.__dict__.__contains__('__repr__') == True ('__repr__' is defined on UUID; returns 'UUID(...)' representation for debugging)"]

