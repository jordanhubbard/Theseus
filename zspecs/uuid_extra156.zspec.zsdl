# data property descriptors (hex, int, bytes, bytes_le, fields, time, clock_seq,
# clock_seq_hi_variant, clock_seq_low, node, time_low, time_mid, time_hi_version,
# is_safe, urn, variant, version = 17 properties), dunder methods (__init__, __str__,
