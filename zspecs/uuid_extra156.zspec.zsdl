invariant uuid_extra156.UUID_dict_len_37:
  description: "uuid.UUID.__dict__.__len__() == 37 — 37 entries: 17 data properties (hex/int/bytes/bytes_le/fields/time/clock_seq/clock_seq_hi_variant/clock_seq_low/node/time_low/time_mid/time_hi_version/is_safe/urn/variant/version) + 14 dunder methods (__init__/__str__/__repr__/__hash__/__eq__/__lt__/__le__/__gt__/__ge__/__int__/__setattr__/__getstate__/__setstate__/__weakref__) + 6 infrastructure (__doc__/__module__/__slots__/__firstlineno__/__static_attributes__/_from_int); 17+14+6=37; uuid_extra152 anchors __len__()==37 as table row; __dict__.__class__.__name__=='mappingproxy'; first uuiddict156 standalone for __len__()"
