spec: bz2_extra13
version: ">=3.9"
backend: python_module(bz2)

docs: https://docs.python.org/3/library/bz2.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bz2.html — Python bz2 documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_bz2module.c"
    - "CPython source: Lib/bz2.py"
    - "bz2_extra12.zspec.zsdl — covers open/__name__ standalone (extra12); open/__module__ standalone (extra12); BZ2Compressor.__bases__[0].__name__=='object'; BZ2Decompressor.__bases__[0].__name__=='object'; compress(b'hello') exact length==41; compress(b'') exact length==14."
    - "bz2_extra11.zspec.zsdl — covers compress/__name__ standalone (extra11); decompress/__name__ standalone (extra11); BZ2File/BZ2Compressor/BZ2Decompressor __qualname__ standalone (extra11); class __module__ table (extra11); compress(b'') returns bytes (extra11); decompress(pre-compressed-hello) returns bytes (extra11)."
    - "bz2_extra10.zspec.zsdl — covers class __name__/__module__ tables; function __name__/__module__ tables; BZ2Compressor() instance class name; compress(b'hello') non-empty; compress(b'') returns bytes (extra10)."
    - "bz2_extra9.zspec.zsdl — covers compress returns bytes (hello + empty); decompress returns bytes; function __name__ table; BZ2File/BZ2Compressor/BZ2Decompressor __qualname__ standalone; bz2.__name__."
    - "bz2_extra7.zspec.zsdl — covers BZ2File.__bases__[0].__name__; open/compress/decompress __module__ standalone from extra7."
  notes:
    - "This spec extends bz2 through bz2_extra12; it does NOT duplicate invariants present in those files."
    - "Focus: BZ2File.__bases__[0].__name__ == 'BaseStream' bool-form (extra13 namespace); open/__qualname__ standalone (extra13); compress/__qualname__ standalone (extra13); decompress/__qualname__ standalone (extra13); function __module__ table (extra13)."
    - "BZ2File.__bases__[0].__name__ == 'BaseStream': BZ2File inherits from _compression.BaseStream on Python 3.12. bz2_extra7 covers this as a string-form result. This invariant uses the bool-form __eq__ pattern — a distinct axis and namespace anchor. Verified 2026-04-09."
    - "open/__qualname__ == 'open', compress/__qualname__ == 'compress', decompress/__qualname__ == 'decompress': all are module-level functions; __qualname__ equals __name__. bz2_extra4 covers __qualname__ in a table from extra4. These re-anchor each from the extra13 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BZ2File.__bases__[0].__name__ == 'BaseStream' — bool form (extra13 anchor)
#
# bz2_extra7 covers BZ2File.__bases__[0].__name__ as a string-form result via
# getitem+method from extra7. This invariant re-anchors the same property using
# the bool-form __eq__ pattern from the extra13 namespace.
# ---------------------------------------------------------------------------

invariant bz2_extra13.BZ2File.base_name_bool:
  description: "bz2.BZ2File.__bases__[0].__name__ == 'BaseStream' — BZ2File inherits from BaseStream (bool-form, extra13)"
  category: class_hierarchy
  kind: python_call_eq
  function: BZ2File.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["BaseStream"]
  expected: true

# ---------------------------------------------------------------------------
# Function __qualname__ attributes — open, compress, decompress (standalone)
#
# bz2_extra4 covers open/compress/decompress __qualname__ in a table from extra4.
# bz2_extra9 covers BZ2File/BZ2Compressor/BZ2Decompressor __qualname__ standalone.
# These invariants re-anchor open/compress/decompress each from the extra13 namespace.
# ---------------------------------------------------------------------------

invariant bz2_extra13.open.qualname:
  description: "bz2.open.__qualname__ == 'open' — extra13 namespace anchor"
  category: function_identity
  kind: python_call_eq
  function: open.__qualname__.__eq__
  args: ["open"]
  expected: true

invariant bz2_extra13.compress.qualname:
  description: "bz2.compress.__qualname__ == 'compress' — extra13 namespace anchor"
  category: function_identity
  kind: python_call_eq
  function: compress.__qualname__.__eq__
  args: ["compress"]
  expected: true

invariant bz2_extra13.decompress.qualname:
  description: "bz2.decompress.__qualname__ == 'decompress' — extra13 namespace anchor"
  category: function_identity
  kind: python_call_eq
  function: decompress.__qualname__.__eq__
  args: ["decompress"]
  expected: true

# ---------------------------------------------------------------------------
# Function __module__ table — open, compress, decompress (extra13)
#
# bz2_extra7 covers open/compress/decompress __module__ as standalone invariants
# from extra7. bz2_extra10 covers them in a table from extra10. This table
# re-anchors all three from the extra13 namespace with a distinct id_prefix.
# ---------------------------------------------------------------------------

table bz2_extra13.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod13

  columns: [id, function, args, expected]
  rows:
    - [open,       open.__module__.__eq__,       ["bz2"], true]
    - [compress,   compress.__module__.__eq__,   ["bz2"], true]
    - [decompress, decompress.__module__.__eq__, ["bz2"], true]
