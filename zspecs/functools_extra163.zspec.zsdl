spec: functools_extra163
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.partial.__call__.__qualname__ 'partial.__call__' (C slot wrapper); functools.partial.__repr__.__qualname__ 'partial.__repr__' (C slot wrapper); functools.partial.__new__.__qualname__ 'partial.__new__' (C static method); functools.partialmethod.__repr__.__qualname__ '_partial_repr' (alias to module-level helper); functools.partialmethod.__doc__.__class__.__name__ 'str'; functools.reduce.__doc__.__class__.__name__ 'str'; functools.__name__.__eq__('functools') True; functools.__package__ empty string (Wave 287)."
    - "functools.partial.__call__.__qualname__ == 'partial.__call__' — partial is a C extension type in _functoolsmodule.c; its __call__ slot wrapper has __qualname__ 'partial.__call__'. Verified with Python 3.14.3."
    - "functools.partial.__repr__.__qualname__ == 'partial.__repr__' — partial's __repr__ slot wrapper has __qualname__ 'partial.__repr__'. Verified with Python 3.14.3."
    - "functools.partial.__new__.__qualname__ == 'partial.__new__' — partial's __new__ static method has __qualname__ 'partial.__new__'. Verified with Python 3.14.3."
    - "functools.partialmethod.__repr__.__qualname__ == '_partial_repr' — partialmethod.__repr__ is bound to the module-level helper function _partial_repr defined in Lib/functools.py; its __qualname__ is '_partial_repr' (not 'partialmethod.__repr__'). Verified with Python 3.14.3."
    - "functools.partialmethod.__doc__.__class__.__name__ == 'str' — partialmethod is a Python class with a str docstring. Verified with Python 3.14.3."
    - "functools.reduce.__doc__.__class__.__name__ == 'str' — reduce is a C builtin function with a str docstring. Verified with Python 3.14.3."
    - "functools.__name__ == 'functools' — the module's __name__ attribute is 'functools'. Verified with Python 3.14.3."
    - "functools.__package__ == '' — functools is a top-level module; its __package__ is the empty string (not 'functools'). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial C slot wrapper qualnames
#
# Wave 287 theme: functools.partial.__call__, __repr__, and __new__ qualnames.
#
# functools.partial.__call__.__qualname__ == 'partial.__call__'
# functools.partial.__repr__.__qualname__ == 'partial.__repr__'
# functools.partial.__new__.__qualname__ == 'partial.__new__'
# functools.partialmethod.__repr__.__qualname__ == '_partial_repr'
#
# functools.partial is a C extension type in _functoolsmodule.c. Its slot
# wrappers for __call__ and __repr__ report __qualname__ as 'partial.__call__'
# and 'partial.__repr__' respectively. Its __new__ static method reports
# 'partial.__new__'. By contrast, partialmethod is a Python class in
# Lib/functools.py; its __repr__ is assigned to the module-level helper
# function _partial_repr, so that function's __qualname__ is '_partial_repr'.
# New to extra163.
# ---------------------------------------------------------------------------

table functools_extra163.partial_slot_wrapper_qualnames:
  description: "functools.partial: __call__ qualname 'partial.__call__', __repr__ qualname 'partial.__repr__', __new__ qualname 'partial.__new__'; partialmethod.__repr__ qualname '_partial_repr'; wave 287; new to extra163"
  kind: python_call_eq
  category: identity
  id_prefix: functoolspswq163

  columns: [id, function, args, expected, description]
  rows:
    - [partial_call_qualname_eq,
       "partial.__call__.__qualname__.__eq__",
       ["partial.__call__"],
       true,
       "functools.partial.__call__.__qualname__.__eq__('partial.__call__') == True — partial is a C extension type in _functoolsmodule.c; its __call__ slot wrapper has __qualname__ 'partial.__call__'; str.__eq__('partial.__call__') returns True; new to extra163"]
    - [partial_repr_qualname_eq,
       "partial.__repr__.__qualname__.__eq__",
       ["partial.__repr__"],
       true,
       "functools.partial.__repr__.__qualname__.__eq__('partial.__repr__') == True — partial's __repr__ slot wrapper is defined in C; its __qualname__ is 'partial.__repr__'; str.__eq__('partial.__repr__') returns True; new to extra163"]
    - [partial_new_qualname_eq,
       "partial.__new__.__qualname__.__eq__",
       ["partial.__new__"],
       true,
       "functools.partial.__new__.__qualname__.__eq__('partial.__new__') == True — partial's __new__ static method is defined in C; its __qualname__ is 'partial.__new__'; str.__eq__('partial.__new__') returns True; new to extra163"]
    - [partialmethod_repr_qualname_eq,
       "partialmethod.__repr__.__qualname__.__eq__",
       ["_partial_repr"],
       true,
       "functools.partialmethod.__repr__.__qualname__.__eq__('_partial_repr') == True — partialmethod.__repr__ is assigned to the module-level helper function _partial_repr defined in Lib/functools.py; that function's __qualname__ is '_partial_repr' (not 'partialmethod.__repr__'); str.__eq__('_partial_repr') returns True; new to extra163"]

# ---------------------------------------------------------------------------
# Table 2: functools module-level doc and identity attributes
#
# Wave 287 theme: functools.reduce doc class, functools.partialmethod doc class,
# functools module __name__ and __package__.
#
# functools.partialmethod.__doc__.__class__.__name__ == 'str'
# functools.reduce.__doc__.__class__.__name__ == 'str'
# functools.__name__ == 'functools'
# functools.__package__ == ''
#
# partialmethod is a Python class with a class-level docstring that is a str.
# reduce is a C builtin function whose docstring is also a str. functools is a
# top-level module; its __name__ is 'functools' and its __package__ is the
# empty string (top-level modules have __package__ == ''). New to extra163.
# ---------------------------------------------------------------------------

table functools_extra163.module_doc_and_identity_attrs:
  description: "functools: partialmethod doc class 'str', reduce doc class 'str', __name__ 'functools', __package__ '' (empty string for top-level module); wave 287; new to extra163"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsmdid163

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_doc_class_eq_str,
       "partialmethod.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.partialmethod.__doc__.__class__.__name__.__eq__('str') == True — partialmethod is a Python class in Lib/functools.py with a docstring; the docstring is a Python str object; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra163"]
    - [reduce_doc_class_eq_str,
       "reduce.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.reduce.__doc__.__class__.__name__.__eq__('str') == True — reduce is a C builtin function in _functoolsmodule.c; its docstring is a Python str object; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra163"]
    - [functools_name_eq_functools,
       "__name__.__eq__",
       ["functools"],
       true,
       "functools.__name__.__eq__('functools') == True — the functools module's __name__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra163"]
    - [functools_package_eq_empty,
       "__package__.__eq__",
       [""],
       true,
       "functools.__package__.__eq__('') == True — functools is a top-level stdlib module; its __package__ attribute is the empty string (top-level modules have __package__ == ''); str.__eq__('') returns True; new to extra163"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra163
# ---------------------------------------------------------------------------

invariant functools_extra163.partial_call_qualname_eq:
  description: "functools.partial.__call__.__qualname__ == 'partial.__call__' — C slot wrapper qualname for partial's call slot; wave 287; new to extra163"
  kind: python_call_eq
  function: partial.__call__.__qualname__.__eq__
  args: ["partial.__call__"]
  expected: true

invariant functools_extra163.partial_repr_qualname_eq:
  description: "functools.partial.__repr__.__qualname__ == 'partial.__repr__' — C slot wrapper qualname for partial's repr slot; wave 287; new to extra163"
  kind: python_call_eq
  function: partial.__repr__.__qualname__.__eq__
  args: ["partial.__repr__"]
  expected: true

invariant functools_extra163.partial_new_qualname_eq:
  description: "functools.partial.__new__.__qualname__ == 'partial.__new__' — C static method qualname for partial's new slot; wave 287; new to extra163"
  kind: python_call_eq
  function: partial.__new__.__qualname__.__eq__
  args: ["partial.__new__"]
  expected: true

invariant functools_extra163.partialmethod_repr_qualname_partial_repr:
  description: "functools.partialmethod.__repr__.__qualname__ == '_partial_repr' — partialmethod.__repr__ is bound to the module-level helper _partial_repr; wave 287; new to extra163"
  kind: python_call_eq
  function: partialmethod.__repr__.__qualname__.__eq__
  args: ["_partial_repr"]
  expected: true

invariant functools_extra163.functools_name_functools:
  description: "functools.__name__ == 'functools' — module __name__ is 'functools'; wave 287; new to extra163"
  kind: python_call_eq
  function: __name__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra163.functools_package_empty_string:
  description: "functools.__package__ == '' — top-level module __package__ is empty string; wave 287; new to extra163"
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true
