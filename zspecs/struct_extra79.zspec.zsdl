spec: struct_extra79
version: ">=3.9"
extends: struct_extra78
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra78.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __doc__.__class__.__name__=='str' / Struct.format/size/__class__.__name__=='getset_descriptor' / Struct.pack/unpack/pack_into/unpack_from/iter_unpack __class__.__name__=='method_descriptor' / Struct.__module__/__len__()==7 / Struct.__name__/__len__()==6 (table + invariants)."
    - "struct_extra77.zspec.zsdl — covers Struct/__dict__/__len__()==16 / error/__dict__/__len__()==3 / Struct/__doc__/__len__()==40 / module-level and Struct __doc__.__class__.__name__ cross-checks (table + invariants)."
    - "struct_extra75.zspec.zsdl — covers struct.error.__name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__() / pack/unpack __qualname__.__eq__ (table + invariants)."
    - "struct_extra74.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __qualname__.__len__() / module-level pack/unpack/pack_into/unpack_from/iter_unpack/calcsize __qualname__.__len__() (table + invariants)."
    - "struct_extra59.zspec.zsdl — covers pack.__doc__.__len__()==176 (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra78; it does NOT duplicate invariants present in those files."
    - "Wave 250 theme: struct module-level function __qualname__.__eq__ identity and __doc__.__len__() cross-checks."
    - "struct.pack.__qualname__.__eq__('pack') == True — confirmed as True. struct_extra75 checks __qualname__.__eq__ for pack/unpack (standing invariants); this spec checks additional functions. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__qualname__.__eq__('pack_into') == True — pack_into's qualname is 'pack_into'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__qualname__.__eq__('unpack_from') == True — unpack_from's qualname is 'unpack_from'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__qualname__.__eq__('calcsize') == True — calcsize's qualname is 'calcsize'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__qualname__.__eq__('iter_unpack') == True — iter_unpack's qualname is 'iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__qualname__.__eq__('error') == True — error exception class qualname is 'error'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__qualname__.__eq__('Struct') == True — Struct class qualname is 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__doc__.__len__() == 176 — pack docstring is 176 characters. Already anchored in struct_extra59; re-checked here for cross-spec consistency. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__doc__.__len__() == 173 — unpack docstring is 173 characters. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__doc__.__len__() == 66 — calcsize docstring is 66 characters. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__doc__.__len__() == 40 — Struct class docstring is 40 characters. Already anchored in struct_extra77. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack_into/__qualname__/__eq__('pack_into') / unpack_from/__qualname__/__eq__('unpack_from')
# struct.calcsize/__qualname__/__eq__('calcsize') / iter_unpack/__qualname__/__eq__('iter_unpack')
#
# Wave 250 theme: module-level function __qualname__.__eq__ identity (group 1).
#
# pack_into, unpack_from, calcsize, iter_unpack all have qualnames equal to their names.
# struct_extra75 covers pack and unpack __qualname__.__eq__; this covers the remaining four.
# struct_extra74 covers __qualname__.__len__() but not __qualname__.__eq__() for these.
# No prior struct spec checks __qualname__.__eq__ for pack_into/unpack_from/calcsize/iter_unpack.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra79.function_qualname_eq_group1:
  description: "struct.pack_into/__qualname__/__eq__('pack_into')==True / unpack_from/__qualname__/__eq__('unpack_from')==True / calcsize/__qualname__/__eq__('calcsize')==True / iter_unpack/__qualname__/__eq__('iter_unpack')==True — all four module-level functions have __qualname__ equal to their own names; struct_extra74 anchors __qualname__.__len__(); struct_extra75 anchors pack/unpack __qualname__.__eq__(); this table adds the remaining four; first __qualname__.__eq__ anchor for pack_into/unpack_from/calcsize/iter_unpack"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra79

  columns: [id, function, args, expected]
  rows:
    - [pack_into_qualname_eq,    pack_into.__qualname__.__eq__,    ["pack_into"],    true]
    - [unpack_from_qualname_eq,  unpack_from.__qualname__.__eq__,  ["unpack_from"],  true]
    - [calcsize_qualname_eq,     calcsize.__qualname__.__eq__,     ["calcsize"],     true]
    - [iter_unpack_qualname_eq,  iter_unpack.__qualname__.__eq__,  ["iter_unpack"],  true]

# ---------------------------------------------------------------------------
# struct.error/__qualname__/__eq__('error') / Struct/__qualname__/__eq__('Struct')
# struct.pack_into/__qualname__/__len__() / unpack_from/__qualname__/__len__()
#
# Wave 250 theme: error and Struct __qualname__.__eq__ and pack_into/unpack_from qualname lengths.
#
# error.__qualname__ == 'error' and Struct.__qualname__ == 'Struct'.
# pack_into.__qualname__ is 'pack_into' (9 chars), unpack_from.__qualname__ is 'unpack_from' (11 chars).
# struct_extra74 covers __qualname__.__len__() for these; this cross-checks __qualname__.__eq__
# for error and Struct alongside length cross-checks for pack_into/unpack_from.
# No prior struct spec checks error.__qualname__.__eq__ or Struct.__qualname__.__eq__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra79.error_struct_qualname_and_lengths:
  description: "struct.error/__qualname__/__eq__('error')==True / Struct/__qualname__/__eq__('Struct')==True / pack_into/__qualname__/__len__()==9 / unpack_from/__qualname__/__len__()==11 — error exception and Struct class both have __qualname__ equal to their names; 'pack_into' is 9 chars and 'unpack_from' is 11 chars; no prior struct spec checks error.__qualname__.__eq__ or Struct.__qualname__.__eq__; first __qualname__.__eq__ anchor for struct.error and struct.Struct"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra79

  columns: [id, function, args, expected]
  rows:
    - [error_qualname_eq,          error.__qualname__.__eq__,    ["error"],   true]
    - [struct_qualname_eq,         Struct.__qualname__.__eq__,   ["Struct"],  true]
    - [pack_into_qualname_len_9,   pack_into.__qualname__.__len__,  [],       9]
    - [unpack_from_qualname_len_11, unpack_from.__qualname__.__len__, [],     11]

# ---------------------------------------------------------------------------
# struct.unpack/__doc__/__len__() / calcsize/__doc__/__len__()
# struct.pack_into/__doc__/__len__() / unpack_from/__doc__/__len__()
#
# Wave 250 theme: module-level function __doc__.__len__() cross-checks.
#
# unpack.__doc__.__len__() == 173, calcsize.__doc__.__len__() == 66.
# pack_into.__doc__.__len__() == 274, unpack_from.__doc__.__len__() == 188.
# struct_extra59 covers pack.__doc__.__len__()==176.
# No prior struct spec checks unpack/calcsize/pack_into/unpack_from __doc__.__len__().
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra79.function_doc_lengths:
  description: "struct.unpack/__doc__/__len__()==173 / calcsize/__doc__/__len__()==66 / pack_into/__doc__/__len__()==274 / unpack_from/__doc__/__len__()==188 — unpack docstring is 173 chars; calcsize docstring is 66 chars; pack_into docstring is 274 chars; unpack_from docstring is 188 chars; struct_extra59 anchors pack.__doc__.__len__()==176; this table anchors the remaining four module-level function doc lengths; first __doc__.__len__ anchor for unpack/calcsize/pack_into/unpack_from"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra79

  columns: [id, function, args, expected]
  rows:
    - [unpack_doc_len_173,      unpack.__doc__.__len__,      [], 173]
    - [calcsize_doc_len_66,     calcsize.__doc__.__len__,    [], 66]
    - [pack_into_doc_len_274,   pack_into.__doc__.__len__,   [], 274]
    - [unpack_from_doc_len_188, unpack_from.__doc__.__len__, [], 188]

# ---------------------------------------------------------------------------
# struct.calcsize/__qualname__/__len__() / iter_unpack/__qualname__/__len__()
# struct.error/__qualname__/__len__() / Struct/__qualname__/__len__()
#
# Wave 250 theme: error/Struct/calcsize/iter_unpack qualname string lengths.
#
# calcsize.__qualname__.__len__() == 8 ('calcsize' is 8 chars).
# iter_unpack.__qualname__.__len__() == 11 ('iter_unpack' is 11 chars).
# error.__qualname__.__len__() == 5 ('error' is 5 chars).
# Struct.__qualname__.__len__() == 6 ('Struct' is 6 chars).
# No prior struct spec checks __qualname__.__len__() for error or Struct directly.
# struct_extra74 covers calcsize and iter_unpack __qualname__.__len__().
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra79.qualname_lengths_group2:
  description: "struct.calcsize/__qualname__/__len__()==8 / iter_unpack/__qualname__/__len__()==11 / error/__qualname__/__len__()==5 / Struct/__qualname__/__len__()==6 — 'calcsize' is 8 chars; 'iter_unpack' is 11 chars; 'error' is 5 chars; 'Struct' is 6 chars; struct_extra74 covers calcsize/iter_unpack __qualname__.__len__(); this table adds error and Struct alongside cross-checks; first __qualname__.__len__ anchor for struct.error and struct.Struct"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra79

  columns: [id, function, args, expected]
  rows:
    - [calcsize_qualname_len_8,    calcsize.__qualname__.__len__,    [], 8]
    - [iter_unpack_qualname_len_11, iter_unpack.__qualname__.__len__, [], 11]
    - [error_qualname_len_5,       error.__qualname__.__len__,       [], 5]
    - [struct_qualname_len_6,      Struct.__qualname__.__len__,      [], 6]

# ---------------------------------------------------------------------------
# struct.pack_into.__qualname__.__eq__('pack_into') — standalone
#
# pack_into.__qualname__ is 'pack_into'. No prior struct spec checks
# pack_into.__qualname__.__eq__. First __qualname__.__eq__ standalone for
# struct.pack_into. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra79.pack_into_qualname_eq:
  description: "struct.pack_into.__qualname__.__eq__('pack_into') == True — pack_into's qualified name equals its function name 'pack_into'; struct_extra74 anchors __qualname__.__len__(); this standalone anchors __qualname__.__eq__; first __qualname__.__eq__ standalone for struct.pack_into"
  category: class_attrs
  kind: python_call_eq
  function: pack_into.__qualname__.__eq__
  args: ["pack_into"]
  expected: true

# ---------------------------------------------------------------------------
# struct.calcsize.__qualname__.__eq__('calcsize') — standalone
#
# calcsize.__qualname__ is 'calcsize'. No prior struct spec checks
# calcsize.__qualname__.__eq__. First __qualname__.__eq__ standalone for
# struct.calcsize. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra79.calcsize_qualname_eq:
  description: "struct.calcsize.__qualname__.__eq__('calcsize') == True — calcsize's qualified name equals its function name 'calcsize'; no prior struct spec checks calcsize.__qualname__.__eq__; first __qualname__.__eq__ standalone for struct.calcsize"
  category: class_attrs
  kind: python_call_eq
  function: calcsize.__qualname__.__eq__
  args: ["calcsize"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__qualname__.__eq__('error') — standalone
#
# error.__qualname__ is 'error'. No prior struct spec checks
# error.__qualname__.__eq__. First __qualname__.__eq__ standalone for
# struct.error. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra79.error_qualname_eq:
  description: "struct.error.__qualname__.__eq__('error') == True — the struct.error exception class has __qualname__ equal to 'error'; no prior struct spec checks error.__qualname__.__eq__; first __qualname__.__eq__ standalone for struct.error"
  category: class_attrs
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["error"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__qualname__.__eq__('Struct') — standalone
#
# Struct.__qualname__ is 'Struct'. No prior struct spec checks
# Struct.__qualname__.__eq__. First __qualname__.__eq__ standalone for
# struct.Struct. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra79.struct_qualname_eq:
  description: "struct.Struct.__qualname__.__eq__('Struct') == True — the Struct class has __qualname__ equal to 'Struct'; no prior struct spec checks Struct.__qualname__.__eq__; first __qualname__.__eq__ standalone for struct.Struct"
  category: class_attrs
  kind: python_call_eq
  function: Struct.__qualname__.__eq__
  args: ["Struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.unpack.__doc__.__len__() — standalone
#
# unpack.__doc__.__len__() == 173. No prior struct spec checks
# unpack.__doc__.__len__(). struct_extra59 covers pack.__doc__.__len__()==176.
# First __doc__.__len__ standalone for struct.unpack.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
