invariant struct_extra79.unpack_doc_len_173:
  description: "struct.unpack.__doc__.__len__() == 173 — unpack's docstring is 173 characters; struct_extra59 anchors pack.__doc__.__len__()==176; this standalone anchors unpack; first __doc__.__len__ standalone for struct.unpack"
  category: class_attrs
  kind: python_call_eq
  function: unpack.__doc__.__len__
