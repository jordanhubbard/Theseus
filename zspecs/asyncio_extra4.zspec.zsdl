spec: asyncio_extra4
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks and Coroutines"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
    - "CPython source: Lib/asyncio/events.py"
    - "CPython source: Lib/asyncio/runners.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "Extends asyncio.zspec.zsdl, asyncio_events.zspec.zsdl, asyncio_extra.zspec.zsdl, asyncio_extra2.zspec.zsdl, asyncio_extra3.zspec.zsdl."
    - "asyncio_extra3.zspec.zsdl covers: __qualname__ for Task/Future/Queue/Lock/Event/Semaphore/Condition; gather/sleep/create_task __qualname__; wait/__name__; shield/__name__; wait_for/__name__; PriorityQueue/LifoQueue __qualname__; Barrier/TaskGroup/Runner name+module (Python 3.11+)."
    - "This spec adds: __module__ checks for get_event_loop/get_running_loop/new_event_loop (asyncio.events), run (asyncio.runners), sleep/gather/wait/create_task/ensure_future (asyncio.tasks), Task (asyncio.tasks), Future (asyncio.futures), TimeoutError/CancelledError (asyncio), Queue (asyncio.queues), Lock (asyncio.locks)."
    - "asyncio.get_event_loop.__module__ == 'asyncio.events' — defined in Lib/asyncio/events.py."
    - "asyncio.get_running_loop.__module__ == 'asyncio.events' — defined in Lib/asyncio/events.py."
    - "asyncio.new_event_loop.__module__ == 'asyncio.events' — defined in Lib/asyncio/events.py."
    - "asyncio.run.__module__ == 'asyncio.runners' — defined in Lib/asyncio/runners.py."
    - "asyncio.sleep.__module__ == 'asyncio.tasks' — coroutine defined in Lib/asyncio/tasks.py."
    - "asyncio.gather.__module__ == 'asyncio.tasks' — coroutine defined in Lib/asyncio/tasks.py."
    - "asyncio.wait.__module__ == 'asyncio.tasks' — coroutine defined in Lib/asyncio/tasks.py."
    - "asyncio.create_task.__module__ == 'asyncio.tasks' — defined in Lib/asyncio/tasks.py."
    - "asyncio.ensure_future.__module__ == 'asyncio.tasks' — defined in Lib/asyncio/tasks.py."
    - "asyncio.Task.__module__ == 'asyncio.tasks' — Task class defined in Lib/asyncio/tasks.py."
    - "asyncio.Future.__module__ == 'asyncio.futures' — Future class defined in Lib/asyncio/futures.py."
    - "asyncio.TimeoutError.__module__ == 'asyncio' — re-exported at package level."
    - "asyncio.CancelledError.__module__ == 'asyncio' — re-exported at package level."
    - "asyncio.Queue.__module__ == 'asyncio.queues' — Queue class defined in Lib/asyncio/queues.py."
    - "asyncio.Lock.__module__ == 'asyncio.locks' — Lock class defined in Lib/asyncio/locks.py."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ for event loop functions
#
# get_event_loop, get_running_loop, and new_event_loop are defined in
# asyncio/events.py. They are re-exported at the asyncio package level but
# their __module__ reflects their origin file.
# ---------------------------------------------------------------------------

invariant asyncio_extra4.get_event_loop.module:
  description: "asyncio.get_event_loop.__module__ == 'asyncio.events'"
  category: function_modules
  kind: python_call_eq
  function: get_event_loop.__module__.__eq__
  args: ["asyncio.events"]
  expected: true

invariant asyncio_extra4.get_running_loop.module:
  description: "asyncio.get_running_loop.__module__ == 'asyncio.events'"
  category: function_modules
  kind: python_call_eq
  function: get_running_loop.__module__.__eq__
  args: ["asyncio.events"]
  expected: true

invariant asyncio_extra4.new_event_loop.module:
  description: "asyncio.new_event_loop.__module__ == 'asyncio.events'"
  category: function_modules
  kind: python_call_eq
  function: new_event_loop.__module__.__eq__
  args: ["asyncio.events"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ for asyncio.run
#
# asyncio.run is defined in asyncio/runners.py (Python 3.7+).
# ---------------------------------------------------------------------------

invariant asyncio_extra4.run.module:
  description: "asyncio.run.__module__ == 'asyncio.runners'"
  category: function_modules
  kind: python_call_eq
  function: run.__module__.__eq__
  args: ["asyncio.runners"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ for task coroutine functions
#
# sleep, gather, wait, create_task, and ensure_future are all defined in
# asyncio/tasks.py and re-exported at the asyncio package level.
# ---------------------------------------------------------------------------

table asyncio_extra4.tasks_function_modules:
  description: "asyncio task functions have __module__ == 'asyncio.tasks'"
  kind: python_call_eq
  category: function_modules
  id_prefix: tasks_module

  columns: [id, function, args, expected]
  rows:
    - [sleep,         sleep.__module__.__eq__,         ["asyncio.tasks"], true]
    - [gather,        gather.__module__.__eq__,        ["asyncio.tasks"], true]
    - [wait,          wait.__module__.__eq__,          ["asyncio.tasks"], true]
    - [create_task,   create_task.__module__.__eq__,   ["asyncio.tasks"], true]
    - [ensure_future, ensure_future.__module__.__eq__, ["asyncio.tasks"], true]

# ---------------------------------------------------------------------------
# __module__ for asyncio.Task and asyncio.Future
#
# Task is defined in asyncio/tasks.py and Future in asyncio/futures.py.
# These class __module__ values differ from each other and from asyncio.locks.
# ---------------------------------------------------------------------------

invariant asyncio_extra4.Task.module:
  description: "asyncio.Task.__module__ == 'asyncio.tasks'"
  category: class_modules
  kind: python_call_eq
  function: Task.__module__.__eq__
  args: ["asyncio.tasks"]
  expected: true

invariant asyncio_extra4.Future.module:
  description: "asyncio.Future.__module__ == 'asyncio.futures'"
  category: class_modules
  kind: python_call_eq
  function: Future.__module__.__eq__
  args: ["asyncio.futures"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ for asyncio exception classes
#
# TimeoutError and CancelledError are re-exported at the asyncio package
# level. Their __module__ is 'asyncio'.
# ---------------------------------------------------------------------------

invariant asyncio_extra4.TimeoutError.module:
  description: "asyncio.TimeoutError.__module__ == 'asyncio'"
  category: class_modules
  kind: python_call_eq
  function: TimeoutError.__module__.__eq__
  args: ["asyncio"]
  expected: true

invariant asyncio_extra4.CancelledError.module:
  description: "asyncio.CancelledError.__module__ == 'asyncio'"
  category: class_modules
  kind: python_call_eq
  function: CancelledError.__module__.__eq__
  args: ["asyncio"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ for asyncio.Queue and asyncio.Lock
#
# Queue is defined in asyncio/queues.py and Lock in asyncio/locks.py.
# Both are re-exported at the asyncio package level.
# ---------------------------------------------------------------------------

invariant asyncio_extra4.Queue.module:
  description: "asyncio.Queue.__module__ == 'asyncio.queues'"
  category: class_modules
  kind: python_call_eq
  function: Queue.__module__.__eq__
  args: ["asyncio.queues"]
  expected: true

invariant asyncio_extra4.Lock.module:
  description: "asyncio.Lock.__module__ == 'asyncio.locks'"
  category: class_modules
  kind: python_call_eq
  function: Lock.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true
