spec: itertools_extra179
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools module attributes — itertools.__name__=='itertools' (len=9); itertools.__package__=='' (empty string for C extension modules — no package); itertools.__spec__.__class__.__name__=='ModuleSpec'; itertools.__doc__.__class__.__name__=='str'; itertools.__loader__.__class__.__name__ — for C extension modules this is 'ExtensionFileLoader' or similar; itertools.chain.__doc__.__class__.__name__=='str'; itertools.count.__doc__.__class__.__name__=='str'."
    - "itertools.__name__ == 'itertools' — the itertools module's __name__ attribute is 'itertools', 9 characters. Verified with Python 3.14.3."
    - "itertools.__package__ == '' — itertools is a C extension module at the top level (no package); its __package__ is the empty string ''. Verified with Python 3.14.3."
    - "itertools.__spec__.__class__.__name__ == 'ModuleSpec' — Python's import system attaches a ModuleSpec to every loaded module; itertools.__spec__ is a ModuleSpec instance. Verified with Python 3.14.3."
    - "itertools.__doc__.__class__.__name__ == 'str' — itertools has a module-level C docstring exposed as a Python str. Verified with Python 3.14.3."
    - "itertools.__loader__.__class__.__name__ — for itertools the loader is the built-in import mechanism; __loader__.__class__.__name__ is 'type' (the loader is a class object itself, as itertools is a C extension loaded by the built-in importer). Verified with Python 3.14.3."
    - "itertools.chain.__doc__.__class__.__name__ == 'str' — itertools.chain is a C extension type with a docstring accessible as a Python str. Verified with Python 3.14.3."
    - "itertools.count.__doc__.__class__.__name__ == 'str' — itertools.count is a C extension type with a docstring accessible as a Python str. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools module __name__ and __package__
#
# itertools.__name__ == 'itertools'
# itertools.__name__.__len__() == 9
# itertools.__package__ == ''
# itertools.__package__.__len__() == 0
#
# itertools.__name__ is 'itertools' (9 chars). itertools.__package__ is the
# empty string (0 chars) because itertools is a top-level C extension module
# with no package. New to extra179.
# ---------------------------------------------------------------------------

table itertools_extra179.module_name_and_package:
  description: "itertools.__name__ 'itertools' len 9; __package__ '' (empty string, C extension top-level); new to extra179"
  kind: python_call_eq
  category: identity
  id_prefix: itermodule179

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_eq,
       "__name__.__eq__",
       ["itertools"],
       true,
       "itertools.__name__.__eq__('itertools') == True — the itertools module's __name__ attribute is the string 'itertools'; str.__eq__('itertools') returns True; new to extra179"]
    - [module_name_len_9,
       "__name__.__len__",
       [],
       9,
       "itertools.__name__.__len__() == 9 — the module name 'itertools' has exactly 9 characters: i-t-e-r-t-o-o-l-s; str.__len__() returns 9; new to extra179"]
    - [module_package_empty,
       "__package__.__eq__",
       [""],
       true,
       "itertools.__package__.__eq__('') == True — itertools is a C extension module at the top level with no enclosing package; its __package__ is the empty string ''; str.__eq__('') returns True; new to extra179"]
    - [module_package_len_0,
       "__package__.__len__",
       [],
       0,
       "itertools.__package__.__len__() == 0 — the __package__ attribute is the empty string '' which has length 0; str.__len__() returns 0; new to extra179"]

# ---------------------------------------------------------------------------
# Table 2: itertools.__spec__ class name and itertools.__doc__ class name
#
# itertools.__spec__.__class__.__name__ == 'ModuleSpec'
# itertools.__doc__.__class__.__name__ == 'str'
# itertools.__doc__.__class__.__name__.__len__() == 3
#
# itertools.__spec__ is a ModuleSpec (from importlib._bootstrap) attached by
# the import machinery. itertools.__doc__ is a str (C-level docstring).
# New to extra179.
# ---------------------------------------------------------------------------

table itertools_extra179.module_spec_and_doc:
  description: "itertools.__spec__.__class__.__name__ 'ModuleSpec'; __doc__.__class__.__name__ 'str' len 3; new to extra179"
  kind: python_call_eq
  category: identity
  id_prefix: itermodule179

  columns: [id, function, args, expected, description]
  rows:
    - [module_spec_class_name,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "itertools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — Python's import system attaches a ModuleSpec instance to every successfully loaded module as its __spec__ attribute; itertools.__spec__.__class__.__name__ is 'ModuleSpec'; str.__eq__('ModuleSpec') returns True; new to extra179"]
    - [module_doc_class_str,
       "__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.__doc__.__class__.__name__.__eq__('str') == True — itertools is a C extension module with a module-level C docstring that Python exposes as a str; its __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra179"]
    - [module_doc_class_len_3,
       "__doc__.__class__.__name__.__len__",
       [],
       3,
       "itertools.__doc__.__class__.__name__.__len__() == 3 — the class name 'str' has exactly 3 characters: s-t-r; str.__len__() returns 3; new to extra179"]
    - [module_loader_class_type,
       "__loader__.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.__loader__.__class__.__name__.__eq__('type') == True — itertools is a C extension module whose __loader__ is a class object (the built-in import mechanism exposes it as a type); its __loader__.__class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra179"]

# ---------------------------------------------------------------------------
# Table 3: itertools.chain.__doc__ and itertools.count.__doc__ class names
#
# itertools.chain.__doc__.__class__.__name__ == 'str'
# itertools.count.__doc__.__class__.__name__ == 'str'
# itertools.count.__doc__.__class__.__name__.__len__() == 3
#
# Both chain and count are C extension types in itertoolsmodule.c; each has
# a C-level docstring exposed as a Python str. New to extra179.
# ---------------------------------------------------------------------------

table itertools_extra179.chain_doc_and_count_doc:
  description: "itertools.chain.__doc__.__class__.__name__ 'str'; count.__doc__.__class__.__name__ 'str'; new to extra179"
  kind: python_call_eq
  category: identity
  id_prefix: itermodule179

  columns: [id, function, args, expected, description]
  rows:
    - [chain_doc_class_str,
       "chain.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.chain.__doc__.__class__.__name__.__eq__('str') == True — itertools.chain is a C extension type in itertoolsmodule.c with a C-level docstring that Python exposes as a str; its __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra179"]
    - [count_doc_class_str,
       "count.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.count.__doc__.__class__.__name__.__eq__('str') == True — itertools.count is a C extension type in itertoolsmodule.c with a C-level docstring that Python exposes as a str; its __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra179"]
    - [count_doc_class_len_3,
       "count.__doc__.__class__.__name__.__len__",
       [],
       3,
       "itertools.count.__doc__.__class__.__name__.__len__() == 3 — the class name 'str' has exactly 3 characters: s-t-r; str.__len__() returns 3; new to extra179"]
    - [chain_doc_class_len_3,
       "chain.__doc__.__class__.__name__.__len__",
       [],
       3,
       "itertools.chain.__doc__.__class__.__name__.__len__() == 3 — the class name 'str' has exactly 3 characters: s-t-r; str.__len__() returns 3; new to extra179"]

