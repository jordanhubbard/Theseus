spec: math_extra9
version: ">=3.9"
backend: python_module(math)

docs: https://docs.python.org/3/library/math.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/math.html — Python math documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/mathmodule.c"
  notes:
    - "This spec extends math.zspec.zsdl and prior extras through math_extra8.zspec.zsdl."
    - "math_extra3 covers: sinh/cosh/tanh NOT covered (only their presence is noted); atan2(1,1) class only; erfc NOT covered; gamma(1)==1, lgamma(1)==0; fmod, remainder, modf, frexp, ldexp, log1p, expm1."
    - "math_extra8 covers: sin(0), cos(0), asin(0), acos(1), log(1), log(e), exp(0), hypot(3,4)."
    - "No prior spec covers sinh(0)==0.0, cosh(0)==1.0, tanh(0)==0.0."
    - "No prior spec covers atan2(0, 1)==0.0 as a value vector."
    - "No prior spec covers erfc(0.0)==1.0."
    - "No prior spec covers gamma(5.0)==24.0."
    - "No prior spec covers log2(1024)==10.0 or log10(100)==2.0."
    - "No prior spec covers radians(180)==pi or radians(90)==pi/2."
    - "No prior spec covers comb(5,5)==1 (n choose n)."
    - "No prior spec covers hypot(0, 5)==5.0."
    - "No prior spec covers isclose(1.0, 1.0)==True."
    - "No prior spec covers fsum([1,2,3,4])==10.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Hyperbolic functions at zero
#
# math_extra3 covers erf/gamma/lgamma/expm1/log1p. No prior spec covers
# the hyperbolic trig functions sinh/cosh/tanh, which all have exact identity
# values at zero.
# ---------------------------------------------------------------------------

invariant math_extra9.sinh.zero:
  description: "math.sinh(0) == 0.0 — sinh of zero is zero"
  category: hyperbolic
  kind: python_call_eq
  function: sinh
  args: [0]
  expected: 0.0

invariant math_extra9.cosh.zero:
  description: "math.cosh(0) == 1.0 — cosh of zero is one"
  category: hyperbolic
  kind: python_call_eq
  function: cosh
  args: [0]
  expected: 1.0

invariant math_extra9.tanh.zero:
  description: "math.tanh(0) == 0.0 — tanh of zero is zero"
  category: hyperbolic
  kind: python_call_eq
  function: tanh
  args: [0]
  expected: 0.0

# ---------------------------------------------------------------------------
# atan2 — two-argument arctangent value vector
#
# math_extra3 covers atan2(1.0, 1.0) only for __class__.__name__.
# No prior spec covers atan2(0, 1) == 0.0 as a value vector.
# ---------------------------------------------------------------------------

invariant math_extra9.atan2.zero_one:
  description: "math.atan2(0, 1) == 0.0 — atan2(0, 1) == angle of point (1,0) == 0 radians"
  category: trigonometry
  kind: python_call_eq
  function: atan2
  args: [0, 1]
  expected: 0.0

# ---------------------------------------------------------------------------
# erfc — complementary error function
#
# math_extra3 covers erf(0.0)==0.0. No prior spec covers erfc(0.0)==1.0.
# erfc(x) == 1 - erf(x), so erfc(0) == 1.0 exactly.
# ---------------------------------------------------------------------------

invariant math_extra9.erfc.zero:
  description: "math.erfc(0.0) == 1.0 — complementary error function at zero is 1"
  category: special_functions
  kind: python_call_eq
  function: erfc
  args: [0.0]
  expected: 1.0

# ---------------------------------------------------------------------------
# gamma — additional value vector
#
# math_extra3 covers gamma(1.0)==1.0. No prior spec covers gamma(5.0)==24.0.
# gamma(n) == (n-1)! for positive integers; gamma(5) == 4! == 24.
# ---------------------------------------------------------------------------

invariant math_extra9.gamma.five:
  description: "math.gamma(5.0) == 24.0 — gamma(5) == 4! == 24"
  category: special_functions
  kind: python_call_eq
  function: gamma
  args: [5.0]
  expected: 24.0

# ---------------------------------------------------------------------------
# log2 / log10 — new value vectors
#
# math.zspec and math_extra cover log2(8)==3.0 and log10(1000)==3.0.
# New here: log2(1024)==10.0 and log10(100)==2.0 (distinct inputs).
# ---------------------------------------------------------------------------

invariant math_extra9.log2.ten_twenty_four:
  description: "math.log2(1024) == 10.0 — 2^10 == 1024"
  category: logarithm
  kind: python_call_eq
  function: log2
  args: [1024]
  expected: 10.0

invariant math_extra9.log10.hundred:
  description: "math.log10(100) == 2.0 — 10^2 == 100"
  category: logarithm
  kind: python_call_eq
  function: log10
  args: [100]
  expected: 2.0

# ---------------------------------------------------------------------------
# radians — angle conversion (degrees to radians)
#
# math.zspec covers degrees(pi)==180.0 and degrees(0.0)==0.0.
# No prior spec covers radians(180.0)==pi or radians(90.0)==pi/2.
# ---------------------------------------------------------------------------

invariant math_extra9.radians.one_eighty:
  description: "math.radians(180) == math.pi — 180 degrees is pi radians"
  category: angle_conversion
  kind: python_call_eq
  function: radians
  args: [180]
  expected: 3.141592653589793

invariant math_extra9.radians.zero:
  description: "math.radians(0) == 0.0 — 0 degrees is 0 radians"
  category: angle_conversion
  kind: python_call_eq
  function: radians
  args: [0]
  expected: 0.0

# ---------------------------------------------------------------------------
# comb — n choose n == 1
#
# Prior specs cover comb(5,2), comb(5,0), comb(10,0), comb(6,3).
# No prior spec covers comb(n, n) == 1 for any n.
# ---------------------------------------------------------------------------

invariant math_extra9.comb.five_choose_five:
  description: "math.comb(5, 5) == 1 — there is exactly one way to choose all n items"
  category: combinatorics
  kind: python_call_eq
  function: comb
  args: [5, 5]
  expected: 1

# ---------------------------------------------------------------------------
# fsum — exact floating-point sum
#
# math_extra8 covers fsum.__name__. No prior spec covers fsum value vectors.
# fsum([1, 2, 3, 4]) == 10.0 (exact result).
# ---------------------------------------------------------------------------

invariant math_extra9.fsum.integer_list:
  description: "math.fsum([1, 2, 3, 4]) == 10.0 — exact sum of integers as float"
  category: arithmetic
  kind: python_call_eq
  function: fsum
  args: [[1, 2, 3, 4]]
  expected: 10.0

# ---------------------------------------------------------------------------
# isclose — approximate equality
#
# No prior spec covers isclose value vectors (only __module__ in extra7).
# isclose(1.0, 1.0) == True (identical values are close).
# ---------------------------------------------------------------------------

invariant math_extra9.isclose.identical:
  description: "math.isclose(1.0, 1.0) == True — identical values are always close"
  category: predicates
  kind: python_call_eq
  function: isclose
  args: [1.0, 1.0]
  expected: true
