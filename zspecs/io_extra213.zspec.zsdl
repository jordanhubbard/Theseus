spec: io_extra213
version: ">=3.9"
backend: python_module(_pyio)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/ — C extension implementations"
  notes:
    - "This spec covers: __code__ attributes of io class methods via the pure-Python _pyio module, since io.FileIO/StringIO/BytesIO are C extensions with no __code__ attribute."
    - "_pyio.FileIO.__init__.__code__.co_flags.__class__.__name__ == 'int' — co_flags is an integer bitmask encoding compilation flags; value 201326595 on Python 3.14.3."
    - "_pyio.open.__func__.__code__.co_flags.__class__.__name__ == 'int' — _pyio.open is a staticmethod; access __code__ via __func__; co_flags value 67108867."
    - "_pyio.FileIO.__init__.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is the required stack depth for the frame; value 6."
    - "_pyio.StringIO.__init__.__code__.co_flags.__class__.__name__ == 'int' — co_flags value 134217731."
    - "_pyio.StringIO.__init__.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize value 7."
    - "_pyio.open is a staticmethod at module level; its __code__ must be reached via _pyio.open.__func__.__code__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# _pyio.FileIO.__init__.__code__ co_flags and co_stacksize — class names
#
# _pyio.FileIO.__init__ is a Python function.
# __code__.co_flags is an integer bitmask: value 201326595 on Python 3.14.3
# __code__.co_stacksize is an integer: value 6
# Both co_flags and co_stacksize have __class__.__name__ == 'int'
# ---------------------------------------------------------------------------

table io_extra213.FileIO_init_code_attrs:
  description: "_pyio.FileIO.__init__.__code__ attribute types — co_flags and co_stacksize are both int; co_flags==201326595; co_stacksize==6; verified Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: iocoflags213

  columns: [id, function, args, expected, description]
  rows:
    - [fileio_coflags_cls,      FileIO.__init__.__code__.co_flags.__class__.__name__.__eq__,      ["int"], true, "_pyio.FileIO.__init__.__code__.co_flags.__class__.__name__ == 'int' — co_flags bitmask value 201326595; verified Python 3.14.3"]
    - [fileio_costacksize_cls,  FileIO.__init__.__code__.co_stacksize.__class__.__name__.__eq__,  ["int"], true, "_pyio.FileIO.__init__.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize value 6; verified Python 3.14.3"]
    - [fileio_coflags_not_str,  FileIO.__init__.__code__.co_flags.__class__.__name__.__eq__,      ["str"], false, "_pyio.FileIO.__init__.__code__.co_flags.__class__.__name__ != 'str' — co_flags is an integer bitmask, not a string; verified Python 3.14.3"]
    - [fileio_costacksize_not_str, FileIO.__init__.__code__.co_stacksize.__class__.__name__.__eq__, ["str"], false, "_pyio.FileIO.__init__.__code__.co_stacksize.__class__.__name__ != 'str' — co_stacksize is an integer, not a string; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# _pyio.open.__func__.__code__ co_flags and co_stacksize — class names
#
# _pyio.open is a staticmethod; __code__ is reached via __func__
# __code__.co_flags.__class__.__name__ == 'int'  (value 67108867)
# __code__.co_stacksize.__class__.__name__ == 'int'  (value 7)
# ---------------------------------------------------------------------------

table io_extra213.open_func_code_attrs:
  description: "_pyio.open.__func__.__code__ attribute types — _pyio.open is a staticmethod; co_flags and co_stacksize are int; co_flags==67108867; co_stacksize==7; verified Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: iocoflags213

  columns: [id, function, args, expected, description]
  rows:
    - [open_coflags_cls,     "open.__func__.__code__.co_flags.__class__.__name__.__eq__",     ["int"], true, "_pyio.open.__func__.__code__.co_flags.__class__.__name__ == 'int' — staticmethod; co_flags value 67108867; verified Python 3.14.3"]
    - [open_costacksize_cls, "open.__func__.__code__.co_stacksize.__class__.__name__.__eq__", ["int"], true, "_pyio.open.__func__.__code__.co_stacksize.__class__.__name__ == 'int' — staticmethod; co_stacksize value 7; verified Python 3.14.3"]
    - [open_coflags_not_float, "open.__func__.__code__.co_flags.__class__.__name__.__eq__",  ["float"], false, "_pyio.open.__func__.__code__.co_flags.__class__.__name__ != 'float' — co_flags is int not float; verified Python 3.14.3"]
    - [open_costacksize_not_none, "open.__func__.__code__.co_stacksize.__class__.__name__.__eq__", ["NoneType"], false, "_pyio.open.__func__.__code__.co_stacksize.__class__.__name__ != 'NoneType' — co_stacksize is int; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# _pyio.StringIO.__init__.__code__ co_flags and co_stacksize — class names
#
