# ---------------------------------------------------------------------------

table io_extra213.StringIO_init_code_attrs:
  description: "_pyio.StringIO.__init__.__code__ attribute types — co_flags and co_stacksize are both int; co_flags==134217731; co_stacksize==7; verified Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: iocoflags213

  columns: [id, function, args, expected, description]
  rows:
    - [stringio_coflags_cls,     StringIO.__init__.__code__.co_flags.__class__.__name__.__eq__,     ["int"], true, "_pyio.StringIO.__init__.__code__.co_flags.__class__.__name__ == 'int' — co_flags value 134217731; verified Python 3.14.3"]
    - [stringio_costacksize_cls, StringIO.__init__.__code__.co_stacksize.__class__.__name__.__eq__, ["int"], true, "_pyio.StringIO.__init__.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize value 7; verified Python 3.14.3"]
    - [stringio_coflags_not_str, StringIO.__init__.__code__.co_flags.__class__.__name__.__eq__,     ["str"], false, "_pyio.StringIO.__init__.__code__.co_flags.__class__.__name__ != 'str' — co_flags is int bitmask; verified Python 3.14.3"]
    - [stringio_costacksize_not_float, StringIO.__init__.__code__.co_stacksize.__class__.__name__.__eq__, ["float"], false, "_pyio.StringIO.__init__.__code__.co_stacksize.__class__.__name__ != 'float' — co_stacksize is int; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — io_extra213
# ---------------------------------------------------------------------------

invariant io_extra213.FileIO_init_co_flags_class_name:
  description: "_pyio.FileIO.__init__.__code__.co_flags.__class__.__name__ == 'int' — co_flags is a CPython integer bitmask encoding function compilation flags; value 201326595 on Python 3.14.3; io.FileIO is a C extension without __code__ but _pyio.FileIO provides the inspectable Python implementation; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: FileIO.__init__.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant io_extra213.FileIO_init_co_stacksize_class_name:
  description: "_pyio.FileIO.__init__.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is the maximum stack depth for the code object's frame; value 6 on Python 3.14.3; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: FileIO.__init__.__code__.co_stacksize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant io_extra213.open_func_co_flags_class_name:
  description: "_pyio.open.__func__.__code__.co_flags.__class__.__name__ == 'int' — _pyio.open is a staticmethod; co_flags is accessed via __func__.__code__; value 67108867 on Python 3.14.3; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "open.__func__.__code__.co_flags.__class__.__name__.__eq__"
  args: ["int"]
  expected: true

invariant io_extra213.open_func_co_stacksize_class_name:
  description: "_pyio.open.__func__.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize for the _pyio.open staticmethod; value 7 on Python 3.14.3; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "open.__func__.__code__.co_stacksize.__class__.__name__.__eq__"
  args: ["int"]
  expected: true

invariant io_extra213.StringIO_init_co_flags_class_name:
  description: "_pyio.StringIO.__init__.__code__.co_flags.__class__.__name__ == 'int' — co_flags bitmask value 134217731 on Python 3.14.3; StringIO is the pure-Python string-based in-memory stream; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: StringIO.__init__.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant io_extra213.StringIO_init_co_stacksize_class_name:
  description: "_pyio.StringIO.__init__.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize value 7 on Python 3.14.3; same stack depth as _pyio.open; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: StringIO.__init__.__code__.co_stacksize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant io_extra213.FileIO_coflags_not_str:
  description: "_pyio.FileIO.__init__.__code__.co_flags.__class__.__name__ != 'str' — co_flags is always an integer bitmask in CPython; it encodes flags like CO_OPTIMIZED, CO_NEWLOCALS, CO_VARARGS etc.; never a string; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: FileIO.__init__.__code__.co_flags.__class__.__name__.__eq__
  args: ["str"]
  expected: false

invariant io_extra213.StringIO_costacksize_not_str:
  description: "_pyio.StringIO.__init__.__code__.co_stacksize.__class__.__name__ != 'str' — co_stacksize is always an integer in CPython representing the number of stack entries needed; never a string; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: StringIO.__init__.__code__.co_stacksize.__class__.__name__.__eq__
  args: ["str"]
  expected: false
