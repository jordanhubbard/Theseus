    "return_codes": [
      {
        "name": "Z_OK",
        "value": 0,
        "description": "Operation completed successfully"
      },
      {
        "name": "Z_STREAM_END",
        "value": 1,
        "description": "End of compressed data reached"
      },
      {
        "name": "Z_NEED_DICT",
        "value": 2,
        "description": "A preset dictionary is needed"
      },
      {
        "name": "Z_ERRNO",
        "value": -1,
        "description": "File operation error; check errno"
      },
      {
        "name": "Z_STREAM_ERROR",
        "value": -2,
        "description": "Invalid stream state or parameter"
      },
      {
        "name": "Z_DATA_ERROR",
        "value": -3,
        "description": "Invalid or incomplete compressed data"
      },
      {
        "name": "Z_MEM_ERROR",
        "value": -4,
        "description": "Insufficient memory"
      },
      {
        "name": "Z_BUF_ERROR",
        "value": -5,
        "description": "Output buffer was full"
      },
      {
        "name": "Z_VERSION_ERROR",
        "value": -6,
        "description": "zlib library version mismatch"
      }
    ]
  },
