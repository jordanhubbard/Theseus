spec: multiprocessing_extra751
version: ">=3.9"
backend: python_module(multiprocessing)
docs: Cover multiprocessing.Value, Array, and process management symbol identity via __qualname__ and __module__ attributes
error_model: python_exceptions
provenance:
  derived_from:
    - multiprocessing standard library documentation
    - CPython source multiprocessing/sharedctypes.py
    - CPython source multiprocessing/context.py
  not_derived_from:
    - multiprocessing.pool or Pool-specific symbols
    - pathos or other multiprocessing wrappers
  notes:
    - Value and Array are defined in sharedctypes but re-exported via context
    - Queue.__qualname__ varies by start method so __module__ is tested instead
    - parent_process was introduced in Python 3.8 and is available in >=3.9
  created_at: "2026-04-12"

table multiprocessing_extra751.name:
  description: Identity checks for multiprocessing shared memory types and process management functions
  kind: python_call_eq
  category: module_identity
  id_prefix: mp751xx
  columns: [id, function, args, expected]
  rows:
    - [mp751xx001, multiprocessing.Value.__qualname__.__eq__, ["Value"], true]
    - [mp751xx002, multiprocessing.Value.__module__.__eq__, ["multiprocessing.sharedctypes"], true]
    - [mp751xx003, multiprocessing.Array.__qualname__.__eq__, ["Array"], true]
    - [mp751xx004, multiprocessing.Array.__module__.__eq__, ["multiprocessing.sharedctypes"], true]
    - [mp751xx005, multiprocessing.Queue.__module__.__eq__, ["multiprocessing.context"], true]
    - [mp751xx006, multiprocessing.Pipe.__qualname__.__eq__, ["Pipe"], true]
    - [mp751xx007, multiprocessing.Pipe.__module__.__eq__, ["multiprocessing.context"], true]
    - [mp751xx008, multiprocessing.cpu_count.__qualname__.__eq__, ["cpu_count"], true]
    - [mp751xx009, multiprocessing.cpu_count.__module__.__eq__, ["multiprocessing.context"], true]
    - [mp751xx010, multiprocessing.current_process.__qualname__.__eq__, ["current_process"], true]
    - [mp751xx011, multiprocessing.active_children.__qualname__.__eq__, ["active_children"], true]
    - [mp751xx012, multiprocessing.parent_process.__qualname__.__eq__, ["parent_process"], true]
