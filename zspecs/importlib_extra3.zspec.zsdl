spec: importlib_extra3
version: ">=3.9"
backend: python_module(importlib)

docs: https://docs.python.org/3/library/importlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/importlib.html — Python importlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/importlib/__init__.py"
    - "CPython source: Lib/importlib/_bootstrap.py"
  notes:
    - "This spec extends prior importlib specs."
    - "Focus: __module__ and __name__ for importlib functions and classes not yet covered."
    - "importlib.import_module.__name__ == 'import_module'."
    - "importlib.reload.__name__ == 'reload'."
    - "importlib.invalidate_caches.__name__ == 'invalidate_caches'."
    - "importlib.find_loader.__name__ == 'find_loader' (deprecated in 3.12)."
    - "importlib.util.find_spec.__name__ == 'find_spec'."
    - "importlib.util.module_from_spec.__name__ == 'module_from_spec'."
    - "importlib.util.spec_from_file_location.__name__ == 'spec_from_file_location'."
    - "importlib.abc.Loader.__name__ == 'Loader'."
    - "importlib.abc.Finder.__name__ == 'Finder'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table importlib_extra3.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [import_module,      import_module.__name__.__eq__,      ["import_module"],      true]
    - [reload,             reload.__name__.__eq__,             ["reload"],             true]
    - [invalidate_caches,  invalidate_caches.__name__.__eq__,  ["invalidate_caches"],  true]

table importlib_extra3.function_modules:
  kind: python_call_eq
  category: module
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [import_module,     import_module.__module__.__eq__,     ["importlib"], true]
    - [reload,            reload.__module__.__eq__,            ["importlib"], true]
    - [invalidate_caches, invalidate_caches.__module__.__eq__, ["importlib"], true]

invariant importlib_extra3.import_module.os:
  description: "importlib.import_module('os').__name__ == 'os'"
  category: import_module
  kind: python_call_eq
  function: import_module
  args: ["os"]
  method: __name__
  expected: "os"

invariant importlib_extra3.import_module.json:
  description: "importlib.import_module('json').__name__ == 'json'"
  category: import_module
  kind: python_call_eq
  function: import_module
  args: ["json"]
  method: __name__
  expected: "json"

invariant importlib_extra3.import_module.class_name:
  description: "importlib.import_module('os').__class__.__name__ == 'module'"
  category: import_module
  kind: python_call_eq
  function: import_module
  args: ["os"]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["module"]
  expected: true

invariant importlib_extra3.import_module.sys_path:
  description: "importlib.import_module('sys').__name__ == 'sys'"
  category: import_module
  kind: python_call_eq
  function: import_module
  args: ["sys"]
  method: __name__
  expected: "sys"

invariant importlib_extra3.import_module.math:
  description: "importlib.import_module('math').__name__ == 'math'"
  category: import_module
  kind: python_call_eq
  function: import_module
  args: ["math"]
  method: __name__
  expected: "math"

invariant importlib_extra3.import_module.returns_module:
  description: "type(importlib.import_module('re')).__name__ == 'module'"
  category: import_module
  kind: python_call_eq
  function: import_module
  args: ["re"]
  method: __spec__.__class__
  method_chain: __name__.__eq__
  method_chain_args: ["ModuleSpec"]
  expected: true

invariant importlib_extra3.reload.name:
  description: "importlib.reload.__name__ == 'reload'"
  category: reload
  kind: python_call_eq
  function: reload.__name__.__eq__
  args: ["reload"]
  expected: true
