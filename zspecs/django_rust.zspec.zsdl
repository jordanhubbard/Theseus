spec: django_rust
version: ">=3.9"
backend: rust_module(django_rust)

docs: https://docs.djangoproject.com/en/5.0/ref/

provenance:
  derived_from:
    - "https://docs.djangoproject.com/en/5.0/ref/ — Django reference"
  not_derived_from:
    - "django source: django/__init__.py"
  notes:
    - "Django is a high-level Python web framework."
    - "django.VERSION is a tuple like (5, 1, 7, 'final', 0)."
    - "django.VERSION[0] >= 4 — major version."
    - "django.utils.text.slugify('Hello World') == 'hello-world'."
    - "django.utils.text.slugify('foo bar baz') == 'foo-bar-baz'."
    - "django.utils.text.truncate_words('a b c', 2) — not available in Django 4+."
    - "django.utils.text.capfirst('hello') == 'Hello'."
    - "Expose django_slugify(text) -> str: django.utils.text.slugify(text)."
    - "Expose django_capfirst(text) -> str: django.utils.text.capfirst(text)."
    - "Expose django_version_major() -> int: django.VERSION[0]."
    - "All test vectors verified against django 5.1.7."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# django_slugify — URL slug from text
table django_rust.text.slugify:
  kind: python_call_eq
  category: slugify
  id_prefix: dj_slug
  function: django_slugify

  columns: [id, args, expected]
  rows:
    - [hello_world, ["Hello World"],   "hello-world"]
    - [three_words, ["foo bar baz"],   "foo-bar-baz"]
    - [mixed_case,  ["Django RULES"],  "django-rules"]

# django_capfirst — capitalize first letter
table django_rust.text.capfirst:
  kind: python_call_eq
  category: capfirst
  id_prefix: dj_cf
  function: django_capfirst

  columns: [id, args, expected]
  rows:
    - [lower, ["hello"], "Hello"]
    - [mixed, ["world"], "World"]

# django_version_major — major version >= 4
invariant django_rust.version.major_ge_4:
  description: "Django major version >= 4"
  category: version
  kind: python_call_eq
  function: django_version_major
  args: []
  expected: 5

