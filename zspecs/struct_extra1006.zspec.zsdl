spec: struct_extra1006
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __doc__.__class__.__name__ == 'str' for struct pack/unpack functions, Struct class, and error exception"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra1006.pack_unpack_docs:
  description: "struct pack and unpack function __doc__ class name checks"
  kind: python_call_eq
  category: pack_unpack_docs
  id_prefix: st1006pu
  columns: [id, function, args, expected]
  rows:
    - [st1006pu001, struct.pack.__doc__.__class__.__name__.__eq__,        ["str"], true]
    - [st1006pu002, struct.unpack.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [st1006pu003, struct.pack_into.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [st1006pu004, struct.unpack_from.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st1006pu005, struct.iter_unpack.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st1006pu006, struct.calcsize.__doc__.__class__.__name__.__eq__,    ["str"], true]

table struct_extra1006.struct_class_docs:
  description: "struct.Struct class and method __doc__ class name checks"
  kind: python_call_eq
  category: struct_class_docs
  id_prefix: st1006sc
  columns: [id, function, args, expected]
  rows:
    - [st1006sc001, struct.Struct.__doc__.__class__.__name__.__eq__,             ["str"], true]
    - [st1006sc002, struct.Struct.pack.__doc__.__class__.__name__.__eq__,        ["str"], true]
    - [st1006sc003, struct.Struct.unpack.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [st1006sc004, struct.Struct.pack_into.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [st1006sc005, struct.Struct.unpack_from.__doc__.__class__.__name__.__eq__, ["str"], true]

table struct_extra1006.error_and_module_docs:
  description: "struct.error exception and module attribute class name checks"
  kind: python_call_eq
  category: error_and_module_docs
  id_prefix: st1006em
  columns: [id, function, args, expected]
  rows:
    - [st1006em001, struct.error.__doc__.__class__.__name__.__eq__,  ["str"],  true]
    - [st1006em002, struct.__doc__.__class__.__name__.__eq__,        ["str"],  true]
    - [st1006em003, struct.__name__.__class__.__name__.__eq__,       ["str"],  true]
    - [st1006em004, struct.error.__name__.__class__.__name__.__eq__, ["str"],  true]
    - [st1006em005, struct.error.__module__.__class__.__name__.__eq__, ["str"], true]
