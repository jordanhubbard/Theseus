spec: contextlib_extra3
version: ">=3.10"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html — Python contextlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
  notes:
    - "Extends contextlib.zspec.zsdl, contextlib_extra.zspec.zsdl, contextlib_extra2.zspec.zsdl, contextlib_suppress.zspec.zsdl."
    - "contextlib.zspec.zsdl covers __name__ for: contextmanager, suppress, ExitStack, closing, redirect_stdout, redirect_stderr, nullcontext, AsyncExitStack, AbstractContextManager, asynccontextmanager."
    - "contextlib_extra.zspec.zsdl covers __module__ for contextmanager/asynccontextmanager/closing/nullcontext; aclosing name/module; is_function/is_type checks."
    - "contextlib_extra2.zspec.zsdl covers a consolidated __name__ table for 10 symbols and ABCMeta metaclass checks."
    - "This spec covers __qualname__ for AsyncExitStack, asynccontextmanager, aclosing, AbstractAsyncContextManager, nullcontext; AsyncContextDecorator name/module; ExitStack __qualname__; chained qualname checks."
    - "contextlib.AsyncExitStack.__name__ == 'AsyncExitStack' and __module__ == 'contextlib' (covered elsewhere); __qualname__ == 'AsyncExitStack'."
    - "contextlib.asynccontextmanager.__qualname__ == 'asynccontextmanager'."
    - "contextlib.aclosing.__qualname__ == 'aclosing'."
    - "contextlib.AbstractAsyncContextManager.__qualname__ == 'AbstractAsyncContextManager'."
    - "contextlib.nullcontext.__qualname__ == 'nullcontext'."
    - "contextlib.AsyncContextDecorator.__name__ == 'AsyncContextDecorator' and __module__ == 'contextlib'."
    - "contextlib.ExitStack.__qualname__ == 'ExitStack'."
    - "contextlib.suppress.__qualname__ == 'suppress'."
    - "contextlib.closing.__qualname__ == 'closing'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# AsyncExitStack — __qualname__ check
#
# contextlib_extra and contextlib_extra2 verify __name__ and __module__.
# This spec adds __qualname__ which equals __name__ for top-level classes.
# ---------------------------------------------------------------------------

invariant contextlib_extra3.AsyncExitStack.qualname:
  description: "contextlib.AsyncExitStack.__qualname__ == 'AsyncExitStack'"
  category: qualnames
  kind: python_call_eq
  function: AsyncExitStack.__qualname__.__eq__
  args: ["AsyncExitStack"]
  expected: true

# ---------------------------------------------------------------------------
# asynccontextmanager — __qualname__ check
# ---------------------------------------------------------------------------

invariant contextlib_extra3.asynccontextmanager.qualname:
  description: "contextlib.asynccontextmanager.__qualname__ == 'asynccontextmanager'"
  category: qualnames
  kind: python_call_eq
  function: asynccontextmanager.__qualname__.__eq__
  args: ["asynccontextmanager"]
  expected: true

# ---------------------------------------------------------------------------
# aclosing — __qualname__ check (Python 3.10+)
# ---------------------------------------------------------------------------

invariant contextlib_extra3.aclosing.qualname:
  description: "contextlib.aclosing.__qualname__ == 'aclosing'"
  category: qualnames
  kind: python_call_eq
  function: aclosing.__qualname__.__eq__
  args: ["aclosing"]
  expected: true

# ---------------------------------------------------------------------------
# AbstractAsyncContextManager — __qualname__ check
# ---------------------------------------------------------------------------

invariant contextlib_extra3.AbstractAsyncContextManager.qualname:
  description: "contextlib.AbstractAsyncContextManager.__qualname__ == 'AbstractAsyncContextManager'"
  category: qualnames
  kind: python_call_eq
  function: AbstractAsyncContextManager.__qualname__.__eq__
  args: ["AbstractAsyncContextManager"]
  expected: true

# ---------------------------------------------------------------------------
# nullcontext — __qualname__ check
# ---------------------------------------------------------------------------

invariant contextlib_extra3.nullcontext.qualname:
  description: "contextlib.nullcontext.__qualname__ == 'nullcontext'"
  category: qualnames
  kind: python_call_eq
  function: nullcontext.__qualname__.__eq__
  args: ["nullcontext"]
  expected: true

# ---------------------------------------------------------------------------
# AsyncContextDecorator — name and module
#
# contextlib.AsyncContextDecorator is the async counterpart of
# contextlib.ContextDecorator. It allows async context managers to also
# act as decorators for async functions. Available since Python 3.10.
# ---------------------------------------------------------------------------

invariant contextlib_extra3.AsyncContextDecorator.name:
  description: "contextlib.AsyncContextDecorator.__name__ == 'AsyncContextDecorator'"
  category: async_context_decorator
  kind: python_call_eq
  function: AsyncContextDecorator.__name__.__eq__
  args: ["AsyncContextDecorator"]
  expected: true

invariant contextlib_extra3.AsyncContextDecorator.module:
  description: "contextlib.AsyncContextDecorator.__module__ == 'contextlib'"
  category: async_context_decorator
  kind: python_call_eq
  function: AsyncContextDecorator.__module__.__eq__
  args: ["contextlib"]
  expected: true

invariant contextlib_extra3.AsyncContextDecorator.qualname:
  description: "contextlib.AsyncContextDecorator.__qualname__ == 'AsyncContextDecorator'"
  category: async_context_decorator
  kind: python_call_eq
  function: AsyncContextDecorator.__qualname__.__eq__
  args: ["AsyncContextDecorator"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ table for remaining core contextlib symbols
#
# ExitStack, suppress, closing have __qualname__ == __name__ since they are
# top-level class definitions. AbstractContextManager likewise.
# ---------------------------------------------------------------------------

table contextlib_extra3.core_qualnames:
  description: "Core contextlib symbols have correct __qualname__ (top-level definitions)"
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [ExitStack,                ExitStack.__qualname__.__eq__,                ["ExitStack"],                true]
    - [suppress,                 suppress.__qualname__.__eq__,                 ["suppress"],                 true]
    - [closing,                  closing.__qualname__.__eq__,                  ["closing"],                  true]
    - [contextmanager,           contextmanager.__qualname__.__eq__,           ["contextmanager"],           true]
    - [AbstractContextManager,   AbstractContextManager.__qualname__.__eq__,   ["AbstractContextManager"],   true]
    - [redirect_stdout,          redirect_stdout.__qualname__.__eq__,          ["redirect_stdout"],          true]
    - [redirect_stderr,          redirect_stderr.__qualname__.__eq__,          ["redirect_stderr"],          true]
