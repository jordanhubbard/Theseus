spec: asyncio_extra2731
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/asyncio.html"
    - "https://docs.python.org/3/library/asyncio-task.html"
    - "https://docs.python.org/3/library/asyncio-sync.html"
    - "https://docs.python.org/3/library/asyncio-queue.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 629 (_extra2731): __trunc__, __floor__, __ceil__ dict-presence checks (rounding/truncation operators)."
    - "asyncio types (Queue, Task, Future, Lock, Event, Semaphore, Condition, Barrier) are concurrency primitives, not numeric types."
    - "None of these types define truncation, floor, or ceiling rounding protocols in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __trunc__ dict-presence checks
#
# Wave 629 theme: asyncio concurrency types do not implement the truncation
# operator. __trunc__ does not appear in any of these classes' own __dict__.
# ---------------------------------------------------------------------------

table asyncio_extra2731.trunc_protocol:
  description: "asyncio types __trunc__ dict-presence checks — none define truncation in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2731

  columns: [id, function, args, expected]
  rows:
    - ["as2731001", "asyncio.Queue.__dict__.__contains__",     ["__trunc__"], false]
    - ["as2731002", "asyncio.Task.__dict__.__contains__",      ["__trunc__"], false]
    - ["as2731003", "asyncio.Future.__dict__.__contains__",    ["__trunc__"], false]
    - ["as2731004", "asyncio.Lock.__dict__.__contains__",      ["__trunc__"], false]
    - ["as2731005", "asyncio.Event.__dict__.__contains__",     ["__trunc__"], false]
    - ["as2731006", "asyncio.Semaphore.__dict__.__contains__", ["__trunc__"], false]
    - ["as2731007", "asyncio.Condition.__dict__.__contains__", ["__trunc__"], false]
    - ["as2731008", "asyncio.Barrier.__dict__.__contains__",   ["__trunc__"], false]

