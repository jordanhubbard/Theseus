# ---------------------------------------------------------------------------
# Table 4: combined __trunc__/__floor__/__ceil__ checks for Task, Future, and
#          Barrier
#
# Wave 629 theme: extended cross-operator coverage for asyncio coroutine and
# synchronization types. Task wraps a coroutine; Future represents an async
# result; Barrier coordinates a group of coroutines. None define any
# rounding/truncation protocol in their own __dict__.
# ---------------------------------------------------------------------------

table asyncio_extra2731.task_future_barrier_rounding:
  description: "asyncio.Task, Future, Barrier combined __trunc__/__floor__/__ceil__ dict-presence checks — coroutine and coordination types define no rounding/truncation"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2731

  columns: [id, function, args, expected]
  rows:
    - ["as2731025", "asyncio.Task.__dict__.__contains__",    ["__trunc__"], false]
    - ["as2731026", "asyncio.Task.__dict__.__contains__",    ["__floor__"], false]
    - ["as2731027", "asyncio.Task.__dict__.__contains__",    ["__ceil__"],  false]
    - ["as2731028", "asyncio.Future.__dict__.__contains__",  ["__trunc__"], false]
    - ["as2731029", "asyncio.Future.__dict__.__contains__",  ["__floor__"], false]
    - ["as2731030", "asyncio.Future.__dict__.__contains__",  ["__ceil__"],  false]
    - ["as2731031", "asyncio.Barrier.__dict__.__contains__", ["__trunc__"], false]
    - ["as2731032", "asyncio.Barrier.__dict__.__contains__", ["__floor__"], false]
    - ["as2731033", "asyncio.Barrier.__dict__.__contains__", ["__ceil__"],  false]
