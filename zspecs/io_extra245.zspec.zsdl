spec: io_extra245
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/bytesio.c"
    - "CPython source: Modules/_io/_iomodule.c"
    - "_io_extra.zspec.zsdl — covers BytesIO read/getvalue/tell/readable/seekable"
    - "io_extra244.zspec.zsdl — covers StringIO class identity and method name/qualname checks"
  notes:
    - "This spec covers: io.BytesIO class identity contracts — __name__, __module__, __qualname__, __bases__, __class__, and method name/qualname checks."
    - "io.BytesIO is the C class for in-memory binary I/O; its __module__ is '_io' (C extension), not 'io'."
    - "io.BytesIO.__name__ == 'BytesIO' — the class name is 7 characters; verified Python 3.14.3 macOS."
    - "io.BytesIO.__module__ == '_io' — defined in the C extension _io, length 3; verified Python 3.14.3 macOS."
    - "io.BytesIO.__qualname__ == 'BytesIO' — matches __name__ for a top-level class; verified Python 3.14.3 macOS."
    - "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' — the immediate base class; length 15; verified Python 3.14.3 macOS."
    - "io.BytesIO.__class__.__name__ == 'type' — BytesIO is a class object; verified Python 3.14.3 macOS."
    - "io.BytesIO.getvalue.__name__ == 'getvalue' — length 8; verified Python 3.14.3 macOS."
    - "io.BytesIO.getvalue.__qualname__ == 'BytesIO.getvalue' — length 16; verified Python 3.14.3 macOS."
    - "io.BytesIO.write.__name__ == 'write' — length 5; verified Python 3.14.3 macOS."
    - "io.BytesIO.write.__qualname__ == 'BytesIO.write' — length 13; verified Python 3.14.3 macOS."
    - "io.BytesIO.read.__name__ == 'read' — length 4; verified Python 3.14.3 macOS."
    - "io.BytesIO.read.__qualname__ == 'BytesIO.read' — length 12; verified Python 3.14.3 macOS."
    - "io.BytesIO.seek.__name__ == 'seek' — length 4; verified Python 3.14.3 macOS."
    - "io.BytesIO.seek.__qualname__ == 'BytesIO.seek' — length 12; verified Python 3.14.3 macOS."
    - "io.BytesIO.tell.__name__ == 'tell' — length 4; verified Python 3.14.3 macOS."
    - "io.BytesIO.tell.__qualname__ == 'BytesIO.tell' — length 12; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BytesIO class name and module identity contracts
# These verify the class object's identity attributes from the io module.
# io.BytesIO is re-exported from _io (C extension).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra245.BytesIO.name_eq:
  description: "io.BytesIO.__name__ == 'BytesIO' — C class name is 'BytesIO'; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: BytesIO.__name__.__eq__
  args: ["BytesIO"]
  expected: true

invariant io_extra245.BytesIO.name_len:
  description: "len(io.BytesIO.__name__) == 7 — 'BytesIO' has 7 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: BytesIO.__name__.__len__
  args: []
  expected: 7

invariant io_extra245.BytesIO.module_eq:
  description: "io.BytesIO.__module__ == '_io' — BytesIO is defined in the C extension _io, not in io.py; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: BytesIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra245.BytesIO.module_len:
  description: "len(io.BytesIO.__module__) == 3 — '_io' has 3 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: BytesIO.__module__.__len__
  args: []
  expected: 3

invariant io_extra245.BytesIO.qualname_eq:
  description: "io.BytesIO.__qualname__ == 'BytesIO' — qualname matches __name__ for a top-level class; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: BytesIO.__qualname__.__eq__
  args: ["BytesIO"]
  expected: true

invariant io_extra245.BytesIO.qualname_len:
  description: "len(io.BytesIO.__qualname__) == 7 — 'BytesIO' has 7 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: BytesIO.__qualname__.__len__
  args: []
  expected: 7

invariant io_extra245.BytesIO.class_is_type:
  description: "io.BytesIO.__class__.__name__ == 'type' — BytesIO is a class object (its metaclass is type); verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: BytesIO.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# io.BytesIO.__bases__[0].__name__ identity contract
# The immediate base class of BytesIO is _BufferedIOBase.
# Accessed via __bases__.__getitem__(0).__name__.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra245.BytesIO.base_name:
  description: "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' — immediate base class of BytesIO; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: BytesIO.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "_BufferedIOBase"

invariant io_extra245.BytesIO.base_name_len:
  description: "len(io.BytesIO.__bases__[0].__name__) == 15 — '_BufferedIOBase' has 15 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: BytesIO.__bases__.__getitem__
  args: [0]
  method: __name__
  method_chain: __len__
  expected: 15

# ---------------------------------------------------------------------------
# io.BytesIO method name identity contracts
# getvalue, write, read, seek, tell are key BytesIO methods.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra245.BytesIO.getvalue.name_eq:
  description: "io.BytesIO.getvalue.__name__ == 'getvalue' — method name is 'getvalue'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: BytesIO.getvalue.__name__.__eq__
  args: ["getvalue"]
  expected: true

invariant io_extra245.BytesIO.getvalue.qualname_eq:
  description: "io.BytesIO.getvalue.__qualname__ == 'BytesIO.getvalue' — qualname is 'BytesIO.getvalue'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: BytesIO.getvalue.__qualname__.__eq__
  args: ["BytesIO.getvalue"]
  expected: true

invariant io_extra245.BytesIO.write.name_eq:
  description: "io.BytesIO.write.__name__ == 'write' — method name is 'write'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: BytesIO.write.__name__.__eq__
  args: ["write"]
  expected: true

invariant io_extra245.BytesIO.write.qualname_eq:
  description: "io.BytesIO.write.__qualname__ == 'BytesIO.write' — qualname is 'BytesIO.write'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: BytesIO.write.__qualname__.__eq__
  args: ["BytesIO.write"]
  expected: true

invariant io_extra245.BytesIO.read.name_eq:
  description: "io.BytesIO.read.__name__ == 'read' — method name is 'read'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: BytesIO.read.__name__.__eq__
  args: ["read"]
  expected: true

invariant io_extra245.BytesIO.seek.name_eq:
  description: "io.BytesIO.seek.__name__ == 'seek' — method name is 'seek'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: BytesIO.seek.__name__.__eq__
  args: ["seek"]
  expected: true

invariant io_extra245.BytesIO.tell.name_eq:
  description: "io.BytesIO.tell.__name__ == 'tell' — method name is 'tell'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: BytesIO.tell.__name__.__eq__
  args: ["tell"]
  expected: true

# ---------------------------------------------------------------------------
# io.BytesIO method __name__ length spot-checks
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra245.BytesIO_method_name_lengths:
  description: "io.BytesIO method __name__ lengths; verified Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: iobio245

  columns: [id, function, args, expected]
  rows:
    - [getvalue_name_len, BytesIO.getvalue.__name__.__len__, [], 8]
    - [write_name_len,    BytesIO.write.__name__.__len__,    [], 5]
    - [read_name_len,     BytesIO.read.__name__.__len__,     [], 4]
    - [seek_name_len,     BytesIO.seek.__name__.__len__,     [], 4]
    - [tell_name_len,     BytesIO.tell.__name__.__len__,     [], 4]

# ---------------------------------------------------------------------------
# io.BytesIO method __qualname__ length spot-checks
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra245.BytesIO_method_qualname_lengths:
  description: "io.BytesIO method __qualname__ lengths; verified Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: iobiom245

  columns: [id, function, args, expected]
  rows:
    - [getvalue_qualname_len, BytesIO.getvalue.__qualname__.__len__, [], 16]
    - [write_qualname_len,    BytesIO.write.__qualname__.__len__,    [], 13]
    - [read_qualname_len,     BytesIO.read.__qualname__.__len__,     [], 12]
    - [seek_qualname_len,     BytesIO.seek.__qualname__.__len__,     [], 12]
    - [tell_qualname_len,     BytesIO.tell.__qualname__.__len__,     [], 12]
