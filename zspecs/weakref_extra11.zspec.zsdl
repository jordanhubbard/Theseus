spec: weakref_extra11
version: ">=3.9"
backend: python_module(weakref)

docs: https://docs.python.org/3/library/weakref.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/weakref.html — Python weakref module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_weakref.c"
    - "CPython source: Lib/weakref.py"
  notes:
    - "This spec extends weakref.zspec.zsdl through weakref_extra10.zspec.zsdl."
    - "weakref_extra10 covers __qualname__ for WeakValueDictionary/WeakSet/WeakKeyDictionary/finalize."
    - "weakref_extra8 covers mro[-1] for WeakKeyDictionary/WeakSet/finalize/WeakMethod, mro_len for WeakSet/finalize/WeakMethod, mro[1] for WeakValueDictionary/WeakKeyDictionary, getweakrefcount/getweakrefs __class__.__name__."
    - "weakref_extra7 covers mro[0] for WeakValueDictionary/WeakKeyDictionary/WeakSet, mro[-1] for WeakValueDictionary, WeakMethod.base_is_ref, proxy.__module__, ReferenceType.__qualname__/__module__, finalize.bases_len."
    - "weakref_extra2 covers WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize __bases__[0].__name__, getweakrefcount/getweakrefs __module__."
    - "NOT yet covered: ref.__bases__.__len__() == 1 — ref (C type) directly subclasses object."
    - "NOT yet covered: ref.__bases__[0].__name__ == 'object' — sole base of the ref C type."
    - "NOT yet covered: ref.__mro__.__len__() == 2 — ref MRO is [ref, object]."
    - "NOT yet covered: ref.__mro__[-1].__name__ == 'object' — last MRO entry of ref."
    - "NOT yet covered: ProxyType.__bases__.__len__() == 1 — ProxyType directly subclasses object."
    - "NOT yet covered: ProxyType.__bases__[0].__name__ == 'object' — sole base of ProxyType."
    - "NOT yet covered: CallableProxyType.__bases__.__len__() == 1."
    - "NOT yet covered: CallableProxyType.__bases__[0].__name__ == 'object'."
    - "NOT yet covered: WeakMethod.__module__.__eq__('weakref') as standalone invariant in extra11 namespace."
    - "weakref.ref.__bases__[0].__name__ == 'object' — the C-level ref type has object as its only base."
    - "weakref.ref.__mro__.__len__() == 2 — MRO is [ref, object]."
    - "weakref.ProxyType.__bases__[0].__name__ == 'object' — ProxyType is a C type with object as sole base."
    - "weakref.CallableProxyType.__bases__[0].__name__ == 'object' — likewise for callable proxy type."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# weakref.ref — base class and MRO
#
# weakref_extra2 covers __bases__[0] for WeakValueDictionary/WeakKeyDictionary/
# WeakSet/finalize. No prior spec checks __bases__[0] or __mro__ for ref itself.
# weakref.ref is a C type whose sole base is object, giving it a two-element MRO:
#   [ref, object] (len 2).
# ---------------------------------------------------------------------------

invariant weakref_extra11.ref.bases_len:
  description: "weakref.ref.__bases__.__len__() == 1 — the C-level ref type has only object as base"
  category: class_hierarchy
  kind: python_call_eq
  function: ref.__bases__.__len__
  args: []
  expected: 1

invariant weakref_extra11.ref.base_is_object:
  description: "weakref.ref.__bases__[0].__name__ == 'object' — sole base of the ref C type"
  category: class_hierarchy
  kind: python_call_eq
  function: ref.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant weakref_extra11.ref.mro_len:
  description: "weakref.ref.__mro__.__len__() == 2 — MRO is [ref, object]"
  category: mro
  kind: python_call_eq
  function: ref.__mro__.__len__
  args: []
  expected: 2

invariant weakref_extra11.ref.mro_last:
  description: "weakref.ref.__mro__[-1].__name__ == 'object' — last MRO entry is object"
  category: mro
  kind: python_call_eq
  function: ref.__mro__.__getitem__
  args: [-1]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# ProxyType — base class checks
#
# weakref_extra6 covers ProxyType.__qualname__ and ProxyType.__module__.
# weakref_extra7 covers ReferenceType.__qualname__ and ReferenceType.__module__.
# No prior spec checks __bases__ for ProxyType. ProxyType is a C type whose
# sole direct base is object.
# ---------------------------------------------------------------------------

invariant weakref_extra11.ProxyType.bases_len:
  description: "weakref.ProxyType.__bases__.__len__() == 1 — ProxyType has only object as base"
  category: class_hierarchy
  kind: python_call_eq
  function: ProxyType.__bases__.__len__
  args: []
  expected: 1

invariant weakref_extra11.ProxyType.base_is_object:
  description: "weakref.ProxyType.__bases__[0].__name__ == 'object' — sole base of ProxyType"
  category: class_hierarchy
  kind: python_call_eq
  function: ProxyType.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# CallableProxyType — base class checks
#
# weakref_extra6 covers CallableProxyType.__qualname__ and __module__.
# No prior spec checks __bases__ for CallableProxyType. As a C type, its
# sole direct base is object.
# ---------------------------------------------------------------------------

invariant weakref_extra11.CallableProxyType.bases_len:
  description: "weakref.CallableProxyType.__bases__.__len__() == 1 — CallableProxyType has only object as base"
  category: class_hierarchy
  kind: python_call_eq
  function: CallableProxyType.__bases__.__len__
  args: []
  expected: 1

invariant weakref_extra11.CallableProxyType.base_is_object:
  description: "weakref.CallableProxyType.__bases__[0].__name__ == 'object' — sole base of CallableProxyType"
  category: class_hierarchy
  kind: python_call_eq
  function: CallableProxyType.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# WeakMethod — module affiliation (extra11-namespace anchor)
#
# weakref_extra6 covers WeakMethod.__module__ == 'weakref'. This provides an
# extra11-namespace anchor for the same fact, confirming that WeakMethod is
# defined in the weakref module regardless of namespace.
# ---------------------------------------------------------------------------

invariant weakref_extra11.WeakMethod.module:
  description: "weakref.WeakMethod.__module__.__eq__('weakref') == True — extra11-namespace anchor"
  category: module
  kind: python_call_eq
  function: WeakMethod.__module__.__eq__
  args: ["weakref"]
  expected: true

# ---------------------------------------------------------------------------
# getweakrefcount and getweakrefs — module affiliation (extra11-namespace anchor)
#
# weakref_extra2 records __module__ == '_weakref' for these functions in the
# notes section. No prior spec asserts this as a standalone boolean invariant
# using the __module__.__eq__ method chain.
# ---------------------------------------------------------------------------

invariant weakref_extra11.getweakrefcount.module:
  description: "weakref.getweakrefcount.__module__.__eq__('_weakref') == True — C extension function"
  category: module
  kind: python_call_eq
  function: getweakrefcount.__module__.__eq__
  args: ["_weakref"]
  expected: true

invariant weakref_extra11.getweakrefs.module:
  description: "weakref.getweakrefs.__module__.__eq__('_weakref') == True — C extension function"
  category: module
  kind: python_call_eq
  function: getweakrefs.__module__.__eq__
  args: ["_weakref"]
  expected: true
