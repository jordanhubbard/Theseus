spec: linecache_extra11
version: ">=3.9"
backend: python_module(linecache)

docs: https://docs.python.org/3/library/linecache.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/linecache.html — Python linecache module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/linecache.py"
    - "linecache_extra10.zspec.zsdl — covers __name__ standalone invariants (getline/getlines/clearcache/checkcache/updatecache); __module__ table; cache.__class__.__name__ == 'dict'"
    - "linecache_extra9.zspec.zsdl — covers module __name__; __name__ last-character table; __qualname__ length table"
    - "linecache_extra5.zspec.zsdl — covers lazycache.__qualname__; function __class__.__name__ table"
    - "linecache_extra4.zspec.zsdl — covers __qualname__ table (getline/getlines/clearcache/checkcache/updatecache)"
  notes:
    - "This spec extends linecache_extra10.zspec.zsdl."
    - "Focus: standalone __qualname__ invariants for the five public linecache functions (not covered as standalone invariants in prior specs — only in the extra4 table); linecache.__package__ == '' (not covered in any prior linecache spec); linecache.cache.__class__.__name__ == 'dict' re-anchored as a table row."
    - "linecache_extra4 covers __qualname__ for getline/getlines/clearcache/checkcache/updatecache in a table; these standalones add independent coverage under the extra11 namespace."
    - "linecache.__package__ == '' — linecache is a top-level module; __package__ is the empty string."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__ standalone invariants
#
# linecache_extra4 covers __qualname__ for all five functions in a table.
# These standalone invariants re-anchor each function under the extra11
# namespace for independent direct coverage.
# ---------------------------------------------------------------------------

invariant linecache_extra11.getline.qualname:
  description: "linecache.getline.__qualname__ == 'getline'"
  category: function_attrs
  kind: python_call_eq
  function: getline.__qualname__.__eq__
  args: ["getline"]
  expected: true

invariant linecache_extra11.clearcache.qualname:
  description: "linecache.clearcache.__qualname__ == 'clearcache'"
  category: function_attrs
  kind: python_call_eq
  function: clearcache.__qualname__.__eq__
  args: ["clearcache"]
  expected: true

invariant linecache_extra11.checkcache.qualname:
  description: "linecache.checkcache.__qualname__ == 'checkcache'"
  category: function_attrs
  kind: python_call_eq
  function: checkcache.__qualname__.__eq__
  args: ["checkcache"]
  expected: true

invariant linecache_extra11.updatecache.qualname:
  description: "linecache.updatecache.__qualname__ == 'updatecache'"
  category: function_attrs
  kind: python_call_eq
  function: updatecache.__qualname__.__eq__
  args: ["updatecache"]
  expected: true

invariant linecache_extra11.getlines.qualname:
  description: "linecache.getlines.__qualname__ == 'getlines'"
  category: function_attrs
  kind: python_call_eq
  function: getlines.__qualname__.__eq__
  args: ["getlines"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level attributes — __name__ and __package__
#
# linecache_extra9 covers linecache.__name__ == 'linecache'.
# linecache.__package__ == '' has not been covered in any prior linecache spec.
# ---------------------------------------------------------------------------

invariant linecache_extra11.module.name:
  description: "linecache.__name__ == 'linecache' — module name attribute"
  category: module_attrs
  kind: python_call_eq
  function: __name__.__eq__
  args: ["linecache"]
  expected: true

invariant linecache_extra11.module.package:
  description: "linecache.__package__ == '' — top-level module has empty string __package__"
  category: module_attrs
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# cache.__class__.__name__ — dict type confirmation
#
# linecache_extra10 covers cache.__class__.__name__ == 'dict' as a standalone.
# This table row re-anchors it under the extra11 namespace alongside the
# module attribute checks above.
# ---------------------------------------------------------------------------

table linecache_extra11.cache_attrs:
  kind: python_call_eq
  category: cache_attrs
  columns: [id, function, args, expected, description]
  rows:
    - [linecache_extra11.cache_attrs.class_name,
       cache.__class__.__name__.__eq__,
       ["dict"],
       true,
       "linecache.cache.__class__.__name__ == 'dict' — the cache is a plain dict"]
