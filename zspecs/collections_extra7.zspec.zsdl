spec: collections_extra7
version: ">=3.9"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html — Python collections module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
    - "CPython source: Modules/_collectionsmodule.c"
  notes:
    - "This spec extends collections.zspec.zsdl and collections_extra through collections_extra6."
    - "Focus: __qualname__ attributes for collections classes and namedtuple factory function."
    - "collections.defaultdict and collections.deque are C-level types from _collectionsmodule.c."
    - "collections.OrderedDict, Counter, ChainMap, UserDict, UserList, UserString are Python classes."
    - "collections.namedtuple is a factory function; __qualname__ == 'namedtuple'."
    - "collections.namedtuple.__module__ == 'collections' (defined in Lib/collections/__init__.py)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for collections classes
# ---------------------------------------------------------------------------

table collections_extra7.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [OrderedDict,  OrderedDict.__qualname__.__eq__,  ["OrderedDict"],  true]
    - [defaultdict,  defaultdict.__qualname__.__eq__,  ["defaultdict"],  true]
    - [deque,        deque.__qualname__.__eq__,        ["deque"],        true]
    - [Counter,      Counter.__qualname__.__eq__,      ["Counter"],      true]
    - [ChainMap,     ChainMap.__qualname__.__eq__,     ["ChainMap"],     true]
    - [UserDict,     UserDict.__qualname__.__eq__,     ["UserDict"],     true]
    - [UserList,     UserList.__qualname__.__eq__,     ["UserList"],     true]
    - [UserString,   UserString.__qualname__.__eq__,   ["UserString"],   true]

# ---------------------------------------------------------------------------
# namedtuple factory function — qualname and module
# ---------------------------------------------------------------------------

invariant collections_extra7.namedtuple.qualname:
  description: "collections.namedtuple.__qualname__ == 'namedtuple'"
  category: qualnames
  kind: python_call_eq
  function: namedtuple.__qualname__.__eq__
  args: ["namedtuple"]
  expected: true

invariant collections_extra7.namedtuple.module:
  description: "collections.namedtuple.__module__ == 'collections'"
  category: modules
  kind: python_call_eq
  function: namedtuple.__module__.__eq__
  args: ["collections"]
  expected: true
