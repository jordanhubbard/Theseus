spec: itertools_extra48
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra47.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for all major itertools types; __qualname__.__len__() for groupby/islice/zip_longest/accumulate/chain.from_iterable/combinations_with_replacement/count/cycle/repeat/starmap/compress/dropwhile/takewhile/filterfalse; __mro__.__len__()==2 for all major types; __bases__[0].__name__.__len__()==6 for all types; __name__/__qualname__ string equality for all major types; __bases__[0].__name__=='object' string equality for all major types; __bases__[0].__qualname__=='object' for all major types; __class__.__name__=='type' for groupby/chain/compress/islice/zip_longest/product/count/cycle/repeat."
    - "This spec covers: __class__.__qualname__ == 'type' for groupby/chain/compress/islice/zip_longest/product/count/cycle/repeat/accumulate/starmap/dropwhile/takewhile/filterfalse/combinations/permutations/combinations_with_replacement; __class__.__module__ == 'builtins' for groupby/chain/compress/islice/zip_longest/product."
    - "Key findings: All itertools module-level objects are C-extension types defined in Modules/itertoolsmodule.c. Since their __class__ is the built-in 'type' metaclass — a top-level built-in with no enclosing class scope — __class__.__qualname__ == __class__.__name__ == 'type'. The qualname of the 'type' metaclass is simply 'type' (4 chars) with no dotted prefix. This is consistent with the general Python rule that __qualname__ == __name__ for all top-level built-in types. The __class__.__module__ attribute for all itertools types is 'builtins' because their __class__ is the 'type' metaclass, which is defined in the 'builtins' C runtime module. Prior spec extra47 recorded __class__.__name__ == 'type' (string equality) for nine itertools types; this spec records __class__.__qualname__ == 'type' for seventeen types (a comprehensive sweep) and __class__.__module__ == 'builtins' for six of them as a module attribution spot-check. No prior spec recorded __class__.__qualname__ or __class__.__module__ string equality for any itertools type. All invariants are new to extra48."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools combinatoric and grouping types __class__.__qualname__ — extra48
#
# itertools.groupby, chain, compress, islice, and zip_longest are C-extension
# types defined in Modules/itertoolsmodule.c. Their __class__ is the built-in
# 'type' metaclass. Since 'type' is a top-level built-in with no enclosing class
# scope, __class__.__qualname__ == __class__.__name__ == 'type'. Prior spec
# extra47 recorded __class__.__name__ == 'type' for all five; this spec records
# __class__.__qualname__ == 'type'. No prior spec recorded __class__.__qualname__
# for any itertools type. All five are new to extra48.
# ---------------------------------------------------------------------------

table itertools_extra48.groupby_chain_compress_islice_zip_class_qualnames:
  description: "itertools groupby/chain/compress/islice/zip_longest __class__.__qualname__ == 'type' — C-extension types in itertoolsmodule.c; __class__ is the built-in 'type' metaclass; __qualname__ == __name__ == 'type' for top-level built-in types; 4-char qualname"
  kind: python_call_eq
  category: identity
  id_prefix: itertclsqual48

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_class_qualname,
       groupby.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "itertools.groupby.__class__.__qualname__ == 'type' — C-extension type in Modules/itertoolsmodule.c; groups consecutive elements with equal key function output; __class__ is the 'type' metaclass; __class__.__qualname__ == __class__.__name__ == 'type' (4 chars) for top-level built-in types"]
    - [chain_class_qualname,
       chain.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "itertools.chain.__class__.__qualname__ == 'type' — C-extension type in Modules/itertoolsmodule.c; chains multiple iterables into a single iterable; __class__ is the 'type' metaclass; __class__.__qualname__ == __class__.__name__ == 'type' (4 chars)"]
    - [compress_class_qualname,
       compress.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "itertools.compress.__class__.__qualname__ == 'type' — C-extension type in Modules/itertoolsmodule.c; filters elements based on a boolean selector iterable; __class__ is the 'type' metaclass; __class__.__qualname__ == __class__.__name__ == 'type' (4 chars)"]
    - [islice_class_qualname,
       islice.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "itertools.islice.__class__.__qualname__ == 'type' — C-extension type in Modules/itertoolsmodule.c; slices an iterator like a sequence slice without materializing the full sequence; __class__ is the 'type' metaclass; __class__.__qualname__ == 'type' (4 chars)"]
    - [zip_longest_class_qualname,
       zip_longest.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "itertools.zip_longest.__class__.__qualname__ == 'type' — C-extension type in Modules/itertoolsmodule.c; zips iterables filling missing values with a fill value; __class__ is the 'type' metaclass; __class__.__qualname__ == 'type' (4 chars)"]

# ---------------------------------------------------------------------------
# itertools product/count/cycle/repeat __class__.__qualname__ — extra48
#
# itertools.product, count, cycle, and repeat are C-extension types for
# Cartesian products and infinite sequences. All four have __class__.__qualname__
# == 'type' for the same reason as the types above. Prior spec extra47 recorded
# __class__.__name__ == 'type' for all four. No prior spec recorded
# __class__.__qualname__ for any of them. All four are new to extra48.
# ---------------------------------------------------------------------------

table itertools_extra48.product_count_cycle_repeat_class_qualnames:
  description: "itertools product/count/cycle/repeat __class__.__qualname__ == 'type' — C-extension types in itertoolsmodule.c; __class__ is the built-in 'type' metaclass; __qualname__ == 'type' (4 chars) for top-level built-in types"
  kind: python_call_eq
  category: identity
  id_prefix: pccr48

  columns: [id, function, args, expected, description]
  rows:
    - [product_class_qualname,
       product.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "itertools.product.__class__.__qualname__ == 'type' — C-extension type in Modules/itertoolsmodule.c; yields Cartesian product of input iterables; __class__ is the 'type' metaclass; __class__.__qualname__ == __class__.__name__ == 'type' (4 chars)"]
    - [count_class_qualname,
       count.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "itertools.count.__class__.__qualname__ == 'type' — C-extension type in Modules/itertoolsmodule.c; infinite counter starting from a given value with optional step; __class__ is the 'type' metaclass; __class__.__qualname__ == 'type' (4 chars)"]
    - [cycle_class_qualname,
       cycle.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "itertools.cycle.__class__.__qualname__ == 'type' — C-extension type in Modules/itertoolsmodule.c; cycles through an iterable indefinitely saving a copy internally; __class__ is the 'type' metaclass; __class__.__qualname__ == 'type' (4 chars)"]
    - [repeat_class_qualname,
       repeat.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "itertools.repeat.__class__.__qualname__ == 'type' — C-extension type in Modules/itertoolsmodule.c; yields the same object indefinitely or n times; __class__ is the 'type' metaclass; __class__.__qualname__ == 'type' (4 chars)"]

# ---------------------------------------------------------------------------
# itertools accumulate/starmap/dropwhile/takewhile/filterfalse __class__.__qualname__
#
# itertools.accumulate, starmap, dropwhile, takewhile, and filterfalse are
# C-extension types in Modules/itertoolsmodule.c for functional-style iteration.
# All five have __class__.__qualname__ == 'type'. No prior spec recorded
# __class__.__qualname__ for any of them. All five are new to extra48.
# ---------------------------------------------------------------------------

table itertools_extra48.accumulate_starmap_filter_class_qualnames:
  description: "itertools accumulate/starmap/dropwhile/takewhile/filterfalse __class__.__qualname__ == 'type' — C-extension types in itertoolsmodule.c; __class__ is the 'type' metaclass; __qualname__ == 'type' (4 chars)"
  kind: python_call_eq
  category: identity
  id_prefix: asfdt48

  columns: [id, function, args, expected, description]
  rows:
    - [accumulate_class_qualname,
       accumulate.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "itertools.accumulate.__class__.__qualname__ == 'type' — C-extension type in Modules/itertoolsmodule.c; returns accumulated sums or other binary function results; __class__ is the 'type' metaclass; __class__.__qualname__ == 'type' (4 chars)"]
    - [starmap_class_qualname,
       starmap.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "itertools.starmap.__class__.__qualname__ == 'type' — C-extension type in Modules/itertoolsmodule.c; applies a function to arguments obtained from an iterable of tuples; __class__ is the 'type' metaclass; __class__.__qualname__ == 'type' (4 chars)"]
    - [dropwhile_class_qualname,
       dropwhile.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "itertools.dropwhile.__class__.__qualname__ == 'type' — C-extension type in Modules/itertoolsmodule.c; drops elements while predicate is true then yields the rest; __class__ is the 'type' metaclass; __class__.__qualname__ == 'type' (4 chars)"]
    - [takewhile_class_qualname,
       takewhile.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "itertools.takewhile.__class__.__qualname__ == 'type' — C-extension type in Modules/itertoolsmodule.c; yields elements while predicate is true then stops; __class__ is the 'type' metaclass; __class__.__qualname__ == 'type' (4 chars)"]
    - [filterfalse_class_qualname,
       filterfalse.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "itertools.filterfalse.__class__.__qualname__ == 'type' — C-extension type in Modules/itertoolsmodule.c; yields elements for which predicate returns False (complement of filter); __class__ is the 'type' metaclass; __class__.__qualname__ == 'type' (4 chars)"]

# ---------------------------------------------------------------------------
# itertools combinatoric types __class__.__qualname__ — extra48 namespace
#
# itertools.combinations, permutations, and combinations_with_replacement are
# C-extension combinatoric types defined in Modules/itertoolsmodule.c. All three
# have __class__.__qualname__ == 'type'. No prior spec recorded __class__.__qualname__
# for any of them. All three are new to extra48.
# ---------------------------------------------------------------------------

table itertools_extra48.combinatoric_class_qualnames:
  description: "itertools combinations/permutations/combinations_with_replacement __class__.__qualname__ == 'type' — C-extension combinatoric types in itertoolsmodule.c; __class__ is the 'type' metaclass; __qualname__ == 'type' (4 chars)"
  kind: python_call_eq
  category: identity
  id_prefix: combcq48

  columns: [id, function, args, expected, description]
  rows:
    - [combinations_class_qualname,
       combinations.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "itertools.combinations.__class__.__qualname__ == 'type' — C-extension type in Modules/itertoolsmodule.c; yields r-length combinations of elements from an iterable without repetition; __class__ is the 'type' metaclass; __class__.__qualname__ == 'type' (4 chars)"]
    - [permutations_class_qualname,
       permutations.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "itertools.permutations.__class__.__qualname__ == 'type' — C-extension type in Modules/itertoolsmodule.c; yields r-length permutations of elements from an iterable; __class__ is the 'type' metaclass; __class__.__qualname__ == 'type' (4 chars)"]
    - [combinations_with_replacement_class_qualname,
       combinations_with_replacement.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "itertools.combinations_with_replacement.__class__.__qualname__ == 'type' — C-extension type in Modules/itertoolsmodule.c; yields r-length combinations with individual elements repeatable; __class__ is the 'type' metaclass; __class__.__qualname__ == 'type' (4 chars)"]

# ---------------------------------------------------------------------------
# itertools types __class__.__module__ spot-check — extra48 namespace
#
# Since all itertools types have __class__ == type (the built-in metaclass),
# and 'type' is defined in the 'builtins' C runtime module, every itertools
# type has __class__.__module__ == 'builtins'. This section records six
# representative examples as a module attribution spot-check. No prior spec
# recorded __class__.__module__ for any itertools type. All six are new to extra48.
# ---------------------------------------------------------------------------

table itertools_extra48.class_module_builtins_spotcheck:
  description: "itertools groupby/chain/compress/islice/zip_longest/product __class__.__module__ == 'builtins' — __class__ is the 'type' metaclass which is defined in the 'builtins' C runtime module; 7-char module name"
  kind: python_call_eq
  category: identity
  id_prefix: itcmod48

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_class_module,
       groupby.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "itertools.groupby.__class__.__module__ == 'builtins' — C-extension type whose __class__ is the 'type' metaclass; 'type' is defined in the 'builtins' C runtime module; 7-char module name"]
    - [chain_class_module,
       chain.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "itertools.chain.__class__.__module__ == 'builtins' — C-extension type whose __class__ is the 'type' metaclass; 'type' is defined in the 'builtins' C runtime module; 7-char module name"]
    - [compress_class_module,
       compress.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "itertools.compress.__class__.__module__ == 'builtins' — C-extension type whose __class__ is the 'type' metaclass; 'type' is defined in the 'builtins' C runtime module; 7-char module name"]
    - [islice_class_module,
       islice.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "itertools.islice.__class__.__module__ == 'builtins' — C-extension type whose __class__ is the 'type' metaclass; 'type' is defined in the 'builtins' C runtime module; 7-char module name"]
    - [zip_longest_class_module,
       zip_longest.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "itertools.zip_longest.__class__.__module__ == 'builtins' — C-extension type whose __class__ is the 'type' metaclass; 'type' is defined in the 'builtins' C runtime module; 7-char module name"]
    - [product_class_module,
       product.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "itertools.product.__class__.__module__ == 'builtins' — C-extension type whose __class__ is the 'type' metaclass; 'type' is defined in the 'builtins' C runtime module; 7-char module name"]
