spec: watchdog_rust
version: ">=3.9"
backend: rust_module(watchdog_rust)

docs: https://python-watchdog.readthedocs.io/en/stable/

provenance:
  derived_from:
    - "https://python-watchdog.readthedocs.io/en/stable/ — watchdog documentation"
  not_derived_from:
    - "watchdog source: watchdog/__init__.py"
  notes:
    - "watchdog monitors file system events."
    - "watchdog.observers.Observer is available."
    - "watchdog.events.FileSystemEventHandler is available."
    - "watchdog.__version__ is a non-empty string."
    - "Expose watchdog_observer_name() -> str: watchdog.observers.Observer.__name__."
    - "Expose watchdog_has_events() -> bool: hasattr(watchdog, 'events')."
    - "Expose watchdog_version_nonempty() -> bool: len(watchdog.__version__) > 0."
    - "All test vectors verified against watchdog 6.0.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# watchdog_observer_name — Observer class name
invariant watchdog_rust.observer.class_name:
  description: "watchdog.observers.Observer.__name__ == 'Observer'"
  category: observer
  kind: python_call_eq
  function: watchdog_observer_name
  args: []
  expected: "Observer"

# watchdog_has_events — events module present
invariant watchdog_rust.module.has_events:
  description: "watchdog.events is available"
  category: module
  kind: python_call_eq
  function: watchdog_has_events
  args: []
  expected: true

# watchdog_version_nonempty — version non-empty
invariant watchdog_rust.version.nonempty:
  description: "watchdog.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: watchdog_version_nonempty
  args: []
  expected: true

