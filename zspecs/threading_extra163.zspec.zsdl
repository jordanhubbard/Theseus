spec: threading_extra163
version: ">=3.8"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.excepthook.__class__.__name__ 'builtin_function_or_method'; threading.excepthook.__module__ '_thread'; threading.excepthook.__name__ '_excepthook'; threading.ExceptHookArgs.__name__ '_ExceptHookArgs'; threading.ExceptHookArgs.__module__ '_thread'; threading.ExceptHookArgs.__bases__[0].__name__ 'tuple'; threading.ExceptHookArgs.__class__.__name__ 'type'; threading.ExceptHookArgs.n_fields 4 (Wave 291)."
    - "threading.excepthook.__class__.__name__ == 'builtin_function_or_method' — threading.excepthook is a C built-in function defined in Modules/_threadmodule.c as _excepthook; it handles uncaught thread exceptions; its __class__.__name__ is 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "threading.excepthook.__module__ == '_thread' — threading.excepthook is the same object as _thread._excepthook; it is defined in the _thread C extension module; its __module__ is '_thread'. Verified with Python 3.14.3."
    - "threading.excepthook.__name__ == '_excepthook' — the C built-in __name__ for threading.excepthook is '_excepthook' (with underscore prefix), reflecting its internal _thread module name. Verified with Python 3.14.3."
    - "threading.ExceptHookArgs.__name__ == '_ExceptHookArgs' — threading.ExceptHookArgs is the same object as _thread._ExceptHookArgs; its true type __name__ is '_ExceptHookArgs' with an underscore prefix. Verified with Python 3.14.3."
    - "threading.ExceptHookArgs.__module__ == '_thread' — ExceptHookArgs is defined in the _thread C extension module (Modules/_threadmodule.c); its __module__ is '_thread'. Verified with Python 3.14.3."
    - "threading.ExceptHookArgs.__bases__[0].__name__ == 'tuple' — ExceptHookArgs is a C structseq type that inherits from tuple; its base class __name__ is 'tuple'. Verified with Python 3.14.3."
    - "threading.ExceptHookArgs.__class__.__name__ == 'type' — ExceptHookArgs is a C extension class object; its metaclass __name__ is 'type'. Verified with Python 3.14.3."
    - "threading.ExceptHookArgs.n_fields == 4 — ExceptHookArgs has 4 fields: exc_type, exc_value, exc_traceback, thread. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.excepthook C built-in identity
#
# Wave 291 theme: threading.excepthook identity — it is a C built-in function
# from the _thread extension module, not a Python function.
#
# threading.excepthook.__class__.__name__ == 'builtin_function_or_method'
# threading.excepthook.__module__ == '_thread'
# threading.excepthook.__name__ == '_excepthook'
#
# threading.excepthook (added in Python 3.8) is the hook called when a thread
# raises an unhandled exception. It is the same C built-in function object as
# _thread._excepthook, implemented in Modules/_threadmodule.c. Its internal
# C-level name is '_excepthook' (with underscore prefix) and its __module__
# is '_thread'. The public name 'excepthook' in the threading module is just
# an alias. Its __class__.__name__ is 'builtin_function_or_method'. New to extra163.
# ---------------------------------------------------------------------------

table threading_extra163.excepthook_builtin_identity:
  description: "threading.excepthook: __class__.__name__ 'builtin_function_or_method', __module__ '_thread', __name__ '_excepthook'; C built-in from _threadmodule.c; wave 291; new to extra163"
  kind: python_call_eq
  category: identity
  id_prefix: threadingeh163

  columns: [id, function, args, expected, description]
  rows:
    - [eh_class_name_eq_builtin,
       "excepthook.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "threading.excepthook.__class__.__name__.__eq__('builtin_function_or_method') == True — threading.excepthook is a C built-in function (_thread._excepthook) defined in Modules/_threadmodule.c; it handles unhandled thread exceptions; its __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra163"]
    - [eh_module_eq_thread,
       "excepthook.__module__.__eq__",
       ["_thread"],
       true,
       "threading.excepthook.__module__.__eq__('_thread') == True — threading.excepthook is the same C built-in as _thread._excepthook; it is defined in the _thread C extension module (Modules/_threadmodule.c); its __module__ is '_thread' not 'threading'; str.__eq__('_thread') returns True; new to extra163"]
    - [eh_name_eq_excepthook_internal,
       "excepthook.__name__.__eq__",
       ["_excepthook"],
       true,
       "threading.excepthook.__name__.__eq__('_excepthook') == True — threading.excepthook is the C built-in _thread._excepthook; its C-level __name__ is '_excepthook' (with underscore prefix); the 'excepthook' name in threading module is an alias; str.__eq__('_excepthook') returns True; new to extra163"]
    - [eh_class_name_ne_function,
       "excepthook.__class__.__name__.__eq__",
       ["function"],
       false,
       "threading.excepthook.__class__.__name__.__eq__('function') == False — excepthook is a C built-in, not a Python function; its __class__.__name__ is 'builtin_function_or_method', not 'function'; str.__eq__('function') returns False; new to extra163"]

# ---------------------------------------------------------------------------
# Table 2: threading.ExceptHookArgs structseq identity
#
# Wave 291 theme: threading.ExceptHookArgs identity — it is a C structseq type
# from the _thread extension module that inherits from tuple.
#
# threading.ExceptHookArgs.__name__ == '_ExceptHookArgs'
# threading.ExceptHookArgs.__module__ == '_thread'
# threading.ExceptHookArgs.__bases__[0].__name__ == 'tuple'
# threading.ExceptHookArgs.__class__.__name__ == 'type'
# threading.ExceptHookArgs.n_fields == 4
#
# threading.ExceptHookArgs (added in Python 3.8) is the named tuple type
# passed to threading.excepthook. It holds exc_type, exc_value, exc_traceback,
# and thread. It is a C structseq type from Modules/_threadmodule.c. Its true
# type __name__ is '_ExceptHookArgs' (with underscore prefix) and its __module__
# is '_thread'. As a structseq it inherits from tuple and has n_fields == 4.
# New to extra163.
# ---------------------------------------------------------------------------

table threading_extra163.excepthookargs_structseq_identity:
  description: "threading.ExceptHookArgs: __name__ '_ExceptHookArgs', __module__ '_thread', __bases__[0].__name__ 'tuple', __class__.__name__ 'type', n_fields 4; wave 291; new to extra163"
  kind: python_call_eq
  category: identity
  id_prefix: threadingehargs163

  columns: [id, function, args, expected, description]
  rows:
    - [eha_name_eq_internal,
       "ExceptHookArgs.__name__.__eq__",
       ["_ExceptHookArgs"],
       true,
       "threading.ExceptHookArgs.__name__.__eq__('_ExceptHookArgs') == True — threading.ExceptHookArgs is the same C structseq type as _thread._ExceptHookArgs defined in Modules/_threadmodule.c; its true type __name__ is '_ExceptHookArgs' with an underscore prefix; str.__eq__('_ExceptHookArgs') returns True; new to extra163"]
    - [eha_module_eq_thread,
       "ExceptHookArgs.__module__.__eq__",
       ["_thread"],
       true,
       "threading.ExceptHookArgs.__module__.__eq__('_thread') == True — ExceptHookArgs is defined in the _thread C extension module (Modules/_threadmodule.c); its __module__ is '_thread' not 'threading'; str.__eq__('_thread') returns True; new to extra163"]
    - ["eha_bases_0_name_eq_tuple",
       "ExceptHookArgs.__bases__[0].__name__.__eq__",
       ["tuple"],
       true,
       "threading.ExceptHookArgs.__bases__[0].__name__.__eq__('tuple') == True — ExceptHookArgs is a C structseq that inherits from tuple; its single base class __name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra163"]
    - [eha_class_name_eq_type,
       "ExceptHookArgs.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.ExceptHookArgs.__class__.__name__.__eq__('type') == True — ExceptHookArgs is a C extension class object; its metaclass __name__ is 'type'; str.__eq__('type') returns True; new to extra163"]
    - [eha_n_fields_eq_4,
       "ExceptHookArgs.n_fields.__eq__",
       [4],
       true,
       "threading.ExceptHookArgs.n_fields.__eq__(4) == True — ExceptHookArgs has 4 fields: exc_type, exc_value, exc_traceback, and thread; the C structseq n_fields attribute is 4; int.__eq__(4) returns True; new to extra163"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra163
# ---------------------------------------------------------------------------

invariant threading_extra163.excepthook_class_builtin:
  description: "threading.excepthook.__class__.__name__ == 'builtin_function_or_method' — excepthook is a C built-in, not a Python function; wave 291; new to extra163"
  kind: python_call_eq
  function: excepthook.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant threading_extra163.excepthook_module_thread:
  description: "threading.excepthook.__module__ == '_thread' — excepthook is _thread._excepthook from the _thread C extension; wave 291; new to extra163"
  kind: python_call_eq
  function: excepthook.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra163.excepthook_name_internal:
  description: "threading.excepthook.__name__ == '_excepthook' — C-level name has underscore prefix; public alias is 'excepthook' in threading; wave 291; new to extra163"
  kind: python_call_eq
  function: excepthook.__name__.__eq__
  args: ["_excepthook"]
  expected: true

invariant threading_extra163.excepthookargs_name_internal:
  description: "threading.ExceptHookArgs.__name__ == '_ExceptHookArgs' — C structseq type; true name has underscore prefix; wave 291; new to extra163"
  kind: python_call_eq
  function: ExceptHookArgs.__name__.__eq__
  args: ["_ExceptHookArgs"]
  expected: true

invariant threading_extra163.excepthookargs_module_thread:
  description: "threading.ExceptHookArgs.__module__ == '_thread' — ExceptHookArgs is defined in _threadmodule.c; wave 291; new to extra163"
  kind: python_call_eq
  function: ExceptHookArgs.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra163.excepthookargs_bases_0_tuple:
  description: "threading.ExceptHookArgs.__bases__[0].__name__ == 'tuple' — ExceptHookArgs is a C structseq that inherits from tuple; wave 291; new to extra163"
  kind: python_call_eq
  function: "ExceptHookArgs.__bases__[0].__name__.__eq__"
  args: ["tuple"]
  expected: true

invariant threading_extra163.excepthookargs_class_type:
  description: "threading.ExceptHookArgs.__class__.__name__ == 'type' — ExceptHookArgs is a C extension class object with metaclass 'type'; wave 291; new to extra163"
  kind: python_call_eq
  function: ExceptHookArgs.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant threading_extra163.excepthookargs_n_fields_4:
  description: "threading.ExceptHookArgs.n_fields == 4 — ExceptHookArgs has 4 fields: exc_type, exc_value, exc_traceback, thread; wave 291; new to extra163"
  kind: python_call_eq
  function: ExceptHookArgs.n_fields.__eq__
  args: [4]
  expected: true
