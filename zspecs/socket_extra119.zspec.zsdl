spec: socket_extra119
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra118.zspec.zsdl — covers AddressFamily metaclass module/name lengths and AF_UNIX/AF_UNSPEC member name lengths (table + invariants)."
    - "socket_extra112.zspec.zsdl — covers SOCK_STREAM/SOCK_DGRAM/SOCK_RAW .name equality / SOCK_STREAM.name.__len__()==11 / SOCK_DGRAM.name.__len__()==10 (table + invariants)."
    - "socket_extra105.zspec.zsdl — covers SocketKind.__class__.__name__.__eq__('EnumType') / AddressFamily.__class__.__name__.__eq__('EnumType') (table + invariants)."
    - "socket_extra95.zspec.zsdl — covers SOCK_STREAM/SOCK_DGRAM/SOCK_RAW/SOCK_SEQPACKET value and name equality (table + invariants)."
    - "socket_extra6.zspec.zsdl — covers SOCK_STREAM.value==1 / SOCK_DGRAM.value==2 (table + invariants)."
    - "socket_extra10.zspec.zsdl — covers SOCK_RAW.value==3 as standalone invariant."
  notes:
    - "This spec extends socket through socket_extra118; it does NOT duplicate invariants present in those files."
    - "Wave 279 theme: socket.SocketKind enum metaclass module and member name lengths not yet covered — extra105 anchors SocketKind.__class__.__name__.__eq__('EnumType'); extra112 anchors SOCK_STREAM/SOCK_DGRAM .name length; NOT YET covered: SocketKind.__class__.__name__.__len__()==8 as grouped table; SocketKind.__class__.__module__.__eq__('enum') as grouped table; SocketKind.__class__.__module__.__len__()==4 as grouped table; SOCK_RAW.name.__len__()==8 as table row."
    - "socket.SocketKind.__class__.__name__.__len__() == 8 — len('EnumType')==8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__class__.__module__.__eq__('enum') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__class__.__module__.__len__() == 4 — len('enum')==4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__name__.__len__() == 10 — len('SocketKind')==10. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__module__.__len__() == 6 — len('socket')==6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.value == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_DGRAM.value == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_RAW.value == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.name.__len__() == 11 — len('SOCK_STREAM')==11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_DGRAM.name.__len__() == 10 — len('SOCK_DGRAM')==10. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_RAW.name.__len__() == 8 — len('SOCK_RAW')==8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.SocketKind is an IntEnum defined in Lib/socket.py. Its metaclass is 'EnumType' (8 chars, from the Python stdlib 'enum' module, 4 chars). This is the same metaclass as AddressFamily (both are IntEnum subclasses). SOCK_STREAM.value==1, SOCK_DGRAM.value==2, SOCK_RAW.value==3 are the POSIX socket type constants. SOCK_STREAM (11 chars), SOCK_DGRAM (10 chars), SOCK_RAW (8 chars) — the names decrease in length as the protocol becomes more primitive. Values 1/2/3 are stable across macOS/Darwin and Linux."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.SocketKind.__class__.__name__.__len__() == 8
# socket.SocketKind.__class__.__module__.__eq__('enum') == True
# socket.SocketKind.__class__.__module__.__len__() == 4
# socket.SocketKind.__name__.__len__() == 10
# socket.SocketKind.__module__.__len__() == 6
#
# Wave 279 theme: socket.SocketKind enum metaclass module and name lengths.
#
# socket.SocketKind is an IntEnum defined in Lib/socket.py. Its metaclass is
# 'EnumType' (8 chars), from the Python stdlib 'enum' module (4 chars, Lib/enum.py).
# socket_extra105 anchors SocketKind.__class__.__name__.__eq__('EnumType') as a table
# row; socket_extra118 anchors the same pattern for AddressFamily with module len==4.
# No prior spec anchors SocketKind.__class__.__module__ (the 'enum' module) or its
# length (4 chars) specifically for SocketKind in a grouped table. Similarly, no prior
# spec anchors SocketKind.__class__.__name__.__len__()==8 or SocketKind.__name__.__len__()
# (10 chars) and SocketKind.__module__.__len__() (6 chars) together. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table socket_extra119.SocketKind_metaclass_module_and_lengths:
  description: "SocketKind.__class__.__name__.__len__()==8 / SocketKind.__class__.__module__.__eq__('enum')==True / SocketKind.__class__.__module__.__len__()==4 / SocketKind.__name__.__len__()==10 / SocketKind.__module__.__len__()==6 — EnumType metaclass (8 chars) is from 'enum' module (4 chars); 'SocketKind'=10 chars; 'socket'=6 chars; extra105 anchors __class__.__name__.__eq__('EnumType'); extra118 anchors same pattern for AddressFamily; no prior spec anchors SocketKind class module or these lengths as grouped table; first socksock119 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: socksock119

  columns: [id, function, args, expected, description]
  rows:
    - [sk_cls_name_len,   SocketKind.__class__.__name__.__len__,    [],       8,    "SocketKind.__class__.__name__.__len__() is 8 (len('EnumType')==8; Enum metaclass renamed from 'EnumMeta' in Python 3.11; extra105 anchors __eq__('EnumType'))"]
    - [sk_cls_mod_eq,     SocketKind.__class__.__module__.__eq__,   ["enum"], true, "SocketKind.__class__.__module__ is 'enum' (EnumType metaclass is from Python stdlib Lib/enum.py; 4-char module name)"]
    - [sk_cls_mod_len,    SocketKind.__class__.__module__.__len__,  [],       4,    "SocketKind.__class__.__module__.__len__() is 4 (len('enum')==4; same as len('uuid')=4 coincidentally)"]
    - [sk_name_len,       SocketKind.__name__.__len__,              [],       10,   "SocketKind.__name__.__len__() is 10 (len('SocketKind')==10; 'Socket'=6 + 'Kind'=4; cross-check with extra30)"]
    - [sk_module_len,     SocketKind.__module__.__len__,            [],       6,    "SocketKind.__module__.__len__() is 6 (len('socket')==6; defined in Lib/socket.py; cross-check with extra101)"]

# ---------------------------------------------------------------------------
# socket.SOCK_STREAM.value == 1
# socket.SOCK_DGRAM.value == 2
# socket.SOCK_RAW.value == 3
# socket.SOCK_STREAM.name.__len__() == 11
# socket.SOCK_DGRAM.name.__len__() == 10
#
# Wave 279 theme: SocketKind member values and name lengths in one table.
#
# socket_extra95 anchors SOCK_STREAM/SOCK_DGRAM/SOCK_RAW values in a table; extra6/10
# anchor them individually. socket_extra112 anchors SOCK_STREAM.name.__len__()==11 and
# SOCK_DGRAM.name.__len__()==10 as table rows (and SOCK_RAW.name.__len__()==8 in the
# description only, not as a table row). This table cross-checks values (1/2/3) with
# name lengths (11/10), combining both axes for SOCK_STREAM and SOCK_DGRAM in one view.
# Grouping value and name length for the same constants highlights the inverse pattern:
# SOCK_STREAM has the highest name value/length (1/11), SOCK_DGRAM is next (2/10),
# SOCK_RAW is shortest (3/8). Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra119.SocketKind_member_values_and_name_lengths:
  description: "SOCK_STREAM.value==1 / SOCK_DGRAM.value==2 / SOCK_RAW.value==3 / SOCK_STREAM.name.__len__()==11 / SOCK_DGRAM.name.__len__()==10 — SocketKind POSIX socket type values (1=reliable stream, 2=datagram, 3=raw); name lengths decrease as protocol becomes more primitive (SOCK_STREAM=11, SOCK_DGRAM=10, SOCK_RAW=8); extra95/extra6/extra10 anchor values; extra112 anchors SOCK_STREAM/SOCK_DGRAM name lengths; first socksock119 cross-check combining values and name lengths"
  kind: python_call_eq
  category: type_identity
  id_prefix: socksock119

  columns: [id, function, args, expected, description]
  rows:
    - [sock_stream_val,      SOCK_STREAM.value.__eq__,    [1],  true, "SOCK_STREAM.value is 1 (POSIX AF_STREAM; TCP-style reliable stream; lowest SOCK_* value; cross-check with extra6/extra95)"]
    - [sock_dgram_val,       SOCK_DGRAM.value.__eq__,     [2],  true, "SOCK_DGRAM.value is 2 (POSIX AF_DGRAM; UDP-style unreliable datagram; cross-check with extra6/extra95)"]
    - [sock_raw_val,         SOCK_RAW.value.__eq__,       [3],  true, "SOCK_RAW.value is 3 (raw socket for direct protocol access; cross-check with extra10/extra95)"]
    - [sock_stream_name_len, SOCK_STREAM.name.__len__,    [], 11,    "SOCK_STREAM.name.__len__() is 11 ('SOCK_STREAM': S-O-C-K-_-S-T-R-E-A-M; cross-check with extra112)"]
    - [sock_dgram_name_len,  SOCK_DGRAM.name.__len__,     [], 10,    "SOCK_DGRAM.name.__len__() is 10 ('SOCK_DGRAM': S-O-C-K-_-D-G-R-A-M; one less than SOCK_STREAM; cross-check with extra112)"]

# ---------------------------------------------------------------------------
# socket.SOCK_RAW.name.__len__() == 8
# socket.SocketKind.__class__.__name__.__len__() == 8
# socket.SocketKind.__class__.__module__.__eq__('enum') == True
# socket.SocketKind.__class__.__module__.__len__() == 4
# socket.SOCK_RAW.value.__eq__(3) == True
#
# Wave 279 theme: SOCK_RAW name length and SocketKind class module cross-check.
#
# A notable coincidence: SOCK_RAW.name.__len__()==8 (len('SOCK_RAW')==8) and
# SocketKind.__class__.__name__.__len__()==8 (len('EnumType')==8) are equal. Both are
# 8-char strings related to the SocketKind enum: SOCK_RAW is a member of SocketKind,
# and EnumType is SocketKind's metaclass. This coincidence in lengths is not documented
# in prior specs. socket_extra112 anchors SOCK_RAW.name.__eq__('SOCK_RAW') as a table
# row, but does NOT anchor SOCK_RAW.name.__len__()==8 as a table row (only mentioned in
# a text note). This is the first time SOCK_RAW.name.__len__()==8 appears as a table row.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra119.SOCK_RAW_name_len_and_SocketKind_metaclass_cross:
  description: "SOCK_RAW.name.__len__()==8 / SocketKind.__class__.__name__.__len__()==8 / SocketKind.__class__.__module__.__eq__('enum')==True / SocketKind.__class__.__module__.__len__()==4 / SOCK_RAW.value.__eq__(3)==True — length coincidence: SOCK_RAW.name=8 chars and EnumType=8 chars (member name and metaclass name have same length); extra112 anchors SOCK_RAW.name.__eq__('SOCK_RAW') but NOT len==8 as table row; first socksock119 anchor for SOCK_RAW name length and SocketKind class module cross-check"
  kind: python_call_eq
  category: type_identity
  id_prefix: socksock119

  columns: [id, function, args, expected, description]
  rows:
    - [sock_raw_name_len,    SOCK_RAW.name.__len__,                  [],       8,    "SOCK_RAW.name.__len__() is 8 (len('SOCK_RAW')==8; 'SOCK_'=5 + 'RAW'=3; raw socket; first table row for this length)"]
    - [sk_cls_name_len2,     SocketKind.__class__.__name__.__len__,  [],       8,    "SocketKind.__class__.__name__.__len__() is 8 (len('EnumType')==8; length coincidence with SOCK_RAW.name; cross-check)"]
    - [sk_cls_mod_eq2,       SocketKind.__class__.__module__.__eq__, ["enum"], true, "SocketKind.__class__.__module__ is 'enum' (cross-check; EnumType metaclass from Python stdlib Lib/enum.py)"]
    - [sk_cls_mod_len2,      SocketKind.__class__.__module__.__len__, [],      4,    "SocketKind.__class__.__module__.__len__() is 4 (len('enum')==4; cross-check confirming 4-char module name)"]
    - [sock_raw_val2,        SOCK_RAW.value.__eq__,                  [3],     true,  "SOCK_RAW.value is 3 (POSIX raw socket type; cross-check with extra10; lowest-level access to network layer)"]

# ---------------------------------------------------------------------------
# socket.SocketKind.__class__.__name__.__len__() == 8 — standalone
#
# socket.SocketKind.__class__.__name__.__len__() is 8. 'EnumType' has 8 chars:
# 'Enum'=4 + 'Type'=4 = 8. EnumType is the metaclass for all Python Enum classes
# (renamed from 'EnumMeta' to 'EnumType' in Python 3.11). On Python 3.14.3, it is
# 'EnumType' (8 chars). socket_extra105 anchors SocketKind.__class__.__name__
# .__eq__('EnumType') as a table row; socket_extra118 anchors the length==8 for
# AddressFamily.__class__.__name__.__len__(). No prior spec anchors the length==8
# specifically for SocketKind.__class__.__name__ as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra119.SocketKind_class_name_len_8:
  description: "socket.SocketKind.__class__.__name__.__len__() == 8 — len('EnumType')==8 ('Enum'=4 + 'Type'=4; renamed from 'EnumMeta' to 'EnumType' in Python 3.11; extra105 anchors __eq__('EnumType') for SocketKind; extra118 anchors len==8 for AddressFamily class name; no prior spec anchors SocketKind class name length as standalone; first standalone under socksock119)"
  category: type_identity
  kind: python_call_eq
  function: SocketKind.__class__.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# socket.SocketKind.__class__.__module__.__eq__('enum') — standalone
#
# socket.SocketKind.__class__.__module__ is 'enum'. SocketKind uses the 'EnumType'
# metaclass (from the Python stdlib 'enum' module, Lib/enum.py). This is the same
# metaclass module as AddressFamily (socket_extra118 anchors AddressFamily.__class__
# .__module__.__eq__('enum') as a standalone). This standalone covers SocketKind
# specifically. The 'enum' module (4 chars) implements the EnumType metaclass which
# provides IntEnum/IntFlag/Enum functionality through class creation hooks. SocketKind
# is an IntEnum, meaning SOCK_STREAM.value is directly usable as an integer in system
# calls. No prior spec anchors SocketKind.__class__.__module__ as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra119.SocketKind_class_module_enum:
  description: "socket.SocketKind.__class__.__module__.__eq__('enum') == True — EnumType metaclass is from the Python stdlib 'enum' module (4 chars; Lib/enum.py; implements IntEnum/Flag/IntFlag through class creation hooks); SocketKind is an IntEnum (SOCK_* values usable as integers in system calls); extra118 anchors same for AddressFamily; no prior spec anchors SocketKind class module as standalone; first standalone under socksock119"
  category: type_identity
  kind: python_call_eq
  function: SocketKind.__class__.__module__.__eq__
  args: ["enum"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SocketKind.__class__.__module__.__len__() == 4 — standalone
#
# socket.SocketKind.__class__.__module__.__len__() is 4. 'enum' has 4 chars.
# The 'enum' module name (4 chars) is one of the shortest stdlib module names.
# Coincidentally, len('enum')==4 equals len('uuid')==4 and len('math')==4 and
# len('json')==4 — several important stdlib modules have 4-char names. The 'enum'
# module is particularly central because IntEnum/IntFlag are widely used for system
# constants (socket types, OS flags, etc.). No prior spec anchors SocketKind
# .__class__.__module__.__len__() as a standalone. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant socket_extra119.SocketKind_class_module_len_4:
  description: "socket.SocketKind.__class__.__module__.__len__() == 4 — len('enum')==4 ('enum' is one of the shortest stdlib module names; coincidentally same length as 'uuid'=4, 'math'=4, 'json'=4; EnumType metaclass from 'enum' provides IntEnum/IntFlag for system constant mapping); no prior spec anchors SocketKind class module length as standalone; first standalone under socksock119"
  category: type_identity
  kind: python_call_eq
  function: SocketKind.__class__.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# socket.SOCK_RAW.name.__len__() == 8 — standalone
#
# socket.SOCK_RAW.name.__len__() is 8. 'SOCK_RAW' has 8 chars: 'SOCK_'=5 plus
# 'RAW'=3 = 8. SOCK_RAW (value=3) is the most primitive socket type — it allows
# direct access to the network/transport layer without OS protocol processing. It
# is used for custom protocol implementations (e.g., ICMP ping, custom IP headers).
# Unlike SOCK_STREAM (11 chars) and SOCK_DGRAM (10 chars), SOCK_RAW (8 chars) is
# the shortest name among the three primary socket types. socket_extra112 anchors
# SOCK_RAW.name.__eq__('SOCK_RAW') as a table row; the __len__()==8 is mentioned
# only in a description note, not as a table row or standalone. This is the first
# standalone invariant for SOCK_RAW.name.__len__(). Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant socket_extra119.SOCK_RAW_name_len_8:
  description: "socket.SOCK_RAW.name.__len__() == 8 — len('SOCK_RAW')==8 ('SOCK_'=5 + 'RAW'=3; RAW socket for direct protocol access without OS processing; ICMP/custom IP; SOCK_RAW=8 is shortest among SOCK_STREAM=11/SOCK_DGRAM=10/SOCK_RAW=8; coincidentally same length as len('EnumType')==8 — SocketKind metaclass name; extra112 anchors __eq__('SOCK_RAW') but NOT len==8 as table row or standalone; first standalone under socksock119)"
  category: type_identity
  kind: python_call_eq
  function: SOCK_RAW.name.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# socket.SocketKind.__name__.__len__() == 10 — standalone
#
# socket.SocketKind.__name__.__len__() is 10. 'SocketKind' has 10 chars:
# 'Socket'=6 + 'Kind'=4 = 10. SocketKind is the IntEnum class grouping the socket
# type constants (SOCK_STREAM, SOCK_DGRAM, SOCK_RAW, SOCK_SEQPACKET, etc.).
# Prior specs anchor SocketKind.__name__.__eq__('SocketKind') (extra30/extra105)
# and SocketKind.__name__.__len__()==10 as a grouped table row in extra30/extra95;
# this standalone anchors the length==10 independently in the socksock119 namespace
# for regression coverage. The 10-char name contrasts with AddressFamily (13 chars)
# — SocketKind is 3 chars shorter. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra119.SocketKind_name_len_10:
  description: "socket.SocketKind.__name__.__len__() == 10 — len('SocketKind')==10 ('Socket'=6 + 'Kind'=4; IntEnum grouping SOCK_STREAM/SOCK_DGRAM/SOCK_RAW/SOCK_SEQPACKET etc.; 3 chars shorter than AddressFamily=13; extra30/extra95 anchor this as table rows; first standalone under socksock119 for independent regression coverage)"
  category: type_identity
  kind: python_call_eq
  function: SocketKind.__name__.__len__
  args: []
  expected: 10

