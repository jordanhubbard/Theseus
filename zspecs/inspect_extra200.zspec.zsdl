       ["str"],
       true,
       "inspect.signature.__doc__.__class__.__name__.__eq__('str') == True — signature is a Python function returning a Signature object; its __doc__ is a non-None string; __class__.__name__ is 'str'; new to extra200"]
    - [getsource_doc_class_str,
