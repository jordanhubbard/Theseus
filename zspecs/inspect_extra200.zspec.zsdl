spec: inspect_extra200
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers __doc__.__class__.__name__ identity for public inspect functions and classes: isfunction, isbuiltin, isclass, getmembers, signature, getsource, currentframe, Parameter."
    - "inspect.isfunction.__doc__.__class__.__name__ == 'str' — isfunction is a Python function with a string docstring. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__doc__.__class__.__name__ == 'str' — isbuiltin is a Python function with a string docstring. Verified with Python 3.14.3."
    - "inspect.isclass.__doc__.__class__.__name__ == 'str' — isclass is a Python function with a string docstring. Verified with Python 3.14.3."
    - "inspect.getmembers.__doc__.__class__.__name__ == 'str' — getmembers is a Python function with a string docstring. Verified with Python 3.14.3."
    - "inspect.signature.__doc__.__class__.__name__ == 'str' — signature is a Python function with a string docstring. Verified with Python 3.14.3."
    - "inspect.getsource.__doc__.__class__.__name__ == 'str' — getsource is a Python function with a string docstring. Verified with Python 3.14.3."
    - "inspect.currentframe.__doc__.__class__.__name__ == 'str' — currentframe is a Python builtin_function_or_method with a string docstring (not None). Verified with Python 3.14.3."
    - "inspect.Parameter.__doc__.__class__.__name__ == 'str' — Parameter is a Python class defined in inspect with a string docstring. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __doc__.__class__.__name__ for inspect predicate functions
#
# isfunction, isbuiltin, isclass: Python predicate functions in inspect.
# All have non-None string docstrings; __class__.__name__ is 'str'.
# ---------------------------------------------------------------------------

table inspect_extra200.doc_class_predicates:
  description: "inspect predicate functions: isfunction, isbuiltin, isclass __doc__.__class__.__name__=='str'; new to extra200"
  kind: python_call_eq
  category: doc_class_identity
  id_prefix: inspectdocs200

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_doc_class_str,
       isfunction.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.isfunction.__doc__.__class__.__name__.__eq__('str') == True — isfunction is a Python predicate function; its __doc__ is a non-None string; __class__.__name__ is 'str'; new to extra200"]
    - [isbuiltin_doc_class_str,
       isbuiltin.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.isbuiltin.__doc__.__class__.__name__.__eq__('str') == True — isbuiltin is a Python predicate function; its __doc__ is a non-None string; __class__.__name__ is 'str'; new to extra200"]
    - [isclass_doc_class_str,
       isclass.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.isclass.__doc__.__class__.__name__.__eq__('str') == True — isclass is a Python predicate function; its __doc__ is a non-None string; __class__.__name__ is 'str'; new to extra200"]

# ---------------------------------------------------------------------------
