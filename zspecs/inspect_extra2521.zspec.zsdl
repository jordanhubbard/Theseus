spec: inspect_extra2521
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: __bool__, __index__, and __int__ dict-presence checks for inspect module classes."
    - "Theme: truthiness, integer coercion, and indexing protocol dict-presence — checking whether classes define __bool__, __index__, or __int__ in their class __dict__."
    - "inspect.Parameter, inspect.Signature, and inspect.BoundArguments are the primary introspection data-carrier classes in the inspect module; none define __bool__, __index__, or __int__."
    - "inspect.Parameter represents a single parameter in a callable's signature; its identity is based on name and kind (POSITIONAL_ONLY, KEYWORD_ONLY, etc.), not on any numeric or truthiness protocol. It defines __eq__ and __hash__ but not __bool__, __index__, or __int__. Verified with Python 3.14."
    - "inspect.Signature represents the full call signature of a callable, holding an ordered mapping of Parameter objects and an optional return annotation; it defines __eq__ and __str__ but carries no numeric coercion or truthiness protocol. Verified with Python 3.14."
    - "inspect.BoundArguments is returned by Signature.bind() and holds the mapping of argument values to parameters; it provides apply_defaults() and args/kwargs properties but defines no __bool__, __index__, or __int__. Verified with Python 3.14."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter — truthiness/int/index protocol absence
#
# Theme: __bool__, __index__, __int__ absent from inspect.Parameter.__dict__.
# Parameter is a frozen data-carrier describing a single parameter in a
# callable signature. It defines __eq__, __hash__, and __repr__ but has
# no numeric coercion or truthiness override — truth-testing falls through
# to the default object protocol (always True for non-None instances).
# ---------------------------------------------------------------------------

table inspect_extra2521.parameter_bool_index_int:
  description: "__bool__, __index__, __int__ absent from inspect.Parameter.__dict__; wave 2521"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: in2521

  columns: [id, function, args, expected]
  rows:
    - ["in2521-001", "Parameter.__dict__.__contains__", ["__bool__"], false]
    - ["in2521-002", "Parameter.__dict__.__contains__", ["__index__"], false]
    - ["in2521-003", "Parameter.__dict__.__contains__", ["__int__"], false]

# ---------------------------------------------------------------------------
# Table 2: inspect.Signature — truthiness/int/index protocol absence
#
# Theme: __bool__, __index__, __int__ absent from inspect.Signature.__dict__.
# Signature holds an ordered mapping of Parameter objects plus an optional
# return annotation. It exposes bind(), bind_partial(), and replace() but
# carries no integer coercion, indexing protocol, or truthiness override.
# ---------------------------------------------------------------------------

table inspect_extra2521.signature_bool_index_int:
  description: "__bool__, __index__, __int__ absent from inspect.Signature.__dict__; wave 2521"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: in2521

  columns: [id, function, args, expected]
  rows:
    - ["in2521-004", "Signature.__dict__.__contains__", ["__bool__"], false]
    - ["in2521-005", "Signature.__dict__.__contains__", ["__index__"], false]
    - ["in2521-006", "Signature.__dict__.__contains__", ["__int__"], false]

# ---------------------------------------------------------------------------
# Table 3: inspect.BoundArguments — truthiness/int/index protocol absence
#
# Theme: __bool__, __index__, __int__ absent from inspect.BoundArguments.__dict__.
# BoundArguments is returned by Signature.bind() and maps concrete argument
# values to their corresponding Parameter objects. It provides apply_defaults()
# and exposes .args and .kwargs views, but defines no numeric or boolean protocol.
# ---------------------------------------------------------------------------

table inspect_extra2521.bound_arguments_bool_index_int:
  description: "__bool__, __index__, __int__ absent from inspect.BoundArguments.__dict__; wave 2521"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: in2521

  columns: [id, function, args, expected]
  rows:
    - ["in2521-007", "BoundArguments.__dict__.__contains__", ["__bool__"], false]
    - ["in2521-008", "BoundArguments.__dict__.__contains__", ["__index__"], false]
    - ["in2521-009", "BoundArguments.__dict__.__contains__", ["__int__"], false]

# ---------------------------------------------------------------------------
# Table 4: cross-class summary — all three operators across all three classes
#
# Theme: consolidated view confirming that none of the three inspect data-
# carrier classes define any of the three protocol methods examined in this spec.
# Rows 010-018 re-confirm the same properties across all three classes
# in a single table to make cross-class comparison straightforward.
# ---------------------------------------------------------------------------

table inspect_extra2521.all_classes_bool_index_int_summary:
  description: "__bool__, __index__, __int__ all absent from Parameter, Signature, BoundArguments; wave 2521 summary"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: in2521

  columns: [id, function, args, expected]
  rows:
    - ["in2521-010", "Parameter.__dict__.__contains__", ["__bool__"], false]
    - ["in2521-011", "Signature.__dict__.__contains__", ["__bool__"], false]
    - ["in2521-012", "BoundArguments.__dict__.__contains__", ["__bool__"], false]
    - ["in2521-013", "Parameter.__dict__.__contains__", ["__index__"], false]
    - ["in2521-014", "Signature.__dict__.__contains__", ["__index__"], false]
    - ["in2521-015", "BoundArguments.__dict__.__contains__", ["__index__"], false]
    - ["in2521-016", "Parameter.__dict__.__contains__", ["__int__"], false]
    - ["in2521-017", "Signature.__dict__.__contains__", ["__int__"], false]
    - ["in2521-018", "BoundArguments.__dict__.__contains__", ["__int__"], false]
