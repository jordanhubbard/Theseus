spec: threading_extra2356
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/threading.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 604 (_extra2356): __init__ and __new__ implementation type classification."
    - "threading.Thread, Event, Condition, Semaphore, Barrier, Timer are Python classes with custom __init__: returns 'function'."
    - "threading.local is a C type: __init__ == 'wrapper_descriptor', __new__ == 'builtin_function_or_method'."
    - "All pure Python threading classes without custom __new__ return 'builtin_function_or_method' for __new__."
    - "threading.Thread.__doc__ and threading.local.__doc__ are both 'str'."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __init__ implementation type for threading classes
# ---------------------------------------------------------------------------

table threading_extra2356.init_types:
  description: "threading class __init__ implementation type — pure Python classes with custom __init__ return 'function'; C type threading.local returns 'wrapper_descriptor'"
  kind: python_call_eq
  category: type_identity
  id_prefix: th2356
  columns: [id, function, args, expected]
  rows:
    - ["th2356001", "threading.Thread.__init__.__class__.__name__",    [], "function"]
    - ["th2356002", "threading.Event.__init__.__class__.__name__",     [], "function"]
    - ["th2356003", "threading.Condition.__init__.__class__.__name__", [], "function"]
    - ["th2356004", "threading.Semaphore.__init__.__class__.__name__", [], "function"]
    - ["th2356005", "threading.Barrier.__init__.__class__.__name__",   [], "function"]
    - ["th2356006", "threading.Timer.__init__.__class__.__name__",     [], "function"]
    - ["th2356007", "threading.local.__init__.__class__.__name__",     [], "wrapper_descriptor"]

# ---------------------------------------------------------------------------
# __new__ implementation type for threading classes
# ---------------------------------------------------------------------------

table threading_extra2356.new_types:
  description: "threading class __new__ implementation type — Python classes without custom __new__ return 'builtin_function_or_method'; threading.local is a C type with same result"
  kind: python_call_eq
  category: type_identity
  id_prefix: th2356
  columns: [id, function, args, expected]
  rows:
    - ["th2356008", "threading.Thread.__new__.__class__.__name__",    [], "builtin_function_or_method"]
    - ["th2356009", "threading.Event.__new__.__class__.__name__",     [], "builtin_function_or_method"]
    - ["th2356010", "threading.Condition.__new__.__class__.__name__", [], "builtin_function_or_method"]
    - ["th2356011", "threading.Semaphore.__new__.__class__.__name__", [], "builtin_function_or_method"]
    - ["th2356012", "threading.Barrier.__new__.__class__.__name__",   [], "builtin_function_or_method"]
    - ["th2356013", "threading.Timer.__new__.__class__.__name__",     [], "builtin_function_or_method"]
    - ["th2356014", "threading.local.__new__.__class__.__name__",     [], "builtin_function_or_method"]

# ---------------------------------------------------------------------------
# __doc__ class names for threading classes
# ---------------------------------------------------------------------------

table threading_extra2356.doc_class_names:
  description: "threading class __doc__.__class__.__name__ — Thread and local have str docstrings; others are also str"
  kind: python_call_eq
  category: type_identity
  id_prefix: th2356
  columns: [id, function, args, expected]
  rows:
    - ["th2356015", "threading.Thread.__doc__.__class__.__name__",    [], "str"]
    - ["th2356016", "threading.local.__doc__.__class__.__name__",     [], "str"]
    - ["th2356017", "threading.Condition.__doc__.__class__.__name__", [], "str"]
    - ["th2356018", "threading.Semaphore.__doc__.__class__.__name__", [], "str"]
    - ["th2356019", "threading.Barrier.__doc__.__class__.__name__",   [], "str"]
    - ["th2356020", "threading.Timer.__doc__.__class__.__name__",     [], "str"]
    - ["th2356021", "threading.Event.__doc__.__class__.__name__",     [], "str"]
