spec: multiprocessing_extra1936
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/multiprocessing.html"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Wave 576 (_extra1936): __get__/__set__/__delete__ descriptor protocol, __set_name__, __class__ checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "multiprocessing.Process and all synchronize/queue/pool types are not descriptor types."
    - "None of the multiprocessing classes define __get__, __set__, __delete__, or __set_name__ in their own __dict__."
    - "multiprocessing module __class__.__name__ == 'module'; multiprocessing class objects have __class__.__name__ == 'type'."
  created_at: "2026-04-12"
error_model: python_exceptions

table multiprocessing_extra1936.descriptor_get:
  description: "multiprocessing types __get__ dict-presence checks — none define __get__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1936

  columns: [id, function, args, expected]
  rows:
    - ["mp1936001", "multiprocessing.Process.__dict__.__contains__",                     ["__get__"], false]
    - ["mp1936002", "multiprocessing.synchronize.Lock.__dict__.__contains__",            ["__get__"], false]
    - ["mp1936003", "multiprocessing.synchronize.RLock.__dict__.__contains__",           ["__get__"], false]
    - ["mp1936004", "multiprocessing.synchronize.Event.__dict__.__contains__",           ["__get__"], false]
    - ["mp1936005", "multiprocessing.synchronize.Semaphore.__dict__.__contains__",       ["__get__"], false]
    - ["mp1936006", "multiprocessing.synchronize.BoundedSemaphore.__dict__.__contains__", ["__get__"], false]
    - ["mp1936007", "multiprocessing.synchronize.Condition.__dict__.__contains__",       ["__get__"], false]
    - ["mp1936008", "multiprocessing.synchronize.Barrier.__dict__.__contains__",         ["__get__"], false]

