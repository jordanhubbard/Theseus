table multiprocessing_extra1936.class_name:
  description: "__class__.__name__ checks: multiprocessing module is 'module'; mp classes are 'type'"
  kind: python_call_eq
  category: class_identity
  id_prefix: mp1936

  columns: [id, function, args, expected]
  rows:
    - ["mp1936033", "multiprocessing.__class__.__name__.__eq__",                         ["module"], true]
    - ["mp1936034", "multiprocessing.Process.__class__.__name__.__eq__",                 ["type"],   true]
    - ["mp1936035", "multiprocessing.synchronize.Lock.__class__.__name__.__eq__",        ["type"],   true]
    - ["mp1936036", "multiprocessing.synchronize.RLock.__class__.__name__.__eq__",       ["type"],   true]
    - ["mp1936037", "multiprocessing.synchronize.Event.__class__.__name__.__eq__",       ["type"],   true]
    - ["mp1936038", "multiprocessing.synchronize.Semaphore.__class__.__name__.__eq__",   ["type"],   true]
    - ["mp1936039", "multiprocessing.synchronize.Condition.__class__.__name__.__eq__",   ["type"],   true]
    - ["mp1936040", "multiprocessing.queues.Queue.__class__.__name__.__eq__",            ["type"],   true]
