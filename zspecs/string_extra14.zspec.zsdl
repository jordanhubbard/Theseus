spec: string_extra14
version: ">=3.9"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/string.py"
  notes:
    - "This spec extends string.zspec.zsdl and prior extras through string_extra13.zspec.zsdl."
    - "string_extra13 covers: ascii_lowercase.__contains__('a'/'z'); digits.__contains__('5'); octdigits.__contains__('7'/'8'); hexdigits.__contains__('9'); whitespace.__contains__(' '); ascii_lowercase[0]=='a'; ascii_uppercase[-1]=='Z'; capwords five words."
    - "string_extra12 covers: hexdigits/octdigits/printable/punctuation startswith; Formatter().vformat positional; capwords four-word; Template punctuation-suffix substitute."
    - "string_extra11 covers: digits.startswith; octdigits.endswith; hexdigits.endswith('F'); Formatter two kwargs; Template brace-delimited substitute; capwords single-word and all-caps multi-word."
    - "string_extra10 covers: Template.substitute positional dict; Template.safe_substitute missing key; Formatter().format positional and keyword."
    - "NOT yet covered: string.Template('Hello $name').substitute({'name': 'World'}) == 'Hello World' — dict passed positionally."
    - "NOT yet covered: string.Template('$x plus $y').substitute({'x': 'one', 'y': 'two'}) == 'one plus two' — two vars via dict."
    - "NOT yet covered: string.Template('${price} USD').substitute({'price': '10'}) == '10 USD' — brace-delimited with dict arg."
    - "NOT yet covered: string.Template('No vars').substitute({}) == 'No vars' — empty dict, no substitution."
    - "NOT yet covered: string.Template('$greeting').template == '$greeting' — .template attribute stores original string."
    - "NOT yet covered: string.Template.__bases__[0].__name__ == 'object' — Template base class."
    - "NOT yet covered: string.ascii_letters.__len__() == 52 — total letter count."
    - "NOT yet covered: string.digits.__len__() == 10 — ten decimal digits."
    - "NOT yet covered: string.ascii_lowercase.__len__() == 26 — twenty-six lowercase letters."
    - "NOT yet covered: string.ascii_uppercase.__len__() == 26 — twenty-six uppercase letters."
    - "string.Template('Hello $name').substitute({'name': 'World'}) == 'Hello World' — dict arg positionally."
    - "string.Template('$x plus $y').substitute({'x': 'one', 'y': 'two'}) == 'one plus two' — two vars via dict."
    - "string.Template('${price} USD').substitute({'price': '10'}) == '10 USD' — brace-delimited var with dict."
    - "string.Template('No vars').substitute({}) == 'No vars' — empty substitution dict leaves string unchanged."
    - "string.Template('$greeting').template == '$greeting' — .template attribute stores the original template string."
    - "string.Template.__bases__[0].__name__ == 'object' — Template inherits directly from object."
    - "string.ascii_letters.__len__() == 52 — 26 lowercase + 26 uppercase."
    - "string.digits.__len__() == 10 — ten decimal digit characters."
    - "string.ascii_lowercase.__len__() == 26 — twenty-six lowercase letters."
    - "string.ascii_uppercase.__len__() == 26 — twenty-six uppercase letters."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Template.substitute — dict passed as positional argument
#
# string_extra10 covers Template('$greeting world').substitute(greeting='Hello')
# using keyword arguments. string_extra11 covers brace-delimited keyword form.
# string_extra12 covers '$name!' with keyword.
# No prior spec passes a dict positionally to substitute():
# Template('Hello $name').substitute({'name': 'World'}) == 'Hello World'.
# ---------------------------------------------------------------------------

invariant string_extra14.Template.substitute_dict_positional:
  description: "string.Template('Hello $name').substitute({'name': 'World'}) == 'Hello World' — dict arg"
  category: Template
  kind: python_call_eq
  function: Template
  args: ["Hello $name"]
  method: substitute
  method_args: [{name: World}]
  expected: "Hello World"

invariant string_extra14.Template.substitute_two_vars_dict:
  description: "string.Template('$x plus $y').substitute({'x': 'one', 'y': 'two'}) == 'one plus two'"
  category: Template
  kind: python_call_eq
  function: Template
  args: ["$x plus $y"]
  method: substitute
  method_args: [{x: one, y: two}]
  expected: "one plus two"

invariant string_extra14.Template.substitute_brace_dict:
  description: "string.Template('${price} USD').substitute({'price': '10'}) == '10 USD' — brace-delimited via dict"
  category: Template
  kind: python_call_eq
  function: Template
  args: ["${price} USD"]
  method: substitute
  method_args: [{price: "10"}]
  expected: "10 USD"

invariant string_extra14.Template.substitute_empty_dict:
  description: "string.Template('No vars').substitute({}) == 'No vars' — empty dict, string unchanged"
  category: Template
  kind: python_call_eq
  function: Template
  args: ["No vars"]
  method: substitute
  method_args: [{}]
  expected: "No vars"

# ---------------------------------------------------------------------------
# Template — .template attribute
#
# No prior spec checks the .template attribute of a Template instance.
# Template stores the original template string in the .template attribute.
# Template('$greeting').template == '$greeting'.
# ---------------------------------------------------------------------------

invariant string_extra14.Template.template_attr:
  description: "string.Template('$greeting').template == '$greeting' — original string stored in .template"
  category: Template
  kind: python_call_eq
  function: Template
  args: ["$greeting"]
  method: template.__eq__
  method_args: ["$greeting"]
  expected: true

# ---------------------------------------------------------------------------
# Template — base class
#
# No prior spec checks Template.__bases__[0].__name__. Template inherits
# directly from object (no intermediate base class).
# ---------------------------------------------------------------------------

invariant string_extra14.Template.base_class:
  description: "string.Template.__bases__[0].__name__ == 'object' — Template inherits from object"
  category: Template
  kind: python_call_eq
  function: Template.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# Constant lengths — ascii_letters, digits, ascii_lowercase, ascii_uppercase
#
# string_extra8 covers __len__ for ascii_letters(52), digits(10), hexdigits(22),
# octdigits(8), punctuation(32), whitespace(6), printable(100).
# No prior spec tests ascii_lowercase.__len__() or ascii_uppercase.__len__()
# as standalone invariants. Both are 26.
# ---------------------------------------------------------------------------

invariant string_extra14.ascii_lowercase.len:
  description: "string.ascii_lowercase.__len__() == 26 — twenty-six lowercase letters"
  category: constants
  kind: python_call_eq
  function: ascii_lowercase.__len__
  args: []
  expected: 26

invariant string_extra14.ascii_uppercase.len:
  description: "string.ascii_uppercase.__len__() == 26 — twenty-six uppercase letters"
  category: constants
  kind: python_call_eq
  function: ascii_uppercase.__len__
  args: []
  expected: 26

# ---------------------------------------------------------------------------
# Table: Template.substitute with dict positional arg
#
# Groups the four dict-positional substitute vectors in one indexed table.
# No prior spec provides a table for Template.substitute with dict args.
# ---------------------------------------------------------------------------

table string_extra14.Template_substitute_dict:
  description: "Template.substitute with dict passed as positional argument"
  kind: python_call_eq
  category: Template
  id_prefix: tsd

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [hello_name,  Template, ["Hello $name"],   substitute, [{name: World}],        "Hello World"]
    - [two_vars,    Template, ["$x plus $y"],    substitute, [{x: one, y: two}],     "one plus two"]
    - [brace_dict,  Template, ["${price} USD"],  substitute, [{price: "10"}],        "10 USD"]
    - [empty_dict,  Template, ["No vars"],       substitute, [{}],                   "No vars"]

# ---------------------------------------------------------------------------
# Table: ascii_lowercase and ascii_uppercase __len__
#
# Groups the two length checks for the case-specific letter constants.
# ---------------------------------------------------------------------------

table string_extra14.case_letter_lengths:
  description: "ascii_lowercase and ascii_uppercase character counts"
  kind: python_call_eq
  category: constants
  id_prefix: cll

  columns: [id, function, args, expected]
  rows:
    - [lowercase_len, ascii_lowercase.__len__, [], 26]
    - [uppercase_len, ascii_uppercase.__len__, [], 26]
