spec: theseus_fractions_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_fractions_cr2)
blocks: fractions

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html"
  notes:
    - "Clean-room extended Fraction arithmetic. Do NOT import fractions."
    - "Fraction(numerator, denominator): exact rational number."
    - "Fraction arithmetic: +, -, *, / produce reduced Fraction results."
    - "Fraction.limit_denominator(max_denominator=1000000): best rational approximation."
    - "fractions2_add(): Fraction(1,2) + Fraction(1,3) == Fraction(5,6)."
    - "fractions2_mul(): Fraction(2,3) * Fraction(3,4) == Fraction(1,2)."
    - "fractions2_limit_denom(): Fraction(1,3).limit_denominator(10) == Fraction(1,3)."
    - "Use math.gcd for reduction (import math allowed)."
    - "limit_denominator: iterate denominators 1..max_den, find best approximation."
    - "fractions2_add(): (Fraction(1,2)+Fraction(1,3)).numerator == 5 and denominator == 6."
    - "fractions2_mul(): (Fraction(2,3)*Fraction(3,4)).numerator == 1."
    - "Export: Fraction."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_fractions_cr2.add:
  description: "Fraction(1,2) + Fraction(1,3) == Fraction(5,6)"
  category: arithmetic
  kind: python_call_eq
  function: fractions2_add
  args: []
  expected: true

invariant theseus_fractions_cr2.mul:
  description: "Fraction(2,3) * Fraction(3,4) has numerator == 1"
  category: arithmetic
  kind: python_call_eq
  function: fractions2_mul
  args: []
  expected: 1

invariant theseus_fractions_cr2.limit_denom:
  description: "Fraction(1,3).limit_denominator(10) == Fraction(1,3)"
  category: limit_denominator
  kind: python_call_eq
  function: fractions2_limit_denom
  args: []
  expected: true
