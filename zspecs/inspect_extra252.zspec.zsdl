spec: inspect_extra252
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.stack, inspect.currentframe, inspect.getouterframes, inspect.getinnerframes, inspect.getframeinfo function identity, and inspect.FrameInfo, inspect.Traceback class identity behavioral contracts."
    - "inspect.stack.__name__ == 'stack' — stack is a pure-Python function; __name__ is 'stack'. Verified with Python 3.14.3."
    - "inspect.stack.__module__ == 'inspect' — stack is defined in the inspect module; __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.stack.__class__.__name__ == 'function' — stack is a plain Python function; __class__.__name__ is 'function'. Verified with Python 3.14.3."
    - "inspect.currentframe.__name__ == 'currentframe' — currentframe is a pure-Python function wrapping sys._getframe; __name__ is 'currentframe'. Verified with Python 3.14.3."
    - "inspect.currentframe.__module__ == 'inspect' — currentframe is defined (re-exported) in the inspect module; __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.currentframe.__class__.__name__ == 'function' — currentframe is a plain Python function; __class__.__name__ is 'function'. Verified with Python 3.14.3."
    - "inspect.getouterframes.__name__ == 'getouterframes' — getouterframes is a pure-Python function; __name__ is 'getouterframes'. Verified with Python 3.14.3."
    - "inspect.getinnerframes.__name__ == 'getinnerframes' — getinnerframes is a pure-Python function; __name__ is 'getinnerframes'. Verified with Python 3.14.3."
    - "inspect.getframeinfo.__name__ == 'getframeinfo' — getframeinfo is a pure-Python function; __name__ is 'getframeinfo'. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__name__ == 'FrameInfo' — FrameInfo is a class; __name__ is 'FrameInfo'. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__module__ == 'inspect' — FrameInfo is defined in the inspect module; __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__bases__[0].__name__ == '_FrameInfo' — FrameInfo inherits from the internal _FrameInfo named tuple base; first base __name__ is '_FrameInfo'. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__class__.__name__ == 'type' — FrameInfo is a class whose metaclass is type; __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "inspect.Traceback.__name__ == 'Traceback' — Traceback is a class; __name__ is 'Traceback'. Verified with Python 3.14.3."
    - "inspect.Traceback.__module__ == 'inspect' — Traceback is defined in the inspect module; __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.Traceback.__bases__[0].__name__ == '_Traceback' — Traceback inherits from the internal _Traceback named tuple base; first base __name__ is '_Traceback'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.stack and inspect.currentframe function identity
#
# inspect.stack.__name__ == 'stack'
# inspect.stack.__module__ == 'inspect'
# inspect.stack.__class__.__name__ == 'function'
# inspect.currentframe.__name__ == 'currentframe'
# inspect.currentframe.__module__ == 'inspect'
# inspect.currentframe.__class__.__name__ == 'function'
#
# Both are pure-Python functions in the inspect module. New to extra252.
# ---------------------------------------------------------------------------

table inspect_extra252.stack_currentframe_identity:
  description: "inspect.stack and inspect.currentframe __name__, __module__, __class__.__name__ identity contracts; new to extra252"
  kind: python_call_eq
  category: identity
  id_prefix: inspstackframe252

  columns: [id, function, args, expected, description]
  rows:
    - [stack_name_eq,
       stack.__name__.__eq__,
       ["stack"],
       true,
       "inspect.stack.__name__.__eq__('stack') == True — stack is a pure-Python function returning a list of FrameInfo records for the call stack; __name__ is 'stack'; new to extra252"]
    - [stack_module_eq,
       stack.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.stack.__module__.__eq__('inspect') == True — stack is defined in the inspect module; __module__ is 'inspect'; new to extra252"]
    - [stack_class_name_eq,
       stack.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.stack.__class__.__name__.__eq__('function') == True — stack is a plain Python function; __class__.__name__ is 'function'; new to extra252"]
    - [currentframe_name_eq,
       currentframe.__name__.__eq__,
       ["currentframe"],
       true,
       "inspect.currentframe.__name__.__eq__('currentframe') == True — currentframe is a pure-Python function returning the current stack frame; __name__ is 'currentframe'; new to extra252"]
    - [currentframe_module_eq,
       currentframe.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.currentframe.__module__.__eq__('inspect') == True — currentframe is defined (re-exported) in the inspect module; __module__ is 'inspect'; new to extra252"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getouterframes, getinnerframes, getframeinfo identity
#
# inspect.getouterframes.__name__ == 'getouterframes'
# inspect.getouterframes.__module__ == 'inspect'
# inspect.getinnerframes.__name__ == 'getinnerframes'
# inspect.getinnerframes.__module__ == 'inspect'
# inspect.getframeinfo.__name__ == 'getframeinfo'
# inspect.getframeinfo.__module__ == 'inspect'
#
# All three are pure-Python functions in the inspect module. New to extra252.
# ---------------------------------------------------------------------------

table inspect_extra252.getouterframes_getinnerframes_getframeinfo_identity:
  description: "inspect.getouterframes, getinnerframes, getframeinfo __name__ and __module__ identity contracts; new to extra252"
  kind: python_call_eq
  category: identity
  id_prefix: inspgetframes252

  columns: [id, function, args, expected, description]
  rows:
    - [getouterframes_name_eq,
       getouterframes.__name__.__eq__,
       ["getouterframes"],
       true,
       "inspect.getouterframes.__name__.__eq__('getouterframes') == True — getouterframes returns FrameInfo records for all outer frames; __name__ is 'getouterframes'; new to extra252"]
    - [getouterframes_module_eq,
       getouterframes.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getouterframes.__module__.__eq__('inspect') == True — getouterframes is defined in the inspect module; __module__ is 'inspect'; new to extra252"]
    - [getinnerframes_name_eq,
       getinnerframes.__name__.__eq__,
       ["getinnerframes"],
       true,
       "inspect.getinnerframes.__name__.__eq__('getinnerframes') == True — getinnerframes returns FrameInfo records for a traceback's inner frames; __name__ is 'getinnerframes'; new to extra252"]
    - [getinnerframes_module_eq,
       getinnerframes.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getinnerframes.__module__.__eq__('inspect') == True — getinnerframes is defined in the inspect module; __module__ is 'inspect'; new to extra252"]
    - [getframeinfo_name_eq,
       getframeinfo.__name__.__eq__,
       ["getframeinfo"],
       true,
       "inspect.getframeinfo.__name__.__eq__('getframeinfo') == True — getframeinfo returns a Traceback named tuple for a frame or traceback object; __name__ is 'getframeinfo'; new to extra252"]

# ---------------------------------------------------------------------------
# Table 3: inspect.FrameInfo and inspect.Traceback class identity
#
# inspect.FrameInfo.__name__ == 'FrameInfo'
# inspect.FrameInfo.__module__ == 'inspect'
# inspect.FrameInfo.__bases__[0].__name__ == '_FrameInfo'
# inspect.FrameInfo.__class__.__name__ == 'type'
# inspect.Traceback.__name__ == 'Traceback'
# inspect.Traceback.__module__ == 'inspect'
# inspect.Traceback.__bases__[0].__name__ == '_Traceback'
# inspect.Traceback.__class__.__name__ == 'type'
#
# Both are named-tuple-derived classes defined in the inspect module.
# New to extra252.
# ---------------------------------------------------------------------------

table inspect_extra252.FrameInfo_Traceback_identity:
  description: "inspect.FrameInfo and inspect.Traceback __name__, __module__, __bases__[0].__name__, __class__.__name__ identity contracts; new to extra252"
  kind: python_call_eq
  category: identity
  id_prefix: inspframeinfo252

  columns: [id, function, args, expected, description]
  rows:
    - [frameinfo_name_eq,
       FrameInfo.__name__.__eq__,
       ["FrameInfo"],
       true,
       "inspect.FrameInfo.__name__.__eq__('FrameInfo') == True — FrameInfo is a named-tuple-derived class holding frame inspection results; __name__ is 'FrameInfo'; new to extra252"]
    - [frameinfo_module_eq,
       FrameInfo.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.FrameInfo.__module__.__eq__('inspect') == True — FrameInfo is defined in the inspect module; __module__ is 'inspect'; new to extra252"]
    - ["frameinfo_base0_name_eq",
       "FrameInfo.__bases__[0].__name__.__eq__",
       ["_FrameInfo"],
       true,
       "inspect.FrameInfo.__bases__[0].__name__.__eq__('_FrameInfo') == True — FrameInfo inherits from internal _FrameInfo named tuple base; first base __name__ is '_FrameInfo'; new to extra252"]
    - [traceback_name_eq,
       Traceback.__name__.__eq__,
       ["Traceback"],
       true,
       "inspect.Traceback.__name__.__eq__('Traceback') == True — Traceback is a named-tuple-derived class holding traceback information; __name__ is 'Traceback'; new to extra252"]
    - ["traceback_base0_name_eq",
       "Traceback.__bases__[0].__name__.__eq__",
       ["_Traceback"],
       true,
       "inspect.Traceback.__bases__[0].__name__.__eq__('_Traceback') == True — Traceback inherits from internal _Traceback named tuple base; first base __name__ is '_Traceback'; new to extra252"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra252
# ---------------------------------------------------------------------------

invariant inspect_extra252.stack.name_eq:
  description: "inspect.stack.__name__ == 'stack' — pure-Python function returning call stack as list of FrameInfo records; new to extra252"
  category: identity
  kind: python_call_eq
  function: stack.__name__.__eq__
  args: ["stack"]
  expected: true

invariant inspect_extra252.stack.module_eq:
  description: "inspect.stack.__module__ == 'inspect' — defined in the inspect module; new to extra252"
  category: identity
  kind: python_call_eq
  function: stack.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra252.stack.class_is_function:
  description: "inspect.stack.__class__.__name__ == 'function' — stack is a plain Python function; new to extra252"
  category: identity
  kind: python_call_eq
  function: stack.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra252.stack.name_len_5:
  description: "inspect.stack.__name__.__len__() == 5 — 'stack' has 5 characters; new to extra252"
  category: identity
  kind: python_call_eq
  function: stack.__name__.__len__
  args: []
  expected: 5

invariant inspect_extra252.currentframe.name_eq:
  description: "inspect.currentframe.__name__ == 'currentframe' — pure-Python function returning the current execution frame; new to extra252"
  category: identity
  kind: python_call_eq
  function: currentframe.__name__.__eq__
  args: ["currentframe"]
  expected: true

invariant inspect_extra252.currentframe.module_eq:
  description: "inspect.currentframe.__module__ == 'inspect' — currentframe is re-exported through the inspect module; __module__ is 'inspect'; new to extra252"
  category: identity
  kind: python_call_eq
  function: currentframe.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra252.currentframe.class_is_function:
  description: "inspect.currentframe.__class__.__name__ == 'function' — currentframe is a plain Python function; new to extra252"
  category: identity
  kind: python_call_eq
  function: currentframe.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra252.currentframe.name_len_12:
  description: "inspect.currentframe.__name__.__len__() == 12 — 'currentframe' has 12 characters; new to extra252"
  category: identity
  kind: python_call_eq
  function: currentframe.__name__.__len__
  args: []
  expected: 12

invariant inspect_extra252.getouterframes.name_eq:
  description: "inspect.getouterframes.__name__ == 'getouterframes' — pure-Python function returning FrameInfo records for outer frames; new to extra252"
  category: identity
  kind: python_call_eq
  function: getouterframes.__name__.__eq__
  args: ["getouterframes"]
  expected: true

invariant inspect_extra252.getouterframes.module_eq:
  description: "inspect.getouterframes.__module__ == 'inspect' — defined in the inspect module; new to extra252"
  category: identity
  kind: python_call_eq
  function: getouterframes.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra252.getinnerframes.name_eq:
  description: "inspect.getinnerframes.__name__ == 'getinnerframes' — pure-Python function returning FrameInfo records for traceback inner frames; new to extra252"
  category: identity
  kind: python_call_eq
  function: getinnerframes.__name__.__eq__
  args: ["getinnerframes"]
  expected: true

invariant inspect_extra252.getinnerframes.module_eq:
  description: "inspect.getinnerframes.__module__ == 'inspect' — defined in the inspect module; new to extra252"
  category: identity
  kind: python_call_eq
  function: getinnerframes.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra252.getframeinfo.name_eq:
  description: "inspect.getframeinfo.__name__ == 'getframeinfo' — pure-Python function returning a Traceback record for a frame or traceback; new to extra252"
  category: identity
  kind: python_call_eq
  function: getframeinfo.__name__.__eq__
  args: ["getframeinfo"]
  expected: true

invariant inspect_extra252.getframeinfo.module_eq:
  description: "inspect.getframeinfo.__module__ == 'inspect' — defined in the inspect module; new to extra252"
  category: identity
  kind: python_call_eq
  function: getframeinfo.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra252.FrameInfo.name_eq:
  description: "inspect.FrameInfo.__name__ == 'FrameInfo' — named-tuple-derived class for frame inspection results; new to extra252"
  category: identity
  kind: python_call_eq
  function: FrameInfo.__name__.__eq__
  args: ["FrameInfo"]
  expected: true

invariant inspect_extra252.FrameInfo.module_eq:
  description: "inspect.FrameInfo.__module__ == 'inspect' — FrameInfo is defined in the inspect module; new to extra252"
  category: identity
  kind: python_call_eq
  function: FrameInfo.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra252.FrameInfo.class_is_type:
  description: "inspect.FrameInfo.__class__.__name__ == 'type' — FrameInfo is a class whose metaclass is type; new to extra252"
  category: identity
  kind: python_call_eq
  function: FrameInfo.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra252.Traceback.name_eq:
  description: "inspect.Traceback.__name__ == 'Traceback' — named-tuple-derived class for traceback information; new to extra252"
  category: identity
  kind: python_call_eq
  function: Traceback.__name__.__eq__
  args: ["Traceback"]
  expected: true

invariant inspect_extra252.Traceback.module_eq:
  description: "inspect.Traceback.__module__ == 'inspect' — Traceback is defined in the inspect module; new to extra252"
  category: identity
  kind: python_call_eq
  function: Traceback.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra252.Traceback.class_is_type:
  description: "inspect.Traceback.__class__.__name__ == 'type' — Traceback is a class whose metaclass is type; new to extra252"
  category: identity
  kind: python_call_eq
  function: Traceback.__class__.__name__.__eq__
  args: ["type"]
  expected: true
