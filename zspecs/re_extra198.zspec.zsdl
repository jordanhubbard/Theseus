spec: re_extra198
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers re module function name lengths not covered by prior re_extra specs."
    - "re.match.__name__.__len__() == 5 — m(1)a(2)t(3)c(4)h(5); confirmed Python 3.14.3 macOS."
    - "re.search.__name__.__len__() == 6 — s(1)e(2)a(3)r(4)c(5)h(6); confirmed Python 3.14.3 macOS."
    - "re.findall.__name__.__len__() == 7 — f(1)i(2)n(3)d(4)a(5)l(6)l(7); confirmed Python 3.14.3 macOS."
    - "re.finditer.__name__.__len__() == 8 — f(1)i(2)n(3)d(4)i(5)t(6)e(7)r(8); confirmed Python 3.14.3 macOS."
    - "re.sub.__name__.__len__() == 3 — s(1)u(2)b(3); confirmed Python 3.14.3 macOS."
    - "re.subn.__name__.__len__() == 4 — s(1)u(2)b(3)n(4); confirmed Python 3.14.3 macOS."
    - "re.split.__name__.__len__() == 5 — s(1)p(2)l(3)i(4)t(5); confirmed Python 3.14.3 macOS."
    - "re.compile.__name__.__len__() == 7 — c(1)o(2)m(3)p(4)i(5)l(6)e(7); confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re function name lengths — match, search, findall
# match(5), search(6), findall(7)
# ---------------------------------------------------------------------------

table re_extra198.short_to_medium_name_lengths:
  description: "re function name lengths: match(5), search(6), findall(7)"
  kind: python_call_eq
  category: identity
  id_prefix: refuncnamelens198

  columns: [id, function, args, expected, description]
  rows:
    - [match_name_len,   re.match.__name__.__len__,   [], 5, "re.match.__name__.__len__() == 5 — m(1)a(2)t(3)c(4)h(5); confirmed Python 3.14.3 macOS"]
    - [search_name_len,  re.search.__name__.__len__,  [], 6, "re.search.__name__.__len__() == 6 — s(1)e(2)a(3)r(4)c(5)h(6); confirmed Python 3.14.3 macOS"]
    - [findall_name_len, re.findall.__name__.__len__,  [], 7, "re.findall.__name__.__len__() == 7 — f(1)i(2)n(3)d(4)a(5)l(6)l(7); confirmed Python 3.14.3 macOS"]
    - [match_name_eq,    re.match.__name__.__eq__,    ["match"],   true, "re.match.__name__ == 'match' (len=5); the function name matches the public API name; confirmed Python 3.14.3 macOS"]
    - [search_name_eq,   re.search.__name__.__eq__,   ["search"],  true, "re.search.__name__ == 'search' (len=6); the function name matches the public API name; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re function name lengths — finditer, sub, subn
# finditer(8), sub(3), subn(4)
# ---------------------------------------------------------------------------

table re_extra198.finditer_sub_subn_name_lengths:
  description: "re function name lengths: finditer(8), sub(3), subn(4)"
  kind: python_call_eq
  category: identity
  id_prefix: refuncnamelens198

  columns: [id, function, args, expected, description]
  rows:
    - [finditer_name_len, re.finditer.__name__.__len__, [], 8, "re.finditer.__name__.__len__() == 8 — f(1)i(2)n(3)d(4)i(5)t(6)e(7)r(8); confirmed Python 3.14.3 macOS"]
    - [sub_name_len,      re.sub.__name__.__len__,      [], 3, "re.sub.__name__.__len__() == 3 — s(1)u(2)b(3); the shortest re function name; confirmed Python 3.14.3 macOS"]
    - [subn_name_len,     re.subn.__name__.__len__,     [], 4, "re.subn.__name__.__len__() == 4 — s(1)u(2)b(3)n(4); subn returns (new_string, n_subs); confirmed Python 3.14.3 macOS"]
    - [finditer_name_eq,  re.finditer.__name__.__eq__,  ["finditer"], true, "re.finditer.__name__ == 'finditer' (len=8); finditer returns an iterator of match objects; confirmed Python 3.14.3 macOS"]
    - [sub_name_eq,       re.sub.__name__.__eq__,       ["sub"],      true, "re.sub.__name__ == 'sub' (len=3); sub performs substring replacement; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re function name lengths — split, compile
# split(5), compile(7)
# ---------------------------------------------------------------------------

table re_extra198.split_compile_name_lengths:
  description: "re function name lengths: split(5), compile(7)"
  kind: python_call_eq
  category: identity
  id_prefix: refuncnamelens198

  columns: [id, function, args, expected, description]
  rows:
    - [split_name_len,    re.split.__name__.__len__,   [], 5, "re.split.__name__.__len__() == 5 — s(1)p(2)l(3)i(4)t(5); confirmed Python 3.14.3 macOS"]
    - [compile_name_len,  re.compile.__name__.__len__, [], 7, "re.compile.__name__.__len__() == 7 — c(1)o(2)m(3)p(4)i(5)l(6)e(7); confirmed Python 3.14.3 macOS"]
    - [split_name_eq,     re.split.__name__.__eq__,    ["split"],   true, "re.split.__name__ == 'split' (len=5); split divides a string by pattern matches; confirmed Python 3.14.3 macOS"]
    - [compile_name_eq,   re.compile.__name__.__eq__,  ["compile"], true, "re.compile.__name__ == 'compile' (len=7); compile creates a compiled regex pattern object; confirmed Python 3.14.3 macOS"]
    - [subn_name_eq,      re.subn.__name__.__eq__,     ["subn"],    true, "re.subn.__name__ == 'subn' (len=4); subn returns a tuple (new_string, n_substitutions); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra198.match_name_len:
  description: "re.match.__name__.__len__() == 5 — 'match' has 5 characters: m(1)a(2)t(3)c(4)h(5); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.match.__name__.__len__
  args: []
  expected: 5

invariant re_extra198.search_name_len:
  description: "re.search.__name__.__len__() == 6 — 'search' has 6 characters: s(1)e(2)a(3)r(4)c(5)h(6); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.search.__name__.__len__
  args: []
  expected: 6

invariant re_extra198.findall_name_len:
  description: "re.findall.__name__.__len__() == 7 — 'findall' has 7 characters: f(1)i(2)n(3)d(4)a(5)l(6)l(7); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.findall.__name__.__len__
  args: []
  expected: 7

invariant re_extra198.finditer_name_len:
  description: "re.finditer.__name__.__len__() == 8 — 'finditer' has 8 characters: f(1)i(2)n(3)d(4)i(5)t(6)e(7)r(8); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.finditer.__name__.__len__
  args: []
  expected: 8

invariant re_extra198.sub_name_len:
  description: "re.sub.__name__.__len__() == 3 — 'sub' has 3 characters: s(1)u(2)b(3); the shortest public re function name; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.sub.__name__.__len__
  args: []
  expected: 3

invariant re_extra198.subn_name_len:
  description: "re.subn.__name__.__len__() == 4 — 'subn' has 4 characters: s(1)u(2)b(3)n(4); subn returns (string, count); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.subn.__name__.__len__
  args: []
  expected: 4

invariant re_extra198.split_name_len:
  description: "re.split.__name__.__len__() == 5 — 'split' has 5 characters: s(1)p(2)l(3)i(4)t(5); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.split.__name__.__len__
  args: []
  expected: 5

invariant re_extra198.compile_name_len:
  description: "re.compile.__name__.__len__() == 7 — 'compile' has 7 characters: c(1)o(2)m(3)p(4)i(5)l(6)e(7); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.compile.__name__.__len__
  args: []
  expected: 7

