spec: io_extra2506
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra.zspec.zsdl — covers DEFAULT_BUFFER_SIZE, SEEK_* constants, TextIOWrapper/BufferedRandom/UnsupportedOperation class metadata"
  notes:
    - "Theme: __add__, __sub__, __mul__ arithmetic operator dict-presence for io classes."
    - "Checks whether io stream classes define arithmetic operators directly in their class __dict__."
    - "io.IOBase, RawIOBase, BufferedIOBase, TextIOBase, BytesIO, StringIO, FileIO are I/O protocol classes, not numeric types."
    - "None of these classes define __add__, __sub__, or __mul__ in their own __dict__."
    - "io.IOBase.__dict__ contains only: __abstractmethods__, __doc__, __firstlineno__, __module__, __static_attributes__."
    - "io.BytesIO.__dict__ contains: __new__, __iter__, __next__, __init__, __getstate__, __setstate__, __sizeof__, __doc__, __module__ — no arithmetic operators."
    - "io.StringIO.__dict__ contains: __doc__, __getstate__, __init__, __module__, __new__, __next__, __setstate__ — no arithmetic operators."
    - "io.FileIO.__dict__ contains read, write, __init__ and similar I/O methods — no arithmetic operators."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io.IOBase, RawIOBase, BufferedIOBase — arithmetic operators absent
#
# These are abstract base classes for the I/O hierarchy. They define no
# arithmetic operators; their __dict__ contains only abstract-method machinery
# and documentation attributes.
# ---------------------------------------------------------------------------

table io_extra2506.abstract_bases_arith:
  description: "__add__, __sub__, __mul__ absent from io.IOBase, RawIOBase, BufferedIOBase __dict__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: io2506

  columns: [id, function, args, expected]
  rows:
    - ["io2506-001", "IOBase.__dict__.__contains__",       ["__add__"], false]
    - ["io2506-002", "IOBase.__dict__.__contains__",       ["__sub__"], false]
    - ["io2506-003", "IOBase.__dict__.__contains__",       ["__mul__"], false]
    - ["io2506-004", "RawIOBase.__dict__.__contains__",    ["__add__"], false]
    - ["io2506-005", "RawIOBase.__dict__.__contains__",    ["__sub__"], false]
    - ["io2506-006", "RawIOBase.__dict__.__contains__",    ["__mul__"], false]
    - ["io2506-007", "BufferedIOBase.__dict__.__contains__", ["__add__"], false]
    - ["io2506-008", "BufferedIOBase.__dict__.__contains__", ["__sub__"], false]
    - ["io2506-009", "BufferedIOBase.__dict__.__contains__", ["__mul__"], false]

# ---------------------------------------------------------------------------
# Table 2: io.TextIOBase, io.BytesIO, io.StringIO — arithmetic operators absent
#
# TextIOBase is the abstract base for text streams. BytesIO and StringIO are
# the concrete in-memory stream implementations. None define arithmetic ops.
# ---------------------------------------------------------------------------

table io_extra2506.text_bytes_str_arith:
  description: "__add__, __sub__, __mul__ absent from io.TextIOBase, BytesIO, StringIO __dict__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: io2506

  columns: [id, function, args, expected]
  rows:
    - ["io2506-010", "TextIOBase.__dict__.__contains__", ["__add__"], false]
    - ["io2506-011", "TextIOBase.__dict__.__contains__", ["__sub__"], false]
    - ["io2506-012", "TextIOBase.__dict__.__contains__", ["__mul__"], false]
    - ["io2506-013", "BytesIO.__dict__.__contains__",    ["__add__"], false]
    - ["io2506-014", "BytesIO.__dict__.__contains__",    ["__sub__"], false]
    - ["io2506-015", "BytesIO.__dict__.__contains__",    ["__mul__"], false]
    - ["io2506-016", "StringIO.__dict__.__contains__",   ["__add__"], false]
    - ["io2506-017", "StringIO.__dict__.__contains__",   ["__sub__"], false]
    - ["io2506-018", "StringIO.__dict__.__contains__",   ["__mul__"], false]

# ---------------------------------------------------------------------------
# Table 3: io.FileIO — arithmetic operators absent; positive anchors
#
# FileIO is the raw file I/O class. Arithmetic operators are absent.
# Positive anchors confirm that __dict__.__contains__ works correctly
# by checking attributes that ARE present.
# ---------------------------------------------------------------------------

table io_extra2506.fileio_arith_and_anchors:
  description: "__add__, __sub__, __mul__ absent from io.FileIO; __init__ and read present as anchors"
  kind: python_call_eq
  category: dict_presence
  id_prefix: io2506

  columns: [id, function, args, expected]
  rows:
    - ["io2506-019", "FileIO.__dict__.__contains__", ["__add__"], false]
    - ["io2506-020", "FileIO.__dict__.__contains__", ["__sub__"], false]
    - ["io2506-021", "FileIO.__dict__.__contains__", ["__mul__"], false]
    - ["io2506-022", "FileIO.__dict__.__contains__", ["__init__"], true]
    - ["io2506-023", "FileIO.__dict__.__contains__", ["read"],     true]
    - ["io2506-024", "BytesIO.__dict__.__contains__", ["__init__"], true]
    - ["io2506-025", "StringIO.__dict__.__contains__", ["__init__"], true]
