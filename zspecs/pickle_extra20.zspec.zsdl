spec: pickle_extra20
version: ">=3.9"
backend: python_module(pickle)

docs: https://docs.python.org/3/library/pickle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pickle.html — Python pickle module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pickle.py"
    - "CPython source: Modules/_pickle.c"
  notes:
    - "This spec extends pickle.zspec.zsdl through pickle_extra19.zspec.zsdl."
    - "pickle_extra19 covers: dump/__module__; load/__module__; PickleError/PicklingError/UnpicklingError __qualname__.__class__.__name__ type axis."
    - "pickle_extra18 covers: Pickler.__init__/__qualname__; Unpickler.__init__/__qualname__; PickleBuffer/__qualname__.__class__.__name__."
    - "pickle_extra14 covers: Pickler/__qualname__; Unpickler/__qualname__; PickleBuffer/__qualname__; loads/__qualname__; load/__qualname__; dump/__qualname__."
    - "pickle_extra13 covers: dumps/__qualname__; PickleError/PicklingError/UnpicklingError __name__."
    - "pickle_extra12 covers: PickleError/PicklingError/UnpicklingError __module__; dumps/__module__; loads/__module__; Pickler/__module__; Unpickler/__module__."
    - "pickle_extra11 covers: PickleError/__bases__[0].__name__; PicklingError/__bases__[0].__name__; UnpicklingError/__bases__[0].__name__."
    - "Focus: __bases__[0].__name__ for Pickler and Unpickler; __bases__[0].__qualname__ axis for Pickler, Unpickler, PickleError, PicklingError, and UnpicklingError; __module__ type axis for dump/loads."
    - "No prior pickle spec checks Pickler.__bases__[0].__name__."
    - "No prior pickle spec checks Unpickler.__bases__[0].__name__."
    - "No prior pickle spec checks Pickler.__bases__[0].__qualname__."
    - "No prior pickle spec checks Unpickler.__bases__[0].__qualname__."
    - "No prior pickle spec checks PickleError.__bases__[0].__qualname__."
    - "No prior pickle spec checks PicklingError.__bases__[0].__qualname__."
    - "No prior pickle spec checks UnpicklingError.__bases__[0].__qualname__."
    - "No prior pickle spec checks dump.__module__.__class__.__name__ (type axis)."
    - "No prior pickle spec checks loads.__module__.__class__.__name__ (type axis)."
    - "pickle.Pickler.__bases__[0].__name__ == 'object' — Pickler's pure-Python base is object."
    - "pickle.Unpickler.__bases__[0].__name__ == 'object' — Unpickler's pure-Python base is object."
    - "pickle.Pickler.__bases__[0].__qualname__ == 'object' — for top-level classes, qualname equals name."
    - "pickle.Unpickler.__bases__[0].__qualname__ == 'object' — for top-level classes, qualname equals name."
    - "pickle.PickleError.__bases__[0].__qualname__ == 'Exception' — PickleError inherits from Exception."
    - "pickle.PicklingError.__bases__[0].__qualname__ == 'PickleError' — PicklingError inherits from PickleError."
    - "pickle.UnpicklingError.__bases__[0].__qualname__ == 'PickleError' — UnpicklingError inherits from PickleError."
    - "pickle.dump.__module__.__class__.__name__ == 'str' — __module__ attribute is always a string."
    - "pickle.loads.__module__.__class__.__name__ == 'str' — __module__ attribute is always a string."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Pickler and Unpickler — __bases__[0].__name__
#
# pickle_extra11 checks __bases__[0].__name__ for PickleError, PicklingError,
# and UnpicklingError.  No prior pickle spec checks __bases__[0].__name__ for
# the Pickler or Unpickler classes.  Both inherit from object.
# ---------------------------------------------------------------------------

invariant pickle_extra20.Pickler.base_name:
  description: "pickle.Pickler.__bases__[0].__name__ == 'object' — Pickler inherits from object"
  category: class_attrs
  kind: python_call_eq
  function: "Pickler.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant pickle_extra20.Unpickler.base_name:
  description: "pickle.Unpickler.__bases__[0].__name__ == 'object' — Unpickler inherits from object"
  category: class_attrs
  kind: python_call_eq
  function: "Unpickler.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# __bases__[0].__qualname__ for Pickler, Unpickler, and exception classes
#
# No prior pickle spec checks the __qualname__ of any base class.  For
# top-level built-in classes (object, Exception, PickleError), __qualname__
# equals __name__.  PicklingError and UnpicklingError both inherit from
# PickleError, so their base's __qualname__ is 'PickleError'.
# ---------------------------------------------------------------------------

invariant pickle_extra20.Pickler.base_qualname:
  description: "pickle.Pickler.__bases__[0].__qualname__ == 'object' — base class qualname equals name"
  category: class_attrs
  kind: python_call_eq
  function: "Pickler.__bases__[0].__qualname__.__eq__"
  args: ["object"]
  expected: true

invariant pickle_extra20.Unpickler.base_qualname:
  description: "pickle.Unpickler.__bases__[0].__qualname__ == 'object' — base class qualname equals name"
  category: class_attrs
  kind: python_call_eq
  function: "Unpickler.__bases__[0].__qualname__.__eq__"
  args: ["object"]
  expected: true

invariant pickle_extra20.PickleError.base_qualname:
  description: "pickle.PickleError.__bases__[0].__qualname__ == 'Exception' — base class qualname equals name"
  category: class_attrs
  kind: python_call_eq
  function: "PickleError.__bases__[0].__qualname__.__eq__"
  args: ["Exception"]
  expected: true

invariant pickle_extra20.PicklingError.base_qualname:
  description: "pickle.PicklingError.__bases__[0].__qualname__ == 'PickleError' — PicklingError inherits from PickleError"
  category: class_attrs
  kind: python_call_eq
  function: "PicklingError.__bases__[0].__qualname__.__eq__"
  args: ["PickleError"]
  expected: true

invariant pickle_extra20.UnpicklingError.base_qualname:
  description: "pickle.UnpicklingError.__bases__[0].__qualname__ == 'PickleError' — UnpicklingError inherits from PickleError"
  category: class_attrs
  kind: python_call_eq
  function: "UnpicklingError.__bases__[0].__qualname__.__eq__"
  args: ["PickleError"]
  expected: true

# ---------------------------------------------------------------------------
# Type axis for function __module__ strings
#
# pickle_extra19 checks the values of dump.__module__ and load.__module__.
# pickle_extra12 checks the values of dumps.__module__ and loads.__module__.
# No prior pickle spec checks the type (__class__.__name__) of those __module__
# attributes.  A function's __module__ is always a plain str.
# ---------------------------------------------------------------------------

invariant pickle_extra20.dump.module.class_name:
  description: "pickle.dump.__module__.__class__.__name__ == 'str' — __module__ is a string"
  category: type_attrs
  kind: python_call_eq
  function: dump.__module__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant pickle_extra20.loads.module.class_name:
  description: "pickle.loads.__module__.__class__.__name__ == 'str' — __module__ is a string"
  category: type_attrs
  kind: python_call_eq
  function: loads.__module__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all nine new invariants
#
# All nine are first covered in this spec (pickle_extra20).
# ---------------------------------------------------------------------------

table pickle_extra20.base_names_qualnames_and_module_types:
  description: "pickle Pickler/Unpickler base name, five-class base qualnames, function __module__ type axis"
  kind: python_call_eq
  category: class_attrs
  id_prefix: pbq20

  columns: [id, function, args, expected]
  rows:
    - [Pickler_base_name,        "Pickler.__bases__[0].__name__.__eq__",        ["object"],     true]
    - [Unpickler_base_name,      "Unpickler.__bases__[0].__name__.__eq__",      ["object"],     true]
    - [Pickler_base_qn,          "Pickler.__bases__[0].__qualname__.__eq__",    ["object"],     true]
    - [Unpickler_base_qn,        "Unpickler.__bases__[0].__qualname__.__eq__",  ["object"],     true]
    - [PickleError_base_qn,      "PickleError.__bases__[0].__qualname__.__eq__",    ["Exception"],  true]
    - [PicklingError_base_qn,    "PicklingError.__bases__[0].__qualname__.__eq__",  ["PickleError"], true]
    - [UnpicklingError_base_qn,  "UnpicklingError.__bases__[0].__qualname__.__eq__", ["PickleError"], true]
    - [dump_mod_type,            dump.__module__.__class__.__name__.__eq__,     ["str"],        true]
    - [loads_mod_type,           loads.__module__.__class__.__name__.__eq__,    ["str"],        true]
