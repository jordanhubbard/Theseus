spec: uuid_extra1591
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — descriptor protocol checks via __dict__.__contains__ for uuid.UUID and uuid.SafeUUID"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for descriptor protocol"
    - "uuid.UUID is a value object: it does not implement the descriptor protocol (__get__, __set__, __delete__) in its own __dict__."
    - "uuid.UUID exposes many read-only attributes via property descriptors: hex, bytes, bytes_le, fields, int, urn, variant, version, time_low, time_mid, time_hi_version, clock_seq_hi_variant, clock_seq_low, node."
    - "uuid.SafeUUID is an IntEnum subclass and also does not implement the descriptor protocol in its own __dict__."
  created_at: "2026-04-12"
error_model: python_exceptions

table uuid_extra1591.uuid_no_descriptor:
  description: "uuid.UUID and uuid.SafeUUID do not define descriptor protocol methods in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1591nd

  columns: [id, function, args, expected]
  rows:
    - ["uu1591nd001", "uuid.UUID.__dict__.__contains__",     ["__get__"],    false]
    - ["uu1591nd002", "uuid.UUID.__dict__.__contains__",     ["__set__"],    false]
    - ["uu1591nd003", "uuid.UUID.__dict__.__contains__",     ["__delete__"], false]
    - ["uu1591nd004", "uuid.UUID.__dict__.__contains__",     ["__set_name__"], false]
    - ["uu1591nd005", "uuid.SafeUUID.__dict__.__contains__", ["__get__"],    false]
    - ["uu1591nd006", "uuid.SafeUUID.__dict__.__contains__", ["__set__"],    false]
    - ["uu1591nd007", "uuid.SafeUUID.__dict__.__contains__", ["__delete__"], false]
    - ["uu1591nd008", "uuid.SafeUUID.__dict__.__contains__", ["__set_name__"], false]
    - ["uu1591nd009", "uuid.UUID.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
    - ["uu1591nd010", "uuid.UUID.__name__.__eq__",           ["UUID"],     true]
    - ["uu1591nd011", "uuid.UUID.__module__.__eq__",         ["uuid"],     true]
    - ["uu1591nd012", "uuid.SafeUUID.__name__.__eq__",       ["SafeUUID"], true]
    - ["uu1591nd013", "uuid.SafeUUID.__module__.__eq__",     ["uuid"],     true]
    - ["uu1591nd014", "uuid.UUID.__bases__.__len__",         [],           1]
    - ["uu1591nd015", "uuid.UUID.__mro__.__class__.__name__.__eq__", ["tuple"], true]

table uuid_extra1591.uuid_properties_present:
  description: "uuid.UUID exposes read-only attributes as property descriptors defined in its __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1591pp

  columns: [id, function, args, expected]
  rows:
    - ["uu1591pp001", "uuid.UUID.__dict__.__contains__", ["hex"],                  true]
    - ["uu1591pp002", "uuid.UUID.__dict__.__contains__", ["bytes"],                true]
    - ["uu1591pp003", "uuid.UUID.__dict__.__contains__", ["bytes_le"],             true]
    - ["uu1591pp004", "uuid.UUID.__dict__.__contains__", ["fields"],               true]
    - ["uu1591pp005", "uuid.UUID.__dict__.__contains__", ["int"],                  true]
    - ["uu1591pp006", "uuid.UUID.__dict__.__contains__", ["urn"],                  true]
    - ["uu1591pp007", "uuid.UUID.__dict__.__contains__", ["variant"],              true]
    - ["uu1591pp008", "uuid.UUID.__dict__.__contains__", ["version"],              true]
    - ["uu1591pp009", "uuid.UUID.__dict__.__contains__", ["time_low"],             true]
    - ["uu1591pp010", "uuid.UUID.__dict__.__contains__", ["time_mid"],             true]
    - ["uu1591pp011", "uuid.UUID.__dict__.__contains__", ["time_hi_version"],      true]
    - ["uu1591pp012", "uuid.UUID.__dict__.__contains__", ["clock_seq_hi_variant"], true]
    - ["uu1591pp013", "uuid.UUID.__dict__.__contains__", ["clock_seq_low"],        true]
    - ["uu1591pp014", "uuid.UUID.__dict__.__contains__", ["node"],                 true]
    - ["uu1591pp015", "uuid.UUID.__dict__.__contains__", ["time"],                 true]
    - ["uu1591pp016", "uuid.UUID.__dict__.__contains__", ["clock_seq"],            true]
    - ["uu1591pp017", "uuid.UUID.__dict__.__contains__", ["__init__"],             true]
    - ["uu1591pp018", "uuid.UUID.__dict__.__contains__", ["__repr__"],             true]
    - ["uu1591pp019", "uuid.UUID.__dict__.__contains__", ["__str__"],              true]
    - ["uu1591pp020", "uuid.UUID.__dict__.__contains__", ["__eq__"],               true]
    - ["uu1591pp021", "uuid.UUID.__dict__.__contains__", ["__lt__"],               true]
    - ["uu1591pp022", "uuid.UUID.__dict__.__contains__", ["__hash__"],             true]
    - ["uu1591pp023", "uuid.UUID.__dict__.__contains__", ["__int__"],              true]
    - ["uu1591pp024", "uuid.UUID.__dict__.__contains__", ["__setattr__"],          true]
    - ["uu1591pp025", "uuid.UUID.__dict__.__contains__", ["__weakref__"],          false]

table uuid_extra1591.uuid_properties_are_descriptors:
  description: "The attribute entries in uuid.UUID.__dict__ for read-only fields are property objects, which are themselves data descriptors"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1591pd

  columns: [id, function, args, expected]
  rows:
    - ["uu1591pd001", "isinstance(uuid.UUID.__dict__['hex'], property).__eq__",                  [true], true]
    - ["uu1591pd002", "isinstance(uuid.UUID.__dict__['bytes'], property).__eq__",                [true], true]
    - ["uu1591pd003", "isinstance(uuid.UUID.__dict__['bytes_le'], property).__eq__",             [true], true]
    - ["uu1591pd004", "isinstance(uuid.UUID.__dict__['int'], property).__eq__",                  [true], true]
    - ["uu1591pd005", "isinstance(uuid.UUID.__dict__['fields'], property).__eq__",               [true], true]
    - ["uu1591pd006", "isinstance(uuid.UUID.__dict__['urn'], property).__eq__",                  [true], true]
    - ["uu1591pd007", "isinstance(uuid.UUID.__dict__['variant'], property).__eq__",              [true], true]
    - ["uu1591pd008", "isinstance(uuid.UUID.__dict__['version'], property).__eq__",              [true], true]
    - ["uu1591pd009", "isinstance(uuid.UUID.__dict__['time_low'], property).__eq__",             [true], true]
    - ["uu1591pd010", "isinstance(uuid.UUID.__dict__['time_mid'], property).__eq__",             [true], true]
    - ["uu1591pd011", "isinstance(uuid.UUID.__dict__['time_hi_version'], property).__eq__",      [true], true]
    - ["uu1591pd012", "isinstance(uuid.UUID.__dict__['clock_seq_hi_variant'], property).__eq__", [true], true]
    - ["uu1591pd013", "isinstance(uuid.UUID.__dict__['clock_seq_low'], property).__eq__",        [true], true]
    - ["uu1591pd014", "isinstance(uuid.UUID.__dict__['node'], property).__eq__",                 [true], true]
    - ["uu1591pd015", "isinstance(uuid.UUID.__dict__['time'], property).__eq__",                 [true], true]
    - ["uu1591pd016", "isinstance(uuid.UUID.__dict__['clock_seq'], property).__eq__",            [true], true]
    - ["uu1591pd017", "property.__dict__.__contains__",                                          ["__get__"], true]
    - ["uu1591pd018", "property.__dict__.__contains__",                                          ["__set__"], true]
    - ["uu1591pd019", "property.__dict__.__contains__",                                          ["__delete__"], true]
    - ["uu1591pd020", "uuid.UUID.__dict__['hex'].__class__.__name__.__eq__",                     ["property"], true]
    - ["uu1591pd021", "uuid.UUID.__dict__['int'].__class__.__name__.__eq__",                     ["property"], true]
    - ["uu1591pd022", "uuid.UUID.__dict__['bytes'].__class__.__name__.__eq__",                   ["property"], true]
    - ["uu1591pd023", "isinstance(uuid.UUID.__dict__['hex'], property).__eq__",                  [false], false]
    - ["uu1591pd024", "uuid.UUID.__dict__['hex'].fset.__eq__",                                   [None], true]
    - ["uu1591pd025", "uuid.UUID.__dict__['int'].fset.__eq__",                                   [None], true]
