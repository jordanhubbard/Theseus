spec: re_extra257
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers re.Match and re.Pattern attribute descriptor identity."
    - "re.Match.lastgroup is a getset_descriptor — a C-level property with getter/setter."
    - "re.Match.lastindex is a getset_descriptor — a C-level property with getter/setter."
    - "re.Match.endpos is a member_descriptor — a C-level slot member (read-only integer slot)."
    - "re.Match.string is a member_descriptor — a C-level slot member for the matched string."
    - "re.Match.pos is a member_descriptor — a C-level slot member for the start search position."
    - "re.Match.re is a member_descriptor — a C-level slot member for the compiled pattern."
    - "re.Pattern.pattern is a member_descriptor — a C-level slot member for the pattern string."
    - "re.Pattern.flags is a member_descriptor — a C-level slot member for the pattern flags."
    - "re.Pattern.groups is a member_descriptor — a C-level slot member for the group count."
    - "re.Pattern.groupindex is a getset_descriptor — a C-level property for the group name mapping."
    - "getset_descriptor: __class__.__name__ == 'getset_descriptor' — C-level get/set descriptor."
    - "member_descriptor: __class__.__name__ == 'member_descriptor' — C-level slot member descriptor."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re.Match attribute descriptor identity
#
# The re.Match class exposes its attributes as C-level descriptors.
# lastgroup and lastindex are getset_descriptor (they compute their value
# dynamically via a C getter function). endpos, string, pos, and re are
# member_descriptor (they map directly to fixed-offset struct members).
# ---------------------------------------------------------------------------

table re_extra257.match_descriptor_identity:
  description: "re.Match attribute descriptor identity — __class__.__name__ for lastgroup, lastindex, endpos, string, pos, re; new to extra257"
  kind: python_call_eq
  category: identity
  id_prefix: rexmdi257

  columns: [id, function, args, expected, description]
  rows:
    - [lastgroup_class,
       "Match.lastgroup.__class__.__name__.__eq__",
       ["getset_descriptor"],
       true,
       "re.Match.lastgroup.__class__.__name__.__eq__('getset_descriptor') == True — lastgroup is a C-level getset_descriptor; it returns the name of the last matched group, or None; str.__eq__('getset_descriptor') returns True; new to extra257"]
    - [lastindex_class,
       "Match.lastindex.__class__.__name__.__eq__",
       ["getset_descriptor"],
       true,
       "re.Match.lastindex.__class__.__name__.__eq__('getset_descriptor') == True — lastindex is a C-level getset_descriptor; it returns the integer index of the last matched capturing group, or None; str.__eq__('getset_descriptor') returns True; new to extra257"]
    - [endpos_class,
       "Match.endpos.__class__.__name__.__eq__",
       ["member_descriptor"],
       true,
       "re.Match.endpos.__class__.__name__.__eq__('member_descriptor') == True — endpos is a C-level member_descriptor; it holds the end-of-search position that was passed to match() or search(); str.__eq__('member_descriptor') returns True; new to extra257"]
    - [string_class,
       "Match.string.__class__.__name__.__eq__",
       ["member_descriptor"],
       true,
       "re.Match.string.__class__.__name__.__eq__('member_descriptor') == True — string is a C-level member_descriptor; it holds the string that was passed to match() or search(); str.__eq__('member_descriptor') returns True; new to extra257"]
    - [pos_class,
       "Match.pos.__class__.__name__.__eq__",
       ["member_descriptor"],
       true,
       "re.Match.pos.__class__.__name__.__eq__('member_descriptor') == True — pos is a C-level member_descriptor; it holds the start-of-search position passed to match() or search(); str.__eq__('member_descriptor') returns True; new to extra257"]
    - [re_class,
       "Match.re.__class__.__name__.__eq__",
       ["member_descriptor"],
       true,
       "re.Match.re.__class__.__name__.__eq__('member_descriptor') == True — re is a C-level member_descriptor; it holds the compiled Pattern object whose match() or search() produced this match; str.__eq__('member_descriptor') returns True; new to extra257"]

# ---------------------------------------------------------------------------
# Table 2: re.Pattern attribute descriptor identity
#
# re.Pattern exposes its attributes as C-level descriptors.
# pattern, flags, and groups are member_descriptor (direct struct slots).
# groupindex is a getset_descriptor (dynamically computed from a C dict).
# ---------------------------------------------------------------------------

table re_extra257.pattern_descriptor_identity:
  description: "re.Pattern attribute descriptor identity — __class__.__name__ for pattern, flags, groups, groupindex; new to extra257"
  kind: python_call_eq
  category: identity
  id_prefix: rexpdi257

  columns: [id, function, args, expected, description]
  rows:
    - [pattern_class,
       "Pattern.pattern.__class__.__name__.__eq__",
       ["member_descriptor"],
       true,
       "re.Pattern.pattern.__class__.__name__.__eq__('member_descriptor') == True — pattern is a C-level member_descriptor; it holds the pattern string (or bytes) that was compiled; str.__eq__('member_descriptor') returns True; new to extra257"]
    - [flags_class,
       "Pattern.flags.__class__.__name__.__eq__",
       ["member_descriptor"],
       true,
       "re.Pattern.flags.__class__.__name__.__eq__('member_descriptor') == True — flags is a C-level member_descriptor; it holds the integer flags used when compiling the pattern; str.__eq__('member_descriptor') returns True; new to extra257"]
    - [groups_class,
       "Pattern.groups.__class__.__name__.__eq__",
       ["member_descriptor"],
       true,
       "re.Pattern.groups.__class__.__name__.__eq__('member_descriptor') == True — groups is a C-level member_descriptor; it holds the number of capturing groups in the pattern; str.__eq__('member_descriptor') returns True; new to extra257"]
    - [groupindex_class,
       "Pattern.groupindex.__class__.__name__.__eq__",
       ["getset_descriptor"],
       true,
       "re.Pattern.groupindex.__class__.__name__.__eq__('getset_descriptor') == True — groupindex is a C-level getset_descriptor; it returns a dict mapping group names to group numbers; str.__eq__('getset_descriptor') returns True; new to extra257"]

# ---------------------------------------------------------------------------
# Standalone invariants — re_extra257
# ---------------------------------------------------------------------------

invariant re_extra257.match_lastgroup_is_getset:
  description: "re.Match.lastgroup.__class__.__name__ == 'getset_descriptor' — lastgroup is a C-level getset_descriptor returning the last matched group name; new to extra257"
  kind: python_call_eq
  function: Match.lastgroup.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

invariant re_extra257.match_lastindex_is_getset:
  description: "re.Match.lastindex.__class__.__name__ == 'getset_descriptor' — lastindex is a C-level getset_descriptor returning the last matched group index; new to extra257"
  kind: python_call_eq
  function: Match.lastindex.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

invariant re_extra257.match_endpos_is_member:
  description: "re.Match.endpos.__class__.__name__ == 'member_descriptor' — endpos is a C-level member_descriptor for the end search position; new to extra257"
  kind: python_call_eq
  function: Match.endpos.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant re_extra257.match_string_is_member:
  description: "re.Match.string.__class__.__name__ == 'member_descriptor' — string is a C-level member_descriptor holding the matched string; new to extra257"
  kind: python_call_eq
  function: Match.string.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant re_extra257.match_pos_is_member:
  description: "re.Match.pos.__class__.__name__ == 'member_descriptor' — pos is a C-level member_descriptor for the start search position; new to extra257"
  kind: python_call_eq
  function: Match.pos.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant re_extra257.match_re_is_member:
  description: "re.Match.re.__class__.__name__ == 'member_descriptor' — re is a C-level member_descriptor holding the compiled Pattern that produced the match; new to extra257"
  kind: python_call_eq
  function: Match.re.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant re_extra257.pattern_pattern_is_member:
  description: "re.Pattern.pattern.__class__.__name__ == 'member_descriptor' — pattern is a C-level member_descriptor holding the compiled pattern string; new to extra257"
  kind: python_call_eq
  function: Pattern.pattern.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant re_extra257.pattern_flags_is_member:
  description: "re.Pattern.flags.__class__.__name__ == 'member_descriptor' — flags is a C-level member_descriptor holding the integer compile flags; new to extra257"
  kind: python_call_eq
  function: Pattern.flags.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant re_extra257.pattern_groups_is_member:
  description: "re.Pattern.groups.__class__.__name__ == 'member_descriptor' — groups is a C-level member_descriptor holding the capturing group count; new to extra257"
  kind: python_call_eq
  function: Pattern.groups.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant re_extra257.pattern_groupindex_is_getset:
  description: "re.Pattern.groupindex.__class__.__name__ == 'getset_descriptor' — groupindex is a C-level getset_descriptor returning the group name to number mapping; new to extra257"
  kind: python_call_eq
  function: Pattern.groupindex.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true
