spec: hashlib_extra266
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Lib/hashlib.py"
    - "hashlib_extra265.zspec.zsdl — covers sha3_256/sha3_512 digest_size/block_size/name/hexdigest length; blake2b custom digest_size=32 properties."
    - "hashlib_extra206.zspec.zsdl — covers hashlib.__dict__.__contains__ for core hash constructors and algorithms sets."
  notes:
    - "hashlib.__name__ == 'hashlib' — the module __name__ attribute is the bare module name. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.__package__ == '' — hashlib is a top-level stdlib module; its __package__ is the empty string. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.__spec__.__class__.__name__ == 'ModuleSpec' — hashlib.__spec__ is an importlib.machinery.ModuleSpec. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.__spec__.name == 'hashlib' — the ModuleSpec .name is the fully-qualified module name. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.__loader__.__class__.__name__ == 'SourceFileLoader' — hashlib is a pure-Python source module; its loader is a SourceFileLoader. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.__all__.__class__.__name__ == 'tuple' — hashlib.__all__ is a tuple (not a list). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.new.__name__ == '__hash_new' — the public API 'new' attribute in the hashlib module is actually a function named '__hash_new' (a wrapper). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.new.__qualname__ == '__hash_new' — qualname matches name for this module-level function. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.new.__module__ == 'hashlib' — the function's __module__ is 'hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.new.__class__.__name__ == 'function' — new is a plain Python function object. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib module identity — __name__, __package__, __spec__, __loader__
# ---------------------------------------------------------------------------

table hashlib_extra266.module_identity:
  description: "hashlib module identity attributes: __name__, __package__, __spec__ class and name, __loader__ class; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibid266

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,          __name__.__eq__,                         ["hashlib"],        true, "hashlib.__name__ == 'hashlib' — module name attribute"]
    - [package_eq,       __package__.__eq__,                      [""],               true, "hashlib.__package__ == '' — top-level module has empty string package"]
    - [spec_class_name,  __spec__.__class__.__name__.__eq__,       ["ModuleSpec"],     true, "hashlib.__spec__.__class__.__name__ == 'ModuleSpec'"]
    - [spec_name_eq,     __spec__.name.__eq__,                    ["hashlib"],        true, "hashlib.__spec__.name == 'hashlib'"]
    - [loader_class,     __loader__.__class__.__name__.__eq__,     ["SourceFileLoader"], true, "hashlib.__loader__.__class__.__name__ == 'SourceFileLoader'"]

# ---------------------------------------------------------------------------
# hashlib.__all__ — type check
# hashlib.__all__ is a tuple (not a list); it contains the public API names.
# ---------------------------------------------------------------------------

invariant hashlib_extra266.all_type_is_tuple:
  description: "hashlib.__all__.__class__.__name__ == 'tuple' — __all__ is a tuple in the hashlib module"
  category: identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new function identity — name, qualname, module, class
# hashlib.new is exposed as 'new' in the module namespace but its actual
# function name is '__hash_new' (a private wrapper function).
# ---------------------------------------------------------------------------

table hashlib_extra266.new_function_identity:
  description: "hashlib.new function identity: __name__=='__hash_new', __qualname__=='__hash_new', __module__=='hashlib', __class__.__name__=='function'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibid266

  columns: [id, function, args, expected, description]
  rows:
    - [new_name,     new.__name__.__eq__,           ["__hash_new"], true, "hashlib.new.__name__ == '__hash_new' — new is a wrapper function named __hash_new"]
    - [new_qualname, new.__qualname__.__eq__,        ["__hash_new"], true, "hashlib.new.__qualname__ == '__hash_new' — qualname matches __name__ for this module-level function"]
    - [new_module,   new.__module__.__eq__,          ["hashlib"],    true, "hashlib.new.__module__ == 'hashlib'"]
    - [new_class,    new.__class__.__name__.__eq__,  ["function"],   true, "hashlib.new.__class__.__name__ == 'function' — new is a plain Python function"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashlib_extra266.module_name:
  description: "hashlib.__name__ == 'hashlib' — the module's __name__ attribute is the bare module name"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["hashlib"]
  expected: true

invariant hashlib_extra266.module_package:
  description: "hashlib.__package__ == '' — hashlib is a top-level stdlib module; __package__ is the empty string"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant hashlib_extra266.spec_class_name:
  description: "hashlib.__spec__.__class__.__name__ == 'ModuleSpec' — __spec__ is an importlib.machinery.ModuleSpec"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant hashlib_extra266.spec_name:
  description: "hashlib.__spec__.name == 'hashlib' — the ModuleSpec .name is the fully-qualified module name"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["hashlib"]
  expected: true

invariant hashlib_extra266.loader_class:
  description: "hashlib.__loader__.__class__.__name__ == 'SourceFileLoader' — hashlib is a Python source module"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant hashlib_extra266.new_name:
  description: "hashlib.new.__name__ == '__hash_new' — the public 'new' attribute is a wrapper function named '__hash_new'"
  category: identity
  kind: python_call_eq
  function: new.__name__.__eq__
  args: ["__hash_new"]
  expected: true

invariant hashlib_extra266.new_module:
  description: "hashlib.new.__module__ == 'hashlib' — the new function's __module__ attribute"
  category: identity
  kind: python_call_eq
  function: new.__module__.__eq__
  args: ["hashlib"]
  expected: true

invariant hashlib_extra266.new_class:
  description: "hashlib.new.__class__.__name__ == 'function' — new is a plain Python function object"
  category: identity
  kind: python_call_eq
  function: new.__class__.__name__.__eq__
  args: ["function"]
  expected: true
