spec: concurrent_futures_extra80
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra79.zspec.zsdl."
    - "This spec covers: wave 245 theme — concurrent.futures class __module__ values. NEW in extra80: ThreadPoolExecutor.__module__=='concurrent.futures.thread'; ProcessPoolExecutor.__module__=='concurrent.futures.process'; Executor.__module__=='concurrent.futures._base'; Future.__module__=='concurrent.futures._base'; CancelledError.__module__=='concurrent.futures._base'; TimeoutError.__module__=='builtins' (concurrent.futures.TimeoutError is actually the built-in TimeoutError re-exported); BrokenExecutor.__module__=='concurrent.futures._base'; InvalidStateError.__module__=='concurrent.futures._base'; ThreadPoolExecutor.__qualname__=='ThreadPoolExecutor'; ProcessPoolExecutor.__qualname__=='ProcessPoolExecutor'; Future.__qualname__=='Future'; Executor.__qualname__=='Executor'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'. ThreadPoolExecutor is defined in the thread submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__module__ == 'concurrent.futures.process'. ProcessPoolExecutor is defined in the process submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__module__ == 'concurrent.futures._base'. Executor base class is defined in the _base submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__module__ == 'concurrent.futures._base'. Future is defined in the _base submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.CancelledError.__module__ == 'concurrent.futures._base'. CancelledError is defined in _base. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.TimeoutError.__module__ == 'builtins'. concurrent.futures.TimeoutError is actually the built-in TimeoutError, re-exported from the module. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base'. BrokenExecutor is defined in _base. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.InvalidStateError.__module__ == 'concurrent.futures._base'. InvalidStateError is defined in _base. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor'. Simple unqualified class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor'. Simple unqualified class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__qualname__ == 'Future'. Simple unqualified class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__qualname__ == 'Executor'. Simple unqualified class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures executor __module__ checks — extra80
#
# Wave 245 theme: concurrent.futures class __module__ values.
#
# ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'
# ProcessPoolExecutor.__module__ == 'concurrent.futures.process'
# Executor.__module__ == 'concurrent.futures._base'
# Future.__module__ == 'concurrent.futures._base'
# ---------------------------------------------------------------------------

table concurrent_futures_extra80.executor_modules:
  description: "concurrent.futures executor and Future __module__ checks in cfextra80 namespace — wave 245 theme: concurrent.futures class __module__ values; ThreadPoolExecutor.__module__=='concurrent.futures.thread'; ProcessPoolExecutor.__module__=='concurrent.futures.process'; Executor.__module__=='concurrent.futures._base'; Future.__module__=='concurrent.futures._base'; each class is defined in its own submodule of concurrent.futures; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfextra80

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_module,   ThreadPoolExecutor.__module__.__eq__,  ["concurrent.futures.thread"],   true, "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' — defined in thread submodule; verified with Python 3.14.3"]
    - [ppe_module,   ProcessPoolExecutor.__module__.__eq__,  ["concurrent.futures.process"],  true, "ProcessPoolExecutor.__module__ == 'concurrent.futures.process' — defined in process submodule; verified with Python 3.14.3"]
    - [exec_module,  Executor.__module__.__eq__,             ["concurrent.futures._base"],    true, "Executor.__module__ == 'concurrent.futures._base' — base class defined in _base submodule; verified with Python 3.14.3"]
    - [future_module, Future.__module__.__eq__,             ["concurrent.futures._base"],    true, "Future.__module__ == 'concurrent.futures._base' — Future defined in _base submodule; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures exception __module__ checks — extra80
#
# CancelledError.__module__ == 'concurrent.futures._base'
# TimeoutError.__module__ == 'builtins'
# BrokenExecutor.__module__ == 'concurrent.futures._base'
# InvalidStateError.__module__ == 'concurrent.futures._base'
# ---------------------------------------------------------------------------

table concurrent_futures_extra80.exception_modules:
  description: "concurrent.futures exception __module__ checks in cfextra80 namespace — wave 245 theme: concurrent.futures exception __module__ values; CancelledError.__module__=='concurrent.futures._base'; TimeoutError.__module__=='builtins' (concurrent.futures.TimeoutError is the built-in TimeoutError re-exported); BrokenExecutor.__module__=='concurrent.futures._base'; InvalidStateError.__module__=='concurrent.futures._base'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfextra80a

  columns: [id, function, args, expected, description]
  rows:
    - [cancelled_module,    CancelledError.__module__.__eq__,    ["concurrent.futures._base"], true, "CancelledError.__module__ == 'concurrent.futures._base' — CancelledError defined in _base; verified with Python 3.14.3"]
    - [timeout_module,      TimeoutError.__module__.__eq__,      ["builtins"],                 true, "TimeoutError.__module__ == 'builtins' — concurrent.futures.TimeoutError is the built-in TimeoutError re-exported; verified with Python 3.14.3"]
    - [broken_module,       BrokenExecutor.__module__.__eq__,    ["concurrent.futures._base"], true, "BrokenExecutor.__module__ == 'concurrent.futures._base' — BrokenExecutor defined in _base; verified with Python 3.14.3"]
    - [invalid_module,      InvalidStateError.__module__.__eq__, ["concurrent.futures._base"], true, "InvalidStateError.__module__ == 'concurrent.futures._base' — InvalidStateError defined in _base; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures executor __qualname__ checks — extra80
#
# ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor'
# ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor'
# Future.__qualname__ == 'Future'
# Executor.__qualname__ == 'Executor'
# ---------------------------------------------------------------------------

table concurrent_futures_extra80.executor_qualnames:
  description: "concurrent.futures executor __qualname__ checks in cfextra80 namespace — wave 245 theme: concurrent.futures class __qualname__ values; ThreadPoolExecutor.__qualname__=='ThreadPoolExecutor'; ProcessPoolExecutor.__qualname__=='ProcessPoolExecutor'; Future.__qualname__=='Future'; Executor.__qualname__=='Executor'; all are top-level classes with simple unqualified names; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfextra80b

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_qualname,   ThreadPoolExecutor.__qualname__.__eq__,  ["ThreadPoolExecutor"],  true, "ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor' — simple top-level class name; verified with Python 3.14.3"]
    - [ppe_qualname,   ProcessPoolExecutor.__qualname__.__eq__, ["ProcessPoolExecutor"], true, "ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor' — simple top-level class name; verified with Python 3.14.3"]
    - [future_qualname, Future.__qualname__.__eq__,            ["Future"],              true, "Future.__qualname__ == 'Future' — simple top-level class name; verified with Python 3.14.3"]
    - [exec_qualname,  Executor.__qualname__.__eq__,           ["Executor"],            true, "Executor.__qualname__ == 'Executor' — simple top-level class name; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures module cross-check table — extra80
# ---------------------------------------------------------------------------

table concurrent_futures_extra80.module_cross_checks:
  description: "concurrent.futures class __module__ cross-check table in cfextra80 namespace — wave 245 theme: all classes defined in correct submodules; ThreadPoolExecutor.__module__=='concurrent.futures.thread' (cross-check); Executor.__module__=='concurrent.futures._base' (cross-check); CancelledError.__module__=='concurrent.futures._base' (cross-check); TimeoutError.__module__=='builtins' (cross-check: built-in re-export); BrokenExecutor.__module__=='concurrent.futures._base' (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfextra80c

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_module_cross,      ThreadPoolExecutor.__module__.__eq__,  ["concurrent.futures.thread"],   true, "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' — cross-check; verified with Python 3.14.3"]
    - [exec_module_cross,     Executor.__module__.__eq__,            ["concurrent.futures._base"],    true, "Executor.__module__ == 'concurrent.futures._base' — cross-check; verified with Python 3.14.3"]
    - [cancelled_module_cross, CancelledError.__module__.__eq__,     ["concurrent.futures._base"],    true, "CancelledError.__module__ == 'concurrent.futures._base' — cross-check; verified with Python 3.14.3"]
    - [timeout_module_cross,   TimeoutError.__module__.__eq__,       ["builtins"],                    true, "TimeoutError.__module__ == 'builtins' — built-in re-export cross-check; verified with Python 3.14.3"]
    - [broken_module_cross,    BrokenExecutor.__module__.__eq__,     ["concurrent.futures._base"],    true, "BrokenExecutor.__module__ == 'concurrent.futures._base' — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra80
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra80.ThreadPoolExecutor_module:
  description: "concurrent.futures.ThreadPoolExecutor.__module__.__eq__('concurrent.futures.thread') returns True — ThreadPoolExecutor is defined in the thread submodule, not in _base or the top-level package; NEW in extra80: first standalone __module__ invariant for ThreadPoolExecutor in cfextra80 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.__module__.__eq__
  args: ["concurrent.futures.thread"]
  expected: true

invariant concurrent_futures_extra80.ProcessPoolExecutor_module:
  description: "concurrent.futures.ProcessPoolExecutor.__module__.__eq__('concurrent.futures.process') returns True — ProcessPoolExecutor is defined in the process submodule; NEW in extra80: first standalone __module__ invariant for ProcessPoolExecutor in cfextra80 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ProcessPoolExecutor.__module__.__eq__
  args: ["concurrent.futures.process"]
  expected: true

invariant concurrent_futures_extra80.Executor_module:
  description: "concurrent.futures.Executor.__module__.__eq__('concurrent.futures._base') returns True — Executor base class is defined in the _base submodule; NEW in extra80: first standalone __module__ invariant for Executor in cfextra80 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Executor.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra80.TimeoutError_module:
  description: "concurrent.futures.TimeoutError.__module__.__eq__('builtins') returns True — concurrent.futures.TimeoutError is actually the built-in TimeoutError re-exported from the module, hence __module__ is 'builtins'; NEW in extra80: first standalone __module__ invariant for TimeoutError in cfextra80 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: TimeoutError.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant concurrent_futures_extra80.Future_qualname:
  description: "concurrent.futures.Future.__qualname__.__eq__('Future') returns True — Future is a top-level class with a simple unqualified name; NEW in extra80: first standalone __qualname__ invariant for Future in cfextra80 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Future.__qualname__.__eq__
  args: ["Future"]
  expected: true
