spec: poplib_extra
version: ">=3.9"
backend: python_module(poplib)

docs: https://docs.python.org/3/library/poplib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/poplib.html — Python poplib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/poplib.py"
  notes:
    - "poplib.POP3 is the main class for connecting to a POP3 server."
    - "poplib.POP3_SSL is the TLS-wrapped variant of POP3."
    - "poplib.error_proto is the module's exception class."
    - "POP3.__module__ == 'poplib' — the class is defined in the poplib module."
    - "POP3_SSL.__module__ == 'poplib' — the SSL class is also defined in the poplib module."
    - "error_proto.__bases__[0].__name__ == 'Exception' — inherits directly from Exception."
    - "POP3 and POP3_SSL are regular Python classes: type(X).__name__ == 'type'."
    - "error_proto.__name__ == 'error_proto' — lowercase exception name following poplib convention."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

table poplib_extra.classes.class_names:
  kind: python_call_eq
  category: classes
  id_prefix: class_name

  columns: [id, function, args, expected]
  rows:
    - [POP3_name,        POP3.__name__.__eq__,        ["POP3"],        true]
    - [POP3_SSL_name,    POP3_SSL.__name__.__eq__,    ["POP3_SSL"],    true]
    - [error_proto_name, error_proto.__name__.__eq__, ["error_proto"], true]

# ---------------------------------------------------------------------------
# Class type checks — all are class objects
# ---------------------------------------------------------------------------

table poplib_extra.types.class_types:
  kind: python_call_eq
  category: types
  id_prefix: type

  columns: [id, function, args, expected]
  rows:
    - [POP3_is_type,        POP3.__class__.__name__.__eq__,        ["type"], true]
    - [POP3_SSL_is_type,    POP3_SSL.__class__.__name__.__eq__,    ["type"], true]
    - [error_proto_is_type, error_proto.__class__.__name__.__eq__, ["type"], true]

# ---------------------------------------------------------------------------
# Module affiliation checks
# ---------------------------------------------------------------------------

invariant poplib_extra.module.POP3_module:
  description: "POP3.__module__ == 'poplib' — the class is defined in the poplib module"
  category: module
  kind: python_call_eq
  function: POP3.__module__.__eq__
  args: ["poplib"]
  expected: true

invariant poplib_extra.module.POP3_SSL_module:
  description: "POP3_SSL.__module__ == 'poplib' — the SSL class is also defined in the poplib module"
  category: module
  kind: python_call_eq
  function: POP3_SSL.__module__.__eq__
  args: ["poplib"]
  expected: true

invariant poplib_extra.module.error_proto_module:
  description: "error_proto.__module__ == 'poplib' — the exception is defined in the poplib module"
  category: module
  kind: python_call_eq
  function: error_proto.__module__.__eq__
  args: ["poplib"]
  expected: true

# ---------------------------------------------------------------------------
# error_proto class hierarchy — inherits from Exception
# ---------------------------------------------------------------------------

invariant poplib_extra.classes.error_proto_base_is_Exception:
  description: "error_proto.__bases__[0].__name__ == 'Exception' — error_proto inherits from Exception"
  category: classes
  kind: python_call_eq
  function: error_proto.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  expected: true

# ---------------------------------------------------------------------------
# Qualname checks
# ---------------------------------------------------------------------------

table poplib_extra.classes.qualnames:
  kind: python_call_eq
  category: classes
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [POP3_qualname,        POP3.__qualname__.__eq__,        ["POP3"],        true]
    - [POP3_SSL_qualname,    POP3_SSL.__qualname__.__eq__,    ["POP3_SSL"],    true]
    - [error_proto_qualname, error_proto.__qualname__.__eq__, ["error_proto"], true]

# ---------------------------------------------------------------------------
# POP3_SSL inheritance — POP3_SSL inherits from POP3
# ---------------------------------------------------------------------------

invariant poplib_extra.classes.POP3_SSL_base_is_POP3:
  description: "POP3_SSL.__bases__[0].__name__ == 'POP3' — POP3_SSL inherits from POP3"
  category: classes
  kind: python_call_eq
  function: POP3_SSL.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  expected: true
