spec: functools_rust
version: ">=3.9"
backend: rust_module(functools_rust)

docs: https://docs.python.org/3/library/functools.html#functools.reduce

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools documentation"
  not_derived_from:
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "Clean-room Rust reimplementation of functools.reduce with pre-wired binary operators, exposed via PyO3."
    - "reduce requires a callable, so this module exposes pre-wired variants using operator module functions."
    - "reduce_add(iterable, initial) == functools.reduce(operator.add, iterable, initial)."
    - "reduce_mul(iterable, initial) == functools.reduce(operator.mul, iterable, initial)."
    - "reduce_add([1,2,3,4,5], 0) == 15."
    - "reduce_mul([1,2,3,4,5], 1) == 120."
    - "reduce_add([], 0) == 0 — empty iterable returns initial value."
    - "reduce_mul([], 1) == 1 — empty iterable returns initial value."
    - "All test vectors verified against Python 3.14.3 functools module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# reduce_add — reduce with operator.add
table functools_rust.reduce_add.vectors:
  kind: python_call_eq
  category: reduce_add
  id_prefix: ft_radd
  function: reduce_add

  columns: [id, args, expected]
  rows:
    - [one_to_five,  [[1, 2, 3, 4, 5], 0],   15]
    - [empty,        [[], 0],                  0]
    - [single,       [[42], 0],               42]
    - [with_init,    [[1, 2, 3], 10],         16]
    - [negatives,    [[-1, -2, -3], 0],       -6]

# reduce_mul — reduce with operator.mul
table functools_rust.reduce_mul.vectors:
  kind: python_call_eq
  category: reduce_mul
  id_prefix: ft_rmul
  function: reduce_mul

  columns: [id, args, expected]
  rows:
    - [factorial5, [[1, 2, 3, 4, 5], 1], 120]
    - [factorial4, [[1, 2, 3, 4], 1],    24]
    - [empty,      [[], 1],               1]
    - [single,     [[7], 1],             7]
    - [with_init,  [[2, 3], 5],          30]

