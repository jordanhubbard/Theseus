spec: struct_extra55
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra54.zspec.zsdl — covers struct.__loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__.__class__.__name__.__eq__('str') / __cached__.__class__.__name__.__eq__('str') (table + invariant)."
    - "struct_extra53.zspec.zsdl — covers struct.__all__.__contains__ for pack/unpack/unpack_from (table); struct.__dict__.__contains__ for Struct/pack/error/calcsize (table); error.__doc__.__class__.__name__.__eq__('NoneType') (invariant)."
    - "struct_extra52.zspec.zsdl — covers struct.__all__.__class__.__name__.__eq__('list'); __all__.__contains__ for Struct/error/pack_into/iter_unpack (table) and calcsize (invariant); Struct/error __eq__.__class__.__name__.__eq__('wrapper_descriptor')."
    - "struct_extra29.zspec.zsdl — covers struct.__spec__.__name__.__len__()==6 and struct.__loader__.__class__.__name__.__len__()==16."
    - "struct_extra26.zspec.zsdl — covers struct.__spec__.__class__.__name__.__len__()==10 and struct.__all__.__len__()==8."
    - "struct_extra19.zspec.zsdl — covers struct.__package__.__eq__('') and struct.__package__.__class__.__name__.__eq__('str')."
    - "struct.zspec — covers struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra54; it does NOT duplicate invariants present in those files."
    - "Wave 226 theme: __spec__.origin values + __spec__.submodule_search_locations + __loader__.__name__ length checks."
    - "struct in Python 3 is loaded as a thin Python wrapper (Lib/struct.py) around the C extension _struct. struct.__loader__.__class__.__name__ == 'SourceFileLoader' (confirmed in wave 225d — struct.py is what import struct loads). struct is not a package: it has no sub-module directory, so __spec__.submodule_search_locations is None (NoneType). For Python source files, __spec__.has_location is True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 1: No prior struct spec checks struct.__loader__.__class__.__name__.__len__()==16 in a table row context alongside the new __spec__.origin checks. struct_extra29 covers __loader__.__class__.__name__.__len__()==16 as a standalone invariant; struct_extra54 covers __loader__.__class__.__name__.__eq__('SourceFileLoader'). This spec adds __loader__.__class__.__name__.__len__()==16 as a table row in the wave 226 grouped context. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior struct spec checks struct.__spec__.origin.__class__.__name__.__eq__('str'). struct.__spec__.origin is the absolute file path to struct.py (the Python wrapper) as a Python str. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__spec__.origin.__class__.__name__ == 'str'. The ModuleSpec.origin attribute is the path to the source file (e.g., '.../lib/python3.14/struct.py') stored as a Python str. No prior struct spec checks __spec__.origin.__class__.__name__ in any form. Entirely novel origin type anchor for struct. Note: origin points to the Python wrapper struct.py, not to the underlying C extension _struct.cpython-*.so. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 3: No prior struct spec checks struct.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType'). struct is a single-file module (struct.py + _struct C extension behind it), not a package; therefore __spec__.submodule_search_locations is None. None.__class__.__name__ == 'NoneType'. This confirms struct is not a package. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__spec__.submodule_search_locations is None. For non-package modules, ModuleSpec.submodule_search_locations is None. The struct module presents as a flat single-file module from the import system's perspective, even though it internally loads the _struct C extension. No prior struct spec checks submodule_search_locations in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 4: No prior struct spec checks struct.__spec__.has_location. For Python source modules, ModuleSpec.has_location is True. has_location being True confirms struct is file-backed (the Python wrapper struct.py has a path). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__spec__.has_location == True. struct is loaded from a Python wrapper file (Lib/struct.py); its ModuleSpec.has_location is True. No prior struct spec checks __spec__.has_location. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct __spec__.origin + submodule_search_locations + has_location checks
#
# Wave 226 theme: __spec__.origin values + __spec__.submodule_search_locations +
# __loader__.__name__ length checks.
#
# struct is loaded as a Python wrapper (Lib/struct.py) around the _struct C
# extension. From the import system perspective it is a single-file module
# (not a package). Its ModuleSpec has:
#   - origin: str path to struct.py (the Python wrapper)
#   - submodule_search_locations: None (NoneType) — not a package
#   - has_location: True — file-backed module (struct.py has a path)
# ---------------------------------------------------------------------------

table struct_extra55.spec_origin_submodule_location:
  description: "struct __loader__.__class__.__name__.__len__()==16 / __spec__.origin.__class__.__name__.__eq__('str') / __spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') / __spec__.has_location==True — wave 226 theme: origin/submodule_search_locations/has_location checks for struct; struct is the Python wrapper Lib/struct.py (not a package); origin is a str path to struct.py, submodule_search_locations is None (NoneType), has_location is True; all spec.origin/submodule/has_location rows are novel for struct"
  kind: python_call_eq
  category: module_structure
  id_prefix: structspec55

  columns: [id, function, args, expected]
  rows:
    - [loader_class_name_len,               __loader__.__class__.__name__.__len__,                             [], 16]
    - [spec_origin_class_name_eq,           __spec__.origin.__class__.__name__.__eq__,                         ["str"],      true]
    - [spec_submodule_search_class_name_eq, __spec__.submodule_search_locations.__class__.__name__.__eq__,      ["NoneType"], true]
    - [spec_has_location,                   __spec__.has_location.__eq__,                                       [true],       true]

# ---------------------------------------------------------------------------
# struct.__spec__.origin.__class__.__name__.__eq__('str') — standalone
#
# struct.__spec__.origin is the absolute file path to struct.py (the Python
# wrapper), stored as a Python str. No prior struct spec checks __spec__.origin
# in any form. Note: origin points to the Python wrapper file struct.py, not
# to the underlying C extension _struct. This is the primary origin type
# anchor for the struct module.
# ---------------------------------------------------------------------------

invariant struct_extra55.spec_origin_class_name_str:
  description: "struct.__spec__.origin.__class__.__name__.__eq__('str') == True — struct.__spec__.origin is the str path to the Python wrapper Lib/struct.py; ModuleSpec.origin is str for file-backed Python modules; no prior struct spec checks __spec__.origin in any form; primary origin type anchor for struct confirming the Python-wrapper loading path (not the _struct C extension path)"
  category: module_structure
  kind: python_call_eq
  function: __spec__.origin.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType')
# — standalone
#
# struct is not a package: it is a single-file module (struct.py + _struct C
# extension internally). ModuleSpec.submodule_search_locations is None for
# non-package modules. None.__class__.__name__ == 'NoneType'. No prior struct
# spec checks submodule_search_locations in any form. This confirms struct
# presents as a flat single-file module from the import system's perspective.
# ---------------------------------------------------------------------------

invariant struct_extra55.spec_submodule_search_locations_nonetype:
  description: "struct.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') == True — struct is a single-file module (not a package); ModuleSpec.submodule_search_locations is None for non-package modules; None.__class__.__name__ == 'NoneType'; no prior struct spec checks submodule_search_locations; confirms struct presents as flat single-file from the import system perspective"
  category: module_structure
  kind: python_call_eq
  function: __spec__.submodule_search_locations.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true
