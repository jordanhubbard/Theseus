spec: short_uuid
version: ">=6.0.0"
backend: node(short-uuid)

docs: https://github.com/oculus42/short-uuid#readme

provenance:
  derived_from:
    - "short-uuid README — https://github.com/oculus42/short-uuid#readme"
    - "Test vectors verified with short-uuid via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "short-uuid source"
  notes:
    - "Translate UUIDs to/from shorter alphabets (default flickrBase58, 22 chars)."
    - "Install: npm install short-uuid"
    - "v6 CJS; named exports generate / createTranslator / uuid / constants."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure functions; translator throws on invalid input characters."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# generate() — direct shortened UUID v4
invariant short_uuid.generate_length_is_22:
  description: "short.generate() produces a 22-character flickrBase58 string"
  category: generate
  kind: node_chain_eq
  entry: named
  function: generate
  entry_args: []
  chain:
    - {get: length}
  expected: 22

invariant short_uuid.generate_is_string:
  description: "short.generate() returns a String"
  category: generate
  kind: node_chain_eq
  entry: named
  function: generate
  entry_args: []
  chain:
    - {get: "constructor.name"}
  expected: "String"

# Translator round-trip — flickrBase58 alphabet
invariant short_uuid.translator_zero_uuid:
  description: "translator(flickrBase58).fromUUID('00..00') is '11..11' (22 chars of '1')"
  category: translator
  kind: node_chain_eq
  entry: named
  function: createTranslator
  entry_args: ["123456789abcdefghijkmnopqrstuvwxyzABCDEFGHJKLMNPQRSTUVWXYZ"]
  chain:
    - {method: fromUUID, args: ["00000000-0000-0000-0000-000000000000"]}
  expected: "1111111111111111111111"

invariant short_uuid.translator_round_trip_to_uuid:
  description: "translator.toUUID(translator.fromUUID(zero_uuid)) returns the original"
  category: translator
  kind: node_chain_eq
  entry: named
  function: createTranslator
  entry_args: ["123456789abcdefghijkmnopqrstuvwxyzABCDEFGHJKLMNPQRSTUVWXYZ"]
  chain:
    - {method: toUUID, args: ["1111111111111111111111"]}
  expected: "00000000-0000-0000-0000-000000000000"

# constants — known alphabets
invariant short_uuid.constants_flickrBase58:
  description: "short.constants.flickrBase58 is the documented 58-char alphabet (digits, lowercase, uppercase — Flickr ordering)"
  category: constants
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constants.flickrBase58"}
  expected: "123456789abcdefghijkmnopqrstuvwxyzABCDEFGHJKLMNPQRSTUVWXYZ"

invariant short_uuid.constants_flickrBase58_length:
  description: "flickrBase58 alphabet is exactly 58 characters"
  category: constants
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constants.flickrBase58"}
    - {get: length}
  expected: 58

invariant short_uuid.constants_rfcBase32_length:
  description: "rfcBase32 alphabet is exactly 32 characters"
  category: constants
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constants.rfcBase32"}
    - {get: length}
  expected: 32
