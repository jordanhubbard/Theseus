spec: itertools_extra194
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "itertools.product.__name__ == 'product' (len=7); product is a C-level type implementing Cartesian product iteration; verified with Python 3.14.3."
    - "itertools.product.__module__ == 'itertools' (len=9); defined in the itertools C extension module; verified with Python 3.14.3."
    - "itertools.product.__qualname__ == 'product' (len=7); top-level type so qualname equals name; verified with Python 3.14.3."
    - "itertools.product.__bases__[0].__name__ == 'object' (len=6); product is a C-level type inheriting directly from object; verified with Python 3.14.3."
    - "itertools.combinations.__bases__[0].__name__ == 'object' (len=6); combinations is also a C-level type inheriting directly from object; verified with Python 3.14.3."
    - "itertools.permutations.__bases__[0].__name__ == 'object' (len=6); permutations is a C-level type inheriting directly from object; verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__name__ == 'combinations_with_replacement' (len=29); C-level type for combinations allowing repeated elements; verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__bases__[0].__name__ == 'object' (len=6); inherits directly from object; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.product name, module, and qualname identity
#
# itertools.product.__name__     == 'product' (len=7)
# itertools.product.__module__   == 'itertools' (len=9)
# itertools.product.__qualname__ == 'product' (len=7)
#
# product is a C-level type implementing Cartesian product iteration.
# It lives in the itertools extension module. New to extra194.
# ---------------------------------------------------------------------------

table itertools_extra194.product_name_module_qualname:
  description: "itertools.product identity: __name__=='product'(len=7); __module__=='itertools'(len=9); __qualname__=='product'(len=7); new to extra194"
  kind: python_call_eq
  category: identity
  id_prefix: iterproduct194

  columns: [id, function, args, expected, description]
  rows:
    - [product_name_eq,
       product.__name__.__eq__,
       ["product"],
       true,
       "itertools.product.__name__.__eq__('product') == True — product is a C-level type implementing Cartesian product iteration; __name__ is 'product' (len=7); str.__eq__('product') returns True; verified with Python 3.14.3; new to extra194"]
    - [product_name_len,
       product.__name__.__len__,
       [],
       7,
       "itertools.product.__name__.__len__() == 7 — 'product' has 7 characters: p-r-o-d-u-c-t; str.__len__() returns 7; verified with Python 3.14.3; new to extra194"]
    - [product_module_eq,
       product.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.product.__module__.__eq__('itertools') == True — product is defined in the itertools C extension module; __module__ is 'itertools' (len=9); str.__eq__('itertools') returns True; verified with Python 3.14.3; new to extra194"]
    - [product_module_len,
       product.__module__.__len__,
       [],
       9,
       "itertools.product.__module__.__len__() == 9 — 'itertools' has 9 characters: i-t-e-r-t-o-o-l-s; str.__len__() returns 9; verified with Python 3.14.3; new to extra194"]
    - [product_qualname_eq,
       product.__qualname__.__eq__,
       ["product"],
       true,
       "itertools.product.__qualname__.__eq__('product') == True — product is a top-level type so its qualname equals its name; __qualname__ is 'product' (len=7); str.__eq__('product') returns True; verified with Python 3.14.3; new to extra194"]

# ---------------------------------------------------------------------------
