spec: hashlib_extra48
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_blake2module.c"
    - "hashlib_extra47.zspec.zsdl — covers sha3_512.__module__.__eq__('_hashlib') and sha3_512.__module__.__len__()==8."
    - "hashlib_extra46.zspec.zsdl — covers sha3_224/sha3_384 __name__.__eq__ and __module__.__eq__ (openssl-backed string eq values)."
    - "hashlib_extra45.zspec.zsdl — covers sha3_224/sha3_384 __qualname__.__eq__ and __qualname__.__len__()."
    - "hashlib_extra44.zspec.zsdl — covers blake2b/blake2s __class__.__name__.__eq__('type')."
    - "hashlib_extra32.zspec.zsdl — covers blake2b/blake2s __name__.__len__()==7 and __module__.__len__()==7."
    - "hashlib_extra28.zspec.zsdl — covers blake2b/blake2s __qualname__.__eq__('blake2b'/'blake2s') and __qualname__.__len__()==7."
    - "hashlib_extra6.zspec.zsdl — covers blake2b/blake2s __module__.__eq__('_blake2')."
  notes:
    - "This spec extends hashlib through hashlib_extra47; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: hashlib_extra28 covers blake2b.__qualname__.__eq__('blake2b') and blake2s.__qualname__.__eq__('blake2s') (__qualname__ axis). hashlib_extra32 covers blake2b.__name__.__len__()==7 and blake2s.__name__.__len__()==7 (length only). But NO prior spec checks blake2b.__name__.__eq__('blake2b') or blake2s.__name__.__eq__('blake2s') as string eq values. The __name__.__eq__ axis is distinct from __qualname__.__eq__ (extra28), providing independent regression vectors. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__name__ == 'blake2b'. hashlib_extra28 covers __qualname__.__eq__('blake2b'); hashlib_extra32 covers __name__.__len__()==7 (length only); hashlib_extra6 covers __module__.__eq__('_blake2'). No prior spec checks __name__.__eq__('blake2b') as a string eq value. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__name__ == 'blake2s'. Same coverage gaps as blake2b. No prior spec checks __name__.__eq__('blake2s'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior hashlib spec checks blake2b.__mro__ or blake2s.__mro__ at all. blake2b and blake2s are C extension types whose mro is (blake2b, object) and (blake2s, object) respectively — depth 2. Both inherit directly from object. The __mro__ axis provides structural regression vectors distinct from __name__/__qualname__/__module__/__class__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__mro__.__len__() == 2. blake2b is a C extension type with mro (blake2b, object). No prior hashlib spec checks blake2b.__mro__ at all. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__mro__.__len__() == 2. Same mro depth as blake2b. No prior hashlib spec checks blake2s.__mro__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__mro__[0].__name__ == 'blake2b'. First mro entry is blake2b itself. No prior spec checks this. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__mro__[1].__name__ == 'object'. Second mro entry is the root object type. No prior spec checks blake2b.__mro__[1]. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__mro__[0].__name__ == 'blake2s'. First mro entry is blake2s itself. No prior spec checks this. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__mro__[1].__name__ == 'object'. Second mro entry is the root object type. No prior spec checks blake2s.__mro__[1]. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.blake2b and blake2s __name__.__eq__ string values
#
# hashlib_extra28 covers blake2b/blake2s __qualname__.__eq__('blake2b'/'blake2s').
# hashlib_extra32 covers blake2b/blake2s __name__.__len__()==7 (length only).
# hashlib_extra6 covers blake2b/blake2s __module__.__eq__('_blake2').
# hashlib_extra44 covers blake2b/blake2s __class__.__name__.__eq__('type').
# NO prior spec checks blake2b.__name__.__eq__('blake2b') or blake2s.__name__.__eq__('blake2s')
# as string eq values. For C extension types, __name__ == __qualname__, but the
# __name__ attribute is a distinct chain from __qualname__ and provides an
# independent regression vector.
# ---------------------------------------------------------------------------

table hashlib_extra48.blake2_name_eq:
  description: "hashlib.blake2b/__name__.__eq__('blake2b') and blake2s/__name__.__eq__('blake2s') — novel __name__ axis; extra28 covers __qualname__.__eq__; extra32 covers __name__.__len__ only; no prior spec checks __name__.__eq__ string values for blake2b or blake2s"
  kind: python_call_eq
  category: function_names
  id_prefix: hbne48

  columns: [id, function, args, expected]
  rows:
    - [blake2b_name_eq, blake2b.__name__.__eq__, ["blake2b"], true]
    - [blake2s_name_eq, blake2s.__name__.__eq__, ["blake2s"], true]

# ---------------------------------------------------------------------------
# hashlib.blake2b and blake2s __mro__.__len__()
#
# No prior hashlib spec checks blake2b.__mro__ or blake2s.__mro__ at all.
# blake2b.__mro__ == (<class '_blake2.blake2b'>, <class 'object'>)
# blake2s.__mro__ == (<class '_blake2.blake2s'>, <class 'object'>)
# Both inherit directly from object, so __mro__.__len__() == 2.
# ---------------------------------------------------------------------------

table hashlib_extra48.blake2_mro_len:
  description: "hashlib.blake2b/__mro__.__len__()==2 and blake2s/__mro__.__len__()==2 — both C extension types inherit directly from object; novel: no prior hashlib spec checks blake2b or blake2s __mro__ at all"
  kind: python_call_eq
  category: type_structure
  id_prefix: hbml48

  columns: [id, function, args, expected]
  rows:
    - [blake2b_mro_len, blake2b.__mro__.__len__, [], 2]
    - [blake2s_mro_len, blake2s.__mro__.__len__, [], 2]

# ---------------------------------------------------------------------------
# hashlib.blake2b and blake2s __mro__ entry __name__ string eq values
#
# No prior spec checks the __name__ of individual mro entries for blake2b or blake2s.
# blake2b.__mro__[0].__name__ == 'blake2b'  (the type itself)
# blake2b.__mro__[1].__name__ == 'object'   (the root base)
# blake2s.__mro__[0].__name__ == 'blake2s'  (the type itself)
# blake2s.__mro__[1].__name__ == 'object'   (the root base)
# ---------------------------------------------------------------------------

table hashlib_extra48.blake2_mro_entry_names:
  description: "hashlib blake2b/blake2s __mro__[0]/__name__.__eq__ and __mro__[1]/__name__.__eq__('object') — novel: no prior hashlib spec checks any blake2b or blake2s mro entry __name__ as string eq"
  kind: python_call_eq
  category: type_structure
  id_prefix: hbmen48

  columns: [id, function, args, expected]
  rows:
    - [blake2b_mro0_name_eq, "blake2b.__mro__[0].__name__.__eq__", ["blake2b"], true]
    - [blake2b_mro1_name_eq, "blake2b.__mro__[1].__name__.__eq__", ["object"],  true]
    - [blake2s_mro0_name_eq, "blake2s.__mro__[0].__name__.__eq__", ["blake2s"], true]
    - [blake2s_mro1_name_eq, "blake2s.__mro__[1].__name__.__eq__", ["object"],  true]
