spec: abc_extra248
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py (ABCMeta metaclass implementation)"
    - "CPython source: Lib/_collections_abc.py (collections.abc abstract base classes)"
  notes:
    - "collections.abc.Sequence.__name__ == 'Sequence' (len=8); __module__ == 'collections.abc' (len=15); __bases__ == ['Reversible', 'Collection'] — two bases, not one."
    - "collections.abc.Mapping.__name__ == 'Mapping' (len=7); __module__ == 'collections.abc' (len=15); __bases__[0].__name__ == 'Collection' (len=10)."
    - "collections.abc.Iterable.__name__ == 'Iterable' (len=8); __module__ == 'collections.abc' (len=15)."
    - "collections.abc.Iterator.__name__ == 'Iterator' (len=8); __module__ == 'collections.abc' (len=15); __bases__[0].__name__ == 'Iterable' (len=8) — Iterator inherits from Iterable."
    - "collections.abc.Callable.__name__ == 'Callable' (len=8); __module__ == 'collections.abc' (len=15)."
    - "type(collections.abc.Sequence).__name__ == 'ABCMeta' (len=7); __module__ == 'abc' (len=3) — all collections.abc classes use ABCMeta as their metaclass."
    - "Sequence, Iterable, Iterator, Callable all have __name__ len=8; Mapping has __name__ len=7; all have __module__ 'collections.abc' len=15."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# collections.abc class __name__ and __module__ identity
#
# Sequence.__name__ == 'Sequence' (len=8); __module__ == 'collections.abc' (len=15)
# Mapping.__name__ == 'Mapping' (len=7); __module__ == 'collections.abc' (len=15)
# Iterable.__name__ == 'Iterable' (len=8); __module__ == 'collections.abc' (len=15)
# Iterator.__name__ == 'Iterator' (len=8); __module__ == 'collections.abc' (len=15)
# Callable.__name__ == 'Callable' (len=8); __module__ == 'collections.abc' (len=15)
# ---------------------------------------------------------------------------

table abc_extra248.collections_abc_class_name_module:
  description: "collections.abc class __name__ and __module__ identity — Sequence(len=8), Iterable(len=8), Iterator(len=8), Callable(len=8) all share len=8 for __name__; Mapping(len=7) is one shorter; all share __module__=='collections.abc'(len=15); these are abstract base classes defined via ABCMeta from the abc module; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc248nm

  columns: [id, function, args, expected, description]
  rows:
    - [seq_name_eq,    Sequence.__name__.__eq__,   ["Sequence"],        true, "collections.abc.Sequence.__name__ == 'Sequence'; verified with Python 3.14.3"]
    - [seq_name_len,   Sequence.__name__.__len__,  [],                  8,    "collections.abc.Sequence.__name__.__len__() == 8; verified with Python 3.14.3"]
    - [seq_mod_eq,     Sequence.__module__.__eq__,  ["collections.abc"], true, "collections.abc.Sequence.__module__ == 'collections.abc'; verified with Python 3.14.3"]
    - [seq_mod_len,    Sequence.__module__.__len__, [],                  15,   "collections.abc.Sequence.__module__.__len__() == 15; verified with Python 3.14.3"]
    - [mp_name_eq,     Mapping.__name__.__eq__,    ["Mapping"],         true, "collections.abc.Mapping.__name__ == 'Mapping'; verified with Python 3.14.3"]
    - [mp_name_len,    Mapping.__name__.__len__,   [],                  7,    "collections.abc.Mapping.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [mp_mod_eq,      Mapping.__module__.__eq__,   ["collections.abc"], true, "collections.abc.Mapping.__module__ == 'collections.abc'; verified with Python 3.14.3"]
    - [mp_mod_len,     Mapping.__module__.__len__,  [],                  15,   "collections.abc.Mapping.__module__.__len__() == 15; verified with Python 3.14.3"]
    - [it_name_eq,     Iterable.__name__.__eq__,   ["Iterable"],        true, "collections.abc.Iterable.__name__ == 'Iterable'; verified with Python 3.14.3"]
    - [it_name_len,    Iterable.__name__.__len__,  [],                  8,    "collections.abc.Iterable.__name__.__len__() == 8; verified with Python 3.14.3"]
    - [it_mod_eq,      Iterable.__module__.__eq__,  ["collections.abc"], true, "collections.abc.Iterable.__module__ == 'collections.abc'; verified with Python 3.14.3"]
    - [itr_name_eq,    Iterator.__name__.__eq__,   ["Iterator"],        true, "collections.abc.Iterator.__name__ == 'Iterator'; verified with Python 3.14.3"]
    - [itr_name_len,   Iterator.__name__.__len__,  [],                  8,    "collections.abc.Iterator.__name__.__len__() == 8; verified with Python 3.14.3"]
    - [itr_mod_eq,     Iterator.__module__.__eq__,  ["collections.abc"], true, "collections.abc.Iterator.__module__ == 'collections.abc'; verified with Python 3.14.3"]
    - [cal_name_eq,    Callable.__name__.__eq__,   ["Callable"],        true, "collections.abc.Callable.__name__ == 'Callable'; verified with Python 3.14.3"]
    - [cal_name_len,   Callable.__name__.__len__,  [],                  8,    "collections.abc.Callable.__name__.__len__() == 8; verified with Python 3.14.3"]
    - [cal_mod_eq,     Callable.__module__.__eq__,  ["collections.abc"], true, "collections.abc.Callable.__module__ == 'collections.abc'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# collections.abc class inheritance (base class names)
#
# Sequence.__bases__[0].__name__ == 'Reversible' (len=10)
# Sequence.__bases__[1].__name__ == 'Collection' (len=10)
# Mapping.__bases__[0].__name__ == 'Collection' (len=10)
# Iterator.__bases__[0].__name__ == 'Iterable' (len=8)
# ---------------------------------------------------------------------------

table abc_extra248.collections_abc_class_bases:
  description: "collections.abc class base class identity — Sequence has two bases: Reversible(len=10) and Collection(len=10); Mapping has one base: Collection(len=10); Iterator's base is Iterable(len=8), establishing the Iterator->Iterable chain; ABCMeta metaclass (type(Sequence).__name__=='ABCMeta', len=7, from module 'abc', len=3) governs all these abstract base classes; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc248base

  columns: [id, function, args, expected, description]
  rows:
    - [seq_base0_eq,   "Sequence.__bases__[0].__name__.__eq__",  ["Reversible"],  true, "collections.abc.Sequence.__bases__[0].__name__ == 'Reversible'; verified with Python 3.14.3"]
    - [seq_base0_len,  "Sequence.__bases__[0].__name__.__len__", [],              10,   "collections.abc.Sequence.__bases__[0].__name__.__len__() == 10; verified with Python 3.14.3"]
    - [seq_base1_eq,   "Sequence.__bases__[1].__name__.__eq__",  ["Collection"],  true, "collections.abc.Sequence.__bases__[1].__name__ == 'Collection'; verified with Python 3.14.3"]
    - [seq_base1_len,  "Sequence.__bases__[1].__name__.__len__", [],              10,   "collections.abc.Sequence.__bases__[1].__name__.__len__() == 10; verified with Python 3.14.3"]
    - [mp_base0_eq,    "Mapping.__bases__[0].__name__.__eq__",   ["Collection"],  true, "collections.abc.Mapping.__bases__[0].__name__ == 'Collection'; verified with Python 3.14.3"]
    - [mp_base0_len,   "Mapping.__bases__[0].__name__.__len__",  [],              10,   "collections.abc.Mapping.__bases__[0].__name__.__len__() == 10; verified with Python 3.14.3"]
    - [itr_base0_eq,   "Iterator.__bases__[0].__name__.__eq__",  ["Iterable"],    true, "collections.abc.Iterator.__bases__[0].__name__ == 'Iterable' — Iterator inherits from Iterable; verified with Python 3.14.3"]
    - [itr_base0_len,  "Iterator.__bases__[0].__name__.__len__", [],              8,    "collections.abc.Iterator.__bases__[0].__name__.__len__() == 8; verified with Python 3.14.3"]
    - [seq_meta_eq,    Sequence.__class__.__name__.__eq__,       ["ABCMeta"],     true, "type(collections.abc.Sequence).__name__ == 'ABCMeta' — Sequence uses ABCMeta metaclass from abc module; verified with Python 3.14.3"]
    - [seq_meta_len,   Sequence.__class__.__name__.__len__,      [],              7,    "type(collections.abc.Sequence).__name__.__len__() == 7; verified with Python 3.14.3"]
    - [seq_meta_mod,   Sequence.__class__.__module__.__eq__,     ["abc"],         true, "type(collections.abc.Sequence).__module__ == 'abc' — ABCMeta is defined in the abc module; verified with Python 3.14.3"]
    - [seq_meta_mlen,  Sequence.__class__.__module__.__len__,    [],              3,    "type(collections.abc.Sequence).__module__.__len__() == 3; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra248
# ---------------------------------------------------------------------------

invariant abc_extra248.iterator_inherits_iterable:
  description: "collections.abc.Iterator.__bases__[0].__name__.__eq__('Iterable') returns True — Iterator inherits from Iterable, establishing the Iterator->Iterable chain; Iterator.__name__=='Iterator'(len=8) and its base Iterable.__name__=='Iterable'(len=8) share the same name length; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Iterator.__bases__[0].__name__.__eq__"
  args: ["Iterable"]
  expected: true

invariant abc_extra248.sequence_metaclass_is_abcmeta:
  description: "type(collections.abc.Sequence).__name__.__eq__('ABCMeta') returns True — Sequence (and all collections.abc classes) use ABCMeta as their metaclass; ABCMeta.__name__=='ABCMeta'(len=7); ABCMeta.__module__=='abc'(len=3); this confirms abc module integration with collections.abc abstract base classes; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Sequence.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true
