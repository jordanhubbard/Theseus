spec: struct_extra264
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra263.zspec.zsdl — covers struct.error class identity; pack/unpack raises struct.error for invalid arguments."
    - "struct_extra262.zspec.zsdl — covers Struct method __name__/__class__/__qualname__ identity; Struct.size/format getset_descriptor identity."
    - "struct_extra261.zspec.zsdl — covers struct module-level function identity."
  notes:
    - "struct.calcsize('!HH') == 4 — two network-order unsigned shorts (2+2 bytes). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('!BHI') == 7 — unsigned byte (1) + unsigned short (2) + unsigned int (4) = 7 bytes, network order. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('!hhi') == 8 — two signed shorts (2+2) + signed int (4) = 8 bytes, network order. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('!4s') == 4 — 4-byte char array, network order. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('!II') == 8 — two network-order unsigned ints (4+4 bytes). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('!IHH') == 8 — unsigned int (4) + two unsigned shorts (2+2) = 8 bytes, network order. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('!BI') == 5 — unsigned byte (1) + unsigned int (4) = 5 bytes, network order. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('!BBB') == 3 — three unsigned bytes = 3 bytes, network order. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.pack.__class__.__name__ == 'builtin_function_or_method' — pack is a C builtin from _struct extension. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize.__class__.__name__ == 'builtin_function_or_method' — calcsize is a C builtin from _struct extension. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.calcsize for multi-format strings — network byte order ('!')
# These are deterministic sizes independent of platform architecture since
# '!' forces big-endian (network) byte order with fixed-size types.
# ---------------------------------------------------------------------------

table struct_extra264.calcsize_network_order_formats:
  description: "struct.calcsize for multi-format network-order strings — !HH/!BHI/!hhi/!4s/!II deterministic sizes; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: structcalc264

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_HH,  calcsize.__eq__, [4],  true, "struct.calcsize('!HH') == 4 — checked indirectly; two unsigned shorts 2+2=4 bytes network order"]
    - [calcsize_BHI, calcsize.__eq__, [7],  true, "struct.calcsize('!BHI') == 7 — checked indirectly; byte(1)+short(2)+int(4)=7 bytes network order"]
    - [calcsize_hhi, calcsize.__eq__, [8],  true, "struct.calcsize('!hhi') == 8 — checked indirectly; short(2)+short(2)+int(4)=8 bytes network order"]
    - [calcsize_4s,  calcsize.__eq__, [4],  true, "struct.calcsize('!4s') == 4 — checked indirectly; 4-byte char array network order"]
    - [calcsize_II,  calcsize.__eq__, [8],  true, "struct.calcsize('!II') == 8 — checked indirectly; two unsigned ints 4+4=8 bytes network order"]

# ---------------------------------------------------------------------------
# struct module-level function class identity
# pack, unpack, calcsize are all C builtins from the _struct extension.
# ---------------------------------------------------------------------------

table struct_extra264.module_function_class_identity:
  description: "struct.pack/unpack/calcsize __class__.__name__ identity — all are 'builtin_function_or_method' from _struct C extension; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: structfcls264

  columns: [id, function, args, expected, description]
  rows:
    - [pack_class,     pack.__class__.__name__.__eq__,     ["builtin_function_or_method"], true, "struct.pack.__class__.__name__ == 'builtin_function_or_method' — C builtin from _struct extension"]
    - [unpack_class,   unpack.__class__.__name__.__eq__,   ["builtin_function_or_method"], true, "struct.unpack.__class__.__name__ == 'builtin_function_or_method' — C builtin from _struct extension"]
    - [calcsize_class, calcsize.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "struct.calcsize.__class__.__name__ == 'builtin_function_or_method' — C builtin from _struct extension"]
    - [pack_name,      pack.__name__.__eq__,               ["pack"],                       true, "struct.pack.__name__ == 'pack' — C builtin function name matches attribute name"]
    - [calcsize_name,  calcsize.__name__.__eq__,           ["calcsize"],                   true, "struct.calcsize.__name__ == 'calcsize' — C builtin function name matches attribute name"]

# ---------------------------------------------------------------------------
# struct.calcsize standalone invariants — specific multi-format strings
# Direct calcsize calls with specific format strings, checking return values.
# ---------------------------------------------------------------------------

invariant struct_extra264.calcsize_HH_eq:
  description: "struct.calcsize('!HH') == 4 — two network-order unsigned shorts (H=2 bytes each); total 4 bytes; deterministic on all platforms; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: calcsize
  args: ["!HH"]
  expected: 4

invariant struct_extra264.calcsize_BHI_eq:
  description: "struct.calcsize('!BHI') == 7 — unsigned byte (1) + unsigned short (2) + unsigned int (4) = 7 bytes; network byte order; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: calcsize
  args: ["!BHI"]
  expected: 7

invariant struct_extra264.calcsize_hhi_eq:
  description: "struct.calcsize('!hhi') == 8 — two signed shorts (2+2) + signed int (4) = 8 bytes; network byte order; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: calcsize
  args: ["!hhi"]
  expected: 8

invariant struct_extra264.calcsize_4s_eq:
  description: "struct.calcsize('!4s') == 4 — 4-character byte string; network byte order; size is always 4; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: calcsize
  args: ["!4s"]
  expected: 4

invariant struct_extra264.calcsize_II_eq:
  description: "struct.calcsize('!II') == 8 — two network-order unsigned ints (4+4 bytes); deterministic on all platforms; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: calcsize
  args: ["!II"]
  expected: 8

invariant struct_extra264.calcsize_IHH_eq:
  description: "struct.calcsize('!IHH') == 8 — unsigned int (4) + two unsigned shorts (2+2) = 8 bytes; network byte order; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: calcsize
  args: ["!IHH"]
  expected: 8

invariant struct_extra264.calcsize_BI_eq:
  description: "struct.calcsize('!BI') == 5 — unsigned byte (1) + unsigned int (4) = 5 bytes; network byte order; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: calcsize
  args: ["!BI"]
  expected: 5

invariant struct_extra264.calcsize_BBB_eq:
  description: "struct.calcsize('!BBB') == 3 — three unsigned bytes = 3 bytes; network byte order; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: calcsize
  args: ["!BBB"]
  expected: 3
