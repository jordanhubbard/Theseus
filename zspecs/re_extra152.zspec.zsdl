spec: re_extra152
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.__dict__.__contains__ membership for functions, types, flags, and other names exported by the re module."
    - "re.__dict__ is a plain dict (len==62 on Python 3.14.3). All the major re module names are present."
    - "re.__dict__.__contains__('compile') == True, re.__dict__.__contains__('match') == True, etc."
    - "re.__dict__.__contains__('Pattern') == True (the compiled regex type); re.__dict__.__contains__('Match') == True (the match object type)."
    - "re.__dict__.__contains__('error') == True and re.__dict__.__contains__('PatternError') == True — both names exist because PatternError was the new name in Python 3.14, with error as a backward-compatible alias."
    - "re.__dict__.__contains__('RegexFlag') == True — the enum.IntFlag subclass for regex flags."
    - "Flag membership: IGNORECASE, DOTALL, MULTILINE, UNICODE, ASCII, VERBOSE, NOFLAG are all True."
    - "re.__dict__.__contains__('NOFLAG') == True — the zero-value flag introduced for clarity; re.NOFLAG == 0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.__dict__.__contains__ — function membership
# compile, match, search, fullmatch, findall, finditer, sub, subn,
# split, escape, purge all True.
# ---------------------------------------------------------------------------

table re_extra152.dict_contains_functions:
  description: "re.__dict__.__contains__: core re functions compile/match/search/fullmatch/findall/finditer/sub/subn/split/escape/purge are all True"
  kind: python_call_eq
  category: dict_membership
  id_prefix: redict152

  columns: [id, function, args, expected, description]
  rows:
    - [has_compile,   __dict__.__contains__, ["compile"],   true, "re.__dict__.__contains__('compile') == True (re.compile() takes pattern and flags; returns a compiled Pattern object with match/search/findall methods)"]
    - [has_match,     __dict__.__contains__, ["match"],     true, "re.__dict__.__contains__('match') == True (re.match() tries to match pattern at the beginning of string; equivalent to re.compile(pattern).match(string))"]
    - [has_search,    __dict__.__contains__, ["search"],    true, "re.__dict__.__contains__('search') == True (re.search() scans through string looking for a location where pattern matches; unlike match() it does not anchor to the start)"]
    - [has_fullmatch, __dict__.__contains__, ["fullmatch"], true, "re.__dict__.__contains__('fullmatch') == True (re.fullmatch() requires the pattern to match the entire string; added in Python 3.4)"]
    - [has_findall,   __dict__.__contains__, ["findall"],   true, "re.__dict__.__contains__('findall') == True (re.findall() returns all non-overlapping matches of pattern in string as a list of strings)"]
    - [has_sub,       __dict__.__contains__, ["sub"],       true, "re.__dict__.__contains__('sub') == True (re.sub() returns the string obtained by replacing leftmost non-overlapping occurrences of pattern with repl)"]
    - [has_split,     __dict__.__contains__, ["split"],     true, "re.__dict__.__contains__('split') == True (re.split() splits string at each match of pattern; like str.split() but for regex patterns)"]

# ---------------------------------------------------------------------------
# re.__dict__.__contains__ — type membership
# Pattern, Match, error, PatternError, RegexFlag all True.
# ---------------------------------------------------------------------------

table re_extra152.dict_contains_types:
  description: "re.__dict__.__contains__: types Pattern/Match/error/PatternError/RegexFlag are all True"
  kind: python_call_eq
  category: dict_membership
  id_prefix: redict152

  columns: [id, function, args, expected, description]
  rows:
    - [has_Pattern,      __dict__.__contains__, ["Pattern"],      true, "re.__dict__.__contains__('Pattern') == True (re.Pattern is the compiled regex type; instances are created by re.compile() and also by match()/search() on the module)"]
    - [has_Match,        __dict__.__contains__, ["Match"],        true, "re.__dict__.__contains__('Match') == True (re.Match is the match object type; instances are returned by Pattern.match(), Pattern.search(), Pattern.fullmatch())"]
    - [has_error,        __dict__.__contains__, ["error"],        true, "re.__dict__.__contains__('error') == True (re.error is the exception raised for invalid regex patterns; it is an alias for re.PatternError since Python 3.14)"]
    - [has_PatternError, __dict__.__contains__, ["PatternError"], true, "re.__dict__.__contains__('PatternError') == True (re.PatternError is the canonical name for the regex exception since Python 3.14; re.error is a backward-compatible alias)"]
    - [has_RegexFlag,    __dict__.__contains__, ["RegexFlag"],    true, "re.__dict__.__contains__('RegexFlag') == True (re.RegexFlag is an enum.IntFlag subclass that defines all regex flag constants; IGNORECASE, DOTALL, MULTILINE, etc. are members)"]

# ---------------------------------------------------------------------------
# re.__dict__.__contains__ — flag constant membership
# IGNORECASE, DOTALL, MULTILINE, UNICODE, ASCII, VERBOSE, NOFLAG all True.
# re.__dict__.__len__() == 62.
# re.__dict__.__class__.__name__ == 'dict'.
# ---------------------------------------------------------------------------

table re_extra152.dict_contains_flags:
  description: "re.__dict__.__contains__: flag constants IGNORECASE/DOTALL/MULTILINE/UNICODE/ASCII/VERBOSE/NOFLAG are all True; __dict__.__len__()==62"
  kind: python_call_eq
  category: dict_membership
  id_prefix: redict152

  columns: [id, function, args, expected, description]
  rows:
    - [has_IGNORECASE,  __dict__.__contains__, ["IGNORECASE"],  true, "re.__dict__.__contains__('IGNORECASE') == True (re.IGNORECASE (==re.I) makes the pattern case-insensitive; equivalent to setting (?i) inline in the pattern)"]
    - [has_DOTALL,      __dict__.__contains__, ["DOTALL"],      true, "re.__dict__.__contains__('DOTALL') == True (re.DOTALL (==re.S) makes . match any character including newline; without it, . matches everything except newline)"]
    - [has_MULTILINE,   __dict__.__contains__, ["MULTILINE"],   true, "re.__dict__.__contains__('MULTILINE') == True (re.MULTILINE (==re.M) makes ^ and $ match at the start and end of each line, not just the whole string)"]
    - [has_UNICODE,     __dict__.__contains__, ["UNICODE"],     true, "re.__dict__.__contains__('UNICODE') == True (re.UNICODE (==re.U) enables Unicode matching; the default for str patterns; \\w \\d \\s etc. match Unicode character categories)"]
    - [has_ASCII,       __dict__.__contains__, ["ASCII"],       true, "re.__dict__.__contains__('ASCII') == True (re.ASCII (==re.A) makes \\w \\d \\s and \\b perform ASCII-only matching instead of Unicode; mutually exclusive with UNICODE for str patterns)"]
    - [has_VERBOSE,     __dict__.__contains__, ["VERBOSE"],     true, "re.__dict__.__contains__('VERBOSE') == True (re.VERBOSE (==re.X) allows verbose regex patterns with whitespace and comments for readability)"]
    - [has_NOFLAG,      __dict__.__contains__, ["NOFLAG"],      true, "re.__dict__.__contains__('NOFLAG') == True (re.NOFLAG == 0; the zero-value flag introduced in Python 3.11 for clarity when explicitly meaning no flags set)"]
    - [dict_len,        __dict__.__len__,      [],              62,   "re.__dict__.__len__() == 62 — the re module exports 62 names; includes all functions, types, flag constants (long and short forms like IGNORECASE and I), and dunder module attributes"]
    - [dict_cls_eq,     __dict__.__class__.__name__.__eq__, ["dict"], true, "re.__dict__.__class__.__name__ == 'dict' (module __dict__ is a plain mutable dict, unlike class __dict__ which is a read-only mappingproxy)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra152.dict.has_compile:
  description: "re.__dict__.__contains__('compile') == True — re.compile() is the primary way to create a compiled regex Pattern object; it accepts pattern and optional flags and returns a re.Pattern; compiled patterns are faster than repeated module-level match/search calls because the regex is compiled only once"
  category: dict_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["compile"]
  expected: true

invariant re_extra152.dict.has_Pattern:
  description: "re.__dict__.__contains__('Pattern') == True — re.Pattern is the type of compiled regular expression objects; instances have methods match(), search(), fullmatch(), findall(), finditer(), sub(), subn(), split(); the type's __name__ == 'Pattern' (not 're.Pattern')"
  category: dict_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["Pattern"]
  expected: true

invariant re_extra152.dict.has_Match:
  description: "re.__dict__.__contains__('Match') == True — re.Match is the type of match objects returned by Pattern.match(), Pattern.search(), Pattern.fullmatch() etc.; match objects provide group(), groups(), groupdict(), start(), end(), span() and other methods for inspecting the match"
  category: dict_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["Match"]
  expected: true

invariant re_extra152.dict.has_error:
  description: "re.__dict__.__contains__('error') == True — re.error is the exception raised when a string passed to one of the re functions is not a valid regular expression or when some error occurs during compilation or matching; in Python 3.14 it is an alias for re.PatternError"
  category: dict_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["error"]
  expected: true

invariant re_extra152.dict.has_RegexFlag:
  description: "re.__dict__.__contains__('RegexFlag') == True — re.RegexFlag is an enum.IntFlag subclass that groups all regex flag constants; IGNORECASE, DOTALL, MULTILINE, UNICODE, ASCII, VERBOSE, NOFLAG are all members; being an IntFlag allows flags to be combined with | operator"
  category: dict_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["RegexFlag"]
  expected: true

invariant re_extra152.dict.has_NOFLAG:
  description: "re.__dict__.__contains__('NOFLAG') == True — re.NOFLAG == 0 is the zero-value RegexFlag member introduced in Python 3.11; it provides a named constant for the absence of any flags, making code more explicit than passing the integer 0 as the flags argument"
  category: dict_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["NOFLAG"]
  expected: true

invariant re_extra152.dict.len_62:
  description: "re.__dict__.__len__() == 62 — the re module exports 62 names on Python 3.14.3; this includes 11 functions (compile, match, search, fullmatch, findall, finditer, sub, subn, split, escape, purge), 5 types (Pattern, Match, error, PatternError, RegexFlag), flag constants in both long form (IGNORECASE, DOTALL, etc.) and short form (I, S, M, U, A, X, L) aliases, and standard module dunder attributes"
  category: dict_membership
  kind: python_call_eq
  function: __dict__.__len__
  args: []
  expected: 62
