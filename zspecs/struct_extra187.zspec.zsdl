spec: struct_extra187
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "struct.Struct.__name__ == 'Struct' — the class name as a string; len=6."
    - "struct.Struct.__module__ == '_struct' — Struct is implemented in the _struct C extension; len=7."
    - "struct.Struct.__bases__[0].__name__ == 'object' — Struct inherits directly from object."
    - "struct.Struct.__class__.__name__ == 'type' — Struct is a metaclass instance (a type)."
    - "struct.Struct.__init__.__qualname__ == 'Struct.__init__' — qualified name of the __init__ slot; len=15."
    - "struct.Struct.size.__class__.__name__ == 'getset_descriptor' — size is a C-level getset descriptor, not a property."
    - "struct.Struct.format.__class__.__name__ == 'getset_descriptor' — format is also a C-level getset descriptor."
    - "struct.Struct.__doc__.__class__.__name__ == 'str' — the docstring is a plain Python str."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: struct.Struct class name and module identity
#
# struct.Struct.__name__   == 'Struct'  (len=6)
# struct.Struct.__module__ == '_struct' (len=7)
# struct.Struct.__class__.__name__ == 'type'
#
# Struct is a C-extension type defined in Modules/_struct.c; its __module__
# is '_struct' (the private C extension), not 'struct' (the public wrapper).
# ---------------------------------------------------------------------------

table struct_extra187.Struct_class_identity:
  description: "struct.Struct class name, module, and metaclass identity; new to extra187"
  kind: python_call_eq
  category: identity
  id_prefix: structclass187

  columns: [id, function, args, expected, description]
  rows:
    - [struct_name_eq,
       Struct.__name__.__eq__,
       ["Struct"],
       true,
       "Struct.__name__.__eq__('Struct') == True — class is named 'Struct'; new to extra187"]
    - [struct_name_len,
       Struct.__name__.__len__,
       [],
       6,
       "Struct.__name__.__len__() == 6 — 'Struct' has 6 characters; new to extra187"]
    - [struct_module_eq,
       Struct.__module__.__eq__,
       ["_struct"],
       true,
       "Struct.__module__.__eq__('_struct') == True — implemented in _struct C extension; new to extra187"]
    - [struct_module_len,
       Struct.__module__.__len__,
       [],
       7,
       "Struct.__module__.__len__() == 7 — '_struct' has 7 characters; new to extra187"]
    - [struct_class_name_eq,
       Struct.__class__.__name__.__eq__,
       ["type"],
       true,
       "Struct.__class__.__name__.__eq__('type') == True — Struct is a type (metaclass instance); new to extra187"]

# ---------------------------------------------------------------------------
# Table 2: struct.Struct.__init__ qualname and __bases__ parent
#
# struct.Struct.__init__.__qualname__ == 'Struct.__init__' (len=15)
# struct.Struct.__bases__[0].__name__ == 'object'
#
# __bases__[0] is accessed via __bases__.__getitem__(0) to avoid brackets
# in the function: field (brackets must be double-quoted per spec rules, or
# avoided using __getitem__ in table rows).
# ---------------------------------------------------------------------------

table struct_extra187.Struct_init_and_bases:
  description: "struct.Struct.__init__ qualname and __bases__ parent class name; new to extra187"
  kind: python_call_eq
  category: identity
  id_prefix: structclass187

  columns: [id, function, args, expected, description]
  rows:
    - [init_qualname_eq,
       Struct.__init__.__qualname__.__eq__,
       ["Struct.__init__"],
       true,
       "Struct.__init__.__qualname__.__eq__('Struct.__init__') == True — qualified name of __init__; new to extra187"]
    - [init_qualname_len,
       Struct.__init__.__qualname__.__len__,
       [],
       15,
       "Struct.__init__.__qualname__.__len__() == 15 — 'Struct.__init__' has 15 characters; new to extra187"]
    - [bases_getitem_name_eq,
       Struct.__bases__.__getitem__,
       [0],
       "object",
       "Struct.__bases__.__getitem__(0).__name__ resolution — base class is 'object'; new to extra187"]

# ---------------------------------------------------------------------------
# Table 3: struct.Struct descriptor and docstring class names
#
# struct.Struct.size.__class__.__name__   == 'getset_descriptor' (len=17)
# struct.Struct.format.__class__.__name__ == 'getset_descriptor'
# struct.Struct.__doc__.__class__.__name__ == 'str'
#
# size and format are C-level getset descriptors (not Python properties).
# The docstring (__doc__) is a plain str.
# ---------------------------------------------------------------------------

table struct_extra187.Struct_descriptor_types:
  description: "struct.Struct size/format are getset_descriptor; __doc__ is str; new to extra187"
  kind: python_call_eq
  category: identity
  id_prefix: structclass187

  columns: [id, function, args, expected, description]
  rows:
    - [size_class_name_eq,
       Struct.size.__class__.__name__.__eq__,
       ["getset_descriptor"],
       true,
       "Struct.size.__class__.__name__.__eq__('getset_descriptor') == True — size is a C-level getset; new to extra187"]
    - [size_class_name_len,
       Struct.size.__class__.__name__.__len__,
       [],
       17,
       "Struct.size.__class__.__name__.__len__() == 17 — 'getset_descriptor' has 17 characters; new to extra187"]
    - [format_class_name_eq,
       Struct.format.__class__.__name__.__eq__,
       ["getset_descriptor"],
       true,
       "Struct.format.__class__.__name__.__eq__('getset_descriptor') == True — format is a C-level getset; new to extra187"]
    - [doc_class_name_eq,
       Struct.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "Struct.__doc__.__class__.__name__.__eq__('str') == True — docstring is a plain str; new to extra187"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra187
# ---------------------------------------------------------------------------

invariant struct_extra187.Struct_name_is_Struct:
  description: "struct.Struct.__name__ == 'Struct' — class is named 'Struct'; len=6; new to extra187"
  category: identity
  kind: python_call_eq
  function: Struct.__name__.__eq__
  args: ["Struct"]
  expected: true

invariant struct_extra187.Struct_module_is_c_extension:
  description: "struct.Struct.__module__ == '_struct' — C extension module, not the public 'struct' wrapper; len=7; new to extra187"
  category: identity
  kind: python_call_eq
  function: Struct.__module__.__eq__
  args: ["_struct"]
  expected: true

invariant struct_extra187.Struct_base_is_object:
  description: "struct.Struct.__bases__[0].__name__ == 'object' — Struct inherits directly from object; new to extra187"
  category: identity
  kind: python_call_eq
  function: "Struct.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant struct_extra187.Struct_class_is_type:
  description: "struct.Struct.__class__.__name__ == 'type' — Struct is a C extension type (metaclass instance); new to extra187"
  category: identity
  kind: python_call_eq
  function: Struct.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant struct_extra187.Struct_init_qualname:
  description: "struct.Struct.__init__.__qualname__ == 'Struct.__init__' — qualified name of __init__; len=15; new to extra187"
  category: identity
  kind: python_call_eq
  function: Struct.__init__.__qualname__.__eq__
  args: ["Struct.__init__"]
  expected: true

invariant struct_extra187.Struct_size_is_getset_descriptor:
  description: "struct.Struct.size.__class__.__name__ == 'getset_descriptor' — size is a C-level descriptor, not a property; len=17; new to extra187"
  category: identity
  kind: python_call_eq
  function: Struct.size.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

invariant struct_extra187.Struct_format_is_getset_descriptor:
  description: "struct.Struct.format.__class__.__name__ == 'getset_descriptor' — format is a C-level descriptor, not a property; new to extra187"
  category: identity
  kind: python_call_eq
  function: Struct.format.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

invariant struct_extra187.Struct_doc_is_str:
  description: "struct.Struct.__doc__.__class__.__name__ == 'str' — docstring is a plain Python str; new to extra187"
  category: identity
  kind: python_call_eq
  function: Struct.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
