spec: last_item
version: ">=2.0.0"
backend: node(last-item)

docs: https://www.npmjs.com/package/last-item

provenance:
  derived_from:
    - "last-item README — https://www.npmjs.com/package/last-item"
    - "Test vectors verified with last-item via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "last-item source"
  notes:
    - "last-item is an npm package. Install: npm install last-item"
    - "Returns the last element of an array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the last element."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table last_item.get:
  kind: node_module_call_eq
  function: "default"
  category: array
  id_prefix: litem

  columns: [id, args, expected]
  rows:
    - [numbers,  [[1, 2, 3]],         3]
    - [strings,  [["a", "b", "c"]],   "c"]
    - [single,   [[42]],              42]
