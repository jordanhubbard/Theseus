spec: p_reduce
version: ">=3.0.0"
backend: node(p-reduce)
esm: true

docs: https://github.com/sindresorhus/p-reduce#readme

provenance:
  derived_from:
    - "p-reduce README — https://github.com/sindresorhus/p-reduce#readme"
    - "Test vectors verified with p-reduce via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "p-reduce source"
  notes:
    - "Async Array.reduce — reducer can return a Promise; sequential by design."
    - "Install: npm install p-reduce"
    - "v3 ESM only; default export pReduce(array, reducer, [initialValue])."
    - "Spec covers shape only — JSON entry_args cannot pass async-function reducers."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Returned promise rejects if reducer throws."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant p_reduce.default_export_is_function:
  description: "Default export is an async function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.constructor.name"}
  expected: "AsyncFunction"

invariant p_reduce.default_name:
  description: "Default function name is 'pReduce'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.name"}
  expected: "pReduce"

invariant p_reduce.default_arity:
  description: "Default function takes 3 args (array, reducer, initialValue)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.length"}
  expected: 3

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:22:18Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
