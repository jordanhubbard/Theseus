spec: decimal_extra144
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.__spec__ and loader identity — decimal.__loader__.__class__.__name__ == 'SourceFileLoader', decimal.__spec__.parent == '' (decimal is a top-level module, not a package), decimal.__package__ == ''. Also covers decimal.Decimal.__dict__ and decimal.Context.__dict__ mappingproxy lengths and MRO depths. Also covers decimal.Context method __qualname__ values not covered in prior specs."
    - "decimal.__loader__.__class__.__name__ == 'SourceFileLoader' (len=16) — decimal is a Python source file at Lib/_pydecimal.py (or the C accelerated _decimal); its loader is a SourceFileLoader instance like pathlib and re."
    - "decimal.__package__ == '' (empty string, len=0); decimal.__spec__.parent == '' — decimal is a single top-level module, not a package; same as io."
    - "decimal.Decimal.__dict__.__len__() == 101 (the largest __dict__ among all classes in this spec family); decimal.Context.__dict__.__len__() == 85."
    - "decimal.Decimal.__dict__.__class__.__name__ == 'mappingproxy' (len=12)."
    - "decimal.Context method qualnames not in decimal_extra141: Context.create_decimal_from_float (len=33, the longest Context method qualname), Context.compare_total_mag (len=25), Context.to_integral_exact/to_integral_value (both len=25)."
    - "decimal.Context.create_decimal_from_float.__qualname__ == 'Context.create_decimal_from_float' (len=33; the longest method qualname among all decimal classes)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.__spec__ and loader identity
# decimal.__loader__.__class__.__name__ == 'SourceFileLoader' (len=16).
# decimal.__spec__.parent == '' (decimal is a top-level module, not a package).
# decimal.__package__ == '' (empty string).
# ---------------------------------------------------------------------------

table decimal_extra144.spec_and_loader_identity:
  description: "decimal.__spec__ and loader identity: __loader__.__class__.__name__=='SourceFileLoader' (16), __spec__.parent=='' (0), __package__=='' (0)"
  kind: python_call_eq
  category: identity
  id_prefix: decspec144

  columns: [id, function, args, expected, description]
  rows:
    - [spec_cls_eq,     __spec__.__class__.__name__.__eq__,   ["ModuleSpec"],      true, "decimal.__spec__.__class__.__name__ == 'ModuleSpec' (same as io, pathlib, and re; all module specs are ModuleSpec instances)"]
    - [loader_cls_eq,   __loader__.__class__.__name__.__eq__,  ["SourceFileLoader"],true, "decimal.__loader__.__class__.__name__ == 'SourceFileLoader' (len=16) — decimal is a Python source file; its loader is a SourceFileLoader instance like pathlib and re; contrasts with io whose loader class is 'type' (FrozenImporter)"]
    - [loader_cls_len,  __loader__.__class__.__name__.__len__, [],                  16,   "decimal.__loader__.__class__.__name__.__len__() == 16 ('SourceFileLoader' has 16 characters; the same loader class as pathlib and re)"]
    - [pkg_eq,          __package__.__eq__,                   [""],                true, "decimal.__package__ == '' (empty string; decimal is a single top-level module, not a package; same as io; differs from re (__package__=='re') and pathlib (__package__=='pathlib') which are packages)"]
    - [pkg_len,         __package__.__len__,                  [],                  0,    "decimal.__package__.__len__() == 0 (empty string has 0 characters; same as io.__package__.__len__())"]
    - [spec_parent_eq,  __spec__.parent.__eq__,               [""],                true, "decimal.__spec__.parent == '' (empty string; decimal is not a package so its parent is empty; same as io.__spec__.parent; differs from re.__spec__.parent=='re' and pathlib.__spec__.parent=='pathlib')"]
    - [spec_name_eq,    __spec__.name.__eq__,                  ["decimal"],        true, "decimal.__spec__.name == 'decimal' (the module spec name; len=7)"]

# ---------------------------------------------------------------------------
# decimal.Decimal.__dict__ mappingproxy identity and size
# decimal.Decimal.__dict__.__len__() == 101 (the largest __dict__ in this spec family).
# decimal.Context.__dict__.__len__() == 85.
# Both have MRO length 2 ([Decimal/Context, object]).
# ---------------------------------------------------------------------------

table decimal_extra144.Decimal_Context_dict_identity:
  description: "decimal.Decimal.__dict__ identity: __class__.__name__=='mappingproxy', __len__()==101; decimal.Context.__dict__.__len__()==85; both MRO len==2"
  kind: python_call_eq
  category: identity
  id_prefix: decspec144

  columns: [id, function, args, expected, description]
  rows:
    - [dec_dict_cls_eq,  Decimal.__dict__.__class__.__name__.__eq__,  ["mappingproxy"], true, "decimal.Decimal.__dict__.__class__.__name__ == 'mappingproxy' (Decimal.__dict__ is a read-only mappingproxy like all class __dict__ attributes)"]
    - [dec_dict_cls_len, Decimal.__dict__.__class__.__name__.__len__, [],               12,   "decimal.Decimal.__dict__.__class__.__name__.__len__() == 12 ('mappingproxy' has 12 characters; the same for all class __dict__ attributes)"]
    - [dec_dict_len,     Decimal.__dict__.__len__,                    [],               101,  "decimal.Decimal.__dict__.__len__() == 101 (Decimal has 101 entries — the most of any class in this spec family; includes all arithmetic operators, comparison dunders, predicate methods, conversion methods, copy methods, and formatting/pickling dunders)"]
    - [ctx_dict_cls_eq,  Context.__dict__.__class__.__name__.__eq__,  ["mappingproxy"], true, "decimal.Context.__dict__.__class__.__name__ == 'mappingproxy' (Context.__dict__ is also a mappingproxy)"]
    - [ctx_dict_len,     Context.__dict__.__len__,                    [],               85,   "decimal.Context.__dict__.__len__() == 85 (Context has 85 entries; fewer than Decimal (101); Context mirrors most Decimal methods but omits arithmetic operators, adding Context-specific methods like create_decimal, create_decimal_from_float, Etiny, Etop, clear_flags, clear_traps)"]
    - [dec_mro_len,      "Decimal.__mro__.__len__",                   [],               2,    "decimal.Decimal.__mro__.__len__() == 2 (MRO: [Decimal, object]; Decimal directly subclasses object — same flat 2-entry MRO as Context, re.Pattern, and re.Match)"]
    - [ctx_mro_len,      "Context.__mro__.__len__",                   [],               2,    "decimal.Context.__mro__.__len__() == 2 (MRO: [Context, object]; Context also directly subclasses object)"]
    - [dec_module_eq,    Decimal.__module__.__eq__,                   ["decimal"],      true, "decimal.Decimal.__module__ == 'decimal' (the public module name)"]
    - [ctx_module_eq,    Context.__module__.__eq__,                   ["decimal"],      true, "decimal.Context.__module__ == 'decimal' (same as Decimal)"]

# ---------------------------------------------------------------------------
# decimal.Context method __qualname__ values not covered in decimal_extra141
# New: create_decimal_from_float=33 (longest in decimal), compare_total_mag=25,
# to_integral_exact/to_integral_value=25, compare_signal=22, create_decimal=22,
# logical_invert=22, remainder_near=22.
# ---------------------------------------------------------------------------

table decimal_extra144.Context_new_method_qualnames:
  description: "decimal.Context method __qualname__ values not in decimal_extra141: create_decimal_from_float=33 (longest), compare_total_mag=25, to_integral_exact/to_integral_value=25, logical_invert/compare_signal/create_decimal/remainder_near=22"
  kind: python_call_eq
  category: qualname
  id_prefix: decspec144

  columns: [id, function, args, expected, description]
  rows:
    - [cdfloat_qeq,  Context.create_decimal_from_float.__qualname__.__eq__, ["Context.create_decimal_from_float"], true, "decimal.Context.create_decimal_from_float.__qualname__ == 'Context.create_decimal_from_float' (len=33; converts a Python float to a Decimal exactly; the longest method qualname among all decimal classes)"]
    - [cdfloat_qlen, Context.create_decimal_from_float.__qualname__.__len__,[],                                    33,   "decimal.Context.create_decimal_from_float.__qualname__.__len__() == 33 ('Context.create_decimal_from_float' has 33 characters; 'Context.' (8) + 'create_decimal_from_float' (25) = 33; the longest qualname in the decimal module)"]
    - [ctmag_qeq,    Context.compare_total_mag.__qualname__.__eq__,         ["Context.compare_total_mag"],         true, "decimal.Context.compare_total_mag.__qualname__ == 'Context.compare_total_mag' (len=25; compare_total ignoring signs; tied with to_integral_exact and to_integral_value at 25)"]
    - [ctmag_qlen,   Context.compare_total_mag.__qualname__.__len__,        [],                                    25,   "decimal.Context.compare_total_mag.__qualname__.__len__() == 25 ('Context.compare_total_mag' has 25 characters; tied with to_integral_exact and to_integral_value)"]
    - [tiev_qeq,     Context.to_integral_value.__qualname__.__eq__,         ["Context.to_integral_value"],         true, "decimal.Context.to_integral_value.__qualname__ == 'Context.to_integral_value' (len=25; rounds to nearest integer using context rounding; tied with compare_total_mag and to_integral_exact)"]
    - [tiex_qeq,     Context.to_integral_exact.__qualname__.__eq__,         ["Context.to_integral_exact"],         true, "decimal.Context.to_integral_exact.__qualname__ == 'Context.to_integral_exact' (len=25; like to_integral_value but also signals Inexact/Rounded; tied with compare_total_mag and to_integral_value)"]
    - [csig_qeq,     Context.compare_signal.__qualname__.__eq__,            ["Context.compare_signal"],            true, "decimal.Context.compare_signal.__qualname__ == 'Context.compare_signal' (len=22; like compare but signals InvalidOperation if either operand is NaN; tied with create_decimal, logical_invert, remainder_near at 22)"]
    - [csig_qlen,    Context.compare_signal.__qualname__.__len__,           [],                                    22,   "decimal.Context.compare_signal.__qualname__.__len__() == 22 ('Context.compare_signal' has 22 characters; tied with create_decimal, logical_invert, and remainder_near)"]
    - [cdec_qeq,     Context.create_decimal.__qualname__.__eq__,            ["Context.create_decimal"],            true, "decimal.Context.create_decimal.__qualname__ == 'Context.create_decimal' (len=22; creates a new Decimal from value using this Context; tied at 22 with compare_signal, logical_invert, remainder_near)"]
    - [linv_qeq,     Context.logical_invert.__qualname__.__eq__,            ["Context.logical_invert"],            true, "decimal.Context.logical_invert.__qualname__ == 'Context.logical_invert' (len=22; bitwise inversion treating Decimal as a logical operand; tied at 22)"]
    - [rnear_qeq,    Context.remainder_near.__qualname__.__eq__,            ["Context.remainder_near"],            true, "decimal.Context.remainder_near.__qualname__ == 'Context.remainder_near' (len=22; IEEE 754 remainder: result has smallest absolute value; tied at 22 with compare_signal, create_decimal, logical_invert)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra144.loader.class_is_SourceFileLoader:
  description: "decimal.__loader__.__class__.__name__ == 'SourceFileLoader' (len=16) — decimal is a Python source file; its loader is a SourceFileLoader instance; same as pathlib and re; contrasts with io whose __loader__.__class__.__name__ == 'type' (because io uses FrozenImporter, which is a class not an instance)"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant decimal_extra144.spec.parent_empty:
  description: "decimal.__spec__.parent == '' (empty string) — decimal is a single-file top-level module, not a package; so __spec__.parent is empty; same as io.__spec__.parent == ''; differs from re.__spec__.parent == 're' and pathlib.__spec__.parent == 'pathlib'"
  category: identity
  kind: python_call_eq
  function: __spec__.parent.__eq__
  args: [""]
  expected: true

invariant decimal_extra144.package_empty:
  description: "decimal.__package__ == '' (empty string, len=0) — decimal is not a package; __package__ is '' for top-level non-package modules; io.__package__ is also ''; re.__package__ == 're' and pathlib.__package__ == 'pathlib' because they are packages"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant decimal_extra144.Decimal.dict_len_101:
  description: "decimal.Decimal.__dict__.__len__() == 101 — Decimal has 101 entries, the most of any class in this spec family (more than Context (85), re.Pattern (26), re.Match (21), pathlib.Path (62), io.TextIOWrapper (31)); the 101 entries reflect Decimal's extensive API: all arithmetic operators (__add__, __mul__, __truediv__, __floordiv__, __mod__, __pow__ and their reflected variants), comparison dunders, 8+ predicate methods, 5+ copy/conversion methods, and many more"
  category: identity
  kind: python_call_eq
  function: Decimal.__dict__.__len__
  args: []
  expected: 101

invariant decimal_extra144.Context.dict_len_85:
  description: "decimal.Context.__dict__.__len__() == 85 — Context has 85 entries; fewer than Decimal (101) because Context omits arithmetic operator dunders (__add__, __mul__, etc.) but includes Context-specific methods like create_decimal, create_decimal_from_float, Etiny, Etop, clear_flags, clear_traps, and all the Decimal methods mirrored with explicit context parameter"
  category: identity
  kind: python_call_eq
  function: Context.__dict__.__len__
  args: []
  expected: 85

invariant decimal_extra144.Context.create_decimal_from_float_qualname_len_33:
  description: "decimal.Context.create_decimal_from_float.__qualname__.__len__() == 33 ('Context.create_decimal_from_float' has 33 characters; the longest method qualname in the entire decimal module — longer than Decimal.compare_total_mag (25) and all other methods; 'Context.' (8) + 'create_decimal_from_float' (25) = 33)"
  category: qualname
  kind: python_call_eq
  function: Context.create_decimal_from_float.__qualname__.__len__
  args: []
  expected: 33

invariant decimal_extra144.Context.compare_total_mag_qualname_len_25:
  description: "decimal.Context.compare_total_mag.__qualname__.__len__() == 25 ('Context.compare_total_mag' has 25 characters; tied with to_integral_exact and to_integral_value; compare_total_mag compares the absolute values using total ordering, ignoring signs)"
  category: qualname
  kind: python_call_eq
  function: Context.compare_total_mag.__qualname__.__len__
  args: []
  expected: 25

invariant decimal_extra144.Decimal.mro_len_2:
  description: "decimal.Decimal.__mro__.__len__() == 2 (MRO: [Decimal, object]) — Decimal directly subclasses object; the same flat 2-entry MRO as decimal.Context, re.Pattern, re.Match, and pathlib.PurePath; this contrasts with io.IOBase (3), io.BytesIO (4), and re.RegexFlag (7)"
  category: identity
  kind: python_call_eq
  function: "Decimal.__mro__.__len__"
  args: []
  expected: 2

