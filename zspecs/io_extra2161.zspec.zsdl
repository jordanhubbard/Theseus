# ---------------------------------------------------------------------------
# io.StringIO — descriptor protocol dict-presence and concrete attr presence
#
# StringIO exposes getset_descriptor attributes (closed, newlines,
# line_buffering) but does NOT define __get__, fget, __objclass__, etc.
# in the class's own __dict__.
# ---------------------------------------------------------------------------

table io_extra2161.StringIO_descriptor_presence:
  kind: python_call_eq
  category: descriptor_presence
  columns: [id, function, args, expected]
  rows:
    - ["io2161030", "io.StringIO.__dict__.__contains__", ["__get__"], false]
    - ["io2161031", "io.StringIO.__dict__.__contains__", ["__set__"], false]
