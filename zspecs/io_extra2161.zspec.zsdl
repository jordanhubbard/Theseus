    - ["io2161035", "io.StringIO.__dict__.__contains__", ["fset"], false]
    - ["io2161036", "io.StringIO.__dict__.__contains__", ["fdel"], false]
    - ["io2161037", "io.StringIO.__dict__.__contains__", ["__objclass__"], false]
    - ["io2161038", "io.StringIO.__dict__.__contains__", ["__func__"], false]
    - ["io2161039", "io.StringIO.__dict__.__contains__", ["read"], true]
    - ["io2161040", "io.StringIO.__dict__.__contains__", ["write"], true]
    - ["io2161041", "io.StringIO.__dict__.__contains__", ["closed"], true]
