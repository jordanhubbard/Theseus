spec: io_extra2161
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/io.py"
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "Theme: descriptor protocol dict-presence — checks for __get__, __set__, __delete__, __set_name__, fget, fset, fdel, __objclass__, __func__ in class __dict__."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, and io.TextIOBase are abstract base classes and do not define any descriptor protocol methods in their own __dict__."
    - "io.StringIO, io.BytesIO, and io.FileIO are concrete C-implemented classes; they expose getset_descriptor and member_descriptor attributes (e.g., closed, mode, newlines) but do not themselves define __get__, __set__, __delete__, fget, fset, fdel, __set_name__, __objclass__, or __func__."
    - "The descriptors (closed, mode, etc.) are instances of getset_descriptor or member_descriptor — the descriptor protocol methods live on the descriptor type, not on the io class itself."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.IOBase — descriptor protocol dict-presence
# ---------------------------------------------------------------------------

table io_extra2161.IOBase_descriptor_presence:
  kind: python_call_eq
  category: descriptor_presence
  columns: [id, function, args, expected]
  rows:
    - ["io2161001", "io.IOBase.__dict__.__contains__", ["__get__"], false]
    - ["io2161002", "io.IOBase.__dict__.__contains__", ["__set__"], false]
    - ["io2161003", "io.IOBase.__dict__.__contains__", ["__delete__"], false]
    - ["io2161004", "io.IOBase.__dict__.__contains__", ["__set_name__"], false]
    - ["io2161005", "io.IOBase.__dict__.__contains__", ["fget"], false]
    - ["io2161006", "io.IOBase.__dict__.__contains__", ["fset"], false]
    - ["io2161007", "io.IOBase.__dict__.__contains__", ["fdel"], false]
    - ["io2161008", "io.IOBase.__dict__.__contains__", ["__objclass__"], false]
    - ["io2161009", "io.IOBase.__dict__.__contains__", ["__func__"], false]

