spec: lodash_keys
version: ">=4.0.0"
backend: node(lodash.keys)

docs: https://lodash.com/docs/#keys

provenance:
  derived_from:
    - "lodash.keys README — https://www.npmjs.com/package/lodash.keys"
    - "Test vectors verified with lodash.keys@4.2.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.keys exports the _.keys function directly as module.exports."
    - "keys(object) returns an array of the object's own enumerable property names."
    - "Key order follows insertion order for string keys."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array of own enumerable keys."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_keys.keys:
  kind: node_module_call_eq
  function: ~
  category: keys
  id_prefix: lkeys

  columns: [id, args, expected]
  rows:
    - [basic,  [{"a": 1, "b": 2, "c": 3}],  ["a", "b", "c"]]
    - [one,    [{"x": 42}],                   ["x"]]
    - [empty,  [{}],                           []]
